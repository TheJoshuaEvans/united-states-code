{"tag":"section","attrib":{"id":"id56be31eb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182"},"text":null,"children":[{"tag":"num","attrib":{"value":"2182"},"text":"§ 2182.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multirater assessment of certain personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56be31ec-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multirater Assessment of Certain Personnel.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56be31ed-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Commencing not later than one year after the date of the enactment of the Coast Guard Authorization Act of 2016, the Commandant shall develop and implement a plan to conduct every two years a multirater assessment for each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56be31ee-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each flag officer of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56be31ef-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the Senior Executive Service of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56be31f0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each officer of the Coast Guard nominated for promotion to the grade of flag officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56be31f1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each officer of the Coast Guard shall undergo a multirater assessment before promotion to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56be31f2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grade of O–4;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56be31f3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grade of O–5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56be31f4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grade of O–6.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56be31f5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enlisted members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each enlisted member of the Coast Guard shall undergo a multirater assessment before advancement to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56be31f6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grade of E–7;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56be31f7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grade of E–8;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56be31f8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grade of E–9; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56be31f9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grade of E–10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56be31fa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual assessed shall not be permitted to select the peers and subordinates who provide opinions for the multirater assessment of such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56be31fb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Post-assessment elements.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56be31fc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Following an assessment of an individual pursuant to paragraphs (1) through (3), the individual shall be provided appropriate post-assessment counseling and leadership coaching.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56be31fd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of results","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The supervisor of the individual assessed shall be provided with the results of the multirater assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56be31fe-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2182/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multirater Assessment Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “multirater assessment” means a review that seeks opinion from members senior to the reviewee and the peers and subordinates of the reviewee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56be31ff-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s214/a/1"},"text":"Pub. L. 114–120, title II, § 214(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/43"},"text":"130 Stat. 43","children":[],"tail":", § 429; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3503/a"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2775"},"text":"130 Stat. 2775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3531/c/12"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3531(c)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2320"},"text":"132 Stat. 2320","children":[],"tail":"; renumbered § 2182, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s112/b"},"text":"Pub. L. 115–282, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXII/s11244/a"},"text":"Pub. L. 117–263, div. K, title CXII, § 11244(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4042"},"text":"136 Stat. 4042","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56be3200-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56be3201-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56be3202-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Coast Guard Authorization Act of 2016, referred to in subsec. (a)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56be3203-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added pars. (2) to (5) and struck out former par. (2). Prior to amendment, text of par. (2) read as follows: “Following an assessment of an individual pursuant to paragraph (1), the individual shall be provided appropriate post-assessment counseling and leadership coaching.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s429"},"text":"section 429 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “Commandant” for “Commandant of the Coast Guard” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “Coast Guard Authorization Act of 2016” for “Coast Guard Authorization Act of 2015”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56be3204-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id56be3205-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3503/e"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3503(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2775"},"text":"130 Stat. 2775","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/328/dC/tXXXV/s3503/e"},"text":"“The amendments made by this section [amending this section, sections 315, 676a, and 2702 of this title, sections 3104, 4503, and 7510 of Title 46, Shipping, and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1151"},"text":"section 1151 of Title 16","children":[],"tail":", Conservation] shall take effect as if included in the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Public Law 114–120","children":[],"tail":" ["},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
