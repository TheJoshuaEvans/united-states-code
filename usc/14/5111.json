{"tag":"section","attrib":{"id":"id56df755a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5111"},"text":null,"children":[{"tag":"num","attrib":{"value":"5111"},"text":"§ 5111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on diversity at Coast Guard Academy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56df755b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2021-01-15"},"text":"January 15, 2021","children":[],"tail":", and annually thereafter, the Commandant shall submit a report on diversity at the Coast Guard Academy to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56df755c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56df755d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the implementation of the plan required under section 8272 of the Elijah E. Cummings Coast Guard Authorization Act of 2020;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df755e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific information on outreach and recruitment activities for the preceding year, including the effectiveness of the Coast Guard Academy minority outreach team program described under section 1905 and of outreach and recruitment activities in the territories and other possessions of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df755f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5111/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrollment information about the incoming class, including the gender, race, ethnicity, religion, socioeconomic background, and State of residence of Coast Guard Academy cadets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df7560-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5111/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on class retention, outcomes, and graduation rates, including the race, gender, ethnicity, religion, socioeconomic background, and State of residence of Coast Guard Academy cadets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df7561-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5111/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on efforts to retain diverse cadets, including through professional development and professional advancement programs for staff and faculty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df7562-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5111/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of reported allegations of discrimination on the basis of race, color, national origin, sex, gender, or religion for the preceding 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56df7563-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8273, "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4683"},"text":"134 Stat. 4683","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56df7564-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56df7565-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56df7566-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 8272 of the Elijah E. Cummings Coast Guard Authorization Act of 2020, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8272"},"text":"section 8272 of Pub. L. 116–283","children":[],"tail":", div. G, title LVXXXII [LXXXII], "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","