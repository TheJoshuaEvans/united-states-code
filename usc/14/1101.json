{"tag":"section","attrib":{"id":"id56a8ad28-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1101"},"text":null,"children":[{"tag":"num","attrib":{"value":"1101"},"text":"§ 1101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition directorate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a8ad29-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall establish an acquisition directorate to provide guidance and oversight for the implementation and management of all Coast Guard acquisition processes, programs, and projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8ad2a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mission","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The mission of the acquisition directorate is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8ad2b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire and deliver assets and systems that increase operational readiness, enhance mission performance, and create a safe working environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ad2c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in the development of a workforce that is trained and qualified to further the Coast Guard’s missions and deliver the best-value products and services to the Nation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ad2d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1101/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet the needs of customers of major acquisition programs in the most cost-effective manner practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a8ad2e-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIV/s402/a"},"text":"Pub. L. 111–281, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2931"},"text":"124 Stat. 2931","children":[],"tail":", § 561; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s899/b/1/A"},"text":"Pub. L. 114–328, div. A, title VIII, § 899(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2333"},"text":"130 Stat. 2333","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3531/c/6"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3531(c)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2320"},"text":"132 Stat. 2320","children":[],"tail":"; renumbered § 1101, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s108/b"},"text":"Pub. L. 115–282, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4208"},"text":"132 Stat. 4208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a8ad2f-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a8ad30-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a8ad31-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s561"},"text":"section 561 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “Commandant” for “Commandant of the Coast Guard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56a8ad32-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56a8ad33-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Review Required","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s899/c"},"text":"Pub. L. 114–328, div. A, title VIII, § 899(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2335"},"text":"130 Stat. 2335","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/328/dA/tVIII/s899/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant of the Coast Guard shall conduct a review of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authorities provided to the Commandant in [former] chapter 15 of title 14, United States Code [see, now, chapter 11, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s1101"},"text":"14 U.S.C. 1101","children":[],"tail":" et seq.], and other relevant statutes and regulations related to Coast Guard acquisitions, including developing recommendations to ensure that the Commandant plays an appropriate role in the development of requirements, acquisition processes, and the associated budget practices;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation of the strategy prepared in accordance with section 562(b)(2) [now 1102(b)(2)] of title 14, United States Code, as in effect before the enactment of the National Defense Authorization Act for Fiscal Year 2017 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":", see Tables for classification]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition policies, directives, and regulations of the Coast Guard to ensure such policies, directives, and regulations establish a customer-oriented acquisition system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2017-03-01"},"text":"March 1, 2017","children":[],"tail":", the Commandant shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a report containing, at a minimum, the following:"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The recommendations developed by the Commandant under paragraph (1) and other results of the review conducted under such paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The actions the Commandant is taking, if any, within the Commandant’s existing authority to implement such recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modification of policies, directives, and regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":"], the Commandant of the Coast Guard shall modify the acquisition policies, directives, and regulations of the Coast Guard as necessary to ensure the development and implementation of a customer-oriented acquisition system, pursuant to the review under paragraph (1)(C).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
