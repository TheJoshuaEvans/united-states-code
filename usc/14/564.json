"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7269/a/2"},"text":"Pub. L. 119–60, § 7269(a)(2)","children":[],"tail":", transferred "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11272/c/5"},"text":"section 11272(c)(5) of Pub. L. 117–263","children":[],"tail":" to this section and redesignated it as subsec. (b). See Codification note above. Heading was editorially conformed to the style used for subsection headings in this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id569cc71f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id569cc720-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Annual Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXII/s11272/c/5"},"text":"Pub. L. 117–263, div. K, title CXII, § 11272(c)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4067"},"text":"136 Stat. 4067","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7269/a/1"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7269(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1745"},"text":"139 Stat. 1745","children":[],"tail":", formerly set out as a note under this section, was transferred to subsec. (b) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
