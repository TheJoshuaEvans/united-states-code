{"tag":"section","attrib":{"id":"id569cc70a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s564"},"text":null,"children":[{"tag":"num","attrib":{"value":"564"},"text":"§ 564.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of sexual assault forensic examination kits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id569cc70b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s564/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sexual Assault Forensic Exam Procedure.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id569cc70c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s564/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before embarking on any prescheduled voyage, a Coast Guard vessel shall have in place a written operating procedure that ensures that an embarked victim of sexual assault shall have access to a sexual assault forensic examination—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id569cc70d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s564/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as soon as possible after the victim requests an examination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569cc70e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s564/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is treated with the same level of urgency as emergency medical care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569cc70f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s564/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The written operating procedure required by paragraph (1) shall, at a minimum, account for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id569cc710-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s564/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health, safety, and privacy of a victim of sexual assault;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569cc711-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s564/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proximity of ashore or afloat medical facilities, including coordination as necessary with the Department of Defense, including other military departments (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of title 10","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569cc712-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s564/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of aeromedical evacuation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569cc713-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s564/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operational capabilities of the vessel concerned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569cc714-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s564/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the qualifications of medical personnel onboard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569cc715-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s564/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination with law enforcement and the preservation of evidence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569cc716-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s564/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the means of accessing a sexual assault forensic examination and medical care with a restricted report of sexual assault;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569cc717-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s564/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of nonprescription pregnancy prophylactics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569cc718-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s564/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other unique military considerations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569cc719-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s564/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall submit to the Transportation and Infrastructure Committee of the House of Representatives and the Commerce, Science, and Transportation Committee of the Senate a report containing the number of sexual assault forensic examinations that were requested by, but not administered within 3 days to, alleged victims of sexual assault when such victims were onboard a Coast Guard vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id569cc71a-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXII/s11272/a"},"text":"Pub. L. 117–263, div. K, title CXII, § 11272(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4066"},"text":"136 Stat. 4066","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7269/a/2"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7269(a)(2)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1745"},"text":"139 Stat. 1745","children":[],"tail":", 1746.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569cc71b-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569cc71c-2930-11f1-