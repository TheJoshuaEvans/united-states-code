{"tag":"section","attrib":{"id":"id569a5690-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s547"},"text":null,"children":[{"tag":"num","attrib":{"value":"547"},"text":"§ 547.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rewards for apprehension of persons interfering with aids to navigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Coast Guard may offer and pay rewards for the apprehension and conviction, or for information helpful therein, of persons found interfering in violation of law with aids to navigation maintained by the Coast Guard; or for information leading to the discovery of missing Coast Guard property or to recovery thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id569a5691-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/547"},"text":"63 Stat. 547","children":[],"tail":", § 643; renumbered § 547, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s105/b"},"text":"Pub. L. 115–282, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4200"},"text":"132 Stat. 4200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569a5692-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id569a5693-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 50c (","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch756/s32"},"text":"Aug. 2, 1946, ch. 756, § 32","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/857"},"text":"60 Stat. 857","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is enlarged to provide for payment of rewards for information leading to the discovery or recovery of missing Coast Guard property. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569a5694-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id569a5695-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s643"},"text":"section 643 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
