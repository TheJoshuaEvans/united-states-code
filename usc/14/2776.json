{"tag":"section","attrib":{"id":"id56ced37d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2776"},"text":null,"children":[{"tag":"num","attrib":{"value":"2776"},"text":"§ 2776.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments at time of discharge for good of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Enlisted members discharged by dishonorable discharge, bad-conduct discharge, or any other discharge for the good of the service, may, upon discharge, be paid a sum not to exceed $25. The sum paid shall be fixed by and in the discretion of the Commandant, and shall be paid only in cases where the individual so discharged would otherwise be without funds to meet his immediate needs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56ced37e-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/533"},"text":"63 Stat. 533","children":[],"tail":", § 481; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/3/C"},"text":"Pub. L. 98–557, § 15(a)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":"; renumbered § 2776, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(44), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4750"},"text":"134 Stat. 4750","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ced37f-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56ced380-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Derived from title 34, U.S.C., 1946 ed., § 197, and title 14, U.S.C., 1946 ed., § 3a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-04/ch536/s10"},"text":"Mar. 4, 1925, ch. 536, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1274"},"text":"43 Stat. 1274","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-26/ch623"},"text":"Oct. 26, 1942, ch. 623","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/987"},"text":"56 Stat. 987","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said section 197 was made applicable to the Coast Guard by title 14, U.S.C., 1946 ed., § 3a whenever the Coast Guard is operating with the Navy. Experience has shown the advantage of having such a provision applicable to the Coast Guard at all times.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said section would in no way be affected. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ced381-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ced382-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “individual” for “person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s481"},"text":"section 481 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted “Enlisted members” for “Enlisted men”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
