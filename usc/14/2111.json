{"tag":"section","attrib":{"id":"id56b7058a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2111"},"text":null,"children":[{"tag":"num","attrib":{"value":"2111"},"text":"§ 2111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion zones","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56b7058b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before convening a selection board to recommend officers for promotion to any grade above lieutenant (junior grade) and below rear admiral (lower half), the Secretary shall establish a promotion zone for the grade to be considered. The promotion zone for each grade shall consist of the most senior officers of that grade on the active duty promotion list who are eligible for consideration for promotion to the next higher grade and who have not previously been placed in a promotion zone for selection for promotion to the next higher grade. The number of officers in each zone shall be determined after considering—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b7058c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of the service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b7058d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated numbers of vacancies available in future years to provide comparable opportunity for promotion of officers in successive year groups; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b7058e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2111/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which current terms of service in that grade conform to a desirable career promotion pattern.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"However, such number of officers shall not exceed the number to be selected for promotion divided by one-half.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b7058f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promotion zones from which officers will be selected for promotion to the grade of rear admiral (lower half) shall be established by the Secretary as the needs of the service require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56b70590-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/179"},"text":"77 Stat. 179","children":[],"tail":", § 256; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/444/s1/16"},"text":"Pub. L. 89–444, § 1(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-06-09"},"text":"June 9, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/196"},"text":"80 Stat. 196","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/417/s2/3"},"text":"Pub. L. 97–417, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-04"},"text":"Jan. 4, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2085"},"text":"96 Stat. 2085","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tV/s514/c/1"},"text":"Pub. L. 99–145, title V, § 514(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/629"},"text":"99 Stat. 629","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIII/s1343/c"},"text":"Pub. L. 99–661, div. A, title XIII, § 1343(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3995"},"text":"100 Stat. 3995","children":[],"tail":"; renumbered § 2111 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s112/b"},"text":"Pub. L. 115–282, title I, § 112(b)","children":[],"tail":", title III, § 312, "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":", 4249.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56b70591-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56b70592-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56b70593-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s112/b"},"text":"Pub. L. 115–282, § 112(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s256"},"text":"section 256 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s312"},"text":"Pub. L. 115–282, § 312","children":[],"tail":", substituted “one-half.” for “six-tenths.” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" substituted “rear admiral (lower half)” for “commodore”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" substituted “rear admiral (lower half)” for “commodore”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/417"},"text":"Pub. L. 97–417","children":[],"tail":" substituted “commodore” for “rear admiral”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/444"},"text":"Pub. L. 89–444","children":[],"tail":" limited promotion zone by requiring that list of officers under consideration be officers eligible for consideration for promotion to next higher grade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
