{"tag":"section","attrib":{"id":"id56a18267-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s902"},"text":null,"children":[{"tag":"num","attrib":{"value":"902"},"text":"§ 902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment of draftsmen and engineers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Coast Guard may employ temporarily, at the seat of government, draftsmen and engineers for the preparation of plans and specifications for vessels, lighthouses, aids to navigation, and other projects for the Coast Guard that may be authorized or appropriated for by Congress, to be paid from the appropriations applicable to such projects.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56a18268-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/550"},"text":"63 Stat. 550","children":[],"tail":", § 653; renumbered § 902, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s107/b"},"text":"Pub. L. 115–282, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4205"},"text":"132 Stat. 4205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a18269-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56a1826a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 33, U.S.C., 1946 ed., § 716 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1910-06-17/ch301/s9"},"text":"June 17, 1910, ch. 301, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/538"},"text":"36 Stat. 538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-07-27/ch388/s1"},"text":"July 27, 1939, ch. 388, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1130"},"text":"53 Stat. 1130","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a1826b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a1826c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s653"},"text":"section 653 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
