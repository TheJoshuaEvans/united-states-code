{"tag":"section","attrib":{"id":"id56d1454a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924"},"text":null,"children":[{"tag":"num","attrib":{"value":"2924"},"text":"§ 2924.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child development center employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d1454b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d1454c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall establish a training program for Coast Guard child development center employees and satisfactory completion of the training program shall be a condition of employment for each employee of a Coast Guard child development center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d1454d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing for new hires","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall require each employee of a Coast Guard child development center to complete the training program established under paragraph (1) not later than 6 months after the date on which the employee is hired.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d1454e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The training program established under paragraph (1) shall include, at a minimum, instruction with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56d1454f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early childhood development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d14550-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities and disciplinary techniques appropriate to children of different ages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d14551-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" child abuse and neglect prevention and detection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d14552-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cardiopulmonary resuscitation and other emergency medical procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d14553-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of department of defense programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant may use Department of Defense training programs, on a reimbursable or nonreimbursable basis, for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d14554-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training and Curriculum Specialists.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d14555-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specialist required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall require that at least 1 employee at each Coast Guard child development center be a specialist in training and curriculum development with appropriate credentials and experience.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d14556-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the specialist described in paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56d14557-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special teaching activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d14558-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" daily oversight and instruction of other child care employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d14559-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" daily assistance in the preparation of lesson plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d1455a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting with child abuse and neglect prevention and detection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d1455b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advising the director of the center on the performance of the other child care employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d1455c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2924/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Competitive service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each specialist described in paragraph (1) shall be an employee in a competitive service position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d1455d-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s214/a"},"text":"Pub. L. 113–281, title II, § 214(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3032"},"text":"128 Stat. 3032","children":[],"tail":", § 554; renumbered § 2924, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s117/b"},"text":"Pub. L. 115–282, title I, § 117(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4230"},"text":"132 Stat. 4230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d1455e-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d1455f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d14560-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s554"},"text":"section 554 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
