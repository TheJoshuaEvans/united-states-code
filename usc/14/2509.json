{"tag":"section","attrib":{"id":"id56c2ed0e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2509"},"text":null,"children":[{"tag":"num","attrib":{"value":"2509"},"text":"§ 2509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of certain involuntary administrative separations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56c2ed0f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), the Secretary may not authorize the involuntary administrative separation of a covered individual based on a determination that the covered individual is unsuitable for deployment or other assignment due to a medical condition of the covered individual considered by a Physical Evaluation Board during an evaluation of the covered individual that resulted in the covered individual being determined to be fit for duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c2ed10-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reevaluation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c2ed11-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2509/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may require a Physical Evaluation Board to reevaluate any covered individual if the Secretary determines there is reason to believe that a medical condition of the covered individual considered by a Physical Evaluation Board during an evaluation of the covered individual renders the covered individual unsuitable for continued duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c2ed12-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2509/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retirements and separations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A covered individual who is determined, based on a reevaluation under paragraph (1), to be unfit to perform the duties of the covered individual’s office, grade, rank, or rating may be retired or separated for physical disability under chapter 61 of title 10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c53603-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2509/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Individual Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “covered individual” means any member of the Coast Guard who has been determined by a Physical Evaluation Board, pursuant to a physical evaluation by that board, to be fit for duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56c53604-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/tII/s209/a"},"text":"Pub. L. 112–213, title II, § 209(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1549"},"text":"126 Stat. 1549","children":[],"tail":", § 427; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s209/6"},"text":"Pub. L. 114–120, title II, § 209(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/41"},"text":"130 Stat. 41","children":[],"tail":"; renumbered § 2509, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s114/b"},"text":"Pub. L. 115–282, title I, § 114(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4223"},"text":"132 Stat. 4223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c53605-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c53606-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c53607-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s427"},"text":"section 427 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":" substituted “chapter 61 of title 10” for “this chapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
