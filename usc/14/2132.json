{"tag":"section","attrib":{"id":"id56bbc0c8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2132"},"text":null,"children":[{"tag":"num","attrib":{"value":"2132"},"text":"§ 2132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of officers with particular expertise in military justice or healthcare","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56bbc0c9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary Designation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may designate a limited number of officers of the Coast Guard as having particular expertise in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56bbc0ca-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2132/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military justice; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56bbc0cb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2132/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" healthcare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56bbc0cc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Promotion and Grade","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual designated under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56bbc0cd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2132/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be included on the active duty promotion list;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56bbc0ce-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2132/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be promoted under section 2126; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56bbc0cf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2132/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be promoted to a grade higher than captain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56bbc0d0-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7221/a"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1699"},"text":"139 Stat. 1699","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
