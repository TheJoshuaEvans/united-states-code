{"tag":"section","attrib":{"id":"id56b494f5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1946"},"text":null,"children":[{"tag":"num","attrib":{"value":"1946"},"text":"§ 1946.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit for service as member of civilian teaching staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Service as a member of the civilian teaching staff at the Academy in addition to creditable services authorized by any other law in any of the military services rendered prior to an appointment as professor, associate professor, assistant professor, or instructor shall be credited in computing length of service as a professor, associate professor, assistant professor, or instructor for purposes of pay and allowances.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56b494f6-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/510"},"text":"63 Stat. 510","children":[],"tail":", § 191; "},{"tag":"ref","attrib":{"href":"/us/pl/86/474/s1/14"},"text":"Pub. L. 86–474, § 1(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-05-14"},"text":"May 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/146"},"text":"74 Stat. 146","children":[],"tail":"; renumbered § 1946, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s110/b"},"text":"Pub. L. 115–282, title I, § 110(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4212"},"text":"132 Stat. 4212","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56b494f7-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56b494f8-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 15e (","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-04-16/ch107/s4"},"text":"Apr. 16, 1937, ch. 107, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/67"},"text":"50 Stat. 67","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made in order to adapt the section to the new structure of the permanent commissioned teaching staff. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56b494f9-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56b494fa-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s191"},"text":"section 191 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/474"},"text":"Pub. L. 86–474","children":[],"tail":" substituted “member of civilian teaching staff” for “civilian instructor” in section catchline, and “member of the civilian teaching staff” for “civilian instructor or civilian librarian” in text, and struck out “commissioned” before “instructor” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
