{"tag":"section","attrib":{"id":"id569a566d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s542"},"text":null,"children":[{"tag":"num","attrib":{"value":"542"},"text":"§ 542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unauthorized aids to maritime navigation; penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person, or public body, or instrumentality, excluding the armed services, shall establish, erect, or maintain any aid to maritime navigation in or adjacent to the waters subject to the jurisdiction of the United States, its territories or possessions, or the Trust Territory of the Pacific Islands, or on the high seas if that person, or public body, or instrumentality is subject to the jurisdiction of the United States, without first obtaining authority to do so from the Coast Guard in accordance with applicable regulations. Whoever violates the provisions of this section or any of the regulations issued by the Secretary in accordance herewith shall be guilty of a misdemeanor and shall be fined not more than $1,500 for each offense. Each day during which such violation continues shall be considered as a new offense.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id569a566e-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/500"},"text":"63 Stat. 500","children":[],"tail":", § 83; "},{"tag":"ref","attrib":{"href":"/us/pl/93/283/s1/1"},"text":"Pub. L. 93–283, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-14"},"text":"May 14, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/139"},"text":"88 Stat. 139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s205/a/1"},"text":"Pub. L. 113–281, title 