{"tag":"section","attrib":{"id":"id56c07b6f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2317"},"text":null,"children":[{"tag":"num","attrib":{"value":"2317"},"text":"§ 2317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aviation cadets; procurement; transfer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56c07b70-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2317/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The grade of aviation cadet is established as a special enlisted grade in the Coast Guard. Under such regulations as the Secretary prescribes, citizens in civil life may be enlisted as, and enlisted members of the Coast Guard with their consent may be designated as, aviation cadets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c07b71-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2317/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except in time of war or national emergency declared by Congress, not less than 20 percent of the aviation cadets procured in each fiscal year shall be procured from qualified enlisted members of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c07b72-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2317/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No individuals may be enlisted or designated as an aviation cadet unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c07b73-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2317/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual agrees in writing that, upon successful completion of the course of training as an aviation cadet, the individual will accept a commission as an ensign in the Coast Guard Reserve and will serve on active duty as such for at least three years, unless sooner released; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c07b74-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2317/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if under twenty-one years of age, the individual has the consent of the individual’s parent or guardian to the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c07b75-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2317/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under such regulations as the Secretary prescribes, an aviation cadet may be transferred to another enlisted grade or rating in the Coast Guard, released from active duty, or discharged.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56c07b76-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/444/s1/20"},"text":"Pub. L. 89–444, § 1(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-06-09"},"text":"June 9, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/196"},"text":"80 Stat. 196","children":[],"tail":", § 371; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s2/11"},"text":"Pub. L. 97–295, § 2(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1302"},"text":"96 Stat. 1302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/1"},"text":"Pub. L. 98–557, § 15(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2864"},"text":"98 Stat. 2864","children":[],"tail":"; renumbered § 2317, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s113/b"},"text":"Pub. L. 115–282, title I, § 113(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4221"},"text":"132 Stat. 4221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(20), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4748"},"text":"134 Stat. 4748","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c07b77-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c07b78-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c07b79-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8505/a/20/A"},"text":"Pub. L. 116–283, § 8505(a)(20)(A)","children":[],"tail":", substituted “individuals” for “persons” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8505/a/20/B"},"text":"Pub. L. 116–283, § 8505(a)(20)(B)","children":[],"tail":", substituted “individual” for “person” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8505/a/20/B"},"text":"Pub. L. 116–283, § 8505(a)(20)(B)","children":[],"tail":", (C), substituted “individual” for “person” and “individual’s” for “person’s”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s371"},"text":"section 371 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/1/A"},"text":"Pub. L. 98–557, § 15(a)(1)(A)","children":[],"tail":", struck out “male” before “citizens” and “enlisted members”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/1/B"},"text":"Pub. L. 98–557, § 15(a)(1)(B)","children":[],"tail":", substituted “the person” for “he” in two places and struck out “his” after “upon”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/1/C"},"text":"Pub. L. 98–557, § 15(a)(1)(C)","children":[],"tail":", substituted “the person” for “he”, “the person’s” for “his”, and “the agreement” for “his agreement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “percent” for “per centum”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
