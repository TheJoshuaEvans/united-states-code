{"tag":"section","attrib":{"id":"id569f10db-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s718"},"text":null,"children":[{"tag":"num","attrib":{"value":"718"},"text":"§ 718.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training; emergency response providers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id569f10dc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s718/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant may, on a reimbursable or a non-reimbursable basis, make a training available to emergency response providers whenever the Commandant determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id569f10dd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s718/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Coast Guard, who is scheduled to participate in such training, is unable or unavailable to participate in such training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10de-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s718/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no other member of the Coast Guard, who is assigned to the unit to which the member of the Coast Guard who is unable or unavailable to participate in such training is assigned, is able or available to participate in such training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10df-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s718/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such training, if made available to such emergency response providers, would further the goal of interoperability among Federal agencies, non-Federal governmental agencies, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f10e0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s718/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Emergency Response Providers Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “emergency response providers” has the meaning given that term in section 2 of the Homeland Security Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"6 U.S.C. 101","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f10e1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s718/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reimbursements for a training that the Coast Guard receives under this section shall be credited to the appropriation used to pay the costs for such training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f10e2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s718/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Status; Limitation on Liability.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id569f10e3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s718/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Status","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any individual to whom, as an emergency response provider, training is made available under this section, who is not otherwise a Federal employee, shall not, because of that training, be considered a Federal employee for any purpose (including the purposes of chapter 81 of title 5 (relating to compensation for injury) and sections 2671 through 2680 of title 28 (relating to tort claims)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10e4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s718/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on liability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The United States shall not be liable for actions taken by an individual in the course of training made available under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id569f10e5-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIII/s306/a"},"text":"Pub. L. 115–282, title III, § 306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4247"},"text":"132 Stat. 4247","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
