,"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Aids to navigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id567b5c74-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s102/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Living marine resources (fisheries law enforcement).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id567b5c75-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s102/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Marine environmental protection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id567b5c76-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s102/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ice operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id567b5c77-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Homeland security missions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “homeland security missions” means the following missions of the Coast Guard:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id567dcd78-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s102/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ports, waterways and coastal security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id567dcd79-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s102/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Drug interdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id567dcd7a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s102/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Migrant interdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id567dcd7b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s102/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Defense readiness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id567dcd7c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s102/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other law enforcement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id567dcd7d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Primary Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Coast Guard shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id567dcd7e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforce or assist in the enforcement of all applicable Federal laws on, under, and over the high seas and waters subject to the jurisdiction of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id567dcd7f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in maritime air surveillance or interdiction to enforce or assist in the enforcement of the laws of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id567dcd80-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s102/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer laws and promulgate and enforce regulations for the promotion of safety of life and property on and under the high seas and waters subject to the jurisdiction of the United States, covering all matters not specifically delegated by law to some other executive department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id567dcd81-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s102/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, establish, maintain, and operate, with due regard to the requirements of national defense, aids to maritime navigation, icebreaking facilities, and rescue facilities for the promotion of safety on, under, and over the high seas and waters subject to the jurisdiction of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id567dcd82-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s102/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to international agreements, develop, establish, maintain, and operate icebreaking facilities on, under, and over waters other than the high seas and waters subject to the jurisdiction of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id567dcd83-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s102/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in oceanographic research of the high seas and in waters subject to the jurisdiction of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id567dcd84-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s102/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a state of readiness to assist in the defense of the United States, including when functioning as a specialized service in the Navy pursuant to section 103.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id567dcd85-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/496"},"text":"63 Stat. 496","children":[],"tail":", § 2; "},{"tag":"ref","attrib":{"href":"/us/pl/87/396/s1"},"text":"Pub. L. 87–396, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-10-05"},"text":"Oct. 5, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/827"},"text":"75 Stat. 827","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/278/s1/1"},"text":"Pub. L. 91–278, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"19