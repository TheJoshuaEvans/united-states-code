 1932, ch. 314, § 501","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/415"},"text":"47 Stat. 415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-05-27/ch463/s1"},"text":"May 27, 1936, ch. 463, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1380"},"text":"49 Stat. 1380","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1937-08-16/ch665/s3"},"text":"Aug. 16, 1937, ch. 665, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/667"},"text":"50 Stat. 667","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1941-02-19/ch8"},"text":"Feb. 19, 1941, ch. 8","children":[],"tail":", §§ 2, 201, "},{"tag":"ref","attrib":{"href":"/us/stat/55/9"},"text":"55 Stat. 9","children":[],"tail":", 11; "},{"tag":"ref","attrib":{"href":"/us/act/1941-07-11/ch290/s7"},"text":"July 11, 1941, ch. 290, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/585"},"text":"55 Stat. 585","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-11-23/ch639/s2/2"},"text":"Nov. 23, 1942, ch. 639, § 2(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/102"},"text":"56 Stat. 102","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1944-09-30/ch453/s1"},"text":"Sept. 30, 1944, ch. 453, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/759"},"text":"58 Stat. 759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-22/ch600"},"text":"June 22, 1948, ch. 600","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/574"},"text":"62 Stat. 574","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-26/ch672"},"text":"June 26, 1948, ch. 672","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1050"},"text":"62 Stat. 1050","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section contains a codification of functions. It sets forth in general language the primary responsibilities of the Coast Guard: enforcement of all Federal laws on waters to which they have application, safety of life and property at sea, aiding navigation, and readiness to function with the Navy. Having been created in 1915 by the consolidation of the Revenue Cutter Service and the Life Saving Service, the Coast Guard has gradually been given additional duties and responsibilities, such as the assignment of law enforcement powers on the high seas and navigable waters in 1936, the transfer of the Lighthouse Service in 1939, and the transfer of the Bureau of Marine Inspection and Navigation in 1942. Existing along with these other duties has been that of maintaining a state of readiness as a specialized service prepared for active participation with the Navy in time of war. These various interdependent functions of the Service have not been expressed collectively in any statute heretofore, but it is believed desirable to do so in this revision in order to have outlined in general terms in one section the broad scope of the functions of the Coast Guard. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id567dcd88-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id567dcd89-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s468/a"},"text":"section 468(a) of Title 6","children":[],"tail":", Domestic Security, which was transferred to subsec. (a) of this section by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/j/2"},"text":"Pub. L. 119–60, § 7201(j)(2)","children":[],"tail":", is based on "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s888/a"},"text":"Pub. L. 107–296, title VIII, § 888(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2249"},"text":"116 Stat. 2249","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id567dcd8a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 102 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s717"},"text":"section 717 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id567dcd8b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" designated existing provisions as subsec. (b), inserted heading, and transferred "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s888/a"},"text":"section 888(a) of Pub. L. 107–296","children":[],"tail":" to this section to appear before subsec. (b). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s103/b"},"text":"Pub. L. 115–282, § 103(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2"},"text":"section 2 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s302"},"text":"Pub. L. 115–282, § 302","children":[],"tail":", amended par. (7) generally. Prior to amendment, par. (7) read as follows: “maintain a state of readiness to function as a specialized service in the Navy in time of war, including the fulfillment of Maritime Defense Zone command responsibilities.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213"},"text":"Pub. L. 112–213","children":[],"tail":" amended section generally. Prior to amendment, section related to primary duties of the Coast Guard."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" substituted “United States; shall engage in maritime air surveillance or interdiction to enforce or assist in the enforcement of the laws of the United States; shall administer” for first reference to “United States;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/448"},"text":"Pub. L. 100–448","children":[],"tail":" substituted “Federal laws on, under, and over” for “Federal laws on and under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/640"},"text":"Pub. L. 99–640","children":[],"tail":" inserted “, including the fulfillment of Maritime Defense Zone command responsibilities.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/519"},"text":"Pub. L. 93–519","children":[],"tail":" inserted provision requiring Coast Guard to develop, establish, maintain and operate, pursuant to international agreements, icebreaking facilities in waters other than those subject to the jurisdiction of the United States."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/278"},"text":"Pub. L. 91–278","children":[],"tail":" improved and clarified text, substituting “on and under” for “upon” in clause preceding first semicolon; inserting “and under” after “life and property on” and striking out “on” after “the high seas and” in clause preceding second semicolon; and substituting “icebreaking” for “ice-breaking” and inserting “, under,” after “promotion of safety on” in clause preceding third semicolon, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1961—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/396"},"text":"Pub. L. 87–396","children":[],"tail":" required Coast Guard to engage in oceanographic research on high seas and in waters subject to jurisdiction of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id567dcd8c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id567dcd8d-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
