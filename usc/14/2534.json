{"tag":"section","attrib":{"id":"id56ca18b9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2534"},"text":null,"children":[{"tag":"num","attrib":{"value":"2534"},"text":"§ 2534.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of discharge characterization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56ca18ba-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2534/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Downgrade.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ca18bb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2534/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The decision to conduct a case review under this section shall be at the discretion of the Secretary of the department in which the Coast Guard is operating.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ca18bc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2534/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board of review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1553"},"text":"section 1553 of title 10","children":[],"tail":", a board of review for a former member of the Coast Guard established pursuant to such section and under part 51 of title 33, Code of Federal Regulations (as in effect on the date of enactment of the Coast Guard Authorization Act of 2025), may upon a motion of the board and subject to review by the Secretary of the department in which the Coast Guard is operating, downgrade an honorable discharge to a general (under honorable conditions) discharge upon a finding that a former member of the Coast Guard, while serving on active duty as a member of the armed forces, committed sexual assault or sexual harassment in violation of section 920, 920b, or 934 of title 10 (article 120, 120b, or 134 of the Uniform Code of Military Justice)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ca18bd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2534/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evidence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any downgrade under paragraph (2) shall be supported by clear and convincing evidence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ca18be-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2534/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The review board under paragraph (2) may not downgrade a discharge of a former member of the Coast Guard if the same action described in paragraph (2) was considered prior to separation from active duty by an administrative board in determining the characterization of discharge as otherwise provided by law and in accordance with regulations prescribed by the Secretary of the department in which the Coast Guard is operating.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ca18bf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2534/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedural Rights.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ca18c0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2534/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A review by a board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1553"},"text":"section 1553 of title 10","children":[],"tail":" and under part 51 of title 33, Code of Federal Regulations (as in effect on the date of enactment of the Coast Guard Authorization Act of 2025), shall be based on the records of the Coast Guard, and with respect to a member who also served in another one of the armed forces, the records of the armed forces concerned and such other evidence as may be presented to the board."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ca18c1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2534/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evidence by witness","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A witness may present evidence to the board in person or by affidavit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ca18c2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2534/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appearance before board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who requests a review under this section may appear before the board in person or by counsel or an accredited representative of an organization recognized by the Secretary of Veterans Affairs under chapter 59 of title 38.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ca18c3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2534/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A former member of the Coast Guard who is subject to a downgrade in discharge characterization review under subsection (a) shall be notified in writing of such proceedings, afforded the right to obtain copies of records and documents relevant to the proceedings, and the right to appear before the board in person or by counsel or an accredited representative of an organization recognized by the Secretary of Veterans Affairs under chapter 59 of title 38.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ca18c4-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXV/s7511/a"},"text":"Pub. L. 119–60, div. G, title LXXV, § 7511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1802"},"text":"139 Stat. 1802","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ca18c5-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ca18c6-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56ca18c7-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Coast Guard Authorization Act of 2025, referred to in subsecs. (a)(2) and (b)(1), is the date of enactment of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56ca18c8-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2534, added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8511(b), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4758"},"text":"134 Stat. 4758","children":[],"tail":", which related to application for section 2533 benefits, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXVIII/s11808/a/18"},"text":"Pub. L. 117–263, div. K, title CXVIII, § 11808(a)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4166"},"text":"136 Stat. 4166","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56ca18c9-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56ca18ca-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rulemaking","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXV/s7511/b"},"text":"Pub. L. 119–60, div. G, title LXXV, § 7511(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1807"},"text":"139 Stat. 1807","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dG/tLXXV/s7511/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"], the Commandant [of the Coast Guard] shall initiate a rulemaking to implement section 2534 [this section]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations issued under paragraph (1) shall take effect not later than 180 days after the date on which the Commandant [of the Coast Guard] promulgates a final rule pursuant to such paragraph.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
