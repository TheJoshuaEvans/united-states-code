{"tag":"section","attrib":{"id":"id56dd2bc7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103"},"text":null,"children":[{"tag":"num","attrib":{"value":"5103"},"text":"§ 5103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major acquisitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56dd2bc8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In conjunction with the transmittal by the President to Congress of the budget of the United States for fiscal year 2014 and biennially thereafter, the Secretary shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report on the status of all Level 1 acquisitions or Level 2 acquisitions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56dd2bc9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information To Be Included","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall include for each Level 1 acquisition or Level 2 acquisition—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56dd2bca-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the Coast Guard’s mission needs and performance goals relating to such program, including a justification for any change to those needs and goals subsequent to a report previously submitted under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2bcb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a justification explaining how the projected number and capabilities of assets acquired under such program meet applicable mission needs and performance goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2bcc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of any and all mission hour gaps, accompanied by an explanation of how and when the Coast Guard will close those gaps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2bcd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an identification of any changes with respect to such program, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56dd2bce-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any changes to the timeline for the acquisition of each new asset and the phaseout of legacy assets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56dd2bcf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any changes to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56dd2bd0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of new assets or legacy assets for that fiscal year or future fiscal years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56dd2bd1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total acquisition cost;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2bd2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a justification explaining how any change to such program fulfills the mission needs and performance goals of the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2bd3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the Coast Guard is planning for the integration of each new asset acquired under such program into the Coast Guard, including needs related to shore-based infrastructure and human resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2bd4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of how funds in the applicable fiscal year’s budget request will be allocated, including information on the purchase of specific assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2bd5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a projection of the remaining operational lifespan and life-cycle cost of each legacy asset that also identifies any anticipated resource gaps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2bd6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed explanation of how the costs of legacy assets are being accounted for within such program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2bd7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual performance comparison of new assets to legacy assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56dd2bd8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adequacy of Acquisition Workforce","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56dd2bd9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include information on the scope of the acquisition activities to be performed in the next fiscal year and on the adequacy of the current acquisition workforce to meet that anticipated workload;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2bda-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the number of officers, members, and employees of the Coast Guard currently and planned to be assigned to each position designated under section 1102(c); ","children":[{"tag":"ref","attrib":{"idref":"fn002051"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002051"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2bdb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify positions that are or will be understaffed and actions that will be taken to correct such understaffing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56dd2bdc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cutters Not Maintained in Class","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report under subsection (a) shall identify which, if any, Coast Guard cutters that have been issued a certificate of classification by the American Bureau of Shipping have not been maintained in class, with an explanation detailing the reasons why the cutters have not been maintained in class.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56dd2bdd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Long-term Major Acquisitions Plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall include a plan that describes for the upcoming fiscal year, and for each of the 20 fiscal years thereafter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56dd2bde-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the numbers and types of cutters and aircraft to be decommissioned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2bdf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the numbers and types of cutters and aircraft to be acquired to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56dd2be0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" replace the cutters and aircraft identified under paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56dd2be1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address an identified capability gap; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2be2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the estimated level of funding in each fiscal year required to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56dd2be3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire the cutters and aircraft identified under paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56dd2be4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate and sustain the cutters and aircraft described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56dd2be5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire related command, control, communications, computer, intelligence, surveillance, and reconnaissance systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56dd2be6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, construct, or renovate shoreside infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56dd2be7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56dd2be8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Level 1 acquisition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Level 1 acquisition” has the meaning given such term in section 1171.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2be9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5103/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Level 2 acquisition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Level 2 acquisition” has the meaning given such term in section 1171.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56dd2bea-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/tII/s210/a"},"text":"Pub. L. 112–213, title II, § 210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1550"},"text":"126 Stat. 1550","children":[],"tail":", § 569a; renumbered § 2903 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tI/s101/d/3"},"text":"Pub. L. 114–120, title I, § 101(d)(3)","children":[],"tail":", title II, § 204(e), "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/31"},"text":"130 Stat. 31","children":[],"tail":", 35; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3526/c"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3526(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2317"},"text":"132 Stat. 2317","children":[],"tail":"; renumbered § 5103 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 122(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4239"},"text":"132 Stat. 4239","children":[],"tail":", 4240; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8214, "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4650"},"text":"134 Stat. 4650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXI/s7112/a"},"text":"Pub. L. 119–60, div. G, title LXXI, § 7112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1666"},"text":"139 Stat. 1666","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56dd2beb-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56dd2bec-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56dd2bed-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1102(c), referred to in subsec. (c)(2), was, prior to amendment of this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":", a reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s562/c"},"text":"section 562(c) of this title","children":[],"tail":", which was redesignated as section 562(b) by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s899/b/1/B"},"text":"Pub. L. 114–328, div. A, title VIII, § 899(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2333"},"text":"130 Stat. 2333","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s562"},"text":"Section 562 of this title","children":[],"tail":" was renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s1102"},"text":"section 1102 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s108/b/2"},"text":"Pub. L. 115–282, title I, § 108(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4208"},"text":"132 Stat. 4208","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56dd2bee-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7112/a/1"},"text":"Pub. L. 119–60, § 7112(a)(1)","children":[],"tail":", substituted “Level 1 acquisitions or Level 2 acquisitions” for “major acquisition programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7112/a/2"},"text":"Pub. L. 119–60, § 7112(a)(2)","children":[],"tail":", substituted “Level 1 acquisition or Level 2 acquisition” for “major acquisition program” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7112/a/3"},"text":"Pub. L. 119–60, § 7112(a)(3)","children":[],"tail":", amended subsec. (f) generally. Prior to amendment, text read as follows: “In this section, the term ‘major acquisition program’ means an ongoing acquisition undertaken by the Coast Guard with a life-cycle cost estimate greater than or equal to $300,000,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (e)(3)(B) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added subpar. (B) and redesignated former subpars. (B) and (C) as (C) and (D), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s122/b"},"text":"Pub. L. 115–282, § 122(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2903"},"text":"section 2903 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 1102(c)” for “section 562(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" redesignated subsec. (g) as (f) and struck out former subsec. (f) which required quarterly updates on risks of programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s101/d/3/A"},"text":"Pub. L. 114–120, § 101(d)(3)(A)","children":[],"tail":", (B), renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s569a"},"text":"section 569a of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s101/d/3/C"},"text":"Pub. L. 114–120, § 101(d)(3)(C)","children":[],"tail":", struck out “of this subchapter” after “section 562(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s204/e"},"text":"Pub. L. 114–120, § 204(e)","children":[],"tail":", added subsecs. (e) and (f) and redesignated former subsec. (e) as (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56dd2bef-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56dd2bf0-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Additional Submissions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Commandant of the Coast Guard shall submit to the Committee on Homeland Security of the House of Representatives each plan required under subsection (e) of this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s101/f"},"text":"section 101(f) of Pub. L. 114–120","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s5110"},"text":"section 5110 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
