{"tag":"section","attrib":{"id":"id56ced321-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2766"},"text":null,"children":[{"tag":"num","attrib":{"value":"2766"},"text":"§ 2766.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel card management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56ced322-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2766/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may require that travel or transportation allowances due a civilian employee or military member of the Coast Guard be disbursed directly to the issuer of a Federal contractor-issued travel charge card, but only in an amount not to exceed the authorized travel expenses charged by that Coast Guard member to that travel charge card issued to that employee or member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ced323-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2766/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withholding of Nondisputed Obligations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may also establish requirements similar to those established by the Secretary of Defense pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2784a"},"text":"section 2784a of title 10","children":[],"tail":" for deduction or withholding of pay or retired pay from a Coast Guard employee, member, or retired member who is delinquent in payment under the terms of the contract under which the card was issued and does not dispute the amount of the delinquency."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ced324-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/tII/s210/a"},"text":"Pub. L. 108–293, title II, § 210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1036"},"text":"118 Stat. 1036","children":[],"tail":", § 517; renumbered § 2766, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ced325-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ced326-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ced327-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s517"},"text":"section 517 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
