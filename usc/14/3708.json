{"tag":"section","attrib":{"id":"id56d5ff36-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3708"},"text":null,"children":[{"tag":"num","attrib":{"value":"3708"},"text":"§ 3708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary members of the Reserve; certificate of honorable service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In recognition of the service of temporary members of the Reserve, the Secretary may upon request issue an appropriate certificate of honorable service in lieu of a certificate of disenrollment issued to any individual following disenrollment under honorable conditions from service as a temporary member. Issuance of a certificate of honorable service to any individual under this section does not entitle that individual to any rights, privileges, or benefits under any law of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56d5ff37-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1005"},"text":"94 Stat. 1005","children":[],"tail":", § 708; renumbered § 3708, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s118/b"},"text":"Pub. L. 115–282, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(52), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref"