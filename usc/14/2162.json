{"tag":"section","attrib":{"id":"id56be31bc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2162"},"text":null,"children":[{"tag":"num","attrib":{"value":"2162"},"text":"§ 2162.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and procedures","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each officer under consideration for removal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2159"},"text":"section 2159 of this title","children":[],"tail":" shall be—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56be31bd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2162/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notified in writing at least thirty days before the hearing of the case by a board of inquiry of the reasons for which the officer is being required to show cause for retention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56be31be-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2162/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowed reasonable time, as determined by the board of inquiry under regulations of the Secretary, to prepare his defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56be31bf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2162/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowed to appear in person and by counsel at proceedings before a board of inquiry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56be31c0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2162/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowed full access to, and furnished copies of, records relevant to the case at all stages of the proceeding, except that a board shall withhold any records that the Secretary determines should be withheld in the interests of national security. In any case where any records are withheld under this clause, the officer whose case is under consideration shall, to the extent that the national security permits, be furnished a summary of the records so withheld.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56be31c1-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/188"},"text":"77 Stat. 188","children":[],"tail":", § 325; renumbered § 2162 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 112(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56be31c2-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56be31c3-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56be31c4-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 2159” for “section 322” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s112/b"},"text":"Pub. L. 115–282, § 112(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s325"},"text":"section 325 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
