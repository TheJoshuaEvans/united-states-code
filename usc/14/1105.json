{"tag":"section","attrib":{"id":"id56a8ad6f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1105"},"text":null,"children":[{"tag":"num","attrib":{"value":"1105"},"text":"§ 1105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of lead systems integrators","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a8ad70-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8ad71-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of lead systems integrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant may not use a private sector entity as a lead systems integrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ad72-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Full and open competition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall use full and open competition for any acquisition contract unless otherwise excepted in accordance with Federal acquisition laws and regulations promulgated under those laws, including the Federal Acquisition Regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ad73-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1105/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No effect on small business act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection shall be construed to supersede or otherwise affect the authorities provided by and under the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"15 U.S.C. 631","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8ad74-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Financial Interest in Subcontractors","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Neither an entity performing lead systems integrator functions for a Coast Guard acquisition nor a Tier 1 subcontractor for any acquisition may have a financial interest in a subcontractor below the Tier 1 subcontractor level unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8ad75-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the subcontractor was selected by the prime contractor through full and open competition for such procurement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ad76-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procurement was awarded by an entity performing lead systems integrator functions or a subcontractor through full and open competition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ad77-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1105/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procurement was awarded by a subcontractor through a process over which the entity performing lead systems integrator functions or a Tier 1 subcontractor exercised no control; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ad78-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1105/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commandant has determined that the procurement was awarded in a manner consistent with Federal acquisition laws and regulations promulgated under those laws, including the Federal Acquisition Regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8ad79-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lead Systems Integrator Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “lead systems integrator” has the meaning given such term in section 805(c) of the National Defense Authorization Act for Fiscal Year 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Public Law 109–163","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a8ad7a-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIV/s402/a"},"text":"Pub. L. 111–281, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2935"},"text":"124 Stat. 2935","children":[],"tail":", § 564; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/330/s1/4"},"text":"Pub. L. 111–330, § 1(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3569"},"text":"124 Stat. 3569","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tII/s217/7"},"text":"Pub. L. 112–213, title II, § 217(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1557"},"text":"126 Stat. 1557","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s899/b/1/D"},"text":"Pub. L. 114–328, div. A, title VIII, § 899(b)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2333"},"text":"130 Stat. 2333","children":[],"tail":"; renumbered § 1105 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s108/b"},"text":"Pub. L. 115–282, title I, § 108(b)","children":[],"tail":", title III, § 304(d), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4208"},"text":"132 Stat. 4208","children":[],"tail":", 4245; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7211"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1693"},"text":"139 Stat. 1693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a8ad7b-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a8ad7c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56a8ad7d-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Small Business Act, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2"},"text":"Pub. L. 85–536, § 2","children":[],"tail":"(1 et seq.), "},{"tag":"date","attrib":{"date":"1958-07-18"},"text":"July 18, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/384"},"text":"72 Stat. 384","children":[],"tail":", which is classified generally to chapter 14A (§ 631 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"section 631 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 805(c) of the National Defense Authorization Act for Fiscal Year 2006, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s805/c"},"text":"section 805(c) of Pub. L. 109–163","children":[],"tail":", div. A, title VIII, "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3372"},"text":"119 Stat. 3372","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a8ad7e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s108/b"},"text":"Pub. L. 115–282, § 108(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s564"},"text":"section 564 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s304/d"},"text":"Pub. L. 115–282, § 304(d)","children":[],"tail":", struck out subsec. (c) which related to acquisition of unmanned aerial systems."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213"},"text":"Pub. L. 112–213","children":[],"tail":" amended section generally. Prior to amendment, section related to prohibition on use of lead systems integrators and provided for certain exceptions to such prohibition."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/330"},"text":"Pub. L. 111–330","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/s402/a"},"text":"Pub. L. 111–281, § 402(a)","children":[],"tail":", which enacted this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56a8ad7f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id56a8ad80-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/330/s1"},"text":"Pub. L. 111–330, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3569"},"text":"124 Stat. 3569","children":[],"tail":", provided that the amendment made by section 1(4) is effective with the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
