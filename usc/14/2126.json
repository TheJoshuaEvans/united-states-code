{"tag":"section","attrib":{"id":"id56b95075-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2126"},"text":null,"children":[{"tag":"num","attrib":{"value":"2126"},"text":"§ 2126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of officers not included on active duty promotion list","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Officers who are not included on the active duty promotion list may be promoted under regulations to be prescribed by the Secretary. These regulations shall, as to officers serving in connection with organizing, administering, recruiting, instructing, or training the reserve components and as to officers designated by the Secretary pursuant to this section, provide as nearly as practicable, that such officers will be selected and promoted in the same manner and will be afforded equal opportunity for promotion as officers of the corresponding grade on the active duty promotion list.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56b95076-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/183"},"text":"77 Stat. 183","children":[],"tail":", § 276; renumbered § 2126, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s112/b"},"text":"Pub. L. 115–282, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7221/c/3"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7221(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1700"},"text":"139 Stat. 1700","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56b95077-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56b95078-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56b95079-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" inserted “and as to officers designated by the Secretary pursuant to this section” after “reserve components” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s276"},"text":"section 276 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
