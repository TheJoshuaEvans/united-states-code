{"tag":"section","attrib":{"id":"id56b223c4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1929"},"text":null,"children":[{"tag":"num","attrib":{"value":"1929"},"text":"§ 1929.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cadets; appointment as ensign","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may, by and with the advice and consent of the Senate, appoint as ensigns in the Coast Guard all cadets who shall graduate from the Academy. Ensigns so commissioned on the same date shall take rank according to their proficiency as shown by the order of their merit at date of graduation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56b223c5-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/508"},"text":"63 Stat. 508","children":[],"tail":", § 185; renumbered § 1929, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s110/b"},"text":"Pub. L. 115–282, title I, § 110(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4212"},"text":"132 Stat. 4212","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56b223c6-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56b223c7-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 15a–1 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1943-05-25/ch99"},"text":"May 25, 1943, ch. 99","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/84"},"text":"57 Stat. 84","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said section has been divided. The proviso is incorporated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s182"},"text":"section 182 of this title","children":[],"tail":". The other part is incorporated in this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The last sentence of this section is new as a statute; it makes statutory what has been the practice of years, and is similar to the third sentence of title 34, U.S.C., 1946 ed., § 1057, applicable to graduates of the Naval Academy. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56b223c8-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56b223c9-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s185"},"text":"section 185 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
