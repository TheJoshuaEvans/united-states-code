{"tag":"section","attrib":{"id":"id5689b455-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334"},"text":null,"children":[{"tag":"num","attrib":{"value":"334"},"text":"§ 334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Coast Guard Museum","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5689b456-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant may establish, accept, operate, maintain and support the Museum, on lands which will be federally owned and administered by the Coast Guard, and are located in New London, Connecticut.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5689b457-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may expend funds appropriated to the Coast Guard on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5689b458-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the design of a Museum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5689b459-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engineering, construction, construction administration, and quality assurance services for a Museum, including construction, construction administration, and quality assurance services carried out by the Association; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5689b45a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing Federal financial assistance to the Association for the activities under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5689b45b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding Plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after the date of the enactment of the Elijah E. Cummings Coast Guard Authorization Act of 2020 and at least 90 days before the date on which the Commandant accepts the Museum under subsection (f), the Commandant shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a plan for constructing, operating, and maintaining such Museum, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5689b45c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimated planning, engineering, design, construction, operation, and maintenance costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5689b45d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which appropriated, nonappropriated, and non-Federal funds will be used for such purposes, including the extent to which there is any shortfall in funding for engineering, design, or construction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5689b45e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of any environmental remediation issues related to the land associated with the Museum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5689b45f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification by a third party entity qualified to undertake such a certification process that the estimates provided pursuant to paragraphs (1) and (2) are reasonable and realistic.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5689b460-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5689b461-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Association may construct the Museum described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5689b462-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Museum shall be designed and constructed in compliance with the International Building Code 2018, and construction performed on Federal land under this section shall be exempt from State and local requirements for building or demolition permits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5689b463-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under such terms and conditions as the Commandant considers appropriate, notwithstanding section 504, and until the Commandant accepts the Museum under subsection (f), the Commandant may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5689b464-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" license Federal land to the Association for the purpose of constructing the Museum described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5689b465-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5689b466-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a nominal charge, lease the Museum from the Association for activities and operations related to the Museum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5689b467-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize the Association to generate revenue from the use of the Museum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5689b468-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not earlier than 90 days after the Commandant submits the plan under subsection (c), the Commandant shall accept the Museum from the Association and all right, title, and interest in and to the Museum shall vest in the United States when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5689b469-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Association demonstrates, in a manner acceptable to the Commandant, that the Museum meets the design and construction requirements of subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5689b46a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all financial obligations of the Association incident to the National Coast Guard Museum have been satisfied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5689b46b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Services","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the services related to the activities for which the Secretary can expend funds under subsection (b), or for maintenance or operation of the Museum, the Secretary may, with respect to any entity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5689b46c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit and accept such services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5689b46d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts or memoranda of agreement to acquire such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5689b46e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant may not establish a Museum except as set forth in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5689b46f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5689b470-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Museum","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Museum” means the National Coast Guard Museum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5689b471-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s334/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Association","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Association” means the National Coast Guard Museum Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5689b472-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/tII/s213/a"},"text":"Pub. L. 108–293, title II, § 213(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1037"},"text":"118 Stat. 1037","children":[],"tail":", § 98; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s219"},"text":"Pub. L. 114–120, title II, § 219","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/48"},"text":"130 Stat. 48","children":[],"tail":"; renumbered § 316 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s104/b"},"text":"Pub. L. 115–282, title I, § 104(b)","children":[],"tail":", title III, § 303, "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4196"},"text":"132 Stat. 4196","children":[],"tail":", 4243; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIV"},"text":"Pub. L. 116–283, div. G, title LVXXXIV","children":[],"tail":" [LXXXIV], § 8439(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4737"},"text":"134 Stat. 4737","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXII/s11259"},"text":"Pub. L. 117–263, div. K, title CXII, § 11259","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4058"},"text":"136 Stat. 4058","children":[],"tail":"; renumbered § 334 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7201/b"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7201(b)","children":[],"tail":", (e)(8), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1675"},"text":"139 Stat. 1675","children":[],"tail":", 1684.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5689b473-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5689b474-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5689b475-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Elijah E. Cummings Coast Guard Authorization Act of 2020, referred to in subsec. (c), is the date of enactment of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5689b476-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 334 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2501"},"text":"section 2501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5689b477-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/b"},"text":"Pub. L. 119–60, § 7201(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s316"},"text":"section 316 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/e/8/A"},"text":"Pub. L. 119–60, § 7201(e)(8)(A)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The Secretary shall not expend any funds appropriated to the Coast Guard on the construction of any museum established under this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Subject to the availability of appropriations, the Secretary may expend funds appropriated to the Coast Guard on the engineering and design of a Museum.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The priority for the use of funds appropriated to the Coast Guard shall be to preserve, protect, and display historic Coast Guard artifacts, including the design, fabrication, and installation of exhibits or displays in which such artifacts are included.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/e/8/B"},"text":"Pub. L. 119–60, § 7201(e)(8)(B)","children":[],"tail":", amended subsec. (g) generally. Prior to amendment, text read as follows: “The Commandant may solicit from the Association and accept services from nonprofit entities, including services related to activities for construction of the Museum.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “a third party entity qualified to undertake such a certification process” for “the Inspector General of the department in which the Coast Guard is operating”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" amended section generally. Prior to amendment, section related to National Coast Guard Museum."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s303"},"text":"Pub. L. 115–282, § 303","children":[],"tail":", amended section generally. Prior to amendment, section related to National Coast Guard Museum."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s104/b"},"text":"Pub. L. 115–282, § 104(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s98"},"text":"section 98 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s219/1"},"text":"Pub. L. 114–120, § 219(1)","children":[],"tail":", substituted “any funds appropriated to the Coast Guard on” for “any appropriated Federal funds for”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s219/2"},"text":"Pub. L. 114–120, § 219(2)","children":[],"tail":", substituted “artifacts, including the design, fabrication, and installation of exhibits or displays in which such artifacts are included.” for “artifacts.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5689b478-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5689b479-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7201/f"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7201(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1685"},"text":"139 Stat. 1685","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dG/tLXXII/s7201/f"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in chapter 3 of title 14, United States Code, or any other law, may be construed to require the Coast Guard to construct, own, or operate a Museum as a condition of providing financial support to the Association for the purposes for which assistance is authorized under such chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In paragraph (1), the terms ‘Association’ and ‘Museum’ have the meanings given such terms in chapter 3 of title 14, United States Code.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
