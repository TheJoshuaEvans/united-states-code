{"tag":"section","attrib":{"id":"id56c53611-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2511"},"text":null,"children":[{"tag":"num","attrib":{"value":"2511"},"text":"§ 2511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations of flag officers and Senior Executive Service employees","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In conducting an investigation into an allegation of misconduct by a flag officer or member of the Senior Executive Service serving in the Coast Guard, the Inspector General of the Department of Homeland Security shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c53612-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2511/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct the investigation in a manner consistent with Department of Defense policies for such an investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53613-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2511/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Inspector General of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56c53614-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s220/a"},"text":"Pub. L. 114–120, title II, § 220(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/48"},"text":"130 Stat. 48","children":[],"tail":", § 430; renumbered § 2511, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s114/b"},"text":"Pub. L. 115–282, title I, § 114(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4223"},"text":"132 Stat. 4223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c53615-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c53616-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c53617-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s430"},"text":"section 430 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
