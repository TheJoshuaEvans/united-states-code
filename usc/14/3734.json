{"tag":"section","attrib":{"id":"id56d5ffaa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3734"},"text":null,"children":[{"tag":"num","attrib":{"value":"3734"},"text":"§ 3734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of this subchapter on retirement and retired pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection 3757(b) ","children":[{"tag":"ref","attrib":{"idref":"fn002046"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002046"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section 3757(b)”."}],"tail":" of this title, nothing in this subchapter authorizes the retirement of a Reserve officer or the payment of retired, retainer, or severance pay to a Reserve officer; or affects in any manner the law relating to the retirement of, or the granting of retired or retainer pay or other benefits to a Reserve officer."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56d5ffab-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1007"},"text":"94 Stat. 1007","children":[],"tail":", § 723; renumbered § 3734 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 118(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d5ffac-2930-11f1-a4c1-c531e6569a02"},"text":"\n