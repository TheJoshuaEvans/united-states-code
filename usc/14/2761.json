{"tag":"section","attrib":{"id":"id56ced304-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2761"},"text":null,"children":[{"tag":"num","attrib":{"value":"2761"},"text":"§ 2761.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals discharged as result of court-martial; allowances to","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may furnish individuals discharged pursuant to the sentence of a Coast Guard court-martial suitable civilian clothing and a monetary allowance not to exceed $25 if the individual discharged would not otherwise have suitable clothing or funds to meet immediate needs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56ced305-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-05-05/ch169/s16/a"},"text":"May 5, 1950, ch. 169, § 16(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/148"},"text":"64 Stat. 148","children":[],"tail":", § 509; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/377/s8"},"text":"Pub. L. 90–377, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-05"},"text":"July 5, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/288"},"text":"82 Stat. 288","children":[],"tail":"; renumbered § 2761, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(38)(A), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4749"},"text":"134 Stat. 4749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ced306-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ced307-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ced308-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Individuals” for “Persons” in section catchline and substituted “individuals” for “persons” and “individual” for “person” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s509"},"text":"section 509 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/377"},"text":"Pub. L. 90–377","children":[],"tail":" substituted “Persons discharged as result of court-martial; allowances to” for “Prisoners; allowances to; transportation” in section catchline, and struck out provision that persons confined in prisons in pursuance of the sentence of a Coast Guard court shall during such confinement, be allowed a reasonable sum, not to exceed $3 per month, for necessary prison expenses and the provision that the Commandant of the Coast Guard may transport to their homes or places of enlistment, as he may designate, all discharged prisoners, th