{"tag":"section","attrib":{"id":"id56d84902-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3742"},"text":null,"children":[{"tag":"num","attrib":{"value":"3742"},"text":"§ 3742.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of promotion zones under running mate system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d84903-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3742/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Use Running Mate System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may by regulation implement ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s3740/d/1"},"text":"section 3740(d)(1) of this title","children":[],"tail":" by requiring that the promotion zone for consideration of Reserve officers in an active status for promotion to the next higher grade be determined in accordance with a running mate system as provided in subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d84904-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3742/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration for Promotion","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If promotion zones are determined as authorized under subsection (a), a Reserve officer shall, subject to the eligibility requirements of this subchapter, be placed in a promotion zone when that officer’s running mate is placed in a promotion zone and shall, in accordance with the provisions of this subchapter, be considered for promotion at approximately the same time as that officer’s running mate or as soon thereafter as practicable, or in the event that promotion is not determined in accordance with a running mate system, then a Reserve officer becomes eligible for consideration for promotion to the next higher grade at the beginning of the promotion year in which he or she completes the following amount of service computed from the date of rank in the grade in which he or she is serving:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d84905-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3742/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two years in the grade of lieutenant (junior grade);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d84906-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3742/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three years in the grade of lieutenant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d84907-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3742/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four years in the grade of lieutenant commander;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d84908-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3742/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four years in the grade of commander; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d84909-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3742/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three years in the grade of captain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d8490a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3742/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration of Officers Below the Zone","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary authorizes the selection of officers for promotion from below the promotion zone in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s3740/d/3"},"text":"section 3740(d)(3) of this title","children":[],"tail":", the number of officers to be considered from below the zone may be established through the application of the running mate system under this subchapter or otherwise as the Secretary determines to be appropriate to meet the needs of the Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d8490b-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1011"},"text":"94 Stat. 1011","children":[],"tail":", § 731; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 502(b)(1), (2)(A)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–100; "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIV/s411/b"},"text":"Pub. L. 107–295, title IV, § 411(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2118"},"text":"116 Stat. 2118","children":[],"tail":"; renumbered § 3742 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 118(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d8490c-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d8490d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56d8490e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s783"},"text":"section 783 of this title","children":[],"tail":" prior to the complete revision of former chapter 21 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/96/322"},"text":"Pub. L. 96–322","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d8490f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s118/b"},"text":"Pub. L. 115–282, § 118(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s731"},"text":"section 731 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 3740(d)(1)” for “section 729(d)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 3740(d)(3)” for “section 729(d)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295"},"text":"Pub. L. 107–295","children":[],"tail":" inserted before period at end “, or in the event that promotion is not determined in accordance with a running mate system, then a Reserve officer becomes eligible for consideration for promotion to the next higher grade at the beginning of the promotion year in which he or she completes the following amount of service computed from the date of rank in the grade in which he or she is serving:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) two years in the grade of lieutenant (junior grade);","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) three years in the grade of lieutenant;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) four years in the grade of lieutenant commander;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) four years in the grade of commander; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) three years in the grade of captain”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 502(b)(2)(A)], substituted “Establishment of promotion zones under running mate system” for “Placement in promotion zone; consideration for promotion” as section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 502(b)(1)], added subsec. (a), designated existing provisions as subsec. (b), inserted subsec. (b) heading and substituted “If promotion zones are determined as authorized under subsection (a), a Reserve officer shall, subject to the eligibility requirements of this subchapter,” for “Subject to the eligibility requirements of this subchapter, a Reserve officer shall”, and added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56d84910-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id56d84911-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" applicable with respect to selection boards convened under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s3741"},"text":"section 3741 of this title","children":[],"tail":" on or after "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", see section 1 [[div. A], title V, § 502(c)] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s3740"},"text":"section 3740 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tai