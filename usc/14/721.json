{"tag":"section","attrib":{"id":"id56a18217-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s721"},"text":null,"children":[{"tag":"num","attrib":{"value":"721"},"text":"§ 721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responses to safety recommendations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a18218-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the National Transportation Safety Board submits to the Commandant a recommendation, and supporting justification for such recommendation, relating to transportation safety, the Commandant shall submit to the National Transportation Safety Board a written response to the recommendation, including whether the Commandant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a18219-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s721/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concurs with the recommendation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a1821a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s721/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partially concurs with the recommendation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a1821b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s721/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not concur with the recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a1821c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Explanation of Concurrence","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall include in a response submitted under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a1821d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s721/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a recommendation with which the Commandant concurs or partially concurs, an explanation of the actions the Commandant intends to take to implement such recommendation or part of such recommendation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a1821e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s721/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a recommendation with which the Commandant does not concur, the reasons the Commandant does not concur.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a1821f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s721/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure To Respond","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the National Transportation Safety Board has not received the written response required under subsection (a) by the end of the time period described in such subsection, the National Transportation Safety Board shall notify the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives that such response has not been received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a18220-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXV/s11501/a"},"text":"Pub. L. 117–263, div. K, title CXV, § 11501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4127"},"text":"136 Stat. 4127","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
