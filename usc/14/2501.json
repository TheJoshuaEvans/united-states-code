{"tag":"section","attrib":{"id":"id56c2ec97-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501"},"text":null,"children":[{"tag":"num","attrib":{"value":"2501"},"text":"§ 2501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grade on retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56c2ec98-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commissioned Officers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c2ec99-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A commissioned officer who is retired under any provision of this title, shall be retired from active service with the highest grade held by the commissioned officer for not less than six months while on active duty in which, as determined by the Secretary, the commissioned officer’s performance of duty was satisfactory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c2ec9a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditional determination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"When a commissioned officer is under investigation for alleged misconduct at the time of retirement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c2ec9b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may conditionally determine the highest grade of satisfactory service of the commissioned officer pending completion of the investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c2ec9c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grade under subparagraph (A) is subject to resolution under subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c2ec9d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Warrant Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any warrant officer who is retired under any provision of section 580, 1263, 1293, or 1305 of title 10, shall be retired from active service with the highest commissioned grade above chief warrant officer, W–4, held by the warrant officer for not less than six months on active duty in which, as determined by the Secretary, the warrant officer’s performance of duty was satisfactory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c2ec9e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retirement in Lower Grade.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c2ec9f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Misconduct in lower grade","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a commissioned officer whom the Secretary determines committed misconduct in a lower grade, the Secretary may determine the commissioned officer has not served satisfactorily in any grade equal to or higher than that lower grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c2eca0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adverse findings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A determination of the retired grade of a commissioned officer shall be resolved following a conditional determination under subsection (a)(2) if the investigation of or personnel action against the commissioned officer results in adverse findings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c2eca1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recalculation of retired pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the retired grade of a commissioned officer is reduced pursuant to this subsection, the retired pay of the commissioned officer shall be recalculated under chapter 71 of title 10, and any modification of the retired pay of the commissioned officer shall go into effect on the effective date of the reduction in retired grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c2eca2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Finality of Retired Grade Determinations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c2eca3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), a determination of the retired grade of a commissioned officer under this section is administratively final on the day the commissioned officer is retired, and may not be reopened.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c2eca4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reopening determinations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A determination of the retired grade of a commissioned officer may be reopened if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c2eca5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retirement or retired grade of the commissioned officer was procured by fraud;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c2eca6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantial evidence comes to light after the retirement that could have led to a lower retired grade under this section and such evidence was not known by a competent authority at the time of retirement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c2eca7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantial evidence comes to light that, during the commissioned service of the officer, the officer failed to carry out applicable laws, with an intent to deceive or defraud;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c2eca8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantial evidence comes to light after the retirement that the officer committed rape or sexual assault, as described in sections 920(a) and 920(b) of title 10 (articles 120(a) and 120(b) of the Uniform Code of Military Justice) at any time during the commissioned service of the officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c2eca9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantial evidence comes to light after the retirement that the commissioned officer knew of and failed to report through proper channels, in accordance with existing law at the time of the alleged incident, any known instances of sexual assault by a member of the Coast Guard under the command of the officer during the officer’s service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c2ecaa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mistake of law or calculation was made in the determination of the retired grade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c2ecab-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a retired grade following a conditional determination under subsection (a)(2), the investigation of or personnel action against the commissioned officer results in adverse findings; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c2ecac-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines, under regulations prescribed by the Secretary, that good cause exists to reopen the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c2ecad-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a determination of the retired grade of a commissioned officer is reopened under paragraph (2), the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c2ecae-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall notify the commissioned officer of the reopening; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c2ecaf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not make an adverse determination on the retired grade of the commissioned officer until the commissioned officer has had a reasonable opportunity to respond regarding the basis of the reopening.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c2ecb0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recalculation of retired pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the retired grade of a commissioned officer is reduced through the reopening of the commissioned officer’s retired grade under paragraph (2), the retired pay of the commissioned officer shall be recalculated under chapter 71 of title 10, and any modification of the retired pay of the commissioned officer shall go into effect on the effective date of the reduction in retired grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c2ecb1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2501/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Commissioned Warrant Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section, including subsection (b), shall not apply to commissioned warrant officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56c2ecb2-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/190"},"text":"77 Stat. 190","children":[],"tail":", § 334; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/444/s1/19"},"text":"Pub. L. 89–444, § 1(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-06-09"},"text":"June 9, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/196"},"text":"80 Stat. 196","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/348/tII/s205/b/7"},"text":"Pub. L. 99–348, title II, § 205(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-07-01"},"text":"July 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/700"},"text":"100 Stat. 700","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tXI/s1125/b/2"},"text":"Pub. L. 102–190, div. A, title XI, § 1125(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1505"},"text":"105 Stat. 1505","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tV/s541/f/3"},"text":"Pub. L. 103–337, div. A, title V, § 541(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2766"},"text":"108 Stat. 2766","children":[],"tail":"; renumbered § 2501, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s114/b"},"text":"Pub. L. 115–282, title I, § 114(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4223"},"text":"132 Stat. 4223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8201(c), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4641"},"text":"134 Stat. 4641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7224/a"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7224(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1702"},"text":"139 Stat. 1702","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c2ecb3-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c2ecb4-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c2ecb5-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7224/a/1"},"text":"Pub. L. 119–60, § 7224(a)(1)","children":[],"tail":", inserted “a” before “competent authority”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(C) to (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7224/a/2"},"text":"Pub. L. 119–60, § 7224(a)(2)","children":[],"tail":", added subpars. (C) to (E) and redesignated former subpars. (C) to (E) as (F) to (H), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8201/c/1"},"text":"Pub. L. 116–283, § 8201(c)(1)","children":[],"tail":", designated existing provisions as par. (1), inserted subsec. heading and par. (1) heading, substituted “A commissioned officer” for “Any commissioned officer, other than a commissioned warrant officer,”, “the commissioned officer” for “him”, and “the commissioned officer’s” for “his”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8201/c/2"},"text":"Pub. L. 116–283, § 8201(c)(2)","children":[],"tail":", inserted heading and substituted “the warrant officer” for “him” and “the warrant officer’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8201/c/3"},"text":"Pub. L. 116–283, § 8201(c)(3)","children":[],"tail":", added subsecs. (c) to (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s334"},"text":"section 334 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" substituted “section 580,” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s564"},"text":"section 564 of title 10","children":[],"tail":" (as in effect on the day before the effective date of the Warrant Officer Management Act) or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s564"},"text":"section 564 of title 10","children":[],"tail":" (as in effect on the day before the effective date of the Warrant Officer Management Act) or 1263, 1293, or 1305 of title 10” for “section 564, 1263, 1293, or 1305 of title 10”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348/s205/b/7/A"},"text":"Pub. L. 99–348, § 205(b)(7)(A)","children":[],"tail":", struck out “, with retired pay of the grade with which retired” after “satisfactory”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348/s205/b/7"},"text":"Pub. L. 99–348, § 205(b)(7)","children":[],"tail":", struck out “, with retired pay of the grade with which retired” after “satisfactory” and struck out provision that when the rate of pay of such highest grade is less than the pay of the warrant grade with which the officer would otherwise be retired under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1371"},"text":"section 1371 of title 10","children":[],"tail":", the retired pay was to be based on the higher rate of pay."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/444"},"text":"Pub. L. 89–444","children":[],"tail":" substituted “Grade on retirement” for “Retirement in cases where higher grade has been held” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56c2ecb6-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id56c2ecb7-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" effective on the first day of the fourth month beginning after "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s541/h"},"text":"section 541(h) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s571"},"text":"section 571 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id56c2ecb8-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-02-01"},"text":"Feb. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/s1132"},"text":"section 1132 of Pub. L. 102–190","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s521"},"text":"section 521 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56c2ecb9-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Modifications and Revisions Relating to Reopening Retired Grade Determinations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7224/b"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7224(b)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1703"},"text":"139 Stat. 1703","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dG/tLXXII/s7224/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance and Revision of Regulations Relating to Good Cause to Reopen Retired Grade Determinations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"], the Secretary of the department in which the Coast Guard is operating shall issue or revise, as applicable, and at the discretion of the Secretary consistent with this section, regulations of the Coast Guard to do the following:"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Define what constitutes good cause to reopen a retired grade determination referred to in subparagraph (H) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2501/d/2"},"text":"section 2501(d)(2) of title 14","children":[],"tail":", United States Code, as redesignated by subsection (a), to ensure that the following shall be considered good cause for such a reopening:"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Circumstances that constitute a failure to carry out applicable laws regarding a report of sexual assault with an intent to deceive by a commissioned officer, that relate to a response made to a report of sexual assault, during the commissioned service of the officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Substantial evidence of sexual assault by the commissioned officer concerned, at any time during the commissioned service of such officer, or such evidence that was not considered by the Coast Guard in a manner consistent with law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identify the standard for making, and the evidentiary showing required to support, an adverse determination on the retired grade of a commissioned officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revision of Limitations on Reopening Retired Grade Determinations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of enactment of this Act, the Secretary of the department in which the Coast Guard is operating shall revise applicable guidance in section K.10 of chapter 3 of Commandant Instruction 1000.4A to remove any restriction that limits the ability to reopen the retired grade of a commissioned officer based on—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether new evidence is discovered contemporaneously with or within a short time period after the date of retirement of the officer concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the misconduct concerned was not discoverable through due diligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Clause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No provision of this section [amending this section and enacting this note] or the amendments made by this section shall be construed to permit a review of conduct that was not in violation of law or policy at the time of the alleged conduct.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
