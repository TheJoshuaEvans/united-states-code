{"tag":"section","attrib":{"id":"id56d14509-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2921"},"text":null,"children":[{"tag":"num","attrib":{"value":"2921"},"text":"§ 2921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d1450a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2921/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Child abuse and neglect","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “child abuse and neglect” has the meaning given that term in section 3 of the Child Abuse Prevention and Treatment Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5101"},"text":"42 U.S.C. 5101","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d1450b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2921/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Child development center employee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “child development center employee” means a civilian employee of the Coast Guard who is employed to work in a Coast Guard child development center without regard to whether the employee is paid from appropriated or nonappropriated funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d1450c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2921/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coast guard child development center","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Coast Guard child development center” means a facility on Coast Guard property or on property under the jurisdiction of the commander of a Coast Guard unit at which child care services are provided for members of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d1450d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2921/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Competitive service position","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “competitive service position” means a position in the competitive service (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2102"},"text":"section 2102 of title 5","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d1450e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2921/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Family home daycare","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “family home daycare” means home-based child care services provided for a member of the Coast Guard by an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56d1450f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2921/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is certified by the Commandant as qualified to provide home-based child care services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d14510-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2921/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides home-based child care services on a regular basis in exchange for monetary compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d14511-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s214/a"},"text":"Pub. L. 113–281, title II, § 214(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3031"},"text":"128 Stat. 3031","children":[],"tail":", § 551; renumbered § 2921, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s117/b"},"text":"Pub. L. 115–282, title I, § 117(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4230"},"text":"132 Stat. 4230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d14512-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d14513-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56d14514-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3 of the Child Abuse Prevention and Treatment Act, referred to in par. (1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/s3"},"text":"section 3 of Pub. L. 93–247","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5101"},"text":"section 5101 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d14515-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s551"},"text":"section 551 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
