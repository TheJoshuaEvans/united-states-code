{"tag":"section","attrib":{"id":"id56d38ead-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2944"},"text":null,"children":[{"tag":"num","attrib":{"value":"2944"},"text":"§ 2944.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retired service members and dependents serving on advisory committees","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A committee that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d38eae-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2944/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advises or assists the Coast Guard with respect to a function that affects a member of the Coast Guard or a dependent of such a member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d38eaf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2944/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes in its membership a retired Coast Guard member or a dependent of such a retired member;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall not be considered an advisory committee under chapter 10 of title 5 solely because of such membership.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d38eb0-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s218/a"},"text":"Pub. L. 113–281, title II, § 218(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3036"},"text":"128 Stat. 3036","children":[],"tail":", § 680; renumbered § 2944, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s117/b"},"text":"Pub. L. 115–282, title I, § 117(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4230"},"text":"132 Stat. 4230","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/61"},"text":"Pub. L. 117–286, § 4(a)(61)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4312"},"text":"136 Stat. 4312","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d38eb1-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d38eb2-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d38eb3-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “the Federal Advisory Committee Act (5 U.S.C. App.)” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s680"},"text":"section 680 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
