{"tag":"section","attrib":{"id":"id569f10bc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s716"},"text":null,"children":[{"tag":"num","attrib":{"value":"716"},"text":"§ 716.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arctic maritime transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id569f10bd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s716/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of this section is to ensure safe and secure maritime shipping in the Arctic including the availability of aids to navigation, vessel escorts, spill response capability, and maritime search and rescue in the Arctic.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f10be-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s716/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"International Maritime Organization Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out the purpose of this section, the Secretary is encouraged to enter into negotiations through the International Maritime Organization to conclude and execute agreements to promote coordinated action among the United States, Russia, Canada, Iceland, Norway, and Denmark and other seafaring and Arctic nations to ensure, in the Arctic—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id569f10bf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s716/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" placement and maintenance of aids to navigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10c0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s716/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate marine safety, tug, and salvage capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10c1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s716/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oil spill prevention and response capability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10c2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s716/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maritime domain awareness, including long-range vessel tracking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10c3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s716/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" search and rescue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f10c4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s716/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination by Committee on the Maritime Transportation System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee on the Maritime Transportation System established under section 55501 ","children":[{"tag":"ref","attrib":{"idref":"fn002017"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002017"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 46, United States Code, shall coordinate the establishment of domestic transportation policies in the Arctic necessary to carry out the purpose of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f10c5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s716/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements and Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may, subject to the availability of appropriations, enter into cooperative agreements, contracts, or other agreements with, or make grants to, individuals and governments to carry out the purpose of this section or any agreements established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f10c6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s716/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Icebreaking","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall promote safe maritime navigation by means of icebreaking where necessary, feasible, and effective to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f10c7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s716/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Arctic Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “Arctic” has the meaning given such term in section 112 of the Arctic Research and Policy Act of 1984 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4111"},"text":"15 U.S.C. 4111","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id569f10c8-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/tV/s501/a"},"text":"Pub. L. 113–281, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3056"},"text":"128 Stat. 3056","children":[],"tail":", § 90; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3533/d"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3533(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2321"},"text":"132 Stat. 2321","children":[],"tail":"; renumbered § 716, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s106/b"},"text":"Pub. L. 115–282, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4203"},"text":"132 Stat. 4203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569f10c9-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569f10ca-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id569f10cb-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55501"},"text":"Section 55501 of title 46","children":[],"tail":", United States Code, referred to in subsec. (c), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s50401"},"text":"section 50401 of title 46","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dC/tXXXV/s3512/a/3"},"text":"Pub. L. 117–81, div. C, title XXXV, § 3512(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2239"},"text":"135 Stat. 2239","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id569f10cc-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s90"},"text":"section 90 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" struck out question mark after “the term ‘Arctic’ ”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
