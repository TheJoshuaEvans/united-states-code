{"tag":"section","attrib":{"id":"id56dd2b74-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4903"},"text":null,"children":[{"tag":"num","attrib":{"value":"4903"},"text":"§ 4903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of personnel end strengths","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56dd2b75-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each fiscal year, Congress shall authorize the strength for active duty personnel of the Coast Guard as of the end of that fiscal year. Amounts may be appropriated for a fiscal year to or for the use of active duty personnel of the Coast Guard only if the end strength for active duty personnel for that fiscal year has been authorized by law. If at the end of any fiscal year there is in effect a declaration of war or national emergency, the President may defer the effectiveness of any end-strength limitation with respect to that fiscal year prescribed by law for any military or civilian component of the Coast Guard, for a period not to exceed 6 months after the end of the war or termination of the national emergency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56dd2b76-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56dd2b77-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Congress shall authorize the average military training student loads for the Coast Guard for each fiscal year. That authorization is required for student loads for the following individual training categories:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56dd2b78-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4903/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recruit and specialized training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56dd2b79-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4903/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Flight training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56dd2b7a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4903/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Professional training in military and civilian institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56dd2b7b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4903/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Officer acquisition training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2b7c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts may be appropriated for a fiscal year for use in training military personnel of the Coast Guard in the categories referred to in paragraph (1) only if the average student loads for the Coast Guard for that fiscal year have been authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56dd2b7d-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s2/20/A"},"text":"Pub. L. 97–295, § 2(20)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1302"},"text":"96 Stat. 1302","children":[],"tail":", § 661; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tI/s105/a"},"text":"Pub. L. 107–295, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2085"},"text":"116 Stat. 2085","children":[],"tail":"; renumbered § 2703, "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tI/s101/c"},"text":"Pub. L. 114–120, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/31"},"text":"130 Stat. 31","children":[],"tail":"; renumbered § 4903, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s121/b"},"text":"Pub. L. 115–282, title I, § 121(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4238"},"text":"132 Stat. 4238","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56dd2b7e-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56dd2b7f-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id56dd2b80-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"tex