{"tag":"section","attrib":{"id":"id56d5ffa2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3733"},"text":null,"children":[{"tag":"num","attrib":{"value":"3733"},"text":"§ 3733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of this subchapter in time of war or national emergency","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In time of war or national emergency declared by Congress, the President may suspend the operation of this subchapter or any part hereof. If this subchapter or any part hereof is suspended by the President, prior to placing the suspended provision in operation, the President shall by regulation, in so far as practicable, adjust the grades of Reserve officers in the same manner as adjustments in grade are made for Regular officers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56d5ffa3-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1007"},"text":"94 Stat. 1007","children":[],"tail":", § 722; renumbered § 3733, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s118/b"},"text":"Pub. L. 115–282, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d5ffa4-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d5ffa5-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b",