{"tag":"section","attrib":{"id":"id56dd2bf1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104"},"text":null,"children":[{"tag":"num","attrib":{"value":"5104"},"text":"§ 5104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manpower requirements plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56dd2bf2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On the date on which the President submits to the Congress a budget for fiscal year 2017 under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", on the date on which the President submits to the Congress a budget for fiscal year 2019 under such section, and every 4 years thereafter, the Commandant shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a manpower requirements plan."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56dd2bf3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A manpower requirements plan submitted under subsection (a) shall include for each mission of the Coast Guard—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56dd2bf4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of all projected mission requirements for the upcoming fiscal year and for each of the 3 fiscal years thereafter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2bf5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of active duty, reserve, and civilian personnel assigned or available to fulfill such mission requirements—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56dd2bf6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" currently; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56dd2bf7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as projected for the upcoming fiscal year and each of the 3 fiscal years thereafter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2bf8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of active duty, reserve, and civilian personnel required to fulfill such mission requirements—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56dd2bf9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" currently; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56dd2bfa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as projected for the upcoming fiscal year and each of the 3 fiscal years thereafter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2bfb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an identification of any capability gaps between mission requirements and mission performance caused by deficiencies in the numbers of personnel available—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56dd2bfc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" currently; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56dd2bfd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as projected for the upcoming fiscal year and each of the 3 fiscal years thereafter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2bfe-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the actions the Commandant will take to address capability gaps identified under paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56dd2bff-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In composing a manpower requirements plan for submission under subsection (a), the Commandant shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56dd2c00-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the marine safety strategy required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2116"},"text":"section 2116 of title 46","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2c01-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the adequacy of the acquisition workforce included in the most recent report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s5103"},"text":"section 5103 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2c02-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5104/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal strategic planning effort the Commandant considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56dd2c03-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","childre