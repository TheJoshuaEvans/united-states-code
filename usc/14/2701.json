{"tag":"section","attrib":{"id":"id56ca1924-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2701"},"text":null,"children":[{"tag":"num","attrib":{"value":"2701"},"text":"§ 2701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement of personnel","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Coast Guard may expend operations and support funds for recruiting activities, including advertising and entertainment, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ca1925-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain recruits for the Service and cadet applicants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ca1926-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gain support of recruiting objectives from those who may assist in the recruiting effort.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ca1927-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/531"},"text":"63 Stat. 531","children":[],"tail":", § 468; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tII/s206/b"},"text":"Pub. L. 104–324, title II, § 206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3908"},"text":"110 Stat. 3908","children":[],"tail":"; renumbered § 2701, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8513(a)(4), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4760"},"text":"134 Stat. 4760","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ca1928-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56ca1929-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on the following language contained in the Coast Guard appropriation act for 1949, “Pay and Allowances” and preceding years: ","children":[{"tag":"quotedContent","attrib":{},"text":"“expenses of recruiting for the Coast Guard; advertising for and obtaining enlisted personnel and applicants for appointment as cadets;”","children":[],"tail":"\n ("},{"tag":"ref","attrib":{"href":"/us/act/1948-06-19/ch558"},"text":"June 19, 1948, ch. 558","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/562"},"text":"62 Stat. 562","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ca192a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56ca192b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2701 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s4901"},"text":"section 4901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ca192c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", in introductory provisions, substituted “operations and support” for “operating expense” and struck out “but not limited to” after “including” and “in order” after “entertainment,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s468"},"text":"section 468 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" amended text generally. Prior to amendment, text read as follows: “The Coast Guard may make expenditures as necessary in order to obtain recruits for the service and cadet applicants, including advertising.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
