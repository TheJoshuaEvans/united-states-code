{"tag":"section","attrib":{"id":"id56959a66-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s506"},"text":null,"children":[{"tag":"num","attrib":{"value":"506"},"text":"§ 506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prospective payment of funds necessary to provide medical care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56959a67-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prospective Payment Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In lieu of the reimbursement required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1085"},"text":"section 1085 of title 10","children":[],"tail":", the Secretary of Homeland Security shall make a prospective payment to the Secretary of Defense of an amount that represents the actuarial valuation of treatment or care—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56959a68-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Department of Defense shall provide to members of the Coast Guard, former members of the Coast Guard, and dependents of such members and former members (other than former members and dependents of former members who are a Medicare-eligible beneficiary or for whom the payment for treatment or care is made from the Medicare-Eligible Retiree Health Care Fund as established under chapter 56 of title 10) at facilities under the jurisdiction of the Department of Defense or a military department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959a69-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which a reimbursement would otherwise be made under section 1085.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56959a6a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the prospective payment under subsection (a) shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56959a6b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of treatment or care to be provided to members of the Coast Guard and their dependents, derived from amounts appropriated for the operations and support of the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959a6c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of treatment or care to be provided former members of the Coast Guard and their dependents, derived from amounts appropriated for retired pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959a6d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s506/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined under procedures established by the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959a6e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s506/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid during the fiscal year in which treatment or care is provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959a6f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s506/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to adjustment or reconciliation as the Secretaries determine appropriate during or promptly after such fiscal year in cases in which the prospective payment is determined excessive or insufficient based on the services actually provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56959a70-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Prospective Payment When Service in Navy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No prospective payment shall be made under this section for any period during which the Coast Guard operates as a service in the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56959a71-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s506/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to TRICARE","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall not be construed to require a payment for, or the prospective payment of an amount that represents the value of, treatment or care provided under any TRICARE program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56959a72-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVII/s722/a"},"text":"Pub. L. 114–328, div. A, title VII, § 722(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2228"},"text":"130 Stat. 2228","children":[],"tail":", § 520; renumbered § 506, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s105/b"},"text":"Pub. L. 115–282, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4200"},"text":"132 Stat. 4200","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8513(a)(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4760"},"text":"134 Stat. 4760","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56959a73-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56959a74-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56959a75-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 506, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"act Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/537"},"text":"63 Stat. 537","children":[],"tail":", related to the issue of the national flag to be used for draping the coffin of any deceased member of the Coast Guard, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1954-07-15/ch507/s14/c/5"},"text":"act July 15, 1954, ch. 507, § 14(c)(5)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/481"},"text":"68 Stat. 481","children":[],"tail":". For provisions relating to recovery, care, and disposition of the remains of deceased personnel of the uniformed services and deceased civilian personnel, see "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1481"},"text":"section 1481 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56959a76-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8513/a/1/A"},"text":"Pub. L. 116–283, § 8513(a)(1)(A)","children":[],"tail":", inserted “as established under chapter 56 of title 10” after “Medicare-Eligible Retiree Health Care Fund”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8513/a/1/B"},"text":"Pub. L. 116–283, § 8513(a)(1)(B)","children":[],"tail":", substituted “operations and support” for “operating expenses”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s520"},"text":"section 520 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
