{"tag":"section","attrib":{"id":"id56d84926-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3745"},"text":null,"children":[{"tag":"num","attrib":{"value":"3745"},"text":"§ 3745.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications for promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d84927-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3745/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Reserve officer shall not be promoted to a higher grade unless the officer has been found to be physically qualified and the character of the officer’s service subsequent to the convening of the selection board which recommended the officer for promotion has been verified as satisfactory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d84928-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3745/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) of this section does not exclude from promotion a Reserve officer physically disqualified by a medical board for duty at sea or in the field, if the disqualification results from wounds received in the line of duty, and those wounds do not incapacitate the officer for other duties in the grade to which the officer is to be promoted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d84929-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1012"},"text":"94 Stat. 1012","children":[],"tail":", § 734; renumbered § 3745, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s118/b"},"text":"Pub. L. 115–282, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d8492a-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d8492b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56d8492c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s786"},"text":"section 786 of this title","children":[],"tail":" prior to the complete revision of former chapter 21 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/96/322"},"text":"Pub. L. 96–322","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d8492d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s734"},"text":"section 734 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
