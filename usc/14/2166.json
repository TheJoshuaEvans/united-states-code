{"tag":"section","attrib":{"id":"id56be31dc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2166"},"text":null,"children":[{"tag":"num","attrib":{"value":"2166"},"text":"§ 2166.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation on active duty; Coast Guard officers with certain critical skills","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56be31dd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2166/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant may authorize an officer in a grade above grade O–2 to remain on active duty after the date otherwise provided for the retirement of such officer in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2154"},"text":"section 2154 of this title","children":[],"tail":", if the officer possesses a critical skill, or specialty, or is in a career field designated pursuant to subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56be31de-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2166/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Critical Skills, Specialty, or Career Field","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall designate any critical skill, specialty, or career field eligible for continuation on active duty as provided in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56be31df-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2166/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration of Continuation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer continued on active duty pursuant to this section shall, if not earlier retired, be retired on the first day of the month after the month in which the officer completes 40 years of active service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56be31e0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2166/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall carry out this section by prescribing policy which shall specify the criteria to be used in designating any critical skill, specialty, or career field for purposes of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56be31e1-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXII/s11235/a"},"text":"Pub. L. 117–263, div. K, title CXII, § 11235(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4035"},"text":"136 Stat. 4035","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
