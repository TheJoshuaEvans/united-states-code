{"tag":"section","attrib":{"id":"id56ced34e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772"},"text":null,"children":[{"tag":"num","attrib":{"value":"2772"},"text":"§ 2772.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education loan repayment program for members on active duty in specified military specialties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56ced34f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ced350-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the provisions of this section, the Secretary may repay—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ced351-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any loan made, insured, or guaranteed under part B of title IV of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1071"},"text":"20 U.S.C. 1071","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ced352-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any loan made under part D of such title (the William D. Ford Federal Direct Loan Program, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087a"},"text":"20 U.S.C. 1087a","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ced353-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any loan made under part E of such title (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087aa"},"text":"20 U.S.C. 1087aa","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ced354-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any loan incurred for educational purposes made by a lender that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56ced355-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency or instrumentality of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56ced356-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial or credit institution (including an insurance company) that is subject to examination and supervision by an agency of the United States or any State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56ced357-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/a/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pension fund approved by the Secretary for purposes of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56ced358-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/a/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit private entity designated by a State, regulated by such State, and approved by the Secretary for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ced359-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Repayment of any such loan shall be made on the basis of each complete year of service performed by the borrower.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ced35a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may repay loans described in paragraph (1) in the case of any person for service performed on active duty as a member in an officer program or military specialty specified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ced35b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The portion or amount of a loan that may be repaid under subsection (a) is 33⅓ percent or $1,500, whichever is greater, for each year of service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ced35c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interest Accrual","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a portion of a loan is repaid under this section for any year, interest on the remainder of such loan shall accrue and be paid in the same manner as is otherwise required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ced35d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to authorize refunding any repayment of a loan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ced35e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fractional Credit for Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual who transfers from service making the individual eligible for repayment of loans under this section (as described in subsection (a)(3)) to service making the individual eligible for repayment of loans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s16301"},"text":"section 16301 of title 10","children":[],"tail":" (as described in subsection (a)(2) or (g) of that section) during a year shall be eligible to have repaid a portion of such loan determined by giving appropriate fractional credit for each portion of the year so served, in accordance with regulations of the Secretary concerned."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ced35f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Schedule for Allocation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe a schedule for the allocation of funds made available to carry out the provisions of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s16301"},"text":"section 16301 of title 10","children":[],"tail":" during any year for which funds are not sufficient to pay the sum of the amounts eligible for repayment under subsection (a) and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16301/a"},"text":"section 16301(a) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ced360-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure to Complete Period of Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except an individual described in subsection (e) who transfers to service making the individual eligible for repayment of loans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s16301"},"text":"section 16301 of title 10","children":[],"tail":", a member of the Coast Guard who fails to complete the period of service required to qualify for loan repayment under this section shall be subject to the repayment provisions of section 303a(e) or 373 of title 37."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ced361-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2772/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Issue Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may prescribe procedures for implementing this section, including standards for qualified loans and authorized payees and other terms and conditions for making loan repayments. Such regulations may include exceptions that would allow for the payment as a lump sum of any loan repayment due to a member under a written agreement that existed at the time of a member’s death or disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ced362-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/tII/s218/a"},"text":"Pub. L. 108–293, title II, § 218(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1038"},"text":"118 Stat. 1038","children":[],"tail":", § 472; renumbered § 2772, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(41), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4750"},"text":"134 Stat. 4750","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXII/s11239/a"},"text":"Pub. L. 117–263, div. K, title CXII, § 11239(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4037"},"text":"136 Stat. 4037","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ced363-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ced364-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56ced365-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Higher Education Act of 1965, referred to in subsec. (a)(1)(A) to (C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1219"},"text":"79 Stat. 1219","children":[],"tail":". Parts B, D, and E of title IV of the Act are classified generally to parts B (§ 1071 et seq.), D (§ 1087a et seq.), and E (§ 1087aa et seq.), respectively, of subchapter IV of chapter 28 of Title 20, Education. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ced366-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" amended section generally. Prior to amendment, section related to education loan repayment program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “individual” for “person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s472"},"text":"section 472 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
