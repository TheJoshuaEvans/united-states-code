{"tag":"section","attrib":{"id":"id569a5632-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s528"},"text":null,"children":[{"tag":"num","attrib":{"value":"528"},"text":"§ 528.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protecting against unmanned aircraft","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of section 210G(k)(3)(C)(iv) ","children":[{"tag":"ref","attrib":{"idref":"fn002013"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002013"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Homeland Security Act of 2002, the missions authorized to be performed by the United States Coast Guard shall be those related to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id569a5633-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s528/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" functions of the U.S. Coast Guard relating to security or protection of facilities and assets assessed to be high-risk and a potential target for unlawful unmanned aircraft activity, including the security and protection of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id569a5634-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s528/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a facility, including a facility that is under the administrative control of the Commandant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569a5635-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s528/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a vessel (whether moored or underway) or an aircraft, including a vessel or aircraft—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id569a5636-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s528/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is operated by the Coast Guard, or that the Coast Guard is assisting or escorting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id569a5637-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s528/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is directly involved in a mission of the Coast Guard pertaining to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id569a5638-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s528/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting or escorting a vessel of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id569a5639-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s528/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting or escorting a vessel of national security significance, a high interest vessel, a high capacity passenger vessel, or a high value unit, as those terms are defined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id569a563a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s528/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s527/a"},"text":"section 527(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id569a563b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s528/1/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in protecting the President or the Vice President (or other officer next in order of succession to the Office of the President) pursuant to the Presidential Protection Assistance Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3056"},"text":"18 U.S.C. 3056","children":[],"tail":" note);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id569a563c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s528/1/B/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection of a National Special Security Event and Special Event Assessment Rating events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id569a563d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s528/1/B/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" air defense of the United States, including air sovereignty, ground-based air defense, and the National Capital Region integrated air defense system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id569a563e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s528/1/B/ii/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a search and rescue operation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569a563f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s528/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" missions directed by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"idref":"fn002014"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002014"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by “section”."}],"tail":" 210G(k)(3)(C)(iii) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the Homeland Security Act of 2002."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id569a5640-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dH/s1603/a"},"text":"Pub. L. 115–254, div. H, § 1603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3529"},"text":"132 Stat. 3529","children":[],"tail":", § 104; renumbered § 528 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 105(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4200"},"text":"132 Stat. 4200","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569a5641-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569a5642-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id569a5643-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 210G(k)(3)(C)(iii), (iv) of the Homeland Security Act of 2002, referred to in text, was redesignated section 210G(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3)(C)(iii), (iv) by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXVI/s8602/7"},"text":"Pub. L. 119–60, div. H, title LXXXVI, § 8602(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1942"},"text":"139 Stat. 1942","children":[],"tail":", and is classified to section 124n("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3)(C)(iii), (iv) of Title 6, Domestic Security."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Presidential Protection Assistance Act of 1976, referred to in par. (1)(B)(ii)(IV), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/524"},"text":"Pub. L. 94–524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2475"},"text":"90 Stat. 2475","children":[],"tail":", which enacted and amended provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3056"},"text":"section 3056 of Title 18","children":[],"tail":", Crimes and Criminal Procedure. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id569a5644-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s105/b"},"text":"Pub. L. 115–282, § 105(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s104"},"text":"section 104 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(B)(ii)(III). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 527(a)” for “section 91(a)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
