{"tag":"section","attrib":{"id":"id56dd2c09-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5105"},"text":null,"children":[{"tag":"num","attrib":{"value":"5105"},"text":"§ 5105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory of real property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56dd2c0a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall maintain an inventory of all real property, including submerged lands, under the control of the Coast Guard, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56dd2c0b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the size, the location, and any other appropriate description of each unit of such property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2c0c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the physical condition of each unit of such property, excluding lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2c0d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5105/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a determination of whether each unit of such property should be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56dd2c0e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5105/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retained to fulfill a current or projected Coast Guard mission requirement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56dd2c0f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5105/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to divestiture; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2c10-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5105/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other information the Commandant considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56dd2c11-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall update information on each unit of real property included in the inventory required under subsection (a) not later than 30 days after any change relating to the control of such property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56dd2c12-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2016-03-30"},"text":"March 30, 2016","children":[],"tail":", and every 5 years thereafter, the Commandant shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a report that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56dd2c13-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all real property under the control of the Coast Guard and the location of such property by property type;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2c14-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for divestiture with respect to any units of such property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2c15-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5105/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations for consolidating any units of such property, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56dd2c16-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5105/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the costs or savings associated with each recommended consolidation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56dd2c17-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5105/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discussion of the impact that such consolidation would have on Coast Guard mission effectiveness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56dd2c18-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s217/a"},"text":"Pub. L. 113–281, title II, § 217(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3035"},"text":"128 Stat. 3035","children":[],"tail":", § 679; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3539"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3539","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2322"},"text":"132 Stat. 2322","children":[],"tail":"; renumbered § 5105, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s122/b"},"text":"Pub. L. 115–282, title I, § 122(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4239"},"text":"132 Stat. 4239","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56dd2c19-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56dd2c1a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56dd2c1b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s679"},"text":"section 679 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3539/1"},"text":"Pub. L. 115–232, § 3539(1)","children":[],"tail":", in introductory provisions, substituted “The Commandant shall maintain” for “Not later than "},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"September 30, 2015","children":[],"tail":", the Commandant shall establish”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3539/2"},"text":"Pub. L. 115–232, § 3539(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “The Commandant shall—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) maintain the inventory required under subsection (a) on an ongoing basis; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) update information on each unit of real property included in such inventory not later than 30 days after any change relating to the control of such property.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
