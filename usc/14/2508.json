{"tag":"section","attrib":{"id":"id56c2ed01-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2508"},"text":null,"children":[{"tag":"num","attrib":{"value":"2508"},"text":"§ 2508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency leave retention authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56c2ed02-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A duty assignment for an active duty member of the Coast Guard in support of a declaration of a major disaster or emergency by the President under the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.) or in response to a spill of national significance shall be treated, for the purpose of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s701/e"},"text":"section 701(e) of title 10","children":[],"tail":", as a duty assignment in support of a contingency operation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c2ed03-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c2ed04-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2508/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Spill of national significance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “spill of national significance” means a discharge of oil or a hazardous substance that is declared by the Commandant to be a spill of national significance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c2ed05-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2508/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discharge","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “discharge” has the meaning given that term in section 1001 of the Oil Pollution Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"33 U.S.C. 2701","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56c2ed06-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tII/s207/a"},"text":"Pub. L. 111–281, title II, § 207(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2912"},"text":"124 Stat. 2912","children":[],"tail":", § 426; renumbered § 2508, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s114/b"},"text":"Pub. L. 115–282, title I, § 114(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4223"},"text":"132 Stat. 4223","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVI/s631/c/1"},"text":"Pub. L. 117–263, div. A, title VI, § 631(c)(1)","children":[],"tail":", "},{"tag":"date","