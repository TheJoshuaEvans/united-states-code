{"tag":"section","attrib":{"id":"id56d38f07-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3704"},"text":null,"children":[{"tag":"num","attrib":{"value":"3704"},"text":"§ 3704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grades and ratings; military authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The grades and ratings in the Reserve, including cadets but not grades above rear admiral, are those prescribed by law or regulation for the Coast Guard. A member of the Reserve on active duty or inactive-duty training has the same authority, rights, and privileges in the performance of that duty as a member of the Regular Coast Guard of corresponding grade or rating.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56d38f08-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1003"},"text":"94 Stat. 1003","children":[],"tail":", § 704; renumbered § 3704, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s118/b"},"text":"Pub. L. 115–282, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d38f09-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d38f0a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},