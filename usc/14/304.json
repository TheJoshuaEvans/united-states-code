{"tag":"section","attrib":{"id":"id568287f4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s304"},"text":null,"children":[{"tag":"num","attrib":{"value":"304"},"text":"§ 304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement of Commandant or Vice Commandant","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id568287f5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id568287f6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Commandant who is not reappointed shall be retired with the grade of admiral at the expiration of the appointed term, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s306/d"},"text":"section 306(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id568287f7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Vice Commandant who is retired while serving as Vice Commandant, after serving not less than 2 years as Vice Commandant, shall be retired with the grade of admiral, except as provided in section 306(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id568287f8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Commandant or Vice Commandant who is retired for physical disability shall be placed on the retired list with the grade of admiral.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id568287f9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who is retired prior to the expiration of the officer’s term, while serving as Commandant or as an officer serving as Vice Commandant who has served less than 2 years as Vice Commandant, may, in the discretion of the President, be retired with the grade of admiral.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id568287fa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Retirement under this section is subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2501/a"},"text":"section 2501(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id568287fb-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/499"},"text":"63 Stat. 499","children":[],"tail":", § 46; "},{"tag":"ref","attrib":{"href":"/us/pl/86/474/s1/5"},"text":"Pub. L. 86–474, § 1(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-05-14"},"text":"May 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/144"},"text":"74 Stat. 144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/4"},"text":"Pub. L. 88–130, § 1(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/175"},"text":"77 Stat. 175","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/444/s1/4"},"text":"Pub. L. 89–444, § 1(4)","children":[],"tail":", (5), "},{"tag":"date","attrib":{"date":"1966-06-09"},"text":"June 9, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/195"},"text":"80 Stat. 195","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s2/1"},"text":"Pub. L. 97–295, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1301"},"text":"96 Stat. 1301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/348/tII/s205/b/1"},"text":"Pub. L. 99–348, title II, § 205(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-07-01"},"text":"July 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/699"},"text":"100 Stat. 699","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/206/tII/s204/a"},"text":"Pub. L. 103–206, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2421"},"text":"107 Stat. 2421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s209/2"},"text":"Pub. L. 114–120, title II, § 209(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/40"},"text":"130 Stat. 40","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3528/a"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3528(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2318"},"text":"132 Stat. 2318","children":[],"tail":"; renumbered § 303 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 104(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4196"},"text":"132 Stat. 4196","children":[],"tail":", 4240; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8201(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4641"},"text":"134 Stat. 4641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXII/s11240"},"text":"Pub. L. 117–263, div. K, title CXII, § 11240","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4039"},"text":"136 Stat. 4039","children":[],"tail":"; renumbered § 304, "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7201/b"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1675"},"text":"139 Stat. 1675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id568287fc-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id568287fd-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 161 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1923-01-12/ch25/s2"},"text":"Jan. 12, 1923, ch. 25, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1130"},"text":"42 Stat. 1130","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-25/ch808"},"text":"June 25, 1936, ch. 808","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1924"},"text":"49 Stat. 1924","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1937-06-09/ch309/s1"},"text":"June 9, 1937, ch. 309, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/252"},"text":"50 Stat. 252","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1940-06-06/ch257/s1/a"},"text":"June 6, 1940, ch. 257, § 1(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/246"},"text":"54 Stat. 246","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provision is added for retirement of the Commandant with the grade and pay of vice admiral after 3 years service, in the discretion of the President, regardless of total length of service. Provision is also added for retirement with the grade and pay of vice admiral in case of physical disability. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id568287fe-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id568287ff-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 304 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s303"},"text":"section 303 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 304, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"act Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/518"},"text":"63 Stat. 518","children":[],"tail":", provided for voluntary retirement of warrant officers after thirty years’ service, with retired pay of grade with which retired, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1954-05-29/ch249/s20"},"text":"act May 29, 1954, ch. 249, § 20","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"ref","attrib":{"href":"/us/stat/68/167"},"text":"68 Stat. 167","children":[],"tail":", and by "},{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/A"},"text":"Pub. L. 88–130, § 1(10)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/177"},"text":"77 Stat. 177","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56828800-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s303"},"text":"section 303 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11240/1"},"text":"Pub. L. 117–263, § 11240(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “A Vice Commandant who is not reappointed or appointed Commandant shall be retired with the grade of admiral at the expiration of the appointed term, except as provided in section 306(d).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11240/2"},"text":"Pub. L. 117–263, § 11240(2)","children":[],"tail":", substituted “or as an officer serving as Vice Commandant who has served less than 2 years as Vice Commandant” for “or Vice Commandant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s104/b"},"text":"Pub. L. 115–282, § 104(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s46"},"text":"section 46 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3528/a/1"},"text":"Pub. L. 115–232, § 3528(a)(1)","children":[],"tail":", inserted “or Vice Commandant” after “Commandant” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 306(d)” for “section 51(d)” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3528/a/2"},"text":"Pub. L. 115–232, § 3528(a)(2)","children":[],"tail":", (3), designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3528/a/4"},"text":"Pub. L. 115–232, § 3528(a)(4)","children":[],"tail":", inserted “or Vice Commandant” after “Commandant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3528/a/4"},"text":"Pub. L. 115–232, § 3528(a)(4)","children":[],"tail":", (5), inserted “or Vice Commandant” after “Commandant” and substituted “the officer’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":" substituted “section” for “subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206"},"text":"Pub. L. 103–206","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “Any Commandant who is not reappointed shall, at the expiration of his term, be retired with the grade of admiral.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348"},"text":"Pub. L. 99–348","children":[],"tail":" struck out “and retired pay computed at the highest rates of basic pay applicable to him while he served as Commandant” after “admiral” in subsecs. (a) to (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “Commandant” for “commandant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/444/s1/4"},"text":"Pub. L. 89–444, § 1(4)","children":[],"tail":", removed requirement that the Commandant serve 2½ years as Commandant before being eligible for retirement with the grade of admiral and retired pay computed at the highest rates of basic pay applicable to him while he served as Commandant."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/444/s1/5"},"text":"Pub. L. 89–444, § 1(5)","children":[],"tail":", repealed subsec. (d) which provided that a Commandant who retired within 2½ years of the date of his original appointment as Commandant would retire in his permanent grade and with the retired pay of that grade."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130"},"text":"Pub. L. 88–130","children":[],"tail":" substituted “of admiral and retired pay computed at the highest rates of basic pay applicable to him while he served as Commandant” for “and retired pay of admiral”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/474"},"text":"Pub. L. 86–474","children":[],"tail":" authorized any Commandant who is not reappointed at the expiration of his term to be retired with the grade and retired pay of admiral, directed placement on the retired list with the grade and retired pay of admiral for a Commandant who is retired for physical disability, reduced from three to two and one-half years the period that the Commandant must serve before he may voluntarily apply retirement without regard to total length of service, and provided that any Commandant who retires within two and one-half years of the date of his original appointment as Commandant shall retire in his permanent grade and with the retired pay of that grade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
