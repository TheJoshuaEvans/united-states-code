{"tag":"section","attrib":{"id":"id56a8ad5b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1103"},"text":null,"children":[{"tag":"num","attrib":{"value":"1103"},"text":"§ 1103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of Vice Commandant in major acquisition programs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Vice Commandant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8ad5c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall represent the customer of a major acquisition program with regard to trade-offs made among cost, schedule, technical feasibility, and performance with respect to such program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ad5d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall advise the Commandant in decisions regarding the balancing of resources against priorities, and associated trade-offs referred to in paragraph (1), on behalf of the customer of a major acquisition program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a8ad5e-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s899/b/1/E"},"text":"Pub. L. 114–328, div. A, title VIII, § 899(b)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2334"},"text":"130 Stat. 2334","children":[],"tail":", § 578; renumbered § 1103, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s108/b"},"text":"Pub. L. 115–282, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4208"},"text":"132 Stat. 4208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a8ad5f-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a8ad60-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a8ad61-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s578"},"text":"section 578 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
