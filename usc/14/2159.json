{"tag":"section","attrib":{"id":"id56be31a9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2159"},"text":null,"children":[{"tag":"num","attrib":{"value":"2159"},"text":"§ 2159.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boards of inquiry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56be31aa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2159/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Boards of inquiry shall be convened at such places as the Secretary may prescribe to receive evidence and make findings and recommendations whether an officer who is required to show cause for retention under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2158"},"text":"section 2158 of this title","children":[],"tail":" should be retained on active duty."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56be31ab-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2159/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A fair and impartial hearing before a board of inquiry shall be given to each officer so required to show cause for retention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56be31ac-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2159/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a board of inquiry determines that the officer has failed to establish that he should be retained, it shall recommend to the Secretary that the officer not be retained on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56be31ad-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2159/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a board of inquiry determines that the officer has established that he should be retained, his case is closed. However, at any time after one year from the date of the determination in a case arising under clause (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2158"},"text":"section 2158 of this title","children":[],"tail":", and at any time after the date of the determination in a case arising under clause (2) of that section, an officer may again be required to show cause for retention."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56be31ae-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/188"},"text":"77 Stat. 188","children":[],"tail":", § 322; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s2/10"},"text":"Pub. L. 97–295, § 2(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1302"},"text":"96 Stat. 1302","children":[],"tail":"; renumbered § 2159 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 112(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":", 4240; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7223/b"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7223(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1702"},"text":"139 Stat. 1702","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56be31af-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56be31b0-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56be31b1-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “recommend to the Secretary that the officer not be retained on active duty” for “send the record of its proceedings to a board of review”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s112/b"},"text":"Pub. L. 115–282, § 112(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s322"},"text":"section 322 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 2158” for “section 321”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" inserted “of this title” after “section 321”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
