{"tag":"section","attrib":{"id":"id56d38eff-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3703"},"text":null,"children":[{"tag":"num","attrib":{"value":"3703"},"text":"§ 3703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coast Guard Reserve Boards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d38f00-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall convene a Coast Guard Reserve Policy Board at least annually to consider, recommend, and report to the Secretary on Reserve policy matters. At least one-half of the members of the Board shall be Reserve officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d38f01-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may convene any other Reserve Board the Secretary considers necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d38f02-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1003"},"text":"94 Stat. 1003","children":[],"tail":", § 703; renumbered § 3703, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s118/b"},"text":"Pub. L. 115–282, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","at