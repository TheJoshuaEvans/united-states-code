{"tag":"section","attrib":{"id":"id56980c34-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s527"},"text":null,"children":[{"tag":"num","attrib":{"value":"527"},"text":"§ 527.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safety of vessels of the Armed Forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56980c35-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s527/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may control the anchorage and movement of any vessel in the navigable waters of the United States to ensure the safety or security of any vessel of the Armed Forces in those waters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56980c36-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s527/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary does not exercise the authority in subsection (a) of this section and immediate action is required, the senior officer present in command may control the anchorage or movement of any vessel in the navigable waters of the United States to ensure the safety and security of any vessel of the Armed Forces under the officer’s command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56980c37-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s527/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a person violates, or a vessel is operated in violation of, this section or a regulation or order issued under this section, the person or vessel is subject to the enforcement provisions in section 13 ","children":[{"tag":"ref","attrib":{"idref":"fn002012"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002012"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Ports and Waterways Safety Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1232"},"text":"33 U.S.C. 1232","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56980c38-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s527/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this section “navigable waters of the United States” includes all waters of the territorial sea of the United States as described in Presidential Proclamation No. 5928 of ","children":[{"tag":"date","attrib":{"date":"1988-12-27"},"text":"December 27, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56980c39-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s527/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this title, the term “vessel of the Armed Forces” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56980c3a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s527/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any vessel owned or operated by the Department of Defense or the Coast Guard, other than a time- or voyage-chartered vessel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56980c3b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s527/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any vessel owned and operated by the Department of Transportation that is designated by the Secretary of the department in which the Coast Guard is operating as a vessel equivalent to a vessel described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56980c3c-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/503"},"text":"63 Stat. 503","children":[],"tail":", § 91; "},{"tag":"ref","attrib":{"href":"/us/pl/99/640/s10/a/4"},"text":"Pub. L. 99–640, § 10(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3549"},"text":"100 Stat. 3549","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tII/s201"},"text":"Pub. L. 109–241, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/519"},"text":"120 Stat. 519","children":[],"tail":"; renumbered § 527 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s105/b"},"text":"Pub. L. 115–282, title I, § 105(b)","children":[],"tail":", title III, § 318(a), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4200"},"text":"132 Stat. 4200","children":[],"tail":", 4251.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56980c3d-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56980c3e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 48a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-11-15/ch471/s1"},"text":"Nov. 15, 1941, ch. 471, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/763"},"text":"55 Stat. 763","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56980c3f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56980c40-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 13 of the Ports and Waterways Safety Act, referred to in subsec. (c), was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIV/s402/e"},"text":"Pub. L. 115–282, title IV, § 402(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4264"},"text":"132 Stat. 4264","children":[],"tail":". See Transitional and Savings Provisions note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of Title 46","children":[],"tail":", Shipping, and "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s70036"},"text":"section 70036 of Title 46","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Presidential Proclamation No. 5928, referred to in subsec. (d), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56980c41-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s318/a/1"},"text":"Pub. L. 115–282, § 318(a)(1)","children":[],"tail":", substituted “vessels of the Armed Forces” for “naval vessels” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s105/b"},"text":"Pub. L. 115–282, § 105(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s91"},"text":"section 91 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s318/a/2"},"text":"Pub. L. 115–282, § 318(a)(2)","children":[],"tail":", substituted “vessel of the Armed Forces” for “United States naval vessel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s318/a/3"},"text":"Pub. L. 115–282, § 318(a)(3)","children":[],"tail":", substituted “senior officer present in command” for “senior naval officer present in command” and “vessel of the Armed Forces” for “United States naval vessel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s318/a/4"},"text":"Pub. L. 115–282, § 318(a)(4)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241"},"text":"Pub. L. 109–241","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/640"},"text":"Pub. L. 99–640","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The captain of the port, Coast Guard district commander, or other officer of the Coast Guard designated by the Commandant thereof, or the Governor of the Panama Canal in the case of the territory and waters of the Canal Zone, shall so control the anchorage and movement of any vessel, foreign or domestic, in the territorial waters of the United States, as to insure the safety or security of such United States naval vessels as may be present in his jurisdiction. In territorial waters of the United States where immediate action is required, or where representatives of the Coast Guard are not present, or not present in sufficient force to exercise effective control of shipping as provided herein, the senior naval officer present in command of any naval force may control the anchorage or movement of any vessel, foreign or domestic, to the extent deemed necessary to insure the safety and security of his command.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
