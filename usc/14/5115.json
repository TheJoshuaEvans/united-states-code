{"tag":"section","attrib":{"id":"id56df7584-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115"},"text":null,"children":[{"tag":"num","attrib":{"value":"5115"},"text":"§ 5115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major grants, contracts, or other transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56df7585-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56df7586-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), the Commandant shall notify the appropriate committees of Congress and the Coast Guard Office of Congressional and Governmental Affairs not later than 3 full business days in advance of the Coast Guard—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56df7587-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making or awarding a grant allocation or grant in excess of $1,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df7588-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making or awarding a contract, other transaction agreement, or task or delivery order for the Coast Guard on the multiple award contract, or issuing a letter of intent totaling more than $4,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df7589-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" awarding a task or delivery order requiring an obligation of funds in an amount greater than $10,000,000 from multi-year Coast Guard funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df758a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making a sole-source grant award; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df758b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" announcing publicly the intention to make or award an item described in subparagraph (A), (B), (C), or (D), including a contract covered by the Federal Acquisition Regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df758c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Element","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A notification under this subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56df758d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the award;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df758e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fiscal year for which the funds for the award were appropriated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df758f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df7590-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the entity awarded the contract, such as the name and location of the entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df7591-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the account from which the funds are to be drawn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56df7592-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Commandant determines that compliance with subsection (a) would pose a substantial risk to human life, health, or safety, the Commandant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56df7593-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make an award or issue a letter described in such subsection without the notification required under such subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df7594-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall notify the appropriate committees of Congress not later than 5 full business days after such an award is made or letter issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56df7595-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall not apply to funds that are not available for obligation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56df7596-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate Committees of Congress Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56df7597-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df7598-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5115/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Transportation and Infrastructure and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56df7599-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXII/s11262/a"},"text":"Pub. L. 117–263, div. K, title CXII, § 11262(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4060"},"text":"136 Stat. 4060","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
