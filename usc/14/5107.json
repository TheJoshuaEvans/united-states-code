{"tag":"section","attrib":{"id":"id56dd2c21-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107"},"text":null,"children":[{"tag":"num","attrib":{"value":"5107"},"text":"§ 5107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly acquisition reports and major acquisition program risk assessment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56dd2c22-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 45 days after the end of each fiscal quarter, the Commandant shall provide to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a briefing on all Level 1 and Level 2 acquisition programs, as such terms are defined in section 1171.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56dd2c23-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Briefing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 week before taking procurement actions that will significantly impact the costs or timelines of a Level 1 or Level 2 acquisition program, the Commandant shall brief the committees described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56dd2c24-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each briefing required under subsection (a) or (b) shall include, for each program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56dd2c25-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the purpose of the program, including the capabilities being acquired;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2c26-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of units, as appropriate, to be acquired annually until procurement is complete under the current acquisition program baseline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2c27-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Acquisition Review Board status, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56dd2c28-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current acquisition phase by increment, as applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df7519-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the most recent review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df751a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the program has been paused or is in breach status;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df751b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison between the initial Department-approved acquisition program baseline cost, schedule, and performance thresholds and objectives and the current such thresholds and objectives of the program, if applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df751c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lifecycle cost estimate, adjusted for comparison to the Future Coast Guard Program, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56df751d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the confidence level for the estimate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df751e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fiscal years included in the estimate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df751f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a breakout of the estimate for the prior five years, the current year, and the budget year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df7520-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a breakout of the estimate by appropriation account or other funding source; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df7521-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of and rationale for any changes to the estimate as compared to the previous quarter or to the previously approved baseline, as applicable;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df7522-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the findings of any independent verification and validation of the items to be acquired or an explanation for why no such verification and validation has been performed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df7523-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a table displaying the obligation of all program funds by prior fiscal year, the estimated obligation of funds for the current fiscal year, and an estimate for the planned carryover of funds into the subsequent fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df7524-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a listing of prime contractors and major subcontractors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df7525-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" narrative descriptions of risks to cost, schedule, or performance that could result in a program breach if not successfully mitigated, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56df7526-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current risks to such program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df7527-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any failure of such program to demonstrate a key performance parameter or threshold during operational test and evaluation conducted during the previous fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df7528-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there has been any decision in such fiscal year to order full-rate production before all key performance parameters or thresholds are met;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df7529-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there has been any breach of major acquisition program cost (as such term is defined in the manual of the Coast Guard titled “Major Systems Acquisition Manual” (COMDTINST M5000.10C)) in such fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df752a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/c/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there has been any breach of major acquisition program schedule (as such term is defined in the manual of the Coast Guard titled “Major Systems Acquisition Manual” (COMDTINST M5000.10C)) during such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56df752b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Memorandum Deadline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 5 business days after the date on which the Secretary approves an Acquisition Decision Memorandum for programs described in this section, the Commandant shall submit such memorandum to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56df752c-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3526/a"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3526(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2317"},"text":"132 Stat. 2317","children":[],"tail":", § 2906; renumbered § 5107 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 122(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4239"},"text":"132 Stat. 4239","children":[],"tail":", 4240; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8240(e), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4667"},"text":"134 Stat. 4667","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXI"},"text":"Pub. L. 119–60, div. G, title LXXI","children":[],"tail":", §§ 7112(b), 7113(a), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1666"},"text":"139 Stat. 1666","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56df752d-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56df752e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56df752f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7113/a"},"text":"Pub. L. 119–60, § 7113(a)","children":[],"tail":", amended section generally. Prior to amendmemnt, section related to major acquisition program risk assessment."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7112/b"},"text":"Pub. L. 119–60, § 7112(b)","children":[],"tail":", substituted “section 1171” for “section 5103(f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8240/e/1"},"text":"Pub. L. 116–283, § 8240(e)(1)","children":[],"tail":", substituted “October 15” for “April 15 and October 15”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8240/e/2/A"},"text":"Pub. L. 116–283, § 8240(e)(2)(A)","children":[],"tail":", substituted “the previous fiscal year” for “the 2 fiscal-year quarters preceding such assessment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8240/e/2/B"},"text":"Pub. L. 116–283, § 8240(e)(2)(B)","children":[],"tail":", substituted “such fiscal year” for “such 2 fiscal-year quarters”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8240/e/2/C"},"text":"Pub. L. 116–283, § 8240(e)(2)(C)","children":[],"tail":", substituted “such fiscal year” for “such 2 fiscal-year quarters”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8240/e/2/D"},"text":"Pub. L. 116–283, § 8240(e)(2)(D)","children":[],"tail":", substituted “such fiscal year” for “such 2 fiscal-year quarters”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s122/b"},"text":"Pub. L. 115–282, § 122(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2906"},"text":"section 2906 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 5103(f)” for “section 2903(f)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
