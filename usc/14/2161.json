{"tag":"section","attrib":{"id":"id56be31b5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2161"},"text":null,"children":[{"tag":"num","attrib":{"value":"2161"},"text":"§ 2161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition of boards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56be31b6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2161/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A board convened under section 2158 or 2159 of this title shall consist of at least three officers of the grade of commander or above, all of whom are serving in a grade senior to the grade of any officer considered by the board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56be31b7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2161/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No individual may be a member of more than one board convened under section 2158 or 2159 of this title to consider the same officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56be31b8-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/188"},"text":"77 Stat. 188","children":[],"tail":", § 324; renumbered § 2161 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 112(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Sta