{"tag":"section","attrib":{"id":"id56cc625d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2711"},"text":null,"children":[{"tag":"num","attrib":{"value":"2711"},"text":"§ 2711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deserters; payment of expenses incident to apprehension and delivery; penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56cc625e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2711/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Coast Guard may, pursuant to regulations prescribed by the Secretary, make such expenditures as are deemed necessary for the apprehension and delivery of deserters, stragglers, and prisoners.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56cc625f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2711/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No individual who is convicted by court martial for desertion from the Coast Guard in time of war, and as the result of such conviction is dismissed or dishonorably discharged from the Coast Guard shall afterwards be enlisted, appointed, or commissioned in any military or naval service under the United States, unless the disability resulting from desertion, as established by this section is removed by a board of commissioned officers of the Coast Guard convened for consideration of the case, and the action of the Board is approved by the Secretary; or unless he is restored to duty in time of war.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56cc6260-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-05-05/ch169/s16/a"},"text":"May 5, 1950, ch. 169, § 16(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/148"},"text":"64 Stat. 148","children":[],"tail":", § 508; amended "},{"tag":"ref","attrib":{"href":"/us/act/1952-07-10/ch631/s2"},"text":"July 10, 1952, ch. 631, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/540"},"text":"66 Stat. 540","children":[],"tail":"; renumbered § 2711, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(24), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4749"},"text":"134 Stat. 4749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56cc6261-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56cc6262-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56cc6263-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “individual” for “person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s508"},"text":"section 508 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1952—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1952-07-10"},"text":"July 10, 1952","children":[],"tail":", authorized reimbursement of necessary expenses to persons other than civil officers, and added stragglers and prisoners to class of offenders."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56cc6264-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id56cc6265-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1951-05-31"},"text":"May 31, 1951","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/act/1950-05-05/ch169/s5"},"text":"act May 5, 1950, ch. 169, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/145"},"text":"64 Stat. 145","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
