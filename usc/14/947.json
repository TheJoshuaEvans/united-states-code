{"tag":"section","attrib":{"id":"id56a63ca3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s947"},"text":null,"children":[{"tag":"num","attrib":{"value":"947"},"text":"§ 947.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessel construction bonding requirements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary or the Commandant may require bid, payment, performance, payment and performance, or completion bonds or other financial instruments from contractors for construction, alteration, repair, or maintenance of Coast Guard vessels if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63ca4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s947/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bond is required by law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63ca5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s947/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary or Commandant determines after investigation that the amount of the bond in excess of 20 percent of the value of the base contract quantity excluding options, would not prevent a responsible bidder or offeror from competing for award of the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a63ca6-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/595/tIII/s306/a"},"text":"Pub. L. 101–595, title III, § 306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2985"},"text":"104 Stat. 2985","children":[],"tail":", § 667; renumbered § 947, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s107/b"},"text":"Pub. L. 115–282, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4205"},"text":"132 Stat. 4205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a63ca7-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a63ca8-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a63ca9-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s667"},"text":"section 667 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
