{"tag":"section","attrib":{"id":"id56b9504f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2122"},"text":null,"children":[{"tag":"num","attrib":{"value":"2122"},"text":"§ 2122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of officer from list of selectees for promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56b95050-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may remove the name of any officer from a list of selectees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2121"},"text":"section 2121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b95051-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Senate does not consent to the appointment of an officer whose name is on a list of selectees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2121"},"text":"section 2121 of this title","children":[],"tail":", that officer’s name shall be removed from this list."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b95052-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer whose name is removed from a list under subsection (a) or (b) continues to be eligible for consideration for promotion. If he is selected for promotion by the next selection board and promoted, he shall be given the date of rank and position on the active duty promotion list in the grade to which promoted that he would have held if his name had not been removed. However, if the officer is not selected by the next selection board or if his name is again removed from the list of selectees, he shall be considered for all purposes as having twice failed of selection for promotion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56b95053-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/182"},"text":"77 Stat. 182","children":[],"tail":", § 272; renumbered § 2122 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 112(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56b95054-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56b95055-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56b95056-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s112/b"},"text":"Pub. L. 115–282, § 112(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s272"},"text":"section 272 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 2121” for “section 271”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id56b95057-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56b95058-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Authority of President under subsec. (a) of this section to remove a name of an officer from a list of selectees delegated to Secretary of Homeland Security by Ex. Ord. No. 14106, § 1(b), ","children":[{"tag":"date","attrib":{"date":"2023-08-14"},"text":"Aug. 14, 2023","children":[],"tail":", 88 F.R. 55905, set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2101"},"text":"section 2101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
