{"tag":"section","attrib":{"id":"id56cc62bb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2741"},"text":null,"children":[{"tag":"num","attrib":{"value":"2741"},"text":"§ 2741.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time limit on award; report concerning deed","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56cc62bc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2741/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No medal of honor, Coast Guard cross, distinguished service medal, silver star medal, distinguished flying cross, Coast Guard medal, or bar, emblem, or insignia in lieu thereof may be awarded to an individual unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56cc62bd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2741/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the award is made within five years after the date of the deed or service justifying the award;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56cc62be-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2741/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement setting forth the deed or distinguished service and recommending official recognition of it was made by his superior through official channels within three years from the date of that deed or termination of the service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56cc62bf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2741/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56cc62c0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2741/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement setting forth the deed or distinguished service and recommending official recognition of it was made by the individual’s superior through official channels within three years from the date of that deed or termination of the service and was supported by sufficient evidence within that time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56cc62c1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2741/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no award was made, because the statement was lost or through inadvertence the recommendation was not acted upon; a medal of honor, Coast Guard cross, distinguished service medal, silver star medal, distinguished flying cross, Coast Guard medal, or bar, emblem, or insignia in lieu thereof, as the case may be, may be awarded to the individual within two years after the date of that determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56cc62c2-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/536"},"text":"63 Stat. 536","children":[],"tail":", § 496; "},{"tag":"ref","attrib":{"href":"/us/pl/87/526/s1/5"},"text":"Pub. L. 87–526, § 1(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-07-10"},"text":"July 10, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/141"},"text":"76 Stat. 141","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tII/s224/c/2"},"text":"Pub. L. 111–281, title II, § 224(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2922"},"text":"124 Stat. 2922","children":[],"tail":"; renumbered § 2741, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(34), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4749"},"text":"134 Stat. 4749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56cc62c3-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56cc62c4-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section establishes a time limit on the making of awards. It follows the established practice in all the armed forces (see title 10, U.S.C., 1946 ed., § 1409 and title 34, U.S.C., 1946 ed., § 360). 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56cc62c5-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56cc62c6-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8505/a/34/A"},"text":"Pub. L. 116–283, § 8505(a)(34)(A)","children":[],"tail":", substituted “an individual” for “a person” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8505/a/34/B"},"text":"Pub. L. 116–283, § 8505(a)(34)(B)","children":[],"tail":", substituted “individual’s” for “person’s”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8505/a/34/C"},"text":"Pub. L. 116–283, § 8505(a)(34)(C)","children":[],"tail":", substituted “individual” for “person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s496"},"text":"section 496 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s224/c/2/A"},"text":"Pub. L. 111–281, § 224(c)(2)(A)","children":[],"tail":", substituted “Coast Guard cross, distinguished service medal, silver star medal, distinguished flying cross,” for “distinguished service medal, distinguished flying cross,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s224/c/2/B"},"text":"Pub. L. 111–281, § 224(c)(2)(B)","children":[],"tail":", substituted “Coast Guard cross, distinguished service medal, silver star medal, distinguished flying cross,” for “distinguished service medal, distinguished flying cross,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/526"},"text":"Pub. L. 87–526","children":[],"tail":" incorporated existing provisions in subsec. (a), included the distinguished flying cross and bar in lieu of any award in the enumeration of medals, and extended the time limit for recommending award of a medal after performance of the deed justifying the award from one to three years and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
