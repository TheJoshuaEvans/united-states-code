{"tag":"section","attrib":{"id":"id56cc6277-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2731"},"text":null,"children":[{"tag":"num","attrib":{"value":"2731"},"text":"§ 2731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of powers to make awards; rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may delegate to the Secretary, under such conditions, regulations, and limitations as he prescribes, the powers conferred upon him to make the awards designated in this chapter, and the President may make any and all rules, regulations, and orders which he deems necessary in the conferring of such awards.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56cc6278-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/536"},"text":"63 Stat. 536","children":[],"tail":", § 499; renumbered § 2731, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56cc6279-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56cc627a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section provides for the delegation of powers to make awards to the Secretary. The Navy statute provides for such delegation to force commanders (see title 34, U.S.C., 1946 ed., § 364). 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56cc627b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56cc627c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s499"},"text":"section 499 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
