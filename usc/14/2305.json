{"tag":"section","attrib":{"id":"id56c07b1b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2305"},"text":null,"children":[{"tag":"num","attrib":{"value":"2305"},"text":"§ 2305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary retirement after thirty years’ service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any enlisted member who has completed thirty years’ service may, upon his own application, in the discretion of the Commandant, be retired from active service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56c07b1c-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/521"},"text":"63 Stat. 521","children":[],"tail":", § 354; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/3/A"},"text":"Pub. L. 98–557, § 15(a)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/348/tII/s205/b/8"},"text":"Pub. L. 99–348, title II, § 205(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-07-01"},"text":"July 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/700"},"text":"100 Stat. 700","children":[],"tail":"; renumbered § 2305, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s113/b"},"text":"Pub. L. 115–282, title I, § 113(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4221"},"text":"132 Stat. 4221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c07b1d-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56c07b1e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 175 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1915-01-28/ch20/s3"},"text":"Jan. 28, 1915, ch. 20, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/801"},"text":"38 Stat. 801","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said section has been divided. That part dealing with retirement of enlisted men is placed in this section. That part dealing with retirement of commissioned officers is placed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s231"},"text":"section 231 of this title","children":[],"tail":". That part dealing with retirement of warrant officers is placed in "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s304"},"text":"section 304 of this title","children":[],"tail":". That part providing for retired pay is incorporated in "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s423"},"text":"section 423 of this title","children":[],"tail":". That part providing for assignment of duties to retired personnel is incorporated in sections 241, 311, and 360 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The authority to approve was granted to the Commandant in lieu of the Secretary. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c07b1f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c07b20-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s354"},"text":"section 354 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348"},"text":"Pub. L. 99–348","children":[],"tail":" struck out “, with retired pay of the grade or rating with which retired” after “active service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted reference to enlisted member for reference to enlisted man."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
