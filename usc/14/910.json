{"tag":"section","attrib":{"id":"id56a182ae-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s910"},"text":null,"children":[{"tag":"num","attrib":{"value":"910"},"text":"§ 910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small boat station closures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a182af-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s910/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Closures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not close a Coast Guard multimission small boat station or subunit unless the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a182b0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s910/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a182b1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s910/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remaining search and rescue capabilities maintain the safety of the maritime public in the area of the station or subunit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a182b2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s910/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional or local prevailing weather and marine conditions, including water temperature or unusual tide and current conditions, do not require continued operation of the station or subunit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a182b3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s910/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coast Guard search and rescue standards related to search and rescue response times are met; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f2b4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s910/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an opportunity for public comment and for public meetings in the area of the station or subunit with regard to the decision to close the station or subunit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a3f2b5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s910/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operational Flexibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may implement any management efficiencies within the small boat station system, such as modifying the operational posture of units or reallocating resources as necessary to ensure the safety of the maritime public nationwide. No stations or subunits may be closed under this subsection except in accordance with subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a3f2b6-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tIII/s309/a"},"text":"Pub. L. 104–324, title III, § 309(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3919"},"text":"110 Stat. 3919","children":[],"tail":", § 674; renumbered § 675, "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIV/s405/a/1"},"text":"Pub. L. 107–295, title IV, § 405(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2115"},"text":"116 Stat. 2115","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/a"},"text":"Pub. L. 107–296, title XVII, § 1704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tII/s217/13"},"text":"Pub. L. 112–213, title II, § 217(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1558"},"text":"126 Stat. 1558","children":[],"tail":"; renumbered § 910, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s107/b"},"text":"Pub. L. 115–282, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4205"},"text":"132 Stat. 4205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a3f2b7-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a3f2b8-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a3f2b9-293