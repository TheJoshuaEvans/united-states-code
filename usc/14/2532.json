{"tag":"section","attrib":{"id":"id56c7a737-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2532"},"text":null,"children":[{"tag":"num","attrib":{"value":"2532"},"text":"§ 2532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to maintain certain records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56c7a738-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2532/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall maintain all work product related to documenting a disposition decision on an investigation by the Coast Guard Investigative Service or other law enforcement entity investigating a Coast Guard member accused of an offense against chapter 47 of title 10.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c7a739-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2532/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Record Retention Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Work product documents and the case action summary described in subsection (c) shall be maintained for a period of not less than 7 years from the date of the disposition decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c7a73a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2532/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Case Action Summary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon a final disposition action for cases described in subsection (a), except for offenses of wrongful use or possession of a controlled substance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s912a"},"text":"section 912a of title 10","children":[],"tail":" (article 112a of the Uniform Code of Military Justice), where the member accused is an officer of pay grade O–4 and below or an enlisted member of pay grade E–7 and below, a convening authority shall sign a case action summary that includes the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c7a73b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2532/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The disposition actions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c7a73c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2532/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name and command of the referral authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c7a73d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2532/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Records documenting when a referral authority consulted with a staff judge advocate or special trial counsel, as applicable, before a disposition action was taken, to include the recommendation of the staff judge advocate or special trial counsel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c7a73e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2532/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A reference section listing the materials reviewed in making a disposition decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c7a73f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2532/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Coast Guard Investigative Service report of investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c7a740-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2532/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The completed Coast Guard Investigative Service report of adjudication included as an enclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c7a741-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2532/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “work product” includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c7a742-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2532/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a prosecution memorandum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c7a743-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2532/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emails, notes, and other correspondence related to a disposition decision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c7a744-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2532/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contents described in paragraphs (1) through (6) of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c7a745-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2532/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Clause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section authorizes or requires, or shall be construed to authorize or require, the discovery, inspection, or production of reports, memoranda, or other internal documents or work product generated by counsel, an attorney for the Government, or their assistants or representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ca1846-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXV/s7511/a"},"text":"Pub. L. 119–60, div. G, title LXXV, § 7511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1795"},"text":"139 Stat. 1795","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ca1847-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ca1848-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56ca1849-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2532, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8510(b), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4757"},"text":"134 Stat. 4757","children":[],"tail":", which related to retirement of certain employees of former Lighthouse Service, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXVIII/s11808/a/18"},"text":"Pub. L. 117–263, div. K, title CXVIII, § 11808(a)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4166"},"text":"136 Stat. 4166","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
