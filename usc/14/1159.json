{"tag":"section","attrib":{"id":"id56ad6906-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1159"},"text":null,"children":[{"tag":"num","attrib":{"value":"1159"},"text":"§ 1159.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Floating drydock for United States Coast Guard Yard","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56ad6907-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1159/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), the Commandant, using funds appropriated pursuant to section 1181, may not acquire, procure, or construct a floating dry dock for the Coast Guard Yard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ad6908-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1159/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Permissible Acquisition, Procurement, or Construction Methods","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (a) of this section and section 1105(a), the Commandant may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ad6909-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1159/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for an entity other than the Coast Guard to contract for the acquisition, procurement, or construction of a floating drydock by contract, purchase, or other agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad690a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1159/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construct a floating drydock at the Coast Guard Yard; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad690b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1159/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire or procure a commercially available floating drydock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ad690c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1159/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Design Standards and Construction Practices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent practicable, a floating drydock acquired, procured, or constructed under this section shall reflect commercial design standards and commercial construction practices that are consistent with the best interests of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ad690d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1159/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Berthing Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any floating drydock acquired, procured, or constructed under subsection (b) shall be berthed at the Coast Guard Yard in Baltimore, Maryland, when lifting or maintaining vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ad690e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1159/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Floating Drydock Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “floating drydock” means equipment that is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ad690f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1159/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constructed in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad6910-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1159/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capable of meeting the lifting and maintenance requirements of an Offshore Patrol Cutter or a National Security Cutter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ad6911-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7214/a"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7214(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1695"},"text":"139 Stat. 1695","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
