{"tag":"section","attrib":{"id":"id5684f921-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s306"},"text":null,"children":[{"tag":"num","attrib":{"value":"306"},"text":"§ 306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5684f922-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer, other than the Commandant or Vice Commandant, who, while serving in the grade of admiral or vice admiral, is retired for physical disability shall be placed on the retired list with the highest grade in which that officer served satisfactorily, as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2501"},"text":"section 2501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5684f923-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer, other than the Commandant or Vice Commandant, who is retired while serving in the grade of admiral or vice admiral, or who, after serving at least 2½ years in the grade of admiral or vice admiral, is retired while serving in a lower grade, may in the discretion of the President, be retired with the highest grade in which that officer served satisfactorily, as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2501"},"text":"section 2501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5684f924-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer, other than the Commandant or Vice Commandant, who, after serving less than 2½ years in the grade of admiral or vice admiral, is retired while serving in a lower grade, shall be retired in his permanent grade if performance of duties in such grade is determined to have been satisfactory pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2501"},"text":"section 2501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5684f925-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer serving in the grade of admiral or vice admiral shall continue to hold that grade—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5684f926-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s306/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while being processed for physical disability retirement, beginning on the day of the processing and ending on the day that officer is retired, but not for more than 180 days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5684f927-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s306/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while awaiting retirement, beginning on the day that officer is relieved from the position of Commandant, Vice Commandant, or Vice Admiral and ending on the day before the officer’s retirement, but not for more than 60 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5684f928-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/451/s1/5"},"text":"Pub. L. 92–451, § 1(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-02"},"text":"Oct. 2, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/755"},"text":"86 Stat. 755","children":[],"tail":", § 51; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/348/tII/s205/b/3"},"text":"Pub. L. 99–348, title II, § 205(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-07-01"},"text":"July 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/700"},"text":"100 Stat. 700","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/206/tII"},"text":"Pub. L. 103–206, title II","children":[],"tail":", §§ 204(d), 205(c), "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2421"},"text":"107 Stat. 2421","children":[],"tail":", 2422; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tV/s511/c"},"text":"Pub. L. 111–281, title V, § 511(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2952"},"text":"124 Stat. 2952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s201/c"},"text":"Pub. L. 114–120, title II, § 201(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/33"},"text":"130 Stat. 33","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3528/b"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3528(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2318"},"text":"132 Stat. 2318","children":[],"tail":"; renumbered § 306, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s104/b"},"text":"Pub. L. 115–282, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4196"},"text":"132 Stat. 4196","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8201(b), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4641"},"text":"134 Stat. 4641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7201/b"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1675"},"text":"139 Stat. 1675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5684f929-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5684f92a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5684f92b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 306, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"act Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/519"},"text":"63 Stat. 519","children":[],"tail":", related to retirement for disabilities incident to service, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1950-08-03/ch536/s36"},"text":"act Aug. 3, 1950, ch. 536, § 36","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/408"},"text":"64 Stat. 408","children":[],"tail":", and by "},{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/A"},"text":"Pub. L. 88–130, § 1(10)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/177"},"text":"77 Stat. 177","children":[],"tail":". See sections 1204 and 1376 of Title 10, Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5684f92c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s306"},"text":"section 306 of this title","children":[],"tail":" as this section, resulting in no change."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8201/b/1"},"text":"Pub. L. 116–283, § 8201(b)(1)","children":[],"tail":", inserted “satisfactorily, as determined under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2501"},"text":"section 2501 of this title","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8201/b/2"},"text":"Pub. L. 116–283, § 8201(b)(2)","children":[],"tail":", inserted “satisfactorily, as determined under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2501"},"text":"section 2501 of this title","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8201/b/3"},"text":"Pub. L. 116–283, § 8201(b)(3)","children":[],"tail":", inserted “if performance of duties in such grade is determined to have been satisfactory pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2501"},"text":"section 2501 of this title","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s51"},"text":"section 51 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “other than the Commandant or Vice Commandant,” for “other than the Commandant,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":" inserted “admiral or” before “vice admiral,” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s511/c/1"},"text":"Pub. L. 111–281, § 511(c)(1)","children":[],"tail":", added subsecs. (a) to (c) and struck out former subsecs. (a) to (c) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) An officer who, while serving in the grade of vice admiral, is retired for physical disability shall be placed on the retired list with the grade of vice admiral.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) An officer who is retired while serving in the grade of vice admiral, or who, after serving at least two and one-half years in the grade of vice admiral, is retired while serving in a lower grade, may in the discretion of the President, be retired with the grade of vice admiral.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) An officer who, after serving less than two and one-half years in the grade of vice admiral, is retired while serving in a lower grade, shall be retired in his permanent grade.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s511/c/2"},"text":"Pub. L. 111–281, § 511(c)(2)","children":[],"tail":", substituted “or Vice Admiral” for “Area Commander, or Chief of Staff”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206/s205/c/1"},"text":"Pub. L. 103–206, § 205(c)(1)","children":[],"tail":", substituted “in the grade of vice admiral” for “as Commander, Atlantic Area, or Commander, Pacific Area”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206/s205/c/2"},"text":"Pub. L. 103–206, § 205(c)(2)","children":[],"tail":", substituted “in the grade of vice admiral” for “as Commander, Atlantic Area, or Commander, Pacific Area”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206/s204/d"},"text":"Pub. L. 103–206, § 204(d)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348/s205/b/3/A"},"text":"Pub. L. 99–348, § 205(b)(3)(A)","children":[],"tail":", struck out “and retired pay” after “with the grade”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348/s205/b/3/B"},"text":"Pub. L. 99–348, § 205(b)(3)(B)","children":[],"tail":", struck out “and with the retired pay of that grade” after “permanent grade”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5684f92d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5684f92e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1972-10-02"},"text":"Oct. 2, 1972","children":[],"tail":", except that continuation boards may not be held until one year there­after, see "},{"tag":"ref","attrib":{"href":"/us/pl/92/451/s3"},"text":"section 3 of Pub. L. 92–451","children":[],"tail":", set out as an Effective Date of 1972 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2151"},"text":"section 2151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
