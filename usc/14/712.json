{"tag":"section","attrib":{"id":"id569f1090-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s712"},"text":null,"children":[{"tag":"num","attrib":{"value":"712"},"text":"§ 712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts with Government-owned establishments for work and material","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id569f1091-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All orders or contracts for work or material, under authorization of law, placed with Government-owned establishments by the Coast Guard, shall be considered as obligations in the same manner as provided for similar orders or contracts placed with private contractors, and appropriations for such work or material shall remain available for payment therefor as in the case of orders or contracts placed with private contractors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f1092-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Orders and Agreements for Industrial Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under this section, the Coast Guard industrial activities may accept orders from and enter into reimbursable agreements with establishments, agencies, and departments of the Department of Defense and the Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id569f1093-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/507"},"text":"63 Stat. 507","children":[],"tail":", § 151; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tII/s202"},"text":"Pub. L. 111–281, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2909"},"text":"124 Stat. 2909","children":[],"tail":"; renumbered § 712, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s106/b"},"text":"Pub. L. 115–282, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4203"},"text":"132 Stat. 4203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569f1094-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id569f1095-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 31c (","children":[{"tag":"ref","attrib":{"href":"/us/act/1942-06-06/ch384"},"text":"June 6, 1942, ch. 384","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/328"},"text":"56 Stat. 328","children":[],"tail":"). 81st Congress, House Report No. 557."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569f1096-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id569f1097-2930-11f1-a4c1-c53