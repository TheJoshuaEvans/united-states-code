{"tag":"section","attrib":{"id":"id56bbc0d6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2141"},"text":null,"children":[{"tag":"num","attrib":{"value":"2141"},"text":"§ 2141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation of commissions during first five years of commissioned service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, under such regulations as he may prescribe, may revoke the commission of any regular officer on active duty who, at the date of such revocation, has had less than five years of continuous service as a commissioned officer in the Regular Coast Guard.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56bbc0d7-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/183"},"text":"77 Stat. 183","children":[],"tail":", § 281; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIV/s416/a/1"},"text":"Pub. L. 107–295, title IV, § 416(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2121"},"text":"116 Stat. 2121","children":[],"tail":"; renumbered § 2141, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s112/b"},"text":"Pub. L. 115–282, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56bbc0d8-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","a