8","children":[],"tail":" (46 App. U.S.C. 740; popularly known as the Admiralty Extension Act).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" inserted “of the Coast Guard Auxiliary” after “Administration” in section catchline and amended text generally. Prior to amendment, text read as follows: “The Coast Guard Auxiliary established on "},{"tag":"date","attrib":{"date":"1941-02-19"},"text":"February 19, 1941","children":[],"tail":", is a nonmilitary organization administered by the Commandant under the direction of the Secretary.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56dab9c6-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56dab9c7-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Use of Coast Guard Auxiliary","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/640/s9"},"text":"Pub. L. 99–640, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3548"},"text":"100 Stat. 3548","children":[],"tail":", required the Secretary of Transportation to investigate and submit to Congress a report within 1 year after "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", regarding the membership decline in the Coast Guard Auxiliary, its effect on the maritime community, and recommendations for legislative and administrative action to achieve and maintain the Coast Guard Auxiliary at its optimum strength."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
