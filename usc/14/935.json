{"tag":"section","attrib":{"id":"id56a3f329-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s935"},"text":null,"children":[{"tag":"num","attrib":{"value":"935"},"text":"§ 935.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coast Guard band recordings for commercial sale","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a3f32a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s935/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Coast Guard band may produce recordings for commercial sale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a3f32b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s935/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts received as proceeds from the sale of any such recordings may be credited to applicable appropriations of the Coast Guard for expenses of the Coast Guard band.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a3f32c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s935/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe regulations governing the accounting of such proceeds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a3f32d-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tIII/s327/d/1"},"text":"Pub. L. 101–510, div. A, title III, § 327(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1532"},"text":"104 Stat. 1532","children":[],"tail":", § 640; renumbered § 935, "},{"tag"