{"tag":"section","attrib":{"id":"id56daba0e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3910"},"text":null,"children":[{"tag":"num","attrib":{"value":"3910"},"text":"§ 3910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Radio station deemed government station","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any radio station, while assigned to authorized Coast Guard duty shall be deemed to be a radio station of the Coast Guard and a “government station” within the meaning of section 305 of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s305"},"text":"47 U.S.C. 305","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56daba0f-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/556"},"text":"63 Stat. 556","children":[],"tail":", § 829; "},{"tag":"ref","attrib":{"href":"/us/pl/94/546/s1/38"},"text":"Pub. L. 94–546, § 1(38)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2522"},"text":"90 Stat. 2522","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/640/s10/a/8"},"text":"Pub. L. 99–640, § 10(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3549"},"text":"100 Stat. 3549","children":[],"tail":"; renumbered § 3910, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s119/b"},"text":"Pub. L. 115–282, title I, § 119(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4236"},"text":"132 Stat. 4236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56daba10-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56daba11-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 266b (","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-02-19/ch8"},"text":"Feb. 19, 1941, ch. 8","children":[],"tail":", title I, § 7B, as added "},{"tag":"ref","attrib":{"href":"/us/act/1944-09-30/ch453/s4"},"text":"Sept. 30, 1944, ch. 453, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/760"},"text":"58 Stat. 760","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56daba12-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56daba13-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s829"},"text":"section 829 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/640"},"text":"Pub. L. 99–640","children":[],"tail":" substituted “section” for “Section”."}],"tail":"\n"},