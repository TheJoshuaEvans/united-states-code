{"tag":"section","attrib":{"id":"id56cc628b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2734"},"text":null,"children":[{"tag":"num","attrib":{"value":"2734"},"text":"§ 2734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medal of honor: presentation of Medal of Honor Flag","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President shall provide for the presentation of the Medal of Honor Flag designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s903"},"text":"section 903 of title 36","children":[],"tail":" to each individual to whom a medal of honor is awarded under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2732"},"text":"section 2732 of this title","children":[],"tail":". Presentation of the flag shall be made at the same time as the presentation of the medal under section 2732 or 2743 of this title. In the case of a posthumous presentation of the medal, the flag shall be presented to the individual to whom the medal is presented."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56cc628c-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/248/tVIII/s8143/c/4/A"},"text":"Pub. L. 107–248, title VIII, § 8143(c)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-23"},"text":"Oct. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1571"},"text":"116 Stat. 1571","children":[],"tail":", § 505; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1062/b/1"},"text":"Pub. L. 107–314, div. A, title X, § 1062(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2650"},"text":"116 Stat. 2650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s555/a"},"text":"Pub. L. 109–364, div. A, title V, § 555(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2217"},"text":"120 Stat. 2217","children":[],"tail":"; renumbered § 2734 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 116(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":", 4240; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(27), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4749"},"text":"134 Stat. 4749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56cc628d-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56cc628e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56cc628f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “individual” for “person” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 2732” for “section 491” and “section 2732 or 2743” for “section 491 or 498”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s116/b"},"text":"Pub. L. 115–282, § 116(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s505"},"text":"section 505 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" struck out “after "},{"tag":"date","attrib":{"date":"2002-10-23"},"text":"October 23, 2002","children":[],"tail":"” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t14/s491"},"text":"section 491 of this title","children":[],"tail":"” and inserted at end “In the case of a posthumous presentation of the medal, the flag shall be presented to the person to whom the medal is presented.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2002-10-23"},"text":"October 23, 2002","children":[],"tail":"” for “the date of the enactment of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56cc6290-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56cc6291-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Presentation of Flag for Prior Recipients of Medal of Honor","children":[],"tail":null},{"tag":"p","attrib":{},"text":"President to provide for the presentation of the Medal of Honor Flag to living recipients of the Medal of Honor as expeditiously as possible after ","children":[{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", and for posthumous presentation to survivors of deceased recipients of the Medal of Honor upon written application therefor, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/s555/b"},"text":"section 555(b) of Pub. L. 109–364","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3755"},"text":"section 3755 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
