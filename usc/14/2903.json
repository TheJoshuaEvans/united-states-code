{"tag":"section","attrib":{"id":"id56d144c0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903"},"text":null,"children":[{"tag":"num","attrib":{"value":"2903"},"text":"§ 2903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for adoption expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d144c1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization To Reimburse","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall carry out a program under which a member of the Coast Guard may be reimbursed, as provided in this section, for qualifying adoption expenses incurred by the member in the adoption of a child under 18 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d144c2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adoptions Covered","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An adoption for which expenses may be reimbursed under this section includes an adoption by a single individual, an infant adoption, an intercountry adoption, and an adoption of a child with special needs (as defined in section 473(c) of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s673/c"},"text":"42 U.S.C. 673(c)","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d144c3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Benefits Paid After Adoption Is Final","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Benefits paid under this section in the case of an adoption may be paid only after the adoption is final.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d144c4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Other Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A benefit may not be paid under this section for any expense paid to or for a member of the Coast Guard under any other adoption benefits program administered by the Federal Government or under any such program administered by a State or local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d144c5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d144c6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than $2,000 may be paid under this section to a member of the Coast Guard, or to two such members who are spouses of each other, for expenses incurred in the adoption of a child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d144c7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than $5,000 may be paid under this section to a member of the Coast Guard, or to two such members who are spouses of each other, for adoptions by such member (or members) in any calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d144c8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d144c9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d144ca-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “qualifying adoption expenses” means reasonable and necessary expenses that are directly related to the legal adoption of a child under 18 years of age, but only if such adoption is arranged by a qualified adoption agency. Such term does not include any expense incurred—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56d144cb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an adopting parent for travel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d144cc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with an adoption arranged in violation of Federal, State, or local law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d144cd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “reasonable and necessary expenses” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56d144ce-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public and private agency fees, including adoption fees charged by an agency in a foreign country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d144cf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" placement fees, including fees charged adoptive parents for counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d144d0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legal fees (including court costs) in connection with services that are unavailable to a member of the Coast Guard under section 1044 or 1044a of title 10; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d144d1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical expenses, including hospital expenses of the biological mother of the child to be adopted and of a newborn infant to be adopted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d144d2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “qualified adoption agency” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56d144d3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State or local government agency which has responsibility under State or local law for child placement through adoption.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d144d4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nonprofit, voluntary adoption agency which is authorized by State or local law to place children for adoption.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d144d5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2903/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other source authorized by a State to provide adoption placement if the adoption is supervised by a court under State or local law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d144d6-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVI/s651/b/1"},"text":"Pub. L. 102–190, div. A, title VI, § 651(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1386"},"text":"105 Stat. 1386","children":[],"tail":", § 514; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1054/g"},"text":"Pub. L. 102–484, div. A, title X, § 1054(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2503"},"text":"106 Stat. 2503","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVI/s652/b"},"text":"Pub. L. 104–201, div. A, title VI, § 652(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2582"},"text":"110 Stat. 2582","children":[],"tail":"; renumbered § 541, "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s214/b/1/A"},"text":"Pub. L. 113–281, title II, § 214(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3033"},"text":"128 Stat. 3033","children":[],"tail":"; renumbered § 2903, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s117/b"},"text":"Pub. L. 115–282, title I, § 117(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4230"},"text":"132 Stat. 4230","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(48), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4750"},"text":"134 Stat. 4750","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d144d7-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d144d8-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56d144d9-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2903 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s5103"},"text":"section 5103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d144da-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “individual” for “person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s541"},"text":"section 541 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281"},"text":"Pub. L. 113–281","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s514"},"text":"section 514 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s652/b/1"},"text":"Pub. L. 104–201, § 652(b)(1)","children":[],"tail":", substituted “qualified adoption agency.” for “State or local government agency which has responsibility under State or local law for child placement through adoption or by a nonprofit, voluntary adoption agency which is authorized by State or local law to place children for adoption.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s652/b/2"},"text":"Pub. L. 104–201, § 652(b)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" inserted a close parenthesis before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56d144db-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id56d144dc-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", and applicable to adoptions completed on or after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/s651/c"},"text":"section 651(c) of Pub. L. 102–190","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1052"},"text":"section 1052 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56d144dd-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reimbursement for Adoptions Completed During Interim Between Test and Permanent Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to reimbursement for adoption expenses and time period for application, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s652"},"text":"section 652 of Pub. L. 102–484","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1052"},"text":"section 1052 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
