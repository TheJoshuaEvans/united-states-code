{"tag":"section","attrib":{"id":"id56ca18e4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537"},"text":null,"children":[{"tag":"num","attrib":{"value":"2537"},"text":"§ 2537.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability and transparency relating to allegations of misconduct against senior leaders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56ca18e5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of enactment of the Coast Guard Authorization Act of 2025, the Secretary shall establish a publicly available, written policy to improve oversight, investigations, accountability, and public transparency regarding alleged misconduct of senior leaders of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ca18e6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The policy required by subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ca18e7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall require that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ca18e8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any allegation of alleged misconduct made against a senior leader of the Coast Guard shall be reported to the Office of the Inspector General of the department in which the Coast Guard is operating not later than 72 hours after the allegation is reported to the Coast Guard or the department in which the Coast Guard is operating; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ca18e9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Inspector General of the department in which the Coast Guard is operating shall notify the head of the Coast Guard office in which the senior leader is serving with respect to the receipt of such allegation, or, in a case where the senior leader is the head of such Coast Guard office, the next in the chain of command, as appropriate, except in a case in which the Inspector General determines that such notification would risk impairing an ongoing investigation, would unnecessarily compromise the anonymity of the individual making the allegation, or would otherwise be inappropriate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ca18ea-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, shall be consistent with Department of Defense directives, including Department of Defense Directive 5505.06.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ca18eb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"First Right to Exclusive Investigation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Inspector General of the department in which the Coast Guard is operating—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ca18ec-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have the first right to investigate an allegation described in subsection (b)(1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ca18ed-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cases with concurrent jurisdiction involving an allegation described in subsection (b)(1)(A), may investigate such an allegation to the exclusion of any other Coast Guard criminal or administrative investigation if the Inspector General determines that an exclusive investigation is necessary to maintain the integrity of the investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ca18ee-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Availability and Broad Dissemination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The policy established under subsection (a) shall be made available to the public and incorporated into training and curricula across the Coast Guard at all levels to ensure broad understanding of the policy among members and personnel of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ca18ef-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ca18f0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alleged misconduct","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “alleged misconduct”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ca18f1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a credible allegation that, if proven, would constitute a violation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56ca18f2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provision of criminal law, including the Uniform Code of Military Justice (chapter 47 of title 10); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56ca18f3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recognized standard, such as the Department of Defense Joint Ethics Regulation or other Federal regulation, including any other Department of Defense regulation and any Department of Homeland Security regulation; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ca18f4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could reasonably be expected to be of significance to the Secretary or the Inspector General of the department in which the Coast Guard is operating, particularly in a case in which there is an element of misuse of position or of unauthorized personal benefit to the senior official, a family member, or an associate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ca18f5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Senior leader of the coast guard","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “senior leader of the Coast Guard” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ca18f6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an active duty, retired, or reserve officer of the Coast Guard in the grade of O–7 or higher;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ca18f7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer of the Coast Guard selected for promotion to the grade of O–7;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ca18f8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a current or former civilian member of the Senior Executive Service (career reserved) employed by the Coast Guard; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ca18f9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2537/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any civilian member of the Coast Guard whose position is deemed equivalent to that of a member of the Senior Executive Service (career reserved), as determined by the Office of the Inspector General of the department in which the Coast Guard is operating.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ca18fa-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXV/s7511/a"},"text":"Pub. L. 119–60, div. G, title LXXV, § 7511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1804"},"text":"139 Stat. 1804","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ca18fb-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ca18fc-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56ca18fd-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Coast Guard Authorization Act of 2025, referred to in subsec. (a), is the date of enactment of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
