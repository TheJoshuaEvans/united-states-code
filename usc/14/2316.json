{"tag":"section","attrib":{"id":"id56c07b6a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2316"},"text":null,"children":[{"tag":"num","attrib":{"value":"2316"},"text":"§ 2316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge within three months before expiration of enlistment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary, any enlisted member may be discharged at any time within three months before the expiration of his term of enlistment or extended enlistment without prejudice to any right, privilege, or benefit that he would have received, except pay and allowances for the unexpired period not served, or to which he would thereafter become entitled, had he served his full term of enlistment or extended enlistment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56c07b6b-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-06-08/ch136/s2"},"text":"June 8, 1955, ch. 136, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/88"},"text":"69 Stat. 88","children":[],"tail":", § 370; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/3/A"},"text":"Pub. L. 98–557, § 15(a)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":"; renumbered § 2316, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s113/b"},"text":"Pub. L. 115–282, title I, § 113(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4221"},"text":"132 Stat. 4221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c07b6c-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c07b6d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c07b6e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s370"},"text":"section 370 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted reference to enlisted member for reference to enlisted man."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
