{"tag":"section","attrib":{"id":"id56cc6238-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2706"},"text":null,"children":[{"tag":"num","attrib":{"value":"2706"},"text":"§ 2706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to wear uniform","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When authorized by and in accordance with applicable regulations:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56cc6239-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any member who has served honorably in the Coast Guard during war shall when not in active service, whether or not on the retired list, be entitled to bear the official title and upon occasions of ceremony to wear the uniform of the highest rank or rating held by him during his war service, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56cc623a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any member on the retired list shall be entitled to wear the uniform of his rank or rating.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56cc623b-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/533"},"text":"63 Stat. 533","children":[],"tail":", § 483; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/3/H"},"text":"Pub. L. 98–557, § 15(a)(3)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":"; renumbered § 2706, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56cc623c-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56cc623d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (a) is based on title 14, U.S.C., 1946 ed., § 167b–2 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-21/ch563/s2"},"text":"June 21, 1930, ch. 563, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/793"},"text":"46 Stat. 793","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Inasmuch as the act cited above applies equally to the Navy and Marine Corps as well as the Coast Guard, it is not scheduled for repeal but is being amended by section 12 of this act to eliminate reference to the Coast Guard.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is new to the Coast Guard, although it has been the practice for retired officers to wear the uniform when they so desire. Such authority is granted to retired officers of the Navy (see title 34, U.S.C., 1946 ed., § 389).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56cc623e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56cc623f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s483"},"text":"section 483 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted reference to member for reference to commissioned officer, warrant officer, and enlisted man."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
