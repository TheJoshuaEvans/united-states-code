{"tag":"section","attrib":{"id":"id569f105c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s708"},"text":null,"children":[{"tag":"num","attrib":{"value":"708"},"text":"§ 708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Health and Human Services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id569f105d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commandant may assist the Secretary of Health and Human Services in providing medical emergency helicopter transportation services to civilians. The Commandant may prescribe conditions, including reimbursement, under which resources may be provided under this section. The following specific limitations apply to assistance provided under this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id569f105e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s708/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance may be provided only in areas where Coast Guard units able to provide the assistance are regularly assigned. Coast Guard units may not be transferred from one area to another to provide the assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f105f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s708/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance may be provided only to the extent it does not interfere with the performance of the Coast Guard mission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f1060-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s708/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing assistance may not cause an increase in amounts required for the operation of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f1061-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual (or the estate of that individual) who is authorized by the Coast Guard to provide a service under a program established under subsection (a) and who is acting within the scope of that individual’s duties is not liable for injury to, or loss of, property or personal injury or death that may be caused incident to providing the service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id569f1062-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s2/6/A"},"text":"Pub. L. 97–295, § 2(6)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1301"},"text":"96 Stat. 1301","children":[],"tail":", § 147a; renumbered § 708, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s106/b"},"text":"Pub. L. 115–282, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4203"},"text":"132 Stat. 4203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569f1063-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id569f1064-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id569f1065-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"147a","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"14:141 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 1, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/61/s8"},"text":"Pub. L. 95–61, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/91/260"},"text":"91 Stat. 260","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Secretary of Health and Human Services” are substituted for “Department of Health, Education, and Welfare” because of 20:3508(b) and because the responsibility is in the head of the Department. The word “may” is substituted for “is authorized to” for clarity. The word “conditions” is substituted for “terms and conditions” because it is inclusive. The words “deems appropriate” are omitted as unnecessary. The words “The following . . . limitations apply” are substituted for “shall be subject to the following . . . limitations” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569f1066-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id569f1067-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 708 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s3708"},"text":"section 3708 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id569f1068-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s147a"},"text":"section 147a of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id569f1069-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"similarProvisions","id":"id569f106a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Similar Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Similar provisions were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/61/s8"},"text":"section 8 of Pub. L. 95–61","children":[],"tail":" which was formerly set out as a note under section 141 (now 701) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
