{"tag":"section","attrib":{"id":"id56a63c88-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946"},"text":null,"children":[{"tag":"num","attrib":{"value":"946"},"text":"§ 946.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" User fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a63c89-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A fee or charge for a service or thing of value provided by the Coast Guard shall be prescribed as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9701"},"text":"section 9701 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63c8a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts collected by the Secretary for a service or thing of value provided by the Coast Guard shall be deposited in the general fund of the Treasury as proprietary receipts of the department in which the Coast Guard is operating and ascribed to Coast Guard activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63c8b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the collection of fees and charges established under this section, the Secretary may recover from the person liable for the fee or charge the costs of collecting delinquent payments of the fee or charge, and enforcement costs associated with delinquent payments of the fees and charges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63c8c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63c8d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may employ any Federal, State, or local agency or instrumentality, or any private enterprise or business, to collect a fee or charge established under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63c8e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A private enterprise or business employed by the Secretary to collect fees or charges—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a63c8f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be subject to reasonable terms and conditions agreed to by the Secretary and the enterprise or business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a63c90-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide appropriate accounting to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a63c91-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not institute litigation as part of that collection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63c92-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63c93-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the collection of fees and charges established under this section, in the provision of a service or thing of value by the Coast Guard the Secretary may accept in-kind transportation, travel, and subsistence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63c94-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The value of in-kind transportation, travel, and subsistence accepted under this paragraph may not exceed applicable per diem rates set forth in regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s464"},"text":"section 464 of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63c95-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall account for the agency’s costs of collecting a fee or charge as a reimbursable expense, subject to the availability of appropriations, and the costs shall be credited to the account from which expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63c96-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before January 1 of each year, the Secretary shall submit a report to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63c97-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a verification of each activity for which a fee or charge is collected under any law stating—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a63c98-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount collected in the prior fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a63c99-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the amount spent on that activity in that fiscal year is not less than the amount collected; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63c9a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount expected to be collected under any law in the current fiscal year for each activity for which a fee or charge is expected to be collected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63c9b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s946/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section the term “costs of collecting a fee or charge” includes the reasonable administrative, accounting, personnel, contract, equipment, supply, training, and travel expenses of calculating, assessing, collecting, enforcing, reviewing, adjusting, and reporting on a fee or charge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a63c9c-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tV/s5102/a/3"},"text":"Pub. L. 99–509, title V, § 5102(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1926"},"text":"100 Stat. 1926","children":[],"tail":", § 664; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/225/tII/s211"},"text":"Pub. L. 101–225, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1914"},"text":"103 Stat. 1914","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIV/s408/a/3"},"text":"Pub. L. 107–295, title IV, § 408(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2117"},"text":"116 Stat. 2117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tII/s206"},"text":"Pub. L. 108–293, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1033"},"text":"118 Stat. 1033","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tIII/s311/b"},"text":"Pub. L. 113–281, title III, § 311(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3048"},"text":"128 Stat. 3048","children":[],"tail":"; renumbered § 946, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s107/b"},"text":"Pub. L. 115–282, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4205"},"text":"132 Stat. 4205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a63c9d-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a63c9e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a63c9f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s664"},"text":"section 664 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsecs. (e) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281"},"text":"Pub. L. 113–281","children":[],"tail":" added subsec. (e) and redesignated former subsecs. (e) to (g) as (f) to (h), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsecs. (c) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" added subsecs. (c) to (e) and (g) and redesignated former subsec. (c) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295"},"text":"Pub. L. 107–295","children":[],"tail":" substituted “Transportation and Infrastructure” for “Merchant Marine and Fisheries” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/225"},"text":"Pub. L. 101–225","children":[],"tail":" inserted “under any law” after first reference to “collected” in pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56a63ca0-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56a63ca1-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Towing Safety Management System Fees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVIII/s815"},"text":"Pub. L. 115–282, title VIII, § 815","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4305"},"text":"132 Stat. 4305","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/282/tVIII/s815"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant of the Coast Guard shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" review and compare the costs to the Government of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" towing vessel inspections performed by the Coast Guard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such inspections performed by a third party; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on such review and comparison, determine whether the costs to the Government of such inspections performed by a third party are different than the costs to the Government of such inspections performed by the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revision of Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Commandant determines under subsection (a) that the costs to the Government of such inspections performed by a third party are different than the costs to the Government of such inspections performed by the Coast Guard, then the Commandant shall revise the fee assessed by the Coast Guard for such inspections as necessary to conform to the requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9701"},"text":"section 9701 of title 31","children":[],"tail":", United States Code, that such fee be based on the cost to the Government of such inspections and accurately reflect such costs.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56a63ca2-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/tIII/s311/c"},"text":"Pub. L. 113–281, title III, § 311(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3048"},"text":"128 Stat. 3048","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/281/tIII/s311/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of the Department in which the Coast Guard is operating may not accept in-kind transportation, travel, or subsistence under section 664(e) [now 946(e)] of title 14, United States Code, or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2110/d/4"},"text":"section 2110(d)(4) of title 46","children":[],"tail":", United States Code, as amended by this section, until the Commandant of the Coast Guard—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amends the Standards of Ethical Conduct for members and employees of the Coast Guard to include regulations governing the acceptance of in-kind reimbursements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifies the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives of the amendments made under paragraph (1).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
