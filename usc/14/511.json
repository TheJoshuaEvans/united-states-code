{"tag":"section","attrib":{"id":"id56980bc6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s511"},"text":null,"children":[{"tag":"num","attrib":{"value":"511"},"text":"§ 511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of certain records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56980bc7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coast Guard Message Board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall designate as a record of the Coast Guard, and ensure the longest possible retention approved by the National Archives and Records Administration of, each message placed on Coast Guard message board on or after the date that is 1 year after the date of the enactment of this Act on a publicly available website to the maximum extent possible, in accordance with the Privacy Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"5 U.S.C. 552a","children":[],"tail":") and other applicable laws."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56980bc8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commandant Instruction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall designate as a temporary record of the Coast Guard, and ensure the retention for a period not less than 15 years of or the retention approved by the National Archives & Records Administration, each Commandant Instruction Manual and Coast Guard Academy Superintendent Instruction Manual, including all versions thereof, in effect on or after the date that is 30 days after the date of the enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56980bc9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost-Benefit Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of the enactment of this Act, and annually thereafter, the Commandant shall submit to the appropriate congressional committees a report that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56980bca-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s511/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies all current recurrent requirements for reports to Congress applicable to the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56980bcb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s511/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimates the total annual cost and staff hours required for compliance with such requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56980bcc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s511/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides recommendations to Congress for sunset, consolidation, or automation of such requirements to improve efficiency, consistent applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56980bcd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s511/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56980bce-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s511/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate congressional committees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"CST and T&I ","children":[{"tag":"ref","attrib":{"idref":"fn002010"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002010"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56980bcf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s511/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coast guard message board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Coast Guard message board” means the Coast Guard official platform for disseminating time-sensitive or service-wide administrative information to Coast Guard personnel, including the publishing of official general messages including ALCOAST, ALCGPSC, ALCGENL, and similar formats that provide timely policy updates, operational guidance, or announcements to the field.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56980bd0-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7277/a"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7277(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1750"},"text":"139 Stat. 1750","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56980bd1-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56980bd2-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56980bd3-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this Act, referred to in subsecs. (a) to (c), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56980bd4-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 511 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2763"},"text":"section 2763 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For redesignation of prior sections 512 to 520, see Table Showing Redesignations Made by Title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
