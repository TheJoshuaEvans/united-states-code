{"tag":"section","attrib":{"id":"id56cc62aa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2738"},"text":null,"children":[{"tag":"num","attrib":{"value":"2738"},"text":"§ 2738.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distinguished flying cross","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may present, but not in the name of Congress, a distinguished flying cross of appropriate design, with accompanying ribbon, to any individual who, while serving in any capacity with the Coast Guard, displays heroism or extraordinary achievement while participating in an aerial flight.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56cc62ab-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041/s12/a"},"text":"Aug. 10, 1956, ch. 1041, § 12(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/624"},"text":"70A Stat. 624","children":[],"tail":", § 492a; renumbered § 492b, "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tII/s224/b/1"},"text":"Pub. L. 111–281, title II, § 224(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2922"},"text":"124 Stat. 2922","children":[],"tail":"; renumbered § 2738, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], §§ 8505(a)(31), 8506(e), "},{"tag":"date","attrib":{"date":"2021-01-01"},"t