{"tag":"section","attrib":{"id":"id56d8496a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3752"},"text":null,"children":[{"tag":"num","attrib":{"value":"3752"},"text":"§ 3752.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention boards; removal from an active status to provide a flow of promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d8496b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3752/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of this title, whenever the Secretary determines that it is necessary to reduce the number of Reserve officers in an active status in any grade to provide a steady flow of promotion, or that there is an excessive number of Reserve officers in an active status in any grade, the Secretary may appoint and convene a retention board to consider all of the Reserve officers in that grade in an active status who have 18 years or more of service for retirement, except those officers who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d8496c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3752/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are on extended active duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d8496d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3752/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are on a list of selectees for promotion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d8496e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3752/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will complete 30 years total commissioned service by June 30th following the date that the retention board is convened; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d8496f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3752/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have reached age 59 by the date on which the retention board is convened.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The retention board shall select and recommend a specified number of the officers under consideration for retention in an active status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d84970-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3752/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d84971-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3752/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, consist of at least 50 per centum Reserve officers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d84972-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3752/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consist only of officers who are senior in rank to any officers being considered by that board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d84973-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3752/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, consist of officers who have not served on the last previous retention board which considered officers of the same grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d84974-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3752/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12646"},"text":"section 12646 of title 10","children":[],"tail":", a Reserve officer who is not recommended for retention in an active status under this section shall be given an opportunity to transfer to the Retired Reserve, if qualified, but unless so transferred shall, in the discretion of the Secretary, be transferred to the inactive status list or discharged on June 30 next following the date on which the report of the retention board is approved."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d84975-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3752/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2117"},"text":"section 2117 of this title","children":[],"tail":" shall, to the extent that they are not inconsistent with this subchapter, apply to boards convened under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d84976-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":