{"tag":"section","attrib":{"id":"id56d144f0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2905"},"text":null,"children":[{"tag":"num","attrib":{"value":"2905"},"text":"§ 2905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Youth sponsorship initiatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d144f1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant is authorized to establish, within any Coast Guard unit, an initiative to help integrate into new surroundings the dependent children of members of the Coast Guard who received permanent change of station orders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d144f2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description of Initiative","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An initiative established under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d144f3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2905/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the involvement of a dependent child of a member of the Coast Guard in the dependent child’s new Coast Guard community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d144f4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2905/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primarily focus on preteen and teenaged children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d144f5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out an initiative under subsection (a), the Commandant may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d144f6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2905/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to a dependent child of a member of the Coast Guard information on youth programs and activities available in the dependent child’s new Coast Guard community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d144f7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2905/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into agreements with nonprofit entities to provide youth programs and activities to such child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d144f8-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s214/a"},"text":"Pub. L. 113–281, title II, § 214(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3030"},"text":"128 Stat. 3030","children":[],"tail":", § 543; renumbered § 2905, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s117/b"},"text":"Pub. L. 115–282, title I, § 117(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4230"},"text":"132 Stat. 4230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d144f9-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d144fa-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56d144fb-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2905 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s5106"},"text":"section 5106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d144fc-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s543"},"text":"section 543 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
