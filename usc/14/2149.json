2/s309"},"text":"Pub. L. 115–282, § 309","children":[],"tail":", substituted “zone, or from being placed at the top of the list of selectees promulgated by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2121/a"},"text":"section 2121(a) of this title","children":[],"tail":", is” for “zone is” and inserted “or placed at the top of the list of selectees, as applicable” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 2504(a)” for “section 423(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" substituted “rear admiral (lower half)” for “commodore”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348"},"text":"Pub. L. 99–348","children":[],"tail":" substituted “Retired pay computed under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s423/a"},"text":"section 423(a) of this title","children":[],"tail":"” for “Except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s423/b"},"text":"section 423(b) of this title","children":[],"tail":", the retired pay”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/417"},"text":"Pub. L. 97–417","children":[],"tail":" substituted “commodore” for “rear admiral”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/342"},"text":"Pub. L. 96–342","children":[],"tail":" substituted “Except as provided in section 423(b)” for “Notwithstanding section 423”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/546"},"text":"Pub. L. 94–546","