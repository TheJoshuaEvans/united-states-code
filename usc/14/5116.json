{"tag":"section","attrib":{"id":"id56df759a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5116"},"text":null,"children":[{"tag":"num","attrib":{"value":"5116"},"text":"§ 5116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of overdue reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56df759b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date of enactment of this section, and not later than March 1 of each year thereafter, the Commandant shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a report on the status of reports or briefings required under this chapter that have not been delivered to Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56df759c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under section (a) shall contain the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56df759d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5116/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The status of each required report or briefing that has not been delivered to Congress, including the date the report or briefing is due, and if applicable, the number of days the Coast Guard has exceeded the required completion date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df759e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5116/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed written plan and timeline for the next steps to be taken to complete such outstanding reports or briefings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df759f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5116/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name, position, and agency of each Federal official responsible for writing, reviewing, editing, and approving the report, as well as the responsibility of such official in regard to the report, and how long that report has been under the responsibility with such Federal official after being received from the previous Federal official responsible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df75a0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5116/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the flag officer responsible for the completion of each report or briefing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56df75a1-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXI/s7114/a"},"text":"Pub. L. 119–60, div. G, title LXXI, § 7114(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1668"},"text":"139 Stat. 1668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56df75a2-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56df75a3-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56df75a4-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
