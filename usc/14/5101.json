{"tag":"section","attrib":{"id":"id56dd2b98-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5101"},"text":null,"children":[{"tag":"num","attrib":{"value":"5101"},"text":"§ 5101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission of annual Coast Guard authorization request","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56dd2b99-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the date on which the President submits to Congress a budget for a fiscal year pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the Secretary shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a Coast Guard authorization request with respect to such fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56dd2b9a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coast Guard Authorization Request Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “Coast Guard authorization request” means a proposal for legislation that, with respect to the Coast Guard for the relevant fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56dd2b9b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommends end strengths for personnel for that fiscal year, as described in section 4903;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2b9c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommends authorizations of appropriations for that fiscal year, including with respect to matters described in section 4901; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2b9d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5101/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addresses any other matter that the Secretary determines is appropriate for inclusion in a Coast Guard authorization bill.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56dd2b9e-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s216/a"},"text":"Pub. L. 113–281, title II, § 216(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3035"},"text":"128 Stat. 3035","children":[],"tail":", § 662a; renumbered § 2901 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tI/s101/d/1"},"text":"Pub. L. 114–120, title I, § 101(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/31"},"text":"130 Stat. 31","children":[],"tail":"; renumbered § 5101 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. 