s this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s101/d/1/C/i"},"text":"Pub. L. 114–120, § 101(d)(1)(C)(i)","children":[],"tail":", substituted “described in section 2703” for “described in section 661”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s101/d/1/C/ii"},"text":"Pub. L. 114–120, § 101(d)(1)(C)(ii)","children":[],"tail":", substituted “described in section 2701” for “described in section 662”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56dd2ba2-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56dd2ba3-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Oversight of Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXI/s7116"},"text":"Pub. L. 119–60, div. G, title LXXI, § 7116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1669"},"text":"139 Stat. 1669","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dG/tLXXI/s7116"},"text":"“Not later than 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"], and annually thereafter, the Commandant [of the Coast Guard] shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a detailed expenditure plan, including projected project timelines for each acquisition and procurement appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s1181"},"text":"section 1181 of title 14","children":[],"tail":", United States Code, and a list of project locations to be funded under such section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
