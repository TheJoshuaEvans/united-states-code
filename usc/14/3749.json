{"tag":"section","attrib":{"id":"id56d84947-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3749"},"text":null,"children":[{"tag":"num","attrib":{"value":"3749"},"text":"§ 3749.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of removal by the President or failure of consent of the Senate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d84948-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3749/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may, for cause, remove the name of any officer from a list of selectees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s3740"},"text":"section 3740 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d84949-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3749/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Senate, where required, does not consent to the appointment of an officer whose name is on a list of selectees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s3740"},"text":"section 3740 of this title","children":[],"tail":", that officer’s name shall be removed from the list."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d8494a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3749/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer whose name is removed from a list of selectees under subsection (a) or (b) continues to be eligible for consideration for promotion. If selected for promotion by the next selection board and promoted, that officer shall be assigned the date of rank and precedence that would have been assigned if the officer’s name had not been previously removed. However, if the officer is not selected by the next selection board, or if the officer’s name is again removed from the list of selectees, the officer shall be considered for all purposes as having twice failed of selection for promotion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d8494b-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1013"},"text":"94 Stat. 1013","children":[],"tail":", § 738; renumbered § 3749 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 118(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d8494c-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d8494d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56d8494e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s788"},"text":"section 788 of this title","children":[],"tail":" prior to the complete revision of former chapter 21 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/96/322"},"text":"Pub. L. 96–322","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d8494f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s118/b"},"text":"Pub. L. 115–282, § 118(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s738"},"text":"section 738 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 3740” for “section 729”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id56d84950-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id56d84951-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For assignment of functions of President under subsec. (a) of this section, see section 2(d) of Ex. Ord. No. 13358, ","children":[{"tag":"date","attrib":{"date":"2004-09-28"},"text":"Sept. 28, 2004","children":[],"tail":", 69 F.R. 58797, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
