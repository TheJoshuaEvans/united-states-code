{"tag":"section","attrib":{"id":"id56bbc0fb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2144"},"text":null,"children":[{"tag":"num","attrib":{"value":"2144"},"text":"§ 2144.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular Coast Guard; officers serving under temporary appointments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56bbc0fc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2144/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each officer of the Regular Coast Guard appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2104"},"text":"section 2104 of this title","children":[],"tail":" who is serving in the grade of lieutenant (junior grade) or lieutenant and who has failed of selection for promotion to the grade of lieutenant or lieutenant commander, respectively, for the second time shall:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56bbc0fd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2144/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be honorably discharged on June 30 of the promotion year in which his second failure of selection occurs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56bbc0fe-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2144/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if he so requests, be honorably discharged at an earlier date without loss of benefits that would accrue if he were discharged on that date under clause (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56bbc0ff-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2144/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if on the date specified for his discharge in this section he is eligible for retirement under any law, be retired under that law on that date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56bbc100-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2144/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each officer subject to discharge or retirement under subsection (a) may elect to revert to his permanent grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56bbc101-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/184"},"text":"77 Stat. 184","children":[],"tail":", § 284; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/546/s1/23"},"text":"Pub. L. 94–546, § 1(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2520"},"text":"90 Stat. 2520","children":[],"tail":"; renumbered § 2144 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 112(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56bbc102-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56bbc103-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56bbc104-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s112/b"},"text":"Pub. L. 115–282, § 112(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s284"},"text":"section 284 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 2104” for “section 214” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/546"},"text":"Pub. L. 94–546","children":[],"tail":" substituted “promotion year” for “fiscal year”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56bbc105-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56bbc106-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Retired Pay on or Prior to ","children":[{"tag":"date","attrib":{"date":"1963-09-24"},"text":"September 24, 1963","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Savings provisions in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s5/g"},"text":"section 5(g) of Pub. L. 88–130","children":[],"tail":" providing that "},{"tag":"ref","attrib":{"href":"/us/pl/88/130"},"text":"Pub. L. 88–130","children":[],"tail":" does not affect the retired pay of anyone retired on or prior to "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", are set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2101"},"text":"section 2101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56bbc107-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effectiveness of Election, Change, or Revocation of Election of Annuity","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Savings provisions in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s5/h"},"text":"section 5(h) of Pub. L. 88–130","children":[],"tail":" providing that notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1431"},"text":"section 1431 of Title 10","children":[],"tail":", Armed Forces, an election, change or revocation thereof affecting an annuity, by an officer retired under this section, is effective if made prior to the first day of the third month following September 1963, are set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2101"},"text":"section 2101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
