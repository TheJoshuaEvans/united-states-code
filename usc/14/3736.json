{"tag":"section","attrib":{"id":"id56d5ffbb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3736"},"text":null,"children":[{"tag":"num","attrib":{"value":"3736"},"text":"§ 3736.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Precedence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d5ffbc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3736/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reserve officers rank and take precedence in their respective grades among themselves and with officers of the same grade on the active duty promotion list, officers designated by the Secretary pursuant to this section, and the officers on the permanent commissioned teaching staff in accordance with their dates of rank. When Reserve officers and officers on the active duty promotion list, officers designated by the Secretary pursuant to this section, or the officers on the permanent commissioned teaching staff have the same date of rank in a grade, they take prec­edence as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ffbd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3736/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other law, a Reserve officer shall not lose precedence when transferred to or from the active duty promotion list, nor shall that officer’s date of rank be changed due to the transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ffbe-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3736/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Reserve officer shall, when on the active duty promotion list, be promoted in the same manner as any other officer on the active duty promotion list regardless of the length of active duty service of the Reserve officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ffbf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3736/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other law, a Reserve officer shall not lose precedence by reason of promotion to the grade of rear admiral or rear admiral (lower half), if the promotion is determined in accordance with a running mate system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ffc0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3736/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall adjust the date of rank of a Reserve officer so that no changes of precedence occur.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d5ffc1-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1008"},"text":"94 Stat. 1008","children":[],"tail":", § 725; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tII/s220/a"},"text":"Pub. L. 108–293, title II, § 220(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1039"},"text":"118 Stat. 1039","children":[],"tail":"; renumbered § 3736, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s118/b"},"text":"Pub. L. 115–282, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7221/c/4"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7221(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1700"},"text":"139 Stat. 1700","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d5ffc2-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d5ffc3-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56d5ffc4-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s781"},"text":"section 781 of this title","children":[],"tail":" prior to the complete revision of former chapter 21 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/96/322"},"text":"Pub. L. 96–322","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d5ffc5-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted, in first sentence, “promotion list, officers designated by the Secretary pursuant to this section, and the officers on the” for “promotion list and the” and, in second sentence, “promotion list, officers designated by the Secretary pursuant to this section, or the officers on the” for “promotion list or the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s725"},"text":"section 725 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" added subsecs. (d) and (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
