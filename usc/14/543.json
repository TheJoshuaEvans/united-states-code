{"tag":"section","attrib":{"id":"id569a5676-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s543"},"text":null,"children":[{"tag":"num","attrib":{"value":"543"},"text":"§ 543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interference with aids to navigation; penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person, or public body, or instrumentality, excluding the armed forces, to remove, change the location of, obstruct, wilfully damage, make fast to, or interfere with any aid to navigation established, installed, operated, or maintained by the Coast Guard pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s541"},"text":"section 541 of this title","children":[],"tail":", or with any aid to navigation lawfully maintained under authority granted by the Coast Guard pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s542"},"text":"section 542 of this title","children":[],"tail":", or to anchor any vessel in any of the navigable waters of the United States so as to obstruct or interfere with range lights maintained therein. Whoever violates the provisions of this section shall be guilty of a misdemeanor and shall be fined not more than $1,500 for each offense. Each day during which such violation shall continue shall be considered as a new offense."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id569a5677-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/500"},"text":"63 Stat. 500","children":[],"tail":", § 84; "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s205/a/2"},"text":"Pub. L. 113–281, title II, § 205(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3025"},"text":"128 Stat. 3025","children":[],"tail":"; renumbered § 543 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 105(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4200"},"text":"132 Stat. 4200","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569a5678-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id569a5679-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 33, U.S.C., 1946, ed., §§ 761, 762 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1908-05-14/ch168/s6"},"text":"May 14, 1908, ch. 168, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/162"},"text":"35 Stat. 162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1910-06-17/ch301/s6"},"text":"June 17, 1910, ch. 301, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/538"},"text":"36 Stat. 538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1915-03-03/ch81/s8"},"text":"Mar. 3, 1915, ch. 81, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/928"},"text":"38 Stat. 928","children":[],"tail":"; 1939 Reorg. Plan No. II, § 2(a), eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2731, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1432"},"text":"53 Stat. 1432","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569a567a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id569a567b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 543 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2905"},"text":"section 2905 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id569a567c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 541” for “section 81” and “section 542” for “section 83”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s105/b"},"text":"Pub. L. 115–282, § 105(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s84"},"text":"section 84 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281"},"text":"Pub. L. 113–281","children":[],"tail":" substituted “$1,500” for “$500”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
