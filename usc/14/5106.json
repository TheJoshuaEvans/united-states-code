{"tag":"section","attrib":{"id":"id56dd2c1c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5106"},"text":null,"children":[{"tag":"num","attrib":{"value":"5106"},"text":"§ 5106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual performance report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than the date on which the President submits to Congress a budget pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the Commandant of the Coast Guard shall make available on a public website and submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate an update on Coast Guard mission performance during the previous fiscal year."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56dd2c1d-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3521/b/1"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3521(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2314"},"text":"132 Stat. 2314","children":[],"tail":", § 2905; renumbered § 5106, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s122/b"},"text":"Pub. L. 115–282, title I, § 122(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4239"},"text":"132 Stat. 4239","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56dd2c1e-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56dd2c1f-2930-11f1-a4c1-c531e6