{"tag":"section","attrib":{"id":"id56d38eb4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2945"},"text":null,"children":[{"tag":"num","attrib":{"value":"2945"},"text":"§ 2945.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyance of real property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d38eb5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2945/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conveyance Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary may convey, at fair market value, real property, owned or under the administrative control of the Coast Guard, for the purpose of expending the proceeds from such conveyance to acquire and construct military family housing and military unaccompanied housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d38eb6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2945/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and Conditions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d38eb7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2945/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The conveyance of real property under this section shall be by sale, for cash. The Secretary shall deposit the proceeds from the sale in the Coast Guard Housing Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2946"},"text":"section 2946 of this title","children":[],"tail":", for the purpose of expending such proceeds to acquire and construct military family housing and military unaccompanied housing."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d38eb8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2945/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The conveyance of real property under this section shall not diminish the mission capacity of the Coast Guard, but further the mission support capability of the Coast Guard with regard to military family housing or military unaccompanied housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d38eb9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2945/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Environmental Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not affect or limit the application of or obligation to comply with any environmental law, including section 120(h) of the Comprehensive Environmental Response, Compensation, and Liability Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9620/h"},"text":"42 U.S.C. 9620(h)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d38eba-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tII/s208/a"},"text":"Pub. L. 104–324, title II, § 208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3911"},"text":"110 Stat. 3911","children":[],"tail":", § 685; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/400/s2"},"text":"Pub. L. 106–400, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1675"},"text":"114 Stat. 1675","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/c/4"},"text":"Pub. L. 107–217, § 3(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1299"},"text":"116 Stat. 1299","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tII/s221/a/4"},"text":"Pub. L. 111–281, title II, § 221(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2919"},"text":"124 Stat. 2919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/c/4"},"text":"Pub. L. 111–350, § 5(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3847"},"text":"124 Stat. 3847","children":[],"tail":"; renumbered § 2945 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 117(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4230"},"text":"132 Stat. 4230","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d38ebb-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d38ebc-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d38ebd-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s117/b"},"text":"Pub. L. 115–282, § 117(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s685"},"text":"section 685 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 2946” for “section 687”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":", which directed substitution of “division C (except sections 3302, 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41” for “title III of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s251"},"text":"41 U.S.C. 251","children":[],"tail":" et seq.)” in subsec. (c)(1), could not be executed because of the prior general amendment of this section by "},{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":". See 2010 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" amended section generally. Prior to amendment, section authorized Secretary to convey or lease existing property and facilities under certain conditions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/c/4/A"},"text":"Pub. L. 107–217, § 3(c)(4)(A)","children":[],"tail":", substituted “Subtitle I of title 40 and title III of the” for “The” and “("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s251"},"text":"41 U.S.C. 251","children":[],"tail":" et seq.)” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s471"},"text":"40 U.S.C. 471","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/c/4/B"},"text":"Pub. L. 107–217, § 3(c)(4)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s1302"},"text":"Section 1302 of title 40","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/act/1932-06-30/s321"},"text":"Section 321 of the Act of June 30, 1932","children":[],"tail":" (commonly known as the Economy Act) ("},{"tag":"ref","attrib":{"href":"/us/stat/47/412"},"text":"47 Stat. 412","children":[],"tail":", chapter 314; "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s303b"},"text":"40 U.S.C. 303b","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/400"},"text":"Pub. L. 106–400","children":[],"tail":" substituted “McKinney-Vento Homeless Assistance Act” for “Stewart B. McKinney Homeless Assistance Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
