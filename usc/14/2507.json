{"tag":"section","attrib":{"id":"id56c2ecf3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2507"},"text":null,"children":[{"tag":"num","attrib":{"value":"2507"},"text":"§ 2507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board for Correction of Military Records deadline","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56c2ecf4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for Completion of Action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall complete processing of an application for correction of military records under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1552"},"text":"section 1552 of title 10","children":[],"tail":" by not later than 10 months after the date the Secretary receives the completed application."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c2ecf5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedies Deemed Exhausted","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Ten months after a complete application for correction of military records is received by the Board for Correction of Military Records of the Coast Guard, administrative remedies are deemed to have been exhausted, and—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c2ecf6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2507/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Board has rendered a recommended decision, its recommendation shall be final agency action and not subject to further review or approval within the department in which the Coast Guard is operating; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c2ecf7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2507/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the Board has not rendered a recommended decision, agency action is deemed to have been unreasonably delayed or withheld and the applicant is entitled to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c2ecf8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2507/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s706/1"},"text":"section 706(1) of title 5","children":[],"tail":", directing final action be taken within 30 days from the date the order is entered; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c2ecf9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2507/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from amounts appropriated to the department in which the Coast Guard is operating, the costs of obtaining the order, including a reasonable attorney’s fee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56c2ecfa-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tII/s209/a"},"text":"Pub. L. 104–324, title II, § 209(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3914"},"text":"110 Stat. 3914","children":[],"tail":", § 425; renumbered § 2507, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s114/b"},"text":"Pub. L. 115–282, title I, § 114(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4223"},"text":"132 Stat. 4223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c2ecfb-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c2ecfc-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c2ecfd-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s425"},"text":"section 425 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56c2ecfe-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id56c2ecff-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s209/d"},"text":"Pub. L. 104–324, § 209(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3914"},"text":"110 Stat. 3914","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/324/s209/d"},"text":"“This section [enacting this section and provisions set out as a note below] shall be effective on and after ","children":[{"tag":"date","attrib":{"date":"1990-06-12"},"text":"June 12, 1990","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56c2ed00-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Special Right of Applications After Deadline for Completion of Board Action","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s209/c"},"text":"Pub. L. 104–324, § 209(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3914"},"text":"110 Stat. 3914","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/324/s209/c"},"text":"“This section [enacting this section and provisions set out as a note above] applies to any applicant who had an application filed with or pending before the Board or the Secretary of the department in which the Coast Guard is operating on or after ","children":[{"tag":"date","attrib":{"date":"1990-06-12"},"text":"June 12, 1990","children":[],"tail":", who files with the Board for Correction of Military Records of the Coast Guard an application for relief under the amendment made by subsection (a) [enacting this section]. If a recommended decision was modified or reversed on review with final agency action occurring after expiration of the 10-month deadline under that amendment, an applicant who so requests shall have the order in the final decision vacated and receive the relief granted in the recommended decision if the Coast Guard has the legal authority to grant such relief. The recommended decision shall otherwise have no effect as precedent.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
