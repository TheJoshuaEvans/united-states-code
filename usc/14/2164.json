{"tag":"section","attrib":{"id":"id56be31ca-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2164"},"text":null,"children":[{"tag":"num","attrib":{"value":"2164"},"text":"§ 2164.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers considered for removal; retirement or discharge; separation benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56be31cb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2164/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At any time during proceedings under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2159"},"text":"section 2159 of this title","children":[],"tail":", and before the removal of an officer, the Secretary may grant a request—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56be31cc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2164/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for voluntary retirement, if the officer is otherwise qualified therefor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56be31cd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2164/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for discharge with separation benefits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2146/c"},"text":"section 2146(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56be31ce-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2164/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each officer removed from active duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2163"},"text":"section 2163 of this title","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56be31cf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2164/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if on the date of removal the officer is eligible for voluntary retirement under any law, be retired in the grade for which he would be eligible if retired at his request; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56be31d0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2164/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if on that date the officer is ineligible for voluntary retirement under any law, be honorably discharged with separation benefits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2146/c"},"text":"section 2146(c) of this title","children":[],"tail":", unless under regulations promulgated by the Secretary the condition under which the officer is discharged does not warrant an honorable discharge."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56be31d1-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/189"},"text":"77 Stat. 189","children":[],"tail":", § 327; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s2/10"},"text":"Pub. L. 97–295, § 2(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1302"},"text":"96 Stat. 1302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/348/tII/s205/b/6"},"text":"Pub. L. 99–348, title II, § 205(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-07-01"},"text":"July 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/700"},"text":"100 Stat. 700","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/383/tII/s201/c"},"text":"Pub. L. 105–383, title II, § 201(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3414"},"text":"112 Stat. 3414","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIV/s416/a/5"},"text":"Pub. L. 107–295, title IV, § 416(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2122"},"text":"116 Stat. 2122","children":[],"tail":"; renumbered § 2164 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 112(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":", 4240; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7223/d/1/C"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7223(d)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1702"},"text":"139 Stat. 1702","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56be31d2-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56be31d3-2930-11f1-a4c1-