p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/s416/a/5/A"},"text":"Pub. L. 107–295, § 416(a)(5)(A)","children":[],"tail":", substituted “separation” for “severance” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/s416/a/5/B"},"text":"Pub. L. 107–295, § 416(a)(5)(B)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “for honorable discharge with severance benefits under subsection (b) in those cases arising under clause (1) of "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s321"},"text":"section 321 of this title","children":[],"tail":"; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/s416/a/5/C"},"text":"Pub. L. 107–295, § 416(a)(5)(C)","children":[],"tail":", struck out par. (3) which read as follows: “for discharge with severance benefits under subsection (b) in those cases arising under clause (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s321"},"text":"section 321 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/s416/a/5/D"},"text":"Pub. L. 107–295, § 416(a)(5)(D)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “if on that date the officer is ineligible for voluntary retirement under any law, be honorably discharged in the grade then held with severance pay computed by multiplying his years of active commissioned service, but not more than twelve, by one month’s basic pay of that grade, in those cases arising under clause (1) of "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s321"},"text":"section 321 of this title","children":[],"tail":"; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/s416/a/5/E"},"text":"Pub. L. 107–295, § 416(a)(5)(E)","children":[],"tail":", struck out par. (3) which read as follows: “if on that date the officer is ineligible for voluntary retirement under any law, be discharged in the grade then held with severance pay computed by multiplying his years of active commissioned service, but not more than twelve, by one month’s basic pay of that grade, in those cases arising under clause (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s321"},"text":"section 321 of this title","children":[],"tail":", unless the Secretary determines that the conditions under which the officer is discharged or separated do not warrant payment of that amount of severance pay.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383"},"text":"Pub. L. 105–383","children":[],"tail":" inserted before period at end “, unless the Secretary determines that the conditions under which the officer is discharged or separated do not warrant payment of that amount of severance pay”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348"},"text":"Pub. L. 99–348","children":[],"tail":" struck out “, and with the pay” after “in the grade”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" inserted “of this title” after “section 322 or 323” and “section 321” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56be31d5-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"i