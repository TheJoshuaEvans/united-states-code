{"tag":"section","attrib":{"id":"id56dab9dc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3904"},"text":null,"children":[{"tag":"num","attrib":{"value":"3904"},"text":"§ 3904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of the Auxiliary; status","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56dab9dd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this chapter, a member of the Coast Guard Auxiliary shall not be considered to be a Federal employee and shall not be subject to the provisions of law relating to Federal employment, including those relating to hours of work, rates of compensation, leave, unemployment compensation, Federal employee benefits, ethics, conflicts of interest, and other similar criminal or civil statutes and regulations governing the conduct of Federal employees. However, nothing in this subsection shall constrain the Commandant from prescribing standards for the conduct and behavior of members of the Auxiliary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56dab9de-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of the Auxiliary while assigned to duty shall be deemed to be a Federal employee only for the purposes of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56dab9df-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 171 of title 28 (popularly known as the Federal Tort Claims Act).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dab9e0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2733"},"text":"Section 2733 of title 10","children":[],"tail":" (popularly known as the Military Claims Act)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dab9e1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3904/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s30101"},"text":"Section 30101 of title 46","children":[],"tail":" (popularly known as the Admiralty Extension Act)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dab9e2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3904/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 309 of title 46 (known as the Suits in Admiralty Act).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dab9e3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3904/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 311 of title 46 (known as the Public Vessels Act).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dab9e4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3904/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other matters related to noncontractual civil liability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":