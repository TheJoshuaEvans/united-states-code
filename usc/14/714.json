{"tag":"section","attrib":{"id":"id569f109f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714"},"text":null,"children":[{"tag":"num","attrib":{"value":"714"},"text":"§ 714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arctic maritime domain awareness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id569f10a0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall improve maritime domain awareness in the Arctic—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id569f10a1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by promoting interagency cooperation and coordination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10a2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by employing joint, interagency, and international capabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10a3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by facilitating the sharing of information, intelligence, and data related to the Arctic maritime domain between the Coast Guard and departments and agencies listed in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f10a4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall seek to coordinate the collection, sharing, and use of information, intelligence, and data related to the Arctic maritime domain between the Coast Guard and the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id569f10a5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10a6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10a7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10a8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10a9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10aa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Aeronautics and Space Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10ab-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10ac-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10ad-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10ae-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Arctic Research Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10af-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any Federal agency or commission or State the Commandant determines is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f10b0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant and the head of a department or agency listed in subsection (b) may by agreement, on a reimbursable basis or otherwise, share personnel, services, equipment, and facilities to carry out the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f10b1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 5","children":[{"tag":"inline","attrib":{},"text":"-year Strategic Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2016-01-01"},"text":"January 1, 2016","children":[],"tail":" and every 5 years thereafter, the Commandant shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a 5-year strategic plan to guide interagency and international intergovernmental cooperation and coordination for the purpose of improving maritime domain awareness in the Arctic."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f10b2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s714/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section the term “Arctic” has the meaning given that term in section 112 of the Arctic Research and Policy Act of 1984 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4111"},"text":"15 U.S.C. 4111","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id569f10b3-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/tV/s502/a"},"text":"Pub. L. 113–281, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3057"},"text":"128 Stat. 3057","children":[],"tail":", § 154; renumbered § 714, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s106/b"},"text":"Pub. L. 115–282, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4203"},"text":"132 Stat. 4203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569f10b4-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569f10b5-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id569f10b6-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s154"},"text":"section 154 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
