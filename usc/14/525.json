{"tag":"section","attrib":{"id":"id56980c12-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s525"},"text":null,"children":[{"tag":"num","attrib":{"value":"525"},"text":"§ 525.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special agents of the Coast Guard Investigative Service law enforcement authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56980c13-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s525/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56980c14-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s525/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A special agent of the Coast Guard Investigative Service designated under subsection (b) has the following authority:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56980c15-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s525/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry firearms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56980c16-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s525/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To execute and serve any warrant or other process issued under the authority of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56980c17-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s525/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To make arrests without warrant for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56980c18-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s525/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any offense against the United States committed in the agent’s presence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56980c19-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s525/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any felony cognizable under the laws of the United States if the agent has probable cause to believe that the individual to be arrested has committed or is committing the felony.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56980c1a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s525/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authorities provided in paragraph (1) shall be exercised only in the enforcement of statutes for which the Coast Guard has law enforcement authority, or in exigent circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56980c1b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s525/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commandant may designate to have the authority provided under subsection (a) any special agent of the Coast Guard Investigative Service whose duties include conducting, supervising, or coordinating investigation of criminal activity in programs and operations of the United States Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56980c1c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s525/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority provided under subsection (a) shall be exercised in accordance with guidelines prescribed by the Commandant and approved by the Attorney General and any other applicable guidelines prescribed by the Secretary or the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56980c1d-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/448/s10/a"},"text":"Pub. L. 100–448, § 10(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-28"},"text":"Sept. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1842"},"text":"102 Stat. 1842","children":[],"tail":", § 95; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/383/tII/s205/a"},"text":"Pub. L. 105–383, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3415"},"text":"112 Stat. 3415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/a"},"text":"Pub. L. 107–296, title XVII, § 1704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tII/s217/2"},"text":"Pub. L. 112–213, title II, § 217(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1557"},"text":"126 Stat. 1557","children":[],"tail":"; renumbered § 525, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s105/b"},"text":"Pub. L. 115–282, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4200"},"text":"132 Stat. 4200","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(6), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4748"},"text":"134 Stat. 4748","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56980c1e-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56980c1f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56980c20-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “individual” for “person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s95"},"text":"section 95 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213"},"text":"Pub. L. 112–213","children":[],"tail":" struck out “of Homeland Security” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383"},"text":"Pub. L. 105–383","children":[],"tail":" substituted “Special agents of the Coast Guard Investigative Service law enforcement authority” for “Civilian agents authorized to carry firearms” as section catchline and amended text generally. Prior to amendment, text read as follows: “Under regulations prescribed by the Secretary with the approval of the Attorney General, civilian special agents of the Coast Guard may carry firearms or other appropriate weapons while assigned to official investigative or law enforcement duties.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56980c21-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id56980c22-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
