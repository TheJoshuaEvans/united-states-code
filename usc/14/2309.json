{"tag":"section","attrib":{"id":"id56c07b3a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2309"},"text":null,"children":[{"tag":"num","attrib":{"value":"2309"},"text":"§ 2309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recall to active duty with consent of member","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any enlisted member on the retired list may, with his consent, be assigned to such duties as he may be able to perform, except that no enlisted member on the retired list who has reached the age of sixty-two years shall be recalled in time of peace.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56c07b3b-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/522"},"text":"63 Stat. 522","children":[],"tail":", § 360; "},{"tag":"ref","attrib":{"href":"/us/act/1950-08-03/ch536/s19"},"text":"Aug. 3, 1950, ch. 536, § 19","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/407"},"text":"64 Stat. 407","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/3/A"},"text":"Pub. L. 98–557, § 15(a)(3)(A)","children":[],"tail":", (4)(B)(i), "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":"; renumbered § 2309, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s113/b"},"text":"Pub. L. 115–282, title I, § 113(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4221"},"text":"132 Stat. 4221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c07b3c-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56c07b3d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 185c (","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-05-24/ch146/s4"},"text":"May 24, 1939, ch. 146, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/755"},"text":"53 Stat. 755","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section was changed so as to make provisions for enlisted men parallel to similar provisions for commissioned and warrant officers (see §§ 241 and 311 of the revised title). It seems fair and equitable that similar provisions should apply to all classes of personnel insofar as practicable. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c07b3e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c07b3f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s360"},"text":"section 360 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted “member” for “man” in section catchline, and in text substituted reference to enlisted member for reference to enlisted man in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-08-03"},"text":"Aug. 3, 1950","children":[],"tail":", struck out all references to pay."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
