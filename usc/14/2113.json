{"tag":"section","attrib":{"id":"id56b70599-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113"},"text":null,"children":[{"tag":"num","attrib":{"value":"2113"},"text":"§ 2113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of officers for consideration for promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56b7059a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer on the active duty promotion list becomes eligible for consideration for promotion to the next higher grade at the beginning of the promotion year in which he completes the following amount of service computed from his date of rank in the grade in which he is serving:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b7059b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two years in the grade of lieutenant (junior grade);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b7059c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three years in the grade of lieutenant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b7059d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four years in the grade of lieutenant commander;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b7059e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four years in the grade of commander; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b7059f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three years in the grade of captain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b705a0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, service in a grade includes all qualifying service in that grade or a higher grade, under either a temporary or permanent appointment. However, service in a grade under a temporary service appointment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2125"},"text":"section 2125 of this title","children":[],"tail":" is considered as service only in the grade that the officer concerned would have held had he not been so appointed."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b705a1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No officer may become eligible for consideration for promotion until all officers of his grade senior to him are so eligible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b705a2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except when his name is on a list of selectees, each officer who becomes eligible for consideration for promotion to the next higher grade remains eligible so long as he—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b705a3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continues on active duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b705a4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not promoted to that grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b705a5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer whose involuntary retirement or separation is deferred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2156"},"text":"section 2156 of this title","children":[],"tail":" is not eligible for consideration for promotion to the next higher grade during the period of that deferment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b705a6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may waive subsection (a) to the extent necessary to allow officers described therein to have at least two opportunities for consideration for promotion to the next higher grade as officers below the promotion zone.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b705a7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b705a8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsection (a), the Commandant may provide that an officer may, upon the officer’s request and with the approval of the Commandant, be excluded from consideration by a selection board convened under section 2106.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b705a9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commandant shall approve a request under paragraph (1) only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56b705aa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis for the request is to allow the officer to complete a broadening assignment, advanced education, another assignment of significant value to the Coast Guard, a career progression requirement delayed by the assignment or education, or a qualifying personal or professional circumstance, as determined by the Commandant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b705ab-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commandant determines the exclusion from consideration is in the best interest of the Coast Guard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b705ac-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2113/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer has not previously failed of selection for promotion to the grade for which the officer requests the exclusion from consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56b705ad-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/179"},"text":"77 Stat. 179","children":[],"tail":", § 257; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/546/s1/19"},"text":"Pub. L. 94–546, § 1(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2520"},"text":"90 Stat. 2520","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s17/b/1"},"text":"Pub. L. 98–557, § 17(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2867"},"text":"98 Stat. 2867","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tII/s203"},"text":"Pub. L. 109–241, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/520"},"text":"120 Stat. 520","children":[],"tail":"; renumbered § 2113 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 112(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":", 4240; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8202(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4642"},"text":"134 Stat. 4642","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56b705ae-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56b705af-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56b705b0-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s112/b"},"text":"Pub. L. 115–282, § 112(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s257"},"text":"section 257 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 2125” for “section 275”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 2156” for “section 295”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241"},"text":"Pub. L. 109–241","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/546/s1/19/a"},"text":"Pub. L. 94–546, § 1(19)(a)","children":[],"tail":", substituted “promotion year” for “fiscal year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/546/s1/19/b"},"text":"Pub. L. 94–546, § 1(19)(b)","children":[],"tail":", struck out cl. (3) “if serving in a grade below captain, has not twice failed of selection for promotion to the next higher grade.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
