{"tag":"section","attrib":{"id":"id56c2ecca-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504"},"text":null,"children":[{"tag":"num","attrib":{"value":"2504"},"text":"§ 2504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of retired pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56c2eccb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c2eccc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The retired pay of a member who first became a member of a uniformed service (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of title 10","children":[],"tail":") before "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"September 8, 1980","children":[],"tail":", is determined by multiplying—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c2eccd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56c2ecce-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basic pay of the member’s retired grade or rate, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c2eccf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all permanent additions thereto including longevity credit to which the member was entitled at the time of retirement; by","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c2ecd0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retired pay multiplier determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1409"},"text":"section 1409 of title 10","children":[],"tail":" for the number of years of service that may be credited to the member under section 1405 of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c2ecd1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an officer who served as Commandant, retired pay under paragraph (1) shall be computed at the highest rate of basic pay applicable to the officer while so serving.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c2ecd2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an enlisted member who served as the master chief petty officer of the Coast Guard, retired pay under paragraph (1) shall be computed at the highest rate of basic pay to which the member was entitled while so serving, if that basic pay is greater than the basic pay of the grade or rate to which the member is otherwise entitled at the time of retirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c2ecd3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an officer whose retired pay is computed on the pay of a grade for which basic pay is not based upon years of service, retired pay under paragraph (1) shall be computed on the basis of the number of years of service for which the officer would be entitled to credit in the computation of pay on the active list had the officer been serving in the grade of captain at the time of retirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c2ecd4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The retired pay of a member who first became a member of a uniformed service (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of title 10","children":[],"tail":") on or after "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"September 8, 1980","children":[],"tail":", is determined by multiplying—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c2ecd5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retired pay base determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1407"},"text":"section 1407 of title 10","children":[],"tail":"; by"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c2ecd6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retired pay multiplier determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1409"},"text":"section 1409 of title 10","children":[],"tail":" for the number of years of service that may be credited to the member under section 1405 of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c2ecd7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c2ecd8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In computing for the purpose of subsection (a) or (b) the number of years of service that may be credited to a member under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1405"},"text":"section 1405 of title 10","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c2ecd9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each full month of service that is in addition to the number of full years of service creditable to the member shall be counted as ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"12","children":[],"tail":" of a year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c2ecda-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any remaining fractional part of a month shall be disregarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c2ecdb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Retired pay computed under this section, if not a multiple of $1, shall be rounded to the next lower multiple of $1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c2ecdc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2504/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to amounts computed pursuant to subsections (a) through (c) of this section, a full TSP member (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8440e/a"},"text":"section 8440e(a) of title 5","children":[],"tail":") of the Coast Guard is entitled to continuation pay pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s356"},"text":"section 356 of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56c2ecdd-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/525"},"text":"63 Stat. 525","children":[],"tail":", § 423; "},{"tag":"ref","attrib":{"href":"/us/act/1950-08-03/ch536/s23"},"text":"Aug. 3, 1950, ch. 536, § 23","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/407"},"text":"64 Stat. 407","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/422/s11/b"},"text":"Pub. L. 85–422, § 11(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-05-20"},"text":"May 20, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/132"},"text":"72 Stat. 132","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/132/s5/i"},"text":"Pub. L. 88–132, § 5(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-10-02"},"text":"Oct. 2, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/214"},"text":"77 Stat. 214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/455/s2"},"text":"Pub. L. 92–455, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-02"},"text":"Oct. 2, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/761"},"text":"86 Stat. 761","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/342/tVIII/s813/f/2"},"text":"Pub. L. 96–342, title VIII, § 813(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1109"},"text":"94 Stat. 1109","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s2/12"},"text":"Pub. L. 97–295, § 2(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1302"},"text":"96 Stat. 1302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tIX"},"text":"Pub. L. 98–94, title IX","children":[],"tail":", §§ 922(b), 923(d), "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/642"},"text":"97 Stat. 642","children":[],"tail":", 643; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/3/A"},"text":"Pub. L. 98–557, § 15(a)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/348/tII/s205/a"},"text":"Pub. L. 99–348, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-07-01"},"text":"July 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/699"},"text":"100 Stat. 699","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dF/tII/s225"},"text":"Pub. L. 115–141, div. F, title II, § 225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/616"},"text":"132 Stat. 616","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3531/c/13"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3531(c)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2320"},"text":"132 Stat. 2320","children":[],"tail":"; renumbered § 2504, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s114/b"},"text":"Pub. L. 115–282, title I, § 114(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4223"},"text":"132 Stat. 4223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c2ecde-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56c2ecdf-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., §§ 162a, 167, 175c, 185d (","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-04-12/ch501/s9"},"text":"Apr. 12, 1902, ch. 501, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/101"},"text":"32 Stat. 101","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-01-12/ch3/s3"},"text":"Jan. 12, 1938, ch. 3, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/5"},"text":"52 Stat. 5","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-05-24/ch146/s5"},"text":"May 24, 1939, ch. 146, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/756"},"text":"53 Stat. 756","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-02-21/ch34/s10"},"text":"Feb. 21, 1946, ch. 34, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/29"},"text":"60 Stat. 29","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enlarged to include computation of retired pay in all situations. It is in accord with the provisions of Navy statutes. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c2ece0-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c2ece1-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s423"},"text":"section 423 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “Commandant” for “Commandant of the Coast Guard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348"},"text":"Pub. L. 99–348","children":[],"tail":" amended section generally. Prior to amendment, section provided that retired pay of a grade or rating would be computed at the rate of 2½ percent of the sum of the basic pay of that grade or rating and all permanent additions thereto including longevity credit, multiplied by the number of years of service credited, with certain exceptions, and that retired pay of an officer or member of the Coast Guard who first became a member of a uniformed service, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1407/a/2"},"text":"section 1407(a)(2) of title 10","children":[],"tail":", after "},{"tag":"date","attrib":{"date":"1980-09-07"},"text":"Sept. 7, 1980","children":[],"tail":", would be computed at the rate of 2½ percent of the monthly retired pay base computed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1407/f"},"text":"section 1407(f) of title 10","children":[],"tail":", multiplied by the number of years of service credited, but that retired pay was not to be more than 75 percent of such monthly retired pay base."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted reference to enlisted member concerned for reference to enlisted man concerned."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/s923/d"},"text":"Pub. L. 98–94, § 923(d)","children":[],"tail":", substituted “In computing the number of years of service by which the rate of 2½ percent is multiplied, each full month of service that is in addition to the number of full years of service creditable to a member is counted as one-twelfth of a year and any remaining fractional part of a month is disregarded” for “A fractional year of six months or more shall be considered a full year in computing the number of years of service by which the rate of 2½ percent is multiplied”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/s922/b"},"text":"Pub. L. 98–94, § 922(b)","children":[],"tail":", inserted “Retired pay, if not a multiple of $1, shall be rounded to the next lower multiple of $1.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “after "},{"tag":"date","attrib":{"date":"1980-09-07"},"text":"September 7, 1980","children":[],"tail":"” for “on or after the date of the enactment of the Department of Defense Authorization Act, 1981”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/342"},"text":"Pub. L. 96–342","children":[],"tail":" designated existing provisions as subsec. (a), substituted “Except as provided in subsection (b), the” for “The”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/455"},"text":"Pub. L. 92–455","children":[],"tail":" provided for computation of retired pay of an enlisted member serving as the master chief petty officer of the Coast Guard at the highest basic pay applicable to him while he so served, if that basic pay is greater than the basic pay of the grade or rating to which he was otherwise entitled at the time of retirement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/132"},"text":"Pub. L. 88–132","children":[],"tail":" substituted “basic” for “active-duty” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/422"},"text":"Pub. L. 85–422","children":[],"tail":" substituted “that may be credited to him under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1405"},"text":"section 1405 of title 10","children":[],"tail":"” for “for which he was entitled to credit in the computation of his pay when last on active duty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-08-03"},"text":"Aug. 3, 1950","children":[],"tail":", struck out reference to computation of pay of retired personnel retired by reason of physical disability."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56c2ece2-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id56c2ece3-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/s922"},"text":"section 922 of Pub. L. 98–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"Oct. 1, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/s922/e"},"text":"section 922(e) of Pub. L. 98–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1401"},"text":"section 1401 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/s923"},"text":"section 923 of Pub. L. 98–94","children":[],"tail":" applicable with respect to the computation of retired or retainer pay of any individual who becomes entitled to that pay after "},{"tag":"date","attrib":{"date":"1983-09-30"},"text":"Sept. 30, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"