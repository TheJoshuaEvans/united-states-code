{"tag":"section","attrib":{"id":"id56d5ff4a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710"},"text":null,"children":[{"tag":"num","attrib":{"value":"3710"},"text":"§ 3710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve student pre-commissioning assistance program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d5ff4b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may provide financial assistance to an eligible enlisted member of the Coast Guard Reserve, not on active duty, for expenses of the member while the member is pursuing on a full-time basis at an institution of higher education a program of education approved by the Secretary that leads to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d5ff4c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a baccalaureate degree in not more than 5 academic years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d5ff4d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a post-baccalaureate degree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ff4e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d5ff4f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To be eligible for financial assistance under this section, an enlisted member of the Coast Guard Reserve shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56d5ff50-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be enrolled on a full-time basis in a program of education referred to in subsection (a) at any institution of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d5ff51-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into a written agreement with the Coast Guard described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d5ff52-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A written agreement referred to in paragraph (1)(B) is an agreement between the member and the Secretary in which the member agrees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56d5ff53-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept an appointment as a commissioned officer in the Coast Guard Reserve, if tendered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d5ff54-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve on active duty for up to five years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d5ff55-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under such terms and conditions as shall be prescribed by the Secretary, to serve in the Coast Guard Reserve until the eighth anniversary of the date of the appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ff56-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Expenses for which financial assistance may be provided under this section are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d5ff57-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tuition and fees charged by the institution of higher education involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d5ff58-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost of books.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d5ff59-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a program of education leading to a baccalaureate degree, laboratory expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d5ff5a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other expenses as are deemed appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ff5b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of financial assistance provided to a member under this section shall be prescribed by the Secretary, but may not exceed $25,000 for any academic year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ff5c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Financial assistance may be provided to a member under this section for up to 5 consecutive academic years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ff5d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member who receives financial assistance under this section may be ordered to active duty in the Coast Guard Reserve by the Secretary to serve in a designated enlisted grade for such period as the Secretary prescribes, but not more than 4 years, if the member—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d5ff5e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completes the academic requirements of the program and refuses to accept an appointment as a commissioned officer in the Coast Guard Reserve when offered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d5ff5f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to complete the academic requirements of the institution of higher education involved; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d5ff60-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to maintain eligibility for an original appointment as a commissioned officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ff61-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d5ff62-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a member requests to be released from the program and the request is accepted by the Secretary, or if the member fails because of misconduct to complete the period of active duty specified, or if the member fails to fulfill any term or condition of the written agreement required to be eligible for financial assistance under this section, the financial assistance shall be terminated. The Secretary may request the member to reimburse the United States in an amount that bears the same ratio to the total costs of the education provided to that member as the unserved portion of active duty bears to the total period of active duty the member agreed to serve. The Secretary shall have the option to order such reimbursement without first ordering the member to active duty. An obligation to reimburse the United States imposed under this paragraph is a debt owed to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d5ff63-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may waive the service obligated under subsection (f) of a member who becomes unqualified to serve on active duty due to a circumstance not within the control of that member or who is not physically qualified for appointment and who is determined to be unqualified for service as an enlisted member of the Coast Guard Reserve due to a physical or medical condition that was not the result of the member’s own misconduct or grossly negligent conduct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d5ff64-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A discharge in bankruptcy under title 11 that is entered less than 5 years after the termination of a written agreement entered into under subsection (b) does not discharge the individual signing the agreement from a debt arising under such agreement or under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ff65-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3710/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this section, the term “institution of higher education” has the meaning given that term in section 101 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"20 U.S.C. 1001","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d5ff66-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIV/s413/a"},"text":"Pub. L. 107–295, title IV, § 413(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2119"},"text":"116 Stat. 2119","children":[],"tail":", § 709a; renumbered § 3710, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s118/b"},"text":"Pub. L. 115–282, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d5ff67-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d5ff68-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d5ff69-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s709a"},"text":"section 709a of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
