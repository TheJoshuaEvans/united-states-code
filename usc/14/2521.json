{"tag":"section","attrib":{"id":"id56c536cf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2521"},"text":null,"children":[{"tag":"num","attrib":{"value":"2521"},"text":"§ 2521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Board on Women in the Coast Guard","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56c536d0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2521/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall establish within the Coast Guard an Advisory Board on Women in the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c536d1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2521/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Board established under subsection (a) shall be composed of such number of members as the Commandant considers appropriate, selected by the Commandant through a public selection process from among applicants for membership on the Board. The members of the Board shall, to the extent practicable, represent the diversity of the Coast Guard. The members of the Committee shall include an equal number of each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c536d2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2521/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Active duty officers of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c536d3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2521/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Active duty enlisted members of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c536d4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2521/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Coast Guard Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c536d5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2521/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Retired members of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c536d6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2521/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Board established under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c536d7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2521/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall advise the Commandant on improvements to the recruitment, retention, wellbeing, and success of women serving in the Coast Guard and attending the Coast Guard Academy, including recommendations for the report on gender diversity in the Coast Guard required by section 5109 of chapter 51 of title 14;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c536d8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2521/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may submit to the Commandant recommendations in connection with its duties under this subsection, including recommendations to implement the advice described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c536d9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2521/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may brief Congress on its duties under this subsection, including the advice described in paragraph (1) and any recommendations described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56c536da-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8215(c)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4651"},"text":"134 Stat. 4651","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
