{"tag":"section","attrib":{"id":"id56a63caa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s948"},"text":null,"children":[{"tag":"num","attrib":{"value":"948"},"text":"§ 948.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for medical care for retirees, dependents, and survivors: alternative delivery of health care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a63cab-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s948/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may contract for the delivery of health care to which covered beneficiaries are entitled under chapter 55 of title 10. The Secretary may enter into a contract under this section with any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63cac-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s948/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health maintenance organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63cad-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s948/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Preferred provider organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63cae-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s948/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individual providers, individual medical facilities, or insurers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63caf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s948/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consortiums of these providers, facilities, or insurers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63cb0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s948/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A contract entered into under this section may provide for the delivery of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63cb1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s948/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selected health care services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63cb2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s948/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total health care services for selected covered beneficiaries; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63cb3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s948/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total health care services for all covered beneficiaries who reside in a geographic area designated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63cb4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s948/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may prescribe a premium, deductible, copayment, or other change for health care provided under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a63cb5-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/595/tIII/s319/a"},"text":"Pub. L. 101–595, title III, § 319(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2989"},"text":"104 Stat. 2989","children":[],"tail":", § 668; renumbered § 948, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s107/b"},"text":"Pub. L. 115–282, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4205"},"text":"132 Stat. 4205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a63cb6-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a63cb7-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a63cb8-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s668"},"text":"section 668 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
