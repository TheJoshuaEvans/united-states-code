{"tag":"section","attrib":{"id":"id56d144fd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2906"},"text":null,"children":[{"tag":"num","attrib":{"value":"2906"},"text":"§ 2906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dependent school children","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d144fe-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may provide, out of funds appropriated to or for the use of the Coast Guard, for the primary and secondary schooling of dependents of Coast Guard personnel stationed outside the continental United States at costs for any given area not in excess of those of the Department of Defense for the same area, when it is determined by the Secretary that the schools, if any, available in the locality are unable to provide adequately for the education of those dependents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d144ff-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever the Secretary, under such regulations as he may prescribe, determines that schools located in the same area in which a Coast Guard facility is located are not accessible by public means of transportation on a regular basis, he may provide, out of funds appropriated to or for the use of the Coast Guard, for the transportation of dependents of Coast Guard personnel between the schools serving the area and the Coast Guard facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d14500-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/278/s1/14"},"text":"Pub. L. 91–278, § 1(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-12"},"text":"June 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/306"},"text":"84 Stat. 306","children":[],"tail":", § 657; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/430/s5"},"text":"Pub. L. 93–430, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-01"},"text":"Oct. 1, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1182"},"text":"88 Stat. 1182","children":[],"tail":"; renumbered § 544 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s214/b/1/C"},"text":"Pub. L. 113–281, title II, § 214(b)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3033"},"text":"128 Stat. 3033","children":[],"tail":"; renumbered § 2906, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s117/b"},"text":"Pub. L. 115–282, title I, § 117(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4230"},"text":"132 Stat. 4230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d14501-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d14502-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56d14503-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2906 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s5107"},"text":"section 5107 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d14504-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s544"},"text":"section 544 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281"},"text":"Pub. L. 113–281","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s657"},"text":"section 657 of this title","children":[],"tail":" as this section and, in subsec. (a), substituted “The Secretary may” for “Except as otherwise authorized by the Act of "},{"tag":"date","attrib":{"date":"1950-09-30"},"text":"September 30, 1950","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s236–244"},"text":"20 U.S.C. 236–244","children":[],"tail":"), the Secretary may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/430"},"text":"Pub. L. 93–430","children":[],"tail":" struck out “; transportation of” after “children” in section catchline, designated existing provisions as subsec. (b), and added subsec. (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
