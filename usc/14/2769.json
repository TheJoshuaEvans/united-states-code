{"tag":"section","attrib":{"id":"id56ced334-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2769"},"text":null,"children":[{"tag":"num","attrib":{"value":"2769"},"text":"§ 2769.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remission of indebtedness","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may have remitted or cancelled any part of an individual’s indebtedness to the United States or any instrumentality of the United States if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ced335-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2769/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the indebtedness was incurred while the individual served as a member of the Coast Guard, whether as a regular or a reserve in active status; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ced336-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2769/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that remitting or cancelling the indebtedness is in the best interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ced337-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/530"},"text":"63 Stat. 530","children":[],"tail":", § 461; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s33/b"},"text":"Sept. 3, 1954, ch. 1263, § 33(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1238"},"text":"68 Stat. 1238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/526/s1/1"},"text":"Pub. L. 87–526, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-07-10"},"text":"July 10, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/141"},"text":"76 Stat. 141","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s14d/7"},"text":"Pub. L. 87–649, § 14d(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s73/a/3"},"text":"Pub. L. 89–718, § 73(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1124"},"text":"80 Stat. 1124","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s73/c/1"},"text":"Pub. L. 89–718, § 73(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1124"},"text":"80 Stat. 1124","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s2"},"text":"Pub. L. 90–83, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/220"},"text":"81 Stat. 220","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/546/s1/29"},"text":"Pub. L. 94–546, § 1(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2521"},"text":"90 Stat. 2521","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s203/a"},"text":"Pub. L. 114–120, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/34"},"text":"130 Stat. 34","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI/s671/b/4"},"text":"Pub. L. 114–328, div. A, title VI, § 671(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2173"},"text":"130 Stat. 2173","children":[],"tail":"; renumbered § 2769, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(40), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4750"},"text":"134 Stat. 4750","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ced338-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56ced339-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., §§ 20a, 121 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-05-18/ch190/s8"},"text":"May 18, 1920, ch. 190, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/603"},"text":"41 Stat. 603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1922-06-10/ch212"},"text":"June 10, 1922, ch. 212","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/625"},"text":"42 Stat. 625","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1926-07-03/ch742/s10"},"text":"July 3, 1926, ch. 742, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/817"},"text":"44 Stat. 817","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said section 121 was omitted from the 1940 and 1946 editions of the U.S. Code, but it has been held that the assimilation provision thereof is inoperative only insofar as Congress has made specific legislative provision for the Coast Guard, and that benefits derived from legislation pertaining to the Navy previously conferred upon the Coast Guard, and not provided for in subsequent legislation, survive to the Coast Guard under the assimilation statute. (See 27 Comp. Dec. 234; 22 Comp. Gen. 723; decision of ","children":[{"tag":"date","attrib":{"date":"1947-06-09"},"text":"June 9, 1947","children":[],"tail":", B–63472; decision of "},{"tag":"date","attrib":{"date":"1948-04-02"},"text":"April 2, 1948","children":[],"tail":", B–70438; and decision of "},{"tag":"date","attrib":{"date":"1948-09-02"},"text":"September 2, 1948","children":[],"tail":", B–77295.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"It seems desirable to retain this assimilation provision as to pay in order to cover any failure to provide specifically for the Coast Guard in military pay legislation.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section assimilates the pay of military personnel of the Coast Guard to the pay of military personnel of the Navy. It seems that this is the most feasible method of insuring that the pay of military personnel of the Coast Guard will not vary from the pay of military personnel of the other armed forces. The assimilation is intended to include authorization for extra pay and allowances as provided for personnel of the Navy, for all types of special duty: for example, qualified divers on diving duty, military personnel assigned to submarine duty, military personnel assigned to aviation duty, officers assigned as aides to flag officers, and enlisted persons assigned to duty in the mess detail. Military pay acts are intended to include Coast Guard personnel specifically; this section would cover any failure to so provide for Coast Guard personnel in a pay act.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ced33a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ced33b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8505/a/40/A"},"text":"Pub. L. 116–283, § 8505(a)(40)(A)","children":[],"tail":", substituted “an individual’s” for “a person’s” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8505/a/40/B"},"text":"Pub. L. 116–283, § 8505(a)(40)(B)","children":[],"tail":", substituted “individual” for “person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s461"},"text":"section 461 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “If he considers it in the best interest of the United States, the Secretary may have remitted or canceled any part of an enlisted member’s indebtedness to the United States or any of its instrumentalities remaining unpaid before or at the time of, that member’s honorable discharge.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “as a member of the Coast Guard, whether as a regular or a reserve in active status” for “on active duty as a member of the Coast Guard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/546"},"text":"Pub. L. 94–546","children":[],"tail":" substituted “Secretary” for “Secretary of the Treasury”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83"},"text":"Pub. L. 90–83","children":[],"tail":" corrected "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s73/a/3"},"text":"section 73(a)(3) of Pub. L. 89–718","children":[],"tail":" to change the designation of sections repealed under "},{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":" from sections 471(a) and (b) of Title 14 to sections 461(a) and (b) of Title 14. See 1966 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718/s73/a/3"},"text":"Pub. L. 89–718, § 73(a)(3)","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s14d"},"text":"section 14d of Pub. L. 87–649","children":[],"tail":", which contained in cls. (1) to (6) list of sections of Title 14 repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", by inserting “(7) Section 471(a) and (b).” However, for purposes of codification, the repeal has been executed to former subsecs. (a) and (b) of this section, which provided respectively for the awarding of the same pay and allowances as prescribed for corresponding ranks, grades, or ratings for personnel of the Navy and for the withholding of pay of officers on account of indebtedness to the United States, since this appears to have been the intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718/s73/c/1"},"text":"Pub. L. 89–718, § 73(c)(1)","children":[],"tail":", struck out references to pay and allowances and pay of officers indebted to the United States from section catchline and struck out letter designation “(c)” from beginning of former subsec. (c), leaving text of former subsec. (c) as constituting entire text of section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/526/s1/1/A"},"text":"Pub. L. 87–526, § 1(1)(A)","children":[],"tail":", amended section catchline to provide for remission of indebtedness of enlisted members."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/526/s1/1/B"},"text":"Pub. L. 87–526, § 1(1)(B)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-09-03"},"text":"Sept. 3, 1954","children":[],"tail":" inserted “; pay of officers indebted to United States” in section catchline, designated existing provisions as subsec. (a), and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56ced33c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id56ced33d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", and applicable with respect to debt incurred on or after "},{"tag":"date","attrib":{"date":"2001-10-07"},"text":"Oct. 7, 2001","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s671/b/5"},"text":"section 671(b)(5) of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7837"},"text":"section 7837 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id56ced33e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1967 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83/s9/i"},"text":"Pub. L. 90–83, § 9(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/222"},"text":"81 Stat. 222","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/83/s9/i"},"text":"“Section 2 of this Act [correcting ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718/s73/a/3"},"text":"section 73(a)(3) of Pub. L. 89–718","children":[],"tail":"] is effective as of "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"November 2, 1966","children":[],"tail":", for all purposes.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
