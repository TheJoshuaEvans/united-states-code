{"tag":"section","attrib":{"id":"id56c53608-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2510"},"text":null,"children":[{"tag":"num","attrib":{"value":"2510"},"text":"§ 2510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sea service letters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56c53609-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2510/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide a sea service letter to a member or former member of the Coast Guard who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c5360a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2510/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accumulated sea service on a vessel of the Armed Forces (as such term is defined in section 527(e)); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c5360b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2510/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requests such letter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c5360c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2510/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after receiving a request for a sea service letter from a member or former member of the Coast Guard under subsection (a), the Secretary shall provide such letter to such member or former member if such member or former member satisfies the requirement under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56c5360d-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/tIII/s305/b/1"},"text":"Pub. L. 113–281, title III, § 305(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3044"},"text":"128 Stat. 3044","children":[],"tail":", § 428; renumbered § 2510 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s114/b"},"text":"Pub. L. 115–282, title I, § 114(b)","children":[],"tail":", title III, § 318(c), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4223"},"text":"132 Stat. 4223","children":[],"tail":", 4252.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c5360e-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c5360f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c53610-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s114/b"},"text":"Pub. L. 115–282, § 114(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s428"},"text":"section 428 of this title","children"