{"tag":"section","attrib":{"id":"id56dab9d2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3903"},"text":null,"children":[{"tag":"num","attrib":{"value":"3903"},"text":"§ 3903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility; enrollments","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Auxiliary shall be composed of nationals of the United States, as defined in section 101(a)(22) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"8 U.S.C. 1101(a)(22)","children":[],"tail":"), and aliens lawfully admitted for permanent residence, as defined in section 101(a)(20) of the Immigration and Nationality Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/20"},"text":"8 U.S.C. 1101(a)(20)","children":[],"tail":")—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56dab9d3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3903/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56dab9d4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3903/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are owners, sole or part, of motorboats, yachts, aircraft, or radio stations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56dab9d5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3903/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by reason of their special training or experience are deemed by the Commandant to be qualified for duty in the Auxiliary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dab9d6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3903/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who may be enrolled therein pursuant to applicable regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56dab9d7-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/555"},"text":"63 Stat. 555","children":[],"tail":", § 823; "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tII/s215/a"},"text":"Pub. L. 112–213, title II, § 215(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1555"},"text":"126 Stat. 1555","children":[],"tail":"; renumbered § 3903, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s119/b"},"text":"Pub. L. 115–282, title I, § 119(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4236"},"text":"132 Stat. 4236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56dab9d8-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56dab9d9-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., §§ 262, 351 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-02-19/ch8"},"text":"Feb. 19, 1941, ch. 8","children":[],"tail":", title I, § 3, title III, § 301, "},{"tag":"ref","attrib":{"href":"/us/stat/55/9"},"text":"55 Stat. 9","children":[],"tail":", 13; "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-26/ch628"},"text":"Oct. 26, 1942, ch. 628","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/990"},"text":"56 Stat. 990","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1944-09-30/ch453/s2"},"text":"Sept. 30, 1944, ch. 453, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/760"},"text":"58 Stat. 760","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"All reference to the Philippine Islands is eliminated.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56dab9da-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56dab9db-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s823"},"text":"section 823 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213"},"text":"Pub. L. 112–213","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “The Auxiliary shall be composed of citizens of the United States and its territories and possessions, who are owners, sole or part, of motorboats, yachts, aircraft, or radio stations or who by reason of their special training or experience are deemed by the Commandant to be qualified for duty in the Auxiliary, and who may be enrolled therein pursuant to applicable regulations.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
