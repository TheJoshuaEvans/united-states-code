{"tag":"section","attrib":{"id":"id569f1072-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s710"},"text":null,"children":[{"tag":"num","attrib":{"value":"710"},"text":"§ 710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to foreign governments and maritime authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id569f1073-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detail of Members to Assist Foreign Governments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President may upon application from the foreign governments concerned, and whenever in his discretion the public interests render such a course advisable, detail members of the Coast Guard to assist foreign governments in matters concerning which the Coast Guard may be of assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f1074-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical Assistance to Foreign Maritime Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant, in coordination with the Secretary of State, may provide, in conjunction with regular Coast Guard operations, technical assistance (including law enforcement and maritime safety and security training) to foreign navies, coast guards, and other maritime authorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f1075-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s710/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants to International Maritime Organizations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After consultation with the Secretary of State, the Commandant may make grants to, or enter into cooperative agreements, contracts, or other agreements with, international maritime organizations for the purpose of acquiring information or data about merchant vessel inspections, security, safety, environmental protection, classification, and port state or flag state law enforcement or oversight.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f1076-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s710/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Activities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id569f1077-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s710/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commandant may use funds for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id569f1078-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s710/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities of traveling contact teams, including any transportation expense, translation services expense, or administrative expense that is related to such activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569f1079-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s710/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities of maritime authority liaison teams of foreign governments making reciprocal visits to Coast Guard units, including any transportation expense, translation services expense, or administrative expense that is related to such activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569f107a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s710/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seminars and conferences involving members of maritime authorities of foreign governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569f107b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s710/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distribution of publications pertinent to engagement with maritime authorities of foreign governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569f107c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s710/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel expenses for Coast Guard civilian and military personnel to the extent that those expenses relate to participation in an activity described in subparagraph (C) or (D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f107d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s710/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An activity may not be conducted under this subsection with a foreign country unless the Secretary of State approves the conduct of such activity in that foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f107e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s710/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of funds used under this subsection may not exceed $100,000 in any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id569f107f-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/507"},"text":"63 Stat. 507","children":[],"tail":", § 149; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/3/D"},"text":"Pub. L. 98–557, § 15(a)(3)(D)","children":[],"tail":", (E), (4)(A)(i), "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tII/s202/a"},"text":"Pub. L. 109–241, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/520"},"text":"120 Stat. 520","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tII"},"text":"Pub. L. 111–281, title II","children":[],"tail":", §§ 206, 220, "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2911"},"text":"124 Stat. 2911","children":[],"tail":", 2918; "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tII"},"text":"Pub. L. 112–213, title II","children":[],"tail":", §§ 203, 216(d), "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1543"},"text":"126 Stat. 1543","children":[],"tail":", 1555; renumbered § 710, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s106/b"},"text":"Pub. L. 115–282, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4203"},"text":"132 Stat. 4203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569f1080-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id569f1081-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Derived from title 34, U.S.C., 1946 ed., § 441a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-19/ch334"},"text":"May 19, 1926, ch. 334","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/565"},"text":"44 Stat. 565","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-05-14/ch109"},"text":"May 14, 1935, ch. 109","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/218"},"text":"49 Stat. 218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-01/ch571"},"text":"Oct. 1, 1942, ch. 571","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/763"},"text":"56 Stat. 763","children":[],"tail":"; 1946 Proc. No. 2695, "},{"tag":"date","attrib":{"date":"1946-07-04"},"text":"July 4, 1946","children":[],"tail":", 11 F.R. 7517, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1352"},"text":"60 Stat. 1352","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Experience has indicated that it will be advantageous for the Government to include the Coast Guard along with the other armed forces for the purpose of detailing personnel for service with foreign governments.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"It seems probable that the increased collaboration with foreign governments after the war and the vital nature of the Coast Guard’s activities in relation to such collaboration will result in requests from time to time by foreign governments for assistance which the Coast Guard is in the best position to render. This section, which confers broad authority in the President to detail Coast Guard officers and enlisted men to assist foreign governments, is patterned after the act of ","children":[{"tag":"date","attrib":{"date":"1942-10-01"},"text":"October 1, 1942","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/763"},"text":"56 Stat. 763","children":[],"tail":" (title 34, U.S.C., 1946 ed., § 441–a), which authorizes the President to detail Army, Navy, and Marine Corps officers and men to certain foreign governments and, in times of war or national emergency, to any foreign government in the interests of national defense. 81st Congress, House Report No. 557."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569f1082-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id569f1083-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 710 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s3711"},"text":"section 3711 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id569f1084-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s149"},"text":"section 149 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/s216/d"},"text":"Pub. L. 112–213, § 216(d)","children":[],"tail":", struck out at end “Members so detailed may accept, from the government to which detailed, offices and such compensation and emoluments thereunder appertaining as may be first approved by the Secretary. While so detailed such members shall receive, in addition to the compensation and emoluments allowed them by such governments, the pay and allowances to which they are entitled in the Coast Guard and shall be allowed the same credit for longevity, retirement, and for all other purposes that they would receive if they were serving with the Coast Guard.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/s203"},"text":"Pub. L. 112–213, § 203","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s206"},"text":"Pub. L. 111–281, § 206","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s220"},"text":"Pub. L. 111–281, § 220","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241"},"text":"Pub. L. 109–241","children":[],"tail":" substituted “Assistance to foreign governments and maritime authorities” for “Detail of members to assist foreign governments” in section catchline, designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted reference to members for reference to officers and enlisted men in three places in text, and in catchline substituted “members” for “officers and men”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id569f1085-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id569f1086-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Authority of President under this section as invoked by section 2 of Ex. Ord. No. 13223, ","children":[{"tag":"date","attrib":{"date":"2001-09-14"},"text":"Sept. 14, 2001","children":[],"tail":", 66 F.R. 48201, as amended, delegated to Secretary of Homeland Security by section 5 of Ex. Ord. No. 13223, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12302"},"text":"section 12302 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
