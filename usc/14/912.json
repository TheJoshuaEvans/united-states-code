{"tag":"section","attrib":{"id":"id56a3f2cf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912"},"text":null,"children":[{"tag":"num","attrib":{"value":"912"},"text":"§ 912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air facility closures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a3f2d0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Closures.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a3f2d1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":", the Secretary may not close a Coast Guard air facility, except as specified by this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f2d2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determinations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not propose closing or terminating operations at a Coast Guard air facility unless the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a3f2d3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remaining search and rescue capabilities maintain the safety of the maritime public in the area of the air facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a3f2d4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional or local prevailing weather and marine conditions, including water temperatures or unusual tide and current conditions, do not require continued operation of the air facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a3f2d5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coast Guard search and rescue standards related to search and response times are met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f2d6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public notice and comment.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a3f2d7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Prior to closing an air facility, the Secretary shall provide opportunities for public comment, including the convening of public meetings in communities in the area of responsibility of the air facility with regard to the proposed closure or cessation of operations at the air facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a3f2d8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Prior to convening a public meeting under subparagraph (A), the Secretary shall notify each congressional office representing any portion of the area of responsibility of the air station that is the subject to such public meeting of the schedule and location of such public meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f2d9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to closure, cessation of operations, or any significant reduction in personnel and use of a Coast Guard air facility that is in operation on or after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a3f2da-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Congress a proposal for such closure, cessation, or reduction in operations along with the budget of the President submitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":" that includes—"}],"tail":null},{"tag":"clause","attrib":{"id":"id56a3f2db-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discussion of the determination made by the Secretary pursuant to paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56a3f2dc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report summarizing the public comments received by the Secretary under paragraph (3) ","children":[{"tag":"ref","attrib":{"idref":"fn002020"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002020"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “; and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a3f2dd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 7 days after the date a proposal for an air facility is submitted pursuant to subparagraph (A), provide written notice of such proposal to each of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56a3f2de-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the House of Representatives who represents a district in which the air facility is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56a3f2df-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the Senate who represents a State in which the air facility is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56a3f2e0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the House of Representatives who represents a district in which assets of the air facility conduct search and rescue operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56a3f2e1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the Senate who represents a State in which assets of the air facility conduct search and rescue operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56a3f2e2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56a3f2e3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/4/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Transportation and Infrastructure of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56a3f2e4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/4/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Appropriations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56a3f2e5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/4/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Commerce, Science, and Transportation of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f2e6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not close, cease operations, or significantly reduce personnel and use of a Coast Guard air facility for which a written notice is provided under paragraph (4)(A) until a period of 18 months beginning on the date on which such notice is provided has elapsed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a3f2e7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operational Flexibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may implement any reasonable management efficiencies within the air station and air facility network, such as modifying the operational posture of units or reallocating resources as necessary to ensure the safety of the maritime public nationwide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a3f2e8-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s208/a"},"text":"Pub. L. 114–120, title II, § 208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/38"},"text":"130 Stat. 38","children":[],"tail":", § 676a; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3503/a"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2775"},"text":"130 Stat. 2775","children":[],"tail":"; renumbered § 912 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s107/b"},"text":"Pub. L. 115–282, title I, § 107(b)","children":[],"tail":", title III, § 319, "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4205"},"text":"132 Stat. 4205","children":[],"tail":", 4252.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a3f2e9-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a3f2ea-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a3f2eb-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s107/b"},"text":"Pub. L. 115–282, § 107(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s676a"},"text":"section 676a of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s319/1"},"text":"Pub. L. 115–282, § 319(1)","children":[],"tail":", (2), redesignated subsec. (b) as (a) and struck out former subsec. (a) which prohibited the Coast Guard from closing certain air facilities or retiring, transferring, relocating, or deploying an aviation asset for the purpose of closing such facilities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s319/3/A"},"text":"Pub. L. 115–282, § 319(3)(A)","children":[],"tail":", amended par. (3) generally. Prior to amendment, text read as follows: “Prior to closing an air facility, the Secretary shall provide opportunities for public comment, including the convening of public meetings in communities in the area of responsibility of the air facility with regard to the proposed closure or cessation of operations at the air facility.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s319/3/B/i"},"text":"Pub. L. 115–282, § 319(3)(B)(i)","children":[],"tail":", substituted “2017” for “2015” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s319/3/B/ii"},"text":"Pub. L. 115–282, § 319(3)(B)(ii)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “submit to the Congress a proposal for such closure, cessation, or reduction in operations along with the budget of the President submitted to Congress under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":" for the fiscal year in which the action will be carried out; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s319/3/C"},"text":"Pub. L. 115–282, § 319(3)(C)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s319/2"},"text":"Pub. L. 115–282, § 319(2)","children":[],"tail":", redesignated subsec. (c) as (b). Former subsec. (b) redesignated (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “Coast Guard Authorization Act of 2016” for “Coast Guard Authorization Act of 2015”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56a3f2ec-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id56a3f2ed-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective as if included in the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3503/e"},"text":"section 3503(e) of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2182"},"text":"section 2182 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
