{"tag":"section","attrib":{"id":"id56cc626c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2713"},"text":null,"children":[{"tag":"num","attrib":{"value":"2713"},"text":"§ 2713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56cc626d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to improve the accuracy and completeness of a certification or verification of job skills and experience required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1143/a/1"},"text":"section 1143(a)(1) of title 10","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56cc626e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2713/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a database to record all training performed by members of the Coast Guard that may have application to employment in the civilian sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56cc626f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2713/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make unclassified information regarding such information available to States and other potential employers referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1143/c"},"text":"section 1143(c) of title 10","children":[],"tail":" so that States and other potential employers may allow military training to satisfy licensing or certification requirements to engage in a civilian profession."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56cc6270-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form of Certification or Verification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that a certification or verification of job skills and experience required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1143/a/1"},"text":"section 1143(a)(1) of title 10","children":[],"tail":" is rendered in such a way that States and other potential employers can confirm the accuracy and authenticity of the certification or verification."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56cc6271-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2713/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requests by States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State may request that the Secretary confirm the accuracy and authenticity of a certification or verification of job skills and experience provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1143/c"},"text":"section 1143(c) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56cc6272-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8206(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4649"},"text":"134 Stat. 4649","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
