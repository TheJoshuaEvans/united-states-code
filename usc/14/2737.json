{"tag":"section","attrib":{"id":"id56cc62a2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2737"},"text":null,"children":[{"tag":"num","attrib":{"value":"2737"},"text":"§ 2737.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Silver star medal","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President may award a silver star medal of appropriate design, with ribbons and appurtenances, to an individual who, while serving in any capacity with the Coast Guard, when the Coast Guard is not operating under the Department of the Navy, is cited for gallantry in action that does not warrant a medal of honor or Coast Guard cross—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56cc62a3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2737/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while engaged in an action against an enemy of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56cc62a4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2737/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while engaged in military operations involving conflict with an opposing foreign force or international terrorist organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56cc62a5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2737/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while serving with friendly foreign forces engaged in an armed conflict against an opposing armed force in which the United States is not a belligerent party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56cc62a6-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tII/s224/b/2"},"text":"Pub. L. 111–281, title II, § 224(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2922"},"text":"124 Stat. 2922","children":[],"tail":", § 492a; renumbered § 2737, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(30), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4749"},"text":"134 Stat. 4749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56cc62a7-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56cc62a8-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56cc62a9-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “an individual” for “a person” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s492a"},"text":"section 492a of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
