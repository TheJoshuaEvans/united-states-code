{"tag":"section","attrib":{"id":"id56ab1f80-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1136"},"text":null,"children":[{"tag":"num","attrib":{"value":"1136"},"text":"§ 1136.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition approval authority","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter shall be construed as altering or diminishing in any way the statutory authority and responsibility of the Secretary of the department in which the Coast Guard is operating, or the Secretary’s designee, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ab1f81-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1136/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manage and administer department procurements, including procurements by department components, as required by section 701 of the Homeland Security Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s341"},"text":"6 U.S.C. 341","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f82-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1136/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manage department acquisition activities and act as the Acquisition Decision Authority with regard to the review or approval of a Coast Guard Level 1 or Level 2 acquisition project or program, as required by section 16 ","children":[{"tag":"ref","attrib":{"idref":"fn002024"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002024"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/u