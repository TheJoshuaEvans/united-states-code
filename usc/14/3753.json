{"tag":"section","attrib":{"id":"id56d8497e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3753"},"text":null,"children":[{"tag":"num","attrib":{"value":"3753"},"text":"§ 3753.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum ages for retention in an active status","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d8497f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3753/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Reserve officer, if qualified, shall be transferred to the Retired Reserve on the day the officer becomes 60 years of age unless on active duty. If not qualified for retirement, a Reserve officer shall be discharged effective upon the day the officer becomes 60 years of age unless on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d84980-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3753/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Reserve officer on active duty shall, if qualified, be retired effective upon the day the officer become 62 years of age. If not qualified for retirement, a Reserve officer on active duty shall be discharged effective upon the day the officer becomes 62 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d84981-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3753/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsections (a) and (b), the Secretary may authorize the retention of a Reserve rear admiral or rear admiral (lower half) in an active status not longer than the day on which the officer concerned becomes 64 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d84982-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3753/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention of Health Professions Officers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d84983-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3753/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsections (a), (b), and (c), the Secretary may authorize the retention of a Reserve health professions officer in an active status not beyond the first day of the month following the month in which the health professions officer concerned becomes 68 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d84984-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3753/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection may be construed to prohibit or modify the application of any provision relating to mandatory separation or disciplinary action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d84985-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3753/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Health professions officer defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “health professions officer” means an officer or enlisted member of the Coast Guard in good standing who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56d84986-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3753/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a physician, surgeon, medical specialist, nurse or nurse practitioner, physician’s assistant, health service technician, therapist, fully licensed clinical psychotherapist, counselor, social worker, medical assistant, radiology assistant, pharmacist, pharmacy assistant, nutritionist, dietitian, any administrative personnel associated with a Coast Guard medical program (including a clinic), personnel who works in a medical laboratory, physical therapist, physical therapist aide, occupational therapist, or occupational therapist aide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d84987-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3753/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dentist, dental assistant, oral surgeon, or any other dental-related personnel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d84988-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3753/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of a category designated by the Secretary under section 2154(c)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d84989-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3753/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, “active duty” does not include active duty for training, duty on a board, or duty of a limited or temporary nature if assigned to active duty from an inactive duty status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d8498a-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1014"},"text":"94 Stat. 1014","children":[],"tail":", § 742; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/417/s2/16"},"text":"Pub. L. 97–417, § 2(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-04"},"text":"Jan. 4, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2086"},"text":"96 Stat. 2086","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tV/s514/c/1"},"text":"Pub. L. 99–145, title V, § 514(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/629"},"text":"99 Stat. 629","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tII/s209"},"text":"Pub. L. 108–293, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1035"},"text":"118 Stat. 1035","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s209/13"},"text":"Pub. L. 114–120, title II, § 209(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/41"},"text":"130 Stat. 41","children":[],"tail":"; renumbered § 3753, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s118/b"},"text":"Pub. L. 115–282, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7222/b"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7222(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1701"},"text":"139 Stat. 1701","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d8498b-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d8498c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d8498d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s742"},"text":"section 742 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":" substituted “subsections” for “subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) A Reserve officer, if qualified, shall be transferred to the Retired Reserve on the day the officer becomes sixty-two years of age.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) Notwithstanding subsection (a) of this section, the Secretary may authorize the retention of a Reserve rear admiral or rear admiral (lower half) in an active status not longer than the day on which the officer concerned becomes sixty-four years of age.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) Except as provided for in subsections (a) and (b) of this section, a Reserve officer shall be discharged effective upon the day the officer becomes sixty-two years of age.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" substituted “rear admiral (lower half)” for “commodore”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/417"},"text":"Pub. L. 97–417","children":[],"tail":" inserted “or commodore” after “rear admiral”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
