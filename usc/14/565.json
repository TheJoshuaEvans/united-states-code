{"tag":"section","attrib":{"id":"id569cc721-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s565"},"text":null,"children":[{"tag":"num","attrib":{"value":"565"},"text":"§ 565.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of unmanned aircraft systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With respect to any unmanned aircraft system procured by the Coast Guard, the Commandant shall ensure that such system be used to support the primary duties of the Coast Guard pursuant to section 102.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id569cc722-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7338/a"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7338(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1776"},"text":"139 Stat. 1776","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
