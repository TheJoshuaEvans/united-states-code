{"tag":"section","attrib":{"id":"id56b7057e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2109"},"text":null,"children":[{"tag":"num","attrib":{"value":"2109"},"text":"§ 2109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection boards; oath of members","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each member of a selection board shall swear—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b7057f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2109/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the member will, without prejudice or partiality, and having in view both the special fitness of officers and the efficiency of the Coast Guard, perform the duties imposed upon the member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b70580-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2109/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an oath in accordance with section 931.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56b70581-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/179"},"text":"77 Stat. 179","children":[],"tail":", § 254; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tII/s207"},"text":"Pub. L. 112–213, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1546"},"text":"126 Stat. 1546","children":[],"tail":"; renumbered § 2109 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 112(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56b70582-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56b70583-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56b70584-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s112/b"},"text":"Pub. L. 115–282, § 112(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s254"},"text":"section 254 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 931” for “section 635”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213"},"text":"Pub. L. 112–213","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “Each member of a selection board shall swear that he will, without prejudice or partiality, and having in view both the special fitness of officers and the efficiency of the Coast Guard, perform the duties imposed upon him.”"}],"tail":"\n"}],"t