{"tag":"section","attrib":{"id":"id56c07b15-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2304"},"text":null,"children":[{"tag":"num","attrib":{"value":"2304"},"text":"§ 2304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compulsory retirement at age of sixty-two","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any enlisted member who has reached the age of sixty-two shall be retired from active service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56c07b16-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/520"},"text":"63 Stat. 520","children":[],"tail":", § 353; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/3/A"},"text":"Pub. L. 98–557, § 15(a)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/348/tII/s205/b/8"},"text":"Pub. L. 99–348, title II, § 205(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-07-01"},"text":"July 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/700"},"text":"100 Stat. 700","children":[],"tail":"; renumbered § 2304, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s113/b"},"text":"Pub. L. 115–282, title I, § 113(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4221"},"text":"132 Stat. 4221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c07b17-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56c07b18-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 173 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-04-12/ch501/s4"},"text":"Apr. 12, 1902, ch. 501, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/100"},"text":"32 Stat. 100","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s173"},"text":"Section 173 of title 14","children":[],"tail":", U.S.C., 1946 ed., has been divided. That part dealing with enlisted men is placed in this section. That part dealing with commissioned officers is placed in "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s230"},"text":"section 230 of this title","children":[],"tail":". That part dealing with warrant officers is placed in "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s303"},"text":"section 303 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The compulsory retirement age is changed from 64 to 62 in order to make it the same for enlisted men as for officers. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c07b19-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c07b1a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s353"},"text":"section 353 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348"},"text":"Pub. L. 99–348","children":[],"tail":" struck out “, with retired pay of the grade or rating with which retired” after “active service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted reference to enlisted member for reference to enlisted man."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
