{"tag":"section","attrib":{"id":"id568016da-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s302"},"text":null,"children":[{"tag":"num","attrib":{"value":"302"},"text":"§ 302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commandant; appointment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id568016db-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002004"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002004"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":"The President may appoint, by and with the advice and consent of the Senate, one Commandant for a period of four years, who shall act as Chief of the Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id568016dc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reappointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In time of war or during a national emergency declared by Congress, the Commandant may be reappointed for a term of not more than 4 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id568016dd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of an appointment, and any reappointment, shall begin on June 1 of the appropriate year and end on May 31 of the appropriate year, except that, in the event of death, retirement, resignation, or reassignment, or when the needs of the Service demand, the Secretary may alter the date on which a term begins or ends if the alteration does not result in the term exceeding a period of 4 years. The Commandant shall be appointed from the officers on the active duty promotion list serving above the grade of captain who have completed at least ten years of active service as a commissioned officer in the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id568016de-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grade","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant while so serving shall have the grade of admiral.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id568016df-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/498"},"text":"63 Stat. 498","children":[],"tail":", § 44; "},{"tag":"ref","attrib":{"href":"/us/pl/86/474/s1/3"},"text":"Pub. L. 86–474, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-05-14"},"text":"May 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/144"},"text":"74 Stat. 144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/3"},"text":"Pub. L. 88–130, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/175"},"text":"77 Stat. 175","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/444/s1/3"},"text":"Pub. L. 89–444, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-06-09"},"text":"June 9, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/195"},"text":"80 Stat. 195","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/451/s1/3"},"text":"Pub. L. 92–451, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-02"},"text":"Oct. 2, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/755"},"text":"86 Stat. 755","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s202"},"text":"Pub. L. 113–281, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3024"},"text":"128 Stat. 3024","children":[],"tail":"; renumbered § 302, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s104/b"},"text":"Pub. L. 115–282, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4196"},"text":"132 Stat. 4196","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7201/b"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7201(b)","children":[],"tail":", (e)(2), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1675"},"text":"139 Stat. 1675","children":[],"tail":", 1678.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id568016e0-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id568016e1-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 11 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1908-04-16/ch145"},"text":"Apr. 16, 1908, ch. 145","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/35/61"},"text":"35 Stat. 61","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1915-01-28/ch20/s1"},"text":"Jan. 28, 1915, ch. 20, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/800"},"text":"38 Stat. 800","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1923-01-12/ch25/s2"},"text":"Jan. 12, 1923, ch. 25, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1130"},"text":"42 Stat. 1130","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1930-04-23/ch211"},"text":"Apr. 23, 1930, ch. 211","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/253"},"text":"46 Stat. 253","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1937-06-09/ch309/s1"},"text":"June 9, 1937, ch. 309, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/252"},"text":"50 Stat. 252","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1940-06-06/ch257/s1/a"},"text":"June 6, 1940, ch. 257, § 1(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/246"},"text":"54 Stat. 246","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said section has been divided. The provisions of the first proviso are placed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s45"},"text":"section 45 of this title","children":[],"tail":", and the remainder is placed in this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The grade of the Commandant is fixed as vice admiral rather than that prescribed for Bureau Chiefs of the Navy. The additional qualifications that an officer appointed Commandant must have at least 10 years commissioned service in the Coast Guard has been inserted. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id568016e2-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id568016e3-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/e/2"},"text":"Pub. L. 119–60, § 7201(e)(2)","children":[],"tail":", which directed amendment of "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s303"},"text":"section 303 of this title","children":[],"tail":", was executed to this section to reflect the probable intent of Congress. See 2025 Amendment notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id568016e4-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 302, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"act Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/518"},"text":"63 Stat. 518","children":[],"tail":", related to temporary appointments of warrant officers, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/A"},"text":"Pub. L. 88–130, § 1(10)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/177"},"text":"77 Stat. 177","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id568016e5-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/b"},"text":"Pub. L. 119–60, § 7201(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s302"},"text":"section 302 of this title","children":[],"tail":" as this section, resulting in no change."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/e/2/A"},"text":"Pub. L. 119–60, § 7201(e)(2)(A)","children":[],"tail":", (B), designated first sentence of existing provisions as subsec. (a), inserted heading, and struck out “ ,who may be reappointed for further periods of four years” after “period of four years”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/e/2/C"},"text":"Pub. L. 119–60, § 7201(e)(2)(C)","children":[],"tail":", which directed adding subsec. (b) after “Chief of the Coast Guard”, was executed by adding subsec. (b) after the period following “Chief of the Coast Guard” to reflect the probable intent of Congress. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/e/2/D"},"text":"Pub. L. 119–60, § 7201(e)(2)(D)","children":[],"tail":", inserted subsec. (c) designation and heading before “The term of an appointment”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/e/2/E"},"text":"Pub. L. 119–60, § 7201(e)(2)(E)","children":[],"tail":", inserted subsec. (d) designation and heading before “The Commandant while”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s44"},"text":"section 44 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281"},"text":"Pub. L. 113–281","children":[],"tail":" inserted after first sentence “The term of an appointment, and any reappointment, shall begin on June 1 of the appropriate year and end on May 31 of the appropriate year, except that, in the event of death, retirement, resignation, or reassignment, or when the needs of the Service demand, the Secretary may alter the date on which a term begins or ends if the alteration does not result in the term exceeding a period of 4 years.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/451"},"text":"Pub. L. 92–451","children":[],"tail":" substituted “above the grade of captain” for “in the grade of captain or above” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/444"},"text":"Pub. L. 89–444","children":[],"tail":" struck out provision that the position of an officer appointed Commandant be filled by promotion according to law."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130"},"text":"Pub. L. 88–130","children":[],"tail":" substituted “officers on the active duty promotion list serving in the grade of” for “active list of officers who hold a permanent commission as”, required qualifying period of 10 years commissioned service to be “active” service, and struck out “, pay, and allowances” before “of admiral”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/474"},"text":"Pub. L. 86–474","children":[],"tail":" substituted “active list of officers” for “active list of line officers”, “captain or above” for “commander or above”, and “allowances of admiral” for “allowances of vice admiral”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id568287e6-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id568287e7-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/451"},"text":"Pub. L. 92–451","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1972-10-02"},"text":"Oct. 2, 1972","children":[],"tail":", except that continuation boards may not be held until one year thereafter, see "},{"tag":"ref","attrib":{"href":"/us/pl/92/451/s3"},"text":"section 3 of Pub. L. 92–451","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2151"},"text":"section 2151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id568287e8-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of Higher Grade and Increased Pay and Allowances","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/474/s2"},"text":"Pub. L. 86–474, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-05-14"},"text":"May 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/146"},"text":"74 Stat. 146","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/86/474/s2"},"text":"“The increased grade of admiral for the Commandant and vice admiral for the Assistant Commandant [now Vice Commandant], including the pay and allowances applicable to such grades, shall be effective on the first day of the month following enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1960-05-14"},"text":"May 14, 1960","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id568287e9-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/474/s3"},"text":"Pub. L. 86–474, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-05-14"},"text":"May 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/146"},"text":"74 Stat. 146","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/86/474/s3"},"text":"“Except as provided by section 2 [set out as a note under this section], the amendments by section 1 [amending sections 41, 42, 44, 46, 47, 186 to 191, 222, 247(c), 365, and 462 of this title, and repealing sections 45, 48, and 49 of this title] shall not operate to change or deprive the present incumbents serving as Commandant, Assistant Commandant [now Vice Commandant], and Engineer in Chief of any rights, benefits and privileges appertaining to such offices on the day preceding the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1960-05-14"},"text":"May 14, 1960","children":[],"tail":"], nor to divest them of their offices for the terms appointed.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
