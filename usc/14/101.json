ref","attrib":{"href":"/us/stat/118/1028"},"text":"118 Stat. 1028","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/293/s1"},"text":"“This Act [see Tables for classification] may be referred to as the ‘Coast Guard and Maritime Transportation Act of 2004’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id567b5c6a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIII/s301"},"text":"Pub. L. 107–295, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2102"},"text":"116 Stat. 2102","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/295/tIII/s301"},"text":"“This title [amending sections 259, 260, 271, 336, and 511 of this title, sections 1203, 1231a, 2073, 2302, and 2752 of Title 33, Navigation and Navigable Waters, and sections 2110, 2302, 4508, 7302, 8701, and 13110 of Title 46, Shipping, and enacting provisions set out as notes under sections 88 and 92 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1113"},"text":"section 1113 of Title 33","children":[],"tail":"] may be cited as the ‘Coast Guard Personnel and Maritime Safety Act of 2002’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIV/s401"},"text":"Pub. L. 107–295, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2113"},"text":"116 Stat. 2113","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/295/tIV/s401"},"text":"“This title [see Tables for classification] may be cited as the ‘Omnibus Maritime and Coast Guard Improvements Act of 2002’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id567b5c6b-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Coast Guard transferred to Department of Transportation and all functions, powers, and duties, relating to Coast Guard, of Secretary of the Treasury and of other offices and officers of Department of the Treasury transferred to Secretary of Transportation by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/670/s6/b/1"},"text":"Pub. L. 89–670, § 6(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/931"},"text":"80 Stat. 931","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/89/670/s6/b/2"},"text":"Section 6(b)(2) of Pub. L. 89–670","children":[],"tail":", however, provided that notwithstanding such transfer of functions, Coast Guard shall operate as part of Navy in time of war or when President directs as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s3"},"text":"section 3 of this title","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s108"},"text":"section 108 of Title 49","children":[],"tail":", Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id567b5c6c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Directions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/s7002/b"},"text":"Pub. L. 119–60, div. G, § 7002(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1661"},"text":"139 Stat. 1661","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dG/s7002/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this division [div. G (§§ 7001–7701) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", see Tables for classification], when Secretary [sic] or the Commandant are [sic] directed to provide or develop—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a briefing, such briefing shall be accompanied by a narrative description, and at the option of any committee designated as a recipient, be delivered in person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a policy, such policy shall be detailed, in writing, and publicly available, but may contain a classified annex;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan, such plan shall be detailed, and in writing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report, such report shall be detailed and in writing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a strategy, such strategy shall be detailed and in writing.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of “Commandant” and “Secretary” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7002/b"},"text":"section 7002(b) of Pub. L. 119–60","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7002/a"},"text":"section 7002(a) of Pub. L. 119–60","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s106"},"text":"section 106 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id567b5c6d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Designation of Coast Guard Headquarters Building","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/31"},"text":"Pub. L. 113–31","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-08-09"},"text":"Aug. 9, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/511"},"text":"127 Stat. 511","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/31"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DESIGNATION.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The headquarters building of the Coast Guard on the campus located at 2701 Martin Luther King, Jr., Avenue Southeast in the District of Columbia shall be known and designated as the ‘Douglas A. Munro Coast Guard Headquarters Building’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" REFERENCES.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Any reference in a law, map, regulation, document, paper, or other record of the United States to the building referred to in section 1 shall be deemed to be a reference to the ‘Douglas A. Munro Coast Guard Headquarters Building’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
