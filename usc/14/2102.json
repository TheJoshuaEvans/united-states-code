":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56b4952f-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56b49530-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56b49531-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “officers of the permanent commissioned teaching staff of the Coast Guard Academy, and officers designated by the Secretary pursuant this section” for “and officers of the permanent commissioned teaching staff of the Coast Guard Academy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “An individual” for “A person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s41a"},"text":"section 41a of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12311"},"text":"section 12311 of title 10","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s679"},"text":"section 679 of title 10","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206"},"text":"Pub. L. 103–206","children":[],"tail":" struck out before period at end of second sentence “, except that the rear admiral serving as Chief of Staff shall be the senior rear admiral for all purposes other than pay”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/136/s6/a/1"},"text":"Pub. L. 97–136, § 6(a)(1)","children":[],"tail":", substituted “Reserve officers on active duty, other than pursuant to an active duty agreement executed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s679"},"text":"section 679 of title 10","children":[],"tail":", retired officers, and officers of the permanent commissioned teaching staff of the Coast Guard Academy shall not” for “Retired officers and officers of the permanent commissioned teaching staff of the Coast Guard Academy shall not be included on the active duty promotion list. Reserve officers on extended active duty, other than those serving in connection with organizing, administering, recruiting, instructing, or training the Reserve components or assigned to the Selective Service System, shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/136/s6/a/2"},"text":"Pub. L. 97–136, § 6(a)(2)","children":[],"tail":", inserted exception that rear admiral serving as Chief of Staff shall be senior rear admiral for all purposes other than pay."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/136/s6/a/3"},"text":"Pub. L. 97–136, § 6(a)(3)","children":[],"tail":", substituted “enters on active duty” for “enters on extended active duty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/174"},"text":"Pub. L. 93–174","children":[],"tail":" substituted “Retired officers and officers” for “Retired officers, officers” and struck out “, and officers of the Women’s Reserve” after “Coast Guard Academy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/278"},"text":"Pub. L. 91–278","children":[],"tail":" inserted “or assigned to the Selective Service System” after “components” in last sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56b49532-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id56b49533-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
