{"tag":"section","attrib":{"id":"id56d38ebe-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2946"},"text":null,"children":[{"tag":"num","attrib":{"value":"2946"},"text":"§ 2946.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coast Guard Housing Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d38ebf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2946/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is hereby established on the books of the Treasury an account to be known as the Coast Guard Housing Fund (in this section referred to as the “Fund”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d38ec0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2946/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credits to Fund","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be credited to the Fund the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d38ec1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2946/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts authorized for and appropriated to that Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d38ec2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2946/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (e), any amounts that the Secretary transfers, in such amounts as provided in appropriation Acts, to that Fund from amounts authorized and appropriated to the Department of Homeland Security or Coast Guard for the acquisition or construction of military family housing or military unaccompanied housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d38ec3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2946/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Proceeds from the conveyance of property under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2945"},"text":"section 2945 of this title","children":[],"tail":" for the purpose of carrying out activities under this chapter with respect to military family housing and military unaccompanied housing."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d38ec4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2946/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Monies received under section 504(a)(13).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d38ec5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2946/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts received under section 908(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d38ec6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2946/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Amounts in Fund","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d38ec7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2946/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In such amounts as provided in appropriations Acts, and except as provided in subsection (d), the Secretary may use amounts in the Coast Guard Housing Fund to carry out activities under this chapter with respect to military family housing and military unaccompanied housing, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56d38ec8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2946/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planning, execution, and administration of the conveyance of real property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d38ec9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2946/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all necessary expenses, including expenses for environmental compliance and restoration, to prepare real property for conveyance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d38eca-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2946/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conveyance of real property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d38ecb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2946/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts made available under this subsection shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d38ecc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2946/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Obligations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not incur an obligation under a contract or other agreements entered into under this chapter in excess of the unobligated balance, at the time the contract is entered into, of the Fund required to be used to satisfy the obligation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d38ecd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2946/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification Required for Transfers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A transfer of appropriated amounts to the Fund under subsection (b)(2) of this section may be made only after the end of a 30-day period beginning on the date the Secretary submits written notice of, and justification for, the transfer to the appropriate committees of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d38ece-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tII/s208/a"},"text":"Pub. L. 104–324, title II, § 208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3912"},"text":"110 Stat. 3912","children":[],"tail":", § 687; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIV/s402/b"},"text":"Pub. L. 107–295, title IV, § 402(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2114"},"text":"116 Stat. 2114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/a"},"text":"Pub. L. 107–296, title XVII, § 1704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tII/s207/d"},"text":"Pub. L. 108–293, title II, § 207(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1034"},"text":"118 Stat. 1034","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tII/s221/a/6"},"text":"Pub. L. 111–281, title II, § 221(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2919"},"text":"124 Stat. 2919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/330/s1/2"},"text":"Pub. L. 111–330, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3569"},"text":"124 Stat. 3569","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s208/c"},"text":"Pub. L. 113–281, title II, § 208(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3026"},"text":"128 Stat. 3026","children":[],"tail":"; renumbered § 2946 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 117(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4230"},"text":"132 Stat. 4230","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d38ecf-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d38ed0-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d38ed1-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s117/b"},"text":"Pub. L. 115–282, § 117(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s687"},"text":"section 687 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 2945” for “section 685”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 504(a)(13)” for “section 93(a)(13)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 908(b)” for “section 672a(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281"},"text":"Pub. L. 113–281","children":[],"tail":" added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s221/a/6/A/i"},"text":"Pub. L. 111–281, § 221(a)(6)(A)(i)","children":[],"tail":", substituted “or military unaccompanied” for “or unaccompanied”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s221/a/6/A/ii"},"text":"Pub. L. 111–281, § 221(a)(6)(A)(ii)","children":[],"tail":", substituted “military family housing and” for “military family and” and struck out “or lease” after “conveyance” and “or facilities” after “property”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s221/a/6/A/iii"},"text":"Pub. L. 111–281, § 221(a)(6)(A)(iii)","children":[],"tail":", struck out par. (4) which read as follows: “Income from any activities under this chapter, including interest on loan guarantees made under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s682"},"text":"section 682 of this title","children":[],"tail":", income and gains realized from investments under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s684"},"text":"section 684 of this title","children":[],"tail":", and any return of capital invested as part of such investments.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s221/a/6/B"},"text":"Pub. L. 111–281, § 221(a)(6)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/330"},"text":"Pub. L. 111–330","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “In such amounts as provided in appropriation Acts and except as provided in subsection (d), the Secretary may use amounts in the Coast Guard Housing Fund to carry out activities under this chapter with respect to military family and military unaccompanied housing units, including activities required in connection with the planning, execution, and administration of contracts entered into under the authority of this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s221/a/6/C"},"text":"Pub. L. 111–281, § 221(a)(6)(C)","children":[],"tail":", struck out “or (b)(3)” after “subsection (b)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s221/a/6/D"},"text":"Pub. L. 111–281, § 221(a)(6)(D)","children":[],"tail":", struck out subsecs. (f) and (g) which related to limitation on amount of budget authority and demonstration projects authorized, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/s207/d/1"},"text":"Pub. L. 108–293, § 207(d)(1)","children":[],"tail":", substituted “Projects” for “Project” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/s207/2"},"text":"Pub. L. 108–293, § 207(2)","children":[],"tail":", (3), substituted “demonstration projects” for “a demonstration project” and “Kodiak, Alaska, or any other Coast Guard installation in Alaska;” for “Kodiak, Alaska;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/s207/d/4"},"text":"Pub. L. 108–293, § 207(d)(4)","children":[],"tail":", substituted “such a demonstration project” for “the demonstration project”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/s207/d/5"},"text":"Pub. L. 108–293, § 207(d)(5)","children":[],"tail":", substituted “such demonstration projects” for “the demonstration project”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/s402/b"},"text":"Pub. L. 107–295, § 402(b)","children":[],"tail":", substituted “$40,000,000” for “$20,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/s402/c"},"text":"Pub. L. 107–295, § 402(c)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56d38ed2-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id56d38ed3-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/330/s1"},"text":"Pub. L. 111–330, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3569"},"text":"124 Stat. 3569","children":[],"tail":", provided that the amendment made by section 1(2) is effective with the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id56d38ed4-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56d38ed5-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amounts Credited to Coast Guard Housing Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/93/dD/tII/s232"},"text":"Pub. L. 116–93, div. D, title II, § 232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2517"},"text":"133 Stat. 2517","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/93/dD/tII/s232"},"text":"“Beginning in fiscal year 2021 and for each fiscal year thereafter, amounts credited to the Coast Guard Housing Fund pursuant to paragraphs (3) through (5) of subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2946"},"text":"section 2946 of title 14","children":[],"tail":", United States Code, shall be classified as discretionary offsetting receipts.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
