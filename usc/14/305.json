{"tag":"section","attrib":{"id":"id56828801-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305"},"text":null,"children":[{"tag":"num","attrib":{"value":"305"},"text":"§ 305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vice admirals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56828802-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56828803-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56828804-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" designate, within the Coast Guard, no more than five positions of importance and responsibility that shall be held by officers who, while so serving—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56828805-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have the grade of vice admiral, with the pay and allowances of that grade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56828806-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall perform such duties as the Commandant may prescribe, except that if the President designates five such positions, one position shall oversee personnel management, workforce, and dependent support, training, and related matters; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56828807-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate, within the executive branch, other than within the Coast Guard or the National Oceanic and Atmospheric Administration, positions of importance and responsibility that shall be held by officers who, while so serving, shall have the grade of vice admiral, with the pay and allowances of that grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56828808-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may appoint, by and with the advice and consent of the Senate, and reappoint, by and with the advice and consent of the Senate, to any such position an officer of the Coast Guard who is serving on active duty above the grade of captain. The Commandant shall make recommendations for such appointments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56828809-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5682880a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), one of the vice admirals designated under paragraph (1)(A) must have at least 10 years experience in vessel inspection, marine casualty investigations, mariner licensing, or an equivalent technical expertise in the design and construction of commercial vessels, with at least 4 years of leadership experience at a staff or unit carrying out marine safety functions and shall serve as the principal advisor to the Commandant on these issues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5682880b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirements of subparagraph (A) do not apply to such vice admiral if the subordinate officer serving in the grade of rear admiral with responsibilities for marine safety, security, and stewardship possesses that experience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5682880c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prior to making a recommendation to the President for the nomination of an officer for appointment to a position of importance and responsibility under this section, which appointment would result in the initial appointment of the officer concerned in the grade of vice admiral, the Commandant shall consider all officers determined to be among the best qualified for such position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5682880d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5682880e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The appointment and the grade of vice admiral shall be effective on the date the officer assumes that duty and, except as provided in paragraph (2) of this subsection or in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s306/d"},"text":"section 306(d) of this title","children":[],"tail":", shall terminate on the date the officer is detached from that duty."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5682880f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer who is appointed to a position designated under subsection (a) shall continue to hold the grade of vice admiral—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56828810-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while under orders transferring the officer to another position designated under subsection (a), beginning on the date the officer is detached from that duty and terminating on the date before the day the officer assumes the subsequent duty, but not for more than 60 days;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56828811-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while hospitalized, beginning on the day of the hospitalization and ending on the day the officer is discharged from the hospital, but not for more than 180 days;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56828812-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the discretion of the Secretary, while awaiting orders after being relieved from the position, beginning on the day the officer is relieved from the position, but not for more than 60 days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56828813-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while awaiting retirement, beginning on the date the officer is detached from duty and ending on the day before the officer’s retirement, but not for more than 60 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56828814-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56828815-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An appointment of an officer under subsection (a) does not vacate the permanent grade held by the officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56828816-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer serving in a grade above rear admiral who holds the permanent grade of rear admiral (lower half) shall be considered for promotion to the permanent grade of rear admiral as if the officer was serving in the officer’s permanent grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56828817-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s305/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever a vacancy occurs in a position designated under subsection (a), the Commandant shall inform the President of the qualifications needed by an officer serving in that position or office to carry out effectively the duties and responsibilities of that position or office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56828818-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/451/s1/5"},"text":"Pub. L. 92–451, § 1(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-02"},"text":"Oct. 2, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/755"},"text":"86 Stat. 755","children":[],"tail":", § 50; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/206/tII/s204/c"},"text":"Pub. L. 103–206, title II, § 204(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2421"},"text":"107 Stat. 2421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tV/s511/a"},"text":"Pub. L. 111–281, title V, § 511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2951"},"text":"124 Stat. 2951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/330/s1/5"},"text":"Pub. L. 111–330, § 1(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3569"},"text":"124 Stat. 3569","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s202"},"text":"Pub. L. 114–120, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/33"},"text":"130 Stat. 33","children":[],"tail":"; renumbered § 305 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 104(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4196"},"text":"132 Stat. 4196","children":[],"tail":", 4240; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tV/s551/b/2"},"text":"Pub. L. 116–283, div. A, title V, § 551(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3630"},"text":"134 Stat. 3630","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII"},"text":"Pub. L. 119–60, div. G, title LXXII","children":[],"tail":", §§ 7201(b), (e)(3), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1675"},"text":"139 Stat. 1675","children":[],"tail":", 1678.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56828819-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5682881a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5682881b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 305, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"act Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/518"},"text":"63 Stat. 518","children":[],"tail":", provided for voluntary retirement after twenty years’ service, with retired pay of grade with which retired, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1954-05-29/ch249/s20"},"text":"act May 29, 1954, ch. 249, § 20","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"ref","attrib":{"href":"/us/stat/68/167"},"text":"68 Stat. 167","children":[],"tail":", and by "},{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/A"},"text":"Pub. L. 88–130, § 1(10)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/177"},"text":"77 Stat. 177","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5682881c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/b"},"text":"Pub. L. 119–60, § 7201(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s305"},"text":"section 305 of this title","children":[],"tail":" as this section, resulting in no change."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/e/3/A"},"text":"Pub. L. 119–60, § 7201(e)(3)(A)","children":[],"tail":", substituted “shall” for “may” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/e/3/B"},"text":"Pub. L. 119–60, § 7201(e)(3)(B)","children":[],"tail":", which directed substitution of “oversee personnel management, workforce, and dependent support, training, and related matters” for “be the chief of staff of the Coast Guard”, was executed by making the substitution for “be the Chief of Staff of the Coast Guard”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s104/b"},"text":"Pub. L. 115–282, § 104(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s50"},"text":"section 50 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 306(d)” for “section 51(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s202/1/A"},"text":"Pub. L. 114–120, § 202(1)(A)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “The President may designate no more than 4 positions of importance and responsibility that shall be held by officers who—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) while so serving, shall have the grade of vice admiral, with the pay and allowances of that grade; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) shall perform such duties as the Commandant may prescribe.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s202/1/B"},"text":"Pub. L. 114–120, § 202(1)(B)","children":[],"tail":", substituted “under paragraph (1)(A)” for “under paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s202/2"},"text":"Pub. L. 114–120, § 202(2)","children":[],"tail":", added subpar. (C) and redesignated former subpar. (C) as (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s511/a"},"text":"Pub. L. 111–281, § 511(a)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/330"},"text":"Pub. L. 111–330","children":[],"tail":", amended section generally. Prior to amendment, section provided for the appointment of a Commander, Atlantic Area, and a Commander, Pacific Area, each having the grade of vice admiral with pay and allowances of that grade."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206"},"text":"Pub. L. 103–206","children":[],"tail":" substituted “The appointment and grade of an area commander shall be effective on the date the officer assumes that duty, and shall terminate on the date the officer is detached from that duty, except as provided in sub"},{"tag":"ref","attrib":{"href":"/us/usc/t14/s51/d"},"text":"section 51(d) of this title","children":[],"tail":".” for “The appointment of an area commander is effective on the date the officer assumes that duty, and terminates on the date he is detached from that duty.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5684f91d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5684f91e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/330/s1"},"text":"Pub. L. 111–330, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3569"},"text":"124 Stat. 3569","children":[],"tail":", provided that the amendment made by section 1(5) is effective with the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5684f91f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1972-10-02"},"text":"Oct. 2, 1972","children":[],"tail":", except that continuation boards may not be held until one year there­after, see "},{"tag":"ref","attrib":{"href":"/us/pl/92/451/s3"},"text":"section 3 of Pub. L. 92–451","children":[],"tail":", set out as an Effective Date of 1972 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2151"},"text":"section 2151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5684f920-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Treatment of Incumbents; Transition","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tV/s511/h/1"},"text":"Pub. L. 111–281, title V, § 511(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2953"},"text":"124 Stat. 2953","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/281/tV/s511/h/1"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“Notwithstanding any other provision of law, an officer who, on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":"], is serving as Chief of Staff, Commander, Atlantic Area, or Commander, Pacific Area—"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall continue to have the grade of vice admiral with pay and allowance of that grade until such time that the officer is relieved of his duties and appointed and confirmed to another position as a vice admiral or admiral; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purposes of transition, may continue at the grade of vice admiral with pay and allowance of that grade, for not more than 1 year after the date of enactment of this Act, to perform the duties of the officer’s former position and any other such duties that the Commandant prescribes.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
