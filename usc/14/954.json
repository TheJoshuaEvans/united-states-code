{"tag":"section","attrib":{"id":"id56a63d16-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s954"},"text":null,"children":[{"tag":"num","attrib":{"value":"954"},"text":"§ 954.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mixed-funded athletic and recreational extracurricular programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a63d17-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s954/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a Coast Guard Academy mixed-funded athletic or recreational extracurricular program, the Commandant may designate funds appropriated to the Coast Guard and available for that program to be treated as nonappropriated funds and expended for that program in accordance with laws applicable to the expenditure of nonappropriated funds. Appropriated funds so designated shall be considered to be nonappropriated funds for all purposes and shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63d18-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s954/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “Coast Guard Academy mixed-funded athletic or recreational extracurricular program” means an athletic or recreational extracurricular program of the Coast Guard Academy to which each of the following applies:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63d19-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s954/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program is not considered a morale, welfare, or recreation program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63d1a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s954/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program is supported through appropriated funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63d1b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s954/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program is supported by a nonappropriated fund instrumentality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63d1c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s954/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program is not a private organization and is not operated by a private organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a63d1d-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXII/s11250/a"},"text":"Pub. L. 117–263, div. K, title CXII, § 11250(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4051"},"text":"136 Stat. 4051","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
