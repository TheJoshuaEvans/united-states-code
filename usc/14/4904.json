{"tag":"section","attrib":{"id":"id56dd2b83-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4904"},"text":null,"children":[{"tag":"num","attrib":{"value":"4904"},"text":"§ 4904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized levels of military strength and training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56dd2b84-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Active Duty Strength","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Coast Guard is authorized an end-of-year strength for active duty personnel of 50,000 for fiscal years 2026, and 55,000 for fiscal year 2027.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56dd2b85-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Training Student Loads","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Coast Guard is authorized average military training student loads as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56dd2b86-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For recruit and special training, 4,000 student years for each of fiscal years 2026 and 2027.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2b87-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For flight training, 250 student years for each of fiscal years 2026 and 2027.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2b88-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4904/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For professional training in military and civilian institutions, 700 student years for each of fiscal years 2026 and 2027.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dd2b89-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4904/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For officer acquisition, 1,600 student years for each of fiscal years 2026 and 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56dd2b8a-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tI/s101/a"},"text":"Pub. L. 114–120, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/29"},"text":"130 Stat. 29","children":[],"tail":", § 2704; renumbered § 4904 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s121/b"},"text":"Pub. L. 115–282, title I, § 121(b)","children":[],"tail":", title II, § 203, "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4238"},"text":"132 Stat. 4238","children":[],"tail":", 4242; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXI"},"text":"Pub. L. 116–283, div. G, title LVXXXI","children":[],"tail":" [LXXXI], § 8102, "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4634"},"text":"134 Stat. 4634","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXI/s11102"},"text":"Pub. L. 117–263, div. K, title CXI, § 11102","children":[],"tail":", title CXIV, § 11413(c), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4004"},"text":"136 Stat. 4004","children":[],"tail":", 4120; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXI/s7102/a"},"text":"Pub. L. 119–60, div. G, title LXXI, § 7102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1663"},"text":"139 Stat. 1663","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56dd2b8b-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56dd2b8c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56dd2b8d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7102/a/1"},"text":"Pub. L. 119–60, § 7102(a)(1)","children":[],"tail":", substituted “50,000 for fiscal years 2026, and 55,000 for fiscal year 2027” for “44,500 for each of fiscal years 2022 and 2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7102/a/2/A"},"text":"Pub. L. 119–60, § 7102(a)(2)(A)","children":[],"tail":", struck out “for each of fiscal years 2022 and 2023” after “average military training student loads” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7102/a/2/B"},"text":"Pub. L. 119–60, § 7102(a)(2)(B)","children":[],"tail":", substituted “4,000 student years for each of fiscal years 2026 and 2027” for “2,500 student years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7102/a/2/C"},"text":"Pub. L. 119–60, § 7102(a)(2)(C)","children":[],"tail":", substituted “250 student years for each of fiscal years 2026 and 2027” for “165 student years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7102/a/2/D"},"text":"Pub. L. 119–60, § 7102(a)(2)(D)","children":[],"tail":", substituted “700 student years for each of fiscal years 2026 and 2027” for “385 student years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7102/a/2/E"},"text":"Pub. L. 119–60, § 7102(a)(2)(E)","children":[],"tail":", substituted “1,600 student years for each of fiscal years 2026 and 2027” for “1,200 student years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11102/1"},"text":"Pub. L. 117–263, § 11102(1)","children":[],"tail":", substituted “fiscal years 2022 and 2023” for “fiscal years 2020 and 2021”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11102/2"},"text":"Pub. L. 117–263, § 11102(2)","children":[],"tail":", substituted “fiscal years 2022 and 2023” for “fiscal years 2020 and 2021”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11413/c"},"text":"Pub. L. 117–263, § 11413(c)","children":[],"tail":", substituted “385” for “350”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8102/1"},"text":"Pub. L. 116–283, § 8102(1)","children":[],"tail":", substituted “44,500 for each of fiscal years 2020 and 2021” for “43,000 for fiscal year 2018 and 44,500 for fiscal year 2019”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8102/2"},"text":"Pub. L. 116–283, § 8102(2)","children":[],"tail":", substituted “fiscal years 2020 and 2021” for “fiscal years 2018 and 2019” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2704"},"text":"section 2704 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s203/1"},"text":"Pub. L. 115–282, § 203(1)","children":[],"tail":", substituted “for fiscal year 2018 and 44,500 for fiscal year 2019” for “for each of fiscal years 2016 and 2017”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s203/2"},"text":"Pub. L. 115–282, § 203(2)","children":[],"tail":", substituted “fiscal years 2018 and 2019” for “fiscal years 2016 and 2017” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56dd2b8e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56dd2b8f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reporting Requirement","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXI/s7102/b"},"text":"Pub. L. 119–60, div. G, title LXXI, § 7102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1664"},"text":"139 Stat. 1664","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dG/tLXXI/s7102/b"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“In any fiscal year in which the submission required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", United States Code, does not include a proportional increase in the Operations and Support funding under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s4902/1/A"},"text":"section 4902(1)(A) of title 14","children":[],"tail":", United States Code, to support the end strengths authorized under the amendments made by subsection (a) [amending this section]—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Commandant [of the Coast Guard] shall provide to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a report on the plan of the Coast Guard to achieve growth in the Coast Guard’s military strength to 60,000, which shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposed missions and purposes for the growth of the Coast Guard in military strength;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each fiscal year from 2027 through 2032—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the additional estimated cost of salaries and all benefits, including housing, education, and medical benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimated recruiting and training resources and costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimated resources and costs required to achieve sufficient training capacity for growth in enlisted and officer corps; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation for why the estimated cost in subparagraph (B) was not included in the submission required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commandant [of the Coast Guard] may not delegate the briefing required in paragraph (1).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
