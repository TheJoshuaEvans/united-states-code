{"tag":"section","attrib":{"id":"id56ced367-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2773"},"text":null,"children":[{"tag":"num","attrib":{"value":"2773"},"text":"§ 2773.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rations or commutation therefor in money","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56ced368-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2773/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enlisted members of the Coast Guard, civilian officers and civilian crews of vessels, and working parties in the field shall be allowed a ration or commutation thereof in money, in such amount and under limitations and regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ced369-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2773/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Money for commuted rations shall be paid, under such regulations as the Secretary shall prescribe, on proper vouchers, or pay rolls, to individuals entitled to receive it, or to the officers designated by the Commandant to administer the financial affairs of the messes in which such individuals may be subsisted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ced36a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2773/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Money paid for commuted rations to the designated officer may be deposited in general or limited depositories of public money or in any bank in which deposits are insured. Such funds shall be expended and accounted for under such regulations as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ced36b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2773/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing contained in this section shall be construed as modifying or changing in any manner the provisions of law pertaining to subsistence allowances for enlisted members, but no ration or commutation thereof shall be allowed an individual receiving a subsistence allowance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ced36c-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/532"},"text":"63 Stat. 532","children":[],"tail":", § 478; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/3/B"},"text":"Pub. L. 98–557, § 15(a)(3)(B)","children":[],"tail":", (C), "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":"; renumbered § 2773, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(42), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4750"},"text":"134 Stat. 4750","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ced36d-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56ced36e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., §§ 134, 135 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-03-25/ch71"},"text":"Mar. 25, 1940, ch. 71","children":[],"tail":", title I, "},{"tag":"ref","attrib":{"href":"/us/stat/54/64"},"text":"54 Stat. 64","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1940-06-06/ch257/s10"},"text":"June 6, 1940, ch. 257, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/248"},"text":"54 Stat. 248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1941-05-31/ch156"},"text":"May 31, 1941, ch. 156","children":[],"tail":", title I, § 1, "},{"tag":"ref","attrib":{"href":"/us/stat/55/221"},"text":"55 Stat. 221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-02-07/ch46"},"text":"Feb. 7, 1942, ch. 46","children":[],"tail":", title I, "},{"tag":"ref","attrib":{"href":"/us/stat/56/71"},"text":"56 Stat. 71","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1943-06-26/ch147/s1"},"text":"June 26, 1943, ch. 147, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/211"},"text":"57 Stat. 211","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1944-06-22/ch269/s1"},"text":"June 22, 1944, ch. 269, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/316"},"text":"58 Stat. 316","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1945-05-29/ch130/s1"},"text":"May 29, 1945, ch. 130, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/216"},"text":"59 Stat. 216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-07-12/ch569/s1"},"text":"July 12, 1946, ch. 569, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/531"},"text":"60 Stat. 531","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch756/s31"},"text":"Aug. 2, 1946, ch. 756, § 31","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/857"},"text":"60 Stat. 857","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-01/ch186"},"text":"July 1, 1947, ch. 186","children":[],"tail":", title I, § 101, "},{"tag":"ref","attrib":{"href":"/us/stat/61/226"},"text":"61 Stat. 226","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provisions of said section 134 are extended to include all persons who might be entitled to receive money for commuted rations, rather than only the officer in charge of the mess.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The last proviso of said section 135 is eliminated, because experience during the past 2 years shows that it may react detrimentally on enlisted men in time of rising food costs.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ced36f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ced370-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8505/a/42/A"},"text":"Pub. L. 116–283, § 8505(a)(42)(A)","children":[],"tail":", substituted “individuals” for “persons” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8505/a/42/B"},"text":"Pub. L. 116–283, § 8505(a)(42)(B)","children":[],"tail":", substituted “an individual” for “a person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s478"},"text":"section 478 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsecs. (a), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted reference to enlisted members for reference to enlisted men."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
