{"tag":"section","attrib":{"id":"id56ab1f67-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135"},"text":null,"children":[{"tag":"num","attrib":{"value":"1135"},"text":"§ 1135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition program baseline breach","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56ab1f68-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall submit a report to the appropriate congressional committees and the Committee on Homeland Security of the House of Representatives as soon as possible, but not later than 30 days, after the Chief Acquisition Officer of the Coast Guard becomes aware of the breach of an acquisition program baseline for any Level 1 or Level 2 acquisition program, by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ab1f69-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a likely cost overrun greater than 15 percent of the acquisition program baseline for that individual capability or asset or a class of capabilities or assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f6a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a likely delay of more than 180 days in the delivery schedule for any individual capability or asset or class of capabilities or assets; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f6b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an anticipated failure for any individual capability or asset or class of capabilities or assets to satisfy any key performance threshold or parameter under the acquisition program baseline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ab1f6c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report submitted under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ab1f6d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of the breach and an explanation of its cause;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f6e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected impact to performance, cost, and schedule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f6f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an updated acquisition program baseline and the complete history of changes to the original acquisition program baseline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f70-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the updated acquisition schedule and the complete history of changes to the original schedule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f71-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a full life-cycle cost analysis for the capability or asset or class of capabilities or assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f72-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a remediation plan identifying corrective actions and any resulting issues or risks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f73-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how progress in the remediation plan will be measured and monitored.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ab1f74-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Substantial Variances in Costs or Schedule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a likely cost overrun is greater than 20 percent or a likely delay is greater than 12 months from the costs and schedule described in the acquisition program baseline for any Level 1 or Level 2 acquisition project or program of the Coast Guard, the Commandant shall include in the report a written determination, with a supporting explanation, of whether—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ab1f75-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capability or asset or capability or asset class to be acquired under the project or program is essential to the accomplishment of Coast Guard missions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f76-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are no alternatives to such capability or asset or capability or asset class that will provide equal or greater capability in both a more cost-effective and timely manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f77-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the new acquisition schedule and estimates for total acquisition cost are reasonable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f78-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management structure for the acquisition program is adequate to manage and control performance, cost, and schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ab1f79-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Congress With Respect to Breach of Contract","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 48 hours after the Commandant becomes aware that a major acquisition contract cannot be carried out under the terms specified in the contract, the Commandant shall provide a written notification to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ab1f7a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the terms of the contract that cannot be met; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f7b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1135/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of whether the applicable contract officer has issued a cease and desist order to the contractor based on the breach of such terms of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ab1f7c-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIV/s402/a"},"text":"Pub. L. 111–281, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2947"},"text":"124 Stat. 2947","children":[],"tail":", § 575; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3533/g"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3533(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2321"},"text":"132 Stat. 2321","children":[],"tail":"; renumbered § 1135, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s108/b"},"text":"Pub. L. 115–282, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4208"},"text":"132 Stat. 4208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8221(b), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4657"},"text":"134 Stat. 4657","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ab1f7d-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ab1f7e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ab1f7f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s575"},"text":"section 575 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":", in introductory provisions, substituted “determination, with a supporting explanation, of whether” for “certification, with a supporting explanation, that”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
