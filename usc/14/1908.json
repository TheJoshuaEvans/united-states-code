{"tag":"section","attrib":{"id":"id56b22363-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908"},"text":null,"children":[{"tag":"num","attrib":{"value":"1908"},"text":"§ 1908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for use of Coast Guard Academy facilities and equipment by covered foundations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56b22364-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsections (b) and (c), the Secretary, with the concurrence of the Superintendent of the Coast Guard Academy, may authorize a covered foundation to use, on a reimbursable or nonreimbursable basis as determined by the Secretary, facilities or equipment of the Coast Guard Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b22365-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not authorize any use of facilities or equipment under subsection (a) if such use may jeopardize the health, safety, or well-being of any member of the Coast Guard or cadet of the Coast Guard Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b22366-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may only authorize the use of facilities or equipment under subsection (a) if such use—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b22367-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is without any liability of the United States to the covered foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b22368-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56b22369-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affect the ability of any official or employee of the Coast Guard, or any member of the armed forces, to carry out any responsibility or duty in a fair and objective manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b2236a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compromise the integrity or appearance of integrity of any program of the Coast Guard, or any individual involved in any such program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b2236b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the participation of any cadet of the Coast Guard Academy at an event of the covered foundation, other than participation of such a cadet in an honor guard;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b2236c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with any applicable ethics regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b2236d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been reviewed and approved by an attorney of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b2236e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance of Policies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall issue Coast Guard policies to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b2236f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For any fiscal year in which the Secretary exercises the authority under subsection (a), not later than the last day of such fiscal year, the Commandant shall provide a briefing to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives on the number of events or activities of a covered foundation supported by such exercise of authority during the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b22370-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Foundation Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered foundation” means an organization that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b22371-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a charitable, educational, or civic nonprofit organization under section 501(c)(3) of the Internal Revenue Code of 1986; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b22372-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary determines operates exclusively to support—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56b22373-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruiting activities with respect to the Coast Guard Academy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b22374-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parent or alumni development in support of the Coast Guard Academy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b22375-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic, leadership, or character development of Coast Guard Academy cadets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b22376-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutional development of the Coast Guard Academy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b22377-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1908/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" athletics in support of the Coast Guard Academy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56b22378-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7244/a"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7244(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1729"},"text":"139 Stat. 1729","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56b22379-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56b2237a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56b2237b-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 501(c)(3) of the Internal Revenue Code of 1986, referred to in subsec. (f)(1), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
