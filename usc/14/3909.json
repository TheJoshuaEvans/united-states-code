{"tag":"section","attrib":{"id":"id56daba08-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3909"},"text":null,"children":[{"tag":"num","attrib":{"value":"3909"},"text":"§ 3909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aircraft deemed public aircraft","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"While assigned to authorized Coast Guard duty, any aircraft shall be deemed to be a Coast Guard aircraft, a public vessel of the United States, and a vessel of the Coast Guard within the meaning of sections 937 and 938 of this title and other applicable provisions of law. Subject to the provisions of sections 3904 and 3912 of this title, while assigned to duty, qualified Auxiliary pilots shall be deemed to be Coast Guard pilots.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56daba09-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/556"},"text":"63 Stat. 556","children":[],"tail":", § 828; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tIV/s407"},"text":"Pub. L. 104–324, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3925"},"text":"110 Stat. 3925","children":[],"tail":"; renumbered § 3909 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 119(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4236"},"text":"132 Stat. 4236","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56daba0a-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56daba0b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 266a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-02-19/ch8"},"text":"Feb. 19, 1941, ch. 8","children":[],"tail":", title I, § 7A, as added "},{"tag":"ref","attrib":{"href":"/us/act/1944-09-30/ch453/s4"},"text":"Sept. 30, 1944, ch. 453, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/760"},"text":"58 Stat. 760","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The last clause of said section is eliminated because it might be construed to exempt planes of members from being licensed according to law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56daba0c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56daba0d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “sections 937 and 938” for “sections 646 and 647” and “sections 3904 and 3912” for “sections 823a and 831”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s119/b"},"text":"Pub. L. 115–282, § 119(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s828"},"text":"section 828 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text read as follows: “Any aircraft, while assigned to authorized Coast Guard duty shall be deemed to be a vessel of the Coast Guard within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s646"},"text":"section 646 of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
