{"tag":"section","attrib":{"id":"id56daba4f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4901"},"text":null,"children":[{"tag":"num","attrib":{"value":"4901"},"text":"§ 4901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for prior authorization of appropriations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Amounts may be appropriated to or for the use of the Coast Guard for the following matters only if the amounts have been authorized by law after ","children":[{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56daba50-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the operation and support of the Coast Guard, not otherwise provided for.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56daba51-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the procurement, construction, renovation, and improvement of aids to navigation, shore facilities, vessels, aircraft, and systems, including equipment related thereto, and for maintenance, rehabilitation, lease, and operation of facilities and equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56daba52-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For research and development.","children":[{"tag":"ref","attrib":{"idref":"fn002049"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002049"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should not appear."}],"tail":" of technologies, materials, and human factors directly related to improving the performance of the Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56daba53-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s2/20/A"},"text":"Pub. L. 97–295, § 2(20)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1303"},"text":"96 Stat. 1303","children":[],"tail":", § 662; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/225/tII/s222/c"},"text":"Pub. L. 101–225, title II, § 222(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1919"},"text":"103 Stat. 1919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIV/s442/2"},"text":"Pub. L. 111–259, title IV, § 442(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2733"},"text":"124 Stat. 2733","children":[],"tail":"; renumbered § 2701 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tI/s101/b"},"text":"Pub. L. 114–120, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/30"},"text":"130 Stat. 30","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3538/a"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3538(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2322"},"text":"132 Stat. 2322","children":[],"tail":"; renumbered § 4901 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 121(b), 123(c)(5)(A), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4238"},"text":"132 Stat. 4238","children":[],"tail":", 4241; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8513(a)(5), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4760"},"text":"134 Stat. 4760","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56daba54-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56daba55-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id56daba56-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"662","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"14:656(note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 10, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/406/s5"},"text":"Pub. L. 94–406, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/1236"},"text":"90 Stat. 1236","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “Amounts” is substituted for “funds” for clarity and consistency. Before clause (1), the words “After fiscal year 1977” are omitted as executed. The words “of such funds” are omitted as unnecessary. In clause (2), the words “aids, establishments, vessels, or aircraft” are substituted for “thereto” for clarity. In clause (4), the words “a matter referred to in clauses (1)–(3)” are substituted for “any of the above” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56daba57-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56daba58-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8513/a/5/A"},"text":"Pub. L. 116–283, § 8513(a)(5)(A)","children":[],"tail":", substituted “support” for “maintenance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8513/a/5/B"},"text":"Pub. L. 116–283, § 8513(a)(5)(B)","children":[],"tail":", substituted “procurement” for “acquisition”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8513/a/5/C"},"text":"Pub. L. 116–283, § 8513(a)(5)(C)","children":[],"tail":"–(E), redesignated par. (5) as (3), substituted “research and development.” for “research, development, test, and evaluation”, and struck out former par. (3) which read as follows: “For the Coast Guard Reserve program, including operations and maintenance of the program, personnel and training costs, equipment, and services.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8513/a/5/C"},"text":"Pub. L. 116–283, § 8513(a)(5)(C)","children":[],"tail":", struck out par. (4) which read as follows: “For the environmental compliance and restoration functions of the Coast Guard under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s318"},"text":"section 318 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8513/a/5/D"},"text":"Pub. L. 116–283, § 8513(a)(5)(D)","children":[],"tail":", redesignated par. (5) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8513/a/5/C"},"text":"Pub. L. 116–283, § 8513(a)(5)(C)","children":[],"tail":", struck out par. (6) which read as follows: “For alteration or removal of bridges over navigable waters of the United States constituting obstructions to navigation, and for personnel and administrative costs associated with the Alteration of Bridges Program.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s121/b"},"text":"Pub. L. 115–282, § 121(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2701"},"text":"section 2701 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “aircraft, and systems” for “and aircraft”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/c/5/A"},"text":"Pub. L. 115–282, § 123(c)(5)(A)","children":[],"tail":", substituted “section 318” for “chapter 19”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s101/b/1"},"text":"Pub. L. 114–120, § 101(b)(1)","children":[],"tail":", (2), renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s662"},"text":"section 662 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (1) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s101/b/3"},"text":"Pub. L. 114–120, § 101(b)(3)","children":[],"tail":", added pars. (1) to (6) and struck out former pars. (1) to (5) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) For the operation and maintenance of the Coast Guard.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) For the acquisition, construction, rebuilding, and improvement of aids to navigation, shore or offshore establishments, vessels, or aircraft, including equipment related to the aids, establishments, vessels, or aircraft.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) For altering obstructive bridges.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) For research, development, test, or evaluation related to intelligence systems and capabilities or a matter referred to in clauses (1)–(3).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) For environmental compliance and restoration at Coast Guard facilities.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259"},"text":"Pub. L. 111–259","children":[],"tail":" inserted “intelligence systems and capabilities or” after “related to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/225"},"text":"Pub. L. 101–225","children":[],"tail":" added par. (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
