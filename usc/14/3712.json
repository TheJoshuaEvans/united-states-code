{"tag":"section","attrib":{"id":"id56d5ff72-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3712"},"text":null,"children":[{"tag":"num","attrib":{"value":"3712"},"text":"§ 3712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusiveness of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No member of the Reserve, other than a temporary member, may be a member of another military organization. A temporary member of the Reserve who is a member of another military component shall, if ordered to active duty therein, be disenrolled as a temporary member of the Reserve.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56d5ff73-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1006"},"text":"94 Stat. 1006","children":[],"tail":", § 711; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/136/s6/c/1"},"text":"Pub. L. 97–136, § 6(c)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1706"},"text":"95 Stat. 1706","children":[],"tail":"; renumbered § 3712, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s118/b"},"text":"Pub. L. 115–282, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d5ff74-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"