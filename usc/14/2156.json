{"tag":"section","attrib":{"id":"id56be3194-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2156"},"text":null,"children":[{"tag":"num","attrib":{"value":"2156"},"text":"§ 2156.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferment of retirement or separation for medical reasons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56be3195-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2156/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (b), the Secretary may defer the retirement or separation of a commissioned officer, other than a commissioned warrant officer, if the evaluation of the physical condition of the officer and determination of the officer’s entitlement to retirement or separation for physical disability require hospitalization, medical observation, or other physical disability processing that cannot be completed before the date on which the officer would otherwise be retired or separated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56be3196-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2156/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A deferment under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56be3197-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2156/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may only be made with the consent of the officer involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56be3198-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2156/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary receives written notice from the officer withdrawing that consent, shall end not later than the end of the sixty-day period beginning on the date the Secretary receives that notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56be3199-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557/s17/b/2/A"},"text":"Pub. L. 98–557, § 17(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2867"},"text":"98 Stat. 2867","children":[],"tail":", § 295; renumbered § 2156, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s112/b"},"text":"Pub. L. 115–282, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56be319a-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56be319b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56be319c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s295"},"text":"section 295 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
