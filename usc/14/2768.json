{"tag":"section","attrib":{"id":"id56ced32f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2768"},"text":null,"children":[{"tag":"num","attrib":{"value":"2768"},"text":"§ 2768.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual audit of pay and allowances of members undergoing permanent change of station","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commandant shall conduct each calendar year an audit of member pay and allowances for the members who transferred to new units during such calendar year. The audit for a calendar year shall be completed by the end of the calendar year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56ced330-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s216/a/1"},"text":"Pub. L. 114–120, title II, § 216(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/46"},"text":"130 Stat. 46","children":[],"tail":", § 519; renumbered § 2768, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ced331-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ced332-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ce