{"tag":"section","attrib":{"id":"id569cc739-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s703"},"text":null,"children":[{"tag":"num","attrib":{"value":"703"},"text":"§ 703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treasury Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Commissioned, warrant, and petty officers of the Coast Guard are deemed to be officers of the customs and when so acting shall, insofar as performance of the duties relating to customs laws are concerned, be subject to regulations issued by the Secretary of the Treasury governing officers of the customs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id569cc73a-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/506"},"text":"63 Stat. 506","children":[],"tail":", § 143; renumbered § 703, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s106/b"},"text":"Pub. L. 115–282, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4203"},"text":"132 Stat. 4203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569cc73b-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id569cc73c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 19, U.S.C., 1946 ed., §§ 1401(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), 1709(b) ("},{"tag":"ref","attrib":{"href":"/us/act/1935-08-05/ch435"},"text":"Aug. 5, 1935, ch. 435","children":[],"tail":", title II, § 201, "},{"tag":"ref","attrib":{"href":"/us/stat/49/521"},"text":"49 Stat. 521","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-05/ch438"},"text":"Aug. 5, 1935, ch. 438","children":[],"tail":", title IV, § 401, "},{"tag":"ref","attrib":{"href":"/us/stat/49/529"},"text":"49 Stat. 529","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section will not repeal the sections cited above, but makes further provision that Coast Guard personnel when acting as officers of the customs shall, insofar as enforcing customs laws are concerned, be subject to regulations governing regular officers of the customs. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569cc73d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id569cc73e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 703 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s3703"},"text":"section 3703 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id569cc73f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered sction 143 of this title as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
