{"tag":"section","attrib":{"id":"id56df7538-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5109"},"text":null,"children":[{"tag":"num","attrib":{"value":"5109"},"text":"§ 5109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on gender diversity in the Coast Guard","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56df7539-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2022-01-15"},"text":"January 15, 2022","children":[],"tail":", and biennially thereafter, the Commandant shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a report on gender diversity in the Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56df753a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under subsection (a) shall contain the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56df753b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5109/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gender diversity overview","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An overview of Coast Guard active duty and reserve members, including the number of officers and enlisted members and the percentages of men and women in each.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df753c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5109/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recruitment and retention.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56df753d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5109/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An analysis of the changes in the recruitment and retention of women over the previous 2 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df753e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5109/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A discussion of any changes to Coast Guard recruitment and retention over the previous 2 years that were aimed at increasing the recruitment and retention of female members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df753f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5109/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Parental leave.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56df7540-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5109/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of men and women who took parental leave during each year covered by the report, including the average length of such leave periods.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df7541-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5109/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A discussion of the ways in which the Coast Guard worked to mitigate the impacts of parental leave on Coast Guard operations and on the careers of the members taking such leave.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df7542-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5109/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An analysis of current gender-based limitations on Coast Guard career opportunities, including discussion of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56df7543-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5109/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shipboard opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df7544-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5109/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities to serve at remote units; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df7545-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5109/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other limitations on the opportunities of female members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df7546-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5109/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Progress update","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An update on the Coast Guard’s progress on the implementation of the action plan required under subsection (a) of section 8215 of the Elijah E. Cummings Coast Guard Authorization Act of 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56df7547-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8215(d)(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4652"},"text":"134 Stat. 4652","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56df7548-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56df7549-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56df754a-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (a) of section 8215 of the Elijah E. Cummings Coast Guard Authorization Act of 2020, referred to in subsec. (b)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8215/a"},"text":"section 8215(a) of Pub. L. 116–283","children":[],"tail":", div. G, title LVXXXII [LXXXII], "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4650"},"text":"134 Stat. 4650","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s504"},"text":"section 504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
