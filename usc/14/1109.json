{"tag":"section","attrib":{"id":"id56a8adae-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109"},"text":null,"children":[{"tag":"num","attrib":{"value":"1109"},"text":"§ 1109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Undefinitized contractual actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a8adaf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Coast Guard may not enter into an undefinitized contractual action unless such action is directly approved by the Head of Contracting Activity of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8adb0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requests for Undefinitized Contractual Actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any request to the Head of Contracting Activity for approval of an undefinitized contractual action shall include a description of the anticipated effect on requirements of the Coast Guard if a delay is incurred for the purposes of determining contractual terms, specifications, and price before performance is begun under the contractual action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8adb1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Undefinitized Contractual Actions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8adb2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for agreement on terms, specifications, and price","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contracting officer of the Coast Guard may not enter into an undefinitized contractual action unless the contractual action provides for agreement upon contractual terms, specification, and price by the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a8adb3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the end of the 180-day period beginning on the date on which the contractor submits a qualifying proposal to definitize the contractual terms, specifications, and price; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a8adb4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the amount of funds obligated under the contractual action is equal to more than 50 percent of the negotiated overall ceiling price for the contractual action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8adb5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on obligations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a8adb6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), the contracting officer for an undefinitized contractual action may not obligate under such contractual action an amount that exceeds 50 percent of the negotiated overall ceiling price until the contractual terms, specifications, and price are definitized for such contractual action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a8adb7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subparagraph (A), if a contractor submits a qualifying proposal to definitize an undefinitized contractual action before an amount that exceeds 50 percent of the negotiated overall ceiling price is obligated on such action, the contracting officer for such action may not obligate with respect to such contractual action an amount that exceeds 75 percent of the negotiated overall ceiling price until the contractual terms, specifications, and price are definitized for such contractual action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8adb8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant may waive the application of this subsection with respect to a contract if the Commandant determines that the waiver is necessary to support—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a8adb9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contingency operation (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/13"},"text":"section 101(a)(13) of title 10","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a8adba-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operations to prevent or respond to a transportation security incident (as defined in section 70101(6) ","children":[{"tag":"ref","attrib":{"idref":"fn002022"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002022"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 46);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a8adbb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an operation in response to an emergency that poses an unacceptable threat to human health or safety or to the marine environment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a8adbc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an operation in response to a natural disaster or major disaster or emergency designated by the President under the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8adbd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection does not apply to an undefinitized contractual action for the purchase of initial spares.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8adbe-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion of Nonurgent Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Requirements for spare parts and support equipment that are not needed on an urgent basis may not be included in an undefinitized contractual action by the Coast Guard for spare parts and support equipment that are needed on an urgent basis unless the Commandant approves such inclusion as being—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8adbf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" good business practice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8adc0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the best interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8adc1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modification of Scope","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The scope of an undefinitized contractual action under which performance has begun may not be modified unless the Commandant approves such modification as being—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8adc2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" good business practice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8adc3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the best interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8adc4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allowable Profit","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall ensure that the profit allowed on an undefinitized contractual action for which the final price is negotiated after a substantial portion of the performance required is completed reflects—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8adc5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the possible reduced cost risk of the contractor with respect to costs incurred during performance of the contract before the final price is negotiated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8adc6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduced cost risk of the contractor with respect to costs incurred during performance of the remaining portion of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8adc7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8adc8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Undefinitized contractual action.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a8adc9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), the term “undefinitized contractual action” means a new procurement action entered into by the Coast Guard for which the contractual terms, specifications, or price are not agreed upon before performance is begun under the action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a8adca-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “undefinitized contractual action” does not include contractual actions with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56a8adcb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/g/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign military sales;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56a8adcc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/g/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchases in an amount not in excess of the amount of the simplified acquisition threshold; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56a8adcd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/g/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special access programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8adce-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1109/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifying proposal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “qualifying proposal” means a proposal that contains sufficient information to enable complete and meaningful audits of the information contained in the proposal as determined by the contracting officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a8adcf-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIV/s402/a"},"text":"Pub. L. 111–281, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2938"},"text":"124 Stat. 2938","children":[],"tail":", § 567; renumbered § 1109, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s108/b"},"text":"Pub. L. 115–282, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4208"},"text":"132 Stat. 4208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a8add0-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a8add1-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56a8add2-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70101/6"},"text":"Section 70101(6) of title 46","children":[],"tail":", referred to in subsec. (c)(3)(B), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s70101/7"},"text":"section 70101(7) of title 46","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dJ/s1805/b/1"},"text":"Pub. L. 115–254, div. J, § 1805(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3534"},"text":"132 Stat. 3534","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Robert T. Stafford Disaster Relief and Emergency Assistance Act, referred to in subsec. (c)(3)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":", which is classified principally to chapter 68 (§ 5121 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a8add3-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s567"},"text":"section 567 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
