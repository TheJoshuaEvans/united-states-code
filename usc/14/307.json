{"tag":"section","attrib":{"id":"id5684f92f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s307"},"text":null,"children":[{"tag":"num","attrib":{"value":"307"},"text":"§ 307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vice admirals and admirals, continuity of grade","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The continuity of an officer’s precedence on the active duty promotion list, date of rank, grade, pay, and allowances as a vice admiral or admiral shall not be interrupted by the termination of an appointment for the purpose of reappointment to another position as a vice admiral or admiral.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5684f930-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/322/tI/s115/a/1"},"text":"Pub. L. 97–322, title I, § 115(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1585"},"text":"96 Stat. 1585","children":[],"tail":", § 52; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/225/tII/s203/1"},"text":"Pub. L. 101–225, title II, § 203(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1911"},"text":"103 Stat. 1911","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tV/s511/d"},"text":"Pub. L. 111–281, title V, § 511(d)","children":[],"tail":", (f)(2), "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2952"},"text":"124 Stat. 2952","children":[],"tail":", 2953; renumbered § 307, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s104/b"},"text":"Pub. L. 115–282, title I, § 104(b)","children":[],"tail"