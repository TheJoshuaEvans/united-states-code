{"tag":"section","attrib":{"id":"id56c53675-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516"},"text":null,"children":[{"tag":"num","attrib":{"value":"2516"},"text":"§ 2516.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members asserting post-traumatic stress disorder or traumatic brain injury","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56c53676-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Medical Examination Required.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c53677-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that a member of the Coast Guard who has performed Coast Guard operations described in section 102, and who is diagnosed by an appropriate licensed or certified healthcare professional as experiencing post-traumatic stress disorder or traumatic brain injury or who otherwise alleges, based on the service of the member the signs and symptoms of either such a condition, receives a medical examination to evaluate a diagnosis of post-traumatic stress disorder or traumatic brain injury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53678-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mental, behavioral, or emotional disorder","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of the Coast Guard who has been sexually assaulted during the preceding 5-year period and who alleges, based on such sexual assault, the signs and symptoms of a diagnosable mental, behavioral, or emotional disorder described within the most recent edition of the Diagnostic and Statistical Manual of Mental Disorders published by the American Psychiatric Association—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c53679-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is provided the opportunity to request a medical examination to clinically evaluate such signs and symptoms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c5367a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives such a medical examination to evaluate a diagnosis of post-traumatic stress disorder, traumatic brain injury, or diagnosable mental, behavioral, or emotional disorder described within the most recent edition of the Diagnostic and Statistical Manual of Mental Disorders published by the American Psychiatric Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c5367b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction on administrative separation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member described in this subsection shall not be administratively separated under conditions other than honorable, including an administrative separation in lieu of a court-martial, until the results of the medical examination have been reviewed by appropriate authorities responsible for evaluating, reviewing, and approving the separation case, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c5367c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Post-traumatic stress disorder","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a case involving post-traumatic stress disorder or a diagnosable mental, behavioral, or emotional disorder under this subsection, a medical examination shall be performed by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c5367d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a board-certified psychiatrist;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c5367e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a licensed doctorate-level psychologist;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c5367f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other appropriate licensed or certified healthcare professional designated by the Commandant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c53680-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a psychiatry resident or board-eligible psychologist who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56c53681-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/a/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed a 1-year internship or residency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c53682-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/a/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is under the close supervision of a board-certified psychiatrist or licensed doctorate-level psychologist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53683-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Traumatic brain injury","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a case involving traumatic brain injury under this subsection, a medical examination shall be performed by a physiatrist, psychiatrist, neurosurgeon, or neurologist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c53684-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose of Medical Examination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The medical examination required under subsection (a) shall assess whether the effects of mental or neurocognitive disorders, including post-traumatic stress disorder and traumatic brain injury or a diagnosable mental, behavioral, or emotional disorder, constitute matters in extenuation that relate to the basis for administrative separation under conditions other than honorable or the overall characterization of the service of the member as other than honorable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c53685-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Proceedings Under Uniform Code of Military Justice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The medical examination and procedures required by this section do not apply to courts-martial or other proceedings conducted pursuant to the Uniform Code of Military Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"status":"repealed","id":"id56c53686-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"[(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7201/k/1/B"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7201(k)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1687"},"text":"139 Stat. 1687","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c53687-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Right to Request Medical Examination.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c53688-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any member of the Coast Guard who receives a notice of involuntary administrative separation shall be advised at the time of such notice of the right of the member to request a medical examination under subsection (a) if any condition described in such subsection applies to the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53689-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c5368a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and issue a clear policy for carrying out the notification required under paragraph (1) with respect to any member of the Coast Guard described in that paragraph who has made an unrestricted report of sexual assault; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c5368b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2516/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information on such policy to sexual assault response coordinators of the Coast Guard for the purpose of ensuring that such policy is communicated to members of the Coast Guard who may be eligible for a medical examination under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56c5368c-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIV/s11410/a"},"text":"Pub. L. 117–263, div. K, title CXIV, § 11410(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4116"},"text":"136 Stat. 4116","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII"},"text":"Pub. L. 119–60, div. G, title LXXII","children":[],"tail":", §§ 7201(k)(1), 7227, "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1687"},"text":"139 Stat. 1687","children":[],"tail":", 1705.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c5368d-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c5368e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7227/1/A"},"text":"Pub. L. 119–60, § 7227(1)(A)","children":[],"tail":", struck out “or has been sexually assaulted during the preceding 2-year period” after “Coast Guard operations described in section 102” and substituted “the signs and symptoms of either” for “or based on such sexual assault, the influence of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/k/1/A"},"text":"Pub. L. 119–60, § 7201(k)(1)(A)","children":[],"tail":", inserted “described in section 102” after “Coast Guard operations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7227/1/C"},"text":"Pub. L. 119–60, § 7227(1)(C)","children":[],"tail":", added par. (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7227/1/B"},"text":"Pub. L. 119–60, § 7227(1)(B)","children":[],"tail":", (D), redesignated par. (2) as (3) and substituted “this subsection” for “paragraph (1)”. Former par. (3) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7227/1/B"},"text":"Pub. L. 119–60, § 7227(1)(B)","children":[],"tail":", (E)(i), (ii), redesignated par. (3) as (4) and inserted “or a diagnosable mental, behavioral, or emotional disorder” before “under this subsection” and “performed by” after “shall be” in introductory provisions. Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(A) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7227/1/E/iii"},"text":"Pub. L. 119–60, § 7227(1)(E)(iii)","children":[],"tail":", added subpars. (A) to (D) and struck out former subpars. (A) and (B) which read as follows:"},{"tag":"quotedContent","attrib":{},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" performed by—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a board-certified or board-eligible psychiatrist; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a licensed doctorate-level psychologist; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" performed under the close supervision of—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a board-certified or board-eligible psychiatrist; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a licensed doctorate-level psychologist, a doctorate-level mental health provider, a psychiatry resident, or a clinical or counseling psychologist who has completed a 1-year internship or residency.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7227/1/B"},"text":"Pub. L. 119–60, § 7227(1)(B)","children":[],"tail":", redesignated par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7227/2"},"text":"Pub. L. 119–60, § 7227(2)","children":[],"tail":", inserted “or a diagnosable mental, behavioral, or emotional disorder” after “traumatic brain injury”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/k/1/B"},"text":"Pub. L. 119–60, § 7201(k)(1)(B)","children":[],"tail":", struck out subsec. (d). Prior to amendment, text read as follows: "},{"tag":"quotedContent","attrib":{},"text":"“In this section, the term ‘Coast Guard operations’ has the meaning given that term in section 888(a) of the Homeland Security Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s468/a"},"text":"6 U.S.C. 468(a)","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7227/3"},"text":"Pub. L. 119–60, § 7227(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
