{"tag":"section","attrib":{"id":"id56afd9df-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903"},"text":null,"children":[{"tag":"num","attrib":{"value":"1903"},"text":"§ 1903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual Board of Visitors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56afd9e0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Board of Visitors to the Coast Guard Academy is established to review and make recommendations on the operation of the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56afd9e1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56afd9e2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The membership of the Board shall consist of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56afd9e3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chairperson of the Committee on Commerce, Science, and Transportation of the Senate, or a member of such Committee designated by such chairperson.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afd9e4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chairperson of the Committee on Transportation and Infrastructure of the House of Representatives, or a member of such Committee designated by such chairperson.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afd9e5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 Senators appointed by the Vice President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afd9e6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 Members of the House of Representatives appointed by the Speaker of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afd9e7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 Senators appointed by the Vice President, each of whom shall be selected from among members of the Committee on Appropriations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afd9e8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 Members of the House of Representatives appointed by the Speaker of the House of Representatives, each of whom shall be selected from among members of the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afd9e9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 individuals designated by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56afd9ea-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing of appointments of members.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56afd9eb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Senators","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any member of the Board described in paragraph (1)(C) is not appointed by the date that is 180 days after the date on which the first session of each Congress convenes, the chair and ranking member of the subcommittee of the Committee on Commerce, Science, and Transportation of the Senate with jurisdiction over the authorization of appropriations of the Coast Guard shall be members of the Board until the date on which the second session of such Congress adjourns sine die.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afd9ec-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members of the house of representatives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any member of the Board described in paragraph (1)(D) is not appointed by the date that is 180 days after the date on which the first session of each Congress convenes, the chair and ranking member of the subcommittee of the Committee on Transportation and Infrastructure of the House of Representatives with jurisdiction over the authorization of appropriations for the Coast Guard shall be members of the Board until the date on which the second session of such Congress adjourns sine die.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afd9ed-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members of the committee on appropriations of the senate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any member of the Board described in paragraph (1)(E) is not appointed by the date that is 180 days after the date on which the first session of each Congress convenes, the chair and ranking member of the subcommittee of the Committee on Appropriations of the Senate with jurisdiction over appropriations for the Coast Guard shall be members of the Board until the date on which the second session of such Congress adjourns sine die.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afd9ee-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members of the committee on appropriations of the house of representatives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any member of the Board described in paragraph (1)(F) is not appointed by the date that is 180 days after the date on which the first session of each Congress convenes, the chair and ranking member of the subcommittee of the Committee on Appropriations of the House of Representatives with jurisdiction over appropriations for the Coast Guard shall be members of the Board until the date on which the second session of such Congress adjourns sine die.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56afd9ef-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairperson.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56afd9f0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On a biennial basis and subject to paragraph (4), the Board shall select from among the members of the Board a Member of Congress to serve as the Chair of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afd9f1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rotation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Member of the House of Representatives and a Member of the Senate shall alternately be selected as the Chair of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afd9f2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual may not serve as Chairperson of the Board for consecutive terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56afd9f3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Length of service.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56afd9f4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members of congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Member of Congress designated as a member of the Board under paragraph (1) shall be designated as a member in the first session of the applicable Congress and shall serve for the duration of such Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afd9f5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individuals designated by the president","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each individual designated by the President under paragraph (1)(G) shall serve as a member of the Board for 3 years, except that any such member whose term of office has expired shall continue to serve until a successor is appointed by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afd9f6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Death or resignation of a member","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a member of the Board dies or resigns, a successor shall be designated for any unexpired portion of the term of the member by the official who designated the member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56afd9f7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Academy Visits.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56afd9f8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual visit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall invite each member of the Board, and any staff designated under subsection (e)(2)(A), to visit the Coast Guard Academy at least once annually to review the operation of the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56afd9f9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional visits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With the approval of the Secretary, the Board or any members of the Board in connection with the duties of the Board may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56afd9fa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make visits to the Academy in addition to the visits described in paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afd9fb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consult with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56afd9fc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Superintendent of the Academy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56afd9fd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the faculty, staff, or cadets of the Academy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56afd9fe-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall ensure that the Board or any members of the Board who visits the Academy under this paragraph is provided reasonable access to the grounds, facilities, cadets, faculty, staff, and other personnel of the Academy for the purpose of carrying out the duties of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56afd9ff-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall review, with respect to the Academy—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56afda00-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the state of morale and discipline, including with respect to prevention of, response to, and recovery from sexual assault and sexual harassment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56afda01-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment and retention, including diversity, inclusion, and issues regarding women specifically;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56afda02-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the curriculum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56afda03-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56afda04-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical equipment, including infrastructure, living quarters, and deferred maintenance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56afda05-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fiscal affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56afda06-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other matters relating to the Academy that the Board determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56afda07-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Matters.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56afda08-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56afda09-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less frequently than annually, the Board shall meet at a location chosen by the Commandant, in consultation with the Board, to conduct the review required by subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afda0a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairperson and charter","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal officer designated under subsection (g)(1)(B) shall organize a meeting of the Board for the purposes of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56afda0b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selecting a Chairperson of the Board under subsection (b)(3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56afda0c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopting an official charter for the Board, which shall establish the schedule of meetings of the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56afda0d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other matter such designated Federal officer or the Board considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afda0e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scheduling","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In scheduling a meeting of the Board, such designated Federal officer shall coordinate, to the greatest extent practicable, with the members of the Board to determine the date and time of the meeting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afda0f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less than 30 days before each scheduled meeting of the Board, such designated Federal officer shall notify each member of the Board of the time, date, and location of the meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56afda10-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staff.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56afda11-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The chairperson and the ranking member of the Committee on Commerce, Science, and Transportation of the Senate and the chairperson and the ranking member of the Committee on Transportation and Infrastructure of the House of Representatives may each designate 1 staff member of each such Committees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56afda12-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Role","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Staff designated under subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56afda13-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may attend and participate in visits and carry out consultations described under subsection (c)(1) and attend and participate in meetings described under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56b22304-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not otherwise carry out duties or take actions reserved to members of the Board under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b22305-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If approved by the Secretary, the Board may consult with advisors in carrying out the duties of the Board under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b22306-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56b22307-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date on which the Board conducts a meeting of the Board under paragraph (1), the Commandant, in consultation with the Board, shall submit a report on the actions of the Board during the meeting and the recommendations of the Board pertaining to the Academy to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56b22308-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56b22309-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation and the Committee on Armed Services of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56b2230a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Transportation and Infrastructure and the Committee on Armed Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b2230b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report submitted under this paragraph shall be published on a publicly accessible website of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b2230c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant and the Superintendent of the Academy shall ensure candid and complete disclosure to the Board, consistent with applicable laws relating to disclosure of information, with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b2230d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each issue described in subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b2230e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other issue the Board or the Commandant considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b2230f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coast Guard Support.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b22310-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56b22311-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide support to the Board, as Board considers necessary for the performance of the duties of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b22312-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate a Federal officer to support the performance of the duties of the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b22313-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with the Superintendent of the Academy, advise the Board of any institutional issues, consistent with applicable laws concerning the disclosure of information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b22314-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Board and each advisor consulted by the Board under subsection (e)(3) shall be reimbursed, to the extent permitted by law, by the Coast Guard for actual expenses incurred while engaged in duties as a member or advisor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b22315-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1903/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the date on which the first session of each Congress convenes, the Commandant shall provide to the chairperson and ranking member of the Committee on Commerce, Science, and Transportation of the Senate and the chairperson and ranking member of the Committee on Transportation and Infrastructure of the House of Representatives, and the President notification of the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56b22316-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/510"},"text":"63 Stat. 510","children":[],"tail":", § 194; "},{"tag":"ref","attrib":{"href":"/us/pl/101/595/tIII/s304"},"text":"Pub. L. 101–595, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2984"},"text":"104 Stat. 2984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIV/s408/a/1"},"text":"Pub. L. 107–295, title IV, § 408(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2117"},"text":"116 Stat. 2117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s211"},"text":"Pub. L. 113–281, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3027"},"text":"128 Stat. 3027","children":[],"tail":"; renumbered § 1903, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s110/b"},"text":"Pub. L. 115–282, title I, § 110(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4212"},"text":"132 Stat. 4212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8277, "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4687"},"text":"134 Stat. 4687","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tV/s554/d"},"text":"Pub. L. 117–81, div. A, title V, § 554(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1738"},"text":"135 Stat. 1738","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7242"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1723"},"text":"139 Stat. 1723","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56b22317-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56b22318-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 15h (","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-04-16/ch107/s7"},"text":"Apr. 16, 1937, ch. 107, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/67"},"text":"50 Stat. 67","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-07-15/ch288"},"text":"July 15, 1939, ch. 288","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1044"},"text":"53 Stat. 1044","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56b22319-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56b2231a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7242/1"},"text":"Pub. L. 119–60, § 7242(1)","children":[],"tail":", added subsecs. (b) and (c) and struck out former subsecs. (b) and (c) which related to membership and academy visits, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7242/2/A"},"text":"Pub. L. 119–60, § 7242(2)(A)","children":[],"tail":", inserted “ ,including with respect to prevention of, response to, and recovery from sexual assault and sexual harassment” after “discipline”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7242/2/B"},"text":"Pub. L. 119–60, § 7242(2)(B)","children":[],"tail":", inserted “ ,including infrastructure, living quarters, and deferred maintenance” after “equipment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7242/3"},"text":"Pub. L. 119–60, § 7242(3)","children":[],"tail":", added subsecs. (e) to (h) and struck out former subsecs. (e) to (g) which related to report, advisors, and reimbursement, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" substituted “is appointed by the President” for “is appointed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added par. (2) and redesignated former pars. (2) to (6) as (3) to (7), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s194"},"text":"section 194 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281"},"text":"Pub. L. 113–281","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (f) relating to establishment and composition of Board of Visitors, designation of Members, absence of a Member or ex officio Member from an annual meeting, and annual visit to the Academy."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(2), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295"},"text":"Pub. L. 107–295","children":[],"tail":" substituted “Transportation and Infrastructure” for “Merchant Marine and Fisheries”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/595"},"text":"Pub. L. 101–595","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) In addition to the Advisory Committee, there shall be appointed in January of each year a Board of Visitors to the Academy, consisting of two Senators and three members of the House of Representatives, appointed by the chairmen of the committees of the Senate and House of Representatives, respectively, having cognizance of legislation pertaining to the Academy, the chairmen of said committees being ex officio members of the Board, and of one Senator and two members of the House of Representatives appointed by the President of the Senate and the Speaker of the House of Representatives, respectively. Whenever a member or an ex officio member is unable to attend the annual meeting as provided in this section another member may be appointed in his stead in the manner as herein provided but without restriction as to month of appointment.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) Such Board shall visit the Academy annually on a date to be fixed by the Secretary. Each member of the Board shall be reimbursed from Coast Guard appropriations under Government travel regulations for the actual expense incurred by him while engaged in duties as a member of such Board, or such actual expenses as permitted under such regulations shall be defrayed by the Coast Guard.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
