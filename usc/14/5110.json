 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s108/b"},"text":"Pub. L. 115–282, § 108(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s569"},"text":"section 569 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “for fiscal year 2019” for “for fiscal year 2016” and struck out “, on the date on which the President submits to Congress a budget for fiscal year 2019 under such section,” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 5103” for “section 2903”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 5102(a)(1)” for “section 2902(a)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s102/f/1"},"text":"Pub. L. 114–120, § 102(f)(1)","children":[],"tail":", substituted “in section 2903” for “in section 569a(e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s102/f/2"},"text":"Pub. L. 114–120, § 102(f)(2)","children":[],"tail":", substituted “under section 2902(a)(1)” for “under section 663(a)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281"},"text":"Pub. L. 113–281","children":[],"tail":" amended section generally. Prior to amendment, section related to submission of report, not later than "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", to appropriate congressional committees on the employment during the preceding year by Coast Guard contractors of individuals who were Coast Guard officials in the previous 5-year period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213"},"text":"Pub. L. 112–213","children":[],"tail":" struck out “and annually thereafter,” after “"},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":",”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56df7558-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56df7559-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Additional Submissions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tI/s101/f"},"text":"Pub. L. 114–120, title I, § 101(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/32"},"text":"130 Stat. 32","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/120/tI/s101/f"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Commandant of the Coast Guard shall submit to the Committee on Homeland Security of the House of Representatives—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":n