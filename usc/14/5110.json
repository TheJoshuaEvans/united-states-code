{"tag":"section","attrib":{"id":"id56df754b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5110"},"text":null,"children":[{"tag":"num","attrib":{"value":"5110"},"text":"§ 5110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission need statement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56df754c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On the date on which the President submits to Congress a budget for fiscal year 2019 under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" and every 4 years thereafter, the Commandant shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate an integrated major acquisition mission need statement."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56df754d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56df754e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5110/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Integrated major acquisition mission need statement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “integrated major acquisition mission need statement” means a document that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56df754f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5110/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies current and projected gaps in Coast Guard mission capabilities using mission hour targets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df7550-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5110/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explains how each major acquisition program addresses gaps identified under subparagraph (A) if funded at the levels provided for such program in the most recently submitted capital investment plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56df7551-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5110/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the missions the Coast Guard will not be able to achieve, by fiscal year, for each gap identified under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df7552-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5110/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Major acquisition program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “major acquisition program” has the meaning given that term in section 5103.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df7553-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5110/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capital investment plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “capital investment plan” means the plan required under section 5102(a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56df7554-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIV/s402/a"},"text":"Pub. L. 111–281, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2940"},"text":"124 Stat. 2940","children":[],"tail":", § 569; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tII/s217/8"},"text":"Pub. L. 112–213, title II, § 217(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1558"},"text":"126 Stat. 1558","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s215/a"},"text":"Pub. L. 113–281, title II, § 215(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3034"},"text":"128 Stat. 3034","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tI/s102/f"},"text":"Pub. L. 114–120, title I, § 102(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":