{"tag":"section","attrib":{"id":"id56d1448f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2779"},"text":null,"children":[{"tag":"num","attrib":{"value":"2779"},"text":"§ 2779.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation to and from certain places of employment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d14490-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2779/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever the Secretary determines that it is necessary for the effective conduct of the affairs of the Coast Guard, he may, at reasonable rates of fare fixed under regulations to be prescribed by him, provide assured and adequate transportation by motor vehicle or water carrier to and from their places of employment for individuals attached to, or employed by, the Coast Guard; and during a war or during a national emergency declared by Congress or the President, for individuals attached to, or employed in, a private plant that is manufacturing material for the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d14491-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2779/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Transportation may not be provided under subsection (a) unless the Secretary or an officer designated by the Secretary, determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d14492-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2779/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other transportation facilities are inadequate and cannot be made adequate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d14493-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2779/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reasonable effort has been made to induce operators of private facilities to provide the necessary transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d14494-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2779/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the service to be furnished will make proper use of transportation facilities and will supply the most efficient transportation to the individuals concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d14495-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2779/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To provide transportation under subsection (a), the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d14496-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2779/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" buy, lease, or charter motor vehicles or water carriers having a seating capacity of 12 or more passengers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d14497-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2779/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain and operate that equipment by enlisted members or employees of the Coast Guard, or by private individuals under contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d14498-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2779/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lease or charter the equipment to private or public carriers for operation under terms that are considered necessary by the Secretary or by an officer designated by the Secretary, and that may provide for the pooling of government-owned and privately owned equipment and facilities and for the reciprocal use of that equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d14499-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2779/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fares received under subsection (a), and proceeds of the leasing or chartering of equipment under subsection (c)(3), shall be covered into the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d1449a-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/376/s10/a"},"text":"Pub. L. 96–376, § 10(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1510"},"text":"94 Stat. 1510","children":[],"tail":", § 660; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXVI/s1623"},"text":"Pub. L. 99–145, title XVI, § 1623","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/778"},"text":"99 Stat. 778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/550/s2/e"},"text":"Pub. L. 99–550, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3070"},"text":"100 Stat. 3070","children":[],"tail":"; renumbered § 2779, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(46), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4750"},"text":"134 Stat. 4750","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d1449b-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d1449c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d1449d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsecs. (a), (b)(3), (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “individuals” for “persons” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s660"},"text":"section 660 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/550"},"text":"Pub. L. 99–550","children":[],"tail":" struck out subsec. (e) which provided that passenger motor vehicles of the United States could be used to provide transportation between the residence and place of work of the Commandant. See "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1344"},"text":"section 1344 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56d1449e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id56d1449f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXVI/s1623"},"text":"Pub. L. 99–145, title XVI, § 1623","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/778"},"text":"99 Stat. 778","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
