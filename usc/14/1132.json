{"tag":"section","attrib":{"id":"id56a8adfe-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132"},"text":null,"children":[{"tag":"num","attrib":{"value":"1132"},"text":"§ 1132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a8adff-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant may not establish a Level 1 or Level 2 acquisition project or program until the Commandant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8ae00-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clearly defines the operational requirements for the project or program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ae01-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes the feasibility of alternatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ae02-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops an acquisition project or program baseline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ae03-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produces a life-cycle cost estimate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ae04-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses the relative merits of alternatives to determine a preferred solution in accordance with the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8ae05-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission Required Before Proceeding","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any Coast Guard Level 1 or Level 2 acquisition project or program may not begin to obtain any capability or asset or proceed beyond that phase of its development that entails approving the supporting acquisition until the Commandant submits to the appropriate congressional committees the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8ae06-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The key performance parameters, the key system attributes, and the operational performance attributes of the capability or asset to be acquired under the proposed acquisition project or program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ae07-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed list of the systems or other capabilities with which the capability or asset to be acquired is intended to be interoperable, including an explanation of the attributes of interoperability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ae08-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The anticipated acquisition project or program baseline and acquisition unit cost for the capability or asset to be acquired under the project or program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ae09-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed schedule for the acquisition process showing when all capability and asset acquisitions are to be completed and when all acquired capabilities and assets are to be initially and fully deployed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8ae0a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Analysis of Alternatives.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8ae0b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Coast Guard may not acquire an experimental or technically immature capability or asset or implement a Level 1 or Level 2 acquisition project or program, unless it has prepared an analysis of alternatives for the capability or asset to be acquired in the concept and technology development phase of the acquisition process for the capability or asset.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ae0c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The analysis of alternatives shall be prepared by a federally funded research and development center, a qualified entity of the Department of Defense, or a similar independent third-party entity that has appropriate acquisition expertise and has no financial interest in any part of the acquisition project or program that is the subject of the analysis. At a minimum, the analysis of alternatives shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ab1f0d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the technical maturity of the capability or asset, and technical and other risks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f0e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an examination of capability, interoperability, and other advantages and disadvantages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f0f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of whether different combinations or quantities of specific assets or capabilities could meet the Coast Guard’s overall performance needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f10-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discussion of key assumptions and variables, and sensitivity to change in such assumptions and variables;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f11-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when an alternative is an existing capability, asset, or prototype, an evaluation of relevant safety and performance records and costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f12-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a calculation of life-cycle costs including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56ab1f13-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/c/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an examination of likely research and development costs and the levels of uncertainty associated with such estimated costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56ab1f14-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/c/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an examination of likely production and deployment costs and the levels of uncertainty associated with such estimated costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56ab1f15-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/c/2/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an examination of likely operating and support costs and the levels of uncertainty associated with such estimated costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56ab1f16-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/c/2/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if they are likely to be significant, an examination of likely disposal costs and the levels of uncertainty associated with such estimated costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56ab1f17-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/c/2/F/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional measures as the Commandant or the Secretary of the department in which the Coast Guard is operating determines to be necessary for appropriate evaluation of the capability or asset; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f18-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the business case for each viable alternative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ab1f19-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Test and Evaluation Master Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ab1f1a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For any Level 1 or Level 2 acquisition project or program the Chief Acquisition Officer must approve a test and evaluation master plan specific to the acquisition project or program for the capability, asset, or subsystems of the capability or asset and intended to minimize technical, cost, and schedule risk as early as practicable in the development of the project or program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f1b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Test and evaluation strategy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The master plan shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ab1f1c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth an integrated test and evaluation strategy that will verify that capability-level or asset-level and subsystem-level design and development, including performance and supportability, have been sufficiently proven before the capability, asset, or subsystem of the capability or asset is approved for production; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f1d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that adequate developmental tests and evaluations and operational tests and evaluations established under subparagraph (A) are performed to inform production decisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f1e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other components of the master plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At a minimum, the master plan shall identify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ab1f1f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the key performance parameters to be resolved through the integrated test and evaluation strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f20-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance data to be used to determine whether the key performance parameters have been resolved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f21-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" critical operational issues to be assessed in addition to the key performance parameters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f22-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results during test and evaluation that will be required to demonstrate that a capability, asset, or subsystem meets performance requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f23-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific development test and evaluation phases and the scope of each phase;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f24-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modeling and simulation activities to be performed, if any, and the scope of such activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f25-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early operational assessments to be performed, if any, and the scope of such assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f26-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operational test and evaluation phases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f27-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the resources, including funds, that will be required for all test, evaluation, assessment, modeling, and simulation activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f28-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government entity or independent entity that will perform the test, evaluation, assessment, modeling, and simulation activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f29-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Update","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief Acquisition Officer must approve an updated master plan whenever there is a revision to project or program test and evaluation strategy, scope, or phasing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f2a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Coast Guard may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ab1f2b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceed beyond that phase of the acquisition process that entails approving the supporting acquisition of a capability or asset before the master plan is approved by the Chief Acquisition Officer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f2c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award any production contract for a capability, asset, or subsystem for which a master plan is required under this subsection before the master plan is approved by the Chief Acquisition Officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ab1f2d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Life-Cycle Cost Estimates.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ab1f2e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall implement mechanisms to ensure the development and regular updating of life-cycle cost estimates for each acquisition with a total acquisition cost that equals or exceeds $10,000,000 and an expected service life of 10 or more years, and to ensure that these estimates are considered in decisions to develop or produce new or enhanced capabilities and assets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f2f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Types of estimates","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each Level 1 or Level 2 acquisition project or program, in addition to life-cycle cost estimates developed under paragraph (1), the Commandant shall require that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ab1f30-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" life-cycle cost estimates developed under paragraph (1) be updated before—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56ab1f31-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each milestone decision is concluded; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56ab1f32-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project or program enters a new acquisition phase; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f33-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1132/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an independent cost estimate or independent cost assessment, as appropriate, be developed to validate life-cycle cost estimates developed under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ab1f34-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIV/s402/a"},"text":"Pub. L. 111–281, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2942"},"text":"124 Stat. 2942","children":[],"tail":", § 572; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s204/a"},"text":"Pub. L. 114–120, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/34"},"text":"130 Stat. 34","children":[],"tail":"; renumbered § 1132, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s108/b"},"text":"Pub. L. 115–282, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4208"},"text":"132 Stat. 4208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXII/s11210"},"text":"Pub. L. 117–263, div. K, title CXII, § 11210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4012"},"text":"136 Stat. 4012","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ab1f35-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ab1f36-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ab1f37-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (e)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added par. (2) and struck out former pars. (2) and (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Types of estimates","children":[],"tail":".—In addition to life-cycle cost estimates that may be developed by acquisition program offices, the Commandant shall require that an independent life-cycle cost estimate be developed for each Level 1 or Level 2 acquisition project or program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) ","children":[{"tag":"inline","attrib":{},"text":"Required updates","children":[],"tail":".—For each Level 1 or Level 2 acquisition project or program the Commandant shall require that life-cycle cost estimates shall be updated before each milestone decision is concluded and the project or program enters a new acquisition phase.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s572"},"text":"section 572 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (d)(3)(B) to (J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":" added subpars. (B) and (D) and redesignated former subpar. (B) as (C) and former subpars. (C) to (H) as (E) to (J), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
