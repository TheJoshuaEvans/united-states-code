{"tag":"section","attrib":{"id":"id56b70572-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2107"},"text":null,"children":[{"tag":"num","attrib":{"value":"2107"},"text":"§ 2107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection boards; composition of boards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2106"},"text":"section 2106 of this title","children":[],"tail":" shall consist of five or more officers on the active duty promotion list who are serving in or above the grade to which the board may recommend officers for promotion. No officer may be a member of two successive boards convened to consider officers of the same grade for promotion."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56b70573-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/179"},"text":"77 Stat. 179","children":[],"tail":", § 252; renumbered § 2107 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 112(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56b70574-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56b70575-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{