{"tag":"section","attrib":{"id":"id56d38e63-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927"},"text":null,"children":[{"tag":"num","attrib":{"value":"2927"},"text":"§ 2927.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child care subsidy program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d38e64-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d38e65-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant may operate a child care subsidy program to provide financial assistance to eligible providers that provide child care services or youth program services to members of the Coast Guard, members of the Coast Guard with dependents who are participating in the child care subsidy program, and any other individual the Commandant considers appropriate, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56d38e66-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing such financial assistance—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56d38e67-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the best interests of the Coast Guard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56d38e68-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enables supplementation or expansion of the provision of Coast Guard child care services, while not supplanting or replacing Coast Guard child care services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d38e69-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commandant ensures, to the extent practicable, that the eligible provider is able to comply, and does comply, with the regulations, policies, and standards applicable to Coast Guard child care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d38e6a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible providers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A provider of child care services or youth program services is eligible for financial assistance under this section if the provider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56d38e6b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is licensed to provide such services under applicable State and local law or meets all applicable State and local health and safety requirements if licensure is not required;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d38e6c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56d38e6d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is ","children":[{"tag":"ref","attrib":{"idref":"fn002045"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002045"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “is” probably should not appear."}],"tail":" a family home daycare; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56d38e6e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" a provider of family child care services that—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id56d38e6f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise provides federally funded or federally sponsored child development services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id56d38e70-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides such services in a child development center owned and operated by a private, not-for-profit organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id56d38e71-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a before-school or after-school child care program in a public school facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id56d38e72-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/2/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducts an otherwise federally funded or federally sponsored school-age child care or youth services program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id56d38e73-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/2/B/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducts a school-age child care or youth services program operated by a not-for-profit organization; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d38e74-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a provider of another category of child care services or youth program services the Commandant considers appropriate for meeting the needs of members or civilian employees of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d38e75-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial assistance for in-home child care.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56d38e76-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant may provide financial assistance to members of the Coast Guard who pay for services provided by in-home child care providers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d38e77-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out such program, the Commandant shall establish a policy and procedures to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56d38e78-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the needs of families who request services provided by in-home childcare providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56d38e79-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the appropriate amount of financial assistance to provide to families described in paragraph, that is at minimum consistent with the program authorized in subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56d38e7a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure the appropriate qualifications for such in-home child care provider, which shall at minimum—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id56d38e7b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/3/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration qualifications for available in-home child care providers in the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id56d38e7c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/a/3/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the qualifications the Commandant determines appropriate under this paragraph are comparable to the qualifications for a provider of child care services in a Coast Guard child development center or family home day care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d38e7d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Direct Payment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d38e7e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out a child care subsidy program under subsection (a)(1), subject to paragraph (3), the Commandant shall provide financial assistance under the program to an eligible member or individual the Commandant considers appropriate by direct payment to such eligible member or individual through monthly pay, direct deposit, or other direct form of payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d38e7f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this section, the Commandant shall establish a policy to provide direct payment as described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d38e80-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible provider funding continuation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With the approval of an eligible member or an individual the Commandant considers appropriate, which shall include the written consent of such member or individual, the Commandant may continue to provide financial assistance under the child care subsidy program directly to an eligible provider on behalf of such member or individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d38e81-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2927/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection may be construed to affect any preexisting reimbursement arrangement between the Coast Guard and a qualified provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d38e82-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIV/s11401/c/1/A"},"text":"Pub. L. 117–263, div. K, title CXIV, § 11401(c)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4106"},"text":"136 Stat. 4106","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d38e83-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d38e84-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56d38e85-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (b)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56d38e86-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56d38e87-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Expansion of Child Care Subsidy Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIV/s11401/c/2"},"text":"Pub. L. 117–263, div. K, title CXIV, § 11401(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4108"},"text":"136 Stat. 4108","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dK/tCXIV/s11401/c/2"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant [of the Coast Guard] shall—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate potential eligible uses for the child care subsidy program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2927"},"text":"section 2927 of title 14","children":[],"tail":", United States Code (referred to in this paragraph as the ‘program’);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand the eligible uses of funds for the program to accommodate the child care needs of members of the Coast Guard (including such members with nonstandard work hours and surge or other deployment cycles), including in-home care as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2927/a/3"},"text":"section 2927(a)(3) of title 14","children":[],"tail":", United States Code, and including by providing funds directly to such members instead of care providers; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" streamline enrollment policies, practices, paperwork, and requirements for eligible child care providers to reduce barriers for members to enroll in such providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In evaluating potential eligible uses under subparagraph (A), the Commandant shall consider in-home child care services, care services such as supplemental care for children with disabilities, and any other child care delivery method the Commandant considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing expanded eligible uses of funds for the program, the Commandant shall ensure that such uses—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are in the best interests of the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide flexibility for members of the Coast Guard, including such members and employees with nonstandard work hours; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure a safe environment for dependents of such members and employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 18 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], the Commandant shall publish an updated Commandant Instruction Manual (referred to in this paragraph as the ‘manual’) that describes the expanded eligible uses of the program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 18 months after the date of the enactment of this Act, the Commandant shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report outlining the expansion of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required by clause (i) shall include the following:","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An analysis of the considerations described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"“(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the analysis used to identify eligible uses that were evaluated and incorporated into the manual under subparagraph (D).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"“(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A full analysis and justification with respect to the forms of care that were ultimately not included in the manual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"“(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any recommendation with respect to funding or additional authorities necessary, including proposals for legislative change, to meet the current and anticipated future child care subsidy demands of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"“(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the steps taken to streamline enrollment policies, practices, and requirements for eligible child care providers in accordance with paragraph (2)(A)(iii).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
