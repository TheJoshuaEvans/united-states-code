{"tag":"section","attrib":{"id":"id56b2231b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1904"},"text":null,"children":[{"tag":"num","attrib":{"value":"1904"},"text":"§ 1904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Board on Women at the Coast Guard Academy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56b2231c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Superintendent of the Academy shall establish at the Coast Guard Academy an advisory board to be known as the Advisory Board on Women at the Coast Guard Academy (referred to in this section as the “Advisory Board”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b2231d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Board shall be composed of not fewer than 12 current cadets of the Coast Guard Academy, including not fewer than 3 cadets from each current class.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b2231e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment; Term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Cadets shall serve on the Advisory Board pursuant to appointment by the Superintendent of the Academy. Appointments shall be made not later than 60 days after the date of the swearing in of a new class of cadets at the Academy. The term of membership of a cadet on the Advisory Board shall be 1 academic year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b2231f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reappointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Superintendent of the Academy may reappoint not more than 6 cadets from the previous term to serve on the Advisory Board for an additional academic year if the Superintendent of the Academy determines such reappointment to be in the best interests of the Coast Guard Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b22320-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1904/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Board shall meet with the Commandant at least once each academic year on the activities of the Advisory Board. The Advisory Board shall meet in person with the Superintendent of the Academy not less than twice each academic year on the duties of the Advisory Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b22321-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1904/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Board shall identify opportunities and challenges facing cadets at the Academy who are women, including an assessment of culture, leadership development, and access to health care of cadets at the Academy who are women.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b22322-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1904/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Working Groups","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Board may establish one or more working groups to assist the Advisory Board in carrying out its duties, including working groups composed in part of cadets at the Academy who are not current members of the Advisory Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b22323-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1904/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports and Briefings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Board shall regularly provide the Commandant and the Superintendent reports and briefings on the results of its duties, including recommendations for actions to be taken in light of such results. Such reports and briefings may be provided in writing, in person, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56b22324-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8215(b)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4651"},"text":"134 Stat. 4651","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56b22325-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56b22326-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56b22327-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1904 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s1906"},"text":"section 1906 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
