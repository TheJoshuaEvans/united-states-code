{"tag":"section","attrib":{"id":"id56be3168-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2152"},"text":null,"children":[{"tag":"num","attrib":{"value":"2152"},"text":"§ 2152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary retirement after twenty years’ service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any regular commissioned officer who has completed twenty years’ active service in the Coast Guard, Navy, Army, Air Force, Marine Corps, or Space Force, or the Reserve components thereof, including active duty for training, at least ten years of which shall have been active commissioned service, may, upon his own application, in the discretion of the President, be retired from active service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56be3169-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/187"},"text":"77 Stat. 187","children":[],"tail":", § 291; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/348/tII/s205/b/5"},"text":"Pub. L. 99–348, title II, § 205(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-07-01"},"text":"July 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/700"},"text":"100 Stat. 700","children":[],"tail":"; renumbered § 2152, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s112/b"},"text":"Pub. L. 115–282, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/