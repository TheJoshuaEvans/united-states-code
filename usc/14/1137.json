{"tag":"section","attrib":{"id":"id56ab1f88-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1137"},"text":null,"children":[{"tag":"num","attrib":{"value":"1137"},"text":"§ 1137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting for major acquisitions programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56ab1f89-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1137/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out authorities provided to the Secretary to design, construct, accept, or otherwise acquire assets and systems under section 501(d), the Secretary, acting through the Commandant or the head of an integrated program office established for a major acquisition program, may enter into contracts for a major acquisition program and 3 Polar Security Cutters in addition to those approved as part of a major acquisition program on ","children":[{"tag":"date","attrib":{"date":"2019-11-01"},"text":"November 1, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ab1f8a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1137/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Methods","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Contracts entered into under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ab1f8b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1137/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be block buy contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f8c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1137/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be incrementally funded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f8d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1137/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include combined purchases, also known as economic order quantity purchases, of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ab1f8e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1137/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" materials and components; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1f8f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1137/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" long lead time materials; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f90-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1137/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3501"},"text":"section 3501 of title 10","children":[],"tail":", may be multiyear contracts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ab1f91-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1137/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subject to Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any contract entered into under subsection (a) shall provide that any obligation of the United States to make a payment under the contract is subject to the availability of amounts specifically provided in advance for that purpose in subsequent appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ab1f92-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIII/s311/b"},"text":"Pub. L. 115–282, title III, § 311(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4249"},"text":"132 Stat. 4249","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXI"},"text":"Pub. L. 116–283, div. G, title LVXXXI","children":[],"tail":" [LXXXI], § 8111(b), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4639"},"text":"134 Stat. 4639","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1702/d/2"},"text":"Pub. L. 117–81, div. A, title XVII, § 1702(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2156"},"text":"135 Stat. 2156","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ab1f93-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ab1f94-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ab1f95-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" inserted “and 3 Polar Security Cutters in addition to those approved as part of a major acquisition program on "},{"tag":"date","attrib":{"date":"2019-11-01"},"text":"November 1, 2019","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" substituted “section 3501” for “section 2306b”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56ab1f96-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56ab1f97-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Internal Regulations and Policy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIII/s311/e"},"text":"Pub. L. 115–282, title III, § 311(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4249"},"text":"132 Stat. 4249","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/282/tIII/s311/e"},"text":"“Not later than 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":"], the Secretary of the department in which the Coast Guard is operating shall establish the internal regulations and policies necessary to exercise the authorities provided under this section [enacting this section, amending "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s501"},"text":"section 501 of this title","children":[],"tail":", enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s1133"},"text":"section 1133 of this title","children":[],"tail":", amending provisions formerly set out as a note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s573"},"text":"section 573 of this title","children":[],"tail":", and repealing provisions set out as notes under former sections 87 and 577 of this title], including the amendments made in this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
