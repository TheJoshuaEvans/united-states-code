{"tag":"section","attrib":{"id":"id569a56a5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s551"},"text":null,"children":[{"tag":"num","attrib":{"value":"551"},"text":"§ 551.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marking anchorage grounds by Commandant of the Coast Guard","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commandant of the Coast Guard shall provide, establish, and maintain, out of the annual appropriations for the Coast Guard, buoys or other suitable marks for marking anchorage grounds for vessels in waters of the United States, when such anchorage grounds have been defined and established by proper authority in accordance with the laws of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id569a56a6-2930-11f1-a4c1-c531e6569a02"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXVIII/s11808/c"},"text":"Pub. L. 117–263, div. K, title CXVIII, § 11808(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4166"},"text":"136 Stat. 4166","children":[],"tail":", § 548; renumbered § 551, "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7264/a/1/A"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7264(a)(1)(A)","children":[],"tail":", title LXXVII, § 7701(i)(1), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1739"},"text":"139 Stat. 1739","children":[],"tail":", 1836.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569a56a7-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569a56a8-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","at