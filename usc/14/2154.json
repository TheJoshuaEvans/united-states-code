{"tag":"section","attrib":{"id":"id56be3176-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154"},"text":null,"children":[{"tag":"num","attrib":{"value":"2154"},"text":"§ 2154.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compulsory retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56be3177-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regular Commissioned Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any regular commissioned officer, except a commissioned warrant officer, serving in a grade below rear admiral (lower half) shall be retired on the first day of the month following the month in which the officer becomes 62 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56be3178-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Flag-Officer Grades","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56be3179-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), any regular commissioned officer serving in a grade of rear admiral (lower half) or above shall be retired on the first day of the month following the month in which the officer becomes 64 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56be317a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The retirement of an officer under paragraph (1) may be deferred—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56be317b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the President, but such a deferment may not extend beyond the first day of the month following the month in which the officer becomes 68 years of age; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56be317c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Secretary of the department in which the Coast Guard is operating, but such a deferment may not extend beyond the first day of the month following the month in which the officer becomes 66 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56be317d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deferred Retirement or Separation for Health Professions Officers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56be317e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), the Secretary may defer the retirement or separation under subsection (a) of a health professions officer if, during the period of the deferment, the health professions officer will be performing duties that consist primarily of providing patient care or performing other clinical duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56be317f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A deferment under this subsection may not extend beyond the first day of the month following the month in which the health professions officer concerned becomes 68 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56be3180-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may designate as health professions officers a category of members of the Coast Guard whose duties consist primarily of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56be3181-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing health care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56be3182-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing other clinical care, including radiology, specialty care, behavioral health care, pharmacy care, medical laboratory, or testing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56be3183-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing health care-related administrative duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56be3184-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection may be construed to prohibit or modify the application of any provision relating to mandatory separation or disciplinary action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56be3185-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Health professions officer defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “health professions officer” means an officer or enlisted member of the Coast Guard in good standing who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56be3186-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a physician, surgeon, medical specialist, nurse or nurse practitioner, physician’s assistant, health service technician, therapist, fully licensed clinical psychotherapist, counselor, social worker, medical assistant, radiology assistant, pharmacist, pharmacy assistant, nutritionist, dietitian, any administrative personnel associated with a Coast Guard medical program (including a clinic), personnel who works in a medical laboratory, physical therapist, physical therapist aide, occupational therapist, or occupational therapist aide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56be3187-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dentist, dental assistant, oral surgeon, or any other dental-related personnel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56be3188-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2154/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of a category designated by the Secretary under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56be3189-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tII/s215/a"},"text":"Pub. L. 111–281, title II, § 215(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2916"},"text":"124 Stat. 2916","children":[],"tail":", § 293; renumbered § 2154, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s112/b"},"text":"Pub. L. 115–282, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7222/a"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7222(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1700"},"text":"139 Stat. 1700","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56be318a-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56be318b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56be318c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s293"},"text":"section 293 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
