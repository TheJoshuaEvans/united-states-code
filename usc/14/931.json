{"tag":"section","attrib":{"id":"id56a3f308-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s931"},"text":null,"children":[{"tag":"num","attrib":{"value":"931"},"text":"§ 931.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oaths required for boards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The members of a retiring board, selection board, examining board, and any other board authorized to be assembled pursuant to this title shall be sworn to discharge their duties honestly and impartially, the oath to be administered to the members by the President or other presiding officer of the board, and to him by the junior member or recorder.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56a3f309-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/545"},"text":"63 Stat. 545","children":[],"tail":", § 635; renumbered § 931, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s107/b"},"text":"Pub. L. 115–282, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4205"},"text":"132 Stat. 4205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a3f30a-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56a3f30b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 170 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-04-12/ch501/s5"},"text":"Apr. 12, 1902, ch. 501, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/100"},"text":"32 Stat. 100","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said section has been divided. That part relating to oaths is covered in this section. The remainder is covered in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s425"},"text":"section 425 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said section is enlarged to include the oaths required for all boards, rather than to cover retiring boards only. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a3f30c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a3f30d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s635"},"text":"section 635 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
