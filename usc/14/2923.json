{"tag":"section","attrib":{"id":"id56d14534-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923"},"text":null,"children":[{"tag":"num","attrib":{"value":"2923"},"text":"§ 2923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child development center standards and inspections","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d14535-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall require each Coast Guard child development center to meet standards of operation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d14536-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Commandant considers appropriate to ensure the health, safety, and welfare of the children and employees at the center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d14537-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary for accreditation by an appropriate national early childhood programs accrediting entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d14538-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspections.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d14539-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less than twice annually, the Commandant shall ensure that each Coast Guard child development center is subject to an unannounced inspection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d1453a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibility for inspections","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the biannual inspections under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56d1453b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be carried out by a representative of the Coast Guard installation served by the Coast Guard child development center concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d1453c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be carried out by a representative of the Coast Guard child development services work-life programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d1453d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Reporting.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d1453e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall maintain and publicize a means by which an individual can report, with respect to a Coast Guard child development center or a family home daycare—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56d1453f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any suspected violation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56d14540-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards established under subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56d14541-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other applicable law or standard;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d14542-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspected child abuse or neglect; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d14543-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other deficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d14544-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Anonymous reporting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall ensure that an individual making a report pursuant to paragraph (1) may do so anonymously if so desired by the individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d14545-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2923/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall establish procedures for investigating reports made pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d14546-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s214/a"},"text":"Pub. L. 113–281, title II, § 214(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3031"},"text":"128 Stat. 3031","children":[],"tail":", § 553; renumbered § 2923, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s117/b"},"text":"Pub. L. 115–282, title I, § 117(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4230"},"text":"132 Stat. 4230","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8237(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4664"},"text":"134 Stat. 4664","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIV/s11401/b"},"text":"Pub. L. 117–263, div. K, title CXIV, § 11401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4106"},"text":"136 Stat. 4106","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d14547-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d14548-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d14549-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “The Commandant shall require each Coast Guard child development center to meet standards that the Commandant considers appropriate to ensure the health, safety, and welfare of the children and employees at the center.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “The Commandant shall provide for regular and unannounced inspections of each Coast Guard child development center to ensure compliance with this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s553"},"text":"section 553 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
