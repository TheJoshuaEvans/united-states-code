{"tag":"section","attrib":{"id":"id56b2238b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1921"},"text":null,"children":[{"tag":"num","attrib":{"value":"1921"},"text":"§ 1921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corps of Cadets authorized strength","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The number of cadets appointed annually to the Academy shall be as determined by the Secretary but the number appointed in any one year shall not exceed six hundred.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56b2238c-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s110/c/1/B"},"text":"Pub. L. 115–282, title I, § 110(c)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4213"},"text":"132 Stat. 4213","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
