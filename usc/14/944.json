{"tag":"section","attrib":{"id":"id56a63c7c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s944"},"text":null,"children":[{"tag":"num","attrib":{"value":"944"},"text":"§ 944.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidential investigative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not more than $250,000 each fiscal year appropriated for the operations and support of the Coast Guard shall be available for investigative expenses of a confidential character, to be expended on the approval or authority of the Commandant and payment to be made on the Commandant’s certificate of necessity for confidential purposes, and the Commandant’s determination shall be final and conclusive upon the accounting officers of the Government.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56a63c7d-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/283/s1/10"},"text":"Pub. L. 93–283, § 1(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-14"},"text":"May 14, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/140"},"text":"88 Stat. 140","children":[],"tail":", § 658; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tII/s221"},"text":"Pub. L. 108–293, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1040"},"text":"118 Stat. 1040","children":[],"tail":"; renumbered § 944 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s107/b"},"text":"Pub. L. 115–282, title I, § 107(b)","children":[],"tail":", title III, § 308, "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4205"},"text":"132 Stat. 4205","children":[],"tail":", 4248; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8513(a)(3), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4760"},"text":"134 Stat. 4760","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a63c7e-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a63c7f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a63c80-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “the operations and support” for “necessary expenses for the operation” and “the Commandant’s” for “his” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s308"},"text":"Pub. L. 115–282, § 308","children":[],"tail":", substituted “$250,000” for “$45,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s107/b"},"text":"Pub. L. 115–282, § 107(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s658"},"text":"section 658 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" substituted “$45,000 each fiscal year” for “$15,000 per annum”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
