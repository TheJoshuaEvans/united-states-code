{"tag":"section","attrib":{"id":"id568742a7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s315"},"text":null,"children":[{"tag":"num","attrib":{"value":"315"},"text":"§ 315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional affairs; Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commandant shall appoint a Director of Congressional Affairs from among officers of the Coast Guard who are in a grade above captain. The Director of Congressional Affairs is separate and distinct from the Director of Governmental and Public Affairs for the Coast Guard and is the principal advisor to the Commandant on all congressional and legislative matters for the Coast Guard and may have such additional functions as the Commandant may direct.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id568742a8-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8211(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4649"},"text":"134 Stat. 4649","children":[],"tail":", § 321; renumbered § 315, "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7201/b"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1675"},"text":"139 Stat. 1675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id568742a9-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id568742aa-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"head