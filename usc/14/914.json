{"tag":"section","attrib":{"id":"id56a3f2f8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s914"},"text":null,"children":[{"tag":"num","attrib":{"value":"914"},"text":"§ 914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of infrastructure related to E–LORAN","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a3f2f9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s914/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, the Commandant may dismantle or dispose of any real or personal property under the administrative control of the Coast Guard and used for the LORAN–C system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a3f2fa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s914/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No action described in subsection (a) may be taken unless and until—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a3f2fb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s914/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commandant notifies the Secretary of Transportation and the Secretary of Defense in writing of the proposed dismantling or disposal of a LORAN–C system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f2fc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s914/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 90 calendar days expires following the day on which the notice has been submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a3f2fd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s914/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Receipt of Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, not later than 90 calendar days of receipt of the written notification under subsection (b), the Secretary of Transportation or the Secretary of Defense notifies the Commandant, in writing, of a determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s312/d"},"text":"section 312(d) of title 49","children":[],"tail":" that the property is required to provide a positioning, navigation, and timing system to provide redundant capability in the event the Global Positioning System signals are disrupted, the Commandant shall transfer the property to the Department of Transportation without any consideration."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a3f2fe-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s914/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification Expiration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, at the end of the 90 calendar day period no notification under subsection (b) has been received, the Commandant shall notify the Committee on Transportation and Infrastructure and the Committee on Appropriations in the House of Representatives and the Committee on Commerce, Science, and Transportation and the Committee on Appropriations of the Senate that the period in subsection (b)(2) has expired, and may proceed with the dismantling and disposal of the personal property, and disposing of the real property in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2945"},"text":"section 2945 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a3f2ff-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s914/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prohibition on actions in subsection (b) does not apply to actions necessary for the safety of human life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a3f300-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tVI/s610/a/1"},"text":"Pub. L. 114–120, title VI, § 610(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/83"},"text":"130 Stat. 83","children":[],"tail":", § 681; renumbered § 914, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s107/b"},"text":"Pub. L. 115–282, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4205"},"text":"132 Stat. 4205","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8216, "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4653"},"text":"134 Stat. 4653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXII/s11211"},"text":"Pub. L. 117–263, div. K, title CXII, § 11211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4012"},"text":"136 Stat. 4012","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a3f301-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a3f302-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a3f303-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" amended section generally. Prior to amendment, section related to disposition of infrastructure related to E–LORAN and comprised of subsecs. (a) to (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8216/1"},"text":"Pub. L. 116–283, § 8216(1)","children":[],"tail":", substituted “later of the date of the conveyance of the properties directed under section 533(a) of the Coast Guard Authorization Act of 2016 ("},{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Public Law 114–120","children":[],"tail":") or the date” for “date”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8216/2"},"text":"Pub. L. 116–283, § 8216(2)","children":[],"tail":", added par. (2) and struck out former par. (2) which related to availability of proceeds."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s681"},"text":"section 681 of this title","children":[],"tail":", relating to disposition of infrastructure related to E–LORAN, as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
