{"tag":"section","attrib":{"id":"id56a3f2bc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s911"},"text":null,"children":[{"tag":"num","attrib":{"value":"911"},"text":"§ 911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Search and rescue center standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a3f2bd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s911/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall establish, implement, and maintain the minimum standards necessary for the safe operation of all Coast Guard search and rescue center facilities, including with respect to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a3f2be-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s911/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The lighting, acoustics, and temperature in the facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f2bf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s911/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of individuals on a shift in the facility assigned search and rescue responsibilities (including communications), which may be adjusted based on seasonal workload.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f2c0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s911/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The length of time an individual may serve on watch to minimize fatigue, based on the best scientific information available.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f2c1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s911/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The scheduling of individuals having search and rescue responsibilities to minimize fatigue of the individual when on duty in the facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f2c2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s911/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The workload of each individual engaged in search and rescue responsibilities in the facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f2c3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s911/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Stress management for the individuals assigned search and rescue responsibilities in the facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f2c4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s911/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The design of equipment and facilities to minimize fatigue and enhance search and rescue operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f2c5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s911/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The acquisition and maintenance of interim search and rescue command center communications equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f2c6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s911/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other requirements that the Secretary believes will increase the safe operation of the search and rescue centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a3f2c7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s911/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sense of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the sense of the Congress that the Secretary should establish, implement, and maintain minimum standards necessary to ensure that an individual on duty or watch in a Coast Guard search and rescue command center facility does not work more than 12 hours in a 24-hour period, except in an emergency or unforeseen circumstances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a3f2c8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s911/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of this section, the term “search and rescue center facility” means a Coast Guard shore facility that maintains a search and rescue mission coordination and communications watch.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a3f2c9-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIV/s405/a/2"},"text":"Pub. L. 107–295, title IV, § 405(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2115"},"text":"116 Stat. 2115","children":[],"tail":", § 676; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/207/s4/a/3"},"text":"Pub. L. 111–207, § 4(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-27"},"text":"July 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2251"},"text":"124 Stat. 2251","children":[],"tail":"; renumbered § 911, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s107/b"},"text":"Pub. L. 115–282, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4205"},"text":"132 Stat. 4205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a3f2ca-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a3f2cb-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a3f2cc-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s676"},"text":"section 676 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/207"},"text":"Pub. L. 111–207","children":[],"tail":" struck out subsec. (d). Text read as follows: “The Secretary shall provide a quarterly written report to the Senate Committee on Commerce, Science, and Transportation and the House of Representatives Committee on Transportation and Infrastructure, describing the status of implementation of the standards described in subsection (b), including a list of the facilities at which such standards have or have not been implemented.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56a3f2cd-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56a3f2ce-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prescription of Standards","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIV/s405/b"},"text":"Pub. L. 107–295, title IV, § 405(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2116"},"text":"116 Stat. 2116","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/295/tIV/s405/b"},"text":"“The Secretary shall prescribe the standards required under section 675(a) [probably means section 676(a), now 911(a)] of title 14, United States Code, as enacted by subsection (a) of this section, before ","children":[{"tag":"date","attrib":{"date":"2003-01-01"},"text":"January 1, 2003","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
