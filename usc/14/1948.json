{"tag":"section","attrib":{"id":"id56b49501-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1948"},"text":null,"children":[{"tag":"num","attrib":{"value":"1948"},"text":"§ 1948.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marine safety curriculum","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commandant shall ensure that professional courses of study in marine safety are provided at the Coast Guard Academy, and during other officer accession programs, to give Coast Guard cadets and other officer candidates a background and understanding of the marine safety program. These courses may include such topics as program history, vessel design and construction, vessel inspection, casualty investigation, and administrative law and regulations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56b49502-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tV/s525/a"},"text":"Pub. L. 111–281, title V, § 525(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2959"},"text":"124 Stat. 2959","children":[],"tail":", § 200; renumbered § 199 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/330/s1/7/A"},"text":"Pub. L. 111–330, § 1(7)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3569"},"text":"124 Stat. 3569","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3531/c/11"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3531(c)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2320"},"text":"132 Stat. 2320","children":[],"tail":"; renumbered § 1948, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s110/b"},"text":"Pub. L. 115–282, title I, § 110(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4212"},"text":"132 Stat. 4212","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56b49503-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56b49504-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56b49505-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s199"},"text":"section 199 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “Commandant” for “Commandant of the Coast Guard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/330"},"text":"Pub. L. 111–330","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/s525/a"},"text":"Pub. L. 111–281, § 525(a)","children":[],"tail":", which enacted this section, and renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s200"},"text":"section 200 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}