{"tag":"section","attrib":{"id":"id56daba23-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3913"},"text":null,"children":[{"tag":"num","attrib":{"value":"3913"},"text":"§ 3913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injury or death in line of duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When any member of the Auxiliary is physically injured or dies as a result of physical injury incurred while performing any duty to which he has been assigned by competent Coast Guard authority, such member or his beneficiary shall be entitled to the same benefits provided for temporary members of the Reserve who suffer physical injury or death resulting from physical injury incurred incident to service. Members of the Auxiliary who incur physical injury or contract sickness or disease while performing any duty to which they have been assigned by competent Coast Guard authority shall be entitled to the same hospital treatment afforded members of the Coast Guard. The performance of a duty as the term is used in this section includes time engaged in traveling back and forth between the place of assigned duty and the permanent residence of a member of the Auxiliary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56daba24-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/556"},"text":"63 Stat. 556","children":[],"tail":", § 832; "},{"tag":"ref","attrib":{"href":"/us/pl/93/283/s1/15"},"text":"Pub. L. 93–283, § 1(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-14"},"text":"May 14, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/141"},"text":"88 Stat. 141","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/3/D"},"text":"Pub. L. 98–557, § 15(a)(3)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tIV/s404/c"},"text":"Pub. L. 104–324, title IV, § 404(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3924"},"text":"110 Stat. 3924","children":[],"tail":"; renumbered § 3913, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s119/b"},"text":"Pub. L. 115–282, title I, § 119(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4236"},"text":"132 Stat. 4236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56daba25-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56daba26-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 270 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-02-19/ch8"},"text":"Feb. 19, 1941, ch. 8","children":[],"tail":", title I, § 11, as added "},{"tag":"ref","attrib":{"href":"/us/act/1944-09-30/ch453/s7"},"text":"Sept. 30, 1944, ch. 453, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/761"},"text":"58 Stat. 761","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56daba27-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56daba28-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s832"},"text":"section 832 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" struck out “specific” after “performing any” in two places and after “performance of a”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted reference to members for reference to officers and enlisted men after “treatment afforded”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/283"},"text":"Pub. L. 93–283","children":[],"tail":" included time engaged in traveling back and forth between the place of assigned duty and the permanent residence of a member of the Auxiliary as the performance of a specific duty."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
