{"tag":"section","attrib":{"id":"id56b2239a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1924"},"text":null,"children":[{"tag":"num","attrib":{"value":"1924"},"text":"§ 1924.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may summarily dismiss from the Coast Guard any cadet who, during his cadetship, is found unsatisfactory in either studies or conduct, or may be deemed not adapted for a career in the Coast Guard. Cadets shall be subject to rules governing discipline prescribed by the Commandant.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56b2239b-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s110/c/1/C"},"text":"Pub. L. 115–282, title I, § 110(c)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4214"},"text":"132 Stat. 4214","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
