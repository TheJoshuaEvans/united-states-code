{"tag":"section","attrib":{"id":"id56daba3a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4103"},"text":null,"children":[{"tag":"num","attrib":{"value":"4103"},"text":"§ 4103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on rights of members of the Auxiliary and temporary members of the Reserve","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Members of the Auxiliary and temporary members of the Reserve shall be entitled only to such rights, privileges, and benefits as are specifically set forth for them in this title or as may be specifically provided for them in any other Act of Congress. Any Act of Congress which grants rights, privileges, or benefits generally to military personnel, or among others, to personnel of the Coast Guard and the Coast Guard Reserve, without specifically granting such rights, privileges, or benefits to members of the Auxiliary or temporary members of the Reserve, shall not be deemed applicable to members of the Auxiliary or to temporary members of the Reserve.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56daba3b-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/557"},"text":"63 Stat. 557","children":[],"tail":", § 893; renumbered § 4103, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s120/b"},"text":"Pub. L. 115–282, title I, § 120(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4237"},"text":"132 Stat. 4237","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56daba3c-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56daba3d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 271 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-02-19/ch8"},"text":"Feb. 19, 1941, ch. 8","children":[],"tail":", title I, § 12, as added "},{"tag":"ref","attrib":{"href":"/us/act/1944-09-30/ch453/s8"},"text":"Sept. 30, 1944, ch. 453, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/761"},"text":"58 Stat. 761","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Temporary members of the Reserve are included within the provisions of this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56daba3e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56daba3f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s893"},"text":"section 893 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
