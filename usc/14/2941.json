{"tag":"section","attrib":{"id":"id56d38e8c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2941"},"text":null,"children":[{"tag":"num","attrib":{"value":"2941"},"text":"§ 2941.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d38e8d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2941/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “construct” means to build, renovate, or improve military family housing and military unaccompanied housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d38e8e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2941/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “construction” means building, renovating, or improving military family housing and military unaccompanied housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d38e8f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2941/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “military unaccompanied housing” means military housing intended to be occupied by members of the armed forces serving a tour of duty unaccompanied by dependents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d38e90-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2941/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States” includes the Commonwealth of Puerto Rico, Guam, the United States Virgin Islands, and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d38e91-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tII/s208/a"},"text":"Pub. L. 104–324, title II, § 208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3909"},"text":"110 Stat. 3909","children":[],"tail":", § 680; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tII/s207/a"},"text":"Pub. L. 108–293, title II, § 207(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1034"},"text":"118 Stat. 1034","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tII/s221/a/1"},"text":"Pub. L. 111–281, title II, § 221(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2919"},"text":"124 Stat. 2919","children":[],"tail":"; renumbered § 2941, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s117/b"},"text":"Pub. L. 115–282, title I, § 117(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4230"},"text":"132 Stat. 4230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d38e92-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d38e93-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d38e94-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s680"},"text":"section 680 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" added pars. (1) and (2), redesignated former pars. (4) and (5) as (3) and (4), respectively, and struck out former pars. (1) to (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The term ‘construction’ means the construction of military housing units and ancillary supporting facilities or the improvement or rehabilitation of existing units or ancillary supporting facilities.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The term ‘contract’ includes any contract, lease, or other agreement entered into under the authority of this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The term ‘eligible entity’ means any private person, corporation, firm, partnership, or company and any State or local government or housing authority of a State or local government.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Pars. (3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" added par. (3) and redesignated former pars. (3) and (4) as (4) and (5), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56d38e95-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id56d38e96-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Clause","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tII/s221/b"},"text":"Pub. L. 111–281, title II, § 221(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2920"},"text":"124 Stat. 2920","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/281/tII/s221/b"},"text":"“This section [amending this section and sections 681, 685, 687, and 688 of this title and repealing sections 682 to 684, 686, 687a, and 689 of this title] shall not affect any action commenced prior to the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
