{"tag":"section","attrib":{"id":"id56c536a5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2518"},"text":null,"children":[{"tag":"num","attrib":{"value":"2518"},"text":"§ 2518.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Command sponsorship","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On request by a member of the Coast Guard assigned to Unalaska, Alaska, the Commandant shall grant command sponsorship to the dependents of such member.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56c536a6-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7228/a"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7228(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1708"},"text":"139 Stat. 1708","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
