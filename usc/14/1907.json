{"tag":"section","attrib":{"id":"id56b22347-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907"},"text":null,"children":[{"tag":"num","attrib":{"value":"1907"},"text":"§ 1907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coast Guard Academy Cadet Advisory Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56b22348-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall establish within the Coast Guard Academy an advisory board to be known as the “Coast Guard Academy Cadet Advisory Board” (in this section referred to as the “Advisory Board”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b22349-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Board shall be composed of not fewer than 12 cadets of the Coast Guard Academy who are enrolled at the Coast Guard Academy at the time of appointment, including not fewer than 3 cadets from each class.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b2234a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b2234b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Cadets shall be appointed to the Advisory Board by the Provost, in consultation with the Superintendent of the Coast Guard Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b2234c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Cadets who are eligible for appointment to the Advisory Board shall submit an application for appointment to the Provost of the Coast Guard Academy, or a designee of the Provost, for consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b2234d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Provost shall select eligible applicants who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b2234e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are best suited to fulfill the duties described in subsection (g); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b2234f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best represent the student body makeup at the Coast Guard Academy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b22350-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b22351-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Appointments shall be made not later than 60 days after the date of the swearing in of a new class of cadets at the Coast Guard Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b22352-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of membership of a cadet on the Advisory Board shall be 1 academic year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b22353-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Board shall meet in person with the Superintendent not less frequently than twice each academic year to discuss the activities of the Advisory Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b22354-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b22355-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify challenges facing Coast Guard Academy cadets relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56b22356-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health and wellbeing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b22357-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cadet perspectives and information with respect to sexual assault, sexual harassment and sexual violence prevention, response, and recovery at the Coast Guard Academy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b22358-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other matter the Advisory Board considers important;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b22359-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discuss and propose possible solutions to such challenges, including improvements to leadership development at the Coast Guard Academy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b2235a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically review the efficacy of Coast Guard Academy academic, wellness, and other relevant programs and provide recommendations to the Commandant for improvement of such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b2235b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Working Groups.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b2235c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Board shall establish a working group composed, at least in part, of Coast Guard Academy cadets who are not current members of the Advisory Board and members of the Cadets Against Sexual Assault, or any similar successor organization, to assist the Advisory Board in carrying out the duties described in subsection (g)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b2235d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other working groups","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Board may establish such other working groups (which may be composed, at least in part, of Coast Guard Academy cadets who are not current members of the Advisory Board) as the Advisory Board finds to be necessary to carry out duties of the Board, other than the duties described in subparagraph (A) or (C) of subsection (g)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b2235e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b2235f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commandant and superintendent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less frequently than once per academic semester, the Advisory Board shall submit a report or provide a briefing to the Commandant and the Superintendent on the results of the activities carried out in furtherance of the duties of the Advisory Board described in subsection (g), including recommendations for actions to be taken based on such results.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b22360-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Board shall transmit to the Commandant, through the Provost and the Superintendent, an annual report at the conclusion of each academic year, containing the information and materials presented to the Commandant, Superintendent, or both, during each brief provided during such academic year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b22361-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1907/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the receipt by the Commandant of a report under this subsection, the Commandant shall provide to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives any report or other materials provided to the Commandant and Superintendent under paragraph (1) and any other information related to the Advisory Board requested by the Committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56b22362-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7243/a"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7243(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1727"},"text":"139 Stat. 1727","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
