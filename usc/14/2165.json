{"tag":"section","attrib":{"id":"id56be31d7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2165"},"text":null,"children":[{"tag":"num","attrib":{"value":"2165"},"text":"§ 2165.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief of retired officer promoted while on active duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any regular officer on the retired list recalled to active duty who during such active duty is advanced to a higher grade under an appointment shall, upon relief from active duty, if his performance of duty under such appointment has been satisfactory, be advanced on the retired list to the highest grade held while on such active duty.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56be31d8-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/189"},"text":"77 Stat. 189","children":[],"tail":", § 333; renumbered § 2165, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s112/b"},"text":"Pub. L. 115–282, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56be31d9-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56be31da-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56be31db-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s333"},"text":"section 333 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
