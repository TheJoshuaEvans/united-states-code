{"tag":"section","attrib":{"id":"id567dcd8e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s103"},"text":null,"children":[{"tag":"num","attrib":{"value":"103"},"text":"§ 103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department in which the Coast Guard operates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id567dcd8f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Coast Guard shall be a service in the Department of Homeland Security, except when operating as a service in the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id567dcd90-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the declaration of war if Congress so directs in the declaration or when the President directs, the Coast Guard shall operate as a service in the Navy, and shall so continue until the President, by Executive order, transfers the Coast Guard back to the Department of Homeland Security. While operating as a service in the Navy, the Coast Guard shall be subject to the orders of the Secretary of the Navy, who may order changes in Coast Guard operations to render them uniform, to the extent such Secretary deems advisable, with Navy operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id567dcd91-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation as a Service in the Navy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the Coast Guard operates as a service in the Navy—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id567dcd92-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable appropriations of the Navy Department shall be available for the expense of the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id567dcd93-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable appropriations of the Coast Guard shall be available for transfer to the Navy Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id567dcd94-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s103/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" precedence between commissioned officers of corresponding grades in the Coast Guard and the Navy shall be determined by the date of rank stated by their commissions in those grades;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id567dcd95-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s103/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel of the Coast Guard shall be eligible to receive gratuities, medals, and other insignia of honor on the same basis as personnel in the naval service or serving in any capacity with the Navy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id567dcd96-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s103/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may place on furlough any officer of the Coast Guard and officers on furlough shall receive one half of the pay to which they would be entitled if on leave of absence, but officers of the Coast Guard Reserve shall not be so placed on furlough.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id567dcd97-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/496"},"text":"63 Stat. 496","children":[],"tail":", § 3; "},{"tag":"ref","attrib":{"href":"/us/pl/94/546/s1/2"},"text":"Pub. L. 94–546, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2519"},"text":"90 Stat. 2519","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/a"},"text":"Pub. L. 107–296, title XVII, § 1704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tII/s211"},"text":"Pub. L. 109–241, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/523"},"text":"120 Stat. 523","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tII/s217/1"},"text":"Pub. L. 112–213, title II, § 217(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1556"},"text":"126 Stat. 1556","children":[],"tail":"; renumbered § 103, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s103/b"},"text":"Pub. L. 115–282, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4195"},"text":"132 Stat. 4195","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id567dcd98-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id567dcd99-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 1 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1915-01-28/ch20/s1"},"text":"Jan. 28, 1915, ch. 20, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/800"},"text":"38 Stat. 800","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1941-07-11/ch290"},"text":"July 11, 1941, ch. 290","children":[],"tail":", §§ 5, 6(a), "},{"tag":"ref","attrib":{"href":"/us/stat/55/585"},"text":"55 Stat. 585","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said section has been divided. The provisions relating to when the Coast Guard operates as a service in the Navy are in this section. The provisions relating to the establishment of the Coast Guard are placed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s1"},"text":"section 1 of this title","children":[],"tail":". The provisions relating to appropriations are placed in "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s4"},"text":"section 4 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id567dcd9a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id567dcd9b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 103 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s563"},"text":"section 563 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id567dcd9c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s3"},"text":"section 3 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213"},"text":"Pub. L. 112–213","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “Upon the declaration of war if Congress so directs in the declaration or when the President directs, the Coast Guard shall operate as a service in the Navy, and shall so continue until the President, by Executive order, transfers the Coast Guard back to the Department of Homeland Security. While operating as a service in the Navy, the Coast Guard shall be subject to the orders of the Secretary of the Navy who may order changes in Coast Guard operations to render them uniform, to the extent he deems advisable, with Navy operations.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241"},"text":"Pub. L. 109–241","children":[],"tail":" inserted “if Congress so directs in the declaration” after “Upon the declaration of war”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “Department of Homeland Security” for “Department of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/546"},"text":"Pub. L. 94–546","children":[],"tail":" substituted “Executive” for “executive” and “Department of Transportation” for “Treasury Department”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id567dcd9d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id567dcd9e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
