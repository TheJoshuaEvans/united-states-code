{"tag":"section","attrib":{"id":"id56a182a7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s909"},"text":null,"children":[{"tag":"num","attrib":{"value":"909"},"text":"§ 909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small boat station rescue capability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that each Coast Guard small boat station (including a seasonally operated station) maintains, within the area of responsibility for the station, at least 1 vessel that is fully capable of performing offshore rescue operations, taking into consideration prevailing weather, marine conditions, and depositional geologic features such as sand bars.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56a182a8-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tIII/s309/a"},"text":"Pub. L. 104–324, title III, § 309(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3919"},"text":"110 Stat. 3919","children":[],"tail":", § 673; renumbered § 674, "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIV/s405/a/1"},"text":"Pub. L. 107–295, title IV, § 405(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2115"},"text":"116 Stat. 2115","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/a"},"text":"Pub. L. 107–296, title XVII, § 1704(a)","children":[],"tail":", (f)(1), "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":", 2316; "},{"tag":"ref","attrib":{"href":"/us/