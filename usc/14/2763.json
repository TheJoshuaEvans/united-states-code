{"tag":"section","attrib":{"id":"id56ced310-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2763"},"text":null,"children":[{"tag":"num","attrib":{"value":"2763"},"text":"§ 2763.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensatory absence from duty for military personnel at isolated duty stations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may grant compensatory absence from duty to military personnel of the Coast Guard serving at isolated duty stations of the Coast Guard when conditions of duty result in confinement because of isolation or in long periods of continuous duty.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56ced311-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch650/s4"},"text":"Aug. 9, 1955, ch. 650, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/577"},"text":"69 Stat. 577","children":[],"tail":", § 511; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/546/s1/32"},"text":"Pub. L. 94–546, § 1(32)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2521"},"text":"90 Stat. 2521","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIII/s312/a"},"text":"Pub. L. 107–295, title III, § 312(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2102"},"text":"116 Stat. 2102","children":[],"tail":"; renumbered § 2763, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ced312-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ced313-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ced314-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s511"},"text":"section 511 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295"},"text":"Pub. L. 107–295","children":[],"tail":" substituted “Compensatory absence from duty for military personnel at isolated duty stations” for “Compensatory absence of military personnel at isolated aids to navigation” in section catchline and amended text generally. Prior to amendment, text read as follows: “The Secretary, under regulations prescribed by him, may grant compensatory absence from duty to military personnel of the Coast Guard serving in lightships and at lighthouses and other isolated aids to navigation of the Coast Guard when conditions of duty result in confinement because of isolations or in long periods of continuous duty.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/546"},"text":"Pub. L. 94–546","children":[],"tail":" substituted “Secretary” for “head of the department in which the Coast Guard is operating”."}],"tail":