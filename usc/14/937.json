{"tag":"section","attrib":{"id":"id56a3f350-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s937"},"text":null,"children":[{"tag":"num","attrib":{"value":"937"},"text":"§ 937.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admiralty claims against the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a3f351-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s937/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may consider, ascertain, adjust, determine, compromise, or settle, and pay in an amount not more than $425,000, an admiralty claim against the United States for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a3f352-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s937/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damage caused by a vessel in the Coast Guard service or by other property under the jurisdiction of the Department in which the Coast Guard is operating;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f353-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s937/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation for towage and salvage services, including contract salvage, rendered to a vessel in the Coast Guard service or to other property under the jurisdiction of the Department in which the Coast Guard is operating; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f354-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s937/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damage caused by a maritime tort committed by an agent or employee of the Department in which the Coast Guard is operating or by property under the jurisdiction of that Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a3f355-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s937/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon acceptance of payment by the claimant, the settlement or compromise of a claim under this section is final and conclusive notwithstanding any other law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a3f356-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s937/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a claim under this section is settled or compromised for more than $100,000, the Secretary shall certify it to Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a3f357-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/548"},"text":"63 Stat. 548","children":[],"tail":", § 646; "},{"tag":"ref","attrib":{"href":"/us/pl/86/533/s1/3/A"},"text":"Pub. L. 86–533, § 1(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-29"},"text":"June 29, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/245"},"text":"74 Stat. 245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/417/s2/a"},"text":"Pub. L. 92–417, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-29"},"text":"Aug. 29, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/655"},"text":"86 Stat. 655","children":[],"tail":"; renumbered § 937, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s107/b"},"text":"Pub. L. 115–282, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4205"},"text":"132 Stat. 4205","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8212(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4649"},"text":"134 Stat. 4649","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a3f358-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56a3f359-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 71 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-15/ch550"},"text":"June 15, 1936, ch. 550","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1514"},"text":"49 Stat. 1514","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 711, "},{"tag":"ref","attrib":{"href":"/us/stat/58/714"},"text":"58 Stat. 714","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-13/ch958/s5"},"text":"Aug. 13, 1946, ch. 958, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/1051"},"text":"60 Stat. 1051","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section closely parallels title 46, U.S.C., 1946 ed., §§ 797, 798, which authorizes the Secretary of the Navy to negotiate amicable settlement of claims against the United States arising out of the operation of Naval vessels. It grants similar authority to the Secretary of the Treasury in relation to vessels in the Coast Guard service, and the limiting amount is reduced from $1,000,000 to $25,000. It is believed that this section will work to the benefit of the Government by reducing civil litigation and the number of claims which must presently be certified to Congress for appropriations in order to make settlement. It will greatly expedite the settlement of just claims and should result in a considerable overall savings to the Government. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a3f35a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a3f35b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “$425,000” for “$100,000” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s646"},"text":"section 646 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/417"},"text":"Pub. L. 92–417","children":[],"tail":" incorporated in part first sentence of former subsec. (a) in text preceding par. (1), substituted “Secretary” for “Secretary of the Treasury”, inserted provisions authorizing payments up to $100,000, struck out second, third, and fourth sentences providing that provisions of this section were supplementary to other provisions, that claims in excess of $3,000 accrued prior to "},{"tag":"date","attrib":{"date":"1939-09-08"},"text":"Sept. 8, 1939","children":[],"tail":", would not be considered, and that payments be made out of Coast Guard appropriations, and added pars. (1) to (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/417"},"text":"Pub. L. 92–417","children":[],"tail":" incorporated in part first sentence of former subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/417"},"text":"Pub. L. 92–417","children":[],"tail":" incorporated provisions of last sentence of former subsec. (a) and substituted “100,000” for “25,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/533"},"text":"Pub. L. 86–533","children":[],"tail":" repealed subsec. (b) which required the Secretary of the Treasury to report to the Congress the payment of claims determined, compromised, settled, or paid."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
