{"tag":"section","attrib":{"id":"id56d84952-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3750"},"text":null,"children":[{"tag":"num","attrib":{"value":"3750"},"text":"§ 3750.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure of selection for promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d84953-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3750/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Reserve officer, other than one serving in the grade of captain, who is, or is senior to, the junior officer in the promotion zone established for the officer’s grade, fails of selection if not selected for promotion by the selection board that considered the officer, or if having been selected for promotion by the board, the officer’s name is thereafter removed from the report of the board by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d84954-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3750/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Reserve officer is not considered to have failed of selection if the officer was not considered by a selection board because of administrative error. If that officer is selected by the next appropriate selection board after the error is discovered, and is promoted, the same date of rank and precedence shall be assigned that would have been assigned if the officer had been recommended for promotion by the selection board that originally would have considered the officer but for the error.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d84955-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1013"},"text":"94 Stat. 1013","children":[],"tail":", § 739; renumbered § 3750, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s118/b"},"text":"Pub. L. 115–282, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d84956-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d84957-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56d84958-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s796"},"text":"section 796 of this title","children":[],"tail":" prior to the complete revision of former chapter 21 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/96/322"},"text":"Pub. L. 96–322","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d84959-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s739"},"text":"section 739 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
