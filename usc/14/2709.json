{"tag":"section","attrib":{"id":"id56cc6251-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2709"},"text":null,"children":[{"tag":"num","attrib":{"value":"2709"},"text":"§ 2709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement and sale of stores to members and civilian employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Such stores as the Secretary may designate may be procured and sold to members of the Coast Guard, and to the surviving spouses of such members. Such designated stores may also be procured and sold to civilian officers and employees of the United States, and to such other individuals as may be specifically authorized by the Secretary, at Coast Guard stations and other units beyond the continental limits of the United States or in Alaska.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56cc6252-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/534"},"text":"63 Stat. 534","children":[],"tail":", § 487; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/2"},"text":"Pub. L. 98–557, § 15(a)(2)","children":[],"tail":", (3)(D), (4)(D)(i), "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":", 2866; renumbered § 2709, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(22), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4749"},"text":"134 Stat. 4749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56cc6253-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56cc6254-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Derived from title 34, U.S.C., 1946 ed., § 533 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-03/ch255"},"text":"Mar. 3, 1909, ch. 255","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/768"},"text":"35 Stat. 768","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1937-04-14/ch78"},"text":"Apr. 14, 1937, ch. 78","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/63"},"text":"50 Stat. 63","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-06-10/ch196"},"text":"June 10, 1939, ch. 196","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/814"},"text":"53 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-01-23/ch15"},"text":"Jan. 23, 1942, ch. 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/13"},"text":"56 Stat. 13","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1943-04-09/ch39"},"text":"Apr. 9, 1943, ch. 39","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/60"},"text":"57 Stat. 60","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said section granted authority for the Secretary of the Navy to sell designated stores to officers and enlisted men. It is deemed desirable to grant similar authority to the Secretary having control of the Coast Guard.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said section would in no way be affected. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56cc6255-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56cc6256-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “individuals” for “persons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s487"},"text":"section 487 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" in section catchline substituted “members” for “officers, enlisted men,” and in text substituted “surviving spouses” for “widows” and “members” for “officers and enlisted men” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
