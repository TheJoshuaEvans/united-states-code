{"tag":"section","attrib":{"id":"id56b705e4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2119"},"text":null,"children":[{"tag":"num","attrib":{"value":"2119"},"text":"§ 2119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure of selection for promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An officer, other than an officer serving in the grade of captain, who is, or is senior to, the junior officer in the promotion zone established for his grade under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2111"},"text":"section 2111 of this title","children":[],"tail":", fails of selection if he is not selected for promotion by the selection board which considered him, or if having been recommended for promotion by the board, his name is thereafter removed from the report of the board by the President."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56b94fd5-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/181"},"text":"77 Stat. 181","children":[],"tail":", § 262; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tII/s208/c"},"text":"Pub. L. 112–213, title II, § 208(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1549"},"text":"126 Stat. 1549","children":[],"tail":"; renumbered § 2119 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 112(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56b94fd6-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56b94fd7-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56b94fd8-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 2111” for “section 256”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s112/b"},"text":"Pub. L. 115–282, § 112(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s262"},"text":"section 262 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213"},"text":"Pub. L. 112–213","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) and (b) describing failure of selection for promotion with an exception made if an officer was not considered because of administrative error."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56b94fd9-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id56b94fda-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213"},"text":"Pub. L. 112–213","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", with provision for convening a special selection board for certain errors occurring on or after the date that is 1 year before "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/s208/e/1"},"text":"section 208(e)(1) of Pub. L. 112–213","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2118"},"text":"section 2118 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56b94fdb-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Placement Out of Line of Promotion Prior to ","children":[{"tag":"date","attrib":{"date":"1963-09-24"},"text":"September 24, 1963","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s2/a"},"text":"Pub. L. 88–130, § 2(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/190"},"text":"77 Stat. 190","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/88/130/s2/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Officers who have been placed permanently out of line of promotion under laws and regulations of the Secretary in effect the day before the effective date of this Act [","children":[{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":"] shall be considered as having failed of selection for promotion to the next higher grade for the second time on the day before the effective date of this Act, and shall be subject to the provisions of sections 282 through 285 [now 2142 through 2145] of title 14, United States Code, as appropriate. No officer shall be separated from the service under the above provisions prior to the last day of the sixth calendar month following the effective date of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Officers who have been placed temporarily out of line of promotion for appointment for temporary service under laws and regulations of the Secretary in effect the day before the effective date of this Act [","children":[{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":"] shall be considered as having once failed of selection for promotion to the next higher grade.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
