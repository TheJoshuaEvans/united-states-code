{"tag":"section","attrib":{"id":"id56c7a6ec-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531"},"text":null,"children":[{"tag":"num","attrib":{"value":"2531"},"text":"§ 2531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive policy and procedures on retention and access to evidence and records relating to sexual misconduct and other misconduct","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56c7a6ed-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance of Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of the Coast Guard Authorization Act of 2025, the Secretary, in consultation with the Office of the Inspector General of the department in which the Coast Guard is operating and the Office of the Inspector General of the Department of Defense, shall issue a comprehensive policy for the Coast Guard on the retention of and access to evidence and records relating to covered misconduct involving members of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c7a6ee-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Objectives","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The comprehensive policy required by subsection (a) shall revise existing policies and procedures, including systems of records, as necessary to ensure preservation of such evidence and records for periods sufficient—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c7a6ef-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that members of the Coast Guard who were victims of covered misconduct are able to pursue claims for veterans benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c7a6f0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support administrative processes, criminal proceedings, and civil litigation conducted by military or civil authorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c7a6f1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for such other purposes relating to the documentation of an incident of covered misconduct in the Coast Guard as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c7a6f2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c7a6f3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the comprehensive policy required by subsection (a), the Secretary shall, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c7a6f4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify records relating to an incident of covered misconduct that shall be retained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a6f5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to records relating to covered misconduct involving members of the Coast Guard that are not records of the Coast Guard, identify such records known to or in the possession of the Coast Guard, and set forth procedures for Coast Guard coordination with the custodian of such records for proper retention of the records;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a6f6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth criteria for the collection and retention of records relating to covered misconduct involving members of the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a6f7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify physical evidence and nondocumentary forms of evidence relating to covered misconduct that shall be retained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a6f8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" set forth the period for which evidence and records relating to covered misconduct involving members of the Coast Guard, including Coast Guard Form 6095, shall be retained, except that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56c7a6f9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any physical or forensic evidence relating to rape or sexual assault, as described in sections 920(a) and 920(b) of title 10 (articles 120(a) and 120(b) of the Uniform Code of Military Justice), shall be retained not less than 50 years, and for other covered misconduct not less than the statute of limitations of the alleged offense under the Uniform Code of Military Justice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c7a6fa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentary evidence relating to rape or sexual assault, as described in sections 920(a) and 920(b) of title 10 (articles 120(a) and 120(b) of the Uniform Code of Military Justice), shall be retained not less than 50 years;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a6fb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider locations in which such records shall be stored;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a6fc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify media and methods that may be used to preserve and ensure access to such records, including electronic systems of records;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a6fd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure the protection of privacy of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56c7a6fe-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals named in records and status of records under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" (commonly referred to as the “Freedom of Information Act”) and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" (commonly referred to as the “Privacy Act”); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c7a6ff-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals named in restricted reporting cases;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a700-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate the 1 or more positions within the Coast Guard that shall have the responsibility for such record retention by the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a701-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require education and training for members and civilian employees of the Coast Guard on record retention requirements under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a702-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" set forth criteria for access to such records relating to covered misconduct involving members of the Coast Guard, including whether the consent of the victim should be required, by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56c7a703-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/K/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" victims of covered misconduct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c7a704-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/K/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law enforcement authorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c7a705-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/K/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Veterans Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c7a706-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/K/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other individuals and entities, including alleged assailants;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a707-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require uniform collection of data on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56c7a708-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/L/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incidence of covered misconduct in the Coast Guard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c7a709-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/L/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disciplinary actions taken in substantiated cases of covered misconduct in the Coast Guard; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a70a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" set forth standards for communications with, and notifications to, victims, consistent with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56c7a70b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/M/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements of any applicable Department of Defense policy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c7a70c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/1/M/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, any applicable policy of the department in which the Coast Guard is operating.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c7a70d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention of certain forms and evidence in connection with restricted reports and unrestricted reports of sexual assault involving members of the coast guard.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c7a70e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The comprehensive policy required by subsection (a) shall require all unique or original copies of Coast Guard Form 6095 filed in connection with a restricted or unrestricted report on an alleged incident of rape or sexual assault, as described in sections 920(a) and 920(b) of title 10 (articles 120(a) and 120(b) of the Uniform Code of Military Justice), involving a member of the Coast Guard to be retained for the longer of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56c7a70f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 years commencing on the date of signature of the covered person on Coast Guard Form 6095; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c7a710-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time provided for the retention of such form in connection with unrestricted and restricted reports on incidents of sexual assault involving members of the Coast Guard under Coast Guard policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a711-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection of confidentiality","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any Coast Guard form retained under subparagraph (A) shall be retained in a manner that protects the confidentiality of the member of the Coast Guard concerned in accordance with Coast Guard policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c7a712-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention of case notes in investigations of covered misconduct involving members of the coast guard.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c7a713-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required retention of all investigative records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The comprehensive policy required by subsection (a) shall require, for all criminal investigations relating to an alleged incident of covered misconduct involving a member of the Coast Guard, the retention of all elements of the case file.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a714-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The elements of the case file to be retained under subparagraph (A) shall include, at a minimum—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56c7a715-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the case activity record;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c7a716-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the case review record;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c7a717-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigative plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c7a718-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all case notes made by any investigating agent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a719-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All elements of the case file shall be retained for not less than 50 years for cases involving rape or sexual assault, as described in sections 920(a) and 920(b) of title 10 (articles 120(a) and 120(b) of the Uniform Code of Military Justice), and not less than the statute of limitations of the alleged offense under the Uniform Code of Military Justice for other covered misconduct, and no element of any such case file may be destroyed until the expiration of such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c7a71a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Return of personal property upon completion of related proceedings in unrestricted reporting cases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding the records and evidence retention requirements described in paragraphs (1)(E) and (2), personal property retained as evidence in connection with an incident of rape or sexual assault, as described in sections 920(a) and 920(b) of title 10 (articles 120(a) and 120(b) of the Uniform Code of Military Justice), involving a member of the Coast Guard may be returned to the rightful owner of such property after the conclusion of all legal, adverse action, and administrative proceedings related to such incident, as determined by the Commandant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c7a71b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Return of personal property in restricted reporting cases.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c7a71c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe procedures under which a victim who files a restricted report of an incident of sexual assault may request, at any time, the return of any personal property of the victim obtained as part of the sexual assault forensic examination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a71d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The procedures required by subparagraph (A) shall ensure that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56c7a71e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request by a victim for the return of personal property described under subparagraph (A) may be made on a confidential basis and without affecting the restricted nature of the restricted report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c7a71f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at the time of the filing of the restricted report, a Special Victims’ Counsel, Sexual Assault Response Coordinator, or Sexual Assault Prevention and Response Victim Advocate—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id56c7a720-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/5/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informs the victim that the victim may request the return of personal property as described in such subparagraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id56c7a721-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/5/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advises the victim that such a request for the return of personal property may negatively impact a subsequent case adjudication if the victim later decides to convert the restricted report to an unrestricted report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a722-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except with respect to personal property returned to a victim under this paragraph, nothing in this paragraph may be construed to affect the requirement to retain a sexual assault forensic examination kit for the period specified in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c7a723-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Victim access to records","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to victim access to records after all final disposition actions and any appeals have been completed, as applicable, the comprehensive policy required by subsection (a) shall provide that, to the maximum extent practicable, and in such a manner that will not jeopardize an active investigation or an active case—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c7a724-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a victim of covered misconduct in a case in which either the victim or alleged perpetrator is a covered person shall have access to all records that are directly related to the victim’s case, or related to the victim themselves, in accordance with the policy issued under subsection (a) and subject to required protections under sections 552 and 552a of title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a725-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a victim of covered misconduct who requests access to records under section 552 or 552a of title 5 concerning the victim’s case shall be determined to have a compelling need, and the records request shall be processed under expedited processing procedures, if in the request for such records the victim indicates that the records concerned are related to the covered misconduct case;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a726-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in applying sections 552 and 552a of title 5 to the redaction of information related to a records request by a victim of covered misconduct made under such sections after all final disposition actions and any appeals have been completed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56c7a727-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/6/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any such redaction shall be applied to the minimum extent possible so as to ensure the provision of the maximum amount of unredacted information to the victim that is permissible by law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c7a728-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/6/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any such redaction shall not be applied to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id56c7a729-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/6/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receipt by the victim of the victim’s own statement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id56c7a72a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/6/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the victim’s information from an investigation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c7a72b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/c/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of such a records request for which the timelines for expedited processing are not met, the Commandant shall provide to the Secretary, the Committee on Commerce, Science, and Transportation of the Senate, and the Committee on Transportation and Infrastructure of the House of Representatives in person and in writing a briefing that explains the reasons for the denial or the delay in processing, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c7a72c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Covered Person","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered person” includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c7a72d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Coast Guard on active duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c7a72e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Coast Guard Reserve with respect to crimes investigated by or reported to the Secretary on any date on which such member is in a military status under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s802"},"text":"section 802 of title 10","children":[],"tail":" (article 2 of the Uniform Code of Military Justice);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c7a72f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a former member of the Coast Guard with respect to crimes investigated by or reported to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c7a730-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an investigation of covered misconduct conducted by, or an incident of covered misconduct reported to, the Coast Guard involving a civilian employee of the Coast Guard, any such civilian employee of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c7a731-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2531/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Clause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section authorizes or requires, or shall be construed to authorize or require, the discovery, inspection, or production of reports, memoranda, or other internal documents or work product generated by counsel, an attorney for the Government, or their assistants or representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56c7a732-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXV/s7511/a"},"text":"Pub. L. 119–60, div. G, title LXXV, § 7511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1790"},"text":"139 Stat. 1790","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c7a733-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c7a734-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56c7a735-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Coast Guard Authorization Act of 2025, referred to in subsec. (a), is the date of enactment of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56c7a736-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2531, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"act Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/526"},"text":"63 Stat. 526","children":[],"tail":", § 432; "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch650"},"text":"Aug. 9, 1955, ch. 650","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/69/577"},"text":"69 Stat. 577","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/309"},"text":"Pub. L. 86–309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-21"},"text":"Sept. 21, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/585"},"text":"73 Stat. 585","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/278/s1/10"},"text":"Pub. L. 91–278, § 1(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-12"},"text":"June 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/305"},"text":"84 Stat. 305","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/23/s5/a"},"text":"Pub. L. 96–23, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-06-13"},"text":"June 13, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/68"},"text":"93 Stat. 68","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s2/11"},"text":"Pub. L. 97–295, § 2(11)","children":[],"tail":", (13), "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1302"},"text":"96 Stat. 1302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/3/B"},"text":"Pub. L. 98–557, § 15(a)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/640/s10/a/7"},"text":"Pub. L. 99–640, § 10(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3549"},"text":"100 Stat. 3549","children":[],"tail":"; renumbered § 2531, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s114/b"},"text":"Pub. L. 115–282, title I, § 114(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4223"},"text":"132 Stat. 4223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(21), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4748"},"text":"134 Stat. 4748","children":[],"tail":", which related to personnel of former Lighthouse Service, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXVIII/s11808/a/18"},"text":"Pub. L. 117–263, div. K, title CXVIII, § 11808(a)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4166"},"text":"136 Stat. 4166","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
