{"tag":"section","attrib":{"id":"id56b95081-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2128"},"text":null,"children":[{"tag":"num","attrib":{"value":"2128"},"text":"§ 2128.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recall to active duty with consent of officer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56b95082-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2128/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any regular officer on the retired list may, with that officer’s consent, be assigned to such duties as that officer may be able to perform.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b95083-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2128/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of retired officers on active duty in the grade of lieutenant commander, commander, or captain shall not exceed 2 percent of the authorized number of officers on active duty in each such grade. However, this limitation does not apply to retired officers of these grades recalled to serve as members of courts, boards, panels, surveys, or special projects for periods not to exceed one year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56b95084-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/189"},"text":"77 Stat. 189","children":[],"tail":", § 332; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/444/s1/18"},"text":"Pub. L. 89–444, § 1(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-06-09"},"text":"June 9, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/196"},"text":"80 Stat. 196","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/278/s1/9"},"text":"Pub. L. 91–278, § 1(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-12"},"text":"June 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/305"},"text":"84 Stat. 305","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/241/s14"},"text":"Pub. L. 102–241, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2213"},"text":"105 Stat. 2213","children":[],"tail":"; renumbered § 2128, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s112/b"},"text":"Pub. L. 115–282, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56b95085-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56b95086-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56b95087-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s332"},"text":"section 332 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/241/s14/b"},"text":"Pub. L. 102–241, § 14(b)","children":[],"tail":", substituted “that officer’s” for “his” and “that officer” for “he”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/241/s14/a"},"text":"Pub. L. 102–241, § 14(a)","children":[],"tail":", substituted “2” for “1”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/278"},"text":"Pub. L. 91–278","children":[],"tail":" struck out prohibition against recall to duty in time of peace of any officer on retired list who reached age of sixty-two years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/444"},"text":"Pub. L. 89–444","children":[],"tail":" provided that the percentage limitation on the number of retired officers on active duty in the grade of lieutenant commander, commander, or captain should not apply to retired officers of those grades recalled to serve as members of courts, boards, panels, surveys, or special projects for periods not to exceed one year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
