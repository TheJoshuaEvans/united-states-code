{"tag":"section","attrib":{"id":"id56ced31c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2765"},"text":null,"children":[{"tag":"num","attrib":{"value":"2765"},"text":"§ 2765.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retroactive payment of pay and allowances delayed by administrative error or oversight","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary, the Coast Guard may authorize retroactive payment of pay and allowances, including selective reenlistment bonuses, to enlisted members if entitlement to the pay and allowances was delayed in vesting solely because of an administrative error or oversight.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56ced31d-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/448/s13/a"},"text":"Pub. L. 100–448, § 13(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-28"},"text":"Sept. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1844"},"text":"102 Stat. 1844","children":[],"tail":", § 513; renumbered § 2765, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ced31e-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ced31f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"