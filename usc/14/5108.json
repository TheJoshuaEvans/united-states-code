{"tag":"section","attrib":{"id":"id56df7530-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5108"},"text":null,"children":[{"tag":"num","attrib":{"value":"5108"},"text":"§ 5108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfunded priorities list","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56df7531-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date on which the President submits to Congress a budget pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the Commandant shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a list of each unfunded priority for the Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56df7532-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prioritization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The list required under subsection (a) shall present the unfunded priorities in order from the highest priority to the lowest, as determined by the Commandant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56df7533-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unfunded Priority Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “unfunded priority” means a program or mission requirement that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56df7534-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5108/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not been selected for funding in the applicable proposed budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df7535-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5108/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to fulfill a requirement associated with an operational need; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56df7536-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s5108/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commandant would have recommended for inclusion in the applicable proposed budget had additional resources been available or had the requirement emerged before the budget was submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56df7537-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIII/s317/b"},"text":"Pub. L. 115–282, title III, § 317(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4251"},"text":"132 Stat. 4251","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
