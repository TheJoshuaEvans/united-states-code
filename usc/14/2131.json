{"tag":"section","attrib":{"id":"id56bbc0a6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131"},"text":null,"children":[{"tag":"num","attrib":{"value":"2131"},"text":"§ 2131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" College student pre-commissioning initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56bbc0a7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized within the Coast Guard a college student pre-commissioning initiative program (in this section referred to as the “Program” ) for eligible undergraduate students to enlist and receive a guaranteed commission as an officer in the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56bbc0a8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Selection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for the Program a student must meet the following requirements upon submitting an application:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56bbc0a9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Age","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A student must be not less than 19 years old and not more than 27 years old as of September 30 of the fiscal year in which the Program selection panel selecting such student convenes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56bbc0aa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Character.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56bbc0ab-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"All applicants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All applicants must be of outstanding moral character and meet other character requirements as set forth by the Commandant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56bbc0ac-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coast guard applicants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An applicant serving in the Coast Guard may not be commissioned if in the 36 months prior to the first Officer Candidate School class convening date in the selection cycle, such applicant was convicted by a court-martial or awarded nonjudicial punishment, or did not meet performance or character requirements set forth by the Commandant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56bbc0ad-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Citizenship","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A student must be a United States citizen.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56bbc0ae-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clearance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A student must be eligible for a secret clearance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56bbc0af-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dependency.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56bbc0b0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A student may not have more than 2 dependents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56bbc0b1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sole custody","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A student who is single may not have sole or primary custody of dependents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56bbc0b2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Education.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56bbc0b3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Institution","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A student must be an undergraduate sophomore or junior—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56bbc0b4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a historically Black college or university described in section 322(2) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061/2"},"text":"20 U.S.C. 1061(2)","children":[],"tail":") or an institution of higher education described in section 371(a) of the Higher Education Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q/a"},"text":"20 U.S.C. 1067q(a)","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56bbc0b5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an undergraduate sophomore or junior enrolled at an institution of higher education (as defined in section 101 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"20 U.S.C. 1001","children":[],"tail":")) that, at the time of application of the sophomore or junior, has had for 3 consecutive years an enrollment of undergraduate full-time equivalent students (as defined in section 312(e) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1058/e"},"text":"20 U.S.C. 1058(e)","children":[],"tail":")) that is a total of at least 50 percent Black American, Hispanic, Asian American (as defined in section 371(c) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q/c"},"text":"20 U.S.C. 1067q(c)","children":[],"tail":")), Native American Pacific Islander (as defined in such section), or Native American (as defined in such section), among other criteria, as determined by the Commandant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56bbc0b6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Location","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The institution at which such student is an undergraduate must be within 100 miles of a Coast guard ","children":[{"tag":"ref","attrib":{"idref":"fn002029"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002029"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Guard”."}],"tail":" unit or Coast Guard Recruiting Office unless otherwise approved by the Commandant."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56bbc0b7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A student must meet credit and grade point average requirements set forth by the Commandant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56bbc0b8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Medical and administrative","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A student must meet other medical and administrative requirements as set forth by the Commandant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56bbc0b9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enlistment and Obligation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Individuals selected and accept to participate in the Program shall enlist in the Coast Guard in pay grade E–3 with a 4-year duty obligation and 4-year inactive Reserve obligation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56bbc0ba-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Activities Prior to Officer Candidate School","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Individuals enrolled in the Program shall participate in military activities each month, as required by the Commandant, prior to attending Officer Candidate School.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56bbc0bb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation in Officer Candidate School","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each graduate of the Program shall attend the first enrollment of Officer Candidate School that commences after the date of such graduate’s graduation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56bbc0bc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commissioning","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon graduation from Officer Candidate School, Program graduates shall be discharged from enlisted status and commissioned as an O–1 with an initial 3-year duty obligation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56bbc0bd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefing.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56bbc0be-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than August 15 of each year, the Commandant shall provide a briefing to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate on the Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56bbc0bf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The briefing required under paragraph (1) shall describe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56bbc0c0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach and recruitment efforts over the previous year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56bbc0c1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demographic information of enrollees including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56bbc0c2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" race;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56bbc0c3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ethnicity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56bbc0c4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/g/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56bbc0c5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/g/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geographic origin; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56bbc0c6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2131/g/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56bbc0c7-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8276(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4685"},"text":"134 Stat. 4685","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
