attrib":{},"text":"Partnership Program To Diversify Coast Guard","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXII/s11246"},"text":"Pub. L. 117–263, div. K, title CXII, § 11246","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4046"},"text":"136 Stat. 4046","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dK/tCXII/s11246"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant [of the Coast Guard] shall establish a program for the purpose of increasing the number of individuals in the enlisted ranks of the Coast Guard who are—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" underrepresented minorities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Partnerships","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program established under subsection (a), the Commandant shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" seek to enter into 1 or more partnerships with eligible institutions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the visibility of Coast Guard careers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to promote curriculum development—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable acceptance into the Coast Guard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve success on relevant exams, such as the Armed Services Vocational Aptitude Battery; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide mentoring for students entering and beginning Coast Guard careers; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into a partnership with an existing Junior Reserve Officers’ Training Corps for the purpose of promoting Coast Guard careers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible institution","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘eligible institution’ means an institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (as such term is defined in section 101 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"20 U.S.C. 1001","children":[],"tail":")); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a junior or community college (as such term is defined in section 312 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1058"},"text":"20 U.S.C. 1058","children":[],"tail":")[)]; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a part B institution (as such term is defined in section 322 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061"},"text":"20 U.S.C. 1061","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Tribal College or University (as such term is defined in section 316(b) of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c/b"},"text":"20 U.S.C. 1059c(b)","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Hispanic-serving institution (as such term is defined in section 502 of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1101a"},"text":"20 U.S.C. 1101a","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"“(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Alaska Native-serving institution or a Native Hawaiian-serving institution (as such term is defined in section 317(b) of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059d/b"},"text":"20 U.S.C. 1059d(b)","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"“(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Predominantly Black institution (as such term is defined in section 371(c) of that Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q/c"},"text":"20 U.S.C. 1067q(c)","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"“(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Asian American and Native American Pacific Islander-serving institution (as defined in section 320(b) of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059g/b"},"text":"20 U.S.C. 1059g(b)","children":[],"tail":")); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"“(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Native American-serving nontribal institution (as defined in section 319(b) of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059f/b"},"text":"20 U.S.C. 1059f(b)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rural area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘rural area’ means an area that is outside of an urbanized area, as determined by the Bureau of the Census.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
