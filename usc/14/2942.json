{"tag":"section","attrib":{"id":"id56d38e97-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2942"},"text":null,"children":[{"tag":"num","attrib":{"value":"2942"},"text":"§ 2942.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d38e98-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2942/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any other authority providing for the acquisition or construction of military family housing or military unaccompanied housing, the Secretary may acquire or construct the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d38e99-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2942/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military family housing on or near Coast Guard installations within the United States and its territories and possessions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d38e9a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2942/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military unaccompanied housing on or near such Coast Guard installations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d38e9b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2942/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No appropriation shall be made to acquire or construct military family housing or military unaccompanied housing under this chapter if that acquisition or construction has not been approved by resolutions adopted by the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d38e9c-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tII/s208/a"},"text":"Pub. L. 104–324, title II, § 208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3909"},"text":"110 Stat. 3909","children":[],"tail":", § 681; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIV/s402/a"},"text":"Pub. L. 107–295, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2113"},"text":"116 Stat. 2113","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tII/s221/a/2"},"text":"Pub. L. 111–281, title II, § 221(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2919"},"text":"124 Stat. 2919","children":[],"tail":"; renumbered § 2942, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s117/b"},"text":"Pub. L. 115–282, title I, § 117(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4230"},"text":"132 Stat. 4230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d38e9d-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d38e9e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d38e9f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s681"},"text":"section 681 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s221/a/2/A"},"text":"Pub. L. 111–281, § 221(a)(2)(A)","children":[],"tail":", in introductory provisions, substituted “acquire or construct the following:” for “exercise any authority or any combination of authorities provided under this chapter in order to provide for the acquisition or construction by private persons, including a small business concern qualified under section 8(a) of the Small Business Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/a"},"text":"15 U.S.C. 637(a)","children":[],"tail":"), of the following:”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s221/a/2/B"},"text":"Pub. L. 111–281, § 221(a)(2)(B)","children":[],"tail":", substituted “Military family housing” for “Family housing units”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s221/a/2/C"},"text":"Pub. L. 111–281, § 221(a)(2)(C)","children":[],"tail":", substituted “Military unaccompanied housing” for “Unaccompanied housing units”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295"},"text":"Pub. L. 107–295","children":[],"tail":" inserted “, including a small business concern qualified under section 8(a) of the Small Business Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/a"},"text":"15 U.S.C. 637(a)","children":[],"tail":"),” after “private persons” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
