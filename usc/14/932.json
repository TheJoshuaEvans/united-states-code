{"tag":"section","attrib":{"id":"id56a3f30e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s932"},"text":null,"children":[{"tag":"num","attrib":{"value":"932"},"text":"§ 932.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of oaths","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a3f30f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s932/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such commissioned and warrant officers of the Coast Guard as may be designated by the Commandant may, pursuant to rules prescribed by the Commandant, exercise the general powers of a notary public in the administration of oaths for the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a3f310-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s932/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execution, acknowledgment, and attestation of instruments and papers, oaths of allegiance in connection with recruiting, oaths in connection with courts and boards, and all other notarial acts in connection with the proper execution of Coast Guard functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f311-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s932/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execution, acknowledgment, and attestation of instruments and papers, and all other notarial acts in time of war or national emergency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f312-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s932/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execution, acknowledgment, and attestation of instruments and papers, and all other notarial acts in Alaska and places beyond the continental limits of the United States where the Coast Guard is serving.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a3f313-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s932/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No fee of any character shall be charged by any commissioned or warrant officer for performing notarial acts. The signature and indication of grade of any commissioned or warrant officer performing any notarial act shall be prima facie evidence of his authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a3f314-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/545"},"text":"63 Stat. 545","children":[],"tail":", § 636; renumbered § 932, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s107/b"},"text":"Pub. L. 115–282, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4205"},"text":"132 Stat. 4205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a3f315-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56a3f316-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., §§ 26, 27 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1908-04-16/ch145/s12"},"text":"Apr. 16, 1908, ch. 145, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/63"},"text":"35 Stat. 63","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1920-06-05/ch235/s1"},"text":"June 5, 1920, ch. 235, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/880"},"text":"41 Stat. 880","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said sections are rewritten, the provisions concerning oaths being broadened to conform more closely to law applicable to officers of the Navy (see title 34, U.S.C., 1946 ed., § 217a). 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a3f317-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a3f318-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s636"},"text":"section 636 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
