{"tag":"section","attrib":{"id":"id569cc6fc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s563"},"text":null,"children":[{"tag":"num","attrib":{"value":"563"},"text":"§ 563.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of certain determinations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id569cc6fd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s563/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At least 90 days prior to making a final determination that a waterway, or a portion thereof, is navigable for purposes of the jurisdiction of the Coast Guard, the Commandant shall provide notification regarding the proposed determination to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id569cc6fe-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s563/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Governor of each State in which such waterway, or portion thereof, is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569cc6ff-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s563/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569cc700-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s563/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569cc701-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s563/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each notification provided under subsection (a) to an entity specified in paragraph (3) of that subsection shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id569cc702-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s563/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of whether vessels operating on the waterway, or portion thereof, subject to the proposed determination are subject to inspection or similar regulation by State or local officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569cc703-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s563/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of whether operators of commercial vessels on such waterway, or portion thereof, are subject to licensing or similar regulation by State or local officials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569cc704-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s563/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the annual costs that the Coast Guard may incur in conducting operations on such waterway, or portion thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id569cc705-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s210/a"},"text":"Pub. L. 113–281, title II, § 210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3027"},"text":"128 Stat. 3027","children":[],"tail":", § 103; renumbered § 563, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s105/b"},"text":"Pub. L. 115–282, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4200"},"text":"132 Stat. 4200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569cc706-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569cc707-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id569cc708-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For redesignation of prior sections 563 to 688 not listed below as having been previously repealed or renumbered, see Table Showing Redesignations Made by Title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 563 to 567 were repealed by ","children":[{