{"tag":"section","attrib":{"id":"id56ab1fcf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1154"},"text":null,"children":[{"tag":"num","attrib":{"value":"1154"},"text":"§ 1154.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement of buoy chain","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56ab1fd0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1154/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (b), the Coast Guard may not procure buoy chain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ad68c1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1154/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not manufactured in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad68c2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1154/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially all of the components of which are not produced or manufactured in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ad68c3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1154/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Coast Guard may procure buoy chain that is not manufactured in the United States if the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ad68c4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1154/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the price of buoy chain manufactured in the United States is unreasonable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad68c5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1154/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency circumstances exist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ad68c6-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tXI/s1128/a"},"text":"Pub. L. 104–324, title XI, § 1128(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3984"},"text":"110 Stat. 3984","children":[],"tail":", § 97; renumbered § 1154, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s108/b"},"text":"Pub. L. 115–282, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4208"},"text":"132 Stat. 4208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ad68c7-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ad68c8-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ad68c9-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s97"},"text":"section 97 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
