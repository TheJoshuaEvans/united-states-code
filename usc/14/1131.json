{"tag":"section","attrib":{"id":"id56a8adee-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1131"},"text":null,"children":[{"tag":"num","attrib":{"value":"1131"},"text":"§ 1131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of major system acquisitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a8adef-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8adf0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1131/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support mechanisms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall develop and implement mechanisms to support the establishment of mature and stable operational requirements for all acquisitions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8adf1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1131/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mission analysis; affordability assessment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant may not initiate a Level 1 or Level 2 acquisition project or program until the Commandant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a8adf2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1131/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" completes a mission analysis that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56a8adf3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1131/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the specific capability gaps to be addressed by the project or program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56a8adf4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1131/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops a clear mission need to be addressed by the project or program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a8adf5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1131/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepares a preliminary affordability assessment for the project or program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8adf6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8adf7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1131/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The mechanisms required by subsection (a) shall ensure the implementation of a formal process for the development of a mission-needs statement, concept-of-operations document, capability development plan, and resource proposal for the initial project or program funding, and shall ensure the project or program is included in the Coast Guard Capital Investment Plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8adf8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1131/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment of trade-offs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In conducting an affordability assessment under subsection (a)(2)(B), the Commandant shall develop and implement mechanisms to ensure that trade-offs among cost, schedule, and performance are considered in the establishment of preliminary operational requirements for development and production of new assets and capabilities for Level 1 and Level 2 acquisitions projects and programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8adf9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1131/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Human Resource Capital Planning","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall develop staffing predictions, define human capital performance initiatives, and identify preliminary training needs required to implement each Level 1 and Level 2 acquisition project and program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a8adfa-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIV/s402/a"},"text":"Pub. L. 111–281, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2941"},"text":"124 Stat. 2941","children":[],"tail":", § 571; renumbered § 1131, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s108/b"},"text":"Pub. L. 115–282, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4208"},"text":"132 Stat. 4208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a8adfb-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a8adfc-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a8adfd-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s571"},"text":"section 571 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
