{"tag":"section","attrib":{"id":"id62ae047a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2902"},"text":null,"children":[{"tag":"num","attrib":{"value":"2902"},"text":"§ 2902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae047b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Native American” means an Indian, Native Hawaiian, or Native American Pacific Islander.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae047c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Indian” has the meaning given to such term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7491/3"},"text":"section 7491(3) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae047d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2902/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Native Hawaiian” has the meaning given to such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7517"},"text":"section 7517 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae047e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2902/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Native American Pacific Islander” means any descendent of the aboriginal people of any island in the Pacific Ocean that is a territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae047f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2902/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “Indian tribe” and “tribal organization” have the respective meaning given to each of such terms under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0480-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2902/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Native American language” means the historical, traditional languages spoken by Native Americans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0481-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2902/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “traditional leaders” includes Native Americans who have special expertise in Native American culture and Native American languages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0482-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2902/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Indian reservation” has the same meaning given to the term “reservation” under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1452"},"text":"section 1452 of this title","children":[],"tail":"."}],"tai