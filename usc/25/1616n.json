{"tag":"section","attrib":{"id":"id625f6f0b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616n"},"text":null,"children":[{"tag":"num","attrib":{"value":"1616n"},"text":"§ 1616n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal health program administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall, by contract or otherwise, provide training for individuals in the administration and planning of tribal health programs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id625f6f0c-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tI/s121"},"text":"Pub. L. 94–437, title I, § 121","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tI/s113"},"text":"Pub. L. 102–573, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4542"},"text":"106 Stat. 4542","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
