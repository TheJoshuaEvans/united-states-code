{"tag":"section","attrib":{"id":"id62f34b95-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421"},"text":null,"children":[{"tag":"num","attrib":{"value":"5421"},"text":"§ 5421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Fund for Excellence in American Indian Education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f34b96-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2000-12-27"},"text":"December 27, 2000","children":[],"tail":", the Secretary of the Interior shall establish, under the laws of the District of Columbia and in accordance with this subchapter, a foundation to be known as the “National Fund for Excellence in American Indian Education” (hereinafter referred to as the “Foundation”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b97-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Perpetual existence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided, the Foundation shall have perpetual existence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b98-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nature of corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall be a charitable and nonprofit federally chartered corporation and shall not be an agency or instrumentality of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b99-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Place of incorporation and domicile","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall be incorporated and domiciled in the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b9a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Foundation shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34b9b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage, accept, and administer private gifts of real and personal property or any income therefrom or other interest therein for the benefit of, or in support of, the mission of the Office of Indian Education Programs of the Bureau of Indian Affairs (or its successor office);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b9c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to undertake and conduct such other activities as will further the educational opportunities of American Indians who attend a Bureau funded school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b9d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to participate with, and otherwise assist, Federal, State, and tribal governments, agencies, entities, and individuals in undertaking and conducting activities that will further the educational opportunities of American Indians attending Bureau funded schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b9e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Directors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34b9f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Directors shall be the governing body of the Foundation. The Board may exercise, or provide for the exercise of, the powers of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34ba0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The number of members of the Board, the manner of their selection (including the filling of vacancies), and their terms of office shall be as provided in the constitution and bylaws of the Foundation. However, the Board shall have at least 11 members, two of whom shall be the Secretary and the Assistant Secretary of the Interior for Indian Affairs, who shall serve as ex officio nonvoting members, and the initial voting members of the Board shall be appointed by the Secretary not later than 6 months after the date that the Foundation is established and shall have staggered terms (as determined by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34ba1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Board shall be United States citizens who are knowledgeable or experienced in American Indian education and shall, to the extent practicable, represent diverse points of view relating to the education of American Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34ba2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board shall not receive compensation for their services as members, but shall be reimbursed for actual and necessary travel and subsistence expenses incurred by them in the performance of the duties of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34ba3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34ba4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The officers of the Foundation shall be a secretary, elected from among the members of the Board, and any other officers provided for in the constitution and bylaws of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34ba5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of Foundation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The secretary shall serve, at the direction of the Board, as its chief operating officer and shall be knowledgeable and experienced in matters relating to education in general and education of American Indians in particular.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34ba6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The manner of election, term of office, and duties of the officers shall be as provided in the constitution and bylaws of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34ba7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34ba8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall adopt a constitution and bylaws for the management of its property and the regulation of its affairs, which may be amended;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34ba9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may adopt and alter a corporate seal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34baa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make contracts, subject to the limitations of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34bab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may acquire (through a gift or otherwise), own, lease, encumber, and transfer real or personal property as necessary or convenient to carry out the purposes of the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34bac-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may sue and be sued; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34bad-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may perform any other act necessary and proper to carry out the purposes of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34bae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The principal office of the Foundation shall be in the District of Columbia. However, the activities of the Foundation may be conducted, and offices may be maintained, throughout the United States in accordance with the constitution and bylaws of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34baf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall comply with the law on service of process of each State in which it is incorporated and of each State in which the Foundation carries on activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34bb0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of officers and agents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall be liable for the acts of its officers and agents acting within the scope of their authority. Members of the Board are personally liable only for gross negligence in the performance of their duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34bb1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34bb2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on spending","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning with the fiscal year following the first full fiscal year during which the Foundation is in operation, the administrative costs of the Foundation may not exceed 10 percent of the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f34bb3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/l/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts transferred to the Foundation under subsection (m) of this section during the preceding fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f34bb4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/l/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donations received from private sources during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34bb5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and hiring","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appointment of officers and employees of the Foundation shall be subject to the availability of funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34bb6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board, and the officers, employees, and agents of the Foundation are not, by reason of their association with the Foundation, officers, employees, or agents of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34bb7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of donated funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may transfer to the Foundation funds held by the Department of the Interior under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5341"},"text":"section 5341 of this title","children":[],"tail":", if the transfer or use of such funds is not prohibited by any term under which the funds were donated."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34bb8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5421/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall comply with the audit requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s10101"},"text":"section 10101 of title 36","children":[],"tail":", as if it were a corporation in part B of subtitle II of that title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f34bb9-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tVIII/s801"},"text":"Pub. L. 93–638, title VIII, § 801","children":[],"tail":", formerly title V, § 501, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tXIII/s1302"},"text":"Pub. L. 106–568, title XIII, § 1302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2936"},"text":"114 Stat. 2936","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/267/s1/a"},"text":"Pub. L. 108–267, § 1(a)","children":[],"tail":",(b)(2), "},{"tag":"date","attrib":{"date":"2004-07-02"},"text":"July 2, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/797"},"text":"118 Stat. 797","children":[],"tail":"; renumbered title VIII, § 801, "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s231/d/1"},"text":"Pub. L. 111–211, title II, § 231(d)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2278"},"text":"124 Stat. 2278","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62f34bba-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62f34bbb-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62f34bbc-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (h)(3), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", known as the Indian Self-Determination and Education Assistance Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62f34bbd-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s458ddd"},"text":"section 458ddd of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62f34bbe-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/267/s1/b/2"},"text":"Pub. L. 108–267, § 1(b)(2)","children":[],"tail":", substituted “National Fund for Excellence in American Indian Education” for “American Indian Education Foundation” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/267/s1/a"},"text":"Pub. L. 108–267, § 1(a)","children":[],"tail":", substituted “a foundation to be known as the ‘National Fund for Excellence in American Indian Education’ (hereinafter referred to as the ‘Foundation’)” for “the American Indian Education Foundation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62f34bbf-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id62f34bc0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of this subchapter as the “American Indian Education Foundation Act of 2000”, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s1301"},"text":"section 1301 of Pub. L. 106–568","children":[],"tail":", set out as a Short Title of 2000 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
