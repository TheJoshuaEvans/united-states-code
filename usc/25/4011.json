{"tag":"section","attrib":{"id":"id62c8438e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4011"},"text":null,"children":[{"tag":"num","attrib":{"value":"4011"},"text":"§ 4011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility of Secretary to account for daily and annual balances of Indian trust funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c8438f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall account for the daily and annual balance of all funds held in trust by the United States for the benefit of an Indian tribe or an individual Indian which are deposited or invested pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s162a"},"text":"section 162a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c84390-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic statement of performance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 20 business days after the close of a calendar quarter, the Secretary shall provide a statement of performance to each Indian tribe and individual with respect to whom funds are deposited or invested pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s162a"},"text":"section 162a of this title","children":[],"tail":". The statement, for the period concerned, shall identify—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c84391-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4011/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the source, type, and status of the funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c84392-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4011/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the beginning balance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c84393-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4011/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gains and losses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c84394-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4011/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receipts and disbursements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c84395-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4011/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ending balance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c84396-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4011/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall cause to be conducted an annual audit on a fiscal year basis of all funds held in trust by the United States for the benefit of an Indian tribe or an individual Indian which are deposited or invested pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s162a"},"text":"section 162a of this title","children":[],"tail":", and shall include a letter relating to the audit in the first statement of performance provided under subsection (b) after the completion of the audit."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c84397-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/412/tI/s102"},"text":"Pub. L. 103–412, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4240"},"text":"108 Stat. 4240","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c84398-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62c84399-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62c8439a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Performance and Account Statements for Inactive Accounts","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions stating that the Secretary was not required to provide a quarterly statement of performance for any Indian trust account that had not had activity for at least 18 months and had a balance of $1.00 or less but was required to issue an annual account statement and maintain a record of any such accounts and to permit the balance in each such account to be withdrawn upon the express written request of the account holder, were contained in Department of the Interior, Environment, and Related Agencies Appropriations Act, 2006, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/54/tI"},"text":"Pub. L. 109–54, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/519"},"text":"119 Stat. 519","children":[],"tail":", and were repeated in provisions of subsequent appropriations acts which are not set out in the Code. Similar provisions were also contained in the following prior appropriations acts:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dE/tI"},"text":"Pub. L. 108–447, div. E, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3061"},"text":"118 Stat. 3061","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/108/tI"},"text":"Pub. L. 108–108, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-10"},"text":"Nov. 10, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1263"},"text":"117 Stat. 1263","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tI"},"text":"Pub. L. 108–7, div. F, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/236"},"text":"117 Stat. 236","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/63/tI"},"text":"Pub. L. 107–63, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-05"},"text":"Nov. 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/435"},"text":"115 Stat. 435","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/291/tI"},"text":"Pub. L. 106–291, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-11"},"text":"Oct. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/939"},"text":"114 Stat. 939","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/3/tI"},"text":"Pub. L. 106–113, div. B, § 1000(a)(3) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–153."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tI"},"text":"Pub. L. 105–277, div. A, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–251."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
