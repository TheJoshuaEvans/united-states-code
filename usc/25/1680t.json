{"tag":"section","attrib":{"id":"id6279ad8f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t"},"text":null,"children":[{"tag":"num","attrib":{"value":"1680t"},"text":"§ 1680t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other GAO reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6279ad90-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6279ad91-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Comptroller General of the United States shall conduct a study, and evaluate the effectiveness, of coordination of health care services provided to Indians—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6279ad92-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through Medicare, Medicaid, or SCHIP;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ad93-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ad94-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" using funds provided by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6279ad95-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State or local governments; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6279ad96-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279ad97-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Comptroller General shall submit to Congress a report—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6279ad98-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the results of the evaluation under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ad99-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containing recommendations of the Comptroller General regarding measures to support and increase coordination of the provision of health care services to Indians as described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6279ad9a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for contract health services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6279ad9b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General shall conduct a study on the use of health care furnished by health care providers under the contract health services program funded by the Service and operated by the Service, an Indian tribe, or a tribal organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279ad9c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study conducted under paragraph (1) shall include an analysis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6279ad9d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts reimbursed under the contract health services program described in paragraph (1) for health care furnished by entities, individual providers, and suppliers, including a comparison of reimbursement for that health care through other public programs and in the private sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ad9e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" barriers to accessing care under such contract health services program, including barriers relating to travel distances, cultural differences, and public and private sector reluctance to furnish care to patients under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ad9f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of existing Federal funding for health care under the contract health services program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ada0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administration of the contract health service program, including the distribution of funds to Indian health programs pursuant to the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ada1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other items determined appropriate by the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279ada2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Comptroller General shall submit to Congress a report on the study conducted under paragraph (1), together with recommendations regarding—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6279ada3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate level of Federal funding that should be established for health care under the contract health services program described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ada4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how to most efficiently use that funding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ada5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of any inequities in the current distribution formula or inequitable results for any Indian tribe under the funding level, and any recommendations for addressing any inequities or inequitable results identified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279ada6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680t/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting the study under paragraph (1) and preparing the report under paragraph (3), the Comptroller General shall consult with the Service, Indian tribes, and tribal organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6279ada7-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s830"},"text":"Pub. L. 94–437, title VIII, § 830","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6279ada8-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6279ada9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6279adaa-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s830"},"text":"Section 830 of Pub. L. 94–437","children":[],"tail":" is based on section 199 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
