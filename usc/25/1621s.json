{"tag":"section","attrib":{"id":"id62669b11-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621s"},"text":null,"children":[{"tag":"num","attrib":{"value":"1621s"},"text":"§ 1621s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prompt action on payment of claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62669b12-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of response","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Service shall respond to a notification of a claim by a provider of a contract care service with either an individual purchase order or a denial of the claim within 5 working days after the receipt of such notification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62669b13-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to timely respond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Service fails to respond to a notification of a claim in accordance with subsection (a), the Service shall accept as valid the claim submitted by the provider of a contract care service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62669b14-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621s/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Service shall pay a completed contract care service claim within 30 days after completion of the claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62669b15-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tII/s220"},"text":"Pub. L. 94–437, title II, § 220","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tII/s215"},"text":"Pub. L. 102–573, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4558"},"text":"106 Stat. 4558","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
