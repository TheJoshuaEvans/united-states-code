{"tag":"section","attrib":{"id":"id6236d883-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s396f"},"text":null,"children":[{"tag":"num","attrib":{"value":"396f"},"text":"§ 396f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands excepted from leasing provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Sections 396a, 396b, 396c, and 396d of this title shall not apply to the Crow Reservation in Montana, the ceded lands of the Shoshone Reservation in Wyoming, the Osage Reservation in Oklahoma, nor to the coal and asphalt lands of the Choctaw and Chickasaw Tribes in Oklahoma.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6236d884-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-05-11/ch198/s6"},"text":"May 11, 1938, ch. 198, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/348"},"text":"52 Stat. 348","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-05-27/ch106/s2"},"text":"May 27, 1955, ch. 106, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/68"},"text":"69 Stat. 68","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6236d885-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6236d886-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6236d887-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1955—Act ","children":[{"tag":"date","attrib":{"date":"1955-05-27"},"text":"May 27, 195