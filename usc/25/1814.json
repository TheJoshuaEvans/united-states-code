{"tag":"section","attrib":{"id":"id6280b285-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1814"},"text":null,"children":[{"tag":"num","attrib":{"value":"1814"},"text":"§ 1814.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6280b286-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1814/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of Navajo Tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Navajo Tribe shall not be eligible to participate under the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6280b287-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1814/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discriminatory practices prohibited","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6280b288-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1814/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall not provide any funds to any institution which denies admission to any Indian student because such individual is not a member of a specific Indian tribe, or which denies admission to any Indian student because such individual is a member of a specific tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6280b289-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1814/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall take steps to recover any unexpended and unobligated funds provided under this subchapter held by an institution determined to be in violation of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6280b28a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/tI/s114"},"text":"Pub. L. 95–471, title I, § 114","children":[],"tail":", formerly § 113, "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1329"},"text":"92 Stat. 1329","children":[],"tail":"; renumbered § 114, "},{"tag":"ref","attrib":{"href":"/us/pl/98/192/s4/a/1"},"text":"Pub. L. 98–192, § 4(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1336"},"text":"97 Stat. 1336","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
