{"tag":"section","attrib":{"id":"id62d69a9b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303"},"text":null,"children":[{"tag":"num","attrib":{"value":"4303"},"text":"§ 4303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Native American Business Development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d69a9c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d69a9d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Office of the Secretary an office known as the Office of Native American Business Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69a9e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be headed by a Director, appointed by the Secretary, whose title shall be the Director of Native American Business Development. The Director shall be compensated at a rate not to exceed level V of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d69a9f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d69aa0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director, shall ensure the coordination of Federal programs that provide assistance, including financial and technical assistance, to eligible entities for increased business, the expansion of trade by eligible entities, and economic development on Indian lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69aa1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director, shall coordinate Federal programs relating to Indian economic development, including any such program of the Department of the Interior, the Small Business Administration, the Department of Labor, or any other Federal agency charged with Indian economic development responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69aa2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the duties described in paragraph (1), the Secretary, acting through the Director, shall ensure the coordination of, or, as appropriate, carry out—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d69aa3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal programs designed to provide legal, accounting, or financial assistance to eligible entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69aa4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" market surveys;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69aa5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of promotional materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69aa6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financing of business development seminars;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69aa7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facilitation of marketing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69aa8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participation of appropriate Federal agencies or eligible entities in trade fairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69aa9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity that is not described in subparagraphs (A) through (F) that is related to the development of appropriate markets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69aaa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activity that the Secretary, in consultation with the Director, determines to be appropriate to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69aab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conjunction with the activities described in paragraph (3), the Secretary, acting through the Director, shall provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d69aac-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" financial assistance, technical assistance, and administrative services to eligible entities to assist those entities with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d69aad-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and taking advantage of business development opportunities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d69aae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with appropriate laws and regulatory practices; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69aaf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other assistance as the Secretary, in consultation with the Director, determines to be necessary for the development of business opportunities for eligible entities to enhance the economies of Indian Tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69ab0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the duties and activities described in paragraphs (3) and (4), the Secretary, acting through the Director, shall give priority to activities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d69ab1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the greatest degree of economic benefits to Indians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69ab2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster long-term stable economies of Indian Tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69ab3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not provide under this section assistance for any activity related to the operation of a gaming activity on Indian lands pursuant to the Indian Gaming Regulatory Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2701"},"text":"25 U.S.C. 2701","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d69ab4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Director","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d69ab5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall serve as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d69ab6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program and policy advisor to the Secretary with respect to the trust and governmental relationship between the United States and Indian Tribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69ab7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the point of contact for Indian Tribes, Tribal organizations, and Indians regarding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d69ab8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies and programs of the Department of Commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d69ab9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other matters relating to economic development and doing business in Indian lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69aba-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Departmental coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall coordinate with all offices and agencies within the Department of Commerce to ensure that each office and agency has an accountable process to ensure—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d69abb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meaningful and timely coordination and assistance, as required by this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69abc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consultation with Indian Tribes regarding the policies, programs, assistance, and activities of the offices and agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69abd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4303/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section not more than $2,000,000 for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d69abe-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/464/s4"},"text":"Pub. L. 106–464, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2015"},"text":"114 Stat. 2015","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/261/s3/c"},"text":"Pub. L. 116–261, § 3(c)","children":[],"tail":", (e)(2), "},{"tag":"date","attrib":{"date":"2020-12-30"},"text":"Dec. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3308"},"text":"134 Stat. 3308","children":[],"tail":", 3311.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d69abf-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d69ac0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62d69ac1-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Gaming Regulatory Act, referred to in subsec. (b)(6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497"},"text":"Pub. L. 100–497","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2467"},"text":"102 Stat. 2467","children":[],"tail":", as amended, which is classified principally to chapter 29 (§ 2701 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2701"},"text":"section 2701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62d69ac2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/261/s3/c/1/A"},"text":"Pub. L. 116–261, § 3(c)(1)(A)","children":[],"tail":", substituted “Office of the Secretary” for “Department of Commerce” and struck out “(referred to in this chapter as the ‘Office’)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/261/s3/c/1/B"},"text":"Pub. L. 116–261, § 3(c)(1)(B)","children":[],"tail":", struck out “(referred to in this chapter as the ‘Director’)” after “Development”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(B), (5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/261/s3/e/2"},"text":"Pub. L. 116–261, § 3(e)(2)","children":[],"tail":", substituted “Tribes” for “tribes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/261/s3/c/2"},"text":"Pub. L. 116–261, § 3(c)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
