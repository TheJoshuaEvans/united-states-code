{"tag":"section","attrib":{"id":"id62a48e2f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2510"},"text":null,"children":[{"tag":"num","attrib":{"value":"2510"},"text":"§ 2510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" The tribally controlled grant school endowment program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62a48e30-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2510/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a48e31-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2510/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each school receiving a grant under this chapter may establish, at a federally insured financial institution, a trust fund for the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e32-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2510/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits and use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The school may provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a48e33-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2510/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for deposit into the trust fund, only funds from non-Federal sources, except that the interest on funds received from grants provided under this chapter may be used for that purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48e34-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2510/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for deposit into the trust fund, any earnings on funds deposited in the fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48e35-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2510/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the sole use of the school any noncash, in-kind contributions of real or personal property, which may at any time be used, sold, or otherwise disposed of.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a48e36-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2510/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Interest from the fund established under subsection (a) may periodically be withdrawn and used, at the discretion of the school, to defray any expenses associated with the operation of the school consistent with the purposes of this Act.","children":[{"tag":"ref","attrib":{"idref":"fn002182"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002182"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62a48e37-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","a