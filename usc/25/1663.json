{"tag":"section","attrib":{"id":"id627010a7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1663"},"text":null,"children":[{"tag":"num","attrib":{"value":"1663"},"text":"§ 1663.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Direct Service Tribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id627010a8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1663/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Service an office, to be known as the “Office of Direct Service Tribes”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627010a9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1663/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Direct Service Tribes shall be located in the Office of the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627010aa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1663/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of Direct Service Tribes shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627010ab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1663/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing Service-wide leadership, guidance and support for direct service tribes to include strategic planning and program evaluation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627010ac-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1663/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring maximum flexibility to tribal health and related support systems for Indian beneficiaries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627010ad-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1663/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving as the focal point for consultation and participation between direct service tribes and organizations and the Service in the development of Service policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627010ae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1663/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holding no less than biannual consultations with direct service tribes in appropriate locations to gather information and aid in the development of health policy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627010af-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1663/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directing a national program and providing leadership and advocacy in the development of health policy, program management, budget formulation, resource allocation, and delegation support for direct service tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id627010b0-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVI/s603"},"text":"Pub. L. 94–437, title VI, § 603","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id627010b1-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id627010b2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id627010b3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s603"},"text":"Section 603 of Pub. L. 94–437","children":[],"tail":" is based on section 172 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id627010b4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1663, ","children":[{"tag":"r