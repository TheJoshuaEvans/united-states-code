{"tag":"section","attrib":{"id":"id62f59401-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5601"},"text":null,"children":[{"tag":"num","attrib":{"value":"5601"},"text":"§ 5601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f59402-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5601/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there exists a unique relationship between the Government of the United States and the governments of Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f59403-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5601/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there exists a unique Federal responsibility to Indians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f59404-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5601/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through treaties, statutes, and historical relations with Indian tribes, the United States has undertaken a unique trust responsibility to protect and support Indian tribes and Indians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f59405-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5601/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fiduciary responsibilities of the United States to Indians also are founded in part on specific commitments made through written treaties and agreements securing peace, in exchange for which Indians have surrendered claims to vast tracts of land, which provided legal consideration for permanent, ongoing performance of Federal trust duties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f59406-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5601/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the foregoing historic Federal-tribal relations and understandings have benefitted the people of the United States as a whole for centuries and have established enduring and enforceable Federal obligations to which the national honor has been committed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f59407-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/178/tI/s101"},"text":"Pub. L. 114–178, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/432"},"text":"130 Stat. 432","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62f59408-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62f59409-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id62f5940a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/178/s1/a"},"text":"Pub. L. 114–178, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/432"},"text":"130 Stat. 432","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/178/s1/a"},"text":"“This Act [enacting this chapter] may be cited as the ‘Indian Trust Asset Reform Act’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/178/tII/s201"},"text":"Pub. L. 114–178, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/433"},"text":"130 Stat. 433","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/178/tII/s201"},"text":"“This title [enacting subchapter II of this chapter] may be cited as the ‘Indian Trust Asset Management Demonstration Project Act of 2016’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
