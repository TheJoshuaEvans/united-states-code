{"tag":"section","attrib":{"id":"id62e9ad44-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5332"},"text":null,"children":[{"tag":"num","attrib":{"value":"5332"},"text":"§ 5332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sovereign immunity and trusteeship rights unaffected","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall be construed as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62e9ad45-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5332/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affecting, modifying, diminishing, or otherwise impairing the sovereign immunity from suit enjoyed by an Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62e9ad46-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5332/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizing or requiring the termination of any existing trust responsibility of the United States with respect to the Indian people.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62e9ad47-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tI/s111"},"text":"Pub. L. 93–638, title I, § 111","children":[],"tail":", formerly § 110, "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2213"},"text":"88 Stat. 2213","children":[],"tail":"; renumbered § 111, "},{"tag":"ref","attrib":{"href":"/us/pl/100/472/tII/s206/b"},"text":"Pub. L. 100–472, title II, § 206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-05"},"text":"Oct. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2295"},"text":"102 Stat. 2295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62e9ad48-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62e9ad49-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62e9ad4a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", known as the Indian Self-Determination and Education Assistance Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62e9ad4b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450n"},"text":"section 450n of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
