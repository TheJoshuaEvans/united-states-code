{"tag":"section","attrib":{"id":"id625388af-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1451"},"text":null,"children":[{"tag":"num","attrib":{"value":"1451"},"text":"§ 1451.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is hereby declared to be the policy of Congress to provide capital on a reimbursable basis to help develop and utilize Indian resources, both physical and human, to a point where the Indians will fully exercise responsibility for the utilization and management of their own resources and where they will enjoy a standard of living from their own productive efforts comparable to that enjoyed by non-Indians in neighboring communities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id625388b0-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/s2"},"text":"Pub. L. 93–262, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/77"},"text":"88 Stat. 77","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id625388b1-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id625388b2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id625388b3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221/s1/a"},"text":"Pub. L. 109–221, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-05-12"},"text":"May 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/336"},"text":"120 Stat. 336","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/221/s1/a"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s494a"},"text":"section 494a of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1613a"},"text":"section 1613a of Title 43","children":[],"tail":", Public Lands, amending sections 348, 415, 464, 1481, 1485, 1486, 1497, 2206, 2706, and 2717 of this title and sections 1629b and 1629e of Title 43, enacting provisions set out as notes under sections 348 and 415 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1629b"},"text":"section 1629b of Title 43","children":[],"tail":", and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2201"},"text":"section 2201 of this title","children":[],"tail":"] may be cited as the ‘Native American Technical Corrections Act of 2006’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id625388b4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/331/tI/s101"},"text":"Pub. L. 107–331, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-13"},"text":"Dec. 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2835"},"text":"116 Stat. 2835","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/331/tI/s101"},"text":"“This Act [enacting subchapter XIII of chapter 19 of this title, amending sections 415, 1484, and 1485 of this title, and enacting provisions set out as notes under sections 415 and 1485 of this title] may be cited as the ‘Indian Financing Amendments Act of 2002’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id6255d1a5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/449/s1"},"text":"Pub. L. 98–449, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-04"},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1725"},"text":"98 Stat. 1725","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/449/s1"},"text":"“That this Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s47a"},"text":"section 47a of this title","children":[],"tail":" and amending sections 1461, 1465, 1481, 1484, 1491, 1497, 1512, 1522, 1523, 1541, and 1543 of this title] may be cited as the ‘Indian Financing Act Amendments of 1984’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id6255d1a6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/s1"},"text":"Pub. L. 93–262, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/77"},"text":"88 Stat. 77","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/262/s1"},"text":"“That this Act [enacting this chapter] may be cited as the ‘Indian Financing Act of 1974’.”