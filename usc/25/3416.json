{"tag":"section","attrib":{"id":"id62bc5ceb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3416"},"text":null,"children":[{"tag":"num","attrib":{"value":"3416"},"text":"§ 3416.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labor market information on Indian work force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62bc5cec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3416/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Labor, in consultation with the Secretary, Indian tribes, and the Director of the Bureau of the Census, shall develop, maintain and publish, not less than biennially, a report on the population eligible for the services which the Secretary provides to Indian people. The report shall include, but is not limited to, information at the national level by State, Bureau of Indian Affairs Service area, and tribal level for the—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5ced-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3416/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total service population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5cee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3416/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the service population under age 16 and over 64;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5cef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3416/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population available for work, including those not considered to be actively seeking work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5cf0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3416/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employed population, including those employed with annual earnings below the poverty line; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5cf1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3416/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the numbers employed in private sector positions and in public sector positions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5cf2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3416/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian demographic information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Bureau of the Census of the Department of Commerce, and the National Center for Native American Studies and Policy Development authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/301"},"text":"Public Law 101–301","children":[],"tail":", shall prepare a report on the need for comprehensive, accurate and periodically updated information on the size and characteristics of the Indian and Alaska Native population throughout the entire United States. This report shall include the need for information, together with the cost of acquiring such information, on the characteristics and need for education, health, housing, job training, and other basic needs of such population, and shall take into consideration the need for this information by Indian tribes and organizations serving Indians in nonreservation areas. The report shall be submitted to the Committee on Indian Affairs of the Senate and the Committee on Natural Resources and the Committee on Education and Labor of the House of Representatives not later than 12 months after "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"October 23, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62bc5cf3-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/477/s15"},"text":"Pub. L. 102–477, § 15","children":[],"tail":", formerly § 17, "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2305"},"text":"106 Stat. 2305","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s10/e/1"},"text":"Pub. L. 103–437, § 10(e)(1)","children":[],"tail":", (2)(C), "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4589"},"text":"108 Stat. 4589","children":[],"tail":"; renumbered § 15 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/93"},"text":"Pub. L. 115–93","children":[],"tail":", §§ 15, 16(b), "},{"tag":"date","attrib":{"date":"2017-12-18"},"text":"Dec. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2036"},"text":"131 Stat. 2036","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62bc5cf4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62bc5cf5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62bc5cf6-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/301"},"text":"Public Law 101–301","children":[],"tail":", referred to in subsec. (b), is "},{"tag":"ref","attrib":{"href":"/us/pl/101/301"},"text":"Pub. L. 101–301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-24"},"text":"May 24, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/206"},"text":"104 Stat. 206","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/101/301/s11"},"text":"Section 11 of Pub. L. 101–301","children":[],"tail":", which authorized feasibility study for the establishment of a National Center for Native American Studies and Policy Development, is not classified to the Code. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62bc5cf7-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/477/s15"},"text":"section 15 of Pub. L. 102–477","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3414"},"text":"section 3414 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/93"},"text":"Pub. L. 115–93","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62bc5cf8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/93/s15"},"text":"Pub. L. 115–93, § 15","children":[],"tail":", in introductory provisions, substituted “The Secretary of Labor, in consultation with the Secretary, Indian tribes, and the Director of the Bureau of the Census, shall” for “The Secretary, in consultation with the Secretary of Labor, shall, in a consistent and reliable manner,” and struck out “, by gender,” after “population”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Committee on Indian” for “Select Committee on Indian” and “Natural Resources” for “Interior and Insular Affairs”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62bc5cf9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id62bc5cfa-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
