{"tag":"section","attrib":{"id":"id62642ac5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621o"},"text":null,"children":[{"tag":"num","attrib":{"value":"1621o"},"text":"§ 1621o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian youth grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62642ac6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, is authorized to make grants to Indian tribes, tribal organizations, and urban Indian organizations for innovative mental and physical disease prevention and health promotion and treatment programs for Indian preadolescent and adolescent youths.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62642ac7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62642ac8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621o/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Funds made available under this section may be used to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62642ac9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621o/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop prevention and treatment programs for Indian youth which promote mental and physical health and incorporate cultural values, community and family involvement, and traditional healers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62642aca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621o/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and provide community training and education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642acb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621o/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds made available under this section may not be used to provide services described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1665g/c"},"text":"section 1665g(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62642acc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621o/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Models for delivery of comprehensive health care services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62642acd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621o/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate to Indian tribes information regarding models for the delivery of comprehensive health care services to Indian and urban Indian adolescents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642ace-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621o/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the implementation of such models; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642acf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621o/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of an Indian tribe, provide technical assistance in the implementation of such models.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62642ad0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621o/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for review and approval of applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish criteria for the review and approval of applications under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62642ad1-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tII/s216"},"text":"Pub. L. 94–437, title II, § 216","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tII/s212"},"text":"Pub. L. 102–573, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4554"},"text":"106 Stat. 4554","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62642ad2-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62642ad3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62642ad4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" is based on sections 101(b)(4) and 131 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which were enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62642ad5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1665g/c"},"text":"section 1665g(c) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1621h/m"},"text":"section 1621h(m) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pu