{"tag":"section","attrib":{"id":"id62728212-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665n"},"text":null,"children":[{"tag":"num","attrib":{"value":"1665n"},"text":"§ 1665n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Behavioral health research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62728213-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with appropriate Federal agencies, shall make grants to, or enter into contracts with, Indian tribes, tribal organizations, and urban Indian organizations or enter into contracts with, or make grants to appropriate institutions for, the conduct of research on the incidence and prevalence of behavioral health problems among Indians served by the Service, Indian tribes, or tribal organizations and among Indians in urban areas. Research priorities under this section shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62728214-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665n/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the multifactorial causes of Indian youth suicide, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62728215-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665n/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protective and risk factors and scientific data that identifies those factors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728216-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665n/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects of loss of cultural identity and the development of scientific data on those effects;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728217-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665n/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interrelationship and interdependence of behavioral health problems with alcoholism and other substance abuse, suicide, homicides, other injuries, and the incidence of family violence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728218-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665n/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of models of prevention techniques.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62728219-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emphasis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The effect of the interrelationships and interdependencies referred to in subsection (a)(2) on children, and the development of prevention techniques under subsection (a)(3) applicable to children, shall be emphasized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6272821a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s715"},"text":"Pub. L. 94–437, title VII, § 715","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6272821b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6272821c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6272821d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s715"},"text":"Section 715 of Pub. L. 94–437","children":[],"tail":" is based on section 181 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
