{"tag":"section","attrib":{"id":"id62d1dfee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4182"},"text":null,"children":[{"tag":"num","attrib":{"value":"4182"},"text":"§ 4182.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of new commitments for rental assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1997-09-30"},"text":"September 30, 1997","children":[],"tail":", financial assistance for rental housing assistance under the United States Housing Act of 1937 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"42 U.S.C. 1437","children":[],"tail":" et seq.] may not be provided to any Indian housing authority or tribally designated housing entity, unless such assistance is provided pursuant to a contract for such assistance entered into by the Secretary and the Indian housing authority before such date. Any such assistance provided pursuant to such a contract shall be governed by the provisions of the United States Housing Act of 1937 (as in effect before the date of the effectiveness of this chapter) and the provisions of such contract."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62d1dfef-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tV/s503"},"text":"Pub. L. 104–330, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4043"},"text":"110 Stat. 4043","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d1dff0-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d1dff1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"childre