{"tag":"section","attrib":{"id":"id621a288e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s152"},"text":null,"children":[{"tag":"num","attrib":{"value":"152"},"text":"§ 152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceeds of sales of Indian lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All moneys received from the sales of lands that have been, or may be, ceded to the United States by Indian tribes, by treaties providing for the investment or payment to the Indians, parties thereto, of the proceeds of the lands ceded by them, respectively, after deducting the expenses of survey and sale, any sums stipulated to be advanced, and the expenses of fulfilling any engagements contained therein, shall be paid into the Treasury in the same manner that moneys received from the sales of public lands are paid into the Treasury.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621a288f-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2093.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621a2890-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621a2891-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id621a2892-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2093 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1837-01-09/ch1/s1"},"text":"act Jan. 9, 1837, ch. 1, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/5/135"},"text":"5 Stat. 135","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
