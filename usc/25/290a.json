{"tag":"section","attrib":{"id":"id62215499-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s290a"},"text":null,"children":[{"tag":"num","attrib":{"value":"290a"},"text":"§ 290a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau appropriations as not limiting transportation of school children","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1984-10-12"},"text":"October 12, 1984","children":[],"tail":", no part of any appropriation to the Bureau of Indian Affairs under this or any other act shall be used to subject the transportation of school children to any limitation on travel or transportation expenditures for Federal employees."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6221549a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tI/s101/c/tI/s100"},"text":"Pub. L. 98–473, title I, § 101(c) [title I, § 100]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1837"},"text":"98 Stat. 1837","children":[],"tail":", 1850.)"}],"tail":"\n"}],"tail":null}
