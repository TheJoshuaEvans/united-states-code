{"tag":"section","attrib":{"id":"id621c99a1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s199"},"text":null,"children":[{"tag":"num","attrib":{"value":"199"},"text":"§ 199.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to records of Five Civilized Tribes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior, or his accredited representative, shall at all times have access to any books and records of the Choctaw, Chickasaw, Cherokee, Creek, and Seminole Tribes, whether in possession of any of the officers of either of said tribes or any officer or custodian thereof, of the State of Oklahoma.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621f0aa2-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-01/ch2285"},"text":"Mar. 1, 1907, ch. 2285","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1027"},"text":"34 Stat. 1027","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621f0aa3-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id621f0aa4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id621f0aa5-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
