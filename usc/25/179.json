{"tag":"section","attrib":{"id":"id621c994c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s179"},"text":null,"children":[{"tag":"num","attrib":{"value":"179"},"text":"§ 179.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Driving stock to feed on lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every person who drives or otherwise conveys any stock of horses, mules, or cattle, to range and feed on any land belonging to any Indian or Indian tribe, without the consent of such tribe, is liable to a penalty of $1 for each animal of such stock. This section shall not apply to Creek lands.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621c994d-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2117; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-01/ch676/s37"},"text":"Mar. 1, 1901, ch. 676, § 37","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/871"},"text":"31 Stat. 871","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1902-06-30/ch1323/s17"},"text":"June 30, 1902, ch. 1323, § 17","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/504"},"text":"32 Stat. 504","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621c994e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621c994f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id621c9950-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2117 derived from ","children":[{"tag":"ref","