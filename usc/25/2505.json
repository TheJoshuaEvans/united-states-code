{"tag":"section","attrib":{"id":"id62a21dbd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505"},"text":null,"children":[{"tag":"num","attrib":{"value":"2505"},"text":"§ 2505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of eligibility determination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62a21dbe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that a tribally controlled school is eligible for assistance under this chapter, the eligibility determination shall remain in effect until the determination is revoked by the Secretary, and the requirements of subsection (b) or (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2504"},"text":"section 2504 of this title","children":[],"tail":", if applicable, shall be considered to have been met with respect to such school until the eligibility determination is revoked by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a21dbf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a21dc0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each recipient of a grant provided under this chapter shall complete an annual report which shall be limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21dc1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual financial statement reporting revenue and expenditures as defined by the cost accounting established by the grantee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21dc2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual financial audit conducted pursuant to the standards of the Single Audit Act of 1984 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s7501"},"text":"31 U.S.C. 7501","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21dc3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a biennial compliance audit of the procurement of personal property during the period for which the report is being prepared that shall be in compliance with written procurement standards that are developed by the local school board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21dc4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual submission to the Secretary of the number of students served and a brief description of programs offered under the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21dc5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program evaluation conducted by an impartial evaluation review team, to be based on the standards established for purposes of subsection (c)(1)(A)(ii).","children":[{"tag":"ref","attrib":{"idref":"fn002171"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002171"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be subsection “(c)(1)(B)(ii).”"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21dc6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation review teams","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where appropriate, other tribally controlled schools and representatives of tribally controlled community colleges shall make up members of the evaluation review teams.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21dc7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a school which is accredited, evaluations will be conducted at intervals under the terms of accreditation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21dc8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21dc9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" To tribal governing body","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon completion of the report required under paragraph (1), the recipient of the grant shall send (via first class mail, return receipt requested) a copy of such annual report to the tribal governing body (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2012/f"},"text":"section 2012(f) of this title","children":[],"tail":") of the tribally controlled school."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21dca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" To Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after receiving written confirmation that the tribal governing body has received the report sent pursuant to subparagraph (A), the recipient of the grant shall send a copy of the report to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a21dcb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation of eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a21dcc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of eligibility for assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not revoke a determination that a school is eligible for assistance under this chapter if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21dcd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian tribe or tribal organization submits the reports required under subsection (b) with respect to the school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21dce-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at least one of the following clauses applies with respect to the school:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62a21dcf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The school is certified or accredited by a State or regional accrediting association or is a candidate in good standing for such accreditation under the rules of the State or regional accrediting association, showing that credits achieved by the students within the education programs are, or will be, accepted at grade level by a State certified or regionally accredited institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21dd0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary determines that there is a reasonable expectation that the certification or accreditation described in clause (i), or candidacy in good standing for such certification or accreditation, will be achieved by the school within 3 years. The school seeking accreditation shall remain under the standards of the Bureau in effect on ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", until such time as the school is accredited, except that if the Bureau standards are in conflict with the standards of the accrediting agency, the standards of such agency shall apply in such case."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21dd1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The school is accredited by a tribal department of education if such accreditation is accepted by a generally recognized regional or State accreditation agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21dd2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62a21dd3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/1/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to a school that lacks accreditation, or that is not a candidate for accreditation, based on circumstances that are not beyond the control of the school board, every 3 years an impartial evaluator agreed upon by the Secretary and the grant recipient conducts evaluations of the school, and the school receives a positive assessment under such evaluations. The evaluations are conducted under standards adopted by a contractor under a contract for the school entered into under the Indian Self-Determination and Education Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.] (or revisions of such standards agreed to by the Secretary and the grant recipient) prior to "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62a21dd4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/1/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary and a grant recipient other than a tribal governing body fail to agree on such an evaluator, the tribal governing body shall choose the evaluator or perform the evaluation. If the Secretary and a grant recipient that is a tribal governing body fail to agree on such an evaluator, subclause (I) shall not apply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62a21dd5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/1/B/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A positive assessment by an impartial evaluator under this clause shall not affect the revocation of a determination of eligibility by the Secretary where such revocation is based on circumstances that were within the control of the school board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21dd6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice requirements for revocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not revoke a determination that a school is eligible for assistance under this chapter, or reassume control of a school that was a Bureau school prior to approval of an application submitted under section 2505(b)(1)(A) ","children":[{"tag":"ref","attrib":{"idref":"fn002172"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002172"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be section “2504(b)(1)(A)”."}],"tail":" of this title until the Secretary—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a48dd7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides notice to the tribally controlled school and the tribal governing body (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2021"},"text":"section 2021 of this title","children":[],"tail":") of the tribally controlled school which states—"}],"tail":null},{"tag":"clause","attrib":{"id":"id62a48dd8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific deficiencies that led to the revocation or resumption determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a48dd9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions that are needed to remedy such deficiencies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48dda-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affords such authority an opportunity to effect the remedial actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48ddb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide such technical assistance to enable the school and governing body to carry out such remedial actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48ddc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing and appeal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to notice and technical assistance under this subsection, the Secretary shall provide to the school and governing body—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a48ddd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of the school or governing body, a hearing on the record regarding the revocation or reassumption determination, to be conducted under the rules and regulations described in section 2505(f)(1)(C) ","children":[{"tag":"ref","attrib":{"idref":"fn002173"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002173"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be section “2504(f)(1)(C)”."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48dde-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an opportunity to appeal the decision resulting from the hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a48ddf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of section pursuant to election under section 2507(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a tribally controlled school that receives assistance under this chapter pursuant to an election made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2507/b"},"text":"section 2507(b) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a48de0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b) of this section shall apply; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48de1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2505/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may not revoke eligibility for assistance under this chapter except in conformance with subsection (c) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62a48de2-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5206"},"text":"Pub. L. 100–297, title V, § 5206","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1043"},"text":"Pub. L. 107–110, title X, § 1043","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2072"},"text":"115 Stat. 2072","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62a48de3-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62a48de4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62a48de5-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Single Audit Act of 1984, referred to in subsec. (b)(1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/502"},"text":"Pub. L. 98–502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2327"},"text":"98 Stat. 2327","children":[],"tail":", which enacted chapter 75 (§ 7501 et seq.) of Title 31, Money and Finance, and provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s7501"},"text":"section 7501 of Title 31","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1984 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s7501"},"text":"section 7501 of Title 31","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in subsec. (c)(1)(B)(iv)(I), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which is classified principally to chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62a48de6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2505, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5206"},"text":"Pub. L. 100–297, title V, § 5206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/388"},"text":"102 Stat. 388","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/427/s11"},"text":"Pub. L. 100–427, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1608"},"text":"102 Stat. 1608","children":[],"tail":"; "},{"tag":"ref","attri