{"tag":"section","attrib":{"id":"id62701068-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661"},"text":null,"children":[{"tag":"num","attrib":{"value":"1661"},"text":"§ 1661.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the Indian Health Service as an agency of the Public Health Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62701069-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6270106a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to more effectively and efficiently carry out the responsibilities, authorities, and functions of the United States to provide health care services to Indians and Indian tribes, as are or may be on and after ","children":[{"tag":"date","attrib":{"date":"1988-11-23"},"text":"November 23, 1988","children":[],"tail":", provided by Federal statute or treaties, there is established within the Public Health Service of the Department the Indian Health Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6270106b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Service shall be administered by a Director, who shall be appointed by the President, by and with the advice and consent of the Senate. The Director shall report to the Secretary. Effective with respect to an individual appointed by the President, by and with the advice and consent of the Senate, after ","children":[{"tag":"date","attrib":{"date":"2008-01-01"},"text":"January 1, 2008","children":[],"tail":", the term of service of the Director shall be 4 years. A Director may serve more than 1 term."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6270106c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incumbent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The individual serving in the position of Director of the Service on the day before ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", shall serve as Director."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6270106d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advocacy and consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The position of Director is established to, in a manner consistent with the government-to-government relationship between the United States and Indian Tribes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6270106e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate advocacy for the development of appropriate Indian health policy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6270106f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote consultation on matters relating to Indian health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62701070-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Service shall be an agency within the Public Health Service of the Department, and shall not be an office, component, or unit of any other agency of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62701071-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62701072-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform all functions that were, on the day before ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", carried out by or under the direction of the individual serving as Director of the Service on that day;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62701073-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform all functions of the Secretary relating to the maintenance and operation of hospital and health facilities for Indians and the planning for, and provision and utilization of, health services for Indians, including by ensuring that all agency directors, managers, and chief executive officers have appropriate and adequate training, experience, skill levels, knowledge, abilities, and education (including continuing training requirements) to competently fulfill the duties of the positions and the mission of the Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62701074-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" administer all health programs under which health care is provided to Indians based upon their status as Indians which are administered by the Secretary, including programs under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62701075-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701076-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701077-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1954-08-05"},"text":"August 5, 1954","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2001"},"text":"42 U.S.C. 2001","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701078-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1957-08-16"},"text":"August 16, 1957","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2005"},"text":"42 U.S.C. 2005","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701079-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.); "},{"tag":"ref","attrib":{"idref":"fn002084"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002084"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6270107a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer all scholarship and loan functions carried out under subchapter I;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6270107b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly advise the Secretary concerning the development of all policy- and budget-related matters affecting Indian health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6270107c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with the Assistant Secretary for Health concerning appropriate matters of Indian health that affect the agencies of the Public Health Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6270107d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise each Assistant Secretary of the Department concerning matters of Indian health with respect to which that Assistant Secretary has authority and responsibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6270107e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the heads of other agencies and programs of the Department concerning matters of Indian health with respect to which those heads have authority and responsibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6270107f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the activities of the Department concerning matters of Indian health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62701080-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other functions as the Secretary may designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62701081-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62701082-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director, shall have the authority—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62701083-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except to the extent provided for in paragraph (2), to appoint and compensate employees for the Service in accordance with title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701084-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into contracts for the procurement of goods and services to carry out the functions of the Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701085-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to manage, expend, and obligate all funds appropriated for the Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62701086-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1661/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5116"},"text":"section 5116 of this title","children":[],"tail":","},{"tag":"ref","attrib":{"idref":"fn002085"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002085"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" shall apply to all personnel actions taken with respect to new positions created within the Service as a result of its establishment under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62701087-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVI/s601"},"text":"Pub. L. 94–437, title VI, § 601","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tVI/s601/a"},"text":"Pub. L. 100–713, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4824"},"text":"102 Stat. 4824","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVI"},"text":"Pub. L. 102–573, title VI","children":[],"tail":", §§ 601, 602(a)(1), (c), title IX, § 902(6), (7), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4571"},"text":"106 Stat. 4571","children":[],"tail":", 4592; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62701088-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62701089-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6270108a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c)(3)(A), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437"},"text":"Pub. L. 94–437","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1400"},"text":"90 Stat. 1400","children":[],"tail":", known as the Indian Health Care Improvement Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1954-08-05"},"text":"August 5, 1954","children":[],"tail":", referred to in subsec. (c)(3)(C), is "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-05/ch658"},"text":"act Aug. 5, 1954, ch. 658","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/674"},"text":"68 Stat. 674","children":[],"tail":", which is classified generally to subchapter I (§ 2001 et seq.) of chapter 22 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1957-08-16"},"text":"August 16, 1957","children":[],"tail":", referred to in subsec. (c)(3)(D), is "},{"tag":"ref","attrib":{"href":"/us/pl/85/151"},"text":"Pub. L. 85–151","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-16"},"text":"Aug. 16, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/370"},"text":"71 Stat. 370","children":[],"tail":", which is classified generally to subchapter II (§ 2005 et seq.) of chapter 22 of Title 42. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.), referred to in subsec. (c)(3)(E), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of this title prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6270108b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" is based on section 171 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“On and after ","children":[{"tag":"date","attrib":{"date":"1988-11-23"},"text":"November 23, 1988","children":[],"tail":",”, referred to in subsec. (a)(1), was in the original “hereafter” and was translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/713"},"text":"Pub. L. 100–713","children":[],"tail":" which added this section rather than the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", which amended this section generally, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6270108c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1661, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVI/s601"},"text":"Pub. L. 94–437, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1412"},"text":"90 Stat. 1412","children":[],"tail":", related to feasibility study and report to Congress, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/100/713"},"text":"Pub. L. 100–713","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6270108d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" amended section generally, revising and restating provisions relating to establishment of the Indian Health Service as an agency of the Public Health Service and inserting additional provisions relating to responsibilities of the Director."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s602/c"},"text":"Pub. L. 102–573, § 602(c)","children":[],"tail":", inserted at end “Effective with respect to an individual appointed by the President, by and with the advice and consent of the Senate, after "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":", the term of service of the Director shall be 4 years. A Director may serve more than 1 term.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s602/a/1"},"text":"Pub. L. 102–573, § 602(a)(1)","children":[],"tail":", substituted “President, by and with the advice and consent of the Senate” for “Secretary” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s902/6"},"text":"Pub. L. 102–573, § 902(6)","children":[],"tail":", substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2005"},"text":"42 U.S.C. 2005","children":[],"tail":" et seq.)” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2005"},"text":"25 U.S.C. 2005","children":[],"tail":", et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s601"},"text":"Pub. L. 102–573, § 601","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s902/7"},"text":"Pub. L. 102–573, § 902(7)","children":[],"tail":", substituted “appropriated” for “appropriate”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6270108e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6270108f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVI/s602/a/2"},"text":"Pub. L. 102–573, title VI, § 602(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4571"},"text":"106 Stat. 4571","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/573/tVI/s602/a/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall take effect ","children":[{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id62701090-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/713/tVI/s601/c"},"text":"Pub. L. 100–713, title VI, § 601(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4826"},"text":"102 Stat. 4826","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/713/tVI/s601/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), section 601 of the Indian Health Care Improvement Act [this section] added by subsection (a) of this section shall take effect 9 months from the date of the enactment of this section [","children":[{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsections (b) [set out below] and (c)(1), any action which carries out such section 601 that is taken by the Secretary before the effective date of such section 601 shall be effective beginning on the date such action was taken.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62701091-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Interim Appointment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVI/s602/b"},"text":"Pub. L. 102–573, title VI, § 602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4571"},"text":"106 Stat. 4571","children":[],"tail":", authorized the President to appoint an individual to serve as Interim Director of the Service from "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"Jan. 1, 1993","children":[],"tail":", until confirmation of a Director."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62701092-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Personnel, Records, Equipment, Etc., to Indian Health Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/713/tVI/s601/b"},"text":"Pub. L. 100–713, title VI, § 601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4826"},"text":"102 Stat. 4826","children":[],"tail":", provided for the transfer within 9 months of "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", of personnel, records, equipment, facilities, and interests in property of the Indian Health Service to the Indian Health Service established by "},{"tag":"ref","attrib":{"href":"/us/pl/100/713"},"text":"Pub. L. 100–713","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
