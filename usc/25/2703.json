{"tag":"section","attrib":{"id":"id62a48e8d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703"},"text":null,"children":[{"tag":"num","attrib":{"value":"2703"},"text":"§ 2703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a48e8e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Attorney General” means the Attorney General of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e8f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Chairman” means the Chairman of the National Indian Gaming Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e90-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Commission” means the National Indian Gaming Commission established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2704"},"text":"section 2704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e91-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Indian lands” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a48e92-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all lands within the limits of any Indian reservation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48e93-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any lands title to which is either held in trust by the United States for the benefit of any Indian tribe or individual or held by any Indian tribe or individual subject to restriction by the United States against alienation and over which an Indian tribe exercises governmental power.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e94-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Indian tribe” means any Indian tribe, band, nation, or other organized group or community of Indians which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a48e95-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is recognized as eligible by the Secretary for the special programs and services provided by the United States to Indians because of their status as Indians, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48e96-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is recognized as possessing powers of self-government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e97-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “class I gaming” means social games solely for prizes of minimal value or traditional forms of Indian gaming engaged in by individuals as a part of, or in connection with, tribal ceremonies or celebrations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e98-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a48e99-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “class II gaming” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62a48e9a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the game of chance commonly known as bingo (whether or not electronic, computer, or other technologic aids are used in connection therewith)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62a48e9b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/7/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is played for prizes, including monetary prizes, with cards bearing numbers or other designations,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62a48e9c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/7/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the holder of the card covers such numbers or designations when objects, similarly numbered or designated, are drawn or electronically determined, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62a48e9d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/7/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the game is won by the first person covering a previously designated arrangement of numbers or designations on such cards,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"including (if played in the same location) pull-tabs, lotto, punch boards, tip jars, instant bingo, and other games similar to bingo, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a48e9e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" card games that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62a48e9f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/7/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are explicitly authorized by the laws of the State, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62a48ea0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/7/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not explicitly prohibited by the laws of the State and are played at any location in the State,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but only if such card games are played in conformity with those laws and regulations (if any) of the State regarding hours or periods of operation of such card games or limitations on wagers or pot sizes in such card games.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48ea1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “class II gaming” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62a48ea2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any banking card games, including baccarat, chemin de fer, or blackjack (21), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a48ea3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electronic or electromechanical facsimiles of any game of chance or slot machines of any kind.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48ea4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this paragraph, the term “class II gaming” includes those card games played in the State of Michigan, the State of North Dakota, the State of South Dakota, or the State of Washington, that were actually operated in such State by an Indian tribe on or before ","children":[{"tag":"date","attrib":{"date":"1988-05-01"},"text":"May 1, 1988","children":[],"tail":", but only to the extent of the nature and scope of the card games that were actually operated by an Indian tribe in such State on or before such date, as determined by the Chairman."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48ea5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this paragraph, the term “class II gaming” includes, during the 1-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1988-10-17"},"text":"October 17, 1988","children":[],"tail":", any gaming described in subparagraph (B)(ii) that was legally operated on Indian lands on or before "},{"tag":"date","attrib":{"date":"1988-05-01"},"text":"May 1, 1988","children":[],"tail":", if the Indian tribe having jurisdiction over the lands on which such gaming was operated requests the State, by no later than the date that is 30 days after "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"October 17, 1988","children":[],"tail":", to negotiate a Tribal-State compact under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2710/d/3"},"text":"section 2710(d)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48ea6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this paragraph, the term “class II gaming” includes, during the 1-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1991-12-17"},"text":"December 17, 1991","children":[],"tail":", any gaming described in subparagraph (B)(ii) that was legally operated on Indian lands in the State of Wisconsin on or before "},{"tag":"date","attrib":{"date":"1988-05-01"},"text":"May 1, 1988","children":[],"tail":", if the Indian tribe having jurisdiction over the lands on which such gaming was operated requested the State, by no later than "},{"tag":"date","attrib":{"date":"1988-11-16"},"text":"November 16, 1988","children":[],"tail":", to negotiate a Tribal-State compact under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2710/d/3"},"text":"section 2710(d)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48ea7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/7/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, during the 1-year period described in subparagraph (E), there is a final judicial determination that the gaming described in subparagraph (E) is not legal as a matter of State law, then such gaming on such Indian land shall cease to operate on the date next following the date of such judicial decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48ea8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “class III gaming” means all forms of gaming that are not class I gaming or class II gaming.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48ea9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “net revenues” means gross revenues of an Indian gaming activity less amounts paid out as, or paid for, prizes and total operating expenses, excluding management fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48eaa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2703/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62a48eab-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497/s4"},"text":"Pub. L. 100–497, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2467"},"text":"102 Stat. 2467","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/238/s2/a"},"text":"Pub. L. 102–238, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-17"},"text":"Dec. 17, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1908"},"text":"105 Stat. 1908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/497/s16"},"text":"Pub. L. 102–497, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3261"},"text":"106 Stat. 3261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62a48eac-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62a48ead-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62a48eae-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497"},"text":"Pub. L. 100–497","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2467"},"text":"102 Stat. 2467","children":[],"tail":", known as the Indian Gaming Regulatory Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2701"},"text":"section 2701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62a48eaf-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Par. (7)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/497"},"text":"Pub. L. 102–497","children":[],"tail":" struck out “or Montana” after “Wisconsin”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Par. (7)(E), (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/238"},"text":"Pub. L. 102–238","children":[],"tail":" added subpars. (E) and (F)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62a48eb0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62a48eb1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Class II Gaming With Respect to Indian Tribes in Wisconsin or Montana Engaged in Negotiating Tribal-State Compacts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/301/s6"},"text":"Pub. L. 101–301, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-24"},"text":"May 24, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/209"},"text":"104 Stat. 209","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/301/s6"},"text":"“Notwithstanding any other provision of law, the term ‘class II gaming’ includes, for purposes of applying ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497"},"text":"Public Law 100–497","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2701"},"text":"25 U.S.C. 2701","children":[],"tail":" et seq.] with respect to any Indian tribe located in the State of Wisconsin or the State of Montana, during the 1-year period beginning on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1990-05-24"},"text":"May 24, 1990","children":[],"tail":"], any gaming described in "},{"tag":"ref","attrib":{"href":"/us/pl/100/497/s4/7/B/ii"},"text":"section 4(7)(B)(ii) of Public Law 100–497","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2703/7/B/ii"},"text":"25 U.S.C. 2703(7)(B)(ii)","children":[],"tail":"] that was legally operated on Indian lands on or before "},{"tag":"date","attrib":{"date":"1988-05-01"},"text":"May 1, 1988","children":[],"tail":", if the Indian tribe having jurisdiction over the lands on which such gaming was operated made a request, by no later than "},{"tag":"date","attrib":{"date":"1988-11-16"},"text":"November 16, 1988","children":[],"tail":", to the State in which such gaming is operated to negotiate a Tribal-State compact under "},{"tag":"ref","attrib":{"href":"/us/pl/100/497/s11/d/3"},"text":"section 11(d)(3) of Public Law 100–497","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2710/d/3"},"text":"25 U.S.C. 2710(d)(3)","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62a48eb2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Tribal-State Compact Covering Indian Tribes in Minnesota; Operation of Class II Games; Allowance of Additional Year for Negotiations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/121/tI/s118"},"text":"Pub. L. 101–121, title I, § 118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-10-23"},"text":"Oct. 23, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/722"},"text":"103 Stat. 722","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/121/tI/s118"},"text":"“Notwithstanding any other provision of law, the term ‘Class II gaming’ in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497"},"text":"Public Law 100–497","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2701"},"text":"25 U.S.C. 2701","children":[],"tail":" et seq.], for any Indian tribe located in the State of Minnesota, includes, during the period commencing on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1989-10-23"},"text":"Oct. 23, 1989","children":[],"tail":"] and continuing for 365 days from that date, any gaming described in "},{"tag":"ref","attrib":{"href":"/us/pl/100/497/s4/7/B/ii"},"text":"section 4(7)(B)(ii) of Public Law 100–497","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2703/7/B/ii"},"text":"25 U.S.C. 2703(7)(B)(ii)","children":[],"tail":"] that was legally operated on Indian lands on or before "},{"tag":"date","attrib":{"date":"1988-05-01"},"text":"May 1, 1988","children":[],"tail":", if the Indian tribe having jurisdication [sic] over the lands on which such gaming was operated, requested the State of Minnesota, no later than 30 days after the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/497"},"text":"Public Law 100–497","children":[],"tail":" ["},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":"], to negotiate a tribal-state compact pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/100/497/s11/d/3"},"text":"section 11(d)(3) of Public Law 100–497","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2710/d/3"},"text":"25 U.S.C. 2710(d)(3)","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
