{"tag":"section","attrib":{"id":"id626b563d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647"},"text":null,"children":[{"tag":"num","attrib":{"value":"1647"},"text":"§ 1647.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible Indian veteran services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id626b563e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings; purpose","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id626b563f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id626b5640-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborations between the Secretary and the Secretary of Veterans Affairs regarding the treatment of Indian veterans at facilities of the Service should be encouraged to the maximum extent practicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id626b5641-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased enrollment for services of the Department of Veterans Affairs by veterans who are members of Indian tribes should be encouraged to the maximum extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626b5642-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to reaffirm the goals stated in the document entitled “Memorandum of Understanding Between the VA/Veterans Health Administration And HHS/Indian Health Service” and dated ","children":[{"tag":"date","attrib":{"date":"2003-02-25"},"text":"February 25, 2003","children":[],"tail":" (relating to cooperation and resource sharing between the Veterans Health Administration and Service)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626b5643-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id626b5644-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible Indian veteran","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible Indian veteran” means an Indian or Alaska Native veteran who receives any medical service that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id626b5645-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized under the laws administered by the Secretary of Veterans Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id626b5646-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administered at a facility of the Service (including a facility operated by an Indian tribe or tribal organization through a contract or compact with the Service under the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.)) "},{"tag":"ref","attrib":{"idref":"fn002077"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002077"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" pursuant to a local memorandum of understanding."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626b5647-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local memorandum of understanding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “local memorandum of understanding” means a memorandum of understanding between the Secretary (or a designee, including the director of any area office of the Service) and the Secretary of Veterans Affairs (or a designee) to implement the document entitled “Memorandum of Understanding Between the VA/Veterans Health Administration And HHS/Indian Health Service” and dated ","children":[{"tag":"date","attrib":{"date":"2003-02-25"},"text":"February 25, 2003","children":[],"tail":" (relating to cooperation and resource sharing between the Veterans Health Administration and Indian Health Service)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626b5648-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible Indian veterans expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id626b5649-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary shall provide for veteran-related expenses incurred by eligible Indian veterans as described in subsection (b)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626b564a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish such guidelines as the Secretary determines to be appropriate regarding the method of payments to the Secretary of Veterans Affairs under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626b564b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal approval of memoranda","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In negotiating a local memorandum of understanding with the Secretary of Veterans Affairs regarding the provision of services to eligible Indian veterans, the Secretary shall consult with each Indian tribe that would be affected by the local memorandum of understanding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626b564c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id626b564d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Expenses incurred by the Secretary in carrying out subsection (c)(1) shall not be considered to be Contract Health Service expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626b564e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1647/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of funds made available to the Secretary in appropriations Acts for the Service (excluding funds made available for facilities, Contract Health Services, or contract support costs), the Secretary shall use such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id626b564f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tIV/s407"},"text":"Pub. L. 94–437, title IV, § 407","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id626b5650-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id626b5651-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id626b5652-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.), referred to in subsec. (b)(1)(B), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of this title prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id626b5653-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s407"},"text":"Section 407 of Pub. L. 94–437","children":[],"tail":" is based on section 155 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id626b5654-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1647, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tIV/s407"},"text":"Pub. L. 94–437, title IV, § 407","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tIV/s406"},"text":"Pub. L. 102–573, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4566"},"text":"106 Stat. 4566","children":[],"tail":", authorized appropriations through fiscal year 2000 to carry out this subchapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":". The repeal is based on section 101(b)(7) of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
