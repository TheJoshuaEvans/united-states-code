{"tag":"section","attrib":{"id":"id6298a7ce-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2209"},"text":null,"children":[{"tag":"num","attrib":{"value":"2209"},"text":"§ 2209.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trusteeship title of United States for any Indian or Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Title to any land acquired under this chapter by any Indian or Indian tribe shall be taken in trust by the United States for that Indian or Indian tribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6298a7cf-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/459/tII/s210"},"text":"Pub. L. 97–459, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2519"},"text":"96 Stat. 2519","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
