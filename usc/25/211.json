{"tag":"section","attrib":{"id":"id621f0ac1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s211"},"text":null,"children":[{"tag":"num","attrib":{"value":"211"},"text":"§ 211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of Indian reservations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No Indian reservation shall be created, nor shall any additions be made to one heretofore created, within the limits of the States of New Mexico and Arizona, except by Act of Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621f0ac2-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1918-05-25/ch86/s2"},"text":"May 25, 1918, ch. 86, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/570"},"text":"40 Stat. 570","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
