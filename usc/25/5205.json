{"tag":"section","attrib":{"id":"id62ddc6f6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5205"},"text":null,"children":[{"tag":"num","attrib":{"value":"5205"},"text":"§ 5205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment or revocation of charters; suits by and against associations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The charters of any cooperative association organized pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5204"},"text":"section 5204 of this title","children":[],"tail":" shall not be amended or revoked by the Secretary except after a majority vote of the membership. Such cooperative associations may sue and be sued in any court of the State of Oklahoma or of the United States having jurisdiction of the cause of action, but a certified copy of all papers filed in any action against a cooperative association in a court of Oklahoma shall be served upon the Secretary of the Interior, or upon an employee duly authorized by him to receive such service. Within thirty days after such service or within such extended time as the trial court may permit, the Secretary of the Interior may intervene in such action or may remove such action to the United States district court."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62ddc6f7-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-26/ch831/s5"},"text":"June 26, 1936, ch. 831, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1968"},"text":"49 Stat. 1968","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s29"},"text":"June 25, 1948, ch. 646, § 29","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/991"},"text":"62 Stat. 991","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ddc6f8-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62ddc6f9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62ddc6fa-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s505"},"text":"section 505 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62ddc6fb-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1948—Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", struck out provisions relating to procedure for removal."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62ddc6fc-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id62ddc6fd-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1948 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s38"},"text":"Act June 25, 1948, ch. 646, § 38","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/992"},"text":"62 Stat. 992","children":[],"tail":", provided that the amendment made by that act is effective Sept 1, 1948."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
