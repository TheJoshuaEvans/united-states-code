{"tag":"section","attrib":{"id":"id62a48e3e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511"},"text":null,"children":[{"tag":"num","attrib":{"value":"2511"},"text":"§ 2511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a48e3f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Bureau” means the Bureau of Indian Affairs of the Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e40-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible Indian student","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible Indian student” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2007/f"},"text":"section 2007(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e41-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian” means a member of an Indian tribe, and includes individuals who are eligible for membership in a tribe, and the child or grandchild of such an individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e42-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” means any Indian tribe, band, nation, or other organized group or community, including an Alaska Native Village Corporation or Regional Corporation (as defined in or established pursuant to the Alaska Native Claims Settlement Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.]), which is recognized as eligible for the special programs and services provided by the United States to Indians because of their status as Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e43-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local educational agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “local educational agency” means a public board of education or other public authority legally constituted within a State for either administrative control or direction of, or to perform a service function for, public elementary schools or secondary schools in a city, county, township, school district, or other political subdivision of a State or such combination of school districts or counties as are recognized in a State as an administrative agency for the State’s public elementary schools or secondary schools. Such term includes any other public institution or agency having administrative control and direction of a public elementary school or secondary school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e44-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e45-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal governing body","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tribal governing body” means, with respect to any school that receives assistance under this Act,","children":[{"tag":"ref","attrib":{"idref":"fn002183"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002183"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the recognized governing body of the Indian tribe involved."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e46-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal organization","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a48e47-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tribal organization” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62a48e48-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recognized governing body of any Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a48e49-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any legally established organization of Indians that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62a48e4a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/8/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is controlled, sanctioned, or chartered by such governing body or is democratically elected by the adult members of the Indian community to be served by such organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62a48e4b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/8/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the maximum participation of Indians in all phases of the organization’s activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48e4c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which a grant is provided under this chapter to an organization to provide services through a tribally controlled school benefiting more than one Indian tribe, the approval of the governing bodies of Indian tribes representing 80 percent of the students attending the tribally controlled school shall be considered a sufficient tribal authorization for such grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e4d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribally controlled school","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tribally controlled school” means a school that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a48e4e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is operated by an Indian tribe or a tribal organization, enrolling students in kindergarten through grade 12, including a preschool;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48e4f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a local educational agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48e50-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2511/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not directly administered by the Bureau of Indian Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62a48e51-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5212"},"text":"Pub. L. 100–297, title V, § 5212","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1043"},"text":"Pub. L. 107–110, title X, § 1043","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2078"},"text":"115 Stat. 2078","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62a48e52-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62a48e53-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62a48e54-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Alaska Native Claims Settlement Act, referred to in par. (4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in par. (7), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":" and probably should be “this part”, meaning part B of title V of "},{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":", known as the Tribally Controlled Schools Act of 1988, which is classified generally to this chapter. For complete classification of part B to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2501"},"text":"section 2501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62a48e55-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2511, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5212"},"text":"Pub. L. 100–297, title V, § 5212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/394"},"text":"102 Stat. 394","children":[],"tail":", defined terms, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1043"},"text":"Pub. L. 107–110, title X, § 1043","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2063"},"text":"115 Stat. 2063","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62a48e56-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id62a48e57-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
