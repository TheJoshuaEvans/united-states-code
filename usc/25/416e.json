{"tag":"section","attrib":{"id":"id623b938f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s416e"},"text":null,"children":[{"tag":"num","attrib":{"value":"416e"},"text":"§ 416e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of leases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall approve no lease pursuant to sections 416 to 416j of this title that contains any provision that will prevent or delay a termination of Federal trust responsibilities with respect to the land during the term of the lease.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id623b9390-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/715/s6"},"text":"Pub. L. 89–715, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1113"},"text":"80 Stat. 1113","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
