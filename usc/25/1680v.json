{"tag":"section","attrib":{"id":"id6279adb1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680v"},"text":null,"children":[{"tag":"num","attrib":{"value":"1680v"},"text":"§ 1680v.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of HIV/AIDS Prevention and Treatment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6279adb2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680v/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, shall establish within the Service the position of the Director of HIV/AIDS Prevention and Treatment (referred to in this section as the “Director”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6279adb3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680v/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6279adb4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680v/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and promote HIV/AIDS prevention and treatment activities specific to Indians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279adb5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680v/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to Indian tribes, tribal organizations, and urban Indian organizations regarding existing HIV/AIDS prevention and treatment programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279adb6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680v/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure interagency coordination to facilitate the inclusion of Indians in Federal HIV/AIDS research and grant opportunities, with emphasis on the programs operated under the Ryan White Comprehensive Aids ","children":[{"tag":"ref","attrib":{"idref":"fn002100"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002100"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “AIDS”."}],"tail":" Resources Emergency Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/pl/101/381"},"text":"Public Law 101–381","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/104/576"},"text":"104 Stat. 576","children":[],"tail":") and the amendments made by that Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6279adb7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680v/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", and not less frequently than once every 2 years thereafter, the Director shall submit to Congress a report describing, with respect to the preceding 2-year period—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6279adb8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680v/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each activity carried out under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279adb9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680v/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any findings of the Director with respect to HIV/AIDS prevention and treatment activities specific to Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6279adba-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s832"},"text":"Pub. L. 94–437, title VIII, § 832","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6279adbb-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6279adbc-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6279adbd-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Ryan White Comprehensive AIDS Resources Emergency Act of 1990, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attri