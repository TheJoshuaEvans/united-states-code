{"tag":"section","attrib":{"id":"id625f6eb3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l"},"text":null,"children":[{"tag":"num","attrib":{"value":"1616l"},"text":"§ 1616l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community health aide program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id625f6eb4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General purposes of program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":", the Secretary, acting through the Service, shall develop and operate a Community Health Aide Program in the State of Alaska under which the Service—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id625f6eb5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for the training of Alaska Natives as health aides or community health practitioners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6eb6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses those aides or practitioners in the provision of health care, health promotion, and disease prevention services to Alaska Natives living in villages in rural Alaska; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6eb7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for the establishment of teleconferencing capacity in health clinics located in or near those villages for use by community health aides or community health practitioners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625f6eb8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific program requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Community Health Aide Program of the Service, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625f6eb9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using trainers accredited by the Program, provide a high standard of training to community health aides and community health practitioners to ensure that those aides and practitioners provide quality health care, health promotion, and disease prevention services to the villages served by the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6eba-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in order to provide such training, develop a curriculum that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id625f6ebb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combines education regarding the theory of health care with supervised practical experience in the provision of health care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625f6ebc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides instruction and practical experience in the provision of acute care, emergency care, health promotion, disease prevention, and the efficient and effective management of clinic pharmacies, supplies, equipment, and facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625f6ebd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotes the achievement of the health status objectives specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1602/2"},"text":"section 1602(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6ebe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain a Community Health Aide Certification Board to certify as community health aides or community health practitioners individuals who have successfully completed the training described in paragraph (1) or can demonstrate equivalent experience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6ebf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and maintain a system that identifies the needs of community health aides and community health practitioners for continuing education in the provision of health care, including the areas described in paragraph (2)(B), and develop programs that meet the needs for such continuing education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6ec0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and maintain a system that provides close supervision of community health aides and community health practitioners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6ec1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a system under which the work of community health aides and community health practitioners is reviewed and evaluated to ensure the provision of quality health care, health promotion, and disease prevention services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6ec2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id625f6ec3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pulpal therapy (not including pulpotomies on deciduous teeth) or extraction of adult teeth can be performed by a dental health aide therapist only after consultation with a licensed dentist who determines that the procedure is a medical emergency that cannot be resolved with palliative treatment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625f6ec4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dental health aide therapists are strictly prohibited from performing all other oral or jaw surgeries, subject to the condition that uncomplicated extractions shall not be considered oral surgery under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625f6ec5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625f6ec6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Neutral panel","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id625f6ec7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, shall establish a neutral panel to carry out the study under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625f6ec8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the neutral panel shall be appointed by the Secretary from among clinicians, economists, community practitioners, oral epidemiologists, and Alaska Natives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6ec9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id625f6eca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The neutral panel established under paragraph (1) shall conduct a study of the dental health aide therapist services provided by the Community Health Aide Program under this section to ensure that the quality of care provided through those services is adequate and appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625f6ecb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parameters of study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with interested parties, including professional dental organizations, shall develop the parameters of the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625f6ecc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study shall include a determination by the neutral panel with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id625f6ecd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the dental health aide therapist services under this section to address the dental care needs of Alaska Natives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id625f6ece-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quality of care provided through those services, including any training, improvement, or additional oversight required to improve the quality of care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id625f6ecf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether safer and less costly alternatives to the dental health aide therapist services exist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625f6ed0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the study under this paragraph, the neutral panel shall consult with Alaska tribal organizations with respect to the adequacy and accuracy of the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6ed1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The neutral panel shall submit to the Secretary, the Committee on Indian Affairs of the Senate, and the Committee on Natural Resources of the House of Representatives a report describing the results of the study under paragraph (2), including a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id625f6ed2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any determination of the neutral panel under paragraph (2)(C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625f6ed3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any comments received from Alaska tribal organizations under paragraph (2)(D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625f6ed4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nationalization of program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625f6ed5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Secretary, acting through the Service, may establish a national Community Health Aide Program in accordance with the program under this section, as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6ed6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement; exclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraphs (3) and (4), in establishing a national program under paragraph (1), the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id625f6ed7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not reduce the amounts provided for the Community Health Aide Program described in subsections (a) and (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625f6ed8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall exclude dental health aide therapist services from services covered under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6ed9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of Indian tribe or tribal organization","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id625f6eda-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (B) of paragraph (2) shall not apply in the case of an election made by an Indian tribe or tribal organization located in a State (other than Alaska) in which the use of dental health aide therapist services or midlevel dental health provider services is authorized under State law to supply such services in accordance with State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625f6edb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On an election by an Indian tribe or tribal organization under subparagraph (A), the Secretary, acting through the Service, shall facilitate implementation of the services elected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6edc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not fill any vacancy for a certified dentist in a program operated by the Service with a dental health aide therapist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625f6edd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616l/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall restrict the ability of the Service, an Indian tribe, or a tribal organization to participate in any program or to provide any service authorized by any other Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id625f6ede-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tI/s119"},"text":"Pub. L. 94–437, title I, § 119","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tI/s111"},"text":"Pub. L. 102–573, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4539"},"text":"106 Stat. 4539","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id625f6edf-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id625f6ee0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id625f6ee1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":" is based on section 111 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":", except as provided in "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/b/1"},"text":"section 10221(b)(1) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id625f6ee2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"Pub. L. 111–148, § 10221(a)","children":[],"tail":", amended section generally. Prior to amendment, section related to maintenance of Community Health Aide Program for Alaska and related training, curriculum, and establishment and maintenance of Certification Board."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/b/1/A/i"},"text":"Pub. L. 111–148, § 10221(b)(1)(A)(i)","children":[],"tail":", substituted “Subject to paragraphs (3) and (4), in establishing” for “In establishing” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/b/1/A/ii"},"text":"Pub. L. 111–148, § 10221(b)(1)(A)(ii)","children":[],"tail":", added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/b/1/B"},"text":"Pub. L. 111–148, § 10221(b)(1)(B)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
