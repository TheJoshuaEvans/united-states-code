{"tag":"section","attrib":{"id":"id6210b366-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s46"},"text":null,"children":[{"tag":"num","attrib":{"value":"46"},"text":"§ 46.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference to Indians in employment of clerical, mechanical, and other help","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Preference shall at all times, as far as practicable, be given to Indians in the employment of clerical, mechanical, and other help on reservations and about agencies.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6210b367-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1882-05-17/ch163/s6"},"text":"May 17, 1882, ch. 163, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/22/88"},"text":"22 Stat. 88","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1884-07-04/ch180/s6"},"text":"July 4, 1884, ch. 180, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/23/97"},"text":"23 Stat. 97","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6210b368-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6210b369-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id6210b36a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
