{"tag":"section","attrib":{"id":"id62bc5c97-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410"},"text":null,"children":[{"tag":"num","attrib":{"value":"3410"},"text":"§ 3410.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal responsibilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62bc5c98-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead agency","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5c99-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the lead agency responsible for implementation of this chapter shall be the Bureau of Indian Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c9a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The responsibilities of the Director of the Bureau of Indian Affairs in carrying out this chapter shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62bc5c9b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in coordination with the head of each Federal agency overseeing a program identified in the plan, the development of a single model report for each Indian tribe that has in place an approved plan under this chapter to submit to the Director reports on any consolidated activities undertaken and joint expenditures made under the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5c9c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision, directly or through contract, of appropriate voluntary and technical assistance to participating Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5c9d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and use of a single monitoring and oversight system for plans approved under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5c9e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62bc5c9f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the receipt of all funds covered by a plan approved under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62bc5ca0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distribution of the funds to the respective Indian tribes by not later than 45 days after the date of receipt of the funds from the appropriate Federal department or agency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5ca1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62bc5ca2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance of activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3406"},"text":"section 3406 of this title","children":[],"tail":" relating to agency waivers; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62bc5ca3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of an interagency dispute resolution process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5ca4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memorandum of agreement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62bc5ca5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2017-12-18"},"text":"December 18, 2017","children":[],"tail":", the Secretary (acting through the Director of the Bureau of Indian Affairs), in conjunction with the Secretaries of Agriculture, Commerce, Education, Energy, Health and Human Services, Homeland Security, Housing and Urban Development, Labor, Transportation, and Veterans Affairs and the Attorney General, shall enter into an interdepartmental memorandum of agreement providing for the implementation of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5ca6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The memorandum of agreement under subparagraph (A) shall include provisions relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62bc5ca7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an annual meeting of participating Indian tribes and Federal departments and agencies, to be co-chaired by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62bc5ca8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative of the President; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62bc5ca9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative of the participating Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62bc5caa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual review of the achievements under this chapter, including the number and percentage of program participants in unsubsidized employment during the second quarter after exit from the program, and any statutory, regulatory, administrative, or policy obstacles that prevent participating Indian tribes from fully and efficiently carrying out the purposes of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62bc5cab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a forum comprised of participating Indian tribes and Federal departments and agencies to identify and resolve interagency conflicts and conflicts between the Federal Government and Indian tribes in the administration of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5cac-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report format","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5cad-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The lead agency shall develop and distribute to Indian tribes that have in place an approved plan under this chapter a single report format, in accordance with the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5cae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The lead agency shall ensure that the report format developed under paragraph (1), together with records maintained by each participating Indian tribe, contains information sufficient—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62bc5caf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine whether the Indian tribe has complied with the requirements of the approved plan of the Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5cb0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the number and percentage of program participants in unsubsidized employment during the second quarter after exit from the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5cb1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide assurances to the head of each applicable Federal department or agency that the Indian tribe has complied with all directly applicable statutory and regulatory requirements not waived under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3406"},"text":"section 3406 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5cb2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3410/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report format developed under paragraph (1) shall not require a participating Indian tribe to report on the expenditure of funds expressed by fund source or single agency code transferred to the Indian tribe under an approved plan under this chapter but instead shall require the Indian tribe to submit a single report on the expenditure of consolidated funds under such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62bc5cb3-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/477/s11"},"text":"Pub. L. 102–477, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2304"},"text":"106 Stat. 2304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/93/s11"},"text":"Pub. L. 115–93, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-18"},"text":"Dec. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2032"},"text":"131 Stat. 2032","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62bc5cb4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62bc5cb5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62bc5cb6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/93"},"text":"Pub. L. 115–93","children":[],"tail":" amended section generally. Prior to amendment, section related to Federal responsibilities, specifying the responsibilities of Department of the Interior, and report requirements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
