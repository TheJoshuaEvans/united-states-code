{"tag":"section","attrib":{"id":"id6298a7c7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2207"},"text":null,"children":[{"tag":"num","attrib":{"value":"2207"},"text":"§ 2207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full faith and credit to tribal actions under tribal ordinances limiting descent and distribution of trust or restricted or controlled lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary in carrying out his responsibility to regulate the descent and distribution of trust lands under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s372"},"text":"section 372 of this title","children":[],"tail":", and other laws, shall give full faith and credit to any tribal actions taken pursuant to subsections (a) and (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2205"},"text":"section 2205 of this title","children":[],"tail":", which provision shall apply only to estates of decedent’s whose deaths occur on or after the effective date of tribal ordinances adopted pursuant to this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6298a7c8-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/459/tII/s208"},"text":"Pub. L. 97–459, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2519"},"text":"96 Stat. 2519","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/462/tI/s103/5"},"text":"Pub. L. 106–462, title I, § 103(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1999"},"text":"114 Stat. 1999","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6298a7c9-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6298a7ca-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6298a7cb-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/462"},"text":"Pub. L. 106–462","children":[],"tail":" substituted “subsections (a) and (b) of section 2205” for “section 2205”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
