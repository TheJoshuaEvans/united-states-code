{"tag":"section","attrib":{"id":"id62c1177b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3601"},"text":null,"children":[{"tag":"num","attrib":{"value":"3601"},"text":"§ 3601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds and declares that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c1177c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3601/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a government-to-government relationship between the United States and each Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c1177d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3601/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States has a trust responsibility to each tribal government that includes the protection of the sovereignty of each tribal government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c1177e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3601/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress, through statutes, treaties, and the exercise of administrative authorities, has recognized the self-determination, self-reliance, and inherent sovereignty of Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c1177f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3601/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribes possess the inherent authority to establish their own form of government, including tribal justice systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11780-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3601/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal justice systems are an essential part of tribal governments and serve as important forums for ensuring public health and safety and the political integrity of tribal governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11781-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3601/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress and the Federal courts have repeatedly recognized tribal justice systems as the appropriate forums for the adjudication of disputes affecting personal and property rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11782-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3601/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" traditional tribal justice practices are essential to the maintenance of the culture and identity of Indian tribes and to the goals of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11783-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3601/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal justice systems are inadequately funded, and the lack of adequate funding impairs their operation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11784-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3601/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal government involvement in and commitment to improving tribal justice systems is essential to the accomplishment of the goals of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c11785-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/176/s2"},"text":"Pub. L. 103–176, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2004"},"text":"107 Stat. 2004","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c11786-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62c11787-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id62c11788-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/176/s1"},"text":"Pub. L. 103–176, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2004"},"text":"107 Stat. 2004","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/176/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Indian Tribal Justice Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
