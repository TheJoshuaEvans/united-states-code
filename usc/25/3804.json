{"tag":"section","attrib":{"id":"id62c5f979-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3804"},"text":null,"children":[{"tag":"num","attrib":{"value":"3804"},"text":"§ 3804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated such sums as may be necessary to carry out this chapter. Funds provided under this chapter are to be considered nonreimbursable.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62c5f97a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/302/s5"},"text":"Pub. L. 103–302, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1563"},"text":"108 Stat. 1563","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
