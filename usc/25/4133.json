{"tag":"section","attrib":{"id":"id62cd259b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4133"},"text":null,"children":[{"tag":"num","attrib":{"value":"4133"},"text":"§ 4133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62cd259c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cd259d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4133/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), each recipient shall develop written policies governing rents and homebuyer payments charged for dwelling units assisted under this chapter, including the methods by which such rents and homebuyer payments are determined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cd259e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4133/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum rent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any low-income family residing in a dwelling unit assisted with grant amounts under this chapter, the monthly rent or homebuyer payment (as applicable) for such dwelling unit may not exceed 30 percent of the monthly adjusted income of such family.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cd259f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4133/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance and efficient operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient who owns or operates (or is responsible for funding any entity that owns or operates) housing developed or operated pursuant to a contract between the Secretary and an Indian housing authority pursuant to the United States Housing Act of 1937 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"42 U.S.C. 1437","children":[],"tail":" et seq.] shall, using amounts of any grants received under this chapter, reserve and use for operating assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4132/1"},"text":"section 4132(1) of this title","children":[],"tail":" such amounts as may be necessary to provide for the continued maintenance and efficient operation of such housing. This subsection may not be construed to prevent any recipient (or entity funded by a recipient) from demolishing or disposing of Indian housing referred to in this subsection, pursuant to regulations established by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cd25a0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4133/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurance coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient shall maintain adequate insurance coverage for housing units that are owned or operated or assisted with grant amounts provided under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cd25a1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4133/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for admission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient shall develop written policies governing the eligibility, admission, and occupancy of families for housing assisted with grant amounts provided under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cd25a2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4133/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management and maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient shall develop policies governing the management and maintenance of housing assisted with grant amounts under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cd25a3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4133/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant amounts over extended periods","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cd25a4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4133/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that the Indian housing plan for an Indian tribe provides for the use of amounts of a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4111"},"text":"section 4111 of this title","children":[],"tail":" for a period of more than 1 fiscal year, or for affordable housing activities for which the amounts will be committed for use or expended during a subsequent fiscal year, the Secretary shall not require those amounts to be used or committed for use at any time earlier than otherwise provided for in the Indian housing plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cd25a5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4133/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount of a grant provided to an Indian tribe under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4111"},"text":"section 4111 of this title","children":[],"tail":" for a fiscal year that is not used by the Indian tribe during that fiscal year may be used by the Indian tribe during any subsequent fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cd25a6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4133/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" De minimis exemption for procurement of goods and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, a recipient shall not be required to act in accordance with any otherwise applicable competitive procurement rule or procedure with respect to the procurement, using a grant provided under this chapter, of goods and services the value of which is less than $5,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62cd25a7-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tII/s203"},"text":"Pub. L. 104–330, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4032"},"text":"110 Stat. 4032","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/411/tII/s203"},"text":"Pub. L. 110–411, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4325"},"text":"122 Stat. 4325","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62cd25a8-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62cd25a9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62cd25aa-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", known as the Native American Housing Assistance and Self-Determination Act of 1996. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The United States Housing Act of 1937, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"act Sept. 1, 1937, ch. 896","children":[],"tail":", as revised generally by "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/tII/s201/a"},"text":"Pub. L. 93–383, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/653"},"text":"88 Stat. 653","children":[],"tail":", which is classified generally to chapter 8 (§ 1437 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"section 1437 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62cd25ab-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/411"},"text":"Pub. L. 110–411","children":[],"tail":" added subsecs. (f) and (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62cd25ac-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id62cd25ad-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s107"},"text":"section 107 of Pub. L. 104–330","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
