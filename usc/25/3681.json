{"tag":"section","attrib":{"id":"id62c38857-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3681"},"text":null,"children":[{"tag":"num","attrib":{"value":"3681"},"text":"§ 3681.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c38858-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3681/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General may award grants and provide technical assistance to Indian tribes to enable such tribes to carry out programs to support—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c38859-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3681/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, enhancement, and continuing operation of tribal justice systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c3885a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3681/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the development and implementation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62c3885b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3681/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal codes and sentencing guidelines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c3885c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3681/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inter-tribal courts and appellate systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c3885d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3681/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal probation services, diversion programs, and alternative sentencing provisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c3885e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3681/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal juvenile services and multi-disciplinary protocols for child physical and sexual abuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c3885f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3681/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" traditional tribal judicial practices, traditional tribal justice systems, and traditional methods of dispute resolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c38860-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3681/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Attorney General may consult with the Office of Tribal Justice and any other appropriate tribal or Federal officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c38861-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3681/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may promulgate such regulations and guidelines as may be necessary to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c38862-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3681/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out the activities under this section, there are authorized to be appropriated such sums as are necessary for fiscal years 2011 through 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c38863-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/559/tII/s201"},"text":"Pub. L. 106–559, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2781"},"text":"114 Stat. 2781","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s242/b/3/B"},"text":"Pub. L. 111–211, title II, § 242(b)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2292"},"text":"124 Stat. 2292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c38864-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62c38865-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62c38866-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211"},"text":"Pub. L. 111–211","children":[],"tail":" substituted “2011 through 2015” for “2000 through 2004”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
