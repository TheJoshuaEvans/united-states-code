{"tag":"section","attrib":{"id":"id623b9375-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s415b"},"text":null,"children":[{"tag":"num","attrib":{"value":"415b"},"text":"§ 415b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance payment of rent or other consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No rent or other consideration for the use of land leased under sections 415 to 415d of this title shall be paid or collected more than one year in advance, unless so provided in the lease.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id623b9376-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch615/s4"},"text":"Aug. 9, 1955, ch. 615, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/540"},"text":"69 Stat. 540","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
