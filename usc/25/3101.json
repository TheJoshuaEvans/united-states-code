{"tag":"section","attrib":{"id":"id62b2e70f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3101"},"text":null,"children":[{"tag":"num","attrib":{"value":"3101"},"text":"§ 3101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds and declares that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b2e710-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the forest lands of Indians are among their most valuable resources and Indian forest lands—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b2e711-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3101/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encompass more than 15,990,000 acres, including more than 5,700,000 acres of commercial forest land and 8,700,000 acres of woodland,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e712-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3101/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are a perpetually renewable and manageable resource,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e713-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3101/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide economic benefits, including income, employment, and subsistence, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e714-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3101/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide natural benefits, including ecological, cultural, and esthetic values;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e715-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States has a trust responsibility toward Indian forest lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e716-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing Federal laws do not sufficiently assure the adequate and necessary trust management of Indian forest lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e717-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal investment in, and the management of, Indian forest land is significantly below the level of investment in, and management of, National Forest Service forest land, Bureau of Land Management forest land, or private forest land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e718-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3101/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal governments make substantial contributions to the overall management of Indian forest land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e719-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3101/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a serious threat to Indian forest lands arising from trespass and unauthorized harvesting of Indian forest land resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b2e71a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIII/s302"},"text":"Pub. L. 101–630, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4532"},"text":"104 Stat. 4532","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62b2e71b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62b2e71c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id62b2e71d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/278/s1"},"text":"Pub. L. 108–278, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-22"},"text":"July 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/868"},"text":"118 Stat. 868","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/278/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3115a"},"text":"section 3115a of this title","children":[],"tail":" and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3115b"},"text":"section 3115b of this title","children":[],"tail":"] may be cited as the ‘Tribal Forest Protection Act of 2004’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id62b2e71e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIII/s301"},"text":"Pub. L. 101–630, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4532"},"text":"104 Stat. 4532","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/630/tIII/s301"},"text":"“This title [enacting this chapter] may be cited as the ‘National Indian Forest Resources Management Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
