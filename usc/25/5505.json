{"tag":"section","attrib":{"id":"id62f593f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5505"},"text":null,"children":[{"tag":"num","attrib":{"value":"5505"},"text":"§ 5505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gross receipts from conveyed lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f593f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit to credit of tribe; nonapplicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any and all gross receipts derived from, or which relate to, the property conveyed by this chapter, the Act of ","children":[{"tag":"date","attrib":{"date":"1956-07-20"},"text":"July 20, 1956","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/70/581"},"text":"70 Stat. 581","children":[],"tail":"), the Act of "},{"tag":"date","attrib":{"date":"1956-08-02"},"text":"August 2, 1956","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/70/941"},"text":"70 Stat. 941","children":[],"tail":"), the Act of "},{"tag":"date","attrib":{"date":"1972-10-09"},"text":"October 9, 1972","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/86/795"},"text":"86 Stat. 795","children":[],"tail":"), and "},{"tag":"ref","attrib":{"href":"/us/act/1972-10-13/s1"},"text":"section 1 of the Act of October 13, 1972","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/86/806"},"text":"86 Stat. 806","children":[],"tail":") which were received by the United States subsequent to its acquisition by the United States under the statutes cited in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5501"},"text":"section 5501 of this title","children":[],"tail":" and prior to such conveyance, from whatever source and for whatever purpose, including but not limited to the receipts in the special fund of the Treasury as required by section 6 of the Mineral Leasing Act for Acquired Lands of "},{"tag":"date","attrib":{"date":"1947-08-07"},"text":"August 7, 1947","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/61/913"},"text":"61 Stat. 913","children":[],"tail":", 915) ["},{"tag":"ref","attrib":{"href":"/us/usc/t30/s355"},"text":"30 U.S.C. 355","children":[],"tail":"], shall as of "},{"tag":"date","attrib":{"date":"1975-10-17"},"text":"October 17, 1975","children":[],"tail":", be deposited to the credit of the Indian tribe receiving such land and may be expended by the tribe for such beneficial programs as the tribal governing body may determine: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That this section shall not apply to any such receipts received prior to "},{"tag":"date","attrib":{"date":"1975-10-17"},"text":"October 17, 1975","children":[],"tail":", from the leasing of public domain minerals which were subject to the Mineral Leasing Act of 1920 ("},{"tag":"ref","attrib":{"href":"/us/stat/41/437"},"text":"41 Stat. 437","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t30/s181"},"text":"30 U.S.C. 181","children":[],"tail":" et seq.], as amended and supplemented."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f593f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of gross receipts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All gross receipts (including but not limited to bonuses, rents, and royalties) hereafter derived by the United States from any contract, permit or lease referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5504/a"},"text":"section 5504