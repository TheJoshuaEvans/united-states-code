{"tag":"section","attrib":{"id":"id62becd77-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503"},"text":null,"children":[{"tag":"num","attrib":{"value":"3503"},"text":"§ 3503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribal energy resource regulation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62becd78-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide to Indian tribes, on an annual basis, grants for use in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62becd79-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds from a grant provided under this section may be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62becd7a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62becd7b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an Indian tribe for the development of a tribal energy resource inventory or tribal energy resource on Indian land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd7c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an Indian tribe for the development of a feasibility study or other report necessary to the development of energy resources on Indian land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd7d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by an Indian tribe (other than an Indian Tribe in the State of Alaska, except the Metlakatla Indian Community) for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62becd7e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and enforcement of tribal laws (including regulations) relating to tribal energy resource development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62becd7f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of technical infrastructure to protect the environment under applicable law; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd80-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a Native Corporation for the development and implementation of corporate policies and the development of technical infrastructure to protect the environment under applicable law; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd81-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by an Indian tribe for the training of employees that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62becd82-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are engaged in the development of energy resources on Indian land; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd83-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are responsible for protecting the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62becd84-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62becd85-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the obligations of the United States under this chapter, the Secretary shall ensure, to the maximum extent practicable and to the extent of available resources, that on the request of an Indian tribe or a tribal energy development organization, the Indian tribe or tribal energy development organization shall have available scientific and technical information and expertise, for use in the regulation, development, and management of energy resources of the Indian tribe on Indian land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd86-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may carry out paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62becd87-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly, through the use of Federal officials; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd88-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3503/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indirectly, by providing financial assistance to an Indian tribe or tribal energy development organization to secure independent assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62becd89-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXVI/s2603"},"text":"Pub. L. 102–486, title XXVI, § 2603","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tV/s503/a"},"text":"Pub. L. 109–58, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/768"},"text":"119 Stat. 768","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/325/tI/s102"},"text":"Pub. L. 115–325, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-18"},"text":"Dec. 18, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4447"},"text":"132 Stat. 4447","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62becd8a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62becd8b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62becd8c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3503, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXVI/s2603"},"text":"Pub. L. 102–486, title XXVI, § 2603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3114"},"text":"106 Stat. 3114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/388/s10"},"text":"Pub. L. 105–388, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3484"},"text":"112 Stat. 3484","children":[],"tail":", related to promotion of energy resource development and energy vertical integration on Indian reservations, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62becd8d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325/s102/1"},"text":"Pub. L. 115–325, § 102(1)","children":[],"tail":", substituted “on the request of an Indian tribe or a tribal energy development organization, the Indian tribe or tribal energy development organization” for “on the request of an Indian tribe, the Indian tribe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325/s102/2"},"text":"Pub. L. 115–325, § 102(2)","children":[],"tail":", inserted “or tribal energy development organization” after “Indian tribe”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
