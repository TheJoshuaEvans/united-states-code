{"tag":"section","attrib":{"id":"id62ee68b8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365"},"text":null,"children":[{"tag":"num","attrib":{"value":"5365"},"text":"§ 5365.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62ee68b9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian Tribe and the Secretary shall include in any compact or funding agreement provisions that reflect the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee68ba-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian Tribe participating in self-governance shall ensure that internal measures are in place to address, pursuant to Tribal law and procedures, conflicts of interest in the administration of programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee68bb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee68bc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single Agency Audit Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 75 of title 31 shall apply to a funding agreement under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee68bd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost principles","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Indian Tribe shall apply cost principles under the applicable Office of Management and Budget circular, except as modified by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ee68be-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provision of law, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5325"},"text":"section 5325 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ee68bf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any exemptions to applicable Office of Management and Budget circulars subsequently granted by the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee68c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any claim by the Federal Government against an Indian Tribe relating to funds received under a funding agreement based on any audit under this subsection shall be subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5325/f"},"text":"section 5325(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee68c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redesign and consolidation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5367"},"text":"section 5367 of this title","children":[],"tail":", an Indian Tribe may redesign or consolidate programs, or reallocate funds for programs, in a compact or funding agreement in any manner that the Indian Tribe determines to be in the best interest of the Indian community being served—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee68c2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" so long as the redesign or consolidation does not have the effect of denying eligibility for services to population groups otherwise eligible to be served under applicable Federal law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee68c3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except that, with respect to the reallocation, consolidation, and redesign of programs described in subsection (b)(2) or (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5363"},"text":"section 5363 of this title","children":[],"tail":", a joint agreement between the Secretary and the Indian Tribe shall be required."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee68c4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retrocession","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee68c5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian Tribe may fully or partially retrocede to the Secretary any program under a compact or funding agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee68c6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ee68c7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless an Indian Tribe rescinds a request for retrocession under paragraph (1), the retrocession shall become effective on the date specified by the parties in the compact or funding agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ee68c8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the absence of a specification of an effective date in the compact or funding agreement, the retrocession shall become effective on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62ee68c9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the earlier of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62ee68ca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/e/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 year after the date on which the request is submitted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62ee68cb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/e/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the funding agreement expires; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ee68cc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such date as may be mutually agreed upon by the Secretary and the Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee68cd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonduplication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A funding agreement shall provide that, for the period for which, and to the extent to which, funding is provided to an Indian Tribe under this subchapter, the Indian Tribe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee68ce-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be entitled to contract with the Secretary for funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"section 5321 of this title","children":[],"tail":", except that the Indian Tribe shall be eligible for new programs on the same basis as other Indian Tribes; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee68cf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be responsible for the administration of programs in accordance with the compact or funding agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee68d0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee68d1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless an Indian Tribe specifies otherwise in the compact or funding agreement, records of an Indian Tribe shall not be considered to be Federal records for purposes of chapter 5 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee68d2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Indian Tribe shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ee68d3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a recordkeeping system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ee68d4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5365/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a notice period of not less than 30 days, provide the Secretary with reasonable access to the records to enable the Department to meet the requirements of sections 3101 through 3106 of title 44.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62ee68d5-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tIV/s405"},"text":"Pub. L. 93–638, title IV, § 405","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/180/tI/s101/e"},"text":"Pub. L. 116–180, title I, § 101(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-21"},"text":"Oct. 21, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/865"},"text":"134 Stat. 865","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ee68d6-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62ee68d7-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62ee68d8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5365, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tIV/s405"},"text":"Pub. L. 93–638, title IV, § 405","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/413/tII/s204"},"text":"Pub. L. 103–413, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4276"},"text":"108 Stat. 4276","children":[],"tail":", related to reports, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/116/180/tI/s101/e"},"text":"Pub. L. 116–180, title I, § 101(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-21"},"text":"Oct. 21, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/864"},"text":"134 Stat. 864","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5372"},"text":"section 5372 of this title","children":[],"tail":". Such section was formerly classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s458ee"},"text":"section 458ee of this title","children":[],"tail":" prior to editorial reclassification and renumbering as section 5365."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
