{"tag":"section","attrib":{"id":"id6255d242-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1499"},"text":null,"children":[{"tag":"num","attrib":{"value":"1499"},"text":"§ 1499.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on guarantee of debt issues; approval of bond issue sale","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6255d243-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1499/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may guarantee not to exceed 90 percent of the unpaid principal and interest due on an issue of bonds, debentures, or similar obligations issued by an organization satisfactory to the Secretary. Such an issue shall be deemed a loan for purposes of sections 1482, 1483, 1484, 1485, 1486, 1489, 1490, 1491, 1493, 1494, 1495, 1496, and 1497 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d244-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1499/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The method by which an issue of bonds guaranteed under this section may be sold shall be subject to approval by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6255d245-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/tII/s220"},"text":"Pub. L. 93–262, title II, § 220","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/442/s6"},"text":"Pub. L. 100–442, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-22"},"text":"Sept. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1764"},"text":"102 Stat. 1764","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
