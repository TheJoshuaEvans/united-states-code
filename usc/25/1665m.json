{"tag":"section","attrib":{"id":"id627281fa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m"},"text":null,"children":[{"tag":"num","attrib":{"value":"1665m"},"text":"§ 1665m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic and sexual violence prevention and treatment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id627281fb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1665a"},"text":"section 1665a of this title","children":[],"tail":", is authorized to establish in each Service area programs involving the prevention and treatment of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id627281fc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian victims of domestic violence or sexual abuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627281fd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other members of the household or family of the victims described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627281fe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds made available to carry out this section shall be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627281ff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and implement prevention programs and community education programs relating to domestic violence and sexual abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728200-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide behavioral health services, including victim support services, and medical treatment (including examinations performed by sexual assault nurse examiners) to Indian victims of domestic violence or sexual abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728201-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase rape kits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728202-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop prevention and intervention models, which may incorporate traditional health care practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62728203-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and certification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62728204-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Secretary shall establish appropriate protocols, policies, procedures, standards of practice, and, if not available elsewhere, training curricula and training and certification requirements for services for victims of domestic violence and sexual abuse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728205-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Secretary shall submit to the Committee on Indian Affairs of the Senate and the Committee on Natural Resources of the House of Representatives a report that describes the means and extent to which the Secretary has carried out paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62728206-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62728207-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in coordination with the Attorney General, Federal and tribal law enforcement agencies, Indian health programs, and domestic violence or sexual assault victim organizations, shall develop appropriate victim services and victim advocate training programs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62728208-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve domestic violence or sexual abuse responses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728209-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve forensic examinations and collection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272820a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify problems or obstacles in the prosecution of domestic violence or sexual abuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272820b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet other needs or carry out other activities required to prevent, treat, and improve prosecutions of domestic violence and sexual abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6272820c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665m/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Secretary shall submit to the Committee on Indian Affairs of the Senate and the Committee on Natural Resources of the House of Representatives a report that describes, with respect to the matters described in paragraph (1), the improvements made and needed, problems or obstacles identified, and costs necessary to address the problems or obstacles, and any other recommendations that the Secretary determines to be appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6272820d-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s714"},"text":"Pub. L. 94–437, title VII, § 714","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6272820e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6272820f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62728210-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s714"},"text":"Section 714 of Pub. L. 94–437","children":[],"tail":" is based on section 181 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62728211-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1665m, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s714"},"text":"Pub. L. 94–437, title VII, § 714","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s702/a"},"text":"Pub. L. 102–573, title VII, § 702(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4581"},"text":"106 Stat. 4581","children":[],"tail":", authorized appropriations through fiscal year 2000 to carry out this subchapter, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
