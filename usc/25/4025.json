{"tag":"section","attrib":{"id":"id62c843bb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4025"},"text":null,"children":[{"tag":"num","attrib":{"value":"4025"},"text":"§ 4025.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c843bc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4025/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to award grants to Indian tribes for the purpose of developing and implementing plans for the investment of Indian tribal trust funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c843bd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4025/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes for which funds provided under this section may be used include (but are not limited to)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c843be-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4025/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training and education of employees responsible for monitoring the investment of trust funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c843bf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4025/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the building of tribal capacity for the investment and management of trust funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c843c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4025/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of a comprehensive tribal investment plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c843c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4025/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation and management of tribal trust fund investment plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c843c2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4025/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other purposes related to this subchapter that the Secretary deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c843c3-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/412/tII/s205"},"text":"Pub. L. 103–412, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4243"},"text":"108 Stat. 4243","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
