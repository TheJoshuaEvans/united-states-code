{"tag":"section","attrib":{"id":"id6255d1dc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1482"},"text":null,"children":[{"tag":"num","attrib":{"value":"1482"},"text":"§ 1482.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premium charges; deposits in Indian Loan Guaranty and Insurance Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall fix such premium charges for the insurance and guarantee of loans as are in his judgment adequate to cover expenses and probable losses, and deposit receipts from such charges in the Indian Loan Guaranty and Insurance Fund established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1497/a"},"text":"section 1497(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6255d1dd-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/tII/s202"},"text":"Pub. L. 93–262, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/79"},"text":"88 Stat. 79","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
