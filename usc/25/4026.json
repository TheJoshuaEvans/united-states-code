{"tag":"section","attrib":{"id":"id62c843c4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4026"},"text":null,"children":[{"tag":"num","attrib":{"value":"4026"},"text":"§ 4026.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of withdrawn funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to such conditions as the Secretary may prescribe, any Indian tribe which has withdrawn trust funds may choose to return any or all of the trust funds such tribe has withdrawn by notifying the Secretary in writing of its intention to return the funds to the control and management of the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62c843c5-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/412/tII/s206"},"text":"Pub. L. 103–412, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4243"},"text":"108 Stat. 4243","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
