{"tag":"section","attrib":{"id":"id62b530e9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3115a"},"text":"§ 3115a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal forest assets protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b530ea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this Act:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b530eb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal land” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b530ec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land of the National Forest System (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1609/a"},"text":"section 1609(a) of title 16","children":[],"tail":") administered by the Secretary of Agriculture, acting through the Chief of the Forest Service; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b530ed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public lands (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1702"},"text":"section 1702 of title 43","children":[],"tail":"), the surface of which is administered by the Secretary of the Interior, acting through the Director of the Bureau of Land Management."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b530ee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian forest land or rangeland","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Indian forest land or rangeland” means land that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b530ef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is held in trust by, or with a restriction against alienation by, the United States for an Indian tribe or a member of an Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b530f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b530f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62b530f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is Indian forest land (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3103"},"text":"section 3103 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62b530f3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a cover of grasses, brush, or any similar vegetation; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b530f4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formerly had a forest cover or vegetative cover that is capable of restoration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b530f5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b530f6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretary” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b530f7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, with respect to land under the jurisdiction of the Forest Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b530f8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior, with respect to land under the jurisdiction of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b530f9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to protect Indian forest land or rangeland","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b530fa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after the date on which an Indian tribe submits to the Secretary a request to enter into an agreement or contract to carry out a project to protect Indian forest land or rangeland (including a project to restore Federal land that borders on or is adjacent to Indian forest land or rangeland) that meets the criteria described in subsection (c), the Secretary may issue public notice of initiation of any necessary environmental review or of the potential of entering into an agreement or contract with the Indian tribe pursuant to section 347 of the Department of the Interior and Related Agencies Appropriations Act, 1999 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2104"},"text":"16 U.S.C. 2104","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Public Law 105–277","children":[],"tail":") (as amended by section 323 of the Department of the Interior and Related Agencies Appropriations Act, 2003 ("},{"tag":"ref","attrib":{"href":"/us/stat/117/275"},"text":"117 Stat. 275","children":[],"tail":")), or such other authority as appropriate, under which the Indian tribe would carry out activities described in paragraph (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b530fb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Following completion of any necessary environmental analysis, the Secretary may enter into an agreement or contract with the Indian tribe as described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b530fc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under an agreement or contract entered into under paragraph (2), the Indian tribe may carry out activities to achieve land management goals for Federal land that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b530fd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the jurisdiction of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b530fe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bordering or adjacent to the Indian forest land or rangeland under the jurisdiction of the Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b530ff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The criteria referred to in subsection (b), with respect to an Indian tribe, are whether—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b53100-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian forest land or rangeland under the jurisdiction of the Indian tribe borders on or is adjacent to land under the jurisdiction of the Forest Service or the Bureau of Land Management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53101-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Forest Service or Bureau of Land Management land bordering on or adjacent to the Indian forest land or rangeland under the jurisdiction of the Indian tribe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b53102-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" poses a fire, disease, or other threat to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b53103-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian forest land or rangeland under the jurisdiction of the Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b53104-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribal community; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b53105-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in need of land restoration activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53106-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreement or contracting activities applied for by the Indian tribe are not already covered by a stewardship contract or other instrument that would present a conflict on the subject land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53107-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Forest Service or Bureau of Land Management land described in the application of the Indian tribe presents or involves a feature or circumstance unique to that Indian tribe (including treaty rights or biological, archaeological, historical, or cultural circumstances).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b53108-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of denial","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary denies a tribal request under subsection (b)(1), the Secretary may issue a notice of denial to the Indian tribe, which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b53109-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the specific factors that caused, and explains the reasons that support, the denial;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b5310a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies potential courses of action for overcoming specific issues that led to the denial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b5310b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposes a schedule of consultation with the Indian tribe for the purpose of developing a strategy for protecting the Indian forest land or rangeland of the Indian tribe and interests of the Indian tribe in Federal land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b5310c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposal evaluation and determination factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In entering into an agreement or contract in response to a request of an Indian tribe under subsection (b)(1), the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b5310d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use a best-value basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b5310e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" give specific consideration to tribally-related factors in the proposal of the Indian tribe, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b5310f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the Indian tribe as an Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b53110-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trust status of the Indian forest land or rangeland of the Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b53111-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cultural, traditional, and historical affiliation of the Indian tribe with the land subject to the proposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b53112-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the treaty rights or other reserved rights of the Indian tribe relating to the land subject to the proposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b53113-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the indigenous knowledge and skills of members of the Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b53114-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the features of the landscape of the land subject to the proposal, including watersheds and vegetation types;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b53115-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/e/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the working relationships between the Indian tribe and Federal agencies in coordinating activities affecting the land subject to the proposal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b53116-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/e/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the access by members of the Indian tribe to the land subject to the proposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b53117-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on existing authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this Act—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b53118-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibits, restricts, or otherwise adversely affects the participation of any Indian tribe in stewardship agreements or contracting under the authority of section 347 of the Department of the Interior and Related Agencies Appropriations Act, 1999 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2104"},"text":"16 U.S.C. 2104","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Public Law 105–277","children":[],"tail":") (as amended by section 323 of the Department of the Interior and Related Agencies Appropriations Act, 2003 ("},{"tag":"ref","attrib":{"href":"/us/stat/117/275"},"text":"117 Stat. 275","children":[],"tail":")) or other authority invoked pursuant to this Act; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53119-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invalidates any agreement or contract under that authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b5311a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2004-07-22"},"text":"July 22, 2004","children":[],"tail":", the Secretary shall submit to Congress a report that describes the Indian tribal requests received and agreements or contracts that have been entered into under this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b5311b-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/278/s2"},"text":"Pub. L. 108–278, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-22"},"text":"July 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/868"},"text":"118 Stat. 868","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/325/tII/s202/b/1"},"text":"Pub. L. 115–325, title II, § 202(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-18"},"text":"Dec. 18, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4459"},"text":"132 Stat. 4459","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62b5311c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62b5311d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62b5311e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (a), (f), and (g), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/278"},"text":"Pub. L. 108–278","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-22"},"text":"July 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/868"},"text":"118 Stat. 868","children":[],"tail":", which enacted this section and provisions set out as notes under sections 3101 and 3115b of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 347 of the Department of the Interior and Related Agencies Appropriations Act, 1999, referred to in subsecs. (b)(1) and (f)(1), was section § 101(e) [title III, § 347] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA"},"text":"Pub. L. 105–277, div. A","children":[],"tail":", as amended, which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2104"},"text":"section 2104 of Title 16","children":[],"tail":", Conservation, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVIII/s8205/b"},"text":"Pub. L. 113–79, title VIII, § 8205(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/921"},"text":"128 Stat. 921","children":[],"tail":". Provisions similar to § 101(e) [title III, § 347] of "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA"},"text":"Pub. L. 105–277, div. A","children":[],"tail":", as amended, were enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/108/148/tVI/s604"},"text":"Pub. L. 108–148, title VI, § 604","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVIII/s8205/a"},"text":"Pub. L. 113–79, title VIII, § 8205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/918"},"text":"128 Stat. 918","children":[],"tail":" and are classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6591c"},"text":"section 6591c of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62b5311f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Tribal Forest Protection Act of 2004, and not as part of the National Indian Forest Resources Management Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62b53120-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325"},"text":"Pub. L. 115–325","children":[],"tail":" substituted “In this Act” for “In this section” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
