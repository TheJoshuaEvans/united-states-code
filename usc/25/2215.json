{"tag":"section","attrib":{"id":"id6298a818-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2215"},"text":null,"children":[{"tag":"num","attrib":{"value":"2215"},"text":"§ 2215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6298a819-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2215/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish an Acquisition Fund to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6298a81a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2215/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disburse appropriations authorized to accomplish the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2212"},"text":"section 2212 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6298a81b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2215/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect all revenues received from the lease, permit, or sale of resources from interests acquired under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2212"},"text":"section 2212 of this title","children":[],"tail":" or paid by Indian landowners under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2212"},"text":"section 2212 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6298a81c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2215/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits; use","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6298a81d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2215/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All proceeds from leases, permits, or resource sales derived from an interest in trust or restricted lands described in subsection (a)(2) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6298a81e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2215/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be deposited in the Acquisition Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6298a81f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2215/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as specified in advance in appropriations Acts, be available for the purpose of acquiring additional fractional interests in trust or restricted lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6298a820-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2215/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be used to acquire undivided interests on the reservation from which the income was derived.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6298a821-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2215/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use the revenue deposited in the Acquisition Fund under paragraph (1) to acquire some or all of the undivided interests in any parcels of land in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2204"},"text":"section 2204 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6298a822-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/459/tII/s216"},"text":"Pub. L. 97–459, title II, § 216","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/462/tI/s103/6"},"text":"Pub. L. 106–462, title I, § 103(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2002"},"text":"114 Stat. 2002","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/8"},"text":"Pub. L. 108–374, § 6(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1802"},"text":"118 Stat. 1802","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6298a823-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6298a824-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6298a825-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/8/A"},"text":"Pub. L. 108–374, § 6(a)(8)(A)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “collect all revenues received from the lease, permit, or sale of resources from interests in trust or restricted lands transferred to Indian tribes by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2212"},"text":"section 2212 of this title","children":[],"tail":" or paid by Indian landowners under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2212/c"},"text":"section 2212(c) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/8/B/i"},"text":"Pub. L. 108–374, § 6(a)(8)(B)(i)","children":[],"tail":", substituted “All” for “Subject to paragraph (2), all” in introductory provisions and added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/8/B/ii"},"text":"Pub. L. 108–374, § 6(a)(8)(B)(ii)","children":[],"tail":", added par. (2) and struck out heading and text of former par. (2). Text read as follows: “With respect to the deposit of proceeds derived from an interest under paragraph (1), the aggregate amount deposited under that paragraph shall not exceed the purchase price of that interest under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2212"},"text":"section 2212 of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
