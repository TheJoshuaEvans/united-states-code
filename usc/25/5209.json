{"tag":"section","attrib":{"id":"id62ddc710-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5209"},"text":null,"children":[{"tag":"num","attrib":{"value":"5209"},"text":"§ 5209.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations; repeals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to prescribe such rules and regulations as may be necessary to carry out the provisions of this chapter. All Acts or parts of Acts inconsistent with this chapter are repealed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62ddc711-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-26/ch831/s9"},"text":"June 26, 1936, ch. 831, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1968"},"text":"49 Stat. 1968","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ddc712-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62ddc713-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62ddc714-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s509"},"text":"section 509 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
