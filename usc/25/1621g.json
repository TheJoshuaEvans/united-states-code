{"tag":"section","attrib":{"id":"id6261b8d5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1621g"},"text":"§ 1621g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health services research","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Of the amounts appropriated for the Service in any fiscal year, other than amounts made available for the Indian Health Care Improvement Fund, not less than $200,000 shall be available only for research to further the performance of the health service responsibilities of the Service. Indian tribes and tribal organizations contracting with the Service under the authority of the Indian Self-Determination Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.] shall be given an equal opportunity to compete for, and receive, research funds under this section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6261b8d6-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tII/s208"},"text":"Pub. L. 94–437, title II, § 208","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tII/s204"},"text":"Pub. L. 100–713, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4812"},"text":"102 Stat. 4812","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6261b8d7-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6261b8d8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6261b8d9-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination Act, referred to in text, is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2206"},"text":"88 Stat. 2206","children":[],"tail":", which is classified principally to subchapter I (§ 5321 et seq.) of chapter 46 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
