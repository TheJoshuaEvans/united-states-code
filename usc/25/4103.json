{"tag":"section","attrib":{"id":"id62cab454-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103"},"text":null,"children":[{"tag":"num","attrib":{"value":"4103"},"text":"§ 4103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cab455-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjusted income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “adjusted income” means the annual income that remains after excluding the following amounts:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cab456-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Youths, students, and persons with disabilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"$480 for each member of the family residing in the household (other than the head of the household or the spouse of the head of the household)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62cab457-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is under 18 years of age; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab458-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62cab459-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 18 years of age or older; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62cab45a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person with disabilities or a full-time student.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab45b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elderly and disabled families","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"$400 for an elderly or disabled family.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab45c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical and attendant expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount by which 3 percent of the annual income of the family is exceeded by the aggregate of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62cab45d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical expenses, in the case of an elderly or disabled family; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab45e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable attendant care and auxiliary apparatus expenses for each family member who is a person with disabilities, to the extent necessary to enable any member of the family (including a member who is a person with disabilities) to be employed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab45f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child care expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Child care expenses, to the extent necessary to enable another member of the family to be employed or to further his or her education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab460-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Earned income of minors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any earned income of any member of the family who is less than 18 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab461-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Excessive travel expenses, not to exceed $25 per family per week, for employment- or education-related travel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab462-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such other amounts as may be provided in the Indian housing plan for an Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab463-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affordable housing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “affordable housing” means housing that complies with the requirements for affordable housing under subchapter II. The term includes permanent housing for homeless persons who are persons with disabilities, transitional housing, and single room occupancy housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab464-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug-related criminal activity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “drug-related criminal activity” means the illegal manufacture, sale, distribution, use, or possession with intent to manufacture, sell, distribute, or use, of a controlled substance (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"section 802 of title 21","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab465-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elderly families and near-elderly families","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “elderly family” and “near-elderly family” mean a family whose head (or his or her spouse), or whose sole member, is an elderly person or a near-elderly person, respectively. Such terms include 2 or more elderly persons or near-elderly persons living together, and 1 or more such persons living with 1 or more persons determined under the Indian housing plan for the agency to be essential to their care or well-being.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab466-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elderly person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “elderly person” means a person who is at least 62 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab467-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “family” includes a family with or without children, an elderly family, a near-­elderly family, a disabled family, and a single person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab468-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant beneficiary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “grant beneficiary” means the Indian tribe or tribes on behalf of which a grant is made under this chapter to a recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab469-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing related community development","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cab46a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “housing related community development” means any facility, community building, business, activity, or infrastructure that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62cab46b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned by an Indian tribe or a tribally designated housing entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab46c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to the provision of housing in an Indian area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab46d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/8/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62cab46e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/8/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would help an Indian tribe or tribally designated housing entity to reduce the cost of construction of Indian housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62cab46f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/8/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would make housing more affordable, accessible, or practicable in an Indian area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62cab470-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/8/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would otherwise advance the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab471-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “housing and community development” does not include any activity conducted by any Indian tribe under the Indian Gaming Regulatory Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2701"},"text":"25 U.S.C. 2701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab472-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “income” means income from all sources of each member of the household, as determined in accordance with criteria prescribed by the Secretary, except that the following amounts may not be considered as income under this paragraph:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cab473-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amounts not actually received by the family.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab474-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amounts that would be eligible for exclusion under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382b/a/7"},"text":"section 1382b(a)(7) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab475-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amounts received by any member of the family as disability compensation under chapter 11 of title 38 or dependency and indemnity compensation under chapter 13 of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab476-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian” means any person who is a member of an Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab477-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian area” means the area within which an Indian tribe or a tribally designated housing entity, as authorized by 1 or more Indian tribes, provides assistance under this chapter for affordable housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab478-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian housing plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian housing plan” means a plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4112"},"text":"section 4112 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab479-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cab47a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” means a tribe that is a federally recognized tribe or a State recognized tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab47b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally recognized tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “federally recognized tribe” means any Indian tribe, band, nation, or other organized group or community of Indians, including any Alaska Native village or regional or village corporation as defined in or established pursuant to the Alaska Native Claims Settlement Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.], that is recognized as eligible for the special programs and services provided by the United States to Indians because of their status as Indians pursuant to the Indian Self-Determination and Education Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.)."},{"tag":"ref","attrib":{"idref":"fn002230"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002230"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab47c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State recognized tribe","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62cab47d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/13/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State recognized tribe” means any tribe, band, nation, pueblo, village, or community—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62cab47e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/13/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has been recognized as an Indian tribe by any State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62cab47f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/13/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which an Indian Housing Authority has, before the effective date under section 705, entered into a contract with the Secretary pursuant to the United States Housing Act of 1937 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"42 U.S.C. 1437","children":[],"tail":" et seq.] for housing for Indian families and has received funding pursuant to such contract within the 5-year period ending upon such effective date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab480-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/13/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding clause (i)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62cab481-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/13/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allocation formula under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4152"},"text":"section 4152 of this title","children":[],"tail":" shall be determined for a State recognized tribe under tribal membership eligibility criteria in existence on "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"October 26, 1996","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62cab482-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/13/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nothing in this paragraph shall be construed to confer upon a State recognized tribe any rights, privileges, responsibilities, or obligations otherwise accorded groups recognized as Indian tribes by the United States for other purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab483-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income family","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “low-income family” means a family whose income does not exceed 80 percent of the median income for the area, as determined by the Secretary with adjustments for smaller and larger families, except that the Secretary may, for purposes of this paragraph, establish income ceilings higher or lower than 80 percent of the median for the area on the basis of the findings of the Secretary or the agency that such variations are necessary because of prevailing levels of construction costs or unusually high or low family incomes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab484-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Median income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “median income” means, with respect to an area that is an Indian area, the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cab485-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the median income for the Indian area, which the Secretary shall determine; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab486-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the median income for the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab487-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Near-elderly person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “near-elderly person” means a person who is at least 55 years of age and less than 62 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab488-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nonprofit” means, with respect to an organization, association, corporation, or other entity, that no part of the net earnings of the entity inures to the benefit of any member, founder, contributor, or individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab489-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person with disabilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “person with disabilities” means a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cab48a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/18/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a disability as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s423"},"text":"section 423 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab48b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/18/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is determined, pursuant to regulations issued by the Secretary, to have a physical, mental, or emotional impairment which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62cab48c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/18/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is expected to be of long-continued and indefinite duration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab48d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/18/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially impedes his or her ability to live independently; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab48e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/18/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of such a nature that such ability could be improved by more suitable housing conditions; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab48f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/18/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a developmental disability as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15002"},"text":"section 15002 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term shall not exclude persons who have the disease of acquired immunodeficiency syndrome or any conditions arising from the etiologic agent for acquired immunodeficiency syndrome. Notwithstanding any other provision of law, no individual shall be considered a person with disabilities, for purposes of eligibility for housing assisted under this chapter, solely on the basis of any drug or alcohol dependence. The Secretary shall consult with other appropriate Federal agencies to implement the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab490-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recipient","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “recipient” means an Indian tribe or the entity for one or more Indian tribes that is authorized to receive grant amounts under this chapter on behalf of the tribe or tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab491-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided in this chapter, the term “Secretary” means the Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab492-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, Guam, the Virgin Islands, American Samoa, and any other territory or possession of the United States and Indian tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab493-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribally designated housing entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms “tribally designated housing entity” and “housing entity” have the following meaning:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cab494-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/22/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing IHA’s","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any Indian tribe that has not taken action under subparagraph (B), and for which an Indian housing authority—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62cab495-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/22/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was established for purposes of the United States Housing Act of 1937 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"42 U.S.C. 1437","children":[],"tail":" et seq.] before "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"October 26, 1996","children":[],"tail":", that meets the requirements under the United States Housing Act of 1937,"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab496-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/22/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is acting on ","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"October 26, 1996","children":[],"tail":", as the Indian housing authority for the tribe, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab497-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/22/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not an Indian tribe for purposes of this chapter,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the terms mean such Indian housing authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab498-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/22/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any Indian tribe that, pursuant to this chapter, authorizes an entity other than the tribal government to receive grant amounts and provide assistance under this chapter for affordable housing for Indians, which entity is established—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62cab499-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/22/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by exercise of the power of self-government of one or more Indian tribes independent of State law, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab49a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/22/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by operation of State law providing specifically for housing authorities or housing entities for Indians, including regional housing authorities in the State of Alaska,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the terms mean such entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab49b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4103/22/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A tribally designated housing entity may be authorized or established by one or more Indian tribes to act on behalf of each such tribe authorizing or establishing the housing entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62cab49c-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/s4"},"text":"Pub. L. 104–330, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4018"},"text":"110 Stat. 4018","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/256/s13/b"},"text":"Pub. L. 105–256, § 13(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-14"},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1900"},"text":"112 Stat. 1900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s595/e/1"},"text":"Pub. L. 105–276, title V, § 595(e)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2656"},"text":"112 Stat. 2656","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/402/tIV/s401/b/2"},"text":"Pub. L. 106–402, title IV, § 401(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1737"},"text":"114 Stat. 1737","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/292/s3"},"text":"Pub. L. 107–292, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-13"},"text":"Nov. 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2053"},"text":"116 Stat. 2053","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/411/s3"},"text":"Pub. L. 110–411, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4320"},"text":"122 Stat. 4320","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/269/s2"},"text":"Pub. L. 111–269, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-12"},"text":"Oct. 12, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2850"},"text":"124 Stat. 2850","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62cab49d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62cab49e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62cab49f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", known as the Native American Housing Assistance and Self-Determination Act of 1996. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Gaming Regulatory Act, referred to in par. (8)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497"},"text":"Pub. L. 100–497","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2467"},"text":"102 Stat. 2467","children":[],"tail":", which is classified principally to chapter 29 (§ 2701 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2701"},"text":"section 2701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Alaska Native Claims Settlement Act, referred to in par. (13)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.), referred to in par. (13)(B), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of this title prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For the effective date under section 705, referred to in par. (13)(C)(i)(II), as ","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s705"},"text":"section 705 of Pub. L. 104–330","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4211"},"text":"section 4211 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The United States Housing Act of 1937, referred to in 