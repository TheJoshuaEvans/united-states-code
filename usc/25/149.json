{"tag":"section","attrib":{"id":"id621a287a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s149"},"text":null,"children":[{"tag":"num","attrib":{"value":"149"},"text":"§ 149.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Water Rights Settlement Completion Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id621a287b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s149/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a fund to be known as the “Indian Water Rights Settlement Completion Fund” (referred to in this section as the “Fund”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id621a287c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s149/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id621a287d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s149/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the later of ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"October 1, 2021","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", out of any funds in the Treasury not otherwise appropriated, the Secretary of the Treasury shall deposit in the Fund $2,500,000,000, to remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id621a287e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s149/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts deposited in the Fund under paragraph (1) shall be available to the Secretary of the Interior, without further appropriation or fiscal year limitation, for the uses described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id621a287f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s149/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (d), amounts deposited in the Fund under subsection (b) shall be used by the Secretary of the Interior for transfers to funds or accounts authorized to receive discretionary appropriations, or to satisfy other obligations identified by the Secretary of the Interior, under an Indian water settlement approved and authorized by an Act of Congress before ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id621a2880-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s149/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of transfers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id621a2881-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s149/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Transfers authorized under subsection (c) shall be made in such amounts as are determined by the Secretary of the Interior to be appropriate to satisfy the obligations of the United States, including appropriate indexing, pursuant to the applicable Indian water settlement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id621a2882-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s149/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sequence and timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall have the discretion to determine the sequence and timing of transfers from the Fund under subsection (c) in order to substantially complete the eligible Indian water settlements as expeditiously as practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id621a2883-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dG/tI/s70101"},"text":"Pub. L. 117–58, div. G, title I, § 70101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1250"},"text":"135 Stat. 1250","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
