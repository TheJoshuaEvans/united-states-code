{"tag":"section","attrib":{"id":"id623b939d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s416j"},"text":null,"children":[{"tag":"num","attrib":{"value":"416j"},"text":"§ 416j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission San Xavier del Bac","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in sections 416 to 416j of this title shall authorize the Secretary to approve any development which would detract from the scenic, historic, and religious values of the Mission San Xavier del Bac owned by the Franciscan Order of Friars Minor and located on the San Xavier Reservation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id623b939e-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/715/s11"},"text":"Pub. L. 89–715, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1114"},"text":"80 Stat. 1114","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
