{"tag":"section","attrib":{"id":"id62c38867-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3682"},"text":null,"children":[{"tag":"num","attrib":{"value":"3682"},"text":"§ 3682.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant probation officers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the chief judge or chief probation or pretrial services officer of each judicial district, in coordination with the Office of Tribal Justice and the Office of Justice Services, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c38868-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3682/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint individuals residing in Indian country to serve as probation or pretrial services officers or assistants for purposes of monitoring and providing services to Federal prisoners residing in Indian country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c38869-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3682/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide substance abuse, mental health, and other related treatment services to offenders residing on Indian land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c3886a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/559/tII/s203"},"text":"Pub. L. 106–559, title II, § 203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s245"},"text":"Pub. L. 111–211, title II, § 245","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2295"},"text":"124 Stat. 2295","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
