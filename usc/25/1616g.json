{"tag":"section","attrib":{"id":"id625cfe56-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1616g"},"text":"§ 1616g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" INMED program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id625cfe57-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to provide grants to at least 3 colleges and universities for the purpose of maintaining and expanding the Native American health careers recruitment program known as the “Indians into Medicine Program” (hereinafter in this section referred to as “INMED”) as a means of encouraging Indians to enter the health professions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe58-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" University of North Dakota","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide one of the grants authorized under subsection (a) to maintain the INMED program at the University of North Dakota, to be known as the “Quentin N. Burdick Indian Health Programs”, unless the Secretary makes a determination, based upon program reviews, that the program is not meeting the purposes of this section. Such program shall, to the maximum extent feasible, coordinate with the Quentin N. Burdick American Indians Into Psychology Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1621p/b"},"text":"section 1621p(b) of this title","children":[],"tail":" and the Quentin N. Burdick American Indians Into Nursing Program established under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1616e/e"},"text":"section 1616e(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe59-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations; contents of recruitment program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625cfe5a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall develop regulations for the competitive awarding of the grants provided under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe5b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Applicants for grants provided under this section shall agree to provide a program which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id625cfe5c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616g/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides outreach and recruitment for health professions to Indian communities including elementary, secondary and community colleges located on Indian reservations which will be served by the program,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625cfe5d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616g/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporates a program advisory board comprised of representatives from the tribes and communities which will be served by the program,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625cfe5e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616g/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides summer preparatory programs for Indian students who need enrichment in the subjects of math and science in order to pursue training in the health professions,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625cfe5f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616g/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides tutoring, counseling and support to students who are enrolled in a health career program of study at the respective college or university, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625cfe60-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616g/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent feasible, employs qualified Indians in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe61-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"By no later than the date that is 3 years after ","children":[{"tag":"date","attrib":{"date":"1988-11-23"},"text":"November 23, 1988","children":[],"tail":", the Secretary shall submit a report to the Congress on the program established under this section including recommendations for expansion or changes to the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id625cfe62-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tI/s114"},"text":"Pub. L. 94–437, title I, § 114","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tI/s109"},"text":"Pub. L. 100–713, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4796"},"text":"102 Stat. 4796","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tI"},"text":"Pub. L. 102–573, title I","children":[],"tail":", §§ 109, 117(b)(6), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4538"},"text":"106 Stat. 4538","children":[],"tail":", 4544.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id625cfe63-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id625cfe64-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id625cfe65-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s109"},"text":"Pub. L. 102–573, § 109","children":[],"tail":", inserted “to be known as the ‘Quentin N. Burdick Indian Health Programs’,” after “North Dakota,” and “Such program shall, to the maximum extent feasible, coordinate with the Quentin N. Burdick American Indians Into Psychology Program established under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1621p/b"},"text":"section 1621p(b) of this title","children":[],"tail":" and the Quentin N. Burdick American Indians Into Nursing Program established under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1616e/e"},"text":"section 1616e(e) of this title","children":[],"tail":".” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s117/b/6"},"text":"Pub. L. 102–573, § 117(b)(6)","children":[],"tail":", struck out subsec. (e) which authorized appropriations for fiscal years 1990 to 1992."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
