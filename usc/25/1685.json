{"tag":"section","attrib":{"id":"id627bf7e2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685"},"text":null,"children":[{"tag":"num","attrib":{"value":"1685"},"text":"§ 1685.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of traditional foods in public facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id627bf7e3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627bf7e4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide access to traditional foods in food service programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627bf7e5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage increased consumption of traditional foods to decrease health disparities among Indians, particularly Alaska Natives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627bf7e6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide alternative food options for food service programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627bf7e7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627bf7e8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alaska Native","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Alaska Native” means a person who is a member of any Native village, Village Corporation, or Regional Corporation (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602"},"text":"section 1602 of title 43","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627bf7e9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commissioner” means the Commissioner of Food and Drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627bf7ea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food service program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “food service program” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id627bf7eb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food service at residential child care facilities that have a license from an appropriate State agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id627bf7ec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any child nutrition program (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1769f/b"},"text":"section 1769f(b) of title 42","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id627bf7ed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food service at hospitals, clinics, and long-term care facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id627bf7ee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" senior meal programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627bf7ef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian; Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Indian” and “Indian tribe” have the meanings given those terms in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"25 U.S.C. 450b","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn002103"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002103"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627bf7f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Traditional food","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id627bf7f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “traditional food” means food that has traditionally been prepared and consumed by an Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id627bf7f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “traditional food” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id627bf7f3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wild game meat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id627bf7f4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fish;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id627bf7f5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seafood;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id627bf7f6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/5/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine mammals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id627bf7f7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/5/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id627bf7f8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/5/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" berries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627bf7f9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tribal organization” has the meaning given the term in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"25 U.S.C. 450b","children":[],"tail":")."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627bf7fa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary and the Commissioner shall allow the donation to and serving of traditional food through food service programs at public facilities and nonprofit facilities, including facilities operated by Indian tribes and facilities operated by tribal organizations, that primarily serve Indians if the operator of the food service program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627bf7fb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that the food is received whole, gutted, gilled, as quarters, or as a roast, without further processing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627bf7fc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" makes a reasonable determination that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id627bf7fd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the animal was not diseased;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id627bf7fe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the food was butchered, dressed, transported, and stored to prevent contamination, undesirable microbial growth, or deterioration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id627bf7ff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the food will not cause a significant health hazard or potential for human illness;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627bf800-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carries out any further preparation or processing of the food at a different time or in a different space from the preparation or processing of other food for the applicable program to prevent cross-contamination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627bf801-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cleans and sanitizes food-contact surfaces of equipment and utensils after processing the traditional food;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627bf802-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" labels donated traditional food with the name of the food;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627bf803-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stores the traditional food separately from other food for the applicable program, including through storage in a separate freezer or refrigerator or in a separate compartment or shelf in the freezer or refrigerator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627bf804-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" follows Federal, State, local, county, tribal, or other non-Federal law regarding the safe preparation and service of food in public or nonprofit facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627bf805-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" follows other such criteria as established by the Secretary and Commissioner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627bf806-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627bf807-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States, an Indian tribe, a tribal organization, a State, a county or county equivalent, a local educational agency, and an entity or person authorized to facilitate the donation, storage, preparation, or serving of traditional food by the operator of a food service program shall not be liable in any civil action for any damage, injury, or death caused to any person by the donation to or storage, preparation, or serving of traditional foods through food service programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627bf808-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1685/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) alters any liability or other obligation of the United States under the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1450"},"text":"25 U.S.C. 1450","children":[],"tail":" et seq.)."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id627bf809-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIV/s4033"},"text":"Pub. L. 113–79, title IV, § 4033","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/818"},"text":"128 Stat. 818","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIV/s4203"},"text":"Pub. L. 115–334, title IV, § 4203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4656"},"text":"132 Stat. 4656","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id627bf80a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id627bf80b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id627bf80c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in subsecs. (b)(4), (6) and (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of this title prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of this title. Section 4 of the Act was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"section 450b of this title","children":[],"tail":" prior to editorial reclassification as "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id627bf80d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agricultural Act of 2014, and not as part of the Indian Health Care Improvement Act which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s443d"},"text":"section 443d of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id627bf80e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “a tribal organization, a State, a county or county equivalent, a local educational agency, and an entity or person authorized to facilitate the donation, storage, preparation, or serving of traditional food by the operator of a food service program” for “and a tribal organization” and “donation to or storage, preparation, or serving of traditional foods” for “donation to or serving of traditional foods”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
