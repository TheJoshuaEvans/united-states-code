{"tag":"section","attrib":{"id":"id62cd2511-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4114"},"text":null,"children":[{"tag":"num","attrib":{"value":"4114"},"text":"§ 4114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of program income and labor standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62cd2512-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program income","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cd2513-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to retain","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this chapter, a recipient may retain any program income that is realized from any grant amounts under this chapter if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cd2514-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4114/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such income was realized after the initial disbursement of the grant amounts received by the recipient; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cd2515-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4114/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient has agreed that it will utilize such income for housing related activities in accordance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cd2516-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of restricted access or reduction of grant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not restrict access to or reduce the grant amount for any Indian tribe based solely on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cd2517-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4114/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the recipient for the tribe retains program income under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cd2518-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4114/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any such program income retained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cd2519-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4114/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the recipient retains reserve amounts described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4140"},"text":"section 4140 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cd251a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4114/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the recipient has expended retained program income for housing-related activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cd251b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4114/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, by regulation, exclude from consideration as program income any amounts determined to be so small that compliance with the requirements of this subsection would create an unreasonable administrative burden on the recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cd251c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4114/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion from program income of regular developer’s fees for low-income housing tax credit projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, any income derived from a regular and customary developer’s fee for any project that receives a low-income housing tax credit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s42"},"text":"section 42 of title 26","children":[],"tail":", and that is initially funded using a grant provided under this chapter, shall not be considered to be program income if the developer’s fee is approved by the State housing credit agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cd251d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labor standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cd251e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4114/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any contract or agreement for assistance, sale, or lease pursuant to this chapter shall contain a provision requiring that not less than the wages prevailing in the locality, as determined or adopted (subsequent to a determination under applicable State, tribal, or local law) by the Secretary, shall be paid to all architects, technical engineers, draftsmen, and technicians employed in the development, and all maintenance laborers and mechanics employed in the operation, of the affordable housing project involved; and shall also contain a provision that not less than the wages prevailing in the locality, as predetermined by the Secretary of Labor pursuant to sections 3141–3144, 3146, and 3147 of title 40, shall be paid to all laborers and mechanics employed in the development of the affordable housing involved, and the Secretary shall require certification as to compliance with the provisions of this paragraph before making any payment under such contract or agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cd251f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4114/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) and the provisions relating to wages (pursuant to paragraph (1)) in any contract or agreement for assistance, sale, or lease pursuant to this chapter, shall not apply to any individual who receives no compensation or is paid expenses, reasonable benefits, or a nominal fee to perform the services for which the individual volunteered and who is not otherwise employed at any time in the construction work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cd2520-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4114/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of tribal laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any contract or agreement for assistance, sale, or lease pursuant to this chapter, if such contract or agreement is otherwise covered by one or more laws or regulations adopted by an Indian tribe that requires the payment of not less than prevailing wages, as determined by the Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62cd2521-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tI/s104"},"text":"Pub. L. 104–330, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4027"},"text":"110 Stat. 4027","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tX/s1003/j"},"text":"Pub. L. 106–568, title X, § 1003(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2930"},"text":"114 Stat. 2930","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s503/i"},"text":"Pub. L. 106–569, title V, § 503(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2965"},"text":"114 Stat. 2965","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/292/s5"},"text":"Pub. L. 107–292, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-13"},"text":"Nov. 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2054"},"text":"116 Stat. 2054","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/136/s3"},"text":"Pub. L. 109–136, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-22"},"text":"Dec. 22, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2644"},"text":"119 Stat. 2644","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/411/tI/s104"},"text":"Pub. L. 110–411, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4323"},"text":"122 Stat. 4323","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62cd2522-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62cd2523-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62cd2524-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", known as the Native American Housing Assistance and Self-Determination Act of 1996. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62cd2525-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Sections 3141–3144, 3146, and 3147 of title 40” substituted in subsec. (b)(1) for “the Act of ","children":[{"tag":"date","attrib":{"date":"1931-03-03"},"text":"March 3, 1931","children":[],"tail":" (commonly known as the Davis-Bacon Act; chapter 411; "},{"tag":"ref","attrib":{"href":"/us/stat/46/1494"},"text":"46 Stat. 1494","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s276a"},"text":"40 U.S.C. 276a","children":[],"tail":" et seq.)” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62cd2526-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/411"},"text":"Pub. L. 110–411","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/136"},"text":"Pub. L. 109–136","children":[],"tail":" inserted “restrict access to or” after “not” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/292/s5/1/A"},"text":"Pub. L. 107–292, § 5(1)(A)","children":[],"tail":", substituted “Notwithstanding any other provision of this chapter, a recipient” for “A recipient” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/292/s5/1/B"},"text":"Pub. L. 107–292, § 5(1)(B)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “the recipient has agreed that it will utilize the program income for affordable housing activities in accordance with the provisions of this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/292/s5/2/A"},"text":"Pub. L. 107–292, § 5(2)(A)","children":[],"tail":", inserted “restricted access or” before “reduction” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/292/s5/2/B"},"text":"Pub. L. 107–292, § 5(2)(B)","children":[],"tail":"–(D), added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s1003/j/1"},"text":"Pub. L. 106–568, § 1003(j)(1)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s503/i/1"},"text":"Pub. L. 106–569, § 503(i)(1)","children":[],"tail":", amended par. (1) identically, substituting “Act of "},{"tag":"date","attrib":{"date":"1931-03-03"},"text":"March 3, 1931","children":[],"tail":" (commonly known as the Davis-Bacon Act; chapter 411; "},{"tag":"ref","attrib":{"href":"/us/stat/46/1494"},"text":"46 Stat. 1494","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s276a"},"text":"40 U.S.C. 276a","children":[],"tail":" et seq.)” for “Davis-Bacon Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s276a–276a"},"text":"40 U.S.C. 276a–276a","children":[],"tail":"–5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s1003/j/2"},"text":"Pub. L. 106–568, § 1003(j)(2)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s503/i/2"},"text":"Pub. L. 106–569, § 503(i)(2)","children":[],"tail":", amended subsec. (b) identically, adding par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62cd2527-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id62cd2528-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s107"},"text":"section 107 of Pub. L. 104–330","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
