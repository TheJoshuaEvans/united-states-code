{"tag":"section","attrib":{"id":"id62b0757c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3009"},"text":null,"children":[{"tag":"num","attrib":{"value":"3009"},"text":"§ 3009.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall be construed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b0757d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3009/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" limit the authority of any Federal agency or museum to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b0757e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3009/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" return or repatriate Native American cultural items to Indian tribes, Native Hawaiian organizations, or individuals, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b0757f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3009/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into any other agreement with the consent of the culturally affiliated tribe or organization as to the disposition of, or control over, items covered by this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b07580-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3009/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delay actions on repatriation requests that are pending on ","children":[{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b07581-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3009/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny or otherwise affect access to any court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b07582-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3009/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit any procedural or substantive right which may otherwise be secured to individuals or Indian tribes or Native Hawaiian organizations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b07583-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3009/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the application of any State or Federal law pertaining to theft or stolen property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b07584-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/601/s11"},"text":"Pub. L. 101–601, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3057"},"text":"104 Stat. 3057","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62b07585-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62b07586-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"tex