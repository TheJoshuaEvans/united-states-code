{"tag":"section","attrib":{"id":"id62f594c4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5636"},"text":null,"children":[{"tag":"num","attrib":{"value":"5636"},"text":"§ 5636.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost savings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f804c5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5636/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any program, function, service, or activity (or any portion of a program, function, service, or activity) of the Office of the Special Trustee that will not be operated or carried out as a result of a transfer of functions and personnel following enactment of this chapter, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f804c6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5636/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the amounts that the Secretary would otherwise have expended to operate or carry out each program, function, service, and activity (or portion of a program, function, service, or activity); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f804c7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5636/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide to the tribal representatives of the Tribal-Interior Budget Council or the representative of any other appropriate entity that advises the Secretary on Indian program budget or funding issues a list that describes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f804c8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5636/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs, functions, services, and activities (or any portion of a program, function, service, or activity) identified under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f804c9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5636/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts associated with each program, function, service, and activity (or portion of a program, function, service, or activity).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f804ca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5636/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date of receipt of a list under subsection (a)(2), the tribal representatives of the Tribal-Interior Budget Council and the representatives of any other appropriate entities that advise the Secretary on Indian program budget or funding issues may provide recommendations regarding how any amounts or cost savings should be reallocated, incorporated into future budget requests, or appropriated to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f804cb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5636/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f804cc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5636/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f804cd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5636/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f804ce-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5636/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Natural Resources of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f804cf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5636/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f804d0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5636/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Indian Affairs of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f804d1-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/178/tIII/s306"},"text":"Pub. L. 114–178, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/442"},"text":"130 Stat. 442","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
