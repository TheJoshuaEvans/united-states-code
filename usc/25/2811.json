{"tag":"section","attrib":{"id":"id62abbafc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2811"},"text":null,"children":[{"tag":"num","attrib":{"value":"2811"},"text":"§ 2811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American Issues Coordinator","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62abbafd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2811/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Executive Office for United States Attorneys of the Department of Justice a position to be known as the “Native American Issues Coordinator”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62abbafe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2811/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Native American Issues Coordinator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62abbaff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2811/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the United States Attorneys that have authority to prosecute crimes in Indian country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abbb00-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2811/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate prosecutions of crimes of national significance in Indian country, as determined by the Attorney General;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abbb01-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2811/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate as necessary with other components of the Department of Justice and any relevant advisory groups to the Attorney General or the Deputy Attorney General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abbb02-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2811/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such other duties as the Attorney General may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62abbb03-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/379/s14"},"text":"Pub. L. 101–379, § 14","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s214/b"},"text":"Pub. L. 111–211, title II, § 214(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2271"},"text":"124 Stat. 2271","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
