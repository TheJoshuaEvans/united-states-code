{"tag":"section","attrib":{"id":"id6253884b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1341"},"text":null,"children":[{"tag":"num","attrib":{"value":"1341"},"text":"§ 1341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6253884c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1341/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of document on “Indian Affairs, Laws and Treaties” and treatise on “Federal Indian Laws”; compilation of official opinions; printing and republication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order that the constitutional rights of Indians might be fully protected, the Secretary of the Interior is authorized and directed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6253884d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1341/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the document entitled “Indian Affairs, Laws and Treaties” (Senate Document Numbered 319, volumes 1 and 2, Fifty-eighth Congress), revised and extended to include all treaties, laws, Executive orders, and regulations relating to Indian affairs in force on ","children":[{"tag":"date","attrib":{"date":"1967-09-01"},"text":"September 1, 1967","children":[],"tail":", and to have such revised document printed at the Government Publishing Office;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6253884e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1341/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have revised and republished the treatise entitled “Federal Indian Law”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6253884f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1341/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have prepared, to the extent determined by the Secretary of the Interior to be feasible, an accurate compilation of the official opinions, published and unpublished, of the Solicitor of the Department of the Interior relating to Indian affairs rendered by the Solicitor prior to ","children":[{"tag":"date","attrib":{"date":"1967-09-01"},"text":"September 1, 1967","children":[],"tail":", and to have such compilation printed as a Government publication at the Government Publishing Office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62538850-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1341/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the document entitled “Indian Affairs, Laws and Treaties” as revised and extended in accordance with paragraph (1) of subsection (a), and the compilation prepared in accordance with paragraph (3) of such subsection, the Secretary of the Interior shall take such action as may be necessary to keep such document and compilation current on an annual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62538851-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1341/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated for carrying out the provisions of this subchapter such sum as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62538852-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284/tVII/s701"},"text":"Pub. L. 90–284, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/80"},"text":"82 Stat. 80","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/265"},"text":"Pub. L. 93–265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/84"},"text":"88 Stat. 84","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62538853-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62538854-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62538855-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1974—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/265"},"text":"Pub. L. 93–265","children":[],"tail":" struck out “, with respect to the preparation but not including printing,” before “such sum”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62538856-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id62538857-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government Publishing Office” substituted for “Government Printing Office” in subsec. (a)(1), (3) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/b"},"text":"section 1301(b) of Pub. L. 113–235","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
