{"tag":"section","attrib":{"id":"id6217df18-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s123a"},"text":null,"children":[{"tag":"num","attrib":{"value":"123a"},"text":"§ 123a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal funds; use to purchase insurance for protection of tribal property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1926-04-13"},"text":"April 13, 1926","children":[],"tail":", the funds of any tribe of Indians under the control of the United States may be used for payments of insurance premiums for protection of the property of the tribe against fire, theft, tornado, hail, earthquake, or other elements and forces of nature, and for protection against liability on account of injuries or damages to persons or property and other like claims."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6217df19-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-04-13/ch118"},"text":"Apr. 13, 1926, ch. 118","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/242"},"text":"44 Stat. 242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch754"},"text":"Aug. 2, 1946, ch. 754","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/852"},"text":"60 Stat. 852","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6217df1a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6217df1b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6217df1c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1946—Act ","children":[{"tag":"date","attrib":{"date":"1946-08-02"},"text":"Aug. 2, 1946","children":[],"tail":", provided for use of funds to pay premiums on personal and property damage insurance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
