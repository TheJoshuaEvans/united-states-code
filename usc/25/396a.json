{"tag":"section","attrib":{"id":"id6236d866-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s396a"},"text":null,"children":[{"tag":"num","attrib":{"value":"396a"},"text":"§ 396a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leases of unallotted lands for mining purposes; duration of leases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1938-05-11"},"text":"May 11, 1938","children":[],"tail":", unallotted lands within any Indian reservation or lands owned by any tribe, group, or band of Indians under Federal jurisdiction, except those specifically excepted from the provisions of sections 396a to 396g of this title, may, with the approval of the Secretary of the Interior, be leased for mining purposes, by authority of the tribal council or other authorized spokesmen for such Indians, for terms not to exceed ten years and as long thereafter as minerals are produced in paying quantities."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6236d867-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-05-11/ch198/s1"},"text":"May 11, 1938, ch. 198, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/347"},"text":"52 Stat. 347","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6236d868-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6236d869-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6236d86a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Inconsistent Acts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1938-05-11/ch198/s7"},"text":"Act May 11, 1938, ch. 198, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/348"},"text":"52 Stat. 348","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1938-05-11/ch198/s7"},"text":"“All Act [Acts] or parts of Acts inconsistent herewith are hereby repealed.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
