{"tag":"section","attrib":{"id":"id62b07548-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006"},"text":null,"children":[{"tag":"num","attrib":{"value":"3006"},"text":"§ 3006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b07549-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 120 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":", the Secretary shall establish a committee to monitor and review the implementation of the inventory and identification process and repatriation activities required under sections 3003, 3004 and 3005 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b0754a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b0754b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Committee ","children":[{"tag":"ref","attrib":{"idref":"fn002200"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002200"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" established under subsection (a) shall be composed of 7 members,"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b0754c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 of whom shall be appointed by the Secretary from nominations submitted by Indian tribes, Native Hawaiian organizations, and traditional Native American religious leaders with at least 2 of such persons being traditional Indian religious leaders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b0754d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 of whom shall be appointed by the Secretary from nominations submitted by national museum organizations and scientific organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b0754e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 who shall be appointed by the Secretary from a list of persons developed and consented to by all of the members appointed pursuant to subparagraphs (A) and (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b0754f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not appoint Federal officers or employees to the committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b07550-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event vacancies shall occur, such vacancies shall be filled by the Secretary in the same manner as the original appointment within 90 days of the occurrence of such vacancy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b07551-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the committee established under subsection (a) shall serve without pay, but shall be reimbursed at a rate equal to the daily rate for GS–18 of the General Schedule for each day (including travel time) for which the member is actually engaged in committee business. Each member shall receive travel expenses, including per diem in lieu of subsistence, in accordance with sections 5702 and 5703 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b07552-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The committee established under subsection (a) shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b07553-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designating one of the members of the committee as chairman;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b07554-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring the inventory and identification process conducted under sections 3003 and 3004 of this title to ensure a fair, objective consideration and assessment of all available relevant information and evidence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b07555-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" upon the request of any affected party, reviewing and making findings related to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b07556-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity or cultural affiliation of cultural items, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b07557-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the return of such items;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b07558-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the resolution of any disputes among Indian tribes, Native Hawaiian organizations, or lineal descendants and Federal agencies or museums relating to the return of such items including convening the parties to the dispute if deemed desirable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b07559-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compiling an inventory of culturally unidentifiable human remains that are in the possession or control of each Federal agency and museum and recommending specific actions for developing a process for disposition of such remains;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b0755a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consulting with Indian tribes and Native Hawaiian organizations and museums on matters within the scope of the work of the committee affecting such tribes or organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b0755b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consulting with the Secretary in the development of regulations to carry out this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b0755c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing such other related functions as the Secretary may assign to the committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b0755d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making recommendations, if appropriate, regarding future care of cultural items which are to be repatriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b0755e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admissibility of records and findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any records and findings made by the review committee pursuant to this chapter relating to the identity or cultural affiliation of any cultural items and the return of such items may be admissible in any action brought under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3013"},"text":"section 3013 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b0755f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations and report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The committee shall make the recommendations under paragraph ","children":[{"tag":"ref","attrib":{"idref":"fn002201"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002201"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":" (c)(5) in consultation with Indian tribes and Native Hawaiian organizations and appropriate scientific and museum groups."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b07560-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the committee established under subsection (a) and the members of the committee have reasonable access to Native American cultural items under review and to associated scientific and historical documents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b07561-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b07562-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish such rules and regulations for the committee as may be necessary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b07563-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide reasonable administrative and staff support necessary for the deliberations of the committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b07564-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The committee established under subsection (a) shall submit an annual report to the Congress on the progress made, and any barriers encountered, in implementing this section during the previous year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b07565-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3006/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The committee established under subsection (a) shall terminate at the end of the 120-day period beginning on the day the Secretary certifies, in a report submitted to Congress, that the work of the committee has been completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b07566-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/601/s8"},"text":"Pub. L. 101–601, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3055"},"text":"104 Stat. 3055","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62b07567-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62b07568-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62b07569-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (c)(7) and (d), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/601"},"text":"Pub. L. 101–601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3048"},"text":"104 Stat. 3048","children":[],"tail":", known as the Native American Graves Protection and Repatriation Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"section 3001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62b0756a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62b0756b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Other Laws to GS–16, 17, or 18 Pay Rates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References in laws to the rates of pay for GS–16, 17, or 18, or to maximum rates of pay under the General Schedule, to be considered references to rates payable under specified sections of Title 5, Government Organization and Employees, see section 529 [title I, § 101(c)(1)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
