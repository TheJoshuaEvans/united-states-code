{"tag":"section","attrib":{"id":"id621f0aee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s230"},"text":null,"children":[{"tag":"num","attrib":{"value":"230"},"text":"§ 230.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depositions by agents touching depredations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The superintendents, agents, and subagents within their respective districts are authorized and empowered to take depositions of witnesses touching any depredations, within the purview of sections 227, 228 ","children":[{"tag":"ref","attrib":{"idref":"fn002012"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002012"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and 229 of this title, and to administer oaths to the deponents."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621f0aef-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2157.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621f0af0-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621f0af1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id621f0af2-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 227 and 228 of this title, referred to in text, were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645/s21"},"text":"act June 25, 1948, ch. 645, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/862"},"text":"62 Stat. 862","children":[],"tail":", and are covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1160"},"text":"section 1160 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id621f0af3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2157 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1834-06-30/ch161/s18"},"text":"act June 30, 1834, ch. 161, § 18","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/732"},"text":"4 Stat. 732","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id621f0af4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id621f0af5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Indian Agents","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The services of Indian agents have been dispensed with. See note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s64"},"text":"section 64 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id621f0af6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id621f0af7-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"ta