{"tag":"section","attrib":{"id":"id62db56d0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5144"},"text":null,"children":[{"tag":"num","attrib":{"value":"5144"},"text":"§ 5144.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of rental proceeds","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, any actual rental proceeds from the lease of land acquired under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5136"},"text":"section 5136 of this title","children":[],"tail":" certified by the Secretary of the Interior shall be deemed—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62db56d1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5144/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to constitute the rental value of that land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62db56d2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5144/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to satisfy the requirement for appraisal of that land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62db56d3-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221/tII/s203"},"text":"Pub. L. 109–221, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-05-12"},"text":"May 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/341"},"text":"120 Stat. 341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62db56d4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62db56d5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62db56d6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s494a"},"text":"section 494a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
