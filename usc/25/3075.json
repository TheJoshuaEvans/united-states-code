href":"/us/pl/96/95"},"text":"Pub. L. 96–95","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-31"},"text":"Oct. 31, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/721"},"text":"93 Stat. 721","children":[],"tail":", which is classified generally to chapter 1B (§ 470aa et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s470aa"},"text":"section 470aa of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/258"},"text":"Pub. L. 117–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-21"},"text":"Dec. 21, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2372"},"text":"136 Stat. 2372","children":[],"tail":", known as the Safeguard Tribal Objects of Patrimony Act of 2021, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3071"},"text":"section 3071 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The amendments made by this Act, referred to in subsec. (c)(1), means the amendment made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/258"},"text":"Pub. L. 117–258","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1170"},"text":"section 1170 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
