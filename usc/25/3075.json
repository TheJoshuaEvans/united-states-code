{"tag":"section","attrib":{"id":"id62b2e6ca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3075"},"text":null,"children":[{"tag":"num","attrib":{"value":"3075"},"text":"§ 3075.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency working group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b2e6cb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3075/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate a coordinating office to convene an interagency working group consisting of representatives from the Departments of the Interior, Justice, State, and Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b2e6cc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3075/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the interagency working group convened under subsection (a) are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b2e6cd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3075/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the repatriation to Indian Tribes and Native Hawaiian organizations of items that have been illegally removed or trafficked in violation of applicable law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e6ce-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3075/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect tangible cultural heritage, cultural items, and archaeological resources still in the possession of Indian Tribes and Native Hawaiian organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e6cf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3075/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to improve the implementation by the applicable Federal agencies of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b2e6d0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3075/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Native American Graves Protection and Repatriation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"25 U.S.C. 3001","children":[],"tail":" et seq.) (including "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1170"},"text":"section 1170 of title 18","children":[],"tail":", as added by that Act);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e6d1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3075/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Archaeological Resources Protection Act of 1979 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s470aa"},"text":"16 U.S.C. 470aa","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e6d2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3075/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant Federal laws.","chil