{"tag":"section","attrib":{"id":"id6223c59e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s317"},"text":null,"children":[{"tag":"num","attrib":{"value":"317"},"text":"§ 317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall make all needful rules and regulations, not inconsistent with sections 312 to 318 of this title, for the proper execution and carrying into effect of all the provisions of said sections.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6223c59f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1899-03-02/ch374/s7"},"text":"Mar. 2, 1899, ch. 374, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/992"},"text":"30 Stat. 992","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
