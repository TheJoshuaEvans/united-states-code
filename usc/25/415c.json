{"tag":"section","attrib":{"id":"id623b9377-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s415c"},"text":null,"children":[{"tag":"num","attrib":{"value":"415c"},"text":"§ 415c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of leases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall approve no lease pursuant to sections 415 to 415d of this title that contains any provision that will prevent or delay a termination of Federal trust responsibilities with respect to the land during the term of the lease.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id623b9378-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch615/s5"},"text":"Aug. 9, 1955, ch. 615, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/540"},"text":"69 Stat. 540","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
