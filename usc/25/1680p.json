{"tag":"section","attrib":{"id":"id6279ad61-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680p"},"text":null,"children":[{"tag":"num","attrib":{"value":"1680p"},"text":"§ 1680p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual budget submission","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Effective beginning with the submission of the annual budget request to Congress for fiscal year 2011, the President shall include, in the amount requested and the budget justification, amounts that reflect any changes in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6279ad62-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680p/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of health care services, as indexed for United States dollar inflation (as measured by the Consumer Price Index); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279ad63-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680p/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the size of the population served by the Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6279ad64-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s826"},"text":"Pub. L. 94–437, title VIII, § 826","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6279ad65-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6279ad66-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6279ad67-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s826"},"text":"Section 826 of Pub. L. 94–437","children":[],"tail":" is based on section 195 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
