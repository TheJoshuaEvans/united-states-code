{"tag":"section","attrib":{"id":"id62ddc705-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5207"},"text":null,"children":[{"tag":"num","attrib":{"value":"5207"},"text":"§ 5207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability and allocation of funds; royalties from mineral deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All funds appropriated under the several grants of authority contained in the Act of ","children":[{"tag":"date","attrib":{"date":"1934-06-18"},"text":"June 18, 1934","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/48/984"},"text":"48 Stat. 984","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5101"},"text":"25 U.S.C. 5101","children":[],"tail":" et seq.], are hereby made available for use under the provisions of this chapter, and Oklahoma Indians shall be accorded and allocated a fair and just share of any and all funds appropriated after "},{"tag":"date","attrib":{"date":"1936-06-26"},"text":"June 26, 1936","children":[],"tail":", under the authorization herein set forth: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That any royalties, bonuses, or other revenues derived from mineral deposits underlying lands purchased in Oklahoma under the authority granted by this chapter, or by the Act of "},{"tag":"date","attrib":{"date":"1934-06-18"},"text":"June 18, 1934","children":[],"tail":", shall be deposited in the Treasury of the United States, and such revenues are made available for expenditure by the Secretary of the Interior for the acquisition of lands and for loans to Indians in Oklahoma as authorized by this chapter and by the Act of "},{"tag":"date","attrib":{"date":"1934-06-18"},"text":"June 18, 1934","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/48/984"},"text":"48 Stat. 984","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62ddc706-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-26/ch831/s7"},"text":"June 26, 1936, ch. 831, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1968"},"text":"49 Stat. 1968","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ddc707-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62ddc708-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62ddc709-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1934-06-18"},"text":"June 18, 1934","children":[],"tail":", referred to in text, popularly known as the Indian Reorganization Act, is classified generally to chapter 45 (§ 5101 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5101"},"text":"section 5101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62ddc70a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s507"},"text":"section 507 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
