{"tag":"section","attrib":{"id":"id62156d93-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s98"},"text":null,"children":[{"tag":"num","attrib":{"value":"98"},"text":"§ 98.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of supplies without authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No claims for supplies for Indians, purchased without authority of law, shall be paid out of any appropriation for expenses of the Office of Indian Affairs, or for Indians.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62156d94-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2085.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62156d95-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62156d96-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62156d97-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2085 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1870-07-15/ch296/s2"},"text":"act July 15, 1870, ch. 296, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/16/360"},"text":"16 Stat. 360","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id62156d98-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id62156d99-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
