{"tag":"section","attrib":{"id":"id628a4ee5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006"},"text":null,"children":[{"tag":"num","attrib":{"value":"2006"},"text":"§ 2006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau of Indian Affairs education functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id628a4ee6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formulation and establishment of policy and procedure; supervision of programs and expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall vest in the Assistant Secretary for Indian Affairs all functions with respect to formulation and establishment of policy and procedure and supervision of programs and expenditures of Federal funds for the purpose of Indian education administered by the Bureau. The Assistant Secretary shall carry out such functions through the Director of the Office of Indian Education Programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628a4ee7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direction and supervision of personnel operations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628a4ee8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", the Director of the Office shall direct and supervise the operations of all personnel directly and substantially involved in the provision of education program services by the Bureau, including school or institution custodial or maintenance personnel, and personnel responsible for contracting, procurement, and finance functions connected with school operation programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628a4ee9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary for Indian Affairs shall, not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", coordinate the transfer of functions relating to procurements for, contracts of, operation of, and maintenance of schools and other support functions to the Director."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628a4eea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inherent Federal function","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this Act, all functions relating to education that are located at the Area or Agency level and performed by an education line officer shall be subject to contract under the Indian Self-Determination and Education Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.], unless determined by the Secretary to be inherently Federal functions as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2021/12"},"text":"section 2021(12) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628a4eeb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of programs; services and support functions; technical and coordinating assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Education personnel who are under the direction and supervision of the Director of the Office of Indian Education Programs in accordance with subsection (b)(1) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628a4eec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor and evaluate Bureau education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628a4eed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide all services and support functions for education programs with respect to personnel matters involving staffing actions and functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628a4eee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical and coordinating assistance in areas such as procurement, contracting, budgeting, personnel, curriculum, and operation and maintenance of school facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628a4eef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction, improvement, operation, and maintenance of facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628a4ef0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan for construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall submit as part of the annual budget a plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628a4ef1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for school facilities to be constructed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2005/c"},"text":"section 2005(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4ef2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for establishing priorities among projects and for the improvement and repair of educational facilities, which together shall form the basis for the distribution of appropriated funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4ef3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for capital improvements to be made over the 5 succeeding years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628a4ef4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program for operation and maintenance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628a4ef5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall establish a program, including the distribution of appropriated funds, for the operation and maintenance of education facilities. Such program shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id628a4ef6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a method of computing the amount necessary for each educational facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628a4ef7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" similar treatment of all Bureau-funded schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628a4ef8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notice of an allocation of appropriated funds from the Director of the Office of Indian Education Programs directly to the education line officers and appropriate school officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628a4ef9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/e/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a method for determining the need for, and priority of, facilities repair and maintenance projects, both major and minor (to be determined, through the conduct by the Assistant Secretary, of a series of meetings at the agency and area level with representatives of the Bureau-funded schools in those areas and agencies to receive comment on the lists and prioritization of such projects); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628a4efa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/e/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a system for the conduct of routine preventive maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4efb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local supervisors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appropriate education line officers shall make arrangements for the maintenance of education facilities with the local supervisors of the Bureau maintenance personnel. The local supervisors of Bureau maintenance personnel shall take appropriate action to implement the decisions made by the appropriate education line officers, except that no funds under this chapter may be authorized for expenditure unless such appropriate education line officer is assured that the necessary maintenance has been, or will be, provided in a reasonable manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628a4efc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall be implemented as soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628a4efd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of gifts and bequests","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628a4efe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Director of the Office shall promulgate guidelines for the establishment and administration of mechanisms for the acceptance of gifts and bequests for the use and benefit of particular schools or designated Bureau-operated education programs, including, in appropriate cases, the establishment and administration of trust funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628a4eff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring and reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (3), in a case in which a Bureau-operated education program is the beneficiary of such a gift or bequest, the Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628a4f00-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make provisions for monitoring use of the gift or bequest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4f01-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a report to the appropriate committees of Congress that describes the amount and terms of such gift or bequest, the manner in which such gift or bequest shall be used, and any results achieved by such use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628a4f02-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of paragraph (2) shall not apply in the case of a gift or bequest that is valued at $5,000 or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628a4f03-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2006/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this section, the term “functions” includes powers and duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id628a4f04-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1126"},"text":"Pub. L. 95–561, title XI, § 1126","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1042"},"text":"Pub. L. 107–110, title X, § 1042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2026"},"text":"115 Stat. 2026","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id628a4f05-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id628a4f06-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id628a4f07-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (c), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561"},"text":"Pub. L. 95–561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2143"},"text":"92 Stat. 2143","children":[],"tail":", known as the Education Amendments of 1978. For complete classification of this Act to the Code, see Short Title of 1978 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education, and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which is classified principally to chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id628a4f08-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2006, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1126"},"text":"Pub. L. 95–561, title XI, § 1126","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s381"},"text":"Pub. L. 103–382, title III, § 381","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3988"},"text":"108 Stat. 3988","children":[],"tail":", related to Bureau of Indian Affairs education functions, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2006, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1126"},"text":"Pub. L. 95–561, title XI, § 1126","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2319"},"text":"92 Stat. 2319","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/46/s2/b/6"},"text":"Pub. L. 96–46, § 2(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-06"},"text":"Aug. 6, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/341"},"text":"93 Stat. 341","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/511/tV/s504"},"text":"Pub. L. 98–511, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2393"},"text":"98 Stat. 2393","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/89/s4"},"text":"Pub. L. 99–89, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-15"},"text":"Aug. 15, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/381"},"text":"99 Stat. 381","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/427/s1/c/3"},"text":"Pub. L. 100–427, § 1(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1603"},"text":"102 Stat. 1603","children":[],"tail":", related to Bureau of Indian Affairs education functions, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id628a4f09-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id628a4f0a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
