{"tag":"section","attrib":{"id":"id62a48eb3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704"},"text":null,"children":[{"tag":"num","attrib":{"value":"2704"},"text":"§ 2704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Indian Gaming Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62a48eb4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Department of the Interior a Commission to be known as the National Indian Gaming Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a48eb5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition; investigation; term of office; re­moval","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a48eb6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commission shall be composed of three full-time members who shall be appointed as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a48eb7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Chairman, who shall be appointed by the President with the advice and consent of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48eb8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two associate members who shall be appointed by the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48eb9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a48eba-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall conduct a background investigation on any person considered for appointment to the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48ebb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall publish in the Federal Register the name and other information the Secretary deems pertinent regarding a nominee for membership on the Commission and shall allow a period of not less than thirty days for receipt of public comment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48ebc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than two members of the Commission shall be of the same political party. At least two members of the Commission shall be enrolled members of any Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48ebd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a48ebe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), the term of office of the members of the Commission shall be three years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48ebf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Of the initial members of the Commission—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62a48ec0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members, including the Chairman, shall have a term of office of three years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a48ec1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member shall have a term of office of one year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48ec2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No individual shall be eligible for any appointment to, or to continue service on, the Commission, who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a48ec3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been convicted of a felony or gaming offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48ec4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has any financial interest in, or management responsibility for, any gaming activity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48ec5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a financial interest in, or management responsibility for, any management contract approved pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2711"},"text":"section 2711 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48ec6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Commissioner may only be removed from office before the expiration of the term of office of the member by the President (or, in the case of associate member, by the Secretary) for neglect of duty, or malfeasance in office, or for other good cause shown.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a48ec7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Vacancies occurring on the Commission shall be filled in the same manner as the original appointment. A member may serve after the expiration of his term of office until his successor has been appointed, unless the member has been removed for cause under subsection (b)(6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a48ec8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Two members of the Commission, at least one of which is the Chairman or Vice Chairman, shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a48ec9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vice Chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall select, by majority vote, one of the members of the Commission to serve as Vice Chairman. The Vice Chairman shall serve as Chairman during meetings of the Commission in the absence of the Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a48eca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall meet at the call of the Chairman or a majority of its members, but shall meet at least once every 4 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a48ecb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a48ecc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman of the Commission shall be paid at a rate equal to that of level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48ecd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The associate members of the Commission shall each be paid at a rate equal to that of level V of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48ece-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2704/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All members of the Commission shall be reimbursed in accordance with title 5 for travel, subsistence, and other necessary expenses incurred by them in the performance of their duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62a48ecf-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497/s5"},"text":"Pub. L. 100–497, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2469"},"text":"102 Stat. 2469","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
