{"tag":"section","attrib":{"id":"id625f6e87-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1616i"},"text":"§ 1616i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional incentives for health professionals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id625f6e88-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentive special pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide the incentive special pay authorized under section 302(b) or 335(b) of title 37 to civilian medical officers of the Indian Health Service who are assigned to, and serving in, positions included in the list established under subsection (b)(1) for which recruitment or retention of personnel is difficult.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625f6e89-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of positions; bonus pay","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625f6e8a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish and update on an annual basis a list of positions of health care professionals employed by, or assigned to, the Service for which recruitment or retention is difficult.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6e8b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id625f6e8c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616i/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may pay a bonus to any commissioned officer or civil service employee, other than a commissioned medical officer, dental officer, optometrist, and veterinarian, who is employed in or assigned to, and serving in, a position in the Service included in the list established by the Secretary under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625f6e8d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616i/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount of bonus payments made by the Secretary under this paragraph to any employee during any 1-year period shall not exceed $2,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625f6e8e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Work schedules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish programs to allow the use of flexible work schedules, and compressed work schedules, in accordance with the provisions of subchapter II of chapter 61 of title 5, for health professionals employed by, or assigned to, the Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id625f6e8f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tI/s116"},"text":"Pub. L. 94–437, title I, § 116","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tI/s109"},"text":"Pub. L. 100–713, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4798"},"text":"102 Stat. 4798","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tI/s117/b/8"},"text":"Pub. L. 102–573, title I, § 117(b)(8)","children":[],"tail":", title IX, § 901(1), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4544"},"text":"106 Stat. 4544","children":[],"tail":", 4590; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVI/s618/f"},"text":"Pub. L. 115–91, div. A, title VI, § 618(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1427"},"text":"131 Stat. 1427","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id625f6e90-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id625f6e91-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id625f6e92-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" inserted “or 335(b)” after “section 302(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s901/1"},"text":"Pub. L. 102–573, § 901(1)","children":[],"tail":", struck out subsec. (d) which required a report to Congress by the Secretary no later than 6 months after "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", relating to overtime pay for individuals employed by the Service."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s117/b/8"},"text":"Pub. L. 102–573, § 117(b)(8)","children":[],"tail":", struck out subsec. (e) which authorized appropriations for fiscal years 1990 to 1992."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
