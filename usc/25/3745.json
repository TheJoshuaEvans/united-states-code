{"tag":"section","attrib":{"id":"id62c5f940-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3745"},"text":null,"children":[{"tag":"num","attrib":{"value":"3745"},"text":"§ 3745.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c5f941-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3745/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c5f942-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3745/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding source","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The activities required under subchapter II may only be funded from appropriations made pursuant to this chapter. To the greatest extent possible, such activities shall be coordinated with activities funded from other sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c5f943-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/177/tIII/s305"},"text":"Pub. L. 103–177, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2023"},"text":"107 Stat. 2023","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
