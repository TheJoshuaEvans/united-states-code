{"tag":"section","attrib":{"id":"id62773ca8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1679"},"text":null,"children":[{"tag":"num","attrib":{"value":"1679"},"text":"§ 1679.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of California Indians","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62773ca9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1679/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following California Indians shall be eligible for health services provided by the Service:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62773caa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1679/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any member of a federally recognized Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62773cab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1679/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any descendant of an Indian who was residing in California on ","children":[{"tag":"date","attrib":{"date":"1852-06-01"},"text":"June 1, 1852","children":[],"tail":", if such descendant—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62773cac-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1679/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of the Indian community served by a local program of the Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62773cad-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1679/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is regarded as an Indian by the community in which such descendant lives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62773cae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1679/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any Indian who holds trust interests in public domain, national forest, or reservation allotments in California.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62773caf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1679/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any Indian of California who is listed on the plans for distribution of the assets of rancherias and reservations located within the State of California under the Act of ","children":[{"tag":"date","attrib":{"date":"1958-08-18"},"text":"August 18, 1958","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/72/619"},"text":"72 Stat. 619","children":[],"tail":"), and any descendant of such an Indian."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62773cb0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1679/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed as expanding the eligibility of California Indians for health services provided by the Service beyond the scope of eligibility for such health services that applied on ","children":[{"tag":"date","attrib":{"date":"1986-05-01"},"text":"May 1, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62773cb1-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s809"},"text":"Pub. L. 94–437, title VIII, § 809","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62773cb2-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62773cb3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62773cb4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1958-08-18"},"text":"August 18, 1958","children":[],"tail":", referred to in subsec. (a)(4), is "},{"tag":"ref","attrib":{"href":"/us/pl/85/671"},"text":"Pub. L. 85–671","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-18"},"text":"Aug. 18, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/619"},"text":"72 Stat. 619","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62773cb5-4962-11f1-add1-b56d3fa2