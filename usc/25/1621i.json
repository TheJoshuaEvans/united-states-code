{"tag":"section","attrib":{"id":"id62642a42-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1621i"},"text":"§ 1621i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Managed care feasibility study","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62642a43-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, acting through the Service, shall conduct a study to assess the feasibility of allowing an Indian tribe to purchase, directly or through the Service, managed care coverage for all members of the tribe from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62642a44-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribally owned and operated managed care plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a45-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State licensed managed care plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62642a46-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than the date which is 12 months after ","children":[{"tag":"date","attrib":{"date":"1992-10-29"},"text":"October 29, 1992","children":[],"tail":", the Secretary shall transmit to the Congress a report containing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62642a47-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of the study conducted pursuant to this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a48-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discussion of the findings and conclusions of such study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62642a49-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tII/s210"},"text":"Pub. L. 94–437, title II, § 210","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tII/s206/b"},"text":"Pub. L. 102–573, title II, § 206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4549"},"text":"106 Stat. 4549","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
