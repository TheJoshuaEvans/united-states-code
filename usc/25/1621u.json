{"tag":"section","attrib":{"id":"id62669b1d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621u"},"text":null,"children":[{"tag":"num","attrib":{"value":"1621u"},"text":"§ 1621u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for payment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62669b1e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621u/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No patient liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A patient who receives contract health care services that are authorized by the Service shall not be liable for the payment of any charges or costs associated with the provision of such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62669b1f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621u/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall notify a contract care provider and any patient who receives contract health care services authorized by the Service that such patient is not liable for the payment of any charges or costs associated with the provision of such services not later than 5 business days after receipt of a notification of a claim by a provider of contract care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62669b20-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621u/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No recourse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Following receipt of the notice provided under subsection (b), or, if a claim has been deemed accepted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1621s/b"},"text":"section 1621s(b) of this title","children":[],"tail":", the provider shall have no further recourse against the patient who received the services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62669b21-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tII/s222"},"text":"Pub. L. 94–437, title II, § 222","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tII/s215"},"text":"Pub. L. 102–573, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4559"},"text":"106 Stat. 4559","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62669b22-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62669b23-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62669b24-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" is based on section 135 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62669b25-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" amended section generally. Prior to amendment, section related to absence of patient liability for payment of charges or costs for contract health care services and requirement that Secretary notify contract care provider and patient of absence of patient’s liability."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62669b26-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62669b27-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tI/s102/d/3"},"text":"Pub. L. 116–260, div. BB, title I, § 102(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2797"},"text":"134 Stat. 2797","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dBB/tI/s102/d/3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Nothing in this title [probably means “this section”, enacting sections 9816 and 9822 of Title 26, Internal Revenue Code, sections 1185e and 1185k of Title 29, Labor, and sections 300gg–111 and 300gg–117 of Title 42, The Public Health and Welfare, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8902"},"text":"section 8902 of Title 5","children":[],"tail":", Government Organization and Employees, "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s223"},"text":"section 223 of Title 26","children":[],"tail":", and sections 300gg–19a, 300gg–21, 300gg–22, 300gg–23, and 18011 of Title 42, and enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8902"},"text":"section 8902 of Title 5","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s223"},"text":"section 223 of Title 26","children":[],"tail":"], including the amendments made by this title [probably means “this section”] may be construed as modifying, reducing, or eliminating—"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protections under section 222 of the Indian Health Care Improvement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1621u"},"text":"25 U.S.C. 1621u","children":[],"tail":") and under subpart I of part 136 of title 42, Code of Federal Regulations (or any successor regulation), against payment liability for a patient who receives contract health services that are authorized by the Indian Health Service; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements under section 1866(a)(1)(U) of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395cc/a/1/U"},"text":"42 U.S.C. 1395cc(a)(1)(U)","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
