{"tag":"section","attrib":{"id":"id62c1181e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3653"},"text":null,"children":[{"tag":"num","attrib":{"value":"3653"},"text":"§ 3653.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c1181f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3653/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Attorney General” means the Attorney General of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11820-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3653/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Office of Tribal Justice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11821-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3653/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian lands” shall include lands within the definition of “Indian country”, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1151"},"text":"section 1151 of title 18","children":[],"tail":"; or “Indian reservations”, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1452/d"},"text":"section 1452(d) of this title","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1903/10"},"text":"section 1903(10) of this title","children":[],"tail":". For purposes of the preceding sentence, such "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1452/d"},"text":"section 1452(d) of this title","children":[],"tail":" shall be applied by treating the term “former Indian reservations in Oklahoma” as including only lands which are within the jurisdictional area of an Oklahoma Indian Tribe (as determined by the Secretary of the Interior) and are recognized by such Secretary as eligible for trust land status under part 151 of title 25, Code of Federal Regulations (as in effect on "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"December 21, 2000","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11822-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3653/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” means any Indian tribe, band, nation, pueblo, or other organized group or community which administers justice or plans to administer justice under its inherent authority or the authority of the United States and which is recognized as eligible for the special programs and services provided by the United States to Indian tribes because of their status as Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c38823-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3653/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “judicial personnel” means any judge, magistrate, court counselor, court clerk, court administrator, bailiff, probation officer, officer of the court, dispute resolution facilitator, or other official, employee, or volunteer within the tribal judicial system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c38824-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3653/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-profit entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “non-profit entity” or “non-profit entities” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c38825-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3653/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Tribal Justice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Office of Tribal Justice” means the Office of Tribal Justice in the United States Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c38826-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3653/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal justice system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tribal court”, “tribal court system”, or “tribal justice system” means the entire judicial branch, and employees thereof, of an Indian tribe, including, but not limited to, traditional methods and fora for dispute resolution, trial courts, appellate courts, including inter-tribal appellate courts, alternative dispute resolution systems, and circuit rider systems, established by inherent tribunal authority whether or not they constitute a court of record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c38827-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/559/s4"},"text":"Pub. L. 106–559, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2779"},"text":"114 Stat. 2779","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s214/a/1"},"text":"Pub. L. 111–211, title II, § 214(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2270"},"text":"124 Stat. 2270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c38828-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62c38829-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62c3882a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Pars. (2) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211"},"text":"Pub. L. 111–211","children":[],"tail":" added par. (2) and redesignated former pars. (2) to (7) as (3) to (8), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
