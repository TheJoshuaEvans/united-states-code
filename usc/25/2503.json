{"tag":"section","attrib":{"id":"id62a21d4e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503"},"text":null,"children":[{"tag":"num","attrib":{"value":"2503"},"text":"§ 2503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition of grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62a21d4f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The grant provided under this chapter to an Indian tribe or tribal organization for any fiscal year shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a21d50-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of funds allocated for such fiscal year under sections 1127 and 1128 of the Education Amendments of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2007"},"text":"25 U.S.C. 2007","children":[],"tail":", 2008] with respect to the tribally controlled schools eligible for assistance under this chapter which are operated by such Indian tribe or tribal organization, including, but not limited to, funds provided under such sections, or under any other provision of law, for transportation costs;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21d51-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent requested by such Indian tribe or tribal organization, the total amount of funds provided from operations and maintenance accounts and, notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5324"},"text":"section 5324 of this title","children":[],"tail":", or any other provision of law, other facilities accounts for such schools for such fiscal year (including but not limited to those referenced under section 1126(d) of the Education Amendments of 1978 ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2006/d"},"text":"25 U.S.C. 2006(d)","children":[],"tail":"] or any other law); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21d52-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total amount of funds that are allocated to such schools for such fiscal year under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21d53-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title I of the Elementary and Secondary Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"20 U.S.C. 6301","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d54-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Individuals with Disabilities Education Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d55-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal education law, that are allocated to such schools for such fiscal year.","children":[{"tag":"ref","attrib":{"idref":"fn002164"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002164"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The words “, that are allocated to such schools for such fiscal year” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a21d56-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a21d57-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21d58-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds allocated to a tribally controlled school by reason of paragraph (1) or (2) of subsection (a) shall be subject to the provisions of this chapter and shall not be subject to any additional restriction, priority, or limitation that is imposed by the Bureau with respect to funds provided under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62a21d59-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title I of the Elementary and Secondary Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"20 U.S.C. 6301","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21d5a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Individuals with Disabilities Education Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21d5b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal education law other than title XI of the Education Amendments of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2000"},"text":"25 U.S.C. 2000","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d5c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of Bureau provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Indian tribes and tribal organizations to which grants are provided under this chapter, and tribally controlled schools for which such grants are provided, shall not be subject to any requirements, obligations, restrictions, or limitations imposed by the Bureau that would otherwise apply solely by reason of the receipt of funds provided under any law referred to in clause (i), (ii), or (iii) of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21d5d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schools considered contract schools","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Tribally controlled schools for which grants are provided under this chapter shall be treated as contract schools for the purposes of allocation of funds under sections 1126(e), 1127, and 1128 of the Education Amendments of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2006/e"},"text":"25 U.S.C. 2006(e)","children":[],"tail":", 2007, 2008]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21d5e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schools considered Bureau schools","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Tribally controlled schools for which grants are provided under this chapter shall be treated as Bureau schools for the purposes of allocation of funds provided under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21d5f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title I of the Elementary and Secondary Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"20 U.S.C. 6301","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d60-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Individuals with Disabilities Education Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d61-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal education law, that are distributed through the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21d62-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounts; use of certain funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21d63-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate account","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62a21d64-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 2503(a)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002165"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002165"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “2502(a)(2)”."}],"tail":" of this title, with respect to funds from facilities improvement and repair, alteration and renovation (major or minor), health and safety, or new construction accounts included in the grant provided under section 2503(a) "},{"tag":"ref","attrib":{"idref":"fn002166"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002166"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “2502(a)”."}],"tail":" of this title, the grant recipient shall maintain a separate account for such funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21d65-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of accounting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the end of the period designated for the work covered by the funds received, the grant recipient shall submit to the Secretary a separate accounting of the work done and the funds expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21d66-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds received from those accounts may only be used for the purpose for which the funds were appropriated and for the work encompassed by the application or submission for which the funds were received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21d67-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion of project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon completion of a project for which a separate account is established under this paragraph, the portion of the grant related to such project may be closed out upon agreement by the grantee and the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d68-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for projects","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62a21d69-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a grant to a tribally controlled school under this chapter for new construction or facilities improvements and repair in excess of $100,000, such grant shall be subject to the Administrative and Audit Requirements and Cost Principles for Assistance Programs contained in part 12 of title 43, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21d6a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding clause (i), grants described in such clause shall not be subject to section 12.61 of title 43, Code of Federal Regulations. The Secretary and the grantee shall negotiate and determine a schedule of payments for the work to be performed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21d6b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In considering applications for a grant described in clause (i), the Secretary shall consider whether the Indian tribe or tribal organization involved would be deficient in ensuring that the construction projects under the proposed grant conform to applicable building standards and codes and Federal, tribal, or State health and safety standards as required under section 1124 of the Education Amendments of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2005/a"},"text":"25 U.S.C. 2005(a)","children":[],"tail":") "},{"tag":"ref","attrib":{"idref":"fn002167"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002167"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" See References in Text note below."}],"tail":" with respect to organizational and financial management capabilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21d6c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disputes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any disputes between the Secretary and any grantee concerning a grant described in clause (i) shall be subject to the dispute provisions contained in section 2508(e) ","children":[{"tag":"ref","attrib":{"idref":"fn002168"},"text":"5","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002168"},"text":null,"children":[{"tag":"num","attrib":{},"text":"5","children":[],"tail":" So in original. Probably should be “2507(e)”."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d6d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), a school receiving a grant under this chapter for facilities improvement and repair may use such grant funds for new construction if the tribal governing body or tribal organization that submits the application for the grant provides funding for the new construction equal to at least 25 percent of the total cost of such new construction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d6e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In a case in which the appropriations measure under which the funds described in subparagraph (A) are made available or the application submitted for the funds does not stipulate a period for the work covered by the funds, the Secretary and the grant recipient shall consult and determine such a period prior to the transfer of the funds. A period so determined may be extended upon mutual agreement of the Secretary and the grant recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21d6f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of request to include funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21d70-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary fails to carry out a request filed by an Indian tribe or tribal organization to include in such tribe ","children":[{"tag":"ref","attrib":{"idref":"fn002169"},"text":"6","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002169"},"text":null,"children":[{"tag":"num","attrib":{},"text":"6","children":[],"tail":" So in original. Probably should be “tribe’s”."}],"tail":" or organization’s grant under this chapter the funds described in subsection (a)(2) within 180 days after the filing of the request, the Secretary shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"id62a21d71-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be deemed to have approved such request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21d72-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately upon the expiration of such 180-day period amend the grant accordingly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d73-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2503/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A tribe or organization described in subparagraph (A) may enforce its rights under subsection (a)(2) and this paragraph, including rights relating to any denial or failure to act on such tribe’s or organization’s request, pursuant to the dispute authority described in section 2508(e) ","children":[{"tag":"sup","attrib":{},"text":"5","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62a21d74-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5204"},"text":"Pub. L. 100–297, title V, § 5204","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1043"},"text":"Pub. L. 107–110, title X, § 1043","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2066"},"text":"115 Stat. 2066","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62a21d75-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62a21d76-4962-11f1-add1-b56d3fa293fa"},"text