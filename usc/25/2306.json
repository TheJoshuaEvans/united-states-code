{"tag":"section","attrib":{"id":"id629af1bf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2306"},"text":null,"children":[{"tag":"num","attrib":{"value":"2306"},"text":"§ 2306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id629af1c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated for the purpose of carrying out the provisions of this chapter $2,500,000 for each of the fiscal years 1986 and 1987, and such sums as may be necessary for any subsequent fiscal year. The amounts appropriated under the authority of this subsection shall remain available without fiscal year limitation for purposes of carrying out the provisions of this chapter until all claims filed under this chapter have been resolved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629af1c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds necessary to pay the expenses of administering this chapter shall be appropriated and expended under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629af1c2-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/500/s7"},"text":"Pub. L. 98–500, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2318"},"text":"98 Stat. 2318","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
