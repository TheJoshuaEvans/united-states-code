{"tag":"section","attrib":{"id":"id62c11803-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3651"},"text":null,"children":[{"tag":"num","attrib":{"value":"3651"},"text":"§ 3651.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds and declares that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c11804-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3651/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a government-to-government relationship between the United States and Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11805-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3651/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribes are sovereign entities and are responsible for exercising governmental authority over Indian lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11806-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3651/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of violent crime committed in Indian country is approximately twice the rate of violent crime committed in the United States as a whole;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11807-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3651/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any community, a high rate of violent crime is a major obstacle to investment, job creation and economic growth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11808-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3651/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal justice systems are an essential part of tribal governments and serve as important forums for ensuring the health and safety and the political integrity of tribal governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11809-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3651/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress and the Federal courts have repeatedly recognized tribal justice systems as the most appropriate forums for the adjudication of disputes affecting personal and property rights on Native lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c1180a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3651/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing tribal court systems and improving access to those systems serves the dual Federal goals of tribal political self-determination and economic self-sufficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c1180b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3651/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is both inadequate funding and an inadequate coordinating mechanism to meet the technical and legal assistance needs of tribal justice systems and this lack of adequate technical and legal assistance funding impairs their operation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c1180c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3651/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal court membership organizations have served a critical role in providing training and technical assistance for development and enhancement of tribal justice systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c1180d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3651/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian legal services programs, as funded partially through the Legal Services Corporation, have an established record of providing cost effective legal assistance to Indian people in tribal court forums, and also contribute significantly to the development of tribal courts and tribal jurisprudence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c1180e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3651/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of adequate technical assistance to tribal courts and legal assistance to both individuals and tribal courts is an essential element in the development of strong tribal court systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c1180f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/559/s2"},"text":"Pub. L. 106–559, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2778"},"text":"114 Stat. 2778","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c11810-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62c11811-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id62c11812-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/559/s1"},"text":"Pub. L. 106–559, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2778"},"text":"114 Stat. 2778","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/559/s1"},"text":"“This Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3621"},"text":"section 3621 of this title","children":[],"tail":" and sections 1629e and 1629g of Title 43, Public Lands] may be cited as the ‘Indian Tribal Justice Technical and Legal Assistance Act of 2000’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62c11813-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Funds for Courts or Law Enforcement Officers of Certain Tribes or Villages","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dB/tI/s112/a/1"},"text":"Pub. L. 108–199, div. B, title I, § 112(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/62"},"text":"118 Stat. 62","children":[],"tail":", which prohibited use of funds provided in div. B of "},{"tag":"ref","attrib":{"href":"/us/pl/108/199"},"text":"Pub. L. 108–199","children":[],"tail":" or on or after "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", for courts or law enforcement officers for a tribe or village in which fewer than 25 Native members live in the village year round or that is located within certain areas, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s247/e/1"},"text":"Pub. L. 111–211, title II, § 247(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2297"},"text":"124 Stat. 2297","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
