{"tag":"section","attrib":{"id":"id62c117b8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613"},"text":null,"children":[{"tag":"num","attrib":{"value":"3613"},"text":"§ 3613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Base support funding for tribal justice systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c117b9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to the Indian Self-Determination and Education Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.], the Secretary is authorized (to the extent provided in advance in appropriations Acts) to enter into contracts, grants, or agreements with Indian tribes for the performance of any function of the Office and for the development, enhancement, and continuing operation of tribal justice systems and traditional tribal judicial practices by Indian tribal governments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c117ba-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes for which financial assistance may be used","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Financial assistance provided through contracts, grants, or agreements entered into pursuant to this section may be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c117bb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning for the development, enhancement, and operation of tribal justice systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c117bc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employment of tribal court personnel, including tribal court judges, prosecutors, public defenders, appointed defense counsel, guardians ad litem, and court-appointed special advocates for children and juveniles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c117bd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training programs and continuing education for tribal judicial personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c117be-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition, development, and maintenance of a law library and computer assisted legal research capacities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c117bf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, revision, and publication of tribal codes, rules of practice, rules of procedure, and standards of judicial performance and conduct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c117c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and operation of records management systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c117c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction or renovation of facilities for tribal justice systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c117c2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" membership and related expenses for participation in national and regional organizations of tribal justice systems and other professional organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c117c3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the development and operation of other innovative and culturally relevant programs and projects, including (but not limited to) programs and projects for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62c117c4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative dispute resolution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c117c5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal victims assistance or victims services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c117c6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/b/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal probation services or diversion programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c117c7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/b/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" juvenile services and multidisciplinary investigations of child abuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c117c8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/b/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" traditional tribal judicial practices, traditional tribal justice systems, and traditional methods of dispute resolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c117c9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c117ca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1993-12-03"},"text":"December 3, 1993","children":[],"tail":", the Secretary, with the full participation of Indian tribes, shall establish and promulgate by regulation, a formula which establishes base support funding for tribal justice systems in carrying out this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c117cb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall assess caseload and staffing needs for tribal justice systems that take into account unique geographic and demographic conditions. In the assessment of these needs, the Secretary shall work cooperatively with Indian tribes and tribal organizations and shall refer to any data developed as a result of the surveys conducted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3612"},"text":"section 3612 of this title","children":[],"tail":" and to relevant assessment standards developed by the Judicial Conference of the United States, the National Center for State Courts, the American Bar Association, and appropriate State bar associations."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c117cc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Factors to be considered in the development of the base support funding formula shall include, but are not limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62c117cd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the caseload and staffing needs identified under paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c117ce-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographic area and population to be served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c117cf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the volume and complexity of the caseloads;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c117d0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected number of cases per month;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c117d1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected number of persons receiving probation services or participating in diversion programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c117d2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any special circumstances warranting additional financial assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c117d3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3613/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In developing and administering the formula for base support funding for the tribal judicial systems under this section, the Secretary shall ensure equitable distribution of funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c117d4-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/176/tI/s103"},"text":"Pub. L. 103–176, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2007"},"text":"107 Stat. 2007","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s242/a/1"},"text":"Pub. L. 111–211, title II, § 242(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2292"},"text":"124 Stat. 2292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c117d5-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62c117d6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62c117d7-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which is classified principally to chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62c117d8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211"},"text":"Pub. L. 111–211","children":[],"tail":" added par. (2) and struck out former par. (2) which read as follows: “the employment of judicial personnel;”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
