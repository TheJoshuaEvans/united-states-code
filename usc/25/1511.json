{"tag":"section","attrib":{"id":"id6255d247-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1511"},"text":null,"children":[{"tag":"num","attrib":{"value":"1511"},"text":"§ 1511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest subsidies; rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized under such rules and regulations as he may prescribe to pay as an interest subsidy on loans which are guaranteed or insured under the provisions of subchapter II of this chapter amounts which are necessary to reduce the rate payable by the borrower to the rate determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1464"},"text":"section 1464 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6255d248-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/tIII/s301"},"text":"Pub. L. 93–262, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/82"},"text":"88 Stat. 82","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
