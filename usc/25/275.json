{"tag":"section","attrib":{"id":"id621f0b5e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s275"},"text":null,"children":[{"tag":"num","attrib":{"value":"275"},"text":"§ 275.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leaves of absence to employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1912-08-24"},"text":"August 24, 1912","children":[],"tail":" teachers in schools operated by the Bureau of Indian Affairs may be allowed, in addition to annual leave, educational leave not to exceed thirty workdays per calendar year, or sixty workdays in every alternate year, for attendance at educational gatherings, conventions, institutions, or training schools, if the interest of the Government requires, under such regulations as the Secretary of the Interior may prescribe; and no additional salary or expense on account of such leave of absence shall be incurred."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621f0b5f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1912-08-24/ch388/s1"},"text":"Aug. 24, 1912, ch. 388, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/519"},"text":"37 Stat. 519","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1922-08-24/ch286"},"text":"Aug. 24, 1922, ch. 286","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/829"},"text":"42 Stat. 829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1928-05-08/ch510"},"text":"May 8, 1928, ch. 510","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/493"},"text":"45 Stat. 493","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/89"},"text":"Pub. L. 85–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-07-10"},"text":"July 10, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/282"},"text":"71 Stat. 282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621f0b60-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621f0b61-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id621f0b62-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1957—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/89"},"text":"Pub. L. 85–89","children":[],"tail":" substituted “Teachers in schools operated by the Bureau of Indian Affairs” for “Teachers of the Indian schools and physicians of the Indian Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1928—Act ","children":[{"tag":"date","attrib":{"date":"1928-05-08"},"text":"May 8, 1928","children":[],"tail":", made section applicable to physicians of the Indian Service."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1922—Act ","children":[{"tag":"date","attrib":{"date":"1922-08-24"},"text":"Aug. 24, 1922","children":[],"tail":", increased educational leave allowance from 15 to 30 days."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id621f0b63-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id621f0b64-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
