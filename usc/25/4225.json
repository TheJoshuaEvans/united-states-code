{"tag":"section","attrib":{"id":"id62d42a06-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4225"},"text":null,"children":[{"tag":"num","attrib":{"value":"4225"},"text":"§ 4225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of program income and labor standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d42a07-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4225/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program income","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42a08-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4225/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to retain","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Department of Hawaiian Home Lands may retain any program income that is realized from any grant amounts received by the Department under this subchapter if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42a09-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4225/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that income was realized after the initial disbursement of the grant amounts received by the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42a0a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4225/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director agrees to use the program income for affordable housing activities in accordance with the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42a0b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4225/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of reduction of grant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not reduce the grant amount for the Department of Hawaiian Home Lands based solely on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42a0c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4225/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the Department retains program income under paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42a0d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4225/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any such program income retained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42a0e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4225/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, by regulation, exclude from consideration as program income any amounts determined to be so small that compliance with the requirements of this subsection would create an unreasonable administrative burden on the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42a0f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4225/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labor standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42a10-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4225/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any contract or agreement for assistance, sale, or lease pursuant to this subchapter shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42a11-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4225/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provision requiring that an amount not less than the wages prevailing in the locality, as determined or adopted (subsequent to a determination under applicable State or local law) by the Secretary, shall be paid to all architects, technical engineers, draftsmen, technicians employed in the development and all maintenance, and laborers and mechanics employed in the operation, of the affordable housing project involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42a12-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4225/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provision that an amount not less than the wages prevailing in the locality, as predetermined by the Secretary of Labor pursuant to sections 3141–3144, 3146, and 3147 of title 40 shall be paid to all laborers and mechanics employed in the development of the affordable housing involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42a13-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4225/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) and provisions relating to wages required under paragraph (1) in any contract or agreement for assistance, sale, or lease under this subchapter, shall not apply to any individual who performs the services for which the individual volunteered and who is not otherwise employed at any time in the construction work and received no compensation or is paid expenses, reasonable benefits, or a nominal fee for those services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d42a14-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s805"},"text":"Pub. L. 104–330, title VIII, § 805","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s203"},"text":"Pub. L. 106–568, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2883"},"text":"114 Stat. 2883","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s513"},"text":"Pub. L. 106–569, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2976"},"text":"114 Stat. 2976","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d42a15-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d42a16-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62d42a17-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Sections 3141–3144, 3146, and 3147 of title 40” substituted in subsec. (b)(1)(B) for “the Act commonly known as the ‘Davis-Bacon Act’ (","children":[{"tag":"ref","attrib":{"href":"/us/stat/46/1494"},"text":"46 Stat. 1494","children":[],"tail":"; chapter 411; "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s276a"},"text":"40 U.S.C. 276a","children":[],"tail":" et seq.)” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s203"},"text":"Pub. L. 106–568, § 203","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":", enacted substantially identical sections 805 of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":". This section is based on the text of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s805"},"text":"section 805 of Pub. L. 104–330","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
