{"tag":"section","attrib":{"id":"id62d90bcd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5113"},"text":null,"children":[{"tag":"num","attrib":{"value":"5113"},"text":"§ 5113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revolving fund; appropriation for loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated, out of any funds in the Treasury not otherwise appropriated, the sum of $20,000,000 to be established as a revolving fund from which the Secretary of the Interior, under such rules and regulations as he may prescribe, may make loans to Indian chartered corporations for the purpose of promoting the economic development of such tribes and of their members, and may defray the expenses of administering such loans. Repayment of amounts loaned under this authorization shall be credited to the revolving fund and shall be available for the purposes for which the fund is established.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62d90bce-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch576/s10"},"text":"June 18, 1934, ch. 576, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/986"},"text":"48 Stat. 986","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/533/s1/16"},"text":"Pub. L. 86–533, § 1(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-29"},"text":"June 29, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/248"},"text":"74 Stat. 248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/250"},"text":"Pub. L. 87–250","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-15"},"text":"Sept. 15, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/520"},"text":"75 Stat. 520","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d90bcf-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d90bd0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62d90bd1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s470"},"text":"section 470 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62d90bd2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1961—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/250"},"text":"Pub. L. 87–250","children":[],"tail":" substituted “$20,000,000” for “$10,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/533"},"text":"Pub. L. 86–533","children":[],"tail":" repealed provisions which required a report to be made annually to the Congress of transactions under the authorization."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62d90bd3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62d90bd4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Administration of Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Funds from diverse sources to be administered as a single Indian Revolving Loan Fund after ","children":[{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1461"},"text":"section 1461 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
