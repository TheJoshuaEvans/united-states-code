{"tag":"section","attrib":{"id":"id6217df23-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s124"},"text":null,"children":[{"tag":"num","attrib":{"value":"124"},"text":"§ 124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures from tribal funds of Five Civilized Tribes without specific appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No money shall be expended from tribal funds belonging to the Five Civilized Tribes without specific appropriation by Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6217df24-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-05-24/ch199"},"text":"May 24, 1922, ch. 199","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/575"},"text":"42 Stat. 575","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
