{"tag":"section","attrib":{"id":"id62d1e078-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221"},"text":null,"children":[{"tag":"num","attrib":{"value":"4221"},"text":"§ 4221.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d1e079-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Hawaiian Home Lands; Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department of Hawaiian Home Lands” or “Department” means the agency or department of the government of the State of Hawaii that is responsible for the administration of the Hawaiian Homes Commission Act, 1920 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/42/108"},"text":"42 Stat. 108","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e07a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Department of Hawaiian Home Lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e07b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elderly families; near-elderly families","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d1e07c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “elderly family” or “near-elderly family” means a family whose head (or his or her spouse), or whose sole member, is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d1e07d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an elderly family, an elderly person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d1e07e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a near-elderly family, a near-elderly person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d1e07f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain families included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “elderly family” or “near-elderly family” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d1e080-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two or more elderly persons or near-elderly persons, as the case may be, living together; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d1e081-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more persons described in clause (i) living with one or more persons determined under the housing plan to be essential to their care or well-being.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e082-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hawaiian Home Lands","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Hawaiian Home Lands” means lands that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d1e083-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the status as Hawaiian home lands under section 204 of the Hawaiian Homes Commission Act, 1920 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/42/110"},"text":"42 Stat. 110","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d1e084-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are acquired pursuant to that Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e085-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “housing area” means an area of Hawaiian Home Lands with respect to which the Department of Hawaiian Home Lands is authorized to provide assistance for affordable housing under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e086-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “housing entity” means the Department of Hawaiian Home Lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e087-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “housing plan” means a plan developed by the Department of Hawaiian Home Lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e088-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Median income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “median income” means, with respect to an area that is a Hawaiian housing area, the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d1e089-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the median income for the Hawaiian housing area, which shall be determined by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d1e08a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the median income for the State of Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e08b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native Hawaiian","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Native Hawaiian” means any individual who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d1e08c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a citizen of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d1e08d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a descendant of the aboriginal people, who, prior to 1778, occupied and exercised sovereignty in the area that currently constitutes the State of Hawaii, as evidenced by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d1e08e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" genealogical records;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d1e08f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verification by kupuna (elders) or kamaʻaina (long-term community residents); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d1e090-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4221/9/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" birth records of the State of Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d1e091-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s801"},"text":"Pub. L. 104–330, title VIII, § 801","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s203"},"text":"Pub. L. 106–568, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2876"},"text":"114 Stat. 2876","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s513"},"text":"Pub. L. 106–569, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2969"},"text":"114 Stat. 2969","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d1e092-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d1e093-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62d1e094-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Hawaiian Homes Commission Act, 1920, referred to in pars. (1) and (4)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-07-09/ch42"},"text":"act July 9, 1921, ch. 42","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/108"},"text":"42 Stat. 108","children":[],"tail":", which was classified generally to sections 691 to 718 of Title 48, Territories and Insular Possessions, and was omitted from the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in par. (5), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", known as the Native American Housing Assistance and Self-Determination Act of 1996. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62d1e095-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s203"},"text":"Pub. L. 106–568, § 203","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":", enacted substantially identical sections 801 of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":". This section is based on the text of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s801"},"text":"section 801 of Pub. L. 104–330","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62d1e096-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id62d1e097-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s808"},"text":"Pub. L. 104–330, title VIII, § 808","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s513"},"text":"Pub. L. 106–569, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2979"},"text":"114 Stat. 2979","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/569/tV/s513"},"text":"“Except as otherwise expressly provided in this title [enacting this subchapter], this title shall take effect on the date of the enactment of the American Homeownership and Economic Opportunity Act of 2000 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569"},"text":"Pub. L. 106–569","children":[],"tail":", approved "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s808"},"text":"Pub. L. 104–330, title VIII, § 808","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s203"},"text":"Pub. L. 106–568, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2885"},"text":"114 Stat. 2885","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/568/tII/s203"},"text":"“Except as otherwise expressly provided in this title [enacting this subchapter], this title shall take effect on the date of the enactment of the Native American Housing Assistance and Self-Determination Amendments of 2000 [probably should be the Hawaiian Homelands Ownership Act of 2000, title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568"},"text":"Pub. L. 106–568","children":[],"tail":", approved "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62d1e098-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s512"},"text":"Pub. L. 106–569, title V, § 512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2966"},"text":"114 Stat. 2966","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/569/tV/s512"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the United States has undertaken a responsibility to promote the general welfare of the United States by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employing its resources to remedy the unsafe and unsanitary housing conditions and the acute shortage of decent, safe, and sanitary dwellings for families of lower income; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing effective partnerships with governmental and private entities to accomplish the objectives referred to in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States has a special responsibility for the welfare of the Native peoples of the United States, including Native Hawaiians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to the provisions of the Hawaiian Homes Commission Act, 1920 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/42/108"},"text":"42 Stat. 108","children":[],"tail":" et seq.) [former "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s691"},"text":"48 U.S.C. 691","children":[],"tail":" et seq.], the United States set aside 200,000 acres of land in the Federal territory that later became the State of Hawaii in order to establish a homeland for the native people of Hawaii—Native Hawaiians;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" despite the intent of Congress in 1920 to address the housing needs of Native Hawaiians through the enactment of the Hawaiian Homes Commission Act, 1920 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/42/108"},"text":"42 Stat. 108","children":[],"tail":" et seq.), Native Hawaiians eligible to reside on the Hawaiian home lands have been foreclosed from participating in Federal housing assistance programs available to all other eligible families in the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" although Federal housing assistance programs have been administered on a racially neutral basis in the State of Hawaii, Native Hawaiians continue to have the greatest unmet need for housing and the highest rates of overcrowding in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" among the Native American population of the United States, Native Hawaiians experience the highest percentage of housing problems in the United States, as the percentage—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" of housing problems in the Native Hawaiian population is 49 percent, as compared to—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 44 percent for American Indian and Alaska Native households in Indian country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 27 percent for all other households in the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overcrowding in the Native Hawaiian population is 36 percent as compared to 3 percent for all other households in the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" among the Native Hawaiian population, the needs of Native Hawaiians, as that term is defined in section 801 of the Native American Housing Assistance and Self-Determination Act of 1996 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4221"},"text":"25 U.S.C. 4221","children":[],"tail":"] (as added by this subtitle), eligible to reside on the Hawaiian Home Lands are the most severe, as—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of overcrowding in Native Hawaiian households on the Hawaiian Home Lands is 36 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approximately 13,000 Native Hawaiians, which constitute 95 percent of the Native Hawaiians who are eligible to reside on the Hawaiian Home Lands, are in need of housing;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" applying the Department of Housing and Urban Development guidelines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 70.8 percent of Native Hawaiians who either reside or who are eligible to reside on the Hawaiian Home Lands have incomes that fall below the median family income; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of Native Hawaiians who either reside or who are eligible to reside on the Hawaiian Home Lands have incomes below 30 percent of the median family income;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-third of those Native Hawaiians who are eligible to reside on the Hawaiian Home Lands pay more than 30 percent of their income for shelter, and one-half of those Native Hawaiians face overcrowding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"“(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extraordinarily severe housing needs of Native Hawaiians demonstrate that Native Hawaiians who either reside on, or are eligible to reside on, Hawaiian Home Lands have been denied equal access to Federal low-income housing assistance programs available to other qualified residents of the United States, and that a more effective means of addressing their housing needs must be authorized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"“(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the recommendations of the National Commission on American Indian, Alaska Native, and Native Hawaiian Housing, and in order to address the continuing prevalence of extraordinarily severe housing needs among Native Hawaiians who either reside or are eligible to reside on the Hawaiian Home Lands, Congress finds it necessary to extend the Federal low-income housing assistance available to American Indians and Alaska Natives under the Native American Housing Assistance and Self-Determination Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"25 U.S.C. 4101","children":[],"tail":" et seq.) to those Native Hawaiians;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"“(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the treatymaking power of the United States, Congress had the constitutional authority to confirm a treaty between the United States and the government that represented the Hawaiian people, and from 1826 until 1893, the United States recognized the independence of the Kingdom of Hawaii, extended full diplomatic recognition to the Hawaiian Government, and entered into treaties and conventions with the Hawaiian monarchs to govern commerce and navigation in 1826, 1842, 1849, 1875, and 1887;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"“(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the United States has recognized and reaffirmed that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native Hawaiians have a cultural, historic, and land-based link to the indigenous people who exercised sovereignty over the Hawaiian Islands, and that group has never relinquished its claims to sovereignty or its sovereign lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress does not extend services to Native Hawaiians because of their race, but because of their unique status as the indigenous people of a once sovereign nation as to whom the United States has established a trust relationship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress has also delegated broad authority to administer a portion of the Federal trust responsibility to the State of Hawaii;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the political status of Native Hawaiians is comparable to that of American Indians and Alaska Natives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the aboriginal, indigenous people of the United States have—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a continuing right to autonomy in their internal affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an ongoing right of self-determination and self-governance that has never been extinguished;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"“(14)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the political relationship between the United States and the Native Hawaiian people has been recognized and reaffirmed by the United States as evidenced by the inclusion of Native Hawaiians in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Native American Programs Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2291"},"text":"42 U.S.C. 2291","children":[],"tail":" [2991] et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the American Indian Religious Freedom Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1996"},"text":"42 U.S.C. 1996","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Museum of the American Indian Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80q"},"text":"20 U.S.C. 80q","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Native American Graves Protection and Repatriation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"25 U.S.C. 3001","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Historic Preservation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s470"},"text":"16 U.S.C. 470","children":[],"tail":" et seq.) [see "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s300101"},"text":"54 U.S.C. 300101","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Native American Languages Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/106/3434"},"text":"106 Stat. 3434","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/pl/102/524"},"text":"Pub. L. 102–524","children":[],"tail":", see Short Title of 1992 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2991"},"text":"section 2991 of Title 42","children":[],"tail":", The Public Health and Welfare]);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"“(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the American Indian, Alaska Native and Native Hawaiian Culture and Arts [Art] Development Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4401"},"text":"20 U.S.C. 4401","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"“(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Job Training Partnership Act ([former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1501"},"text":"29 U.S.C. 1501","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Older Americans Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"42 U.S.C. 3001","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"“(15)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the area of housing, the United States has recognized and reaffirmed the political relationship with the Native Hawaiian people through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enactment of the Hawaiian Homes Commission Act, 1920 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/42/108"},"text":"42 Stat. 108","children":[],"tail":" et seq.), which set aside approximately 200,000 acres of public lands that became known as Hawaiian Home Lands in the Territory of Hawaii that had been ceded to the United States for homesteading by Native Hawaiians in order to rehabilitate a landless and dying people;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the enactment of the Act entitled ‘An Act to provide for the admission of the State of Hawaii into the Union’, approved ","children":[{"tag":"date","attrib":{"date":"1959-03-18"},"text":"March 18, 1959","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/73/4"},"text":"73 Stat. 4","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/pl/86/3"},"text":"Pub. L. 86–3","children":[],"tail":", 48 U.S.C. note prec. 491]—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by ceding to the State of Hawaii title to the public lands formerly held by the United States, and mandating that those lands be held in public trust, for the betterment of the conditions of Native Hawaiians, as that term is defined in section 201 of the Hawaiian Homes Commission Act, 1920 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/42/108"},"text":"42 Stat. 108","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by transferring the United States responsibility for the administration of Hawaiian Home Lands to the State of Hawaii, but retaining the authority to enforce the trust, including the exclusive right of the United States to consent to any actions affecting the lands which comprise the corpus of the trust and any amendments to the Hawaiian Homes Commission Act, 1920 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/42/108"},"text":"42 Stat. 108","children":[],"tail":" et seq.), enacted by the legislature of the State of Hawaii affecting the rights of beneficiaries under the Act;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authorization of mortgage loans insured by the Federal Housing Administration for the purchase, construction, or refinancing of homes on Hawaiian Home Lands under the National Housing Act (Public Law 479; 73d Congress; ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701"},"text":"12 U.S.C. 1701","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizing Native Hawaiian representation on the National Commission on American Indian, Alaska Native, and Native Hawaiian Housing under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/235"},"text":"Public Law 101–235","children":[],"tail":" [see Tables for classification];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inclusion of Native Hawaiians in the definition under section 3764 [now 3765] of title 38, United States Code, applicable to subchapter V of chapter 37 of title 38, United States Code (relating to a housing loan program for Native American veterans); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enactment of the Hawaiian Home Lands Recovery Act (","children":[{"tag":"ref","attrib":{"href":"/us/stat/109/357"},"text":"109 Stat. 357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s491"},"text":"48 U.S.C. 491","children":[],"tail":", note prec.) ["},{"tag":"ref","attrib":{"href":"/us/pl/104/42/tII"},"text":"Pub. L. 104–42, title II","children":[],"tail":"] which establishes a process for the conveyance of Federal lands to the Department of Hawaiian Homes Lands that are equivalent in value to lands acquired by the United States from the Hawaiian Home Lands inventory.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Substantially identical provisions were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s202"},"text":"Pub. L. 106–568, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2872"},"text":"114 Stat. 2872","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
