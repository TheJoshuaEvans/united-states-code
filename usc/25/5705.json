{"tag":"section","attrib":{"id":"id62f8051d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705"},"text":null,"children":[{"tag":"num","attrib":{"value":"5705"},"text":"§ 5705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reporting requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f8051e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning in the first fiscal year after ","children":[{"tag":"date","attrib":{"date":"2020-10-10"},"text":"October 10, 2020","children":[],"tail":", the Attorney General shall include in its annual Indian Country Investigations and Prosecutions report to Congress information that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f8051f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes known statistics on missing Indians in the United States, available to the Department of Justice, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f80520-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f80521-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f80522-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tribal enrollment information or affiliation, if available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f80523-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current number of open cases per State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f80524-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of closed cases per State each calendar year, from the most recent 10 calendar years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f80525-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant information the Attorney General determines is appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f80526-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes known statistics on murdered Indians in the United States, available to the Department of Justice, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f80527-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f80528-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f80529-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tribal enrollment information or affiliation, if available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f8052a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current number of open cases per State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f8052b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of closed cases per State each calendar year, from the most recent 10 calendar years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f8052c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant information the Attorney General determines is appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f8052d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains victim privacy to the greatest extent possible by excluding information that can be used on its own or with other information to identify, contact, or locate a single person, or to identify an individual in context; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f8052e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f8052f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of why the statistics described in paragraph (1) may not be comprehensive; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f80530-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations on how data collection on missing or murdered Indians may be improved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f80531-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f80532-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in the first fiscal year after ","children":[{"tag":"date","attrib":{"date":"2020-10-10"},"text":"October 10, 2020","children":[],"tail":", and annually thereafter, for the purpose of compiling accurate data for the annual report required under subsection (a), the Attorney General shall request all Tribal, State, and local law enforcement agencies to submit to the Department of Justice, to the fullest extent possible, all relevant information pertaining to missing or murdered Indians collected by the Tribal, State, and local law enforcement agency, and in a format provided by the Department of Justice that ensures the streamlining of data reporting."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f80533-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall disclose and publish annually, including on the website of the Department of Justice, the name of each Tribal, State, or local law enforcement agency that the Attorney General has determined has submitted the information requested under paragraph (1) for the fiscal year in which the report was published.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f80534-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of gender in missing and unidentified persons statistics","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in the first calendar year after ","children":[{"tag":"date","attrib":{"date":"2020-10-10"},"text":"October 10, 2020","children":[],"tail":", and annually thereafter, the Federal Bureau of Investigation shall include gender in its annual statistics on missing and unidentified persons published on its public website."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f80535-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/165/s6"},"text":"Pub. L. 116–165, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-10"},"text":"Oct. 10, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/763"},"text":"134 Stat. 763","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
