{"tag":"section","attrib":{"id":"id622fac6a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s354"},"text":null,"children":[{"tag":"num","attrib":{"value":"354"},"text":"§ 354.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands not liable for debts prior to final patent","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No lands acquired under the provisions of this Act shall, in any event, become liable to the satisfaction of any debt contracted prior to the issuing of the final patent in fee therefor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id622fac6b-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-02-08/ch119"},"text":"Feb. 8, 1887, ch. 119","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1906-06-21/ch3504"},"text":"June 21, 1906, ch. 3504","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/327"},"text":"34 Stat. 327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id622fac6c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id622fac6d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id622fac6e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-02-08/ch119"},"text":"act Feb. 8, 1887, ch. 119","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/388"},"text":"24 Stat. 388","children":[],"tail":", and is popularly known as the Indian General Allotment Act. For classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s331"},"text":"section 331 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
