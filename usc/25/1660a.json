{"tag":"section","attrib":{"id":"id626da00d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1660a"},"text":"§ 1660a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for alcohol and substance abuse related services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id626da00e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants for the provision of health-related services in prevention of, treatment of, rehabilitation of, or school and community-based education in, alcohol and substance abuse in urban centers to those urban Indian organizations with whom the Secretary has entered into a contract under this subchapter or under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1621"},"text":"section 1621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626da00f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each grant made pursuant to subsection (a) shall set forth the goals to be accomplished pursuant to the grant. The goals shall be specific to each grant as agreed to between the Secretary and the grantee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626da010-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish criteria for the grants made under subsection (a), including criteria relating to the—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id626da011-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" size of the urban Indian population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626da012-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accessibility to, and utilization of, other health resources available to such population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626da013-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" duplication of existing Service or other Federal grants or contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626da014-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capability of the organization to adequately perform the activities required under the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626da015-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfactory performance standards for the organization in meeting the goals set forth in such grant, which standards shall be negotiated and agreed to between the Secretary and the grantee on a grant-by-grant basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626da016-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of need for services.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary shall develop a methodology for allocating grants made pursuant to this section based on such criteria.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626da017-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of funds received by urban Indian organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds received by an urban Indian organization under this chapter for substance abuse prevention, treatment, and rehabilitation shall be subject to the criteria set forth in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id626da018-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tV/s511"},"text":"Pub. L. 94–437, title V, § 511","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tV/s502"},"text":"Pub. L. 102–573, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4569"},"text":"106 Stat. 4569","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id626da019-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id626da01a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id626da01b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437"},"text":"Pub. L. 94–437","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1400"},"text":"90 Stat. 1400","children":[],"tail":", known as the Indian Health Care Improvement Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id626da01c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s511"},"text":"section 511 of Pub. L. 94–437","children":[],"tail":" was renumbered section 510 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1660"},"text":"section 1660 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
