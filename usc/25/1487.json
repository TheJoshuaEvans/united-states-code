{"tag":"section","attrib":{"id":"id6255d208-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1487"},"text":null,"children":[{"tag":"num","attrib":{"value":"1487"},"text":"§ 1487.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans eligible for insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any loans insured hereunder shall be restricted to those made by a financial institution subject to examination and supervision by an agency of the United States, a State, or the District of Columbia, and to loans made by Indian organizations from their own funds to other tribes or organizations of Indians.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6255d209-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/tII/s207"},"text":"Pub. L. 93–262, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/80"},"text":"88 Stat. 80","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
