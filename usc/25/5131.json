{"tag":"section","attrib":{"id":"id62db5671-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5131"},"text":null,"children":[{"tag":"num","attrib":{"value":"5131"},"text":"§ 5131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of list of recognized tribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62db5672-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of list","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish in the Federal Register a list of all Indian tribes which the Secretary recognizes to be eligible for the special programs and services provided by the United States to Indians because of their status as Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62db5673-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency of publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The list shall be published within 60 days of ","children":[{"tag":"date","attrib":{"date":"1994-11-02"},"text":"November 2, 1994","children":[],"tail":", and annually on or before every January 30 thereafter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62db5674-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/454/tI/s104"},"text":"Pub. L. 103–454, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4792"},"text":"108 Stat. 4792","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62db5675-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62db5676-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62db5677-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s479a–1"},"text":"section 479a–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
