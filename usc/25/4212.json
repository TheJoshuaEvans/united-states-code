{"tag":"section","attrib":{"id":"id62d1e070-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4212"},"text":null,"children":[{"tag":"num","attrib":{"value":"4212"},"text":"§ 4212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for assistance for a national organization representing Native American housing interests for providing training and technical assistance to Indian housing authorities and tribally designated housing entities such sums as may be necessary for each of fiscal years 2009 through 2013.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62d1e071-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVII/s703"},"text":"Pub. L. 104–330, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4051"},"text":"110 Stat. 4051","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/292/s2/c"},"text":"Pub. L. 107–292, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-13"},"text":"Nov. 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2053"},"text":"116 Stat. 2053","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/411/tVII/s701/c"},"text":"Pub. L. 110–411, title VII, § 701(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4334"},"text":"122 Stat. 4334","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d1e072-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeadin