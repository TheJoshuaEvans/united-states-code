{"tag":"section","attrib":{"id":"id62ec1efa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5353"},"text":null,"children":[{"tag":"num","attrib":{"value":"5353"},"text":"§ 5353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds to agencies, institutions, and organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No funds from any contract or grant pursuant to this subchapter shall be made available by any Federal agency directly to other than public agencies and Indian tribes, institutions, and organizations: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That school districts, State education agencies, and Indian tribes, institutions, and organizations assisted by this subchapter may use funds provided herein to contract for necessary services with any appropriate individual, organization, or corporation."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62ec1efb-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tII/s206"},"text":"Pub. L. 93–638, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2216"},"text":"88 Stat. 2216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ec1efc-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62ec1efd-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62ec1efe-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s458b"},"text":"section 458b of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
