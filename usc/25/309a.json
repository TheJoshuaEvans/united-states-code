{"tag":"section","attrib":{"id":"id6223c571-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s309a"},"text":null,"children":[{"tag":"num","attrib":{"value":"309a"},"text":"§ 309a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated for the purposes of sections 309 and 309a of this title the sum of $25,000,000 for each fiscal year, and not to exceed $1,500,000 of such sum shall be available for administrative purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6223c572-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-03/ch930/s2"},"text":"Aug. 3, 1956, ch. 930, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/986"},"text":"70 Stat. 986","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/273"},"text":"Pub. L. 87–273","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-22"},"text":"Sept. 22, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/571"},"text":"75 Stat. 571","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/230/s1/b"},"text":"Pub. L. 88–230, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-12-23"},"text":"Dec. 23, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/471"},"text":"77 Stat. 471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/14"},"text":"Pub. L. 89–14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-04-22"},"text":"Apr. 22, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/74"},"text":"79 Stat. 74","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/252"},"text":"Pub. L. 90–252","children":[],"tail":", "},{"tag":"date","attrib":{"dat