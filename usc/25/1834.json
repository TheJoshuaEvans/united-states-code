{"tag":"section","attrib":{"id":"id6280b2b7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1834"},"text":null,"children":[{"tag":"num","attrib":{"value":"1834"},"text":"§ 1834.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of complying with the contribution requirement of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1832/b/2/B"},"text":"section 1832(b)(2)(B) of this title","children":[],"tail":", a tribally controlled college or university may use funds which are available from any private or tribal source. Any real or personal property received by a tribally controlled college or university as a donation or gift on or after "},{"tag":"date","attrib":{"date":"1990-10-30"},"text":"October 30, 1990","children":[],"tail":", may, to the extent of its fair market value as determined by the Secretary, be used by such college or university as its contribution pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1832/b/2/B"},"text":"section 1832(b)(2)(B) of this title","children":[],"tail":", or as part of such contribution, as the case may be. In any case in which any such real or personal property so used is thereafter sold or otherwise disposed of by such college or university, the proceeds therefrom shall be deposited pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1832/b/2/B"},"text":"section 1832(b)(2)(B) of this title","children":[],"tail":" but shall not again be considered for Federal capital contribution purposes."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6280b2b8-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/tIII/s304"},"text":"Pub. L. 95–471, title III, § 304","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/192/s13"},"text":"Pub. L. 98–192, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1342"},"text":"97 Stat. 1342","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/477/s1/d/1/C"},"text":"Pub. L. 101–477, § 1(d)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-30"},"text":"Oct. 30, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1153"},"text":"104 Stat. 1153","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s901/b/5"},"text":"Pub. L. 105–244, title IX, § 901(b)(5)","children":[],"tail":", (7), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1828"},"text":"112 Stat. 1828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6280b2b9-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6280b2ba-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6280b2bb-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" substituted “controlled college or university” for “controlled community college” in two places and “such college or university” for “such college” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/477"},"text":"Pub. L. 101–477","children":[],"tail":" inserted at en