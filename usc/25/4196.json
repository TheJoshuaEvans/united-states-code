{"tag":"section","attrib":{"id":"id62d1e038-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196"},"text":null,"children":[{"tag":"num","attrib":{"value":"4196"},"text":"§ 4196.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration program for guaranteed loans to finance tribal community and economic development activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d1e039-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d1e03a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), to the extent and in such amounts as are provided in appropriation Acts, subject to the requirements of this section, and in accordance with such terms and conditions as the Secretary may prescribe, the Secretary may guarantee and make commitments to guarantee the notes and obligations issued by Indian tribes or tribally designated housing entities with tribal approval, for the purposes of financing activities carried out on Indian reservations and in other Indian areas that, under the first sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5308/a"},"text":"section 5308(a) of title 42","children":[],"tail":", are eligible for financing with notes and other obligations guaranteed pursuant to that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e03b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may guarantee, or make commitments to guarantee, under paragraph (1) the notes or obligations of not more than 4 Indian tribes or tribally designated housing entities located in each Department of Housing and Urban Development Office of Native American Programs region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e03c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income benefit requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 70 percent of the aggregate amount received by an Indian tribe or tribally designated housing entity as a result of a guarantee under this section shall be used for the support of activities that benefit low-income families on Indian reservations and other Indian areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e03d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial soundness","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d1e03e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish underwriting criteria for guarantees under this section, including fees for the guarantees, as the Secretary determines to be necessary to ensure that the program under this section is financially sound.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e03f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees for guarantees established under paragraph (1) shall be established in amounts that are sufficient, but do not exceed the minimum amounts necessary, to maintain a negative credit subsidy for the program under this section, as determined based on the risk to the Federal Government under the underwriting requirements established under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e040-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of obligations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d1e041-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each note or other obligation guaranteed pursuant to this section shall be in such form and denomination, have such maturity, and be subject to such conditions as the Secretary may prescribe, by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e042-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not deny a guarantee under this section on the basis of the proposed repayment period for the note or other obligation, unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d1e043-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period is more than 20 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d1e044-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the period would cause the guarantee to constitute an unacceptable financial risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e045-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A guarantee made under this section shall guarantee repayment of 95 percent of the unpaid principal and interest due on the note or other obligation guaranteed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e046-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security and repayment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d1e047-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements on issuer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To ensure the repayment of notes and other obligations and charges incurred under this section and as a condition for receiving the guarantees, the Secretary shall require the Indian tribe or housing entity issuing the notes or obligations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d1e048-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into a contract, in a form acceptable to the Secretary, for repayment of notes or other obligations guaranteed under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d1e049-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to demonstrate that the extent of each issuance and guarantee under this section is within the financial capacity of the Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d1e04a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to furnish, at the discretion of the Secretary, such security as the Secretary determines to be appropriate in making the guarantees, including increments in local tax receipts generated by the activities assisted by a guarantee under this section or disposition proceeds from the sale of land or rehabilitated property, except that the security may not include any grant amounts received or for which the issuer may be eligible under subchapter I.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e04b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full faith and credit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d1e04c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The full faith and credit of the United States is pledged to the payment of all guarantees made under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d1e04d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of guarantees","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d1e04e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any guarantee made by the Secretary under this section shall be conclusive evidence of the eligibility of the obligations for the guarantee with respect to principal and interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d1e04f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incontestable nature","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The validity of any such a guarantee shall be incontestable in the hands of a holder of the guaranteed obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e050-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with Indian tribes and tribally designated housing entities, may carry out training and information activities with respect to the guarantee program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e051-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on amount of guarantees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d1e052-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate fiscal year limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, subject only to the absence of qualified applicants or proposed activities and to the authority provided in this section, and to the extent approved or provided for in appropriations Acts, the Secretary may enter into commitments to guarantee notes and obligations under this section with an aggregate principal amount not to exceed $200,000,000 for each of fiscal years 2009 through 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e053-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for credit subsidy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to cover the costs (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a"},"text":"section 661a of title 2","children":[],"tail":") of guarantees under this section $1,000,000 for each of fiscal years 2009 through 2013."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e054-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate outstanding limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of outstanding obligations guaranteed on a cumulative basis by the Secretary pursuant to this section shall not at any time exceed $1,000,000,000 or such higher amount as may be authorized to be appropriated for this section for any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e055-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year limitations on Indian tribes","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d1e056-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/h/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall monitor the use of guarantees under this section by Indian tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d1e057-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/h/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that 50 percent of the aggregate guarantee authority under paragraph (3) has been committed, the Secretary may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d1e058-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/h/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose limitations on the amount of guarantees pursuant to this section that any single Indian tribe may receive in any fiscal year of $25,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d1e059-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/h/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request the enactment of legislation increasing the aggregate outstanding limitation on guarantees under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e05a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2008-10-14"},"text":"October 14, 2008","children":[],"tail":", the Secretary shall submit to Congress a report describing the use of the authority under this section by Indian tribes and tribally designated housing entities, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d1e05b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the extent of the use and the types of projects and activities financed using that authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e05c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the effectiveness of the use in carrying out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e05d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4196/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Secretary under this section to make new guarantees for notes and obligations shall terminate on ","children":[{"tag":"date","attrib":{"date":"2013-10-01"},"text":"October 1, 2013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d1e05e-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVI/s606"},"text":"Pub. L. 104–330, title VI, § 606","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/411/tVI/s601/a"},"text":"Pub. L. 110–411, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4331"},"text":"122 Stat. 4331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d1e05f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d1e060-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62d1e061-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/s606"},"text":"section 606 of Pub. L. 104–330","children":[],"tail":" is set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4191"},"text":"section 4191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
