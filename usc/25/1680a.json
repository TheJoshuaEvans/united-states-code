{"tag":"section","attrib":{"id":"id62773cbc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1680a"},"text":"§ 1680a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract health facilities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Service shall provide funds for health care programs and facilities operated by tribes and tribal organizations under contracts with the Service entered into under the Indian Self-Determination Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.]—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62773cbd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the maintenance and repair of clinics owned or leased by such tribes or tribal organizations,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62773cbe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for employee training,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62773cbf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for cost-of-living increases for employees, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62773cc0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any other expenses relating to the provision of health services,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"on the same basis as such funds are provided to programs and facilities operated directly by the Service.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62773cc1-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s811"},"text":"Pub. L. 94–437, title VIII, § 811","children":[],"tail":", formerly title VII, § 711, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tVII/s705"},"text":"Pub. L. 100–713, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4828"},"text":"102 Stat. 4828","children":[],"tail":"; renumbered title VIII, § 811, "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s701/a"},"text":"Pub. L. 102–573, title VII, § 701(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4572"},"text":"106 Stat. 4572","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62773cc2-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62773cc3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62773cc4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination Act, referred to in text, is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2206"},"text":"88 Stat. 2206","children":[],"tail":", which is classified principally to subchapter I (§ 5321 et seq.) of chapter 46 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
