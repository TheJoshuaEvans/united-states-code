{"tag":"section","attrib":{"id":"id625cfe49-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1616f"},"text":"§ 1616f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal culture and history","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id625cfe4a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program established","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, shall establish a program under which appropriate employees of the Service who serve particular Indian tribes shall receive educational instruction in the history and culture of such tribes and in the history of the Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe4b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribally controlled institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent feasible, the program established under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625cfe4c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be carried out through tribally controlled colleges or universities (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801/a/4"},"text":"section 1801(a)(4) of this title","children":[],"tail":") and tribally controlled postsecondary vocational institutions (as defined in section 2397h(2) "},{"tag":"ref","attrib":{"idref":"fn002039"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002039"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 20),"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe4d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be developed in consultation with the affected tribal government, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe4e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include instruction in Native American studies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id625cfe4f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tI/s113"},"text":"Pub. L. 94–437, title I, § 113","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tI/s109"},"text":"Pub. L. 100–713, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4796"},"text":"102 Stat. 4796","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tI"},"text":"Pub. L. 102–573, title I","children":[],"tail":", §§ 114(b), 117(b)(5), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4543"},"text":"106 Stat. 4543","children":[],"tail":", 4544; "},{"tag":"ref","attrib":