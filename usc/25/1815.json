{"tag":"section","attrib":{"id":"id6280b28b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1815"},"text":null,"children":[{"tag":"num","attrib":{"value":"1815"},"text":"§ 1815.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6280b28c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1815/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with national Indian organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within four months from ","children":[{"tag":"date","attrib":{"date":"1978-10-17"},"text":"October 17, 1978","children":[],"tail":", the Secretary shall, to the extent practicable, consult with national Indian organizations to consider and formulate appropriate rules and regulations for the conduct of the grant program established by this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6280b28d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1815/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within six months from ","children":[{"tag":"date","attrib":{"date":"1978-10-17"},"text":"October 17, 1978","children":[],"tail":", the Secretary shall publish proposed rules and regulations in the Federal Register for the purpose of receiving comments from interested parties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6280b28e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1815/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within ten months from ","children":[{"tag":"date","attrib":{"date":"1978-10-17"},"text":"October 17, 1978","children":[],"tail":", the Secretary shall promulgate rules and regulations for the conduct of the grant program established by this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6280b28f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1815/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds to carry out the purposes of this section may be drawn from general administrative appropriations to the Secretary made after ","children":[{"tag":"date","attrib":{"date":"1978-10-17"},"text":"October 17, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6280b290-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/tI/s115"},"text":"Pub. L. 95–471, title I, § 115","children":[],"tail":", formerly § 114, "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1329"},"text":"92 Stat. 1329","children":[],"tail":"; renumbered § 115, "},{"tag":"ref","attrib":{"href":"/us/pl/98/192/s4/a/1"},"text":"Pub. L. 98–192, § 4(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1336"},"text":"97 Stat. 1336","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6280b291-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6280b292-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6280b293-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Promulgation of Regulations; Consultation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192/s15"},"text":"Pub. L. 98–192, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1343"},"text":"97 Stat. 1343","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/192/s15"},"text":"“In promulgating any regulations to implement the amendments made by this Act [enacting sections 1804a and 1831 to 1836 of this title and amending former section 640c–1 and sections 1801 to 1803 and 1805 to 1813 of this title], the Secretary of the Interior shall consult with tribally controlled community colleges.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
