{"tag":"section","attrib":{"id":"id6287de73-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004"},"text":null,"children":[{"tag":"num","attrib":{"value":"2004"},"text":"§ 2004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School boundaries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6287de74-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish, by regulation, separate geographical attendance areas for each Bureau-funded school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6287de75-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment by tribal body","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case where there is more than one Bureau-funded school located on an Indian reservation, at the direction of the tribal governing body, the relevant school boards of the Bureau-funded schools on the reservation may, by mutual consent, establish the relevant attendance areas for such schools, subject to the approval of the tribal governing body. Any such boundaries so established shall be accepted by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6287de76-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary revisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6287de77-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On or after ","children":[{"tag":"date","attrib":{"date":"2001-07-01"},"text":"July 1, 2001","children":[],"tail":", no geographical attendance area shall be revised or established with respect to any Bureau-funded school unless the tribal governing body or the local school board concerned (if so designated by the tribal governing body) has been afforded—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6287de78-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 6 months notice of the intention of the Bureau to revise or establish such attendance area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6287de79-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opportunity to propose alternative boundaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6287de7a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any tribe may petition the Secretary for revision of existing attendance area boundaries. The Secretary shall accept such proposed alternative or revised boundaries unless the Secretary finds, after consultation with the affected tribe or tribes, that such revised boundaries do not reflect the needs of the Indian students to be served or do not provide adequate stability to all of the affected programs. The Secretary shall cause such revisions to be published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6287de7b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal resolution determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall deny a tribal governing body the authority, on a continuing basis, to adopt a tribal resolution allowing parents the choice of the Bureau-funded school their children may attend, regardless of the attendance boundaries established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6287de7c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding restrictions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6287de7d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not deny funding to a Bureau-funded school for any eligible Indian student attending the school solely because that student’s home or domicile is outside of the geographical attendance area established for that school under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6287de7e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funding shall be made available without tribal authorization to enable a school to provide transportation for any student to or from the school and a location outside the approved attendance area of the school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6287de7f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation as boundary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When there is only one Bureau-funded program located on an Indian reservation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6287de80-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the attendance area for the program shall be the boundaries (established by treaty, agreement, legislation, court decisions, or executive decisions and as accepted by the tribe) of the reservation served; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6287de81-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those students residing near the reservation shall also receive services from such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6287de82-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Off-reservation home-living (dormitory) schools","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6287de83-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any geographical attendance areas, attendance at off-reservation home-living (dormitory) schools shall include students requiring special emphasis programs to be implemented at each off-reservation home-living (dormitory) school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6287de84-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2004/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such attendance shall be coordinated between education line officers, the family, and the referring and receiving programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6287de85-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1124"},"text":"Pub. L. 95–561, title XI, § 1124","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1042"},"text":"Pub. L. 107–110, title X, § 1042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2019"},"text":"115 Stat. 2019","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6287de86-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6287de87-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6287de88-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2004, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1124"},"text":"Pub. L. 95–561, title XI, § 1124","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s381"},"text":"Pub. L. 103–382, title III, § 381","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3986"},"text":"108 Stat. 3986","children":[],"tail":", related to school boundaries, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2004, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1124"},"text":"Pub. L. 95–561, title XI, § 1124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2319"},"text":"92 Stat. 2319","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/511/tV/s503"},"text":"Pub. L. 98–511, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2393"},"text":"98 Stat. 2393","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/89/s3"},"text":"Pub. L. 99–89, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-15"},"text":"Aug. 15, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/380"},"text":"99 Stat. 380","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5120"},"text":"Pub. L. 100–297, title V, § 5120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/384"},"text":"102 Stat. 384","children":[],"tail":", related to school boundaries, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6287de89-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6287de8a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
