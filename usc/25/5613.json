{"tag":"section","attrib":{"id":"id62f5942b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613"},"text":null,"children":[{"tag":"num","attrib":{"value":"5613"},"text":"§ 5613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian trust asset management plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f5942c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposed plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f5942d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the date on which an Indian tribe receives a notice from the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5612/b/2"},"text":"section 5612(b)(2) of this title","children":[],"tail":", the Indian tribe shall submit to the Secretary a proposed Indian trust asset management plan in accordance with paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f5942e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A proposed Indian trust asset management plan shall include provisions that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f5942f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the trust assets that will be subject to the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f59430-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish trust asset management objectives and priorities for Indian trust assets that are located within the reservation, or otherwise subject to the jurisdiction, of the Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f59431-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocate trust asset management funding that is available for the Indian trust assets subject to the plan in order to meet the trust asset management objectives and priorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f59432-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the Indian tribe has contracted or compacted functions or activities under the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.) "},{"tag":"ref","attrib":{"idref":"fn002280"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002280"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" relating to the management of trust assets—"}],"tail":null},{"tag":"clause","attrib":{"id":"id62f59433-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the functions or activities that are being or will be performed by the Indian tribe under the contracts, compacts, or other agreements under that Act, which may include any of the surface leasing or forest land management activities authorized by the proposed plan pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5614/b"},"text":"section 5614(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62f59434-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the practices and procedures that the Indian tribe will follow;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f59435-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures for nonbinding mediation or resolution of any dispute between the Indian tribe and the United States relating to the trust asset management plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f59436-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a process for the Indian tribe and the Federal agencies affected by the trust asset management plan to conduct evaluations to ensure that trust assets are being managed in accordance with the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f59437-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any Federal regulations that will be superseded by the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f59438-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On receipt of a written request from an Indian tribe, the Secretary shall provide to the Indian tribe any technical assistance and information, including budgetary information, that the Indian tribe determines to be necessary for preparation of a proposed plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f59439-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval and disapproval of proposed plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f5943a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f5943b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after the date on which an Indian tribe submits a proposed Indian trust asset management plan under subsection (a), the Secretary shall approve or disapprove the proposed plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f5943c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for disapproval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall approve a proposed plan unless the Secretary determines that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62f5943d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed plan fails to address a requirement under subsection (a)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62f5943e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed plan includes 1 or more provisions that are inconsistent with subsection (c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62f5943f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of implementing the proposed plan exceeds the amount of funding available for the management of trust assets that would be subject to the proposed plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f59440-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action on disapproval","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f59441-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary disapproves a proposed plan under paragraph (1)(B), the Secretary shall provide to the Indian tribe a written notice of the disapproval, including any reason why the proposed plan was disapproved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f59442-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by tribes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a proposed plan is disapproved under paragraph (1)(B), the Indian tribe may resubmit an amended proposed plan by not later than 90 days after the date on which the Indian tribe receives the notice under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f59443-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to approve or disapprove","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary fails to approve or disapprove a proposed plan in accordance with paragraph (1), the plan shall be considered to be approved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f59444-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Indian tribe may seek judicial review of a determination of the Secretary under this subsection in accordance with subchapter II of chapter 5, and chapter 7, of title 5, (commonly known as the “Administrative Procedure Act”), if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f59445-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary disapproves the proposed plan of the Indian tribe under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f59446-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian tribe has exhausted all other administrative remedies available to the Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f59447-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5614"},"text":"section 5614 of this title","children":[],"tail":", an Indian trust asset management plan, and any activity carried out under the plan, shall not be approved unless the proposed plan is consistent with any treaties, statutes, and Executive orders that are applicable to the trust assets, or the management of the trust assets, identified in the plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f59448-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f59449-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Indian tribe may terminate an Indian trust asset management plan on any date after the date on which a proposed Indian trust asset management plan is approved by providing to the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f5944a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notice of the intent of the Indian tribe to terminate the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f5944b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a resolution of the governing body of the Indian tribe authorizing the termination of the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f5944c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5613/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A termination of an Indian trust asset management plan under paragraph (1) takes effect on October 1 of the first fiscal year following the date on which a notice is provided to the Secretary under paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f5944d-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/178/tII/s204"},"text":"Pub. L. 114–178, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/434"},"text":"130 Stat. 434","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62f5944e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62f5944f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62f59450-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in subsec. (a)(2)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of this title prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
