{"tag":"section","attrib":{"id":"id628594a6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1961"},"text":null,"children":[{"tag":"num","attrib":{"value":"1961"},"text":"§ 1961.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Locally convenient day schools","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id628594a7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1961/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the absence of locally convenient day schools may contribute to the breakup of Indian families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628594a8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1961/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress; contents, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized and directed to prepare, in consultation with appropriate agencies in the Department of Health and Human Services, a report on the feasibility of providing Indian children with schools located near their homes, and to submit such report to the Select Committee on Indian Affairs of the United States Senate and the Committee on Interior and Insular Affairs of the United States House of Representatives within two years from ","children":[{"tag":"date","attrib":{"date":"1978-11-08"},"text":"November 8, 1978","children":[],"tail":". In developing this report the Secretary shall give particular consideration to the provision of educational facilities for children in the elementary grades."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id628594a9-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/608/tIV/s401"},"text":"Pub. L. 95–608, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-08"},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3078"},"text":"92 Stat. 3078","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id628594aa-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id628594ab-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id628594ac-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Department of Health and Human Services” substituted for “Department of Health, Education, and Welfare” in subsec. (b), pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":" which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Select Committee on Indian Affairs of the Senate redesignated Committee on Indian Affairs of the Senate by section 25 of Senate Resolution No. 71, ","children":[{"tag":"date","attrib":{"date":"1993-02-25"},"text":"Feb. 25, 1993","children":[],"tail":", One Hundred Third Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Interior and Insular Affairs of the House of Representatives changed to Committee on Natural Resources of the House of Representatives on ","children":[{"tag":"date","attrib":{"date":"1993-01-05"},"text":"Jan. 5, 1993","children":[],"tail":", by House Resolution No. 5, One Hundred Third Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
