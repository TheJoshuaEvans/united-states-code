{"tag":"section","attrib":{"id":"id62d90b71-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4355"},"text":null,"children":[{"tag":"num","attrib":{"value":"4355"},"text":"§ 4355.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter alters, or demonstrates congressional support for the alteration of, the legal relationship between the United States and any American Indian, Alaska Native, or Native Hawaiian individual, group, organization, or entity.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62d90b72-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/221/s6"},"text":"Pub. L. 114–221, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-09-23"},"text":"Sept. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/851"},"text":"130 Stat. 851","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
