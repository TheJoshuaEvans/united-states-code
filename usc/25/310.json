{"tag":"section","attrib":{"id":"id6223c57d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s310"},"text":null,"children":[{"tag":"num","attrib":{"value":"310"},"text":"§ 310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institute of American Indian and Alaska Native Culture and Arts Development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6223c57e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6223c57f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s310/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To the extent of the availability of funds for such purpose, the Secretary of the Interior shall:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6223c580-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s310/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into a thirty-year agreement with the College of Santa Fe, Santa Fe, New Mexico, to provide educational facilities for the use of, and to develop cooperative educational/arts programs to be carried out with the postsecondary fine arts and museum services programs of, the Institute of American Indian and Alaska Native Culture and Arts Development administered by the Bureau of Indian Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6223c581-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s310/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct such activities as are necessary to improve the facilities used by the Institute of American Indian and Alaska Native Culture and Arts Development at the College of Santa Fe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6223c582-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s310/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this subsection shall take effect on ","children":[{"tag":"date","attrib":{"date":"1984-10-01"},"text":"October 1, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6223c583-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6223c584-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s310/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior, acting through the Bureau of Indian Affairs, is directed to conduct a study for the purpose of determining the need, if any, for a museum facility to be established for the benefit of the Institute of American Indian and Alaska Native Culture and Arts Development, the feasibility of establishing such museum, and the need or desirability, if any, to establish any such museum in close proximity to the facilities currently being used by such Institute at the College of Santa Fe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6223c585-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s310/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On or before ","children":[{"tag":"date","attrib":{"date":"1985-02-01"},"text":"February 1, 1985","children":[],"tail":", the Secretary of the Interior shall report the results of such study, together with his recommendations, to the Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6223c586-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s310/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Should the study recommend establishment of a museum, and should the College of Santa Fe be selected as the best site, any agreement entered into by the Secretary of the Interior for construction of such museum shall contain assurances, satisfactory to the Secretary, that appropriate lands at the College of Santa Fe will be available at no cost to the Federal Government for the establishment of a museum facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6223c587-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/306/s14"},"text":"Pub. L. 98–306, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-31"},"text":"May 31, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/226"},"text":"98 Stat. 226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXV/s1514/c"},"text":"Pub. L. 99–498, title XV, § 1514(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1608"},"text":"100 Stat. 1608","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6223c588-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6223c589-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6223c58a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsecs. (a)(1), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":" substituted “Institute of American Indian and Alaska Native Culture and Arts Development” for “Institute of American Indian Arts” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6223c58b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6223c58c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXV/s1514/f"},"text":"Pub. L. 99–498, title XV, § 1514(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1608"},"text":"100 Stat. 1608","children":[],"tail":", provided that amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":" is effective "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
