{"tag":"section","attrib":{"id":"id6287de4e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002"},"text":null,"children":[{"tag":"num","attrib":{"value":"2002"},"text":"§ 2002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National criteria for home-living situations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6287de4f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6287de50-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Education, Indian organizations and tribes, and Bureau-funded schools, shall revise the national standards for home-living (dormitory) situations to include such factors as heating, lighting, cooling, adult-child ratios, needs for counselors (including special needs related to off-reservation home-living (dormitory) situations), therapeutic programs, space, and privacy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6287de51-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such standards shall be implemented in Bureau-operated schools, and shall serve as minimum standards for contract or grant schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6287de52-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision after establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Once established, any revisions of such standards shall be developed according to the requirements established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2017"},"text":"section 2017 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6287de53-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall implement the revised standards established under this section immediately upon completion of the standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6287de54-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6287de55-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to the appropriate committees of Congress, the tribes, and the affected schools, and publish in the Federal Register, a detailed plan to bring all Bureau-funded schools that provide home-living (dormitory) situations up to the standards established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6287de56-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components of plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan described in paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6287de57-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the relative needs of each Bureau-funded home-living (dormitory) school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6287de58-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projected future needs of each Bureau-funded home-living (dormitory) school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6287de59-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detailed information on the status of each school in relation to the standards established under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6287de5a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific cost estimates for meeting each standard for each such school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6287de5b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aggregate cost estimates for bringing all such schools into compliance with the criteria established under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6287de5c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific timelines for bringing each school into compliance with such standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6287de5d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6287de5e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A tribal governing body or local school board may, in accordance with this subsection, waive the standards established under this section for a school described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6287de5f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inappropriate standards","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6287de60-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A tribal governing body, or the local school board so designated by the tribal governing body, may waive, in whole or in part, the standards established under this section if such standards are determined by such body or board to be inappropriate for the needs of students from that tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6287de61-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tribal governing body or school board involved shall, not later than 60 days after providing a waiver under subparagraph (A) for a school, submit to the Director a proposal for alternative standards that take into account the specific needs of the tribe’s children. Such alternative standards shall be established by the Director for the school involved unless specifically rejected by the Director for good cause and in writing provided to the affected tribes or local school board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6287de62-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2002/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closure for failure to meet standards prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No school in operation on or before ","children":[{"tag":"date","attrib":{"date":"1999-07-01"},"text":"July 1, 1999","children":[],"tail":" (regardless of compliance or noncompliance with the standards established under this section), may be closed, transferred to another authority, or consolidated, and no program of such a school may be substantially curtailed, because the school failed to meet such standards."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6287de63-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1122"},"text":"Pub. L. 95–561, title XI, § 1122","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1042"},"text":"Pub. L. 107–110, title X, § 1042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2018"},"text":"115 Stat. 2018","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6287de64-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6287de65-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6287de66-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Pro