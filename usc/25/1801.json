{"tag":"section","attrib":{"id":"id627e68ad-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801"},"text":null,"children":[{"tag":"num","attrib":{"value":"1801"},"text":"§ 1801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id627e68ae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627e68af-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian” means a person who is a member of an Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e68b0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian tribe” means any Indian tribe, band, nation, or other organized group or community, including any Alaskan Native village or regional or village corporation as defined in or established pursuant to the Alaskan Native Claims Settlement Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.], which is recognized as eligible for the special programs and services provided by the United States to Indians because of their status as Indians;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e68b1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary”, unless otherwise designated, means the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e68b2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “tribally controlled college or university” means an institution of higher education which is formally controlled, or has been formally sanctioned, or chartered, by the governing body of an Indian tribe or tribes, except that no more than one such institution shall be recognized with respect to any such tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e68b3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “institution of higher education” means an institution of higher education as defined by section 1001 ","children":[{"tag":"ref","attrib":{"idref":"fn002104"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002104"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “1001(a)”."}],"tail":" of title 20, except that clause (2) of such section shall not be applicable and the reference to Secretary in clause (5)(A) "},{"tag":"ref","attrib":{"idref":"fn002105"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002105"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “(5)”."}],"tail":" of such section shall be deemed to refer to the Secretary of the Interior;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e68b4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “national Indian organization” means an organization which the Secretary finds is nationally based, represents a substantial Indian constituency, and has expertise in the fields of tribally controlled colleges and universities and Indian higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e68b5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Indian student” means a student who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id627e68b6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of an Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id627e68b7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a biological child of a member of an Indian tribe, living or deceased;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e68b8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian student count” means a number equal to the total number of Indian students enrolled in each tribally controlled college or university, determined in a manner consistent with subsection (b) of this section on the basis of the quotient of the sum of the credit hours of all Indian students so enrolled, divided by twelve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e68b9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “satisfactory progress toward a degree or certificate” has the meaning given to such term by the institution at which the student is enrolled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627e68ba-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following conditions shall apply for the purpose of determining the Indian student count pursuant to subsection (a)(8):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627e68bb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such number shall be calculated on the basis of the registrations of Indian students as in effect at the conclusion of the third week of each academic term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e68bc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Credits earned in classes offered during a summer term shall be counted toward the computation of the Indian student count in the succeeding fall term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e68bd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Credits earned by any student who has not obtained a high school degree or its equivalent shall be counted toward the computation of the Indian student count if the institution at which the student is in attendance has established criteria for the admission of such student on the basis of the student’s ability to benefit from the education or training offered. The institution shall be presumed to have established such criteria if the admission procedures for such studies include counseling or testing that measures the student’s aptitude to successfully complete the course in which the student has enrolled. No credits earned by such student for purposes of obtaining a high school degree or its equivalent shall be counted toward the computation of the Indian student count.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e68be-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian students earning credits in any continuing education program of a tribally controlled college or university shall be included in determining the sum of all credit hours.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e68bf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Eligible credits earned in a continuing education program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id627e68c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be determined as one credit for every ten contact hours in the case of an institution on a quarter system, or 15 contact hours in the case of an institution on a semester system, of participation in an organized continuing education experience under responsible sponsorship, capable direction, and qualified instruction, as described in the criteria established by the International Association for Continuing Education and Training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id627e68c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1801/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be limited to ten percent of the Indian student count of a tribally controlled college or university.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id627e68c2-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/s2"},"text":"Pub. L. 95–471, § 2","children":[],"tail":", formerly § 1, "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1325"},"text":"92 Stat. 1325","children":[],"tail":"; renumbered § 2 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/192/s1"},"text":"Pub. L. 98–192, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1335"},"text":"97 Stat. 1335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/428/s3"},"text":"Pub. L. 99–428, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"Sept. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/982"},"text":"100 Stat. 982","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tI/s102/a/8/B"},"text":"Pub. L. 105–244, title I, § 102(a)(8)(B)","children":[],"tail":", title IX, § 901(b)(5), (9), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1619"},"text":"112 Stat. 1619","children":[],"tail":", 1828; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s941/a"},"text":"Pub. L. 110–315, title IX, § 941(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3460"},"text":"122 Stat. 3460","children":[],"tail":", 3461.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id627e68c3-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id627e68c4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id627e68c5-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471"},"text":"Pub. L. 95–471","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1325"},"text":"92 Stat. 1325","children":[],"tail":", known as the Tribally Controlled Colleges and Universities Assistance Act of 1978, which enacted this chapter and former "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s640c–1"},"text":"section 640c–1 of this title","children":[],"tail":", amended former "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s640c"},"text":"section 640c of this title","children":[],"tail":", and enacted provisions set out as notes under this section and former sections 640a and 640c–1 of this title. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Alaskan Native Claims Settlement Act, referred to in subsec. (a)(2), probably means the Alaska Native Claims Settlement Act, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id627e68c6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s941/a"},"text":"Pub. L. 110–315, § 941(a)","children":[],"tail":", substituted “in the fields of tribally controlled colleges and universities and Indian higher education” for “in the field of Indian education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s941/b"},"text":"Pub. L. 110–315, § 941(b)","children":[],"tail":", added par. (7) and redesignated former pars. (7) and (8) as (8) and (9), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s941/c/1"},"text":"Pub. L. 110–315, § 941(c)(1)","children":[],"tail":", substituted “subsection (a)(8)” for “paragraph (7) of subsection (a)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s941/c/2"},"text":"Pub. L. 110–315, § 941(c)(2)","children":[],"tail":", added par. (5) and struck out former par. (5) which read as follows: “Credits earned in a continuing education program shall be converted to a credit-hour basis in accordance with the tribally controlled college or university’s system for providing credit for participation in such program.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s941/c/3"},"text":"Pub. L. 110–315, § 941(c)(3)","children":[],"tail":", struck out par. (6) which read as follows: “No credit hours earned by an Indian student who is not making satisfactory progress toward a degree or certificate shall be taken into account.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/5"},"text":"Pub. L. 105–244, § 901(b)(5)","children":[],"tail":", substituted “college or university” for “community college”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s102/a/8/B"},"text":"Pub. L. 105–244, § 102(a)(8)(B)","children":[],"tail":", substituted “section 1001” for “section 1141(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/5"},"text":"Pub. L. 105–244, § 901(b)(5)","children":[],"tail":", substituted “college or university” for “community college”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/5"},"text":"Pub. L. 105–244, § 901(b)(5)","children":[],"tail":", substituted “college or university” for “community college”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/9"},"text":"Pub. L. 105–244, § 901(b)(9)","children":[],"tail":", substituted “college or university’s” for “community college’s”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/428/s3/a"},"text":"Pub. L. 99–428, § 3(a)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/428/s3/b"},"text":"Pub. L. 99–428, § 3(b)","children":[],"tail":", added par. (3), redesignated former pars. (3) to (5) as (4) to (6), respectively, and in par. (6) struck out “, in accordance with the standards and practices of the appropriate accrediting agency or the institution at which the student is in attendance,” after “certificate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192/s1/1"},"text":"Pub. L. 98–192, § 1(1)","children":[],"tail":", designated existing provisions as subsec. (a) and inserted introductory provision preceding par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192/s1/2"},"text":"Pub. L. 98–192, § 1(2)","children":[],"tail":", struck out “and is eligible to receive services from the Secretary of the Interior” after “Indian tribe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192/s1/3"},"text":"Pub. L. 98–192, § 1(3)","children":[],"tail":", inserted “and the reference to Secretary in clause (5)(A) of such section shall be deemed to refer to the Secretary of the Interior”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192/s1/4"},"text":"Pub. L. 98–192, § 1(4)","children":[],"tail":", substituted provision defining “Indian student count” to mean a number equal to the total number of Indian students enrolled in each tribally controlled community college, determined as consistent with subsec. (b) of this section on the basis of the quotient of the sum of the credit hours of all Indians so enrolled, divided by twelve for provision defining “full-time equivalent Indian student” to mean the number of Indians enrolled full-time and the full-time equivalent of the number of Indians enrolled part-time, determined on the basis of the quotient of the sum of the credit hours of all part-time students divided by twelve, calculated on the basis of registrations as in effect at the conclusion of the sixth week of an academic term."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192/s1/4"},"text":"Pub. L. 98–192, § 1(4)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id627e68c7-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id627e68c8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id627e68c9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/428/s1"},"text":"Pub. L. 99–428, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"Sept. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/982"},"text":"100 Stat. 982","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/428/s1"},"text":"“This Act [amending this section and sections 640c–1, 1808 to 1810, 1812, 1813, and 1836 of this title] may be cited as the ‘Tribally Controlled Community College Assistance Amendments of 1986’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id627e68ca-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/s1"},"text":"Pub. L. 95–471, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1325"},"text":"92 Stat. 1325","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s901/b/1"},"text":"Pub. L. 105–244, title IX, § 901(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","chi