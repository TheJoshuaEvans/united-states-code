{"tag":"section","attrib":{"id":"id621323e9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s63"},"text":null,"children":[{"tag":"num","attrib":{"value":"63"},"text":"§ 63.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation of agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may, in his discretion, consolidate two or more agencies into one, and where Indians are located on reservations created by Executive order he may, with the consent of the tribes to be affected thereby, expressed in the usual manner, consolidate one or more tribes, and abolish such agencies as are thereby rendered unnecessary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621323ea-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1882-05-17/ch163/s6"},"text":"May 17, 1882, ch. 163, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/22/88"},"text":"22 Stat. 88","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1884-07-04/ch180/s6"},"text":"July 4, 1884, ch. 180, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/23/97"},"text":"23 Stat. 97","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621323eb-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id621323ec-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id621323ed-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation to Secretary of the Interior of authority vested in President by this section, see Ex. Ord. No. 10250, ","children":[{"tag":"date","attrib":{"date":"1951-06-05"},"text":"June 5, 1951","children":[],"tail":", 16 F.R. 5385, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
