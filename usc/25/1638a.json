{"tag":"section","attrib":{"id":"id6268e551-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1638a"},"text":"§ 1638a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal management of federally owned quarters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6268e552-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rental rates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6268e553-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, a tribal health program that operates a hospital or other health facility and the federally owned quarters associated with such a facility pursuant to a contract or compact under the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.) "},{"tag":"ref","attrib":{"idref":"fn002064"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002064"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" may establish the rental rates charged to the occupants of those quarters, on providing notice to the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e554-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing rental rates under this subsection, a tribal health program shall attempt—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6268e555-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to base the rental rates on the reasonable value of the quarters to the occupants of the quarters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6268e556-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to generate sufficient funds to prudently provide for the operation and maintenance of the quarters, and at the discretion of the tribal health program, to supply reserve funds for capital repairs and replacement of the quarters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e557-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A federally owned quarters the rental rates for which are established by a tribal health program under this subsection shall remain eligible to receive improvement and repair funds to the same extent that all federally owned quarters used to house personnel in programs of the Service are eligible to receive those funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e558-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of rate change","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A tribal health program that establishes a rental rate under this subsection shall provide occupants of the federally owned quarters a notice of any change in the rental rate by not later than the date that is 60 days notice before the effective date of the change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e559-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates in Alaska","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A rental rate established by a tribal health program under this section for a federally owned quarters in the State of Alaska may be based on the cost of comparable private rental housing in the nearest established community with a year-round population of 1,500 or more individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6268e55a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct collection of rent","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6268e55b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, and subject to paragraph (2), a tribal health program may collect rent directly from Federal employees who occupy federally owned quarters if the tribal health program submits to the Secretary and the employees a notice of the election of the tribal health program to collect rents directly from the employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e55c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On receipt of a notice described in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6268e55d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the affected Federal employees shall pay rent for occupancy of a federally owned quarters directly to the applicable tribal health program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6268e55e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall not have the authority to collect rent from the employees through payroll deduction or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e55f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rent payments under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6268e560-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be retained by the applicable tribal health program in a separate account, which shall be used by the tribal health program for the maintenance (including capital repairs and replacement) and operation of the quarters, as the tribal health program determines to be appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6268e561-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be made payable to, or otherwise be deposited with, the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e562-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retrocession of authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a tribal health program that elected to collect rent directly under paragraph (1) requests retrocession of the authority of the tribal health program to collect that rent, the retrocession shall take effect on the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6268e563-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first day of the month that begins not less than 180 days after the tribal health program submits the request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6268e564-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other date as may be mutually agreed on by the Secretary and the tribal health program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6268e565-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tIII/s309"},"text":"Pub. L. 94–437, title III, § 309","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6268e566-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6268e567-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6268e568-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.), referred to in subsec. (a)(1), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of this title prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6268e569-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s309"},"text":"Section 309 of Pub. L. 94–437","children":[],"tail":" is based on section 144 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6268e56a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1638a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tIII/s309"},"text":"Pub. L. 94–437, title III, § 309","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tIII/s307/a"},"text":"Pub. L. 102–573, title III, § 307(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4564"},"text":"106 Stat. 4564","children":[],"tail":", authorized appropriations through fiscal year 2000 to carry out this subchapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":". The repeal is based on section 101(b)(6) of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
