{"tag":"section","attrib":{"id":"id62bc5c45-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406"},"text":null,"children":[{"tag":"num","attrib":{"value":"3406"},"text":"§ 3406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62bc5c46-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon receipt of a plan from an Indian tribe, the Secretary shall consult with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5c47-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of each Federal agency overseeing a program identified in the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c48-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian tribe that submitted the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5c49-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The parties identified in subsection (a) shall identify any waivers of applicable statutory, regulatory, or administrative requirements, or of Federal agency policies or procedures necessary to enable the Indian tribe to efficiently implement the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5c4a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal waiver request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In consultation with the Secretary, a participating Indian tribe may request that the head of each affected agency waive any statutory, regulatory, or administrative requirement, policy, or procedure identified subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002219"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002219"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5c4b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5c4c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), notwithstanding any other provision of law, the head of each affected Federal agency shall waive any applicable statutory, regulatory, or administrative requirement, regulation, policy, or procedure promulgated by the agency that has been identified by the parties under subparagraph ","children":[{"tag":"ref","attrib":{"idref":"fn002220"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002220"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":" (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c4d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an affected Federal agency shall not grant a waiver under paragraph (1) if the head of the affected agency determines that a waiver will be inconsistent with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62bc5c4e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5c4f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of law from which the program included in the plan derives its authority that is specifically applicable to Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5c50-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decision on waiver request","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5c51-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the head of an affected agency receives a waiver request, the head of the affected agency shall decide whether to grant or deny the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c52-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the head of the affected agency denies a waiver request, not later than 30 days after the date on which the denial is made, the head of the affected agency shall provide the requesting Indian tribe and the Secretary with written notice of the denial and the reasons for the denial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c53-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to act on request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the head of an affected agency does not make a decision under paragraph (1) by the deadline identified in that paragraph, the request shall be considered to be granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5c54-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the head of an affected agency denies a waiver request under subsection (e)(2), not later than 30 days after the date on which the request is denied, the Secretary shall review the denial and determine whether granting the waiver—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5c55-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be inconsistent with the provisions of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c56-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will prevent the affected agency from fulfilling the obligations of the affected agency under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5c57-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency dispute resolution","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5c58-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the date on which the Secretary determines that granting the waiver will not be inconsistent with the provisions of this chapter and will not prevent the affected agency from fulfilling the obligations of the affected agency under this chapter, the Secretary shall establish and initiate an interagency dispute resolution process involving—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62bc5c59-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5c5a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participating Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5c5b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of the affected agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c5c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A dispute subject to paragraph (1) shall be resolved not later than 30 days after the date on which the process is initiated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5c5d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the dispute resolution process fails to resolve the dispute between a participating Indian tribe and an affected agency, the head of the affected agency shall have the final authority to resolve the dispute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5c5e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final decision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 10 days after the date on which the dispute is resolved under this section, the Secretary shall provide the requesting Indian tribe with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5c5f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the final decision on the waiver request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c60-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3406/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of the right to file an appeal in accordance with the applicable provisions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3407/d"},"text":"section 3407(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62bc5c61-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/477/s7"},"text":"Pub. L. 102–477, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2303"},"text":"106 Stat. 2303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tXI/s1103/c"},"text":"Pub. L. 106–568, title XI, § 1103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2932"},"text":"114 Stat. 2932","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/93/s8"},"text":"Pub. L. 115–93, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-18"},"text":"Dec. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2029"},"text":"131 Stat. 2029","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62bc5c62-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62bc5c63-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62bc5c64-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/93"},"text":"Pub. L. 115–93","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “Upon receipt of the plan from a tribal government, the Secretary of the Interior shall consult with the Secretary of each Federal agency providing funds to be used to implement the plan, and with the tribal government submitting the plan. The parties so consulting shall identify any waivers of statutory requirements or of Federal agency regulations, policies, or procedures necessary to enable the tribal government to implement its plan. Notwithstanding any other provision of law, the Secretary of the affected agency shall have the authority to waive any statutory requirement, regulation, policy, or procedure promulgated by that agency that has been so identified by such tribal government or agency, unless the Secretary of the affected agency determines that such a waiver is inconsistent with the purposes of this chapter or those provisions of the statute from which the program involved derives its authority which are specifically applicable to Indian programs.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568"},"text":"Pub. L. 106–568","children":[],"tail":" substituted “Federal agency” for “Federal department” and “Federal agency regulations” for “Federal departmental regulations”, substituted “agency” for “department” wherever appearing, and inserted “statutory requirement,” after “to waive any”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
