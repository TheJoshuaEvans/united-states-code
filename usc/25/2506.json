{"tag":"section","attrib":{"id":"id62a48de9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2506"},"text":null,"children":[{"tag":"num","attrib":{"value":"2506"},"text":"§ 2506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of grants; investment of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62a48dea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a48deb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this subsection, the Secretary shall make payments to grantees under this chapter in two payments, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a48dec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2506/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first payment shall be made not later than July 1 of each year in an amount equal to 80 percent of the amount which the grantee was entitled to receive during the preceding academic year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48ded-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2506/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the second payment, consisting of the remainder to which the grantee is entitled for the academic year, shall be made not later than December 1 of each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48dee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In a case in which the amount provided to a grant recipient under paragraph (1)(A) is in excess of the amount that the recipient is entitled to receive for the academic year involved, the recipient shall return to the Secretary such excess amount not later than 30 days after the final determination that the school was overpaid pursuant to this section. The amount returned to the Secretary under this paragraph shall be distributed equally to all schools in the system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48def-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2506/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Newly funded schools","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any school for which no payment under this chapter was made from Bureau funds in the preceding academic year, full payment of the amount computed for the first academic year of eligibility under this chapter shall be made not later than December 1 of the academic year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48df0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2506/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Late funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With regard to funds for grantees that become available for obligation on October 1 of the fiscal year for which such funds are appropriated, the Secretary shall make payments to grantees not later than December 1 of the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48df1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2506/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain title 31 provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of chapter 39 of title 31 shall apply to the payments required to be made by paragraphs (1), (3), and (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48df2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2506/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (1), (3), and (4) shall be subject to any restriction on amounts of payments under this chapter that are imposed by a continuing resolution or other Act appropriating the funds involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a48df3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a48df4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of interest and investment income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, any interest or investment income that accrues to any funds provided under this chapter after such funds are paid to the Indian tribe or tribal organization and before such funds are expended for the purpose for which such funds were provided under this chapter shall be the property of the Indian tribe or tribal organization and shall not be taken into account by any officer or employee of the Federal Government in determining whether to provide assistance, or the amount of assistance, under any provision of Federal law. Such interest income shall be spent on behalf of the school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48df5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible investments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds provided under this chapter may be invested by the Indian tribe or tribal organization before such funds are expended for the purposes of this chapter so long as such funds are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a48df6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2506/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invested by the Indian tribe or tribal organization only in obligations of the United States, or in obligations or securities that are guaranteed or insured by the United States, or mutual (or other) funds registered with the Securities and Exchange Commission and which only invest in obligations of the United States, or securities that are guaranteed or insured by the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48df7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2506/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposited only into accounts that are insure by and ","children":[{"tag":"ref","attrib":{"idref":"fn002174"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002174"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “insured by an”."}],"tail":" agency or instrumentality of the United States, or are fully collateralized to ensure protection of the funds, even in the event of a bank failure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a48df8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recoveries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of underrecovery and overrecovery determinations by any Federal agency for any other funds, from whatever source derived, funds received under this chapter shall not be taken into consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62a48df9-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5207"},"text":"Pub. L. 100–297, title V, § 5207","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1043"},"text":"Pub. L. 107–110, title X, § 1043","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2074"},"text":"115 Stat. 2074","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62a48dfa-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62a48dfb-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62a48dfc-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2506, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5207"},"text":"Pub. L. 100–297, title V, § 5207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/391"},"text":"102 Stat. 391","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/427/s12"},"text":"Pub. L. 100–427, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1608"},"text":"102 Stat. 1608","children":[],"tail":", related to duration of eligibility determination, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1043"},"text":"Pub. L. 107–110, title X, § 1043","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2063"},"text":"115 Stat. 2063","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2505"},"text":"section 2505 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62a48dfd-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id62a48dfe-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
