{"tag":"section","attrib":{"id":"id629af168-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2219"},"text":null,"children":[{"tag":"num","attrib":{"value":"2219"},"text":"§ 2219.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to Alaska","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id629af169-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2219/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629af16a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2219/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" numerous academic and governmental organizations have studied the nature and extent of fractionated ownership of Indian land outside of Alaska and have proposed solutions to this problem; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629af16b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2219/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" despite these studies, there has not been a comparable effort to analyze the problem, if any, of fractionated ownership in Alaska.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629af16c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2219/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of chapter to Alaska","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in this section, this chapter shall not apply to land located within Alaska.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629af16d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2219/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to constitute a ratification of any determination by any agency, instrumentality, or court of the United States that may support the assertion of tribal jurisdiction over allotment lands or interests in such land in Alaska.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629af16e-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/459/tII/s220"},"text":"Pub. L. 97–459, title II, § 220","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/462/tI/s103/6"},"text":"Pub. L. 106–462, title I, § 103(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2006"},"text":"114 Stat. 2006","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id629af16f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id629af170-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id629af171-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, which was translated as reading “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/459"},"text":"Pub. L. 97–459","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
