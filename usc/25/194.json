{"tag":"section","attrib":{"id":"id621c998d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s194"},"text":null,"children":[{"tag":"num","attrib":{"value":"194"},"text":"§ 194.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trial of right of property; burden of proof","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In all trials about the right of property in which an Indian may be a party on one side, and a white person on the other, the burden of proof shall rest upon the white person, whenever the Indian shall make out a presumption of title in himself from the fact of previous possession or ownership.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621c998e-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2126.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621c998f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621c9990-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id621c9991-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2126 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1834-06-30/ch161/s22"},"text":"act June 30, 1834, ch. 161, § 22","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/733"},"text":"4 Stat. 733","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
