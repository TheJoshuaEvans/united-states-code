{"tag":"section","attrib":{"id":"id62f805e6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901"},"text":null,"children":[{"tag":"num","attrib":{"value":"5901"},"text":"§ 5901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f805e7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable Bureau office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable Bureau office” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f805e8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Regional office of the Bureau;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f805e9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Agency office of the Bureau; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f805ea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Land Titles and Records Office of the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f805eb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Bureau” means the Bureau of Indian Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f805ec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f805ed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First certified title status report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “first certified title status report” means the title status report needed to verify title status on Indian land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f805ee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian land” has the meaning given the term in section 162.003 of title 25, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2026-05-04"},"text":"May 4, 2026","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f805ef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land mortgage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “land mortgage” means a mortgage obtained by an individual Indian who owns a tract of trust land for the purpose of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f805f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" home acquisition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f805f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" home construction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f805f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" home improvements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f805f3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f805f4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leasehold mortgage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “leasehold mortgage” means a mortgage, deed of trust, or other instrument that pledges the leasehold interest of a lessee as security for a debt or other obligation owed by the lessee to a lender or other mortgagee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f805f5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgage package","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “mortgage package” means a proposed residential leasehold mortgage, business leasehold mortgage, land mortgage, or right-of-way document submitted to an applicable Bureau office under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5902/a/1"},"text":"section 5902(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f805f6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relevant Federal agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “relevant Federal agency” means any of the following Federal agencies that guarantee or make direct mortgage loans on Indian land:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f805f7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f805f8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f805f9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f805fa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right-of-way document","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “right-of-way document” has the meaning given the term in section 169.2 of title 25, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2026-05-04"},"text":"May 4, 2026","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f805fb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5901/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent certified title status report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “subsequent certified title status report” means the title status report needed to identify any liens against a residential, business, or land lease on Indian land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag"