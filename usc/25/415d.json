{"tag":"section","attrib":{"id":"id623b9379-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s415d"},"text":null,"children":[{"tag":"num","attrib":{"value":"415d"},"text":"§ 415d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease of restricted lands under other laws unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing contained in sections 415 to 415d of this title shall be construed to repeal any authority to lease restricted Indian lands conferred by or pursuant to any other provision of law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id623b937a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch615/s6"},"text":"Aug. 9, 1955, ch. 615, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/540"},"text":"69 Stat. 540","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
