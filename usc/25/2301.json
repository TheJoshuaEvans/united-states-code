{"tag":"section","attrib":{"id":"id629af199-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2301"},"text":null,"children":[{"tag":"num","attrib":{"value":"2301"},"text":"§ 2301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629af19a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629af19b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “unauthorized disbursement” means a disbursement made from the trust estate of a deceased Indian which was made by the Secretary to a State or a political subdivision of a State for the purpose of reimbursing the State or political subdivision for any old age assistance made to the deceased Indian before death in violation of Federal laws governing Indian trust property: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That, except for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2303"},"text":"section 2303 of this title","children":[],"tail":", the term also includes the reimbursements for welfare payments identified in either the list published on "},{"tag":"date","attrib":{"date":"1985-04-17"},"text":"April 17, 1985","children":[],"tail":", at page 15290 of volume 50 of the Federal Register, as modified or amended on "},{"tag":"date","attrib":{"date":"1985-11-13"},"text":"November 13, 1985","children":[],"tail":", at page 46835 of volume 50 of the Federal Register, or the list published on "},{"tag":"date","attrib":{"date":"1983-03-31"},"text":"March 31, 1983","children":[],"tail":", at page 13698 of volume 48 of the Federal Register, as modified or amended on "},{"tag":"date","attrib":{"date":"1983-11-07"},"text":"November 7, 1983","children":[],"tail":", at page 51204 of volume 48 of the Federal Register; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629af19c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “trust estate” means that portion of the estate that consists of real or personal property, title to which is held by the United States for the benefit of the Indian or which may not be alienated without the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629af19d-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/500/s2"},"text":"Pub. L. 98–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2317"},"text":"98 Stat. 2317","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/153/s5"},"text":"Pub. L. 100–153, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-05"},"text":"Nov. 5, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/886"},"text":"101 Stat. 886","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id629af19e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id629af19f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id629af1a0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/153"},"text":"Pub. L. 100–153","children":[],"tail":" inserted proviso that “unauthorized disbursement” includes specifically identified reimbursements for welfare payments."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id629af1a1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id629af1a2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/500/s1"},"text":"Pub. L. 98–500, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2317"},"text":"98 Stat. 2317","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/500/s1"},"text":"“That this Act [enacting this chapter] may be cited as the ‘Old Age Assistance Claims Settlement Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
