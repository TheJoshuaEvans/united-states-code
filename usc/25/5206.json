{"tag":"section","attrib":{"id":"id62ddc6fe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5206"},"text":null,"children":[{"tag":"num","attrib":{"value":"5206"},"text":"§ 5206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans to individuals and groups; appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make loans to individual Indians and to associations or corporate groups organized pursuant to this chapter. For the making of such loans and for expenses of the cooperative associations organized pursuant to this chapter there shall be appropriated, out of the Treasury of the United States, the sum of $2,000,000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62ddc6ff-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-26/ch831/s6"},"text":"June 26, 1936, ch. 831, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1968"},"text":"49 Stat. 1968","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ddc700-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62ddc701-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62ddc702-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s506"},"text":"section 506 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62ddc703-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62ddc704-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Administration of Funds in Revolving Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Funds authorized by act ","children":[{"tag":"date","attrib":{"date":"1936-06-26"},"text":"June 26, 1936","children":[],"tail":", to be administered as a single Indian Revolving Loan Fund after "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1461"},"text":"section 1461 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
