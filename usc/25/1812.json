:[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1057"},"text":"70 Stat. 1057","children":[],"tail":", which was formerly classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s443a"},"text":"section 443a of this title","children":[],"tail":" prior to editorial reclassification as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1457"},"text":"section 1457 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Navajo Community College Act, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/189"},"text":"Pub. L. 92–189","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-15"},"text":"Dec. 15, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/646"},"text":"85 Stat. 646","children":[],"tail":", which was classified to section 640a et seq. of this title and was omitted from the Code as being of special and not general application."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in subsec. (c)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which is classified principally to chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1132e–1"},"text":"Section 1132e–1 of title 20","children":[],"tail":", referred to in subsec. (d), was omitted in the general revision of subchapter VII (§ 1132a et seq.) of chapter 28 of Title 20, Education, by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tVII/s701"},"text":"Pub. L. 99–498, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1520"},"text":"100 Stat. 1520","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1132i–1"},"text":"section 1132i–1 of Title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6280b26a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s523"},"text":"Section 523 of title 40","children":[],"tail":"” substituted in subsec. (a)(2) for “section 202(a)(2) of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s483/a/2"},"text":"40 U.S.C. 483(a)(2)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6280b26b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/6"},"text":"Pub. L. 105–244, § 901(b)(6)","children":[],"tail":", substituted “colleges or universities” for “community colleges” in introductory provisions and par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/13"},"text":"Pub. L. 105–244, § 901(b)(13)","children":[],"tail":", substituted “colleges or universities” for “colleges”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/6"},"text":"Pub. L. 105–244, § 901(b)(6)","children":[],"tail":", substituted “colleges or universities” for “community colleges”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/392"},"text":"Pub. L. 101–392","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/428/s6/a"},"text":"Pub. L. 99–428, § 6(a)","children":[],"tail":", substituted “Secretary” for “Administrator of General Services” and “"},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"December 1, 1983","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/428/s6/a/1"},"text":"Pub. L. 99–428, § 6(a)(1)","children":[],"tail":", substituted “Secretary” for “Administrator of General Services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192"},"text":"Pub. L. 98–192","children":[],"tail":" amended section generally, substituting provision requiring a study on the condition of currently existing facilities, submission of a report on the study, contents of the report, establishment of a renovation program, and defining term “reconstruction” for provision which required the Secretary of the Interior, not later than ninety days after "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", to prepare and submit a report to the Congress containing a survey of existing and planned physical facilities of tribally controlled community colleges."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6280b26c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6280b26d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6280b26e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/392"},"text":"Pub. L. 101–392","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-07-01"},"text":"July 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/392/s702/a"},"text":"section 702(a) of Pub. L. 101–392","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3423a"},"text":"section 3423a of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
