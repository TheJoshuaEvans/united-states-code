{"tag":"section","attrib":{"id":"id6280b25a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1812"},"text":null,"children":[{"tag":"num","attrib":{"value":"1812"},"text":"§ 1812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6280b25b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1812/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study on condition of currently existing facilities; submission of report; contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide for the conduct of a study of facilities available for use by tribally controlled colleges or universities. Such study shall consider the condition of currently existing Bureau of Indian Affairs facilities which are vacant or underutilized and shall consider available alternatives for renovation, alteration, repair, and reconstruction of such facilities (including renovation, alteration, repair, and reconstruction necessary to bring such facilities into compliance with local building codes). Such study shall also identify the need for new construction. A report on the results of such study shall be submitted to the Congress not later than eighteen months after ","children":[{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":". Such report shall also include an identification of property—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6280b25c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1812/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on which structurally sound buildings suitable for use as educational facilities are located, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6280b25d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1812/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is available for use by tribally controlled colleges or universities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s523"},"text":"section 523 of title 40","children":[],"tail":" and under the Act of "},{"tag":"date","attrib":{"date":"1956-08-06"},"text":"August 6, 1956","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/70/1057"},"text":"70 Stat. 1057","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s443a"},"text":"25 U.S.C. 443a","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn002111"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002111"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6280b25e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1812/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renovation program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Bureau of Indian Affairs, shall initiate a program to conduct necessary renovations, alterations, repairs, and reconstruction identified pursuant to subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6280b25f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1812/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination and prioritization of construction and renovation needs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6280b260-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1812/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall enter into a contract with an organization described in paragraph (2) to establish and provide on an annual basis criteria for the determination and prioritization in a consistent and equitable manner of the facilities construction and renovation needs of colleges or universities that receive funding under this chapter or the Navajo Community College Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6280b261-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1812/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An organization described in this section is any organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6280b262-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1812/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible to receive a contract under the Indian Self-Determination and Education Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6280b263-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1812/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has demonstrated expertise in areas and issues dealing with tribally controlled colleges or universities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6280b264-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1812/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall include the priority list established pursuant to this subsection in the budget submitted annually to the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6280b265-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1812/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Reconstruction” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, the term “reconstruction” has the meaning provided in the first sentence of subparagraph (B) of section 1132e–1(2) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 20."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6280b266-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/tI/s112"},"text":"Pub. L. 95–471, title I, § 112","children":[],"tail":", formerly § 111, "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1328"},"text":"92 Stat. 1328","children":[],"tail":"; renumbered § 112 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/192"},"text":"Pub. L. 98–192","children":[],"tail":", §§ 4(a)(1), 11, "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1336"},"text":"97 Stat. 1336","children":[],"tail":", 1339; "},{"tag":"ref","attrib":{"href":"/us/pl/99/428/s6/a"},"text":"Pub. L. 99–428, § 6(a)","childre