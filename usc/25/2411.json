{"tag":"section","attrib":{"id":"id629d61f9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411"},"text":null,"children":[{"tag":"num","attrib":{"value":"2411"},"text":"§ 2411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inter-departmental Memorandum of Agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id629d61fa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", the Secretary of the Interior, the Attorney General, and the Secretary of Health and Human Services shall develop and enter into a Memorandum of Agreement which shall, among other things—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id629d61fb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine and define the scope of the problem of alcohol and substance abuse for Indian tribes and their members and its financial and human costs, and specifically identify such problems affecting Indian youth,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d61fc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id629d61fd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resources and programs of the Bureau of Indian Affairs, Office of Justice Programs, Substance Abuse and Mental Health Services Administration, and Indian Health Service, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629d61fe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal, tribal, State and local, and private resources and programs,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"which would be relevant to a coordinated effort to combat alcohol and substance abuse among Indian people, including those programs and resources made available by this chapter,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d61ff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop and establish appropriate minimum standards for each agency’s program responsibilities under the Memorandum of Agreement which may be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id629d6200-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the existing Federal or State standards in effect, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629d6201-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the absence of such standards, new standards which will be developed and established in consultation with Indian tribes,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d6202-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the Bureau of Indian Affairs, Department of Justice, Substance Abuse and Mental Health Services Administration, and Indian Health Service alcohol and substance abuse programs existing on ","children":[{"tag":"date","attrib":{"date":"1986-10-27"},"text":"October 27, 1986","children":[],"tail":", with programs or efforts established by this chapter,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d6203-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delineate the responsibilities of the Bureau of Indian Affairs, Department of Justice, Substance Abuse and Mental Health Services Administration, and the Indian Health Service to coordinate alcohol and substance abuse-related services at the central, area, agency, and service unit levels,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d6204-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct Bureau of Indian Affairs agency and education superintendents, where appropriate, and the Indian Health Service service unit directors to cooperate fully with tribal requests made pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2412"},"text":"section 2412 of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d6205-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for an annual review of such agreements by the Secretary of the Interior, the Attorney General, and the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629d6206-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Character of activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that there are new activities undertaken pursuant to this chapter, those activities shall supplement, not supplant, activities, programs, and local actions that are ongoing on ","children":[{"tag":"date","attrib":{"date":"1986-10-27"},"text":"October 27, 1986","children":[],"tail":". Such activities shall be undertaken in the manner least disruptive to tribal control, in accordance with the Indian Self-Determination and Education Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.),"},{"tag":"ref","attrib":{"idref":"fn002149"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002149"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and local control, in accordance with section 2010 "},{"tag":"ref","attrib":{"idref":"fn002149"},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629d6207-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior, the Attorney General, and the Secretary of Health and Human Services shall, in developing the Memorandum of Agreement under subsection (a), consult with and solicit the comments of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629d6208-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interested Indian tribes,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d6209-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian individuals,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d620a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian organizations, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d620b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professionals in the treatment of alcohol and substance abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629d620c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2411/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Memorandum of Agreement under subsection (a) shall be submitted to Congress and published in the Federal Register not later than 130 days after ","children":[{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":". At the same time as publication in the Federal Register, the Secretary of the Interior shall provide a copy of this chapter and the Memorandum of Agreement under subsection (a) to each Indian tribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629d620d-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4205"},"text":"Pub. L. 99–570, title IV, § 4205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-139"},"text":"100 Stat. 3207–139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s241/a/1"},"text":"Pub. L. 111–211, title II, § 241(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2287"},"text":"124 Stat. 2287","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id629d620e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id629d620f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id629d6210-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.), referred to in subsec. (b), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of this title prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2010"},"text":"Section 2010 of this title","children":[],"tail":", referred to in subsec. (b), was in the original a reference to section 1130 of the Education Amendments of 1978, "},{"tag":"ref","attrib":{"href":"/us/pl/95/561"},"text":"Pub. L. 95–561","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/95/561/s1130"},"text":"Section 1130 of Pub. L. 95–561","children":[],"tail":" was omitted in the general amendment of chapter 22 (§ 2001 et seq.) of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s381"},"text":"Pub. L. 103–382, title III, § 381","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3979"},"text":"108 Stat. 3979","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":" enacted a new "},{"tag":"ref","attrib":{"href":"/us/pl/95/561/s1130"},"text":"section 1130 of Pub. L. 95–561","children":[],"tail":", relating to uniform direct funding and support, which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2010"},"text":"section 2010 of this title","children":[],"tail":". Provisions relating to Indian control of Indian education are now contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2011"},"text":"section 2011 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id629d6211-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/1/A/i"},"text":"Pub. L. 111–211, § 241(a)(1)(A)(i)","children":[],"tail":", in introductory provisions, substituted “Not later than 1 year after "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":"” for “Not later than 120 days after "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"October 27, 1986","children":[],"tail":"” and inserted “, the Attorney General,” after “Secretary of the Interior”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/1/A/ii"},"text":"Pub. L. 111–211, § 241(a)(1)(A)(ii)","children":[],"tail":", which directed insertion of “, Office of Justice Programs, Substance Abuse and Mental Health Services Administration,” after “Bureau of Indian Affairs,”, was executed by making the insertion after “Bureau of Indian Affairs” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/1/A/iii"},"text":"Pub. L. 111–211, § 241(a)(1)(A)(iii)","children":[],"tail":", (iv), inserted “, Department of Justice, Substance Abuse and Mental Health Services Administration,” after “Bureau of Indian Affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/1/A/v"},"text":"Pub. L. 111–211, § 241(a)(1)(A)(v)","children":[],"tail":", inserted “, the Attorney General,” after “Secretary of the Interior”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/1/B"},"text":"Pub. L. 111–211, § 241(a)(1)(B)","children":[],"tail":", inserted “, the Attorney General,” after “Secretary of the Interior” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/1/C"},"text":"Pub. L. 111–211, § 241(a)(1)(C)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"October 27, 1986","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
