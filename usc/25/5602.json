{"tag":"section","attrib":{"id":"id62f5940b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5602"},"text":null,"children":[{"tag":"num","attrib":{"value":"5602"},"text":"§ 5602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reaffirmation of policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Pursuant to the constitutionally vested authority of Congress over Indian affairs, Congress reaffirms that the responsibility of the United States to Indian tribes includes a duty to promote tribal self-determination regarding governmental authority and economic development.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62f5940c-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/178/tI/s102"},"text":"Pub. L. 114–178, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/433"},"text":"130 Stat. 433","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
