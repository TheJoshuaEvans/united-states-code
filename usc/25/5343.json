{"tag":"section","attrib":{"id":"id62e9ad62-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5343"},"text":null,"children":[{"tag":"num","attrib":{"value":"5343"},"text":"§ 5343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Government property by States and Territories","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior, in making any contract authorized by sections 5342 to 5348 of this title, may permit such contracting party to utilize, for the purposes of said sections, existing school buildings, hospitals, and other facilities, and all equipment therein or appertaining thereto, including livestock and other personal property owned by the Government, under such terms and conditions as may be agreed upon for their use and maintenance.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62e9ad63-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-04-16/ch147/s2"},"text":"Apr. 16, 1934, ch. 147, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/596"},"text":"48 Stat. 596","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-04/ch490/s2"},"text":"June 4, 1936, ch. 490, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1459"},"text":"49 Stat. 1459","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62e9ad64-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62e9ad65-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62e9ad66-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s453"},"text":"section 453 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62e9ad67-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1936—Act ","children":[{"tag":"date","attrib":{"date":"1936-06-04"},"text":"June 4, 1936","children":[],"tail":", substituted “, may permit such contracting party” for “with any State or Territory, may permit such State or Territory”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
