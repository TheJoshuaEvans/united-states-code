{"tag":"section","attrib":{"id":"id62b2e6e0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076"},"text":null,"children":[{"tag":"num","attrib":{"value":"3076"},"text":"§ 3076.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native working group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b2e6e1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall convene a Native working group consisting of not fewer than 12 representatives of Indian Tribes and Native Hawaiian organizations with relevant expertise, who shall be nominated by Indian Tribes and Native Hawaiian organizations, to advise the Federal Government in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b2e6e2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Native working group convened under subsection (a) may provide recommendations regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b2e6e3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the voluntary return of tangible cultural heritage by collectors, dealers, and other individuals and non-Federal organizations that hold such tangible cultural heritage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e6e4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the elimination of illegal commerce of cultural items and archaeological resources in the United States and foreign markets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b2e6e5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Native working group convened under subsection (a) may make formal requests to initiate certain agency actions, including requests that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b2e6e6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Justice initiate judicial proceedings domestically or abroad to aid in the repatriation cultural items and archaeological resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e6e7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of State initiate dialogue through diplomatic channels to aid in that repatriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b2e6e8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency and committee assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b2e6e9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On request by the Native working group convened under subsection (a), the agencies and committees described in paragraph (2) shall make efforts to provide information and assistance to the Native working group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e6ea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of agencies and committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agencies and committees referred to in paragraph (1) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b2e6eb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e6ec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e6ed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e6ee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e6ef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The review committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3006/a"},"text":"section 3006(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e6f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Cultural Heritage Coordinating Committee established pursuant to section 2 of the Protect and Preserve International Cultural Property Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/151"},"text":"Public Law 114–151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2601"},"text":"19 U.S.C. 2601","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e6f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other relevant Federal agency, committee, or working group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b2e6f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3076/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of Federal Advisory Committee Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act (5 U.S.C. App.) ","children":[{"tag":"ref","attrib":{"idref":"fn002205"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002205"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall not apply to the Native working group convened under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b2e6f3-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/258/s8"},"text":"Pub. L. 117–258, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-21"},"text":"Dec. 21, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2384"},"text":"136 Stat. 2384","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62b2e6f4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62b2e6f5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62b2e6f6-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Pub. L. 92–463","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-06"},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/770"},"text":"86 Stat. 770","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was substantially repealed and restated in chapter 10 (§ 1001 et seq.) of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4197"},"text":"136 Stat. 4197","children":[],"tail":", 4361. For disposition of sections of the Act into chapter 10 of Title 5, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
