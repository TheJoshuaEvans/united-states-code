{"tag":"section","attrib":{"id":"id6285948e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1933"},"text":null,"children":[{"tag":"num","attrib":{"value":"1933"},"text":"§ 1933.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds for on and off reservation programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6285948f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1933/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriated funds for similar programs of Department of Health and Human Services; appropriation in advance for payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the establishment, operation, and funding of Indian child and family service programs, both on and off reservation, the Secretary may enter into agreements with the Secretary of Health and Human Services, and the latter Secretary is hereby authorized for such purposes to use funds appropriated for similar programs of the Department of Health and Human Services: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That authority to make payments pursuant to such agreements shall be effective only to the extent and in such amounts as may be provided in advance by appropriation Acts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62859490-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1933/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation authorization under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds for the purposes of this chapter may be appropriated pursuant to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62859491-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/608/tII/s203"},"text":"Pub. L. 95–608, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-08"},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3076"},"text":"92 Stat. 3076","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62859492-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62859493-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id62859494-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” and “Department of Health and Human Services” substituted for “Secretary of Health, Education, and Welfare” and “Department of Health, Education, and Welfare”, respectively, in subsec. (a) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
