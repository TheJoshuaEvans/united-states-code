{"tag":"section","attrib":{"id":"id627010b5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1663a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1663a"},"text":"§ 1663a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nevada Area Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id627010b6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1663a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", in a manner consistent with the tribal consultation policy of the Service, the Secretary shall submit to Congress a plan describing the manner and schedule by which an area office, separate and distinct from the Phoenix Area Office of the Service, can be established in the State of Nevada."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627010b7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1663a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to submit plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627010b8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1663a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of operations funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “operations funds” means only the funds used for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id627010b9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1663a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administration of services, including functional expenses such as overtime, personnel salaries, and associated benefits; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id627010ba-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1663a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related tasks that directly affect the operations described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627010bb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1663a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary fails to submit a plan in accordance with subsection (a), the Secretary shall withhold the operations funds reserved for the Office of the Director, subject to the condition that the withholding shall not adversely impact the capacity of the Service to deliver health care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627010bc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1663a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The operations funds withheld pursuant to paragraph (2) may be restored, at the discretion of the Secretary, to the Office of the Director on achievement by that Office of compliance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id627010bd-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVI/s604"},"text":"Pub. L. 94–437, title VI, § 604","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id627010be-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id627010bf-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id627010c0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s604"},"text":"Section 604 of Pub. L. 94–437","children":[],"tail":" is based on section 173 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
