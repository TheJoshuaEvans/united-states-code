{"tag":"section","attrib":{"id":"id62a948bd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2714"},"text":null,"children":[{"tag":"num","attrib":{"value":"2714"},"text":"§ 2714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Decisions made by the Commission pursuant to sections 2710, 2711, 2712, and 2713 of this title shall be final agency decisions for purposes of appeal to the appropriate Federal district court pursuant to chapter 7 of title 5.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62a948be-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497/s15"},"text":"Pub. L. 100–497, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2483"},"text":"102 Stat. 2483","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
