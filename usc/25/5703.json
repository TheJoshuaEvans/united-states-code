{"tag":"section","attrib":{"id":"id62f804ef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5703"},"text":null,"children":[{"tag":"num","attrib":{"value":"5703"},"text":"§ 5703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving Tribal access to databases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f804f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal Enrollment Information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall provide training to law enforcement agencies regarding how to record the Tribal enrollment information or affiliation, as appropriate, of a victim in Federal databases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f804f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f804f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-10-10"},"text":"October 10, 2020","children":[],"tail":", the Attorney General, in cooperation with the Secretary of the Interior, shall complete a formal consultation with Indian Tribes on how to further improve Tribal data relevance and access to databases."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f804f3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial confer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-10-10"},"text":"October 10, 2020","children":[],"tail":", the Attorney General, in coordination with the Secretary of the Interior, shall confer with Tribal organizations and urban Indian organizations on how to further improve American Indian and Alaska Native data relevance and access to databases."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f804f4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5703/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f804f5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-10-10"},"text":"October 10, 2020","children":[],"tail":", the Attorney General shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f804f6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement a dissemination strategy to educate the public of the National Missing and Unidentified Persons System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f804f7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct specific outreach to Indian Tribes, Tribal organizations, and urban Indian organizations regarding the ability to publicly enter information, through the National Missing and Unidentified Persons System or other non-law enforcement sensitive portal, regarding missing persons, which may include family members and other known acquaintances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f804f8-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/165/s4"},"text":"Pub. L. 116–165, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-10"},"text":"Oct. 10, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/761"},"text":"134 Stat. 761","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62f804f9-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62f804fa-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62f804fb-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/165/s4"},"text":"section 4 of Pub. L. 116–165","children":[],"tail":". S