{"tag":"section","attrib":{"id":"id62773c77-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1676"},"text":null,"children":[{"tag":"num","attrib":{"value":"1676"},"text":"§ 1676.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of funds appropriated to Indian Health Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62773c78-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1676/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HHS appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any limitation on the use of funds contained in an Act providing appropriations for the Department of Health and Human Services for a period with respect to the performance of abortions shall apply for that period with respect to the performance of abortions using funds contained in an Act providing appropriations for the Indian Health Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62773c79-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1676/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations pursuant to other Federal law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any limitation pursuant to other Federal laws on the use of Federal funds appropriated to the Service shall apply with respect to the performance or coverage of abortions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62773c7a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s806"},"text":"Pub. L. 94–437, title VIII, § 806","children":[],"tail":", formerly title VII, § 706, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/537/s8/b"},"text":"Pub. L. 96–537, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-17"},"text":"Dec. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3179"},"text":"94 Stat. 3179","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tVII/s718"},"text":"Pub. L. 100–713, title VII, § 718","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4837"},"text":"102 Stat. 4837","children":[],"tail":"; renumbered title VIII, § 806, "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s701/a"},"text":"Pub. L. 102–573, title VII, § 701(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4572"},"text":"106 Stat. 4572","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/b/3"},"text":"Pub. L. 111–148, title X, § 10221(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/936"},"text":"124 Stat. 936","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62773c7b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62773c7c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62773c7d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/713"},"text":"Pub. L. 100–713","children":[],"tail":" inserted section catchline and amended text generally. Prior to amendment, text read as follows: “Within one year from "},{"tag":"date","attrib":{"date":"1980-12-17"},"text":"December 17, 1980","children":[],"tail":", the Secretary shall submit to the Congress a resource allocation plan. Such plan shall explain the future allocation of services and funds among the service population of the Service and shall provide a schedule for reducing deficiencies in resources of tribes and nontribal specific entities.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
