{"tag":"section","attrib":{"id":"id62ee68d9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366"},"text":null,"children":[{"tag":"num","attrib":{"value":"5366"},"text":"§ 5366.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions relating to the Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62ee68da-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A funding agreement shall include a provision to monitor the performance of trust functions by the Indian Tribe through the annual trust evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee68db-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reassumption","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee68dc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A compact or funding agreement shall include provisions for the Secretary to reassume a program and associated funding if there is a specific finding relating to that program of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ee68dd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" imminent jeopardy to a trust asset, a natural resource, or public health and safety that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62ee68de-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is caused by an act or omission of the Indian Tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ee68df-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arises out of a failure to carry out the compact or funding agreement; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ee68e0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gross mismanagement with respect to funds transferred to an Indian Tribe under a compact or funding agreement, as determined by the Secretary in consultation with the Inspector General, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee68e1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not reassume operation of a program, in whole or part, unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ee68e2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary first provides written notice and a hearing on the record to the Indian Tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ee68e3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian Tribe does not take corrective action to remedy the mismanagement of the funds or programs, or the imminent jeopardy to a trust asset, natural resource, or public health and safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee68e4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ee68e5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (2), the Secretary may, on written notice to the Indian Tribe, immediately reassume operation of a program if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62ee68e6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary makes a finding of imminent and substantial jeopardy and irreparable harm to a trust asset, a natural resource, or the public health and safety caused by an act or omission of the Indian Tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ee68e7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the imminent and substantial jeopardy and irreparable harm to the trust asset, natural resource, or public health and safety arises out of a failure by the Indian Tribe to carry out the terms of an applicable compact or funding agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ee68e8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reassumption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary reassumes operation of a program under subparagraph (A), the Secretary shall provide the Indian Tribe with a hearing on the record not later than 10 days after the date of reassumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee68e9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inability to agree on compact or funding agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee68ea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final offer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary and a participating Indian Tribe are unable to agree, in whole or in part, on the terms of a compact or funding agreement (including funding levels), the Indian Tribe may submit a final offer to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee68eb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 60 days after the date of receipt of a final offer by one or more of the officials designated pursuant to paragraph (4), the Secretary shall review and make a determination with respect to the final offer, except that the 60-day period may be extended for up to 30 days for circumstances beyond the control of the Secretary, upon written request by the Secretary to the Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee68ec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extensions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The deadline described in paragraph (2) may be extended for any length of time, as agreed upon by both the Indian Tribe and the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee68ed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated officials","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ee68ee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate one or more appropriate officials in the Department to receive a copy of the final offer described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ee68ef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If no official is designated, the Director of the Office of the Executive Secretariat and Regulatory Affairs shall be the designated official.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee68f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No timely determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary fails to make a determination with respect to a final offer within the period specified in paragraph (2), including any extension agreed to under paragraph (3), the Secretary shall be deemed to have agreed to the offer, except that with respect to any compact or funding agreement provision concerning a program described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5363/c"},"text":"section 5363(c) of this title","children":[],"tail":", the Secretary shall be deemed to have rejected the offer with respect to such provision and the terms of clauses (ii) through (iv) of paragraphs "},{"tag":"ref","attrib":{"idref":"fn002272"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002272"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “paragraph”."}],"tail":" (6)(A) shall apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee68f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rejection of final offer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ee68f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary rejects a final offer (or one or more provisions or funding levels in a final offer), the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62ee68f3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide timely written notification to the Indian Tribe that contains a specific finding that clearly demonstrates, or that is supported by a controlling legal authority, that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62ee68f4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/6/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds proposed in the final offer exceeds the applicable funding level as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5325/a/1"},"text":"section 5325(a)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62ee68f5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/6/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program that is the subject of the final offer is an inherent Federal function or is subject to the discretion of the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5363/c"},"text":"section 5363(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62ee68f6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/6/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian Tribe cannot carry out the program in a manner that would not result in significant danger or risk to the public health or safety, to natural resources, or to trust resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62ee68f7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/6/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian Tribe is not eligible to participate in self-governance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5362/c"},"text":"section 5362(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62ee68f8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/6/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding agreement would violate a Federal statute or regulation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62ee68f9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/6/A/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a program or portion of a program included in a final offer pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5363/b/2"},"text":"section 5363(b)(2) of this title","children":[],"tail":", the program or the portion of the program is not otherwise available to Indian Tribes or Indians under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321/a/1/E"},"text":"section 5321(a)(1)(E) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ee68fa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to overcome the objections stated in the notification required by clause (i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ee68fb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the Indian Tribe with a hearing on the record with the right to engage in full discovery relevant to any issue raised in the matter, and the opportunity for appeal on the objections raised, except that the Indian Tribe may, in lieu of filing such appeal, directly proceed to initiate an action in a United States district court under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5331/a"},"text":"section 5331(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ee68fc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the Indian Tribe the option of entering into the severable portions of a final proposed compact or funding agreement (including a lesser funding amount, if any), that the Secretary did not reject, subject to any additional alterations necessary to conform the compact or funding agreement to the severed provisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ee68fd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of exercising certain option","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an Indian Tribe exercises the option specified in subparagraph (A)(iv)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62ee68fe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian Tribe shall retain the right to appeal the rejection by the Secretary under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ee68ff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/c/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clauses (i), (ii), and (iii) of subparagraph (A) shall apply only to the portion of the proposed final compact or funding agreement that was rejected by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee6900-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burden of proof","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any administrative action, hearing, appeal, or civil action brought under this section, the Secretary shall have the burden of proof—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee6901-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of demonstrating, by a preponderance of the evidence, the validity of the grounds for a reassumption under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee6902-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of clearly demonstrating the validity of the grounds for rejecting a final offer made under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee6903-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Good faith","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee6904-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the negotiation of compacts and funding agreements, the Secretary shall at all times negotiate in good faith to maximize implementation of the self-governance policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee6905-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out this subchapter in a manner that maximizes the policy of Tribal self-governance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee6906-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee6907-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that programs carried out for the benefit of Indian Tribes and Tribal organizations under this subchapter reduce the administrative or other responsibilities of the Secretary with respect to the operation of Indian programs and result in savings that have not otherwise been included in the amount of Tribal shares and other funds determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5368/c"},"text":"section 5368(c) of this title","children":[],"tail":", except for funding agreements entered into for programs under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5363/c"},"text":"section 5363(c) of this title","children":[],"tail":", the Secretary shall make such savings available to the Indian Tribes or Tribal organizations for the provision of additional services to program beneficiaries in a manner equitable to directly served, contracted, and compacted programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee6908-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary programs of special significance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any savings generated as a result of the assumption of a program by an Indian Tribe under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5363/c"},"text":"section 5363(c) of this title","children":[],"tail":", such savings shall be made available to that Indian Tribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee6909-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not waive, modify, or diminish in any way the trust responsibility of the United States with respect to Indian Tribes and individual Indians that exists under treaties, Executive orders, other laws, or court decisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee690a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decision maker","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A decision that constitutes final agency action and relates to an appeal within the Department conducted under subsection (c)(6)(A)(iii) may be made by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee690b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an official of the Department who holds a position at a higher organizational level within the Department than the level of the departmental agency in which the decision that is the subject of the appeal was made; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee690c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an administrative law judge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee690d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5366/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to section 101(a) of the PROGRESS for Indian Tribes Act, each provision of this subchapter and each provision of a compact or funding agreement shall be liberally construed for the benefit of the Indian Tribe participating in self-governance, and any ambiguity shall be resolved in favor of the Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62ee690e-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tIV/s406"},"text":"Pub. L. 93–638, title IV, § 406","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/180/tI/s101/e"},"text":"Pub. L. 116–180, title I, § 101(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-21"},"text":"Oct. 21, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/866"},"text":"134 Stat. 866","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ee690f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"referencesInText","id":"id62ee6910-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 101(a) of the PROGRESS for Indian Tribes Act, referred to in subsec. (i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/180/s101/a"},"text":"section 101(a) of Pub. L. 116–180","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5361"},"text":"section 5361 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62ee6911-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62ee6912-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5366, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tIV/s406"},"text":"Pub. L. 93–638, title IV, § 406","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/413/tII/s204"},"text":"Pub. L. 103–413, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4277"},"text":"108 Stat. 4277","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tI/s133"},"text":"Pub. L. 105–277, div. A, § 101(e) [title I, § 133]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–264, set out disclaimers regarding construction of provisions of this chapter and subchapter. Such ection was formerly classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s458ff"},"text":"section 458ff of this title","children":[],"tail":" prior to editorial reclassification and renumbering as section 5366."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
