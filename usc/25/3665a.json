{"tag":"section","attrib":{"id":"id62c38842-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3665a"},"text":"§ 3665a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Tribal Justice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c38843-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", the Attorney General shall establish the Office of Tribal Justice as a component of the Department."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c38844-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel and funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall provide to the Office of Tribal Justice such personnel and funds as are necessary to establish the Office of Tribal Justice as a component of the Department under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c38845-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of Tribal Justice shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c38846-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the program and legal policy advisor to the Attorney General with respect to the treaty and trust relationship between the United States and Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c38847-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the point of contact for federally recognized tribal governments and tribal organizations with respect to questions and comments regarding policies and programs of the Department and issues relating to public safety and justice in Indian country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c38848-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate with other bureaus, agencies, offices, and divisions within the Department of Justice to ensure that each component has an accountable process to ensure meaningful and timely consultation with tribal leaders in the development of regulatory policies and other actions that affect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62c38849-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trust responsibility of the United States to Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c3884a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any tribal treaty provision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c3884b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of Indian tribes as sovereign governments; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c3884c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665a/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other tribal interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c3884d-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/559/tI/s106"},"text":"Pub. L. 106–559, title I, § 106","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s214/a/2/B"},"text":"Pub. L. 111–211, title II, § 214(a)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2270"},"text":"124 Stat. 2270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c3884e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62c3884f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62c38850-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/559/s106"},"text":"section 106 of Pub. L. 106–559","children":[],"tail":" was renumbered section 107 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3666"},"text":"section 3666 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
