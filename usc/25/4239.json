{"tag":"section","attrib":{"id":"id62d42b18-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4239"},"text":null,"children":[{"tag":"num","attrib":{"value":"4239"},"text":"§ 4239.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d42b19-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4239/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, the Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42b1a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4239/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the progress the Department has made during that fiscal year in carrying out the housing plan submitted by the Department under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42b1b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4239/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a report to the Secretary (in a form acceptable to the Secretary) describing the conclusions of the review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42b1c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4239/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under this section for a fiscal year shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42b1d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4239/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the use of grant amounts provided to the Department of Hawaiian Home Lands for that fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42b1e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4239/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the relationship of the use referred to in paragraph (1) to the goals identified in the housing plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42b1f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4239/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicate the programmatic accomplishments of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42b20-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4239/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the manner in which the Department would change its housing plan submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":" as a result of its experiences."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42b21-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4239/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submissions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42b22-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4239/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a date for submission of each report under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42b23-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4239/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review each such report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42b24-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4239/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to each such report, make recommendations as the Secretary considers appropriate to carry out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42b25-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4239/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42b26-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4239/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comments by beneficiaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In preparing a report under this section, the Director shall make the report publicly available to the beneficiaries of the Hawaiian Homes Commission Act, 1920 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/42/108"},"text":"42 Stat. 108","children":[],"tail":" et seq.) and give a sufficient amount of time to permit those beneficiaries to comment on that report before it is submitted to the Secretary (in such manner and at such time as the Director may determine)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42b27-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4239/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summary of comments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report shall include a summary of any comments received by the Director from beneficiaries under paragraph (1) regarding the program to carry out the housing plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d42b28-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s820"},"text":"Pub. L. 104–330, title VIII, § 820","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s203"},"text":"Pub. L. 106–568, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2893"},"text":"114 Stat. 2893","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s513"},"text":"Pub. L. 106–569, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2987"},"text":"114 Stat. 2987","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d42b29-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d42b2a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62d42b2b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Hawaiian Homes Commission Act, 1920, referred to in subsec. (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-07-09/ch42"},"text":"act July 9, 1921, ch. 42","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/108"},"text":"42 Stat. 108","children":[],"tail":", which was classified generally to sections 691 to 718 of Title 48, Territories and Insular Possessions, and was omitted from the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62d42b2c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s203"},"text":"Pub. L. 106–568, § 203","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":", enacted identical sections 820 of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":". This section is based on the text of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s820"},"text":"section 820 of Pub. L. 104–330","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
