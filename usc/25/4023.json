{"tag":"section","attrib":{"id":"id62c843ad-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4023"},"text":null,"children":[{"tag":"num","attrib":{"value":"4023"},"text":"§ 4023.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judgment funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c843ae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4023/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to approve plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4022"},"text":"section 4022 of this title","children":[],"tail":" for the withdrawal of judgment funds held by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c843af-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4023/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Only such funds held by the Secretary under the terms of the Indian Judgment Funds Use or Distribution Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1401"},"text":"25 U.S.C. 1401","children":[],"tail":" et seq.] or an Act of Congress which provides for the secretarial management of such judgment funds shall be included in such plans."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c843b0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4023/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In approving such plans, the Secretary shall ensure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c843b1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4023/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the purpose and use of the judgment funds identified in the previously approved judgment fund plan will continue to be followed by the Indian tribe in the management of the judgment funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c843b2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4023/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that only funds held for Indian tribes may be withdrawn and that any funds held for individual tribal members are not to be included in the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c843b3-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/412/tII/s203"},"text":"Pub. L. 103–412, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4242"},"text":"108 Stat. 4242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c843b4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62c843b5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62c843b6-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Judgment Funds Use or Distribution Act, referred to in subsec. (b), probably means the Indian Tribal Judgment Funds Use or Distribution Act, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/134"},"text":"Pub. L. 93–134","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-19"},"text":"Oct. 19, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/466"},"text":"87 Stat. 466","children":[],"tail":", which is classified generally to chapter 16 (§ 1401 et seq.) of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
