{"tag":"section","attrib":{"id":"id6261b84f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1621a"},"text":"§ 1621a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Catastrophic Health Emergency Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6261b850-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established an Indian Catastrophic Health Emergency Fund (hereafter in this section referred to as the “CHEF”) consisting of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6261b851-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts deposited under subsection (f); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6261b852-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts appropriated to CHEF under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6261b853-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"CHEF shall be administered by the Secretary, acting through the headquarters of the Service, solely for the purpose of meeting the extraordinary medical costs associated with the treatment of victims of disasters or catastrophic illnesses who are within the responsibility of the Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6261b854-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions on use of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No part of CHEF or its administration shall be subject to contract or grant under any law, including the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.),"},{"tag":"ref","attrib":{"idref":"fn002043"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002043"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" nor shall CHEF funds be allocated, apportioned, or delegated on an Area Office, Service Unit, or other similar basis."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6261b855-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall promulgate regulations consistent with the provisions of this section to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6261b856-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a definition of disasters and catastrophic illnesses for which the cost of the treatment provided under contract would qualify for payment from CHEF;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6261b857-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide that a Service Unit shall not be eligible for reimbursement for the cost of treatment from CHEF until its cost of treating any victim of such catastrophic illness or disaster has reached a certain threshold cost which the Secretary shall establish at—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6261b858-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2000 level of $19,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6261b859-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any subsequent year, not less than the threshold cost of the previous year increased by the percentage increase in the medical care expenditure category of the consumer price index for all urban consumers (United States city average) for the 12-month period ending with December of the previous year;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6261b85a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a procedure for the reimbursement of the portion of the costs that exceeds such threshold cost incurred by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6261b85b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Service Units; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6261b85c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whenever otherwise authorized by the Service, non-Service facilities or providers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6261b85d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a procedure for payment from CHEF in cases in which the exigencies of the medical circumstances warrant treatment prior to the authorization of such treatment by the Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6261b85e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a procedure that will ensure that no payment shall be made from CHEF to any provider of treatment to the extent that such provider is eligible to receive payment for the treatment from any other Federal, State, local, or private source of reimbursement for which the patient is eligible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6261b85f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No offset or limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated to CHEF under this section shall not be used to offset or limit appropriations made to the Service under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":", or any other law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6261b860-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of reimbursement funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be deposited into CHEF all reimbursements to which the Service is entitled from any Federal, State, local, or private source (including third party insurance) by reason of treatment rendered to any victim of a disaster or catastrophic illness the cost of which was paid from CHEF.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6261b861-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tII/s202"},"text":"Pub. L. 94–437, title II, § 202","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tII/s202"},"text":"Pub. L. 100–713, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4803"},"text":"102 Stat. 4803","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tII"},"text":"Pub. L. 102–573, title II","children":[],"tail":", §§ 202(a), 217(b)(2), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4546"},"text":"106 Stat. 4546","children":[],"tail":", 4559; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6261b862-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6261b863-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6261b864-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.), referred to in subsec. (c), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of this title prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6261b865-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" is based on section 122 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6261b866-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" amended section generally. Prior to amendment, section related to establishment of Indian Catastrophic Health Emergency Fund with provisions for its administration, promulgation of regulations, procedures for payment, effect of appropriated funds on other appropriations, and deposit of reimbursements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s202/a/1"},"text":"Pub. L. 102–573, § 202(a)(1)","children":[],"tail":", substituted “to the Fund under this section” for “under subsection (e) of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s202/a/2"},"text":"Pub. L. 102–573, § 202(a)(2)","children":[],"tail":", substituted “shall establish at—” and subpars. (A) and (B) for “shall establish at not less than $10,000 or not more than $20,000;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s202/a/3"},"text":"Pub. L. 102–573, § 202(a)(3)","children":[],"tail":", substituted “Amounts appropriated to the Fund under this section” for “Funds appropriated under subsection (e) of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s217/b/2"},"text":"Pub. L. 102–573, § 217(b)(2)","children":[],"tail":", struck out subsec. (e) which authorized appropriations for fiscal years 1989 to 1992."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6261b867-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6261b868-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/tII/s202/b"},"text":"Pub. L. 102–573, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4546"},"text":"106 Stat. 4546","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/573/tII/s202/b"},"text":"“The amendment made by subsection (a)(2) [amending this section] shall take effect ","children":[{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
