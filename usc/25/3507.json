{"tag":"section","attrib":{"id":"id62c1176c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3507"},"text":null,"children":[{"tag":"num","attrib":{"value":"3507"},"text":"§ 3507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appraisals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c1176d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any transaction that requires approval of the Secretary and involves mineral or energy resources held in trust by the United States for the benefit of an Indian tribe or by an Indian tribe subject to Federal restrictions against alienation, any appraisal relating to fair market value of those resources required to be prepared under applicable law may be prepared by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c1176e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3507/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c1176f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3507/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the affected Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11770-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3507/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certified, third-party appraiser pursuant to a contract with the Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c11771-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial review and approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 45 days after the date on which the Secretary receives an appraisal prepared by or for an Indian tribe under paragraph (2) or (3) of subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c11772-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3507/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the appraisal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11773-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3507/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve the appraisal unless the Secretary determines that the appraisal fails to meet the standards set forth in regulations promulgated under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c11774-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3507/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of disapproval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that an appraisal submitted for approval under subsection (b) should be disapproved, the Secretary shall give written notice of the disapproval to the Indian tribe and a description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c11775-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3507/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each reason for the disapproval; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11776-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3507/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the appraisal should be corrected or otherwise cured to meet the applicable standards set forth in the regulations promulgated under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c11777-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3507/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations to carry out this section, including standards the Secretary shall use for approving or disapproving the appraisal described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c11778-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXVI/s2607"},"text":"Pub. L. 102–486, title XXVI, § 2607","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/325/tII/s204/a"},"text":"Pub. L. 115–325, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-18"},"text":"Dec. 18, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4463"},"text":"132 Stat. 4463","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
