{"tag":"section","attrib":{"id":"id629d6239-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413"},"text":null,"children":[{"tag":"num","attrib":{"value":"2413"},"text":"§ 2413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Departmental responsibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id629d623a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior, acting through the Bureau of Indian Affairs, the Attorney General, and the Secretary of Health and Human Services, acting through the Indian Health Service, shall bear equal responsibility for the implementation of this chapter in cooperation with Indian tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629d623b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Alcohol and Substance Abuse","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629d623c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id629d623d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To improve coordination among the Federal agencies and departments carrying out this chapter, there is established within the Substance Abuse and Mental Health Services Administration an office, to be known as the “Office of Indian Alcohol and Substance Abuse” (referred to in this section as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629d623e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The director of the Office shall be appointed by the Administrator of the Substance Abuse and Mental Health Services Administration—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id629d623f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a permanent basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id629d6240-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a grade of not less than GS–15 of the General Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d6241-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of Office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to other responsibilities which may be assigned to such Office, it shall be responsible for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id629d6242-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating with other agencies to monitor the performance and compliance of the relevant Federal programs in achieving the goals and purposes of this chapter and the Memorandum of Agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2411"},"text":"section 2411 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629d6243-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving as a point of contact for Indian tribes and the Tribal Coordinating Committees regarding the implementation of this chapter, the Memorandum of Agreement, and any Tribal Action Plan established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2412"},"text":"section 2412 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629d6244-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", developing, in coordination and consultation with tribal governments, a framework for interagency and tribal coordination that—"}],"tail":null},{"tag":"clause","attrib":{"id":"id629d6245-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish ","children":[{"tag":"ref","attrib":{"idref":"fn002152"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002152"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “establishes”."}],"tail":" the goals and other desired outcomes of this Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id629d6246-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritizes outcomes that are aligned with the purposes of affected agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id629d6247-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides guidelines for resource and information sharing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id629d6248-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides technical assistance to the affected agencies to establish effective and permanent interagency communication and coordination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id629d6249-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/b/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines whether collaboration is feasible, cost-effective, and within agency capability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d624a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Substance Abuse and Mental Health Services Administration shall appoint such employees to work in the Office, and shall provide such funding, services, and equipment, as may be necessary to enable the Office to carry out the responsibilities under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629d624b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Youth Programs Officer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629d624c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established in the Office the position to be known as the Indian Youth Programs Officer. The Administrator of the Substance Abuse and Mental Health Services Administration shall appoint the Indian Youth Programs Officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d624d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The position of Indian Youth Programs Officer shall be established on a permanent basis at no less than the grade of GS–14 of the General Schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d624e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to other responsibilities which may be assigned to the Indian Youth Programs Officer relating to Indian youth such Officer shall be responsible for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id629d624f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring the performance and compliance of the applicable Federal programs in meeting the goals and purposes of this chapter and the Memorandum of Agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2411"},"text":"section 2411 of this title","children":[],"tail":" as they relate to Indian youth efforts, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629d6250-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2413/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing advice and recommendations, including recommendations submitted by Indian tribes and Tribal Coordinating Committees, to the Director of the Office as they relate to Indian youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629d6251-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4207"},"text":"Pub. L. 99–570, title IV, § 4207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-141"},"text":"100 Stat. 3207–141","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2216"},"text":"Pub. L. 100–690, title II, § 2216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4221"},"text":"102 Stat. 4221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s703/2"},"text":"Pub. L. 102–573, title VII, § 703(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4583"},"text":"106 Stat. 4583","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s241/a/3"},"text":"Pub. L. 111–211, title II, § 241(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2288"},"text":"124 Stat. 2288","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id629d6252-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id629d6253-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id629d6254-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsecs. (b)(1)(B)(ii) and (c)(2), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b)(2)(C)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570"},"text":"Pub. L. 99–570","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207"},"text":"100 Stat. 3207","children":[],"tail":", known as the Anti-Drug Abuse Act of 1986. For complete classification of this Act to the Code, see Short Title of 1986 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of Title 21","children":[],"tail":", Food and Drugs, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id629d6255-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/3/A"},"text":"Pub. L. 111–211, § 241(a)(3)(A)","children":[],"tail":", inserted “, the Attorney General” after “Bureau of Indian Affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/3/B/i"},"text":"Pub. L. 111–211, § 241(a)(3)(B)(i)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “In order to better coordinate the various programs of the Bureau of Indian Affairs in carrying out this chapter, there is established within the Office of the Assistant Secretary of the Interior for Indian Affairs an Office of Alcohol and Substance Abuse. The director of such office shall be appointed by the Assistant Secretary of the Interior for Indian Affairs on a permanent basis at no less than a grade GS–15 of the General Schedule.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/3/B/ii/I"},"text":"Pub. L. 111–211, § 241(a)(3)(B)(ii)(I)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/3/B/ii/II"},"text":"Pub. L. 111–211, § 241(a)(3)(B)(ii)(II)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A) which read as follows: “monitoring the performance and compliance of programs of the Bureau of Indian Affairs in meeting the goals and purposes of this chapter and the Memorandum of Agreement entered into under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2411"},"text":"section 2411 of this title","children":[],"tail":", and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/3/B/ii/III/aa"},"text":"Pub. L. 111–211, § 241(a)(3)(B)(ii)(III)(aa)","children":[],"tail":", struck out “within the Bureau of Indian Affairs” after “point of contact”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/3/B/ii/III/bb"},"text":"Pub. L. 111–211, § 241(a)(3)(B)(ii)(III)(bb)","children":[],"tail":", (IV), added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/3/B/iii"},"text":"Pub. L. 111–211, § 241(a)(3)(B)(iii)","children":[],"tail":", added par. (3) and struck out former par. (3) which read as follows: “The Assistant Secretary of the Interior for Indian Affairs shall appoint such employees to work in the Office of Alcohol and Substance Abuse, and shall provide such funding, services, and equipment as may be necessary to enable the Office of Alcohol and Substance Abuse to carry out its responsibilities.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/3/C/i"},"text":"Pub. L. 111–211, § 241(a)(3)(C)(i)","children":[],"tail":", (ii), struck out “of Alcohol and Substance Abuse” after “Office” and substituted “The Administrator of the Substance Abuse and Mental Health Services Administration” for “The Assistant Secretary of the Interior for Indian Affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/3/C/iii/I"},"text":"Pub. L. 111–211, § 241(a)(3)(C)(iii)(I)","children":[],"tail":", which directed substitution of “youth” for “Youth” in introductory provisions, was executed by making the substitution for “Youth” the second time appearing, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/3/C/iii/II"},"text":"Pub. L. 111–211, § 241(a)(3)(C)(iii)(II)","children":[],"tail":", substituted “the applicable Federal programs” for “programs of the Bureau of Indian Affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/3/C/i"},"text":"Pub. L. 111–211, § 241(a)(3)(C)(i)","children":[],"tail":", struck out “of Alcohol and Substance Abuse” after “Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573"},"text":"Pub. L. 102–573","children":[],"tail":" amended par. (3) generally. Prior to amendment, par. (3) read as follows: “The Assistant Secretary of the Interior for Indian Affairs shall appoint such employees to work in the Office of Alcohol and Substance Abuse, and shall provide such services and equipment, as may be necessary to enable the Office of Alcohol and Substance Abuse to carry out its responsibilities.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2216/1"},"text":"Pub. L. 100–690, § 2216(1)","children":[],"tail":", (2), substituted “Assistant Secretary of the Interior for” for “Assistant Secretary of” and “Assistant Secretary of the Interior for Indian Affairs on” for “Assistant Secretary on”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2216/3"},"text":"Pub. L. 100–690, § 2216(3)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2216/4"},"text":"Pub. L. 100–690, § 2216(4)","children":[],"tail":", inserted at end “The Assistant Secretary of the Interior for Indian Affairs shall appoint the Indian Youth Programs Officer.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
