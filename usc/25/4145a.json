{"tag":"section","attrib":{"id":"id62cf6ef3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4145a"},"text":"§ 4145a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62cf6ef4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of qualifying Indian tribe","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “qualifying Indian tribe” means, with respect to a fiscal year, an Indian tribe or tribally designated housing entity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cf6ef5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to or on behalf of which a grant is made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4111"},"text":"section 4111 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6ef6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has complied with the requirements of section 4112(b)(6) ","children":[{"tag":"ref","attrib":{"idref":"fn002237"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002237"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4112/b"},"text":"Section 4112(b) of this title","children":[],"tail":" does not contain a par. (6)."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6ef7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that, during the preceding 3-fiscal-year period, has no unresolved significant and material audit findings or exceptions, as demonstrated in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cf6ef8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual audits of that period completed under chapter 75 of title 31 (commonly known as the “Single Audit Act”); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cf6ef9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an independent financial audit prepared in accordance with generally accepted auditing principles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cf6efa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under the program under this part, for each of fiscal years 2009 through 2013, the recipient for each qualifying Indian tribe may use the amounts specified in subsection (c) in accordance with this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cf6efb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a fiscal year and a recipient, the amounts referred to in subsection (b) are amounts from any grant provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4111"},"text":"section 4111 of this title","children":[],"tail":" to the recipient for the fiscal year, as determined by the recipient, but in no case exceeding the lesser of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cf6efc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 20 percent of the total grant amount for the recipient for that fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6efd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62cf6efe-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tII/s232"},"text":"Pub. L. 104–330, title II, § 232","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/411/tII/s206/a/2"},"text":"Pub. L. 110–411, title II, § 206(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4326"},"text":"122 Stat. 4326","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
