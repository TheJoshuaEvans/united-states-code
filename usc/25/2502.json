{"tag":"section","attrib":{"id":"id62a21d21-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502"},"text":null,"children":[{"tag":"num","attrib":{"value":"2502"},"text":"§ 2502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62a21d22-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a21d23-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide grants to Indian tribes, and tribal organizations that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21d24-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate contract schools under title XI of the Education Amendments of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2000"},"text":"25 U.S.C. 2000","children":[],"tail":" et seq.] and notify the Secretary of their election to operate the schools with assistance under this chapter rather than continuing the schools as contract schools;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d25-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate other tribally controlled schools eligible for assistance under this chapter and submit applications (which are approved by their tribal governing bodies) to the Secretary for such grants; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d26-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elect to assume operation of Bureau-funded schools with the assistance under this chapter and submit applications (which are approved by their tribal governing bodies) to the Secretary for such grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21d27-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants provided under this chapter shall be deposited into the general operating fund of the tribally controlled school with respect to which the grant is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21d28-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21d29-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this paragraph, grants provided under this chapter shall be used to defray, at the discretion of the school board of the tribally controlled school with respect to which the grant is provided, any expenditures for education related activities for which any funds that compose the grant may be used under the laws described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2504/a"},"text":"section 2504(a) of this title","children":[],"tail":", including expenditures for—"}],"tail":null},{"tag":"clause","attrib":{"id":"id62a21d2a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" school operations, academic, educational, residential, guidance and counseling, and administrative purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21d2b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support services for the school, including transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d2c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants provided under this chapter may, at the discretion of the school board of the tribally controlled school with respect to which such grant is provided, be used to defray operations and maintenance expenditures for the school if any funds for the operation and maintenance of the school are allocated to the school under the provisions of any of the laws described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2504/a"},"text":"section 2504(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a21d2d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a21d2e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" One grant per tribe or organization per fiscal year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than one grant may be provided under this chapter with respect to any Indian tribe or tribal organization for any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21d2f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonsectarian use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided under any grant made under this chapter may not be used in connection with religious worship or sectarian instruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21d30-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided under any grant under this chapter may not be expended for administrative costs (as defined in section 1128(h)(1) of the Education Amendments of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2008/h/1"},"text":"25 U.S.C. 2008(h)(1)","children":[],"tail":"]) in excess of the amount generated for such costs under section 1128 of such Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a21d31-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on transfer of funds among school sites","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a21d32-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a grantee that operates schools at more than one school site, the grantee may expend at any school site operated by the grantee not more than the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21d33-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent of the funds allocated for another school site under section 1128 of the Education Amendments of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2008"},"text":"25 U.S.C. 2008","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d34-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $400,000 of the funds allocated for another school site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21d35-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of school site","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “school site” means the physical location and the facilities of an elementary or secondary educational or residential program operated by, or under contract or grant with, the Bureau for which a discreet ","children":[{"tag":"ref","attrib":{"idref":"fn002163"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002163"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “discrete”."}],"tail":" student count is identified under the funding formula established under section 1127 of the Education Amendments of 1978 ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2007"},"text":"25 U.S.C. 2007","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a21d36-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No requirement to accept grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter may be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a21d37-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require a tribe or tribal organization to apply for or accept; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21d38-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow any person to coerce any tribe or tribal organization to apply for, or accept,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"a grant under this chapter to plan, conduct, and administer all of, or any portion of, any Bureau program. Such applications and the timing of such applications shall be strictly voluntary. Nothing in this chapter may be construed as allowing or requiring any grant with any entity other than the entity to which the grant is provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a21d39-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on Federal responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants provided under this chapter shall not terminate, modify, suspend, or reduce the responsibility of the Federal Government to provide a program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a21d3a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retrocession","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a21d3b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever a tribal governing body requests retrocession of any program for which assistance is provided under this chapter, such retrocession shall become effective upon a date specified by the Secretary that is not later than 120 days after the date on which the tribal governing body requests the retrocession. A later date may be specified if mutually agreed upon by the Secretary and the tribal governing body. If such a program is retroceded, the Secretary shall provide to any Indian tribe served by such program at least the same quantity and quality of services that would have been provided under such program at the level of funding provided under this chapter prior to the retrocession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21d3c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status after retrocession","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tribe requesting retrocession shall specify whether the retrocession is to status as a Bureau-operated school or as a school operated under contract under the Indian Self-Determination and Education Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21d3d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of equipment and materials","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise determined by the Secretary, the tribe or tribal organization operating the program to be retroceded must transfer to the Secretary (or to the tribe or tribal organization which will operate the program as a contract school) the existing equipment and materials which were acquired—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21d3e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with assistance under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d3f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon assumption of operation of the program under this chapter, if the school was a Bureau-funded school under title XI of the Education Amendments of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2000"},"text":"25 U.S.C. 2000","children":[],"tail":" et seq.] before receiving assistance under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a21d40-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2502/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of termination for administrative convenience","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants provided under this chapter may not be terminated, modified, suspended, or reduced solely for the convenience of the administering agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62a21d41-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5203"},"text":"Pub. L. 100–297, title V, § 5203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1043"},"text":"Pub. L. 107–110, title X, § 1043","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2064"},"text":"115 Stat. 2064","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62a21d42-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62a21d43-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62a21d44-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Education Amendments of 1978, referred to in subsecs. (a)(1)(A) and (f)(3)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561"},"text":"Pub. L. 95–561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2143"},"text":"92 Stat. 2143","children":[],"tail":". Title XI of the Act is classified principally to chapter 22 (§ 2000 et seq.) of this title. For complete classification of this Act to the Code, see Short Title of 1978 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education, and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in subsec. (f)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which is classified principally to chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62a21d45-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2502, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5203"},"text":"Pub. L. 100–297, title V, § 5203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/385"},"text":"102 Stat. 385","children":[],"tail":", set forth declaration of policy, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1043"},"text":"Pub. L. 107–110, title X, § 1043","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2063"},"text":"115 Stat. 2063","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2501"},"text":"section 2501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62a21d46-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id62a21d47-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
