{"tag":"section","attrib":{"id":"id62cd25b9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4135"},"text":null,"children":[{"tag":"num","attrib":{"value":"4135"},"text":"§ 4135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income requirement and income targeting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62cd25ba-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4135/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Housing shall qualify as affordable housing for purposes of this chapter only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cd25bb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4135/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each dwelling unit in the housing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cd25bc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4135/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of rental housing, is made available for occupancy only by a family that is a low-income family at the time of their initial occupancy of such unit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cd25bd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4135/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a contract to purchase existing housing, is made available for purchase only by a family that is a low-income family at the time of purchase;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cd25be-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4135/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a lease-purchase agreement for existing housing or for housing to be constructed, is made available for lease-purchase only by a family that is a low-income family at the time the agreement is entered into; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cd25bf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4135/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a contract to purchase housing to be constructed, is made available for purchase only by a family that is a low-income family at the time the contract is entered into; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cd25c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4135/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except for housing assisted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437bb"},"text":"section 1437bb of title 42","children":[],"tail":" (as in effect before the date of the effectiveness of this chapter), each dwelling unit in the housing will remain affordable, according to binding commitments satisfactory to the Secretary, for the remaining useful life of the property (as determined by the Secretary) without regard to the term of the mortgage or to transfer of ownership, or for such other period that the Secretary determines is the longest feasible period of time consistent with sound economics and the purposes of this chapter, except upon a foreclosure by a lender (or upon other transfer in lieu of foreclosure) if such action—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cd25c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4135/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognizes any contractual or legal rights of public agencies, nonprofit sponsors, or others to take actions that would avoid termination of low-income affordability in the case of foreclosure or transfer in lieu of foreclosure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cd25c2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4135/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not for the purpose of avoiding low-income affordability restrictions, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cd25c3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4135/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a), housing assisted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4131/b/2"},"text":"section 4131(b)(2) of this title","children":[],"tail":" shall be considered affordable housing for purposes of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cd25c4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4135/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of paragraph (2) of subsection (a) regarding binding commitments for the remaining useful life of property shall not apply to a family or household member who subsequently takes ownership of a homeownership unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62cd25c5-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tII/s205"},"text":"Pub. L. 104–330, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4033"},"text":"110 Stat. 4033","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s595/e/8"},"text":"Pub. L. 105–276, title V, § 595(e)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2657"},"text":"112 Stat. 2657","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/411/tII/s204"},"text":"Pub. L. 110–411, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4326"},"text":"122 Stat. 4326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62cd25c6-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62cd25c7-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62cd25c8-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", known as the Native American Housing Assistance and Self-Determination Act of 1996. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437bb"},"text":"Section 1437bb of title 42","children":[],"tail":", referred to in subsec. (a)(2), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/tV/s501/a"},"text":"Pub. L. 104–330, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4041"},"text":"110 Stat. 4041","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For the date of the effectiveness of this chapter, referred to in subsec. (a)(2), as ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s107"},"text":"section 107 of Pub. L. 104–330","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62cd25c9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/411"},"text":"Pub. L. 110–411","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1)(B) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276"},"text":"Pub. L. 105–276","children":[],"tail":" added subpars. (B) to (D) and struck out former subpar. (B) which read as follows: “in the case of housing for homeownership, is made available for purchase only by a family that is a low-income family at the time of purchase; and”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62cd25ca-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id62cd25cb-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s107"},"text":"section 107 of Pub. L. 104–330","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
