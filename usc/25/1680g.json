{"tag":"section","attrib":{"id":"id6279ad14-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1680g"},"text":"§ 1680g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocation of base resources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6279ad15-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, any allocation of Service funds for a fiscal year that reduces by 5 percent or more from the previous fiscal year the funding for any recurring program, project, or activity of a service unit may be implemented only after the Secretary has submitted to the President, for inclusion in the report required to be transmitted to the Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1671"},"text":"section 1671 of this title","children":[],"tail":", a report on the proposed change in allocation of funding, including the reasons for the change and its likely effects."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6279ad16-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriated amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply if the total amount appropriated to the Service for a fiscal year is less than the amount appropriated to the Service for previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6279ad17-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s817"},"text":"Pub. L. 94–437, title VIII, § 817","children":[],"tail":", formerly title VII, § 717, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tVII/s711"},"text":"Pub. L. 100–713, title VII, § 711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4833"},"text":"102 Stat. 4833","children":[],"tail":"; renumbered title VIII, § 817, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s701/a"},"text":"Pub. L. 102–573, title VII, § 701(a)","children":[],"tail":", (b), title VIII, § 805, "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4572"},"text":"106 Stat. 4572","children":[],"tail":", 4585.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6279ad18-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6279ad19-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6279ad1a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s805"},"text":"Pub. L. 102–573, § 805","children":[],"tail":", substituted “Secretary has submitted to the President, for inclusion in the report required to be transmitted to the Congress under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1671"},"text":"section 1671 of this title","children":[],"tail":",” for “Secretary has submitted to the Congress”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
