{"tag":"section","attrib":{"id":"id6223c5a0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s318"},"text":null,"children":[{"tag":"num","attrib":{"value":"318"},"text":"§ 318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment or repeal of sections","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Congress reserves the right at any time to alter, amend, or repeal sections 312 to 318 of this title or any portion thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6223c5a1-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1899-03-02/ch374/s8"},"text":"Mar. 2, 1899, ch. 374, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/992"},"text":"30 Stat. 992","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
