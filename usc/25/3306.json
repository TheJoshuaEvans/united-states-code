{"tag":"section","attrib":{"id":"id62ba12a8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3306"},"text":null,"children":[{"tag":"num","attrib":{"value":"3306"},"text":"§ 3306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on use of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62ba12a9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use for religious purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds made available under this subchapter may be used for study at any school or department of divinity or for any religious worship or sectarian activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ba12aa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest on funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No interest or other income on any funds made available under this subchapter shall be used for any purpose other than those for which such funds may be used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ba12ab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ba12ac-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3306/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this subsection, the Secretary shall make payments to grantees under this subchapter in two payments—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ba12ad-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3306/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one payment to be made no later than October 1 of each fiscal year in an amount equal to one-half the amount paid during the preceding fiscal year to the grantee or a contractor that has elected to have the provisions of this subchapter apply, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba12ae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3306/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the second payment consisting of the remainder to which the grantee or contractor is entitled for the fiscal year to be made by no later than January 1 of the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ba12af-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3306/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New grantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any tribe for which no payment was made under this subchapter in the preceding fiscal year, full payment of the amount computed for each fiscal year shall be made by January 1 of the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ba12b0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ba12b1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3306/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as tribal property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, any interest or investment income that accrues on any funds provided under this subchapter after such funds are paid to the Indian tribe or tribal organization and before such funds are expended for the purpose for which such funds were provided under this subchapter shall be the property of the Indian tribe or tribal organization and shall not be taken into account by any officer or employee of the Federal Government in determining whether to provide assistance, or the amount of assistance, under any provision of Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ba12b2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3306/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds provided under this subchapter may be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ba12b3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3306/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invested by the Indian tribe or tribal organization only in obligations of the United States or in obligations or securities that are guaranteed or insured by the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba12b4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3306/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposited only into accounts that are insured by an agency or instrumentality of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ba12b5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3306/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recoveries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of under recovery and over recovery determinations by any Federal agency for any other funds, from whatever source derived, funds received under this subchapter shall not be taken into consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62ba12b6-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/tXIII/s1316"},"text":"Pub. L. 102–325, title XIII, § 1316","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/801"},"text":"106 Stat. 801","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
