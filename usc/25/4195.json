{"tag":"section","attrib":{"id":"id62d1e02b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4195"},"text":null,"children":[{"tag":"num","attrib":{"value":"4195"},"text":"§ 4195.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on amount of guarantees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d1e02c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4195/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate fiscal year limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law and subject only to the absence of qualified applicants or proposed activities and to the authority provided in this subchapter, to the extent approved or provided in appropriations Acts, the Secretary may enter into commitments to guarantee notes and obligations under this subchapter with an aggregate principal amount not to exceed $400,000,000 for each of fiscal years 2009 through 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e02d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4195/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for credit subsidy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to cover the costs (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a"},"text":"section 661a of title 2","children":[],"tail":") of guarantees under this subchapter such sums as may be necessary for each of fiscal years 2009 through 2013."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e02e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4195/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate outstanding limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of outstanding obligations guaranteed on a cumulative basis by the Secretary pursuant to this subchapter shall not at any time exceed $2,000,000,000 or such higher amount as may be authorized to be appropriated for this subchapter for any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e02f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4195/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year limitations on tribes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall monitor the use of guarantees under this subchapter by Indian tribes. If the Secretary finds that 50 percent of the aggregate guarantee authority under subsection (c) has been committed, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d1e030-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4195/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose limitations on the amount of guarantees any one Indian tribe may receive in any fiscal year of $50,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e031-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4195/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request the enactment of legislation increasing the aggregate outstanding limitation on guarantees under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d1e032-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVI/s605"},"text":"Pub. L. 104–330, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4047"},"text":"110 Stat. 4047","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/292/s2/b"},"text":"Pub. L. 107–292, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-13"},"text":"Nov. 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2053"},"text":"116 Stat. 2053","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/411/tVII/s701/b"},"text":"Pub. L. 110–411, title VII, § 701(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4334"},"text":"122 Stat. 4334","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d1e033-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d1e034-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62d1e035-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/411"},"text":"Pub. L. 110–411","children":[],"tail":" substituted “2009 through 2013” for “1997 through 2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/292"},"text":"Pub. L. 107–292","children":[],"tail":" substituted “1997 through 2007” for “1997, 1998, 1999, 2000, and 2001”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62d1e036-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id62d1e037-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s606"},"text":"section 606 of Pub. L. 104–330","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4191"},"text":"section 4191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
