{"tag":"section","attrib":{"id":"id62b7a141-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201"},"text":null,"children":[{"tag":"num","attrib":{"value":"3201"},"text":"§ 3201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b7a142-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress, after careful review of the problem of child abuse on Indian reservations and the historical and special relationship of the Federal Government with Indian people,","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b7a143-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" finds that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b7a144-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incidents of abuse of children on Indian reservations are grossly underreported;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a145-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such underreporting is often a result of the lack of a mandatory Federal reporting law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a146-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiple incidents of sexual abuse of children on Indian reservations have been perpetrated by persons employed or funded by the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a147-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal Government investigations of the background of Federal employees who care for, or teach, Indian children are often deficient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a148-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds spent by the United States on Indian reservations or otherwise spent for the benefit of Indians who are victims of child abuse or family violence are inadequate to meet the growing needs for mental health treatment and counseling for victims of child abuse or family violence and their families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a149-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is no resource that is more vital to the continued existence and integrity of Indian tribes than their children and the United States has a direct interest, as trustee, in protecting Indian children who are members of, or are eligible for membership in, an Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a14a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" declares that two major goals of the United States are to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b7a14b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the scope of incidents of abuse of children and family violence in Indian country and to reduce such incidents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a14c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide funds for mental health treatment for Indian victims of child abuse and family violence on Indian reservations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a14d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b7a14e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that reports of abused Indian children are made to the appropriate authorities in an effort to prevent further abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a14f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a reliable data base for statistical purposes and to authorize a study to determine the need for a central registry for reported incidents of abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a150-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize such other actions as are necessary to ensure effective child protection in Indian country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a151-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the Indian Child Abuse Prevention and Treatment Grant Program to provide funds for the establishment on Indian reservations of treatment programs for victims of child sexual abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a152-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for technical assistance and training related to the investigation and treatment of cases of child abuse and neglect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a153-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish Indian Child Resource and Family Services Centers in each Bureau of Indian Affairs Area Office which will consist of multi-disciplinary teams of personnel with experience and training in the prevention, identification, investigation, and treatment of child abuse and neglect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a154-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the treatment and prevention of incidents of family violence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a155-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish tribally operated programs to protect Indian children and reduce the incidents of family violence in Indian country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a156-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3201/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize other actions necessary to ensure effective child protection on Indian reservations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b7a157-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIV/s402"},"text":"Pub. L. 101–630, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4544"},"text":"104 Stat. 4544","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62b7a158-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62b7a159-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62b7a15a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this title”, meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630"},"text":"Pub. L. 101–630","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4544"},"text":"104 Stat. 4544","children":[],"tail":", known as the Indian Child Protection and Family Violence Prevention Act, which is classified principally to this chapter. For complete classification of title IV to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62b7a15b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id62b7a15c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s1"},"text":"Pub. L. 118–160, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2567"},"text":"138 Stat. 2567","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/160/s1"},"text":"“This Act [amending sections 3202, 3208, 3209, and 3210 of this title] may be cited as the ‘Native American Child Protection Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id62b7a15d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/165/s1"},"text":"Pub. L. 114–165, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-03"},"text":"June 3, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/415"},"text":"130 Stat. 415","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/165/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3207"},"text":"section 3207 of this title","children":[],"tail":"] may be cited as the ‘Native American Children’s Safety Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id62b7a15e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIV/s401"},"text":"Pub. L. 101–630, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4544"},"text":"104 Stat. 4544","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/630/tIV/s401"},"text":"“This title [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1169"},"text":"section 1169 of Title 18","children":[],"tail":", Crimes and Criminal Procedure] may be cited as the ‘Indian Child Protection and Family Violence Prevention Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
