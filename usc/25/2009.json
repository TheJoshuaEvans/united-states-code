{"tag":"section","attrib":{"id":"id628cc0b7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2009"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009"},"text":"§ 2009.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Division of Budget Analysis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id628cc0b8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2009/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", the Secretary shall establish within the Office of Indian Education Programs a Division of Budget Analysis (hereafter in this section referred to as the “Division”). Such Division shall be under the direct supervision and control of the Director of the Office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628cc0b9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2009/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In consultation with the tribal governing bodies and tribal school boards, the Director of the Office, through the Division, shall conduct studies, surveys, or other activities to gather demographic information on Bureau-funded schools and project the amount necessary to provide Indian students in such schools the educational program set forth in this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628cc0ba-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2009/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the date on which the Assistant Secretary for Indian Affairs makes the annual budget submission, for each fiscal year after ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", the Director of the Office shall submit to the appropriate committees of Congress (including the Appropriations committees), all Bureau-funded schools, and the tribal governing bodies of such schools, a report that contains—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id628cc0bb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2009/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projections, based upon the information gathered pursuant to subsection (b) and any other relevant information, of amounts necessary to provide Indian students in Bureau-funded schools the educational program set forth in this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628cc0bc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2009/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the methods and formulas used to calculate the amounts projected pursuant to paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628cc0bd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2009/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Director of the Office considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628cc0be-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2009/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office and the Assistant Secretary for Indian Affairs shall use the annual report required by subsection (c) when preparing annual budget submissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id628cc0bf-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1129"},"text":"Pub. L. 95–561, title XI, § 1129","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1042"},"text":"Pub. L. 107–110, title X, § 1042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2038"},"text":"115 Stat. 2038","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id628cc0c0-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id628cc0c1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id628cc0c2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2009, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1129"},"text":"Pub. L. 95–561, title XI,