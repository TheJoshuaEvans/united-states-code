{"tag":"section","attrib":{"id":"id62c843b7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4024"},"text":null,"children":[{"tag":"num","attrib":{"value":"4024"},"text":"§ 4024.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c843b8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4024/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly or by contract, provide Indian tribes with technical assistance in developing, implementing, and managing Indian trust fund investment plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c843b9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4024/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" among other things, ensure that legal, financial, and other expertise of the Department of the Interior has been made fully available in an advisory capacity to the Indian tribes to assist in the development, implementation, and management of investment plans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c843ba-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/412/tII/s204"},"text":"Pub. L. 103–412, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4243"},"text":"108 Stat. 4243","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
