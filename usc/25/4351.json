{"tag":"section","attrib":{"id":"id62d90b2a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4351"},"text":null,"children":[{"tag":"num","attrib":{"value":"4351"},"text":"§ 4351.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d90b2b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4351/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to enhance and integrate Native American tourism—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d90b2c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4351/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to empower Native American communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d90b2d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4351/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advance the National Travel and Tourism Strategy;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d90b2e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4351/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase coordination and collaboration between Federal tourism assets to support Native American tourism and bolster recreational travel and tourism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d90b2f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4351/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand heritage and cultural tourism opportunities in the United States to spur economic development, create jobs, and increase tourism revenues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d90b30-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4351/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance and improve self-determination and self-governance capabilities in the Native American community and to promote greater self-sufficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d90b31-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4351/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage Indian tribes, tribal organizations, and Native Hawaiian organizations to engage more fully in Native American tourism activities to increase visitation to rural and remote areas in the United States that are too difficult to access or are unknown to domestic travelers and international tourists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d90b32-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4351/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide grants, loans, and technical assistance to Indian tribes, tribal organizations, and Native Hawaiian organizations that will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d90b33-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4351/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" spur important infrastructure development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d90b34-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4351/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase tourism capacity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d90b35-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4351/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elevate living standards in Native American communities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d90b36-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4351/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the development of technologically innovative projects that will incorporate recreational travel and tourism information and data from Federal assets to improve the visitor experience.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d90b37-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/221/s2"},"text":"Pub. L. 114–221, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-09-23"},"text":"Sept. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/847"},"text":"130 Stat. 847","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d90b38-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62d90b39-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id62d90b3a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/221/s1"},"text":"Pub. L. 114–221, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-09-23"},"text":"Sept. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/847"},"text":"130 Stat. 847","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/221/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Native American Tourism and Improving Visitor Experience Act’ or the ‘NATIVE Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
