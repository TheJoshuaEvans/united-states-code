{"tag":"section","attrib":{"id":"id621323ee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s64"},"text":null,"children":[{"tag":"num","attrib":{"value":"64"},"text":"§ 64.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services of agents dispensed with","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be the duty of the President to dispense with the services of such Indian agents and superintendents as may be practicable; and where it is practicable he shall require the same person to perform the duties of two agencies or superintendencies for one salary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621323ef-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2053; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1874-06-22/ch389/s1"},"text":"June 22, 1874, ch. 389, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/18/147"},"text":"18 Stat. 147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1875-03-03/ch132/s1"},"text":"Mar. 3, 1875, ch. 132, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/18/421"},"text":"18 Stat. 421","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621323f0-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621323f1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id621323f2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2053 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1873-02-14/ch138/s1"},"text":"act Feb. 14, 1873, ch. 138, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/437"},"text":"17 Stat. 437","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id621323f3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id621323f4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Indian Agents","children":[],"tail":null},{"tag":"p","attrib":{},"text":"In a communication, dated ","children":[{"tag":"date","attrib":{"date":"1940-11-29"},"text":"November 29, 1940","children":[],"tail":", from the Office of Indian Affairs of the Department of the Interior, it was stated that there have been no Indian agents since 1908, all of the agencies and schools having been placed under the supervision of superintendents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
