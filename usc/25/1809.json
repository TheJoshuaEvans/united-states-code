{"tag":"section","attrib":{"id":"id6280b224-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1809"},"text":null,"children":[{"tag":"num","attrib":{"value":"1809"},"text":"§ 1809.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6280b225-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1809/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as specifically provided in this subchapter, eligibility for assistance under this subchapter shall not, by itself, preclude the eligibility of any tribally controlled college or university to receive Federal financial assistance under any program authorized under the Higher Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"20 U.S.C. 1001","children":[],"tail":" et seq.] or any other applicable program for the benefit of institutions of higher education, community colleges, or postsecondary educational institutions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6280b226-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1809/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations from Bureau of Indian Affairs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6280b227-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1809/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of any grant for which tribally controlled colleges or universities are eligible under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1808"},"text":"section 1808 of this title","children":[],"tail":" shall not be altered because of funds allocated to any such colleges or universities from funds appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6280b228-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1809/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No tribally controlled college or university shall be denied funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":" because of the funds it receives under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6280b229-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1809/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No tribally controlled college or university for which a tribe has designated a portion of the funds appropriated for the tribe from funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":" may be denied a contract for such portion under the Indian Self-Determination and Education Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.) "},{"tag":"ref","attrib":{"idref":"fn002108"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002108"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" (except as provided in that Act), or denied appropriate contract support to administer such portion of the appropriated funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6280b22a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1809/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002109"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002109"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Two subsecs. (c) have been enacted."}],"tail":" Assistance deemed to be basic educational opportunity grant"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of sections 312(2)(A)(i) and 322(a)(2)(A)(i) of the Higher Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1058/2/A/i"},"text":"20 U.S.C. 1058(2)(A)(i)","children":[],"tail":", 1061(a)(2)(A)(i)],"},{"tag":"ref","attrib":{"idref":"fn002110"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002110"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See References in Text note below."}],"tail":" any Indian student who receives a student assistance grant from the Bureau of Indian Affairs for postsecondary education shall be deemed to have received such assistance under subpart 1 of part A of title IV of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"20 U.S.C. 1070a","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6280b22b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1809/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" Treatment of funds under certain Federal laws"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, funds provided under this subchapter to the tribally controlled college or university may be treated as non-Federal, private funds of the college or university for purposes of any provision of Federal law which requires that non-Federal or private funds of the college or university be used in a project or for a specific purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6280b22c-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/tI/s109"},"text":"Pub. L. 95–471, title I, § 109","children":[],"tail":", formerly § 108, "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1328"},"text":"92 Stat. 1328","children":[],"tail":"; renumbered § 109 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/192"},"text":"Pub. L. 98–192","children":[],"tail":", §§ 4(a)(1), 8, "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1336"},"text":"97 Stat. 1336","children":[],"tail":", 1337; "},{"tag":"ref","attrib":{"href":"/us/pl/99/428/s5"},"text":"Pub. L. 99–428, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"Sept. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/983"},"text":"100 Stat. 983","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5403/a"},"text":"Pub. L. 100–297, title V, § 5403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/416"},"text":"102 Stat. 416","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s901/b/5"},"text":"Pub. L. 105–244, title IX, § 901(b)(5)","children":[],"tail":", (6), (8), (10), (12), (e), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1828"},"text":"112 Stat. 1828","children":[],"tail":", 1829.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6280b22d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6280b22e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6280b22f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Higher Education Act of 1965, referred to in subsecs. (a) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1219"},"text":"79 Stat. 1219","children":[],"tail":", which is classified generally to chapter 28 (§ 1001 et seq.) of Title 20, Education. Sections 312 and 322 of the Act, which were classified to sections 1058 and 1061, respectively, of Title 20, were omitted in the general revision of title III of the Higher Education Act of 1965 by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIII/s301/a"},"text":"Pub. L. 99–498, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1290"},"text":"100 Stat. 1290","children":[],"tail":", which enacted new sections 312 and 322 which are classified to sections 1058 and 1061, respectively, of Title 20. Subpart 1 of part A of title IV of the Higher Education Act of 1965 is classified generally to subpart 1 (§ 1070a et seq.) of part A of subchapter IV of chapter 28 of Title 20. For complete classification of the Higher Education Act of 1965 to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.), referred to in subsec. (b)(3), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of this title prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6280b230-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/10"},"text":"Pub. L. 105–244, § 901(b)(10)","children":[],"tail":", inserted “or university” after “tribally controlled college”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/6"},"text":"Pub. L. 105–244, § 901(b)(6)","children":[],"tail":", (8), substituted “controlled colleges or universities” for “controlled community colleges” and “such colleges or universities” for “such colleges”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/5"},"text":"Pub. L. 105–244, § 901(b)(5)","children":[],"tail":", substituted “college or university” for “community college”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/e"},"text":"Pub. L. 105–244, § 901(e)","children":[],"tail":", redesignated subsec. (d), relating to treatment of funds under certain Federal laws, as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/e"},"text":"Pub. L. 105–244, § 901(e)","children":[],"tail":", redesignated subsec. (d), relating to treatment of funds under certain Federal laws, as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/5"},"text":"Pub. L. 105–244, § 901(b)(5)","children":[],"tail":", (12), substituted “controlled college or university” for “controlled community college” and substituted “the college or university” for “the college” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/428"},"text":"Pub. L. 99–428","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192/s8"},"text":"Pub. L. 98–192, § 8","children":[],"tail":", designated existing provision as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6280b231-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6280b232-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6280b233-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date and applicability of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/s6303"},"text":"section 6303 of Pub. L. 100–297","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1071"},"text":"section 1071 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
