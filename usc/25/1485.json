{"tag":"section","attrib":{"id":"id6255d1e5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485"},"text":null,"children":[{"tag":"num","attrib":{"value":"1485"},"text":"§ 1485.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale or assignment of loans and underlying security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6255d1e6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All or any portion of a loan guaranteed or insured under this subchapter, including the security given for the loan—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6255d1e7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be transferred by the lender by sale or assignment to any person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6255d1e8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be retransferred by the transferee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d1e9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a transfer described in subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6255d1ea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer shall be consistent with such regulations as the Secretary shall promulgate under subsection (h); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6255d1eb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transferee shall give notice of the transfer to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d1ec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full faith and credit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6255d1ed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The full faith and credit of the United States is pledged to the payment of all loan guarantees and loan insurance made under this subchapter after ","children":[{"tag":"date","attrib":{"date":"2002-12-13"},"text":"December 13, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6255d1ee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Validity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in regulations in effect on the date on which a loan is made, the validity of a guarantee or insurance of a loan under this subchapter shall be incontestable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d1ef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Damages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", the Secretary may recover from a lender of a loan under this subchapter any damages suffered by the Secretary as a result of a material breach of the obligations of the lender with respect to a guarantee or insurance by the Secretary of the loan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d1f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6255d1f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may collect a fee for any loan or guaranteed or insured portion of a loan that is transferred in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6255d1f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of fiscal transfer agent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A fiscal transfer agent designated under subsection (f) may be compensated through any of the fees assessed under this section and any interest earned on any funds or fees collected by the fiscal transfer agent while the funds or fees are in the control of the fiscal transfer agent and before the time at which the fiscal transfer agent is contractually required to transfer such funds to the Secretary or to transferees or other holders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d1f3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Central registration of loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On promulgation of final regulations under subsection (h), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6255d1f4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a central registration of all guaranteed or insured loans transferred under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6255d1f5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enter into 1 or more contracts with a fiscal transfer agent—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6255d1f6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to act as the designee of the Secretary under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6255d1f7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out on behalf of the Secretary the central registration and fiscal transfer agent functions under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d1f8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pooling of loans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6255d1f9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter prohibits the pooling of whole loans or interests in loans transferred under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6255d1fa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In promulgating regulations under subsection (i),","children":[{"tag":"ref","attrib":{"idref":"fn002029"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002029"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the Secretary may include such regulations to effect orderly and efficient pooling procedures as the Secretary determines to be necessary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d1fb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1485/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2002-12-13"},"text":"December 13, 2002","children":[],"tail":", the Secretary shall develop such procedures and promulgate such regulations as are necessary to facilitate, administer, and promote transfers of loans and guaranteed and insured portions of loans under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6255d1fc-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/tII/s205"},"text":"Pub. L. 93–262, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/80"},"text":"88 Stat. 80","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/442/s2"},"text":"Pub. L. 100–442, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-22"},"text":"Sept. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1763"},"text":"102 Stat. 1763","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/331/tI/s103/b"},"text":"Pub. L. 107–331, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-13"},"text":"Dec. 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2836"},"text":"116 Stat. 2836","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/221/tIV/s401/b"},"text":"Pub. L. 109–221, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-05-12"},"text":"May 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/342"},"text":"120 Stat. 342","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6255d1fd-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6255d1fe-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6255d1ff-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (i), referred to in subsec. (g)(2), was redesignated as subsection (h) of this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221/tIV/s401/b/3"},"text":"Pub. L. 109–221, title IV, § 401(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-05-12"},"text":"May 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/342"},"text":"120 Stat. 342","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6255d200-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221/s401/b/1"},"text":"Pub. L. 109–221, § 401(b)(1)","children":[],"tail":", inserted section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221/s401/b/1"},"text":"Pub. L. 109–221, § 401(b)(1)","children":[],"tail":", added subsecs. (a) and (b) and struck out former subsecs. (a) and (b), which authorized loan sale or assignment and set forth parameters for initial transfers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221/s401/b/2"},"text":"Pub. L. 109–221, § 401(b)(2)","children":[],"tail":", (3), redesignated subsec. (d) as (c) and struck out former subsec. (c) which set forth requirements for secondary transfers under this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221/s401/b/4"},"text":"Pub. L. 109–221, § 401(b)(4)","children":[],"tail":", added par. (2) and struck out former par (2) which provided for the incontestability of a guarantee or insurance of a loan under this subchapter with an exception for fraud or misrepresentation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221/s401/b/3"},"text":"Pub. L. 109–221, § 401(b)(3)","children":[],"tail":", redesignated subsec. (e) as (d). Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221/s401/b/5"},"text":"Pub. L. 109–221, § 401(b)(5)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221/s401/b/3"},"text":"Pub. L. 109–221, § 401(b)(3)","children":[],"tail":", redesignated subsec. (f) as (e). Former subsec. (e) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221/s401/b/6"},"text":"Pub. L. 109–221, § 401(b)(6)","children":[],"tail":", substituted “subsection (h)” for “subsection (i)” in introductory provisions and struck out “, and issuance of acknowledgments,” after “agent functions” in par. (2)(B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221/s401/b/3"},"text":"Pub. L. 109–221, § 401(b)(3)","children":[],"tail":", redesignated subsec. (g) as (f). Former subsec. (f) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221/s401/b/3"},"text":"Pub. L. 109–221, § 401(b)(3)","children":[],"tail":", redesignated subsecs. (h) and (i) as (g) and (h), respectively. Former subsec. (g) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/331"},"text":"Pub. L. 107–331","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading and substituted “Any loan guaranteed or insured” for “Any loan guaranteed”, and added subsecs. (b) to (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/442"},"text":"Pub. L. 100–442","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “Any loan guaranteed hereunder, including the security given therefor, may be sold or assigned by the lender to any financial institution subject to examination and supervision by an agency of the United States or of any State or the District of Columbia.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6255d201-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6255d202-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings and Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/331/tI/s102"},"text":"Pub. L. 107–331, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-13"},"text":"Dec. 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2835"},"text":"116 Stat. 2835","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/331/tI/s102"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian Financing Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1451"},"text":"25 U.S.C. 1451","children":[],"tail":" et seq.) was intended to provide Native American borrowers with access to commercial sources of capital that otherwise would not be available through the guarantee or insurance of loans by the Secretary of the Interior;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" although the Secretary of the Interior has made loan guarantees and insurance available, use of those guarantees and that insurance by lenders to benefit Native American business borrowers has been limited;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" twenty-seven years after the date of enactment of the Indian Financing Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1451"},"text":"25 U.S.C. 1451","children":[],"tail":" et seq.) ["},{"tag":"ref","attrib":{"href":"/us/pl/93/262"},"text":"Pub. L. 93–262","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":"], the promotion and development of Native American-owned business remains an essential foundation for growth of economic and social stability of Native Americans;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use by commercial lenders of the available loan insurance and guarantees may be limited by liquidity and other capital market-driven concerns; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" it is in the best interest of the insured and guaranteed loan program of the Department of the Interior—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage the orderly development and expansion of a secondary market for loans guaranteed or insured by the Secretary of the Interior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand the number of lenders originating loans under the Indian Financing Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1451"},"text":"25 U.S.C. 1451","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this Act [see Short Title of 2002 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1451"},"text":"section 1451 of this title","children":[],"tail":"] is to reform and clarify the Indian Financing Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1451"},"text":"25 U.S.C. 1451","children":[],"tail":" et seq.) in order to—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stimulate the use by lenders of secondary market investors for loans guaranteed or insured under a program administered by the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserve the authority of the Secretary to administer the program and regulate lenders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clarify that a good faith investor in loans insured or guaranteed by the Secretary will receive appropriate payments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the appointment by the Secretary of a qualified fiscal transfer agent to establish and administer a system for the orderly transfer of those loans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize the Secretary to promulgate regulations to encourage and expand a secondary market program for loans guaranteed or insured by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the pooling of those loans as the secondary market develops.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
