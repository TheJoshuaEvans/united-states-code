{"tag":"section","attrib":{"id":"id627281ce-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1665k"},"text":"§ 1665k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fetal alcohol spectrum disorders programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id627281cf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627281d0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1665a"},"text":"section 1665a of this title","children":[],"tail":", acting through the Service, Indian Tribes, and Tribal Organizations, is authorized to establish and operate fetal alcohol spectrum disorders programs as provided in this section for the purposes of meeting the health status objectives specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627281d1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id627281d2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funding provided pursuant to this section shall be used for the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id627281d3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop and provide for Indians community and in-school training, education, and prevention programs relating to fetal alcohol spectrum disorders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id627281d4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To identify and provide behavioral health treatment to high-risk Indian women and high-risk women pregnant with an Indian’s child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id627281d5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To identify and provide appropriate psychological services, educational and vocational support, counseling, advocacy, and information to fetal alcohol spectrum disorders-affected Indians and their families or caretakers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id627281d6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop and implement counseling and support programs in schools for fetal alcohol spectrum disorders-affected Indian children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id627281d7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop prevention and intervention models which incorporate practitioners of traditional health care practices, cultural values, and community involvement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id627281d8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/a/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop, print, and disseminate education and prevention materials on fetal alcohol spectrum disorders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id627281d9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/a/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop and implement, in consultation with Indian Tribes and Tribal Organizations, and in conference with urban Indian Organizations, culturally sensitive assessment and diagnostic tools including dysmorphology clinics and multidisciplinary fetal alcohol spectrum disorders clinics for use in Indian communities and urban Centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id627281da-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/a/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop and provide training on fetal alcohol spectrum disorders to professionals providing services to Indians, including medical and allied health practitioners, social service providers, educators, and law enforcement, court officials and corrections personnel in the juvenile and criminal justice systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id627281db-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any purpose under subparagraph (A), funding provided pursuant to this section may be used for 1 or more of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id627281dc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Early childhood intervention projects from birth on to mitigate the effects of fetal alcohol spectrum disorders among Indians.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id627281dd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Community-based support services for Indians and women pregnant with Indian children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id627281de-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Community-based housing for adult Indians with fetal alcohol spectrum disorders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627281df-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish criteria for the review and approval of applications for funding under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627281e0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Service, Indian Tribes, and Tribal Organizations, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627281e1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and provide services for the prevention, intervention, treatment, and aftercare for those affected by fetal alcohol spectrum disorders in Indian communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627281e2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide supportive services, including services to meet the special educational, vocational, school-to-work transition, and independent living needs of adolescent and adult Indians with fetal alcohol spectrum disorders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627281e3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applied research projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Substance Abuse and Mental Health Services Administration, shall make grants to Indian Tribes, Tribal Organizations, and urban Indian Organizations for applied research projects which propose to elevate the understanding of methods to prevent, intervene, treat, or provide rehabilitation and behavioral health aftercare for Indians and urban Indians affected by fetal alcohol spectrum disorders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627281e4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for urban Indian organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Ten percent of the funds appropriated pursuant to this section shall be used to make grants to urban Indian Organizations funded under subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id627281e5-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s712"},"text":"Pub. L. 94–437, title VII, § 712","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id627281e6-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id627281e7-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id627281e8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s712"},"text":"Section 712 of Pub. L. 94–437","children":[],"tail":" is based on section 181 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id627281e9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1665k, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s712"},"text":"Pub. L. 94–437, title VII, § 712","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s702/a"},"text":"Pub. L. 102–573, title VII, § 702(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4581"},"text":"106 Stat. 4581","children":[],"tail":", provided for establishment of the Gila River alcohol and substance abuse treatment facility, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
