{"tag":"section","attrib":{"id":"id623b938d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s416d"},"text":null,"children":[{"tag":"num","attrib":{"value":"416d"},"text":"§ 416d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance payment of rent or other consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No rent or other consideration for the use of land leased under sections 416 to 416j of this title shall be paid or collected more than one year in advance, unless so provided in the lease.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id623b938e-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/715/s5"},"text":"Pub. L. 89–715, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1113"},"text":"80 Stat. 1113","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
