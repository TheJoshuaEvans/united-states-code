{"tag":"section","attrib":{"id":"id62b7a1fd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208"},"text":null,"children":[{"tag":"num","attrib":{"value":"3208"},"text":"§ 3208.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Child Abuse Treatment Grant Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b7a1fe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Service, in cooperation with the Bureau, shall establish an Indian Child Abuse Treatment Grant Program that provides grants to any Indian tribe or inter­tribal consortium for the establishment on Indian reservations of treatment programs for Indians who have been victims of child abuse or neglect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a1ff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b7a200-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any Indian tribe or intertribal consortium, on its own or in partnership with an urban Indian organization, may submit to the Service an application for a grant under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a201-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any application submitted under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b7a202-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in such form as the Service may prescribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a203-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be submitted to the Service on or before the date designated by the Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a204-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall specify—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b7a205-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the program proposed by the applicant,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b7a206-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the data and information on which the program is based,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b7a207-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the program plans to use or incorporate existing services available on the reservation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b7a208-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific treatment concepts to be used under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a209-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Culturally appropriate treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Service shall encourage the use of culturally appropriate treatment services and programs that respond to the unique cultural values, customs, and traditions of applicant Indian Tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a20a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant administration and final report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each recipient of a grant awarded under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b7a20b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" furnish the Service with such information as the Service may require to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b7a20c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the program for which the grant is made, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a20d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the grant funds are expended for the purposes for which the grant was made, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a20e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Service at the close of the term of the grant a final report which shall include such information as the Service may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a20f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"December 23, 2024","children":[],"tail":", the Service shall submit a report to Congress on the award of grants under this section. The report shall contain—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b7a210-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of treatment and services for which grantees have used funds awarded under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a211-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information that the Service requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a212-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3208/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"there ","children":[{"tag":"ref","attrib":{"idref":"fn002212"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002212"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" is hereby authorized to be appropriated to carry out the provisions of this section $10,000,000 for each of the fiscal years 1992, 1993, 1994, 1995, 1996, and 1997."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b7a213-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIV/s409"},"text":"Pub. L. 101–630, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4551"},"text":"104 Stat. 4551","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/16/s1"},"text":"Pub. L. 104–16, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-06-21"},"text":"June 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/190"},"text":"109 Stat. 190","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/2"},"text":"Pub. L. 118–160, § 2(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2567"},"text":"138 Stat. 2567","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62b7a214-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62b7a215-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62b7a216-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/2/A"},"text":"Pub. L. 118–160, § 2(2)(A)","children":[],"tail":", substituted “The Service, in cooperation with the Bureau” for “The Secretary of Health and Human Services, acting through the Service and in cooperation with the Bureau” and “abuse or neglect” for “sexual abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/2/B"},"text":"Pub. L. 118–160, § 2(2)(B)","children":[],"tail":", (C), inserted “, on its own or in partnership with an urban Indian organization,” after “Any Indian tribe or intertribal consortium” and substituted “Service” for “Secretary of Health and Human Services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/2/B"},"text":"Pub. L. 118–160, § 2(2)(B)","children":[],"tail":", substituted “Service” for “Secretary of Health and Human Services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/2/D"},"text":"Pub. L. 118–160, § 2(2)(D)","children":[],"tail":", substituted “the Service” for “such Secretary” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/2/E"},"text":"Pub. L. 118–160, § 2(2)(E)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, text read as follows: “The maximum amount of any grant awarded under subsection (a) shall not exceed $500,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/2/B"},"text":"Pub. L. 118–160, § 2(2)(B)","children":[],"tail":", (D), substituted “Service” for “Secretary of Health and Human Services” and “as the Service” for “as such Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/2/D"},"text":"Pub. L. 118–160, § 2(2)(D)","children":[],"tail":", (F), substituted “to the Service” for “to such Secretary” and “as the Service” for “as the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/2/G"},"text":"Pub. L. 118–160, § 2(2)(G)","children":[],"tail":", (H), added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/16"},"text":"Pub. L. 104–16","children":[],"tail":" substituted “1995, 1996, and 1997” for “and 1995”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
