{"tag":"section","attrib":{"id":"id629d61df-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2402"},"text":null,"children":[{"tag":"num","attrib":{"value":"2402"},"text":"§ 2402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this chapter to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629d61e0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2402/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize and develop a comprehensive, coordinated attack upon the illegal narcotics traffic in Indian country and the deleterious impact of alcohol and substance abuse upon Indian tribes and their members,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d61e1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2402/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide needed direction and guidance to those Federal agencies responsible for Indian programs to identify and focus existing programs and resources, including those made available by this chapter, upon this problem,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d61e2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2402/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide authority and opportunities for Indian tribes to develop and implement a coordinated program for the prevention and treatment of alcohol and substance abuse at the local level, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d61e3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2402/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ","children":[{"tag":"ref","attrib":{"idref":"fn002148"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002148"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" modify or supplement existing programs and authorities in the areas of education, family and social services, law enforcement and judicial services, and health services to further the purposes of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629d61e4-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4203"},"text":"Pub. L. 99–570, title IV, § 4203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-138"},"text":"100 Stat. 3207–138","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
