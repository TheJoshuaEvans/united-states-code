{"tag":"section","attrib":{"id":"id6270105b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1660h"},"text":"§ 1660h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health information technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, may make grants to urban Indian organizations under this subchapter for the development, adoption, and implementation of health information technology (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300jj"},"text":"section 300jj of title 42","children":[],"tail":"), telemedicine services development, and related infrastructure."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6270105c-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tV/s518"},"text":"Pub. L. 94–437, title V, § 518","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6270105d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6270105e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6270105f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail"