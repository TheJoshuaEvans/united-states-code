{"tag":"section","attrib":{"id":"id62a6d7c8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706"},"text":null,"children":[{"tag":"num","attrib":{"value":"2706"},"text":"§ 2706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62a6d7c9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget approval; civil fines; fees; subpoenas; permanent orders","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall have the power, not subject to delegation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a6d7ca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon the recommendation of the Chairman, to approve the annual budget of the Commission as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2717"},"text":"section 2717 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a6d7cb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to adopt regulations for the assessment and collection of civil fines as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2713/a"},"text":"section 2713(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a6d7cc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an affirmative vote of not less than 2 members, to establish the rate of fees as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2717"},"text":"section 2717 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a6d7cd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an affirmative vote of not less than 2 members, to authorize the Chairman to issue subpoenas as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2715"},"text":"section 2715 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a6d7ce-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an affirmative vote of not less than 2 members and after a full hearing, to make permanent a temporary order of the Chairman closing a gaming activity as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2713/b/2"},"text":"section 2713(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a6d7cf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring; inspection of premises; investigations; access to records; mail; contracts; hearings; oaths; regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a6d7d0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall monitor class II gaming conducted on Indian lands on a continuing basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a6d7d1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall inspect and examine all premises located on Indian lands on which class II gaming is conducted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a6d7d2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall conduct or cause to be conducted such background investigations as may be necessary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a6d7d3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may demand access to and inspect, examine, photocopy, and audit all papers, books, and records respecting gross revenues of class II gaming conducted on Indian lands and any other matters necessary to carry out the duties of the Commission under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a6d7d4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use the United States mail in the same manner and under the same conditions as any department or agency of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a6d7d5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may procure supplies, services, and property by contract in accordance with applicable Federal laws and regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a6d7d6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into contracts with Federal, State, tribal and private entities for activities necessary to the discharge of the duties of the Commission and, to the extent feasible, contract the enforcement of the Commission’s regulations with the Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a6d7d7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may hold such hearings, sit and act at such times and places, take such testimony, and receive such evidence as the Commission deems appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a6d7d8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may administer oaths or affirmations to witnesses appearing before the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a6d7d9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall promulgate such regulations and guidelines as it deems appropriate to implement the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a6d7da-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a6d7db-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of Government Performance and Results Act","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a6d7dc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out any action under this chapter, the Commission shall be subject to the Government Performance and Results Act of 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/62"},"text":"Public Law 103–62","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/107/285"},"text":"107 Stat. 285","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a6d7dd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2706/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any plan required under the Government Performance and Results Act of 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/62"},"text":"Public Law 103–62","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/107/285"},"text":"107 Stat. 285","children":[],"tail":"), the Commission shall submit a plan to provide technical assistance to tribal gaming operations in accordance with that Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62a6d7de-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497/s7"},"text":"Pub. L. 100–497, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2470"},"text":"102 Stat. 2470","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/221/tIII/s301/a"},"text":"Pub. L. 109–221, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-05-12"},"text":"May 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/341"},"text":"120 Stat. 341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62a6d7df-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62a6d7e0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62a6d7e1-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b)(4), (10) and (d)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497"},"text":"Pub. L. 100–497","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2467"},"text":"102 Stat. 2467","children":[],"tail":", known as the Indian Gaming Regulatory Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2701"},"text":"section 2701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Government Performance and Results Act of 1993, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/62"},"text":"Pub. L. 103–62","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-03"},"text":"Aug. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/285"},"text":"107 Stat. 285","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of Title 5","children":[],"tail":", Government Organization and Employees, sections 1115 to 1119, 9703, and 9704 of Title 31, Money and Finance, and sections 2801 to 2805 of Title 39, Postal Service, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of Title 31","children":[],"tail":", and enacted provisions set out as notes under sections 1101 and 1115 of Title 31. For complete classification of this Act to the Code, see Short Title of 1993 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1101"},"text":"section 1101 of Title 31","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62a6d7e2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c) of this section, which required the Commission to submit a report to Congress every two years on various matters relating to the operation of the Commission, terminated, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", pursuant to section 3003 of Pub. L. 104-66, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance. See, also, page 114 of House Document No. 103-7."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62a6d7e3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221"},"text":"Pub. L. 109–221","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
