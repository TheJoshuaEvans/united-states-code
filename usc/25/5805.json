{"tag":"section","attrib":{"id":"id62f805df-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5805"},"text":null,"children":[{"tag":"num","attrib":{"value":"5805"},"text":"§ 5805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schools to business incubator pipeline","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall facilitate the establishment of relationships between eligible applicants receiving funds through the program and educational institutions serving Native American communities, including tribal colleges and universities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62f805e0-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/174/s6"},"text":"Pub. L. 116–174, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-20"},"text":"Oct. 20, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/847"},"text":"134 Stat. 847","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
