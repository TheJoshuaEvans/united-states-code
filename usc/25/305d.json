{"tag":"section","attrib":{"id":"id6223c517-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305d"},"text":null,"children":[{"tag":"num","attrib":{"value":"305d"},"text":"§ 305d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal proceedings; civil actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6223c518-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of Federal law enforcement officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “Federal law enforcement officer” includes a Federal law enforcement officer (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s115/c"},"text":"section 115(c) of title 18","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6223c519-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to conduct investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Federal law enforcement officer shall have the authority to conduct an investigation relating to an alleged violation of this Act occurring within the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6223c51a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal proceedings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6223c51b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6223c51c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305d/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may refer an alleged violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1159"},"text":"section 1159 of title 18","children":[],"tail":" to any Federal law enforcement officer for appropriate investigation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6223c51d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305d/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral not required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal law enforcement officer may investigate an alleged violation of section 1159 of that title regardless of whether the Federal law enforcement officer receives a referral under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6223c51e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The findings of an investigation of an alleged violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1159"},"text":"section 1159 of title 18","children":[],"tail":" by any Federal department or agency under paragraph (1)(A) shall be submitted, as appropriate, to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6223c51f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal or State prosecuting authority; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6223c520-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6223c521-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On receiving the findings of an investigation under paragraph (2), the Board may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6223c522-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305d/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend to the Attorney General that criminal proceedings be initiated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1159"},"text":"section 1159 of title 18","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6223c523-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305d/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such support to the Attorney General relating to the criminal proceedings as the Attorney General determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6223c524-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In lieu of, or in addition to, any criminal proceeding under subsection (c), the Board may recommend that the Attorney General initiate a civil action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s305e"},"text":"section 305e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6223c525-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-27/ch748/s5"},"text":"Aug. 27, 1935, ch. 748, § 5","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/644/tI/s103"},"text":"Pub. L. 101–644, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4662"},"text":"104 Stat. 4662","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tI/s102/a"},"text":"Pub. L. 111–211, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2258"},"text":"124 Stat. 2258","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6223c526-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6223c527-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6223c528-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-27/ch748"},"text":"act Aug. 27, 1935, ch. 748","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/891"},"text":"49 Stat. 891","children":[],"tail":", which is classified generally to section 305 et seq. of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6223c529-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-27/ch748/s5"},"text":"act Aug. 27, 1935, ch. 748, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/892"},"text":"49 Stat. 892","children":[],"tail":", related to counterfeiting of a trade mark and penalty, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645/s21"},"text":"act June 25, 1948, ch. 645, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/862"},"text":"62 Stat. 862","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1158"},"text":"section 1158 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6223c52a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211"},"text":"Pub. L. 111–211","children":[],"tail":" amended section generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) The Board may receive complaints of violations of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1159"},"text":"section 1159 of title 18","children":[],"tail":" and refer complaints of such violations to the Federal Bureau of Investigation for appropriate investigation. After reviewing the investigation report, the Board may recommend to the Attorney General of the United States that criminal proceedings be instituted under that section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) The Board may recommend that the Secretary of the Interior refer the matter to the Attorney General for civil action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s305e"},"text":"section 305e of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
