{"tag":"section","attrib":{"id":"id625cfe0e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1616c"},"text":"§ 1616c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal recruitment and retention program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id625cfe0f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects funded on competitive basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, shall fund, on a competitive basis, projects to enable Indian tribes and tribal and Indian organizations to recruit, place, and retain health professionals to meet the staffing needs of Indian health programs (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1616a/a/2"},"text":"section 1616a(a)(2) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe10-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625cfe11-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any Indian tribe or tribal or Indian organization may submit an application for funding of a project pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe12-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribes and tribal and Indian organizations under the authority of the Indian Self-Determination Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.] shall be given an equal opportunity with programs that are administered directly by the Service to compete for, and receive, grants under subsection (a) for such projects."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id625cfe13-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tI/s110"},"text":"Pub. L. 94–437, title I, § 110","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tI/s108"},"text":"Pub. L. 100–713, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4794"},"text":"102 Stat. 4794","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tI/s117/b/4"},"text":"Pub. L. 102–573, title I, § 117(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4544"},"text":"106 Stat. 4544","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id625cfe14-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id625cfe15-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id625cfe16-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination Act, referred to in subsec. (b)(2), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2206"},"text":"88 Stat. 2206","children":[],"tail":", which is classified principally to subchapter I (§ 5321 et seq.) of chapter 46 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id625cfe17-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573"},"text":"Pub. L. 102–573","children":[],"tail":" struck out subsec. (c) which authorized appropriations for fiscal years 1990 to 1992."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
