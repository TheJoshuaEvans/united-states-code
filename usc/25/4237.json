{"tag":"section","attrib":{"id":"id62d42ad7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237"},"text":null,"children":[{"tag":"num","attrib":{"value":"4237"},"text":"§ 4237.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies for noncompliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d42ad8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by Secretary affecting grant amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42ad9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), if the Secretary finds after reasonable notice and opportunity for a hearing that the Department of Hawaiian Home Lands has failed to comply substantially with any provision of this subchapter, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42ada-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate payments under this subchapter to the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42adb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce payments under this subchapter to the Department by an amount equal to the amount of such payments that were not expended in accordance with this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42adc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the availability of payments under this subchapter to programs, projects, or activities not affected by such failure to comply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42add-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary takes an action under subparagraph (A), (B), or (C) of paragraph (1), the Secretary shall continue that action until the Secretary determines that the failure by the Department to comply with the provision has been remedied by the Department and the Department is in compliance with that provision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42ade-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance because of a technical incapacity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide technical assistance for the Department, either directly or indirectly, that is designed to increase the capability and capacity of the Director of the Department to administer assistance provided under this subchapter in compliance with the requirements under this subchapter if the Secretary makes a finding under subsection (a), but determines that the failure of the Department to comply substantially with the provisions of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42adf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a pattern or practice of activities constituting willful noncompliance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42ae0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a result of the limited capability or capacity of the Department of Hawaiian Home Lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42ae1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral for civil action","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42ae2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In lieu of, or in addition to, any action that the Secretary may take under subsection (a), if the Secretary has reason to believe that the Department of Hawaiian Home Lands has failed to comply substantially with any provision of this subchapter, the Secretary may refer the matter to the Attorney General of the United States with a recommendation that an appropriate civil action be instituted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42ae3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon receiving a referral under paragraph (1), the Attorney General may bring a civil action in any United States district court of appropriate jurisdiction for such relief as may be appropriate, including an action—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42ae4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recover the amount of the assistance furnished under this subchapter that was not expended in accordance with this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42ae5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for mandatory or injunctive relief.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42ae6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42ae7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Director receives notice under subsection (a) of the termination, reduction, or limitation of payments under this chapter, the Director—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42ae8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, not later than 60 days after receiving such notice, file with the United States Court of Appeals for the Ninth Circuit, or in the United States Court of Appeals for the District of Columbia, a petition for review of the action of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42ae9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon the filing of any petition under subparagraph (A), shall forthwith transmit copies of the petition to the Secretary and the Attorney General of the United States, who shall represent the Secretary in the litigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42aea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42aeb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall file in the court a record of the proceeding on which the Secretary based the action, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2112"},"text":"section 2112 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42aec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No objection to the action of the Secretary shall be considered by the court unless the Department has registered the objection before the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42aed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42aee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court proceedings","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d42aef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court shall have jurisdiction to affirm or modify the action of the Secretary or to set the action aside in whole or in part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d42af0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings of fact","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If supported by substantial evidence on the record considered as a whole, the findings of fact by the Secretary shall be conclusive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d42af1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Addition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court may order evidence, in addition to the evidence submitted for review under this subsection, to be taken by the Secretary, and to be made part of the record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42af2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d42af3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, by reason of the additional evidence referred to in subparagraph (A) and filed with the court—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62d42af4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id62d42af5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/3/B/i/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modify the findings of fact of the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id62d42af6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/3/B/i/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make new findings; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d42af7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall file—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id62d42af8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/3/B/i/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such modified or new findings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id62d42af9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/3/B/i/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recommendation of the Secretary, if any, for the modification or setting aside of the original action of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d42afa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The findings referred to in clause (i)(II)(bb) shall, with respect to a question of fact, be considered to be conclusive if those findings are—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62d42afb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supported by substantial evidence on the record; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d42afc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considered as a whole.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42afd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42afe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), upon the filing of the record under this subsection with the court—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d42aff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the jurisdiction of the court shall be exclusive; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d42b00-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the judgment of the court shall be final.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42b01-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4237/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by Supreme Court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A judgment under subparagraph (A) shall be subject to review by the Supreme Court of the United States upon writ of certiorari or certification, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1254"},"text":"section 1254 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d42b02-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s818"},"text":"Pub. L. 104–330, title VIII, § 818","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s203"},"text":"Pub. L. 106–568, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2891"},"text":"114 Stat. 2891","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s513"},"text":"Pub. L. 106–569, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2985"},"text":"114 Stat. 2985","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d42b03-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d42b04-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62d42b05-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", known as the Native American Housing Assistance and Self-Determination Act of 1996. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62d42b06-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s203"},"text":"Pub. L. 106–568, § 203","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":", enacted identical sections 818 of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":". This section is based on the text of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s818"},"text":"section 818 of Pub. L. 104–330","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
