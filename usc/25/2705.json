{"tag":"section","attrib":{"id":"id62a48ed0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2705"},"text":null,"children":[{"tag":"num","attrib":{"value":"2705"},"text":"§ 2705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Chairman","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62a48ed1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Chairman, on behalf of the Commission, shall have power, subject to an appeal to the Commission, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a48ed2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2705/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue orders of temporary closure of gaming activities as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2713/b"},"text":"section 2713(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a6d7c3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2705/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" levy and collect civil fines as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2713/a"},"text":"section 2713(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a6d7c4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2705/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve tribal ordinances or resolutions regulating class II gaming and class III gaming as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2710"},"text":"section 2710 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a6d7c5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2705/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve management contracts for class II gaming and class III gaming as provided in sections 2710(d)(9) and 2711 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a6d7c6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman shall have such other powers as may be delegated by the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62a6d7c7-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497/s6"},"text":"Pub. L. 100–497, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2470"},"text":"102 Stat. 2470","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
