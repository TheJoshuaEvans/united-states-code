{"tag":"section","attrib":{"id":"id621c9951-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s180"},"text":null,"children":[{"tag":"num","attrib":{"value":"180"},"text":"§ 180.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settling on or surveying lands belonging to Indians by treaty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every person who makes a settlement on any lands belonging, secured, or granted by treaty with the United States to any Indian tribe, or surveys or attempts to survey such lands, or to designate any of the boundaries by marking trees, or otherwise, is liable to a penalty of $1,000. The President may, moreover, take such measures and employ such military force as he may judge necessary to remove any such person from the lands.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621c9952-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2118.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621c9953-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621c9954-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id621c9955-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2118 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1834-06-30/ch161/s11"},"text":"act June 30, 1834, ch. 161, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/730"},"text":"4 Stat. 730","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
