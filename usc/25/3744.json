{"tag":"section","attrib":{"id":"id62c5f93c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3744"},"text":null,"children":[{"tag":"num","attrib":{"value":"3744"},"text":"§ 3744.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal, State and local authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c5f93d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3744/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclaimer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to supersede or limit the authority of Federal, State or local agencies otherwise authorized by law to provide services to Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c5f93e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3744/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duplication of services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall work with all appropriate Federal departments and agencies to avoid duplication of programs and services currently available to Indian tribes and landowners from other sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c5f93f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/177/tIII/s304"},"text":"Pub. L. 103–177, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2022"},"text":"107 Stat. 2022","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
