{"tag":"section","attrib":{"id":"id622fac15-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s341"},"text":null,"children":[{"tag":"num","attrib":{"value":"341"},"text":"§ 341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power to grant rights-of-way not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this act shall be so construed as to affect the right and power of Congress to grant the right of way through any lands granted to an Indian, or a tribe of Indians, for railroads or other highways, or telegraph lines, for the public use, or to condemn such lands to public uses, upon making just compensation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id622fac16-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-02-08/ch119/s10"},"text":"Feb. 8, 1887, ch. 119, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/391"},"text":"24 Stat. 391","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id622fac17-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id622fac18-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id622fac19-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-02-08/ch119"},"text":"act Feb. 8, 1887, ch. 119","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/388"},"text":"24 Stat. 388","children":[],"tail":", and is popularly known as the Indian General Allotment Act. For classification of this act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s331"},"text":"section 331 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
