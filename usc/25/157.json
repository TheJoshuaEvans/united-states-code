{"tag":"section","attrib":{"id":"id621a28b5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s157"},"text":null,"children":[{"tag":"num","attrib":{"value":"157"},"text":"§ 157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investments of stock required by treaties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All investments of stock, that are or may be required by treaties with the Indians, shall be made under the direction of the President; and special accounts of the funds under such treaties shall be kept at the Treasury, and statements thereof be annually laid before Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621a28b6-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2095.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621a28b7-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621a28b8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id621a28b9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2095 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1837-01-09/ch1/s3"},"text":"act Jan. 9, 1837, ch. 1, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/5/135"},"text":"5 Stat. 135","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
