{"tag":"section","attrib":{"id":"id62c843ca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4029"},"text":null,"children":[{"tag":"num","attrib":{"value":"4029"},"text":"§ 4029.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c843cb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4029/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"1994-10-25"},"text":"October 25, 1994","children":[],"tail":", the Secretary shall promulgate final regulations for the implementation of this subchapter. All regulations promulgated pursuant to this subchapter shall be developed by the Secretary with the full and active participation of the Indian tribes with trust funds held by the Secretary and other affected Indian tribes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c843cc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4029/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The lack of promulgated regulations shall not limit the effect of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c843cd-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/412/tII/s209"},"text":"Pub. L. 103–412, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"t