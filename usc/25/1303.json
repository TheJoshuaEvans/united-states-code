{"tag":"section","attrib":{"id":"id624ea753-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1303"},"text":null,"children":[{"tag":"num","attrib":{"value":"1303"},"text":"§ 1303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Habeas corpus","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The privilege of the writ of habeas corpus shall be available to any person, in a court of the United States, to test the legality of his detention by order of an Indian tribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id624ea754-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284/tII/s203"},"text":"Pub. L. 90–284, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/78"},"text":"82 Stat. 78","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
