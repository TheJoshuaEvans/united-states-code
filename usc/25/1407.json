{"tag":"section","attrib":{"id":"id6253889a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1407"},"text":null,"children":[{"tag":"num","attrib":{"value":"1407"},"text":"§ 1407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax exemption; resources exemption limitation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"None of the funds which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6253889b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1407/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are distributed per capita or held in trust pursuant to a plan approved under the provisions of this chapter, or ","children":[{"tag":"ref","attrib":{"idref":"fn002026"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002026"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “or” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6253889c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1407/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"1983-01-12"},"text":"January 12, 1983","children":[],"tail":", are to be distributed per capita or are held in trust pursuant to a plan approved by the Congress prior to "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"January 12, 1983","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6253889d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1407/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were distributed pursuant to a plan approved by Congress after ","children":[{"tag":"date","attrib":{"date":"1981-12-31"},"text":"December 31, 1981","children":[],"tail":" but prior to "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"January 12, 1983","children":[],"tail":", and any purchases made with such funds, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6253889e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1407/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are paid by the State of Minnesota to the Bois Forte Band of Chippewa Indians or the Grand Portage Band of Lake Superior Chippewa Indians, or both, pursuant to the agreements of each Band to voluntarily restrict tribal rights to hunt and fish in territory cede ","children":[{"tag":"ref","attrib":{"idref":"fn002027"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002027"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “ceded”."}],"tail":" under the Treaty of "},{"tag":"date","attrib":{"date":"1854-09-30"},"text":"September 30, 1854","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/10/1109"},"text":"10 Stat. 1109","children":[],"tail":"), including all interest accrued on such funds during any period in which such funds are held in a minor’s trust,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"including all interest and investment income accrued thereon while such funds are so held in trust, shall be subject to Federal or State income taxes, nor shall such funds nor their availability be considered as income or resources nor otherwise utilized as the basis for denying or reducing the financial assistance or other benefits to which such household or member would otherwise be entitled under the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s301"},"text":"42 U.S.C. 301","children":[],"tail":" et seq.] or, except for per capita shares in excess of $2,000, any Federal or federally assisted program."}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6253889f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/134/s7"},"text":"Pub. L. 93–134, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-19"},"text":"Oct. 19, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/468"},"text":"87 Stat. 468","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/458/s4"},"text":"Pub. L. 97–458, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2513"},"text":"96 Stat. 2513","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tVIII/s818"},"text":"Pub. L. 106–568, title VIII, § 818","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2918"},"text":"114 Stat. 2918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/290/s2"},"text":"Pub. L. 113–290, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3291"},"text":"128 Stat. 3291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id625388a0-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id625388a1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id625388a2-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":", which is classified generally to chapter 7 (§ 301 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id625388a3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/290"},"text":"Pub. L. 113–290","children":[],"tail":" substituted “or the Grand Portage Band of Lake Superior Chippewa Indians, or both, pursuant to the agreements of each Band” for “pursuant to the agreements of such Band”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568"},"text":"Pub. L. 106–568","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/458"},"text":"Pub. L. 97–458","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “None of the funds distributed per capita or held in trust under the provisions of this chapter shall be subject to Federal or State income taxes, and the per capita payments shall not be considered as income or resources when determining the extent of eligibility for assistance under the Social Security Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
