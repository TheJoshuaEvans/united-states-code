{"tag":"section","attrib":{"id":"id62f80538-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5801"},"text":null,"children":[{"tag":"num","attrib":{"value":"5801"},"text":"§ 5801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f80539-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5801/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entrepreneurs face specific challenges when transforming ideas into profitable business enterprises;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f8053a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5801/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entrepreneurs that want to provide products and services in reservation communities face an additional set of challenges that requires special knowledge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f8053b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5801/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a business incubator is an organization that assists entrepreneurs in navigating obstacles that prevent innovative ideas from becoming viable businesses by providing services that include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f8053c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5801/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" workspace and facilities resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f8053d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5801/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to capital, business education, and counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f8053e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5801/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" networking opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f8053f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5801/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mentorship opportunities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f80540-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5801/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an environment intended to help establish and expand business operations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f80541-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5801/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the business incubator model is suited to accelerating entrepreneurship in reservation communities because the business incubator model promotes collaboration to address shared challenges and provides individually tailored services for the purpose of overcoming obstacles unique to each participating business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f80542-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5801/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business incubators will stimulate economic development by providing Native entrepreneurs with the tools necessary to grow businesses that offer products and services to reservation communities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f80543-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/174/s2"},"text":"Pub. L. 116–174, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-20"},"text":"Oct. 20, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/839"},"text":"134 Stat. 839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62f80544-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62f80545-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id62f80546-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/174/s1"},"text":"Pub. L. 116–174, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-20"},"text":"Oct. 20, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/839"},"text":"134 Stat. 839","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/174/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Native American Business Incubators Program Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
