{"tag":"section","attrib":{"id":"id626da006-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660"},"text":null,"children":[{"tag":"num","attrib":{"value":"1660"},"text":"§ 1660.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Urban Health Programs Branch","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id626da007-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established within the Service a Branch of Urban Health Programs which shall be responsible for carrying out the provisions of this subchapter and for providing central oversight of the programs and services authorized under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626da008-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff, services, and equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint such employees to work in the branch, including a program director, and shall provide such services and equipment, as may be necessary for it to carry out its responsibilities. The Secretary shall also analyze the need to provide at least one urban health program analyst for each area office of the Indian Health Service and shall submit his findings to the Congress as a part of the Department’s fiscal year 1993 budget request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id626da009-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tV/s510"},"text":"Pub. L. 94–437, title V, § 510","children":[],"tail":", formerly § 511, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/630/tV/s508"},"text":"Pub. L. 101–630, title V, § 508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4567"},"text":"104 Stat. 4567","children":[],"tail":"; renumbered § 510 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tV/s501/b/7"},"text":"Pub. L. 102–573, title V, § 501(b)(7)","children":[],"tail":", title IX, § 902(5)(B), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4569"},"text":"106 Stat. 4569","children":[],"tail":", 4591.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id626da00a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id626da00b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id626da00c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s902/5/B"},"text":"Pub. L. 102–573, § 902(5)(B)","children":[],"tail":", made technical amendment to section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s501/b/7"},"text":"Pub. L. 102–573, § 501(b)(7)","children":[],"tail":", inserted “and for providing central oversight of the programs and services authorized under this subchapter” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
