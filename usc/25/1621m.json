{"tag":"section","attrib":{"id":"id62642a77-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m"},"text":null,"children":[{"tag":"num","attrib":{"value":"1621m"},"text":"§ 1621m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Epidemiology centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62642a78-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of centers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62642a79-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an epidemiology center in each Service area to carry out the functions described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a7a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New centers","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62642a7b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), any new center established after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", may be operated under a grant authorized by subsection (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62642a7c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funding provided in a grant described in subparagraph (A) shall not be divisible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a7d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds not divisible","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An epidemiology center established under this subsection shall be subject to the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.),"},{"tag":"ref","attrib":{"idref":"fn002053"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002053"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" but the funds for the center shall not be divisible."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62642a7e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of centers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In consultation with and on the request of Indian tribes, tribal organizations, and urban Indian organizations, each Service area epidemiology center established under this section shall, with respect to the applicable Service area—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62642a7f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect data relating to, and monitor progress made toward meeting, each of the health status objectives of the Service, the Indian tribes, tribal organizations, and urban Indian organizations in the Service area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a80-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate existing delivery systems, data systems, and other systems that impact the improvement of Indian health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a81-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist Indian tribes, tribal organizations, and urban Indian organizations in identifying highest-priority health status objectives and the services needed to achieve those objectives, based on epidemiological data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a82-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations for the targeting of services needed by the populations served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a83-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to improve health care delivery systems for Indians and urban Indians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a84-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide requested technical assistance to Indian tribes, tribal organizations, and urban Indian organizations in the development of local health service priorities and incidence and prevalence rates of disease and other illness in the community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a85-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide disease surveillance and assist Indian tribes, tribal organizations, and urban Indian communities to promote public health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62642a86-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Centers for Disease Control and Prevention shall provide technical assistance to the centers in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62642a87-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for studies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62642a88-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to Indian tribes, tribal organizations, Indian organizations, and eligible intertribal consortia to conduct epidemiological studies of Indian communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a89-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible intertribal consortia","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An intertribal consortium or Indian organization shall be eligible to receive a grant under this subsection if the intertribal consortium is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62642a8a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporated for the primary purpose of improving Indian health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62642a8b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representative of the Indian tribes or urban Indian communities residing in the area in which the intertribal consortium is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a8c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application for a grant under this subsection shall be submitted in such manner and at such time as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a8d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An applicant for a grant under this subsection shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62642a8e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the technical, administrative, and financial expertise necessary to carry out the functions described in paragraph (5);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62642a8f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult and cooperate with providers of related health and social services in order to avoid duplication of existing services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62642a90-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate cooperation from Indian tribes or urban Indian organizations in the area to be served.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a91-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant provided under paragraph (1) may be used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62642a92-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the functions described in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62642a93-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide information to, and consult with, tribal leaders, urban Indian community leaders, and related health staff regarding health care and health service management issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62642a94-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in collaboration with Indian tribes, tribal organizations, and urban Indian organizations, to provide to the Service information regarding ways to improve the health status of Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62642a95-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62642a96-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An epidemiology center operated by a grantee pursuant to a grant awarded under subsection (d) shall be treated as a public health authority (as defined in section 164.501 of title 45, Code of Federal Regulations (or a successor regulation)) for purposes of the Health Insurance Portability and Accountability Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Public Law 104–191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/110/1936"},"text":"110 Stat. 1936","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a97-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall grant to each epidemiology center described in paragraph (1) access to use of the data, data sets, monitoring systems, delivery systems, and other protected health information in the possession of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a98-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621m/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The activities of an epidemiology center described in paragraph (1) shall be for the purposes of research and for preventing and controlling disease, injury, or disability (as those activities are described in section 164.512 of title 45, Code of Federal Regulations (or a successor regulation)), for purposes of the Health Insurance Portability and Accountability Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Public Law 104–191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/110/1936"},"text":"110 Stat. 1936","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62642a99-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tII/s214"},"text":"Pub. L. 94–437, title II, § 214","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tII/s210"},"text":"Pub. L. 102–573, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4551"},"text":"106 Stat. 4551","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62642a9a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62642a9b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62642a9c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.), referred to in subsec. (a)(3), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of this title prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Health Insurance Portability and Accountability Act of 1996, referred to in subsec. (e)(1), (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Pub. L. 104–191","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1936"},"text":"110 Stat. 1936","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1996 Amendments note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of Title 42","children":[],"tail":", The Public Health and Welfare, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62642a9d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" is based on section 130 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62642a9e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" amended section generally. Prior to amendment, section related to establishment and functions of epidemiology centers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
