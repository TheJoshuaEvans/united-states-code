{"tag":"section","attrib":{"id":"id6217df21-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s123d"},"text":null,"children":[{"tag":"num","attrib":{"value":"123d"},"text":"§ 123d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional appropriations from tribal funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to the tribal funds authorized to be expended by existing law, there is appropriated in fiscal year 1988 and thereafter to the Secretary of the Interior for the benefit of the tribes on whose behalf such funds were collected, not to exceed $1,000,000 in each fiscal year from tribal funds not otherwise available for expenditure.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6217df22-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/g/tI/s100"},"text":"Pub. L. 100–202, § 101(g) [title I, § 100]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-213"},"text":"101 Stat. 1329–213","children":[],"tail":", 1329–230.)"}],"tail":"\n"}],"tail":null}
