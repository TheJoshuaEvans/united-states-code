{"tag":"section","attrib":{"id":"id62b5305e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3105"},"text":null,"children":[{"tag":"num","attrib":{"value":"3105"},"text":"§ 3105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest management deduction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b5305f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding of deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s413"},"text":"section 413 of this title","children":[],"tail":", the Secretary shall withhold a reasonable deduction from the gross proceeds of sales of forest products harvested from Indian forest land under a timber sale contract, permit, or other harvest sale document, which has been approved by the Secretary, to cover in whole or part the cost of managing and protecting such Indian forest land."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b53060-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of deduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Deductions made pursuant to subsection (a) shall not exceed the lesser amount of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b53061-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent of gross proceeds, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53062-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of gross proceeds collected on ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":", as forest management deductions by the Secretary on such sales of Indian forest products,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless the appropriate Indian tribe consents to an increase in the deductions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b53063-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The full amount of any deduction collected by the Secretary shall be expended according to an approved expenditure plan, approved by the Secretary and the appropriate Indian tribe, for the performance of forest land management activities on the reservation from which such deductions are collected and shall be made available to the tribe, upon its request, by contract or agreement for the performance of such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b53064-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b53065-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3105/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Forest management deductions withheld pursuant to this section shall not be available to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b53066-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3105/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cover the costs that are paid from funds appropriated specifically for fire suppression or pest control, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b53067-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3105/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise offset Federal appropriations for meeting the Federal trust responsibility for management of Indian forest lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53068-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3105/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No other forest management deductions derived from Indian forest lands shall be collected to be covered into the general funds of the United States Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b53069-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIII/s306"},"text":"Pub. L. 101–630, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4536"},"text":"104 Stat. 4536","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
