{"tag":"section","attrib":{"id":"id62b2e60e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3071"},"text":null,"children":[{"tag":"num","attrib":{"value":"3071"},"text":"§ 3071.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b2e60f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3071/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the trust responsibility of the United States to Indian Tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e610-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3071/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the maximum penalty for actions taken in violation of the Native American Graves Protection and Repatriation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"25 U.S.C. 3001","children":[],"tail":" et seq.) (including "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1170"},"text":"section 1170 of title 18","children":[],"tail":", as added by that Act), in order to strengthen deterrence;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e611-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3071/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to stop the export, and facilitate the international repatriation, of cultural items prohibited from being trafficked by the Native American Graves Protection and Repatriation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"25 U.S.C. 3001","children":[],"tail":" et seq.) (including "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1170"},"text":"section 1170 of title 18","children":[],"tail":", as added by that Act) and archaeological resources prohibited from being trafficked by the Archaeological Resources Protection Act of 1979 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s470aa"},"text":"16 U.S.C. 470aa","children":[],"tail":" et seq.) by—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b2e612-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3071/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explicitly prohibiting the export;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e613-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3071/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating an export certification system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e614-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3071/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" confirming the authority of the President to request from foreign nations agreements or provisional measures to prevent irremediable damage to Native American cultural heritage;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e615-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3071/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a Federal framework in order to support the voluntary return by individuals and organizations of items of tangible cultural heritage, including items covered by the Native American Graves Protection and Repatriation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"25 U.S.C. 3001","children":[],"tail":" et seq.) (including "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1170"},"text":"section 1170 of title 18","children":[],"tail":", as added by that Act) and the Archaeological Resources Protection Act of 1979 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s470aa"},"text":"16 U.S.C. 470aa","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e616-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3071/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish an interagency working group to ensure communication between Federal agencies to successfully implement this chapter, the Native American Graves Protection and Repatriation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"25 U.S.C. 3001","children":[],"tail":" et seq.) (including "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1170"},"text":"section 1170 of title 18","children":[],"tail":", as added by that Act), the Archaeological Resources Protection Act of 1979 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s470aa"},"text":"16 U.S.C. 470aa","children":[],"tail":" et seq.), and other relevant Federal laws;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e617-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3071/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a Native working group of Indian Tribes and Native Hawaiian organizations to assist in the implementation of this chapter, the Native American Graves Protection and Repatriation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"25 U.S.C. 3001","children":[],"tail":" et seq.) (including "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1170"},"text":"section 1170 of title 18","children":[],"tail":", as added by that Act), the Archaeological Resources Protection Act of 1979 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s470aa"},"text":"16 U.S.C. 470aa","children":[],"tail":" et seq.), and other relevant Federal laws;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e618-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3071/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" (commonly known as the “Freedom of Information Act”)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b2e619-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3071/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information submitted by Indian Tribes or Native Hawaiian organizations pursuant to this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e61a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3071/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information relating to an Item Requiring Export Certification for which an export certification was denied pursuant to this chapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e61b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3071/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage buyers to purchase legal contemporary art made by Native artists for commercial purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b2e61c-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/258/s2"},"text":"Pub. L. 117–258, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-21"},"text":"Dec. 21, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2372"},"text":"136 Stat. 2372","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62b2e61d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62b2e61e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62b2e61f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in the provision preceding par. (1) and in pars. (5) to (7), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/258"},"text":"Pub. L. 117–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-21"},"text":"Dec. 21, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2372"},"text":"136 Stat. 2372","children":[],"tail":", known as the Safeguard Tribal Objects of Patrimony Act of 2021, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Native American Graves Protection and Repatriation Act, referred to in pars. (2) to (6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/601"},"text":"Pub. L. 101–601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3048"},"text":"104 Stat. 3048","children":[],"tail":", which is classified principally to chapter 32 (§ 3001 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"section 3001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Archaeological Resources Protection Act of 1979, referred to in pars. (3) to (6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/95"},"text":"Pub. L. 96–95","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-31"},"text":"Oct. 31, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/721"},"text":"93 Stat. 721","children":[],"tail":", which is classified generally to chapter 1B (§ 470aa et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s470aa"},"text":"section 470aa of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62b2e620-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id62b2e621-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/258/s1"},"text":"Pub. L. 117–258, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-21"},"text":"Dec. 21, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2372"},"text":"136 Stat. 2372","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/258/s1"},"text":"“This Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1170"},"text":"section 1170 of Title 18","children":[],"tail":", Crimes and Criminal Procedure] may be cited as the ‘Safeguard Tribal Objects of Patrimony Act of 2021’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
