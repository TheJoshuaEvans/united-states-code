{"tag":"section","attrib":{"id":"id62d42ac9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4236"},"text":null,"children":[{"tag":"num","attrib":{"value":"4236"},"text":"§ 4236.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation formula","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d42aca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4236/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, by regulation issued not later than the expiration of the 6-month period beginning on ","children":[{"tag":"date","attrib":{"date":"2000-12-27"},"text":"December 27, 2000","children":[],"tail":", in the manner provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4227"},"text":"section 4227 of this title","children":[],"tail":", establish a formula to provide for the allocation of amounts available for a fiscal year for block grants under this subchapter in accordance with the requirements of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42acb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4236/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors for determination of need","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The formula under subsection (a) shall be based on factors that reflect the needs for assistance for affordable housing activities, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42acc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4236/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of low-income dwelling units owned or operated at the time pursuant to a contract between the Director and the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42acd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4236/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of poverty and economic distress and the number of Native Hawaiian families eligible to reside on the Hawaiian Home Lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42ace-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4236/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other objectively measurable conditions that the Secretary and the Director may specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42acf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4236/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other factors for consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing the formula under subsection (a), the Secretary shall consider the relative administrative capacities of the Department of Hawaiian Home Lands and other challenges faced by the Department, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42ad0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4236/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geographic distribution within Hawaiian Home Lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42ad1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4236/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical capacity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42ad2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4236/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect on ","children":[{"tag":"date","attrib":{"date":"2000-12-27"},"text":"December 27, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d42ad3-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s817"},"text":"Pub. L. 104–330, title VIII, § 817","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s203"},"text":"Pub. L. 106–568, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2890"},"text":"114 Stat. 2890","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s513"},"text":"Pub. L. 106–569, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2984"},"text":"114 Stat. 2984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d42ad4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d42ad5-4962-11f1-add1-b56d3fa293fa