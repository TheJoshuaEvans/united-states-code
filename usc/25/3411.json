{"tag":"section","attrib":{"id":"id62bc5cb7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3411"},"text":null,"children":[{"tag":"num","attrib":{"value":"3411"},"text":"§ 3411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No reduction in amounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62bc5cb8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In no case shall the amount of Federal funds available to an Indian tribe that has in place an approved plan under this chapter be reduced as a result of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5cb9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3411/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enactment of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5cba-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3411/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the approval or implementation of a plan of an Indian tribe under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5cbb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interaction with other laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The inclusion of a program in a tribal plan under this chapter shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5cbc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3411/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modify, limit, or otherwise affect the eligibility of the program for contracting under the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5cbd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3411/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminate the applicability of any provision of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.), as the provision relates to a specific program eligible for contracting under that Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62bc5cbe-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/477/s12"},"text":"Pub. L. 102–477, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2304"},"text":"106 Stat. 2304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/93/s12"},"text":"Pub. L. 115–93, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-18"},"text":"Dec. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2034"},"text":"131 Stat. 2034","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62bc5cbf-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62bc5cc0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62bc5cc1-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which is classified principally to chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62bc5cc2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/93"},"text":"Pub. L. 115–93","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “In no case shall the amount of Federal funds available to a tribal government involved in any demonstration project be reduced as a result of the enactment of this chapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
