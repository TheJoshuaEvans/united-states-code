{"tag":"section","attrib":{"id":"id62c5f948-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3801"},"text":null,"children":[{"tag":"num","attrib":{"value":"3801"},"text":"§ 3801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c5f949-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3801/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior has identified 53 dams on Indian lands that present a threat to human life in the event of a failure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c5f94a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3801/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of inadequate attention in the past to problems stemming from structural deficiencies and regular maintenance requirements for dams operated by the Bureau of Indian Affairs, unsafe Bureau dams continue to pose an imminent threat to people and property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c5f94b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3801/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" many Bureau dams have maintenance deficiencies regardless of their current safety condition classification and the deficiencies must be corrected to avoid future threats to human life and property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c5f94c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3801/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safe working dams on Indian lands are necessary to supply irrigation water, to provide flood control, to provide water for municipal, industrial, domestic, livestock, and recreation uses, and for fish and wildlife habitats; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c5f94d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3801/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is necessary to institute a regular dam maintenance and repair program, utilizing the expertise in the Bureau, Indian tribes, and other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c5f94e-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/302/s2"},"text":"Pub. L. 103–302, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1560"},"text":"108 Stat. 1560","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c5f94f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62c5f950-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id62c5f951-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/302/s1"},"text":"Pub. L. 103–302, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1560"},"text":"108 Stat. 1560","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/302/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Indian Dams Safety Act of 1994’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
