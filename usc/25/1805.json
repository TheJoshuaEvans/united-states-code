{"tag":"section","attrib":{"id":"id627e68f9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1805"},"text":null,"children":[{"tag":"num","attrib":{"value":"1805"},"text":"§ 1805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id627e68fa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1805/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627e68fb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1805/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide, upon request from a tribally controlled college or university which is receiving funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1808"},"text":"section 1808 of this title","children":[],"tail":", technical assistance either directly or through contract."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e68fc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1805/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require that a contract for technical assistance under paragraph (1) shall be awarded to an organization designated by the tribally controlled college or university to be assisted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627e68fd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1805/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No authority to enter into contracts provided by this section shall be effective except to the extent authorized in advance by appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id627e68fe-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/tI/s105"},"text":"Pub. L. 95–471, title I, § 105","children":[],"tail":", formerly § 104, "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1326"},"text":"92 Stat. 1326","children":[],"tail":"; renumbered § 105 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/192"},"text":"Pub. L. 98–192","children":[],"tail":", §§ 4(a)(1), 5, "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1336"},"text":"97 Stat. 1336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s901/b/5"},"text":"Pub. L. 105–244, title IX, § 901(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1828"},"text":"112 Stat. 1828","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s941/e"},"text":"Pub. L. 110–315, title IX, § 941(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3461"},"text":"122 Stat. 3461","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id627e68ff-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id627e6900-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id627e6901-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" inserted subsec. and par. designations and headings, designated first sentence as par. (1) of subsec. (a), designated second sentence as par. (2) of subsec. (a) and substituted “The Secretary shall require that a contract for technical assistance under paragraph (1) shall be awarded” for “In the awarding of contracts for technical assistance, preference shall be given”, and designated third sentence as subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" substituted “college or university” for “community college” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192/s5"},"text":"Pub. L. 98–192, § 5","children":[],"tail":", inserted “from a tribally controlled community college which is receiving funds under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1808"},"text":"section 1808 of this title","children":[],"tail":"” and struck out “to tribally controlled community colleges” before “either directly”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id627e6902-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id627e6903-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
