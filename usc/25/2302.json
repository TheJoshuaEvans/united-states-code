{"tag":"section","attrib":{"id":"id629af1a3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2302"},"text":null,"children":[{"tag":"num","attrib":{"value":"2302"},"text":"§ 2302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id629af1a4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized and directed to determine the portion of any unauthorized disbursement to which any individual under this chapter is entitled, and to pay to such individual the amount which the Secretary determines such individual to be entitled. Any payment under this provision shall include interest at a rate of 5 per centum per annum, simple interest, from the date on which such disbursement was made from the trust estate of the deceased Indian.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629af1a5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum amount for payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No payment shall be made to a person under subsection (a) with respect to any unauthorized disbursement from the trust estate of a deceased Indian if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629af1a6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of unauthorized disbursements from such trust estate was less than $50; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629af1a7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment (not including interest) would be less than $10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629af1a8-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/500/s3"},"text":"Pub. L. 98–500, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2317"},"text":"98 Stat. 2317","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/581/tII/s201"},"text":"Pub. L. 100–581, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-01"},"text":"Nov. 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2939"},"text":"102 Stat. 2939","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id629af1a9-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id629af1aa-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id629af1ab-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/581"},"text":"Pub. L. 100–581","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “No payment shall be made under subsection (a) with respect to any unauthorized disbursement from the trust estate of a deceased Indian if the total amount of unauthorized disbursement from such trust estate was less than $50.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
