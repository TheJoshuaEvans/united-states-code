{"tag":"section","attrib":{"id":"id62c84365-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3906"},"text":null,"children":[{"tag":"num","attrib":{"value":"3906"},"text":"§ 3906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal demonstration project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c84366-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may establish and carry out a program providing for demonstration projects involving open dumps on Indian land or Alaska Native land. It shall be the purpose of such projects to determine if there are unique cost factors involved in the cleanup and maintenance of open dumps on such land, and the extent to which advanced closure planning is necessary. Under the program, the Director is authorized to select no less than three Indian tribal governments or Alaska Native entities to participate in such demonstration projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c84367-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Criteria established by the Director for the selection and participation of an Indian tribal government or Alaska Native entity in the demonstration project shall provide that in order to be eligible to participate, an Indian tribal government or Alaska Native entity must—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c84368-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3906/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have one or more existing open dumps on Indian lands or Alaska Native lands which are under its authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c84369-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3906/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have developed a comprehensive solid waste management plan for such lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c8436a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3906/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have developed a closure and postclosure maintenance plan for each dump located on such lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c8436b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of funding for project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No demonstration project shall be funded for more than three fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c8436c-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/399/s7"},"text":"Pub. L. 103–399, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4167"},"text":"108 Stat. 4167","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
