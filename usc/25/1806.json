{"tag":"section","attrib":{"id":"id627e6904-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1806"},"text":null,"children":[{"tag":"num","attrib":{"value":"1806"},"text":"§ 1806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility studies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id627e6905-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1806/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of plans, procedures, and criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to enter into an agreement with the Secretary of Education to assist the Bureau of Indian Affairs in developing plans, procedures, and criteria for conducting the eligibility studies required by this section. Such agreement shall provide for continuing technical assistance in the conduct of such studies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627e6906-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1806/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiation by Secretary; grant applications and budgets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, within thirty days after a request by any Indian tribe, shall initiate a ","children":[{"tag":"ref","attrib":{"idref":"fn002106"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002106"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “an”."}],"tail":" eligibility study to determine whether there is justification to encourage and maintain a tribally controlled college or university, and, upon a positive determination, shall aid in the preparation of grant applications and related budgets which will insure successful operation of such an institution. Such a positive determination shall be effective for the fiscal year succeeding the fiscal year in which such determination is made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627e6907-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1806/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds to carry out the purposes of this section for any fiscal year may be drawn from either—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627e6908-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1806/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general administrative appropriations to the Secretary made after ","children":[{"tag":"date","attrib":{"date":"1978-10-17"},"text":"October 17, 1978","children":[],"tail":" for such fiscal year; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e6909-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1806/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 5 per centum of the funds appropriated to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1807"},"text":"section 1807 of this title","children":[],"tail":" for such fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id627e690a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/tI/s106"},"text":"Pub. L. 95–471, title I, § 106","children":[],"tail":", formerly § 105, "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1326"},"text":"92 Stat. 1326","children":[],"tail":"; renumbered § 106 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/192"},"text":"Pub. L. 98–192","children":[],"tail":", §§ 4(a)(1), (b)(1), 6(a), "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1336"},"text":"97 Stat. 1336","children":[],"tail":", 1337; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s901/b/5"},"text":"Pub. L. 105–244, title IX, § 901(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1828"},"text":"112 Stat. 1828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id627e690b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id627e690c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id627e690d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" substituted “college or university” for “community college”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192/s6/a/2"},"text":"Pub. L. 98–192, § 6(a)(2)","children":[],"tail":", (3), substituted “eligibility” for “feasibility” and “Secretary of Education” for “Assistant Secretary of Education of the Department of Health, Education, and Welfare”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192/s6/a/2"},"text":"Pub. L. 98–192, § 6(a)(2)","children":[],"tail":", (4), inserted provision that such positive determination be effective for fiscal year succeeding fiscal year in which such determination is made, and substituted “eligibility” for “feasibility”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192"},"text":"Pub. L. 98–192","children":[],"tail":", §§ 4(b)(1), 6(a)(5), substituted “5 per centum” for “10 per centum” and made a technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1807"},"text":"section 1807 of this title","children":[],"tail":" to reflect renumbering of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id627e690e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id627e690f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
