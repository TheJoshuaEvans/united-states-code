{"tag":"section","attrib":{"id":"id62a48e7b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2701"},"text":null,"children":[{"tag":"num","attrib":{"value":"2701"},"text":"§ 2701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a48e7c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" numerous Indian tribes have become engaged in or have licensed gaming activities on Indian lands as a means of generating tribal governmental revenue;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e7d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal courts have held that ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s81"},"text":"section 81 of this title","children":[],"tail":" requires Secretarial review of management contracts dealing with Indian gaming, but does not provide standards for approval of such contracts;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e7e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing Federal law does not provide clear standards or regulations for the conduct of gaming on Indian lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e7f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2701/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a principal goal of Federal Indian policy is to promote tribal economic development, tribal self-sufficiency, and strong tribal government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e80-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2701/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribes have the exclusive right to regulate gaming activity on Indian lands if the gaming activity is not specifically prohibited by Federal law and is conducted within a State which does not, as a matter of criminal law and public policy, prohibit such gaming activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62a48e81-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497/s2"},"text":"Pub. L. 100–497, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2467"},"text":"102 Stat. 2467","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62a48e82-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62a48e83-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id62a48e84-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497/s1"},"text":"Pub. L. 100–497, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2467"},"text":"102 Stat. 2467","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/497/s1"},"text":"“That this Act [enacting this chapter and sections 1166 to 1168 of Title 18, Crimes and Criminal Procedure] may be cited as the ‘Indian Gaming Regulatory Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
