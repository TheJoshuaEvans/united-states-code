{"tag":"section","attrib":{"id":"id628f0b1d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019"},"text":null,"children":[{"tag":"num","attrib":{"value":"2019"},"text":"§ 2019.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early childhood development program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id628f0b1e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide grants to tribes, tribal organizations, and consortia of tribes and tribal organizations to fund early childhood development programs that are operated by such tribes, organizations, or consortia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0b1f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628f0b20-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The total amount of the grants provided under subsection (a) with respect to each tribe, tribal organization, or consortium of tribes or tribal organizations for each fiscal year shall be equal to the amount which bears the same relationship to the total amount appropriated under the authority of subsection (g) for such fiscal year (less amounts provided under subsection (f)) as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628f0b21-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total number of children under 6 years of age who are members of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id628f0b22-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628f0b23-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tribe that authorized such tribal organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628f0b24-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any tribe that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id628f0b25-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of such consortium; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id628f0b26-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizes any tribal organization that is a member of such consortium; bears to","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628f0b27-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total number of all children under 6 years of age who are members of any tribe that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id628f0b28-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible to receive funds under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628f0b29-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of a consortium that is eligible to receive such funds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628f0b2a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizes a tribal organization that is eligible to receive such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628f0b2b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No grant may be provided under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628f0b2c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any tribe that has less than 500 members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628f0b2d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to any tribal organization which is authorized—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id628f0b2e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by only one tribe that has less than 500 members; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628f0b2f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by one or more tribes that have a combined total membership of less than 500 members; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628f0b30-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any consortium composed of tribes, or tribal organizations authorized by tribes, that have a combined total tribal membership of less than 500 members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0b31-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628f0b32-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant may be provided under subsection (a) to a tribe, tribal organization, or consortium of tribes and tribal organizations only if the tribe, organization, or consortium submits to the Secretary an application for the grant at such time and in such form as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628f0b33-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Applications submitted under paragraph (1) shall set forth the early childhood development program that the applicant desires to operate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0b34-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of programs funded","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The early childhood development programs that are funded by grants provided under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628f0b35-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall coordinate existing programs and may provide services that meet identified needs of parents and children under 6 years of age which are not being met by existing programs, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628f0b36-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prenatal care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628f0b37-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nutrition education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628f0b38-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health education and screening;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628f0b39-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family literacy services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628f0b3a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational testing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628f0b3b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other educational services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628f0b3c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include instruction in the language, art, and culture of the tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628f0b3d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for periodic assessment of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0b3e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of family literacy programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Family literacy programs operated under this section and other family literacy programs operated by the Bureau of Indian Affairs shall be coordinated with family literacy programs for Indian children under subpart 2 of part B of title II of the Elementary and Secondary Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6641"},"text":"20 U.S.C. 6641","children":[],"tail":" et seq.] in order to avoid duplication and to encourage the dissemination of information on quality family literacy programs serving Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0b3f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, out of funds appropriated under subsection (g), include in the grants provided under subsection (a) amounts for administrative costs incurred by the tribe, tribal organization, or consortium of tribes in establishing and maintaining the early childhood development program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0b40-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2019/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id628f0b41-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1139"},"text":"Pub. L. 95–561, title XI, § 1139","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1042"},"text":"Pub. L. 107–110, title X, § 1042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2058"},"text":"115 Stat. 2058","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/cc/1"},"text":"Pub. L. 114–95, title IX, § 9215(cc)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2173"},"text":"129 Stat. 2173","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id628f0b42-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id628f0b43-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id628f0b44-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Elementary and Secondary Education Act of 1965, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-04-11"},"text":"Apr. 11, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/27"},"text":"79 Stat. 27","children":[],"tail":". Subpart 2 of part B of title II of the Act is classified generally to subpart 2 (§ 6641 et seq.) of part B of subchapter II of chapter 70 of Title 20, Education. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id628f0b45-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2019, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1139"},"text":"Pub. L. 95–561, title XI, § 1139","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s381"},"text":"Pub. L. 103–382, title III, § 381","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4011"},"text":"108 Stat. 4011","children":[],"tail":", related to promulgation of regulations, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/362/tVIII/s801/c/5"},"text":"Pub. L. 105–362, title VIII, § 801(c)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3288"},"text":"112 Stat. 3288","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2017"},"text":"section 2017 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2019, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1139"},"text":"Pub. L. 95–561, title XI, § 1139","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2328"},"text":"92 Stat. 2328","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5117"},"text":"Pub. L. 100–297, title V, § 5117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/382"},"text":"102 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/427/s1/c/1"},"text":"Pub. L. 100–427, § 1(c)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1603"},"text":"102 Stat. 1603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/301/s5/a"},"text":"Pub. L. 101–301, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-24"},"text":"May 24, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/207"},"text":"104 Stat. 207","children":[],"tail":", defined terms used in this chapter, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id628f0b46-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" substituted “subpart 2 of part B of title II of the Elementary and Secondary Education Act of 1965” for “part B of title I of the Elementary and Secondary Education Act of 1965”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id628f0b47-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id628f0b48-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id628f0b49-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
