{"tag":"section","attrib":{"id":"id62b7a230-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210"},"text":null,"children":[{"tag":"num","attrib":{"value":"3210"},"text":"§ 3210.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Child Protection and Family Violence Prevention Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b7a231-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish within the Bureau an Indian Child Protection and Family Violence Prevention Program to provide financial assistance to any Indian tribe, tribal organization, or inter-tribal consortium for the development of an Indian Child Protection and Family Violence Prevention program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a232-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Self-Determination Act agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to enter into agreements with Indian tribes, tribal organizations, or inter-tribal consortia pursuant to the Indian Self-Determination Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.] for the establishment of Indian Child Protection and Family Violence Prevention programs on Indian reservations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a233-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation and treatment and prevention of child abuse and family violence","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Indian tribe operating an Indian Child Protection and Family Violence Prevention program established under this section shall designate the agency or officials which shall be responsible—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b7a234-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the investigation of reported cases of child abuse and child neglect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a235-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the treatment and prevention of incidents of family violence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a236-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the provision of immediate shelter and related assistance for victims of family violence and their dependents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a237-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program responsibilities and functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds provided pursuant to this section may be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ba1238-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the establishment of a child protective services program which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ba1239-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employment of child protective services staff to investigate cases of child abuse, neglect, or both,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba123a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training programs for child protective services personnel, law enforcement personnel, and judicial personnel in the investigation, prevention, and treatment of cases of child abuse and child neglect,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba123b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase of equipment to assist in the investigation of cases of child abuse and child neglect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba123c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of agreements between Tribes, States, or private agencies on the coordination of child abuse and neglect prevention, investigation, and treatment services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba123d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" child protective services operational costs including transportation, risk and protective factors assessments, family engagement and kinship navigator services, and relative searches, criminal background checks for prospective placements, and home studies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba123e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of a Tribal child protection or multidisciplinary team to assist in the prevention and investigation of child abuse and neglect;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ba123f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the establishment of a family violence prevention and treatment program which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ba1240-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employment of family violence prevention and treatment staff to respond to incidents of family violence in culturally appropriate ways,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba1241-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of immediate shelter and related assistance for victims of family violence and their dependents,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba1242-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training programs that may include culturally appropriate programs for family violence prevention and treatment personnel, law enforcement personnel, and judicial personnel in the investigation, prevention, and treatment of cases of family violence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba1243-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction or renovation of facilities for the establishment of family violence shelters;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ba1244-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the development and implementation of a multidisciplinary child abuse investigation and prosecution program which may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ba1245-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate child abuse and neglect prevention, investigation, prosecution, treatment, and counseling services,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba1246-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop protocols among related agencies to ensure that investigations of child abuse and neglect cases minimize the trauma to the child victim, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba1247-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the coordination and cooperation of law enforcement agencies, courts of competent jurisdiction, and other tribal, Federal, and State agencies through intergovernmental or interagency agreements that define and specify each party’s responsibilities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ba1248-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of tribal child protection codes and regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ba1249-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the establishment of training programs for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ba124a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional and paraprofessional personnel in the fields of medicine, law, education, social work, and other relevant fields who are engaged in, or intend to work in, the field of prevention, identification, investigation, and treatment of family violence, child abuse, and child neglect,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba124b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instruction in methods of protecting children from abuse and neglect for persons responsible for the welfare of Indian children, including parents of, and persons who work with, Indian children, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba124c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational, identification, prevention and treatment services for child abuse and child neglect in cooperation with preschool, elementary and secondary schools, or tribally controlled college or university ","children":[{"tag":"ref","attrib":{"idref":"fn002213"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002213"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “colleges or universities”."}],"tail":" (within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801"},"text":"section 1801 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ba124d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other community education efforts for tribal members (including school children) regarding issues of family violence, child abuse, and child neglect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ba124e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such other innovative and culturally relevant programs and projects as the Secretary may approve, including programs and projects for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ba124f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parental awareness and self-help,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba1250-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevention and treatment of alcohol and drug-related family violence, child abuse, and child neglect, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba1251-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/d/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" home health visitor programs,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that show promise of successfully preventing and treating cases of family violence, child abuse, and child neglect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ba1252-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002214"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002214"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. No subsec. (e) has been enacted."}],"tail":" Secretarial regulations; base support funding"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ba1253-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, with the participation of Indian tribes, shall establish, and promulgate by regulations, a formula which establishes base support funding for Indian Child Protection and Family Violence Prevention programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ba1254-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the development of regulations for base support funding for such programs, the Secretary shall develop, not later than one year after ","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"December 23, 2024","children":[],"tail":", in consultation with Indian Tribes, appropriate caseload standards and staffing requirements. Each level of funding assistance shall correspond to the staffing requirements established by the Secretary pursuant to this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ba1255-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Factors to be considered in the development of the base support funding formula shall include, but are not limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ba1256-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projected service population of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba1257-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projected service area of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba1258-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projected number of cases per month; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba1259-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special circumstances warranting additional program resources, such as high incidence of child abuse and neglect, high incidence of family violence, high incidence of violent crimes against women, or the existence of a significant victim population within the community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ba125a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The formula established pursuant to this subsection shall provide funding necessary to support not less than one child protective services or family violence caseworker, including fringe benefits and support costs, for each Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ba125b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any fiscal year that appropriations are not sufficient to fully fund Indian Child Protection and Family Violence Prevention programs at each level of assistance under the formula required to be established in this subsection, available funds for each level of assistance shall be evenly divided among the Indian Tribes qualifying for that level of assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ba125c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"December 23, 2024","children":[],"tail":", the Secretary of the Interior, acting through the Bureau of Indian Affairs, shall submit a report to Congress on the award of grants under this section. The report shall contain—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ba125d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of treatment and services for which grantees have used funds awarded under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ba125e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information that the Secretary of the Interior requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ba125f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract evaluation and annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each recipient of funds awarded pursuant to subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ba1260-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" furnish the Secretary with such information as the Secretary may require to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ba1261-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the program for which the award is made, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ba1262-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that funds are expended for the purposes for which the award was made; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ba1263-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary at the end of each fiscal year an annual report which shall include such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ba1264-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3210/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out the provisions of this section $30,000,000 for each of the fiscal years 1992, 1993, 1994, 1995, 1996, and 1997.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62ba1265-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIV/s411"},"text":"Pub. L. 101–630, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4553"},"text":"104 Stat. 4553","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/16/s1"},"text":"Pub. L. 104–16, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-06-21"},"text":"June 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/190"},"text":"109 Stat. 190","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s901/d"},"text":"Pub. L. 105–244, title IX, § 901(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1828"},"text":"112 Stat. 1828","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s941/k/2/J"},"text":"Pub. L. 110–315, title IX, § 941(k)(2)(J)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3467"},"text":"122 Stat. 3467","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/4"},"text":"Pub. L. 118–160, § 2(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2569"},"text":"138 Stat. 2569","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ba1266-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62ba1267-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62ba1268-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination Act, referred to in subsec. (b), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2206"},"text":"88 Stat. 2206","children":[],"tail":", which is classified principally to subchapter I (§ 5321 et seq.) of chapter 46 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62ba1269-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/4/A/i/I"},"text":"Pub. L. 118–160, § 2(4)(A)(i)(I)","children":[],"tail":", substituted “abuse, neglect, or both” for “abuse and child neglect”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(D) to (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/4/A/i/II"},"text":"Pub. L. 118–160, § 2(4)(A)(i)(II)","children":[],"tail":", (III), added subpars. (D) to (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/4/A/ii/I"},"text":"Pub. L. 118–160, § 2(4)(A)(ii)(I)","children":[],"tail":", inserted “in culturally appropriate ways” after “incidents of family violence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/4/A/ii/II"},"text":"Pub. L. 118–160, § 2(4)(A)(ii)(II)","children":[],"tail":", inserted “that may include culturally appropriate programs” after “training programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/4/A/iii/I"},"text":"Pub. L. 118–160, § 2(4)(A)(iii)(I)","children":[],"tail":", inserted “and neglect” after “abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/4/A/iii/II"},"text":"Pub. L. 118–160, § 2(4)(A)(iii)(II)","children":[],"tail":", substituted “and neglect cases” for “cases, to the extent practicable,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/4/B/i"},"text":"Pub. L. 118–160, § 2(4)(B)(i)","children":[],"tail":", substituted “develop, not later than one year after "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"December 23, 2024","children":[],"tail":", in consultation with Indian Tribes, appropriate caseload standards and staffing requirements” for “develop, in consultation with Indian tribes, appropriate caseload standards and staffing requirements which are comparable to standards developed by the National Association of Social Work, the Child Welfare League of America and other professional associations in the field of social work and child welfare”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/4/B/ii"},"text":"Pub. L. 118–160, § 2(4)(B)(ii)","children":[],"tail":", substituted “abuse and neglect, high incidence of family violence” for “sexual abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/4/B/iii"},"text":"Pub. L. 118–160, § 2(4)(B)(iii)","children":[],"tail":", amended par. (4) generally. Prior to amendment, par. (4) read as follows: “The formula established pursuant to this subsection shall provide funding necessary to support—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) one child protective services or family violence caseworker, including fringe benefits and support costs, for each tribe; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) an additional child protective services and family violence caseworker, including fringe benefits and support costs, for each level of assistance for which an Indian tribe qualifies.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/4/B/iv"},"text":"Pub. L. 118–160, § 2(4)(B)(iv)","children":[],"tail":", substituted “Indian Tribes” for “tribes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/4/C"},"text":"Pub. L. 118–160, § 2(4)(C)","children":[],"tail":", amended subsec. (g) generally. Prior to amendment, subsec. (g) provided that services provided under contracts made under this section shall supplement, not supplant, services from any other funds available for the same general purposes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (d)(5)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" substituted “tribally controlled college or university (within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801"},"text":"section 1801 of this title","children":[],"tail":")” for “tribally controlled community colleges (within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801"},"text":"section 1801 of this title","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (d)(5)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801"},"text":"section 1801 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/16"},"text":"Pub. L. 104–16","children":[],"tail":" substituted “1995, 1996, and 1997” for “and 1995”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62ba126a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id62ba126b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
