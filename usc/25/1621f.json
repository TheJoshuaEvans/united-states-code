{"tag":"section","attrib":{"id":"id6261b8c6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1621f"},"text":"§ 1621f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crediting of reimbursements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6261b8c7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6261b8c8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention by program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in sections 1621a(a)(2) and 1680c of this title, all reimbursements received or recovered under any of the programs described in paragraph (2), including under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1680c"},"text":"section 1680c of this title","children":[],"tail":", by reason of the provision of health services by the Service, by an Indian tribe or tribal organization, or by an urban Indian organization, shall be credited to the Service, such Indian tribe or tribal organization, or such urban Indian organization, respectively, and may be used as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1641"},"text":"section 1641 of this title","children":[],"tail":". In the case of such a service provided by or through a Service Unit, such amounts shall be credited to such unit and used for such purposes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6261b8c9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs covered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The programs referred to in paragraph (1) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6261b8ca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621f/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Titles XVIII, XIX, and XXI of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq., 1396 et seq., 1397aa et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6261b8cb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621f/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This chapter, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1680c"},"text":"section 1680c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6261b8cc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621f/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/693"},"text":"Public Law 87–693","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2651"},"text":"42 U.S.C. 2651","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6261b8cd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621f/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6261b8ce-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No offset of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Service may not offset or limit any amount obligated to any Service Unit or entity receiving funding from the Service because of the receipt of reimbursements under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6261b8cf-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tII/s207"},"text":"Pub. L. 94–437, title II, § 207","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tII/s204"},"text":"Pub. L. 100–713, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4812"},"text":"102 Stat. 4812","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s701/c/1"},"text":"Pub. L. 102–573, title VII, § 701(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4572"},"text":"106 Stat. 4572","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6261b8d0-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6261b8d1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6261b8d2-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (a)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Titles XVIII, XIX, and XXI of the Act are classified generally to subchapters XVIII (§ 1395 et seq.), XIX (§ 1396 et seq.), and XXI (§ 1397aa et seq.), respectively, of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(2)(B), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437"},"text":"Pub. L. 94–437","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1400"},"text":"90 Stat. 1400","children":[],"tail":", known as the Indian Health Care Improvement Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/693"},"text":"Public Law 87–693","children":[],"tail":", referred to in subsec. (a)(2)(C), is "},{"tag":"ref","attrib":{"href":"/us/pl/87/693"},"text":"Pub. L. 87–693","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-25"},"text":"Sept. 25, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/593"},"text":"76 Stat. 593","children":[],"tail":", popularly known as the Federal Medical Care Recovery Act, which is classified generally to chapter 32 (§ 2651 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6261b8d3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" is based on section 126 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6261b8d4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" amended section generally. Prior to amendment, section related to crediting of reimbursements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573"},"text":"Pub. L. 102–573","children":[],"tail":" made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1680c"},"text":"section 1680c of this title","children":[],"tail":" to reflect renumbering of corresponding section of original act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
