{"tag":"section","attrib":{"id":"id62ee696e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5369"},"text":null,"children":[{"tag":"num","attrib":{"value":"5369"},"text":"§ 5369.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62ee696f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5369/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided by law (including section 101(a) of the PROGRESS for Indian Tribes Act), the Secretary shall interpret each Federal law and regulation in a manner that facilitates—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee6970-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5369/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inclusion of programs in funding agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee6971-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5369/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of funding agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee6972-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5369/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation waiver","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee6973-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5369/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Indian Tribe may submit to the Secretary a written request for a waiver of applicability of a Federal regulation, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ee6974-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5369/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the specific text in the regulation sought to be waived; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ee6975-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5369/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis for the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee6976-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5369/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by the secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after receipt by the Secretary and the designated officials under paragraph (4) of a request under paragraph (1), the Secretary shall approve or deny the requested waiver in writing to the Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee6977-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5369/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extensions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The deadline described in paragraph (2) may be extended for any length of time, as agreed upon by both the Indian Tribe and the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee6978-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5369/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated officials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate one or more appropriate officials in the Department to receive a copy of the waiver request described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee6979-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5369/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grounds for denial","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may deny a request under paragraph (1) upon a specific finding by the Secretary that the identified text in the regulation may not be waived because such a waiver is prohibited by Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee697a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5369/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to make determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary fails to make a determination with respect to a waiver request within the period specified in paragraph (2) (including any extension agreed to under paragraph (3)), the Secretary shall be deemed to have agreed to the request, except that for a waiver request relating to programs eligible under section 5363(b)(2) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5363/c"},"text":"section 5363(c) of this title","children":[],"tail":", the Secretary shall be deemed to have denied the request."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee697b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5369/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A decision of the Secretary under this section shall be final for the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62ee697c-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tIV/s409"},"text":"Pub. L. 93–638, title IV, § 409","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/180/tI/s101/e"},"text":"Pub. L. 116–180, title I, § 101(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-21"},"text":"Oct. 21, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/874"},"text":"134 Stat. 874","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ee697d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62ee697e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62ee697f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 101(a) of the PROGRESS for Indian Tribes Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/180/s101/a"},"text":"section 101(a) of Pub. L. 116–180","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5361"},"text":"section 5361 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
