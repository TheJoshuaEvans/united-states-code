{"tag":"section","attrib":{"id":"id62f34b1f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5398"},"text":null,"children":[{"tag":"num","attrib":{"value":"5398"},"text":"§ 5398.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In any appeal (including civil actions) involving decisions made by the Secretary under this subchapter, the Secretary shall have the burden of proof of demonstrating by clear and convincing evidence—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34b20-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5398/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the validity of the grounds for the decision made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b21-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5398/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the decision is fully consistent with provisions and policies of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f34b22-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tV/s518"},"text":"Pub. L. 93–638, title V, § 518","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/260/s4"},"text":"Pub. L. 106–260, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-18"},"text":"Aug. 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/730"},"text":"114 Stat. 730","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62f34b23-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62f34b24-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62f34b25-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s458aaa–17"},"text":"section 458aaa–17 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
