{"tag":"section","attrib":{"id":"id621a28e6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s161d"},"text":null,"children":[{"tag":"num","attrib":{"value":"161d"},"text":"§ 161d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of accrued interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The interest accruing on Indian tribal funds under sections 161a to 161c of this title shall be subject to the same disposition as prescribed by existing law for the respective principal funds.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621a28e7-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-02-12/ch178/s4"},"text":"Feb. 12, 1929, ch. 178, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1930-06-13/ch483"},"text":"June 13, 1930, ch. 483","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/584"},"text":"46 Stat. 584","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
