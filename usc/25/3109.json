{"tag":"section","attrib":{"id":"id62b5307e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3109"},"text":null,"children":[{"tag":"num","attrib":{"value":"3109"},"text":"§ 3109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian forest land assistance account","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b5307f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of an Indian tribe, the Secretary may establish a special Indian forest land assistance account within the tribe’s trust fund account to fund the Indian forest land management activities of such tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b53080-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits and expenditures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b53081-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3109/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may deposit into the Indian forest land assistance account established pursuant to subsection (a) any funds received by the Secretary or in the Secretary’s possession from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b53082-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3109/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" non-Federal sources, if such funds are related to activities on or for the Indian forest lands of such tribe’s reservation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b53083-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3109/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donations and contributions,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b53084-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3109/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unobligated forestry appropriations for the benefit of such Indian tribe, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b53085-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3109/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" user fees or other funds transferred under Federal interagency agreements if otherwise authorized by Federal law and, if such funds are related to activities on or for the Indian forest lands of such tribe’s reservation.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Funds deposited in such account shall be for the purpose of conducting forest land management activities on the Indian forest lands of such tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53086-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3109/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds in the Indian forest land assistance account and any interest or other income earned thereon shall remain available until expended and shall not be available to otherwise offset Federal appropriations for meeting the Federal responsibility for management of Indian forest lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b53087-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of an Indian tribe or upon the Secretary’s own volition, the Secretary may conduct audits of the Indian forest land assistance account and shall publish the results of such audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b53088-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIII/s310"},"text":"Pub. L. 101–630, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4538"},"text":"104 Stat. 4538","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
