{"tag":"section","attrib":{"id":"id62701093-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1662"},"text":null,"children":[{"tag":"num","attrib":{"value":"1662"},"text":"§ 1662.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automated management information system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62701094-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1662/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62701095-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1662/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish an automated management information system for the Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62701096-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1662/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The information system established under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62701097-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1662/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial management system,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701098-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1662/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a patient care information system for each area served by the Service,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701099-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1662/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a privacy component that protects the privacy of patient information held by, or on behalf of, the Service, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6270109a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1662/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a services-based cost accounting component that provides estimates of the costs associated with the provision of specific medical treatments or services in each area office of the Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6270109b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1662/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision to Indian tribes and organizations; reimbursement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6270109c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1662/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall provide each Indian tribe and tribal organization that provides health services under a contract entered into with the Service under the Indian Self-Determination Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.] automated management information systems which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6270109d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1662/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the management information needs of such Indian tribe or tribal organization with respect to the treatment by the Indian tribe or tribal organization of patients of the Service, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6270109e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1662/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the management information needs of the Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6270109f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1662/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall reimburse each Indian tribe or tribal organization for the part of the cost of the operation of a system provided under paragraph (1) which is attributable to the treatment by such Indian tribe or tribal organization of patients of the Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627010a0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1662/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide systems under paragraph (1) to Indian tribes and tribal organizations providing health services in California by no later than ","children":[{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627010a1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1662/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, each patient shall have reasonable access to the medical or health records of such patient which are held by, or on behalf of, the Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id627010a2-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVI/s602"},"text":"Pub. L. 94–437, title VI, § 602","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tVI/s601/a"},"text":"Pub. L. 100–713, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4825"},"text":"102 Stat. 4825","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tIX/s901/3"},"text":"Pub. L. 102–573, title IX, § 901(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4591"},"text":"106 Stat. 4591","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id627010a3-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id627010a4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id627010a5-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination Act, referred to in subsec. (b)(1), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2206"},"text":"88 Stat. 2206","children":[],"tail":", which is classified principally to subchapter I (§ 5321 et seq.) of chapter 46 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id627010a6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573"},"text":"Pub. L. 102–573","children":[],"tail":" struck out par. (3) which directed Secretary to submit report to Congress no later than "},{"tag":"date","attrib":{"date":"1989-09-30"},"text":"Sept. 30, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
