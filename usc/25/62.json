{"tag":"section","attrib":{"id":"id621323e2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s62"},"text":null,"children":[{"tag":"num","attrib":{"value":"62"},"text":"§ 62.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discontinuance and transfer of agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President shall, whenever he may judge it expedient, discontinue any Indian agency, or transfer the same, from the place or tribe designated by law, to such other place or tribe as the public service may require.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621323e3-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2059.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621323e4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621323e5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id621323e6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2059 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1834-06-30/ch162/s4"},"text":"act June 30, 1834, ch. 162, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/735"},"text":"4 Stat. 735","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id621323e7-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"t