{"tag":"section","attrib":{"id":"id62ae045e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2815"},"text":null,"children":[{"tag":"num","attrib":{"value":"2815"},"text":"§ 2815.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State, tribal, and local law enforcement cooperation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General may provide technical and other assistance to State, tribal, and local governments that enter into cooperative agreements, including agreements relating to mutual aid, hot pursuit of suspects, and cross-deputization for the purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae045f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2815/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving law enforcement effectiveness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0460-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2815/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing crime in Indian country and nearby communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0461-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2815/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing successful cooperative relationships that effectively combat crime in Indian country and nearby communities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62ae0462-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s222"},"text":"Pub. L. 111–211, title II, § 222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2272"},"text":"124 Stat. 2272","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ae0463-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62ae0464-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62ae0465-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Tribal Law and Order Act of 2010, and not as part of the Indian Law Enforcement Reform Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62ae0466-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id62ae0467-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s203/a"},"text":"section 203(a) of Pub. L. 111–211","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2801"},"text":"section 2801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
