{"tag":"section","attrib":{"id":"id6293c554-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205"},"text":null,"children":[{"tag":"num","attrib":{"value":"2205"},"text":"§ 2205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal probate codes; acquisitions of fractional interests by tribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6293c555-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal probate codes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6293c556-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, any Indian tribe may adopt a tribal probate code to govern descent and distribution of trust or restricted lands that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6293c557-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located within that Indian tribe’s reservation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6293c558-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise subject to the jurisdiction of that Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6293c559-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Possible inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A tribal probate code referred to in paragraph (1) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6293c55a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules of intestate succession; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6293c55b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other tribal probate code provisions that are consistent with Federal law and that promote the policies set forth in section 102 of the Indian Land Consolidation Act Amendments of 2000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6293c55c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal probate codes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in any applicable Federal law, the Secretary shall not approve a tribal probate code, or an amendment to such a code, that prohibits the devise of an interest in trust or restricted land to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6293c55d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian lineal descendant of the original allottee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6293c55e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian who is not a member of the Indian tribe with jurisdiction over such an interest;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless the code provides for—","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6293c55f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/a/3/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the renouncing of interests to eligible devisees in accordance with the code;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6293c560-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/a/3/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opportunity for a devisee who is the spouse or lineal descendant of a testator to reserve a life estate without regard to waste; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6293c561-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/a/3/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of fair market value in the manner prescribed under subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6293c562-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial approval","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6293c563-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any tribal probate code enacted under subsection (a), and any amendment to such a tribal probate code, shall be subject to the approval of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6293c564-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and approval","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6293c565-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Indian tribe that adopts a tribal probate code under subsection (a) shall submit that code to the Secretary for review. Not later than 180 days after a tribal probate code is submitted to the Secretary under this paragraph, the Secretary shall review and approve or disapprove that tribal probate code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6293c566-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consequence of failures to approve or disapprove a tribal probate code","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary fails to approve or disapprove a tribal probate code submitted for review under subparagraph (A) by the date specified in that subparagraph, the tribal probate code shall be deemed to have been approved by the Secretary, but only to the extent that the tribal probate code is consistent with Federal law and promotes the policies set forth in section 102 of the Indian Land Consolidation Act Amendments of 2000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6293c567-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency of tribal probate code with chapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not approve a tribal probate code, or any amendment to such a code, under this paragraph unless the Secretary determines that the tribal probate code promotes the policies set forth in section 102 of the Indian Land Consolidation Act Amendments of 2000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6293c568-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Explanation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary disapproves a tribal probate code, or an amendment to such a code, under this paragraph, the Secretary shall include in the notice of disapproval to the Indian tribe a written explanation of the reasons for the disapproval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6293c569-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6293c56a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Indian tribe that amends a tribal probate code under this paragraph shall submit the amendment to the Secretary for review and approval. Not later than 60 days after receiving an amendment under this subparagraph, the Secretary shall review and approve or disapprove the amendment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6293c56b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consequence of failure to approve or disapprove an amendment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary fails to approve or disapprove an amendment submitted under clause (i), the amendment shall be deemed to have been approved by the Secretary, but only to the extent that the amendment is consistent with Federal law and promotes the policies set forth in section 102 of the Indian Land Consolidation Act ","children":[{"tag":"ref","attrib":{"idref":"fn002135"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002135"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “Amendments”."}],"tail":" of 2000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6293c56c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective dates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A tribal probate code approved under paragraph (2) shall become effective on the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6293c56d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 1 year after the date on which the Secretary makes the certification required under section 8(a)(4) of the American Indian Probate Reform Act of 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2201"},"text":"25 U.S.C. 2201","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/108/374"},"text":"Public Law 108–374","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6293c56e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 180 days after the date of approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6293c56f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6293c570-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal probate codes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each tribal probate code enacted under subsection (a) shall apply only to the estate of a decedent who dies on or after the effective date of the tribal probate code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6293c571-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments to tribal probate codes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to an amendment to a tribal probate code referred to in subparagraph (A), that amendment shall apply only to the estate of a decedent who dies on or after the effective date of the amendment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6293c572-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The repeal of a tribal probate code shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6293c573-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not become effective earlier than the date that is 180 days after the Secretary receives notice of the repeal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6293c574-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply only to the estate of a decedent who dies on or after the effective date of the repeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6293c575-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority available to Indian tribes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6293c576-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6293c577-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the owner of an interest in trust or restricted land devises an interest in such land to a non-Indian under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2206/b/2/A/ii"},"text":"section 2206(b)(2)(A)(ii) of this title","children":[],"tail":", the Indian tribe that exercises jurisdiction over the parcel of land involved may acquire such interest by paying to the Secretary the fair market value of such interest, as determined by the Secretary on the date of the decedent’s death."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6293c578-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall transfer payments received under subparagraph (A) to any person or persons who would have received an interest in land if the interest had not been acquired by the Indian tribe in accordance with this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6293c579-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6293c57a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability to certain interests","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6293c57b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to an interest in trust or restricted land if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6293c57c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while the decedent’s estate is pending before the Secretary, the non-Indian devisee renounces the interest in favor of an Indian person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6293c57d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"item","attrib":{"id":"id6293c57e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/2/A/i/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interest is part of a family farm that is devised to a member of the family of the decedent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id6293c57f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/2/A/i/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the devisee agrees in writing that the Indian tribe with jurisdiction over the land will have the opportunity to acquire the interest for fair market value if the interest is offered for sale to a person or entity that is not a member of the family of the owner of the land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6293c580-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recording of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On request by the Indian tribe described in clause (i)(II)(bb), a restriction relating to the acquisition by the Indian tribe of an interest in a family farm involved shall be recorded as part of the deed relating to the interest involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6293c581-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgage and foreclosure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in clause (i)(II) limits—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6293c582-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of an owner of land to which that clause applies to mortgage the land; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6293c583-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right of the entity holding such a mortgage to foreclose or otherwise enforce such a mortgage agreement in accordance with applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6293c584-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of “member of the family”","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph, the term “member of the family”, with respect to a decedent or landowner, means—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6293c585-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/2/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lineal descendant of a decedent or landowner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6293c586-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/2/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lineal descendant of the grandparent of a decedent or landowner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6293c587-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/2/A/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the spouse of a descendant or landowner described in subclause (I) or (II); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6293c588-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/2/A/iv/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the spouse of a decedent or landowner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6293c589-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of life estate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A non-Indian devisee described in paragraph (1), may retain a life estate in the interest involved, including a life estate to the revenue produced from the interest. The amount of any payment required under paragraph (1) shall be reduced to reflect the value of any life estate reserved by a non-Indian devisee under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6293c58a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to payments by an Indian tribe under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6293c58b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon the request of the tribe, allow a reasonable period of time, not to exceed 2 years, for the tribe to make payments of amounts due pursuant to paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6293c58c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognize alternative agreed upon exchanges of consideration or extended payment terms between the non-Indian devisee described in paragraph (1) and the tribe in satisfaction of the payment under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6293c58d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of proposed findings by tribal justice systems","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6293c58e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal justice system defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “tribal justice system” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3602"},"text":"section 3602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6293c58f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2205/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary by regulation may provide for the use of findings of fact and conclusions of law, as rendered by a tribal justice system, as proposed findings of fact and conclusions of law in the adjudication of probate proceedings by the Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6293c590-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/459/tII/s206"},"text":"Pub. L. 97–459, title II, § 206","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/462/tI/s103/3"},"text":"Pub. L. 106–462, title I, § 103(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1993"},"text":"114 Stat. 1993","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/3"},"text":"Pub. L. 108–374, § 6(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1799"},"text":"118 Stat. 1799","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/157/s3"},"text":"Pub. L. 109–157, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-30"},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2950"},"text":"119 Stat. 2950","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6293c591-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6293c592-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6293c593-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 102 of the Indian Land Consolidation Act Amendments of 2000, referred to in subsecs. (a)(2)(B), (b)(2)(B), (C), (E)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/462/s102"},"text":"section 102 of Pub. L. 106–462","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(2)(C), was in the original “this Act”, which was translated as reading “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/459"},"text":"Pub. L. 97–459","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6293c594-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2205, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/459/tII/s206"},"text":"Pub. L. 97–459, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2518"},"text":"96 Stat. 2518","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/608/s1/3"},"text":"Pub. L. 98–608, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3172"},"text":"98 Stat. 3172","children":[],"tail":", related to descent and distribution of trust or restricted or controlled lands, tribal ordinance barring nonmembers of tribe or non-Indians from inheritance by devise or descent, and limitation on life estate, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/462/tI/s103/3"},"text":"Pub. L. 106–462, title I, § 103(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1993"},"text":"114 Stat. 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6293c595-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/157/s3/1"},"text":"Pub. L. 109–157, § 3(1)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A) which read as follows: “the date specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2206/g/5"},"text":"section 2206(g)(5) of this title","children":[],"tail":"; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/157/s3/2/A"},"text":"Pub. L. 109–157, § 3(2)(A)","children":[],"tail":", substituted “section 2206(b)(2)(A)(ii)” for “section 2206(a)(6)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A)(i)(II)(bb). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/157/s3/2/B"},"text":"Pub. L. 109–157, § 3(2)(B)","children":[],"tail":", inserted “in writing” after “agrees”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/3/A"},"text":"Pub. L. 108–374, § 6(a)(3)(A)","children":[],"tail":", added par. (3) and struck out heading and text of former par. (3). Text read as follows: “The Secretary shall not approve a tribal probate code if such code prevents an Indian person from inheriting an interest in an allotment that was originally allotted to his or her lineal ancestor.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/3/B/i/I"},"text":"Pub. L. 108–374, § 6(a)(3)(B)(i)(I)","children":[],"tail":", (III), substituted “Authority” for “In general” in heading, designated existing provisions as subpar. (A), inserted heading, and struck out at end “The Secretary shall transfer such payment to the devisee.”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/3/B/i/II"},"text":"Pub. L. 108–374, § 6(a)(3)(B)(i)(II)","children":[],"tail":", which directed the substitution of “"},{"tag":"ref","attrib":{"href":"/us/usc/t25/s207/b/2/A/ii"},"text":"section 207(b)(2)(A)(ii) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t25/s207/a/6/A"},"text":"section 207(a)(6)(A) of this title","children":[],"tail":"” in the original, could not be executed, because “of this title” did not appear in the original."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/3/B/ii/I"},"text":"Pub. L. 108–374, § 6(a)(3)(B)(ii)(I)","children":[],"tail":", substituted “Inapplicability to certain interests” for “In general” in heading, designated existing provisions as cl. (i) and inserted heading, inserted subcl. (I) designation and added subcl. (II), and added cls. (ii) to (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/3/B/ii/II"},"text":"Pub. L. 108–374, § 6(a)(3)(B)(ii)(II)","children":[],"tail":", which directed the substitution of “paragraph (1)” for “subparagraph (A) or a non-Indian devisee described in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2206/a/6/B"},"text":"section 2206(a)(6)(B) of this title","children":[],"tail":"” was executed by making the substitution for language which did not contain the words “of this title” in the original, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6293c596-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6293c597-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/157"},"text":"Pub. L. 109–157","children":[],"tail":" effective as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/108/374"},"text":"Pub. L. 108–374","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/157/s9"},"text":"section 9 of Pub. L. 109–157","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5107"},"text":"section 5107 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
