{"tag":"section","attrib":{"id":"id62ae04b0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907"},"text":null,"children":[{"tag":"num","attrib":{"value":"2907"},"text":"§ 2907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey on Native American languages","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62ae04b1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2023-01-05"},"text":"January 5, 2023","children":[],"tail":", and every 5 years thereafter, the Secretary of Health and Human Services, acting through the Commissioner of the Administration for Native Americans (referred to in this section as the “Secretary”), shall undertake a survey of the use of all Native American languages in the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae04b2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to conducting each subsequent survey after the initial survey under subsection (a), the Secretary shall update the survey in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae04b3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall design the initial survey under subsection (a) and each updated survey under subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae04b4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with Indian tribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae04b5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after considering feedback received from Native American language speakers and experts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae04b6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each survey under subsection (a) shall solicit—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae04b7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on which Native American languages are currently spoken;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae04b8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimates of the number of speakers of each Native American language;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae04b9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any language usage statistics or information that the Secretary, in consultation with Indian tribes and Native American language speakers and experts, determines to be relevant and appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae04ba-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the types of Native American language maintenance and revitalization projects and practices that are currently being carried out;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae04bb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on any unmet Native American language resource needs of Indian tribes and Native American language communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae04bc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information that the Secretary, in consultation with Indian tribes and Native American language speakers and experts, determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae04bd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may coordinate, and enter into cooperative agreements with, the Director of the Bureau of the Census for the purposes of carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae04be-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach and engagement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae04bf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out outreach and engagement activities to provide Indian tribes, Native American language communities, and the public information about—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ae04c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities to provide input on the development and design of each survey under subsection (a), including information on the consultations required under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae04c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the goals and purpose of the surveys conducted under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae04c2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits and importance of participation in surveys under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae04c3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants, contracts, and cooperative agreements authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may carry out the outreach and engagement activities required under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ae04c4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae04c5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in partnership with the Bureau of the Census; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae04c6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" through grants to, or contracts or cooperative agreements with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62ae04c7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/f/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ae04c8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/f/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ae04c9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/f/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit organizations that work with Indian tribes, Native American language programs, and Native American language communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae04ca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section requires an Indian tribe, Native American language community, or Native American language speaker—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae04cb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to participate in a survey under subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae04cc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide specific or culturally sensitive information in completing such a survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae04cd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of survey materials and findings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae04ce-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2023-01-05"},"text":"January 5, 2023","children":[],"tail":", and prior to conducting each survey under subsection (a), the Secretary shall submit to the Committee on Indian Affairs of the Senate and the Committees on Education and Labor and Natural Resources of the House of Representatives, and make publicly available, a description of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ae04cf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feedback received under subsection (c) on the design of the survey;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae04d0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the form and content of the survey;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae04d1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan for deploying the survey to ensure a robust response; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae04d2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/h/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Secretary will ensure any survey enumeration efforts are culturally informed and appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae04d3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the date on which analysis of each survey under subsection (a) is completed, the Secretary shall submit to the Committee on Indian Affairs of the Senate and the Committees on Education and Labor and Natural Resources of the House of Representatives, and make publicly available, the results of the survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae04d4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated to carry out this section $1,500,000 for each fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae04d5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preceding a fiscal year during which a survey under subsection (a) is conducted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae04d6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2907/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during which a survey under that subsection is conducted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62ae04d7-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/477/tI/s108"},"text":"Pub. L. 101–477, title I, § 108","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/337/s2/b"},"text":"Pub. L. 117–337, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6153"},"text":"136 Stat. 6153","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ae04d8-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62ae04d9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id62ae04da-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
