{"tag":"section","attrib":{"id":"id624ea708-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1301"},"text":null,"children":[{"tag":"num","attrib":{"value":"1301"},"text":"§ 1301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id624ea709-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian tribe” means any tribe, band, or other group of Indians subject to the jurisdiction of the United States and recognized as possessing powers of self-government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea70a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “powers of self-government” means and includes all governmental powers possessed by an Indian tribe, executive, legislative, and judicial, and all offices, bodies, and tribunals by and through which they are executed, including courts of Indian offenses; and means the inherent power of Indian tribes, hereby recognized and affirmed, to exercise criminal jurisdiction over all Indians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea70b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian court” means any Indian tribal court or court of Indian offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea70c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian” means any person who would be subject to the jurisdiction of the United States as an Indian under section 1153, title 18, if that person were to commit an offense listed in that section in Indian country to which that section applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id624ea70d-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284/tII/s201"},"text":"Pub. L. 90–284, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/77"},"text":"82 Stat. 77","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/511/tVIII/s8077/b"},"text":"Pub. L. 101–511, title VIII, § 8077(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1892"},"text":"104 Stat. 1892","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id624ea70e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id624ea70f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id624ea710-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/511/s8077/b"},"text":"Pub. L. 101–511, § 8077(b)","children":[],"tail":", inserted at end “means the inherent power of Indian tribes, hereby recognized and affirmed, to exercise criminal jurisdiction over all Indians;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/511/s8077/c"},"text":"Pub. L. 101–511, § 8077(c)","children":[],"tail":", added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id624ea711-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id624ea712-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284"},"text":"Pub. L. 90–284","children":[],"tail":", which is classified generally to this subchapter, is popularly known as the “Indian Civil Rights Act of 1968”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id624ea713-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Time Limitation on Criminal Misdemeanor Ju­risdiction of Tribal Courts Over Non-Member Indians","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/511/tVIII/s8077/d"},"text":"Pub. L. 101–511, title VIII, § 8077(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1893"},"text":"104 Stat. 1893","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/124/s1"},"text":"Pub. L. 102–124, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-09"},"text":"Oct. 9, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/616"},"text":"105 Stat. 616","children":[],"tail":", which provided that the effects of subsecs. (b) and (c), which amended this section, as those subsections affect the criminal misdemeanor jurisdiction of tribal courts over non-member Indians have no effect after "},{"tag":"date","attrib":{"date":"1991-10-18"},"text":"Oct. 18, 1991","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/102/137"},"text":"Pub. L. 102–137","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/646"},"text":"105 Stat. 646","children":[],"tail":". Subsequent to repeal, "},{"tag":"ref","attrib":{"href":"/us/pl/102/172/tVIII/s8112A/b"},"text":"Pub. L. 102–172, title VIII, § 8112A(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-26"},"text":"Nov. 26, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1202"},"text":"105 Stat. 1202","children":[],"tail":", purported to amend "},{"tag":"ref","attrib":{"href":"/us/pl/101/511/s8077/d"},"text":"section 8077(d) of Pub. L. 101–511","children":[],"tail":" by substituting “1993” for “1991”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
