{"tag":"section","attrib":{"id":"id6268e4e5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1634"},"text":null,"children":[{"tag":"num","attrib":{"value":"1634"},"text":"§ 1634.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure of non-Service funds for renovation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6268e4e6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1634/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6268e4e7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1634/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of law, the Secretary is authorized to accept any major renovation or modernization by any Indian tribe of any Service facility, or of any other Indian health facility operated pursuant to a contract entered into under the Indian Self-Determination Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.], including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6268e4e8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1634/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any plans or designs for such renovation or modernization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6268e4e9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1634/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any renovation or modernization for which funds appropriated under any Federal law were lawfully expended,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but only if the requirements of subsection (b) are met.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e4ea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1634/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall maintain a separate priority list to address the needs of such facilities for personnel or equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e4eb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1634/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall submit to the President, for inclusion in each report required to be transmitted to the Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1671"},"text":"section 1671 of this title","children":[],"tail":", the priority list maintained pursuant to paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6268e4ec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1634/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of this subsection are met with respect to any renovation or modernization if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6268e4ed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1634/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the tribe or tribal organization—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6268e4ee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1634/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides notice to the Secretary of its intent to renovate or modernize; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6268e4ef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1634/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applies to the Secretary to be placed on a separate priority list to address the needs of such new facilities for personnel or equipment; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e4f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1634/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the renovation or modernization—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6268e4f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1634/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is approved by the appropriate area director of the Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6268e4f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1634/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is administered by the tribe in accordance with the rules and regulations prescribed by the Secretary with respect to construction or renovation of Service facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6268e4f3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1634/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery for non-use as Service facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any Service facility which has been renovated or modernized by an Indian tribe under this section ceases to be used as a Service facility during the 20-year period beginning on the date such renovation or modernization is completed, such Indian tribe shall be entitled to recover from the United States an amount which bears the same ratio to the value of such facility at the time of such cessation as the value of such renovation or modernization (less the total amount of any funds provided specifically for such facility under any Federal program that were expended for such renovation or modernization) bore to the value of such facility at the time of the completion of such renovation or modernization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6268e4f4-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tIII/s305"},"text":"Pub. L. 94–437, title III, § 305","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/537/s5"},"text":"Pub. L. 96–537, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-17"},"text":"Dec. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3175"},"text":"94 Stat. 3175","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tIII/s303/a"},"text":"Pub. L. 100–713, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4816"},"text":"102 Stat. 4816","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tIII/s305"},"text":"Pub. L. 102–573, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4563"},"text":"106 Stat. 4563","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6268e4f5-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6268e4f6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6268e4f7-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination Act, referred to in subsec. (a)(1), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2206"},"text":"88 Stat. 2206","children":[],"tail":", which is classified principally to subchapter I (§ 5321 et seq.) of chapter 46 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6268e4f8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573"},"text":"Pub. L. 102–573","children":[],"tail":" amended section generally, substituting present provisions for former provisions which related to: in subsec. (a), authority of Secretary; in subsec. (b), requirements; in subsec. (c), higher priority project; and in subsec. (d), recovery for non-use as Service facility."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/713"},"text":"Pub. L. 100–713","children":[],"tail":" amended section generally, substituting “Expenditure of non-Service funds for renovation” for “Authorization of appropriations” in section catchline and subsecs. (a) to (d) for former single unlettered par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
