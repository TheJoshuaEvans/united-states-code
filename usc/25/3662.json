{"tag":"section","attrib":{"id":"id62c3882e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3662"},"text":null,"children":[{"tag":"num","attrib":{"value":"3662"},"text":"§ 3662.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal civil legal assistance grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Attorney General, in consultation with the Office of Tribal Justice, shall award grants to non-profit entities, as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":", which provide legal assistance services for Indian tribes, members of Indian tribes, or tribal justice systems pursuant to Federal poverty guidelines that submit an application to the Attorney General in such form and manner as the Attorney General may prescribe for the provision of civil legal assistance (including guardians ad litem and court-appointed special advocates for children and juveniles) to members of Indian tribes and tribal justice systems, and/or other purposes consistent with this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62c3882f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/559/tI/s102"},"text":"Pub. L. 106–559, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2780"},"text":"114 Stat. 2780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s242/b/1"},"text":"Pub. L. 111–211, title II, § 242(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2292"},"text":"124 Stat. 2292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c38830-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62c38831-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62c38832-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211"},"text":"Pub. L. 111–211","children":[],"tail":" inserted “(including guardians ad litem and court-appointed special advocates for children and juveniles)” after “civil legal assistance”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
