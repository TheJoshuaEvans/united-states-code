{"tag":"section","attrib":{"id":"id62917bae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2105"},"text":null,"children":[{"tag":"num","attrib":{"value":"2105"},"text":"§ 2105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of other provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall affect, nor shall any Minerals Agreement approved pursuant to this chapter be subject to or limited by, sections 396a to 396g of this title, or any other law authorizing the development or disposition of the mineral resources of an Indian or Indian tribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62917baf-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/382/s6"},"text":"Pub. L. 97–382, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-22"},"text":"Dec. 22, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1940"},"text":"96 Stat. 1940","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
