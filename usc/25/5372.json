{"tag":"section","attrib":{"id":"id62ee6992-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372"},"text":null,"children":[{"tag":"num","attrib":{"value":"5372"},"text":"§ 5372.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62ee6993-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee6994-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On January 1 of each year, the Secretary shall submit to Congress a report regarding the administration of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee6995-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Indian Tribe may submit to the Office of Self-Governance and to the appropriate committees of Congress a detailed annual analysis of unmet Tribal needs for funding agreements under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee6996-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under subsection (a)(1) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee6997-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be compiled from information contained in funding agreements, annual audit reports, and data of the Secretary regarding the disposition of Federal funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee6998-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ee6999-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative costs and benefits of self-governance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ee699a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with particularity, all funds that are specifically or functionally related to the provision by the Secretary of services and benefits to self-governance Indian Tribes and members of Indian Tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ee699b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funds transferred to each Indian Tribe and the corresponding reduction in the Federal employees and workload; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ee699c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding formula for individual Tribal shares of all Central Office funds, together with the comments of affected Indian Tribes, developed under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee699d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before being submitted to Congress, be distributed to the Indian Tribes for comment (with a comment period of not less than 30 days);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee699e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the separate views and comments of each Indian Tribe or Tribal organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee699f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a list of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ee69a0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all such programs that the Secretary determines, in consultation with Indian Tribes participating in self-governance, are eligible for negotiation to be included in a funding agreement at the request of a participating Indian Tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ee69a1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all such programs which Indian Tribes have formally requested to include in a funding agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5363/c"},"text":"section 5363(c) of this title","children":[],"tail":" due to the special geographic, historical, or cultural significance of the program to the Indian Tribe, indicating whether each request was granted or denied, and stating the grounds for any denial."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee69a2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on non-BIA programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee69a3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to optimize opportunities for including non-BIA programs in agreements with Indian Tribes participating in self-governance under this subchapter, the Secretary shall review all programs administered by the Department, other than through the Bureau of Indian Affairs, the Office of the Assistant Secretary for Indian Affairs, or the Office of the Special Trustee for American Indians, without regard to the agency or office concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee69a4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programmatic targets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish programmatic targets, after consultation with Indian Tribes participating in self-governance, to encourage bureaus of the Department to ensure that an appropriate portion of those programs are available to be included in funding agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee69a5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The lists under subsection (b)(5) and targets under paragraph (2) shall be published in the Federal Register and made available to any Indian Tribe participating in self-governance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee69a6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual review","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ee69a7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall annually review and publish in the Federal Register, after consultation with Indian Tribes participating in self-governance, revised lists and programmatic targets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ee69a8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In preparing the revised lists and programmatic targets, the Secretary shall consider all programs that were eligible for contracting in the original list published in the Federal Register in 1995, except for programs specifically determined not to be contractible as a matter of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee69a9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5372/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on Central Office funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":", the Secretary shall, in consultation with Indian Tribes, develop a funding formula to determine the individual Tribal share of funds controlled by the Central Office of the Bureau of Indian Affairs and the Office of the Special Trustee for inclusion in the compacts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62ee69aa-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tIV/s412"},"text":"Pub. L. 93–638, title IV, § 412","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/180/tI/s101/e"},"text":"Pub. L. 116–180, title I, § 101(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-21"},"text":"Oct. 21, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/876"},"text":"134 Stat. 876","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ee69ab-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62ee69ac-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62ee69ad-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5365"},"text":"section 5365 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/116/180"},"text":"Pub. L. 116–180","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
