{"tag":"section","attrib":{"id":"id629d6284-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2431"},"text":null,"children":[{"tag":"num","attrib":{"value":"2431"},"text":"§ 2431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id629d6285-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2431/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the development of the Memorandum of Agreement required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2411"},"text":"section 2411 of this title","children":[],"tail":", the Secretary of the Interior, the Attorney General, and the Secretary of Health and Human Services, in cooperation with the Secretary of Education shall review and consider—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id629d6286-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2431/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal programs providing education services or benefits to Indian children,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d6287-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2431/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal, State, local, and private educational resources and programs,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d6288-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2431/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal programs providing family and social services and benefits for Indian families and children,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d6289-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2431/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal programs relating to youth employment, recreation, cultural, and community activities, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d628a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2431/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal, State, local, and private resources for programs similar to those cited in paragraphs (3) and (4),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to determine their applicability and relevance in carrying out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629d628b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2431/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The results of the review conducted under subsection (a) shall be provided to each Indian tribe as soon as possible for their consideration and use in the development or modification of a Tribal Action Plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2412"},"text":"section 2412 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629d628c-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4211"},"text":"Pub. L. 99–570, title IV, § 4211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-143"},"text":"100 Stat. 3207–143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s241/a/6"},"text":"Pub. L. 111–211, title II, § 241(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2289"},"text":"124 Stat. 2289","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id629d628d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id629d628e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id629d628f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211"},"text":"Pub. L. 111–211","children":[],"tail":" inserted “, the Attorney General,” after “the Secretary of the Interior” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
