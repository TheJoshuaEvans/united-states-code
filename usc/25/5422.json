{"tag":"section","attrib":{"id":"id62f34bc1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5422"},"text":null,"children":[{"tag":"num","attrib":{"value":"5422"},"text":"§ 5422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative services and support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f34bc2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5422/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of support by Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b) of this section, during the 5-year period beginning on the date that the Foundation is established, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34bc3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5422/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide personnel, facilities, and other administrative support services to the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34bc4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5422/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide funds to reimburse the travel expenses of the members of the Board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5421"},"text":"section 5421 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34bc5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5422/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall require and accept reimbursements from the Foundation for any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f34bc6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5422/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services provided under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f34bc7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5422/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds provided under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34bc8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5422/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Reimbursements accepted under subsection (a)(3) of this section shall be deposited in the Treasury to the credit of the appropriations then current and chargeable for the cost of providing services described in subsection (a)(1) of this section and the travel expenses described in subsection (a)(2) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34bc9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5422/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of certain services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, the Secretary may continue to provide facilities and necessary support services to the Foundation after the termination of the 5-year period specified in subsection (a) of this section, on a space available, reimbursable cost basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f34bca-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tVIII/s802"},"text":"Pub. L. 93–638, title VIII, § 802","children":[],"tail":", formerly title V, § 502, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tXIII/s1302"},"text":"Pub. L. 106–568, title XIII, § 1302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2938"},"text":"114 Stat. 2938","children":[],"tail":"; renumbered title VIII, § 802, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s231/d"},"text":"Pub. L. 111–211, title II, § 231(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2278"},"text":"124 Stat. 2278","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62f34bcb-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62f34bcc-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62f34bcd-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s458ddd–1"},"text":"section 458ddd–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62f34bce-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s231/d/3"},"text":"Pub. L. 111–211, § 231(d)(3)","children":[],"tail":", substituted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5421"},"text":"section 5421 of this title","children":[],"tail":" for reference to former "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s458bbb"},"text":"section 458bbb of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
