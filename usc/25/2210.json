{"tag":"section","attrib":{"id":"id6298a7d0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2210"},"text":null,"children":[{"tag":"num","attrib":{"value":"2210"},"text":"§ 2210.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All lands or interests in land acquired by the United States for an Indian or Indian tribe under authority of this chapter shall be exempt from Federal, State and local taxation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6298a7d1-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/459/tII/s211"},"text":"Pub. L. 97–459, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2519"},"text":"96 Stat. 2519","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
