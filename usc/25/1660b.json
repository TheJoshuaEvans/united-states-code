{"tag":"section","attrib":{"id":"id626da01d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1660b"},"text":"§ 1660b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain demonstration projects","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Tulsa Clinic and Oklahoma City Clinic demonstration projects shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id626da01e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be permanent programs within the Service’s direct care program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626da01f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to be treated as Service units and operating units in the allocation of resources and coordination of care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626da020-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to meet the requirements and definitions of an urban Indian organization in this chapter, and shall not be subject to the provisions of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.)."},{"tag":"ref","attrib":{"idref":"fn002083"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002083"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id626da021-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tV/s512"},"text":"Pub. L. 94–437, title V, § 512","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tV/s503"},"text":"Pub. L. 102–573, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4569"},"text":"106 Stat. 4569","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/256/s4/b"},"text":"Pub. L. 105–256, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-14"},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1897"},"text":"112 Stat. 1897","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id626da022-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id626da023-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id626da024-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in par. (3), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437"},"text":"Pub. L. 94–437","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1400"},"text":"90 Stat. 1400","children":[],"tail":", known as the Indian Health Care Improvement Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.), referred to in par. (3), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of this title prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id626da025-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" is based on sections 101(b)(8) and 162 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which were enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id626da026-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" amended section generally. Prior to amendment, section related to treatment of certain demonstration projects as Service units in the allocation of resources and coordination of care."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" struck out subsec. (c), which authorized appropriations to carry out this section through fiscal year 2002, prior to general amendment of section. See above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/256"},"text":"Pub. L. 105–256","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id626da027-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id626da028-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Permanent Programs Under the Direct Care Program of the Indian Health Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dE/tII"},"text":"Pub. L. 108–447, div. E, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3087"},"text":"118 Stat. 3087","children":[],"tail":", provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/447/dE/tII"},"text":"“Notwithstanding any other provision of law, the Tulsa and Oklahoma City Clinic demonstration projects shall be permanent programs under the direct care program of the Indian Health Service; shall be treated as service units and operating units in the allocation of resources and coordination of care; shall continue to meet the requirements applicable to an Urban Indian organization under this title [title II of div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":", see Tables for classification]; and shall not be subject to the Indian Self-Determination and Education Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62701029-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Extension of Terms of Projects","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/256/s4/a"},"text":"Pub. L. 105–256, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-14"},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1897"},"text":"112 Stat. 1897","children":[],"tail":", provided for extension of terms of projects referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1660b"},"text":"section 1660b of this title","children":[],"tail":" to "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
