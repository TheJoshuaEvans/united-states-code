{"tag":"section","attrib":{"id":"id62abbb04-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812"},"text":null,"children":[{"tag":"num","attrib":{"value":"2812"},"text":"§ 2812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Law and Order Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62abbb05-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a commission to be known as the Indian Law and Order Commission (referred to in this section as the “Commission”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62abbb06-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62abbb07-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall be composed of 9 members, of whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62abbb08-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 3 shall be appointed by the President, in consultation with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62abbb09-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62abbb0a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62abbb0b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 shall be appointed by the Majority Leader of the Senate, in consultation with the Chairpersons of the Committees on Indian Affairs and the Judiciary of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62abbb0c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed by the Minority Leader of the Senate, in consultation with the Vice Chairperson and Ranking Member of the Committees on Indian Affairs and the Judiciary of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62abbb0d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 shall be appointed by the Speaker of the House of Representatives, in consultation with the Chairpersons of the Committees on the Judiciary and Natural Resources of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62abbb0e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed by the Minority Leader of the House of Representatives, in consultation with the Ranking Members of the Committees on the Judiciary and Natural Resources of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abbb0f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member of the Commission shall have significant experience and expertise in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62abbb10-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian country criminal justice system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62abbb11-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" matters to be studied by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abbb12-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, the Speaker and Minority Leader of the House of Representatives, and the Majority Leader and Minority Leader of the Senate shall consult before the appointment of members of the Commission under paragraph (1) to achieve, to the maximum extent practicable, fair and equitable representation of various points of view with respect to the matters to be studied by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0403-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member shall be appointed for the life of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0404-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for initial appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appointment of the members of the Commission shall be made not later than 60 days after the date of enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0405-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vacancy in the Commission shall be filled—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ae0406-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the same manner in which the original appointment was made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae0407-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 60 days after the date on which the vacancy occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae0408-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae0409-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 15 days after the date on which all members of the Commission have been appointed, the Commission shall select 1 member to serve as Chairperson of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae040a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ae040b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall meet at the call of the Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae040c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The initial meeting shall take place not later than 30 days after the date described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae040d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Commission shall constitute a quorum, but a lesser number of members may hold hearings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae040e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may establish, by majority vote, any rules for the conduct of Commission business, in accordance with this chapter and other applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae040f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive study of criminal justice system relating to Indian country","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall conduct a comprehensive study of law enforcement and criminal justice in tribal communities, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae0410-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" jurisdiction over crimes committed in Indian country and the impact of that jurisdiction on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ae0411-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the investigation and prosecution of Indian country crimes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae0412-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residents of Indian land;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0413-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the tribal jail and Federal prisons systems and the effect of those systems with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ae0414-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing Indian country crime; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae0415-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rehabilitation of offenders;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0416-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ae0417-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal juvenile justice systems and the Federal juvenile justice system as relating to Indian country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae0418-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of those systems and related programs in preventing juvenile crime, rehabilitating Indian youth in custody, and reducing recidivism among Indian youth;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0419-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the impact of the Indian Civil Rights Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1301"},"text":"25 U.S.C. 1301","children":[],"tail":" et seq.) on—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ae041a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority of Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae041b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rights of defendants subject to tribal government authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae041c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fairness and effectiveness of tribal criminal systems; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae041d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies of such other subjects as the Commission determines relevant to achieve the purposes of the Tribal Law and Order Act of 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae041e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Taking into consideration the results of the study under paragraph (1),","children":[{"tag":"ref","attrib":{"idref":"fn002193"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002193"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection (d),”."}],"tail":" the Commission shall develop recommendations on necessary modifications and improvements to justice systems at the tribal, Federal, and State levels, including consideration of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae041f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" simplifying jurisdiction in Indian country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0420-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improving services and programs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ae0421-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent juvenile crime on Indian land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae0422-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to rehabilitate Indian youth in custody; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae0423-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce recidivism among Indian youth;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0424-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjustments to the penal authority of tribal courts and exploring alternatives to incarceration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0425-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enhanced use of chapter 43 of title 28 (commonly known as “the Federal Magistrates Act”) in Indian country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0426-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective means of protecting the rights of victims and defendants in tribal criminal justice systems (including defendants incarcerated for a period of less than 1 year);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0427-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes to the tribal jails and Federal prison systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0428-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other issues that, as determined by the Commission, would reduce violent crime in Indian country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae0429-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after the date of enactment of this Act, the Commission shall submit to the President and Congress a report that contains—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae042a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed statement of the findings and conclusions of the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae042b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recommendations of the Commission for such legislative and administrative actions as the Commission considers to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae042c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae042d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ae042e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may hold such hearings, meet and act at such times and places, take such testimony, and receive such evidence as the Commission considers to be advisable to carry out the duties of the Commission under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae042f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The hearings of the Commission under this paragraph shall be open to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0430-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Witness expenses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ae0431-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A witness requested to appear before the Commission shall be paid the same fees and allowances as are paid to witnesses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1821"},"text":"section 1821 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae0432-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Per diem and mileage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fees and allowances for a witness shall be paid from funds made available to the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0433-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information from Federal, tribal, and State agencies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ae0434-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may secure directly from a Federal agency such information as the Commission considers to be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae0435-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal and State agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may request the head of any tribal or State agency to provide to the Commission such information as the Commission considers to be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0436-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postal services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may use the United States mails in the same manner and under the same conditions as other agencies of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0437-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may accept, use, and dispose of gifts or donations of services or property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae0438-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission personnel matters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae0439-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Commission shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for an employee of an agency under subchapter I of chapter 57 of title 5, while away from the home or regular place of business of the member in the performance of the duties of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae043a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of Federal employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the affirmative vote of ⅔ of the members of the Commission and the approval of the appropriate Federal agency head, an employee of the Federal Government may be detailed to the Commission without reimbursement, and such detail shall be without interruption or loss of civil service status, benefits, or privileges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae043b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement of temporary and intermittent services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On request of the Commission, the Attorney General shall provide to the Commission, on a reimbursable basis, reasonable and appropriate office space, supplies, and administrative assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae043c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae043d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Researchers and experts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ae043e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On an affirmative vote of ⅔ of the members of the Commission, the Commission may select nongovernmental researchers and experts to assist the Commission in carrying out the duties of the Commission under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae043f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Institute of Justice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Institute of Justice may enter into a contract with the researchers and experts selected by the Commission under subparagraph (A) to provide funding in exchange for the services of the researchers and experts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0440-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection limits the ability of the Commission to enter into contracts with any other entity or organization to carry out research necessary to carry out the duties of the Commission under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae0441-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal Advisory Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae0442-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall establish a committee, to be known as the “Tribal Advisory Committee”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0443-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ae0444-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Tribal Advisory Committee shall consist of 2 representatives of Indian tribes from each region of the Bureau of Indian Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae0445-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member of the Tribal Advisory Committee shall have experience relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62ae0446-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/j/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" justice systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ae0447-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/j/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crime prevention; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ae0448-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/j/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" victim services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0449-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Tribal Advisory Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ae044a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/j/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as an advisory body to the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae044b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/j/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the Commission advice and recommendations, submit materials, documents, testimony, and such other information as the Commission determines to be necessary to carry out the duties of the Commission under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae044c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the fiscal year after ","children":[{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", out of any unobligated amounts available to the Secretary of the Interior or the Attorney General, the Secretary or the Attorney General may use to carry out this section not more than $2,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae044d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall terminate 90 days after the date on which the Commission submits the report of the Commission under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae044e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2812/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62ae044f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/379/s15"},"text":"Pub. L. 101–379, § 15","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s235"},"text":"Pub. L. 111–211, title II, § 235","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2282"},"text":"124 Stat. 2282","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tIX/s909/a"},"text":"Pub. L. 113–4, title IX, § 909(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/126"},"text":"127 Stat. 126","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/183"},"text":"Pub. L. 117–286, § 4(a)(183)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4326"},"text":"136 Stat. 4326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ae0450-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62ae0451-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62ae0452-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this Act, referred to in subsecs. (b)(5) and (f), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211"},"text":"Pub. L. 111–211","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Civil Rights Act of 1968, referred to in subsec. (d)(4), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284"},"text":"Pub. L. 90–284","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/77"},"text":"82 Stat. 77","children":[],"tail":", which is classified generally to subchapter I (§ 1301 et seq.) of chapter 15 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1301"},"text":"section 1301 of this title","children":[],"tail":" and Tables."}],"ta