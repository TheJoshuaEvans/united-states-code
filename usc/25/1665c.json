{"tag":"section","attrib":{"id":"id62728145-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1665c"},"text":"§ 1665c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive behavioral health prevention and treatment program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62728146-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62728147-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Service, shall provide a program of comprehensive behavioral health, prevention, treatment, and aftercare, which may include, if feasible and appropriate, systems of care, and shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62728148-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevention, through educational intervention, in Indian communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728149-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acute detoxification, psychiatric hospitalization, residential, and intensive outpatient treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272814a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665c/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based rehabilitation and aftercare;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272814b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665c/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community education and involvement, including extensive training of health care, educational, and community-based personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272814c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665c/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specialized residential treatment programs for high-risk populations, including pregnant and postpartum women and their children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272814d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665c/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diagnostic services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6272814e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Target populations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The target population of such programs shall be members of Indian tribes. Efforts to train and educate key members of the Indian community shall also target employees of health, education, judicial, law enforcement, legal, and social service programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6272814f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract health services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62728150-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, may enter into contracts with public or private providers of behavioral health treatment services for the purpose of carrying out the program required under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728151-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Secretary shall provide assistance to Indian tribes and tribal organizations to develop criteria for the certification of behavioral health service providers and accreditation of service facilities which meet minimum standards for such services and facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62728152-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s704"},"text":"Pub. L. 94–437, title VII, § 704","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62728153-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62728154-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62728155-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s704"},"text":"Section 704 of Pub. L. 94–437","children":[],"tail":" is based on section 181 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62728156-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1665c, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s704"},"text":"Pub. L. 94–437, title VII, § 704","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s702/a"},"text":"Pub. L. 102–573, title VII, § 702(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4574"},"text":"106 Stat. 4574","children":[],"tail":", provided for Indian Health Service program of alcohol and substance abuse detoxification and rehabilitation for Indian youth, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
