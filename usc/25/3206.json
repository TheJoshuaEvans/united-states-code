{"tag":"section","attrib":{"id":"id62b7a1b2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3206"},"text":null,"children":[{"tag":"num","attrib":{"value":"3206"},"text":"§ 3206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of parental consent","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b7a1b3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3206/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examinations and interviews","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Photographs, x-rays, medical examinations, psychological examinations, and interviews of an Indian child alleged to have been subject to abuse in Indian country shall be allowed without parental consent if local child protective services or local law enforcement officials have reason to believe the child has been subject to abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a1b4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3206/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interviews by law enforcement and child protective services officials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which officials of the local law enforcement agency or local child protective services agency have reason to believe that an Indian child has been subject to abuse in Indian country, the officials of those agencies shall be allowed to interview the child without first obtaining the consent of the parent, guardian, or legal custodian.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a1b5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3206/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of child","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Examinations and interviews of a child who may have been the subject of abuse shall be conducted under such circumstances and with such safeguards as are designed to minimize additional trauma to the child and, where time permits, shall be conducted with the advise,","children":[{"tag":"ref","attrib":{"idref":"fn002210"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002210"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “advice”."}],"tail":" or under the guidance, of a local multidisciplinary team established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3210"},"text":"section 3210 of this title","children":[],"tail":" or, in the absence of a local team, a multidisciplinary team established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3209"},"text":"section 3209 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a1b6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3206/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon a finding of reasonable suspicion that an Indian child has been the subject of abuse in Indian country, a Federal magistrate judge or United States District Court may issue an order enforcing any provision of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b7a1b7-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIV/s407"},"text":"Pub. L. 101–630, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4550"},"text":"104 Stat. 4550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s321"},"text":"Pub. L. 101–650, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5117"},"text":"104 Stat. 5117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62b7a1b8-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62b7a1b9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id62b7a1ba-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Federal magistrate judge” substituted for “Federal magistrate” in subsec. (d) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/s321"},"text":"section 321 of Pub. L. 101–650","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s631"},"text":"section 631 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
