{"tag":"section","attrib":{"id":"id6268e56b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1638b"},"text":"§ 1638b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of Buy American requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6268e56c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the requirements of the Buy American Act apply to all procurements made with funds made available to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6268e56d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to the Congress a report on the amount of procurements from foreign entities made in fiscal years 1993 and 1994 with funds made available to carry out this subchapter. Such report shall separately indicate the dollar value of items procured with such funds for which the Buy American Act was waived pursuant to the Trade Agreement Act of 1979 or any international agreement to which the United States is a party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6268e56e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent use of Made-in-America label","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If it has been finally determined by a court or Federal agency that any person intentionally affixed a label bearing a “Made in America” inscription, or any inscription with the same meaning, to any product sold in or shipped to the United States that is not made in the United States, such person shall be ineligible to receive any contract or subcontract made with funds made available to carry out this subchapter, pursuant to the debarment, suspension, and ineligibility procedures described in sections 9.400 through 9.409 of title 48, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6268e56f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Buy American Act” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “Buy American Act” means title III of the Act entitled “An Act making appropriations for the Treasury and Post Office Departments for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1934-06-30"},"text":"June 30, 1934","children":[],"tail":", and for other purposes”, approved "},{"tag":"date","attrib":{"date":"1933-03-03"},"text":"March 3, 1933","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s10a"},"text":"41 U.S.C. 10a","children":[],"tail":" et seq.) "},{"tag":"ref","attrib":{"idref":"fn002065"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002065"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6268e570-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tIII/s310"},"text":"Pub. L. 94–437, title III, § 310","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tIII/s308"},"text":"Pub. L. 102–573, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4564"},"text":"106 Stat. 4564","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6268e571-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6268e572-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6268e573-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Trade Agreement Act of 1979, referred to in subsec. (b), probably means the Trade Agreements Act of 1979, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/144"},"text":"93 Stat. 144","children":[],"tail":". For complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2501"},"text":"section 2501 of Title 19","children":[],"tail":", Customs Duties, and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title III of the Act entitled “An Act making appropriations for the Treasury and Post Office Departments for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1934-06-30"},"text":"June 30, 1934","children":[],"tail":", and for other purposes”, approved "},{"tag":"date","attrib":{"date":"1933-03-03"},"text":"March 3, 1933","children":[],"tail":", referred to in subsec. (d), is title III of "},{"tag":"ref","attrib":{"href":"/us/act/1933-03-03/ch212"},"text":"act Mar. 3, 1933, ch. 212","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/1520"},"text":"47 Stat. 1520","children":[],"tail":", known as the Buy American Act, which was classified generally to sections 10a, 10b, and 10c of former Title 41, Public Contracts, and was substantially repealed and restated in chapter 83 (§ 8301 et seq.) of Title 41, Public Contracts, by "},{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":", §§ 3, 7(b), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3677"},"text":"124 Stat. 3677","children":[],"tail":", 3855. For complete classification of title III to the Code, see Short Title of 1933 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s101"},"text":"section 101 of Title 41","children":[],"tail":" and Tables. For disposition of sections of former Title 41, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s101"},"text":"section 101 of Title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6268e574-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" is based on section 101(c)(3) of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6268e575-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" substituted “funds made available to carry out this subchapter” for “funds provided pursuant to the authorization contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1638a"},"text":"section 1638a of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
