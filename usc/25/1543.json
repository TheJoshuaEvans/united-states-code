{"tag":"section","attrib":{"id":"id6258436d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1543"},"text":null,"children":[{"tag":"num","attrib":{"value":"1543"},"text":"§ 1543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds limitation for private contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of entering into contracts pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1542"},"text":"section 1542 of this title","children":[],"tail":" in fiscal year 1985, the Secretary is authorized to use not to exceed 6 percent of any funds appropriated for any fiscal year pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1512"},"text":"section 1512 of this title","children":[],"tail":". For fiscal year 1986 and for each fiscal year thereafter, there are authorized to be appropriated such sums as may be necessary to carry out the provisions of this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6258436e-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/tV/s503"},"text":"Pub. L. 93–262, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/83"},"text":"88 Stat. 83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/449/s13"},"text":"Pub. L. 98–449, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-04"},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1726"},"text":"98 Stat. 1726","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6258436f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62584370-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62584371-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/449"},"text":"Pub. L. 98–449","children":[],"tail":" amended section generally, substituting provisions limiting funds expended for private contracts to 6 percent of appropriated funds in 1985 and authorizing the appropriation of such sums as may be necessary to carry out this subchapter in fiscal years after 1985 for provisions putting a 5 percent limitation on use of appropriated funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
