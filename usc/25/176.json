{"tag":"section","attrib":{"id":"id621c993b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s176"},"text":null,"children":[{"tag":"num","attrib":{"value":"176"},"text":"§ 176.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey of reservations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever it becomes necessary to survey any Indian or other reservations, or any lands, the same shall be surveyed under the direction and control of the Bureau of Land Management, and as nearly as may be in conformity to the rules and regulations under which other public lands are surveyed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621c993c-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2115; 1946 Reorg. Plan No. 3, § 403, eff. ","children":[{"tag":"date","attrib":{"date":"1946-07-16"},"text":"July 16, 1946","children":[],"tail":", 11 F.R. 7876, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1100"},"text":"60 Stat. 1100","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621c993d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621c993e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id621c993f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2115 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-04-08/ch48/s6"},"text":"act Apr. 8, 1864, ch. 48, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/41"},"text":"13 Stat. 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id621c9940-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id621c9941-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Bureau of Land Management” substituted in text for “General Land Office” pursuant to section 403 of Reorg. Plan No. 3 of 1946, set out in the Appendix to Title 5, which established the Bureau and transferred thereto the powers and duties of the General Land Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
