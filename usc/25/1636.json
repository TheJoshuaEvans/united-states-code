{"tag":"section","attrib":{"id":"id6268e4fc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636"},"text":null,"children":[{"tag":"num","attrib":{"value":"1636"},"text":"§ 1636.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program for construction, expansion, and modernization of small ambulatory care facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6268e4fd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6268e4fe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, acting through the Service, shall make grants to tribes and tribal organizations for the construction, expansion, or modernization of facilities for the provision of ambulatory care services to eligible Indians (and noneligible persons as provided in subsection (c)(1)(C)). A grant made under this section may cover up to 100 percent of the costs of such construction, expansion, or modernization. For the purposes of this section, the term “construction” includes the replacement of an existing facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e4ff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A grant under paragraph (1) may only be made to a tribe or tribal organization operating an Indian health facility (other than a facility owned or constructed by the Service, including a facility originally owned or constructed by the Service and transferred to a tribe or tribal organization) pursuant to a contract entered into under the Indian Self-Determination Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6268e500-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6268e501-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A grant provided under this section may be used only for the construction, expansion, or modernization (including the planning and design of such construction, expansion, or modernization) of an ambulatory care facility—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6268e502-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located apart from a hospital;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6268e503-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not funded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1631"},"text":"section 1631 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1637"},"text":"section 1637 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6268e504-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which, upon completion of such construction, expansion, or modernization will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6268e505-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a total capacity appropriate to its projected service population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6268e506-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve no less than 500 eligible Indians annually; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6268e507-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide ambulatory care in a service area (specified in the contract entered into under the Indian Self-Determination Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.]) with a population of not less than 2,000 eligible Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e508-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirements of clauses (ii) and (iii) of paragraph (1)(C) shall not apply to a tribe or tribal organization applying for a grant under this section whose tribal government offices are located on an island.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6268e509-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6268e50a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No grant may be made under this section unless an application for such a grant has been submitted to and approved by the Secretary. An application for a grant under this section shall be submitted in such form and manner as the Secretary shall by regulation prescribe and shall set forth reasonable assurance by the applicant that, at all times after the construction, expansion, or modernization of a facility carried out pursuant to a grant received under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6268e50b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate financial support will be available for the provision of services at such facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6268e50c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such facility will be available to eligible Indians without regard to ability to pay or source of payment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6268e50d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such facility will, as feasible without diminishing the quality or quantity of services provided to eligible Indians, serve noneligible persons on a cost basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e50e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In awarding grants under this section, the Secretary shall give priority to tribes and tribal organizations that demonstrate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6268e50f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a need for increased ambulatory care services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6268e510-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insufficient capacity to deliver such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6268e511-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1636/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of interest to United States upon cessation of facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any facility (or portion thereof) with respect to which funds have been paid under this section, ceases, at any time after completion of the construction, expansion, or modernization carried out with such funds, to be utilized for the purposes of providing ambulatory care services to eligible Indians, all of the right, title, and interest in and to such facility (or portion thereof) shall transfer to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6268e512-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tIII/s306"},"text":"Pub. L. 94–437, title III, § 306","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tIII/s304"},"text":"Pub. L. 100–713, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4817"},"text":"102 Stat. 4817","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tIII/s303"},"text":"Pub. L. 102–573, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4561"},"text":"106 Stat. 4561","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6268e513-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6268e514-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6268e515-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination Act, referred to in subsecs. (a)(2) and (b)(1)(C)(iii), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2206"},"text":"88 Stat. 2206","children":[],"tail":", which is classified principally to subchapter I (§ 5321 et seq.) of chapter 46 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6268e516-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573"},"text":"Pub. L. 102–573","children":[],"tail":" amended section generally, substituting provisions relating to grant program for construction, expansion, and modernization of small ambulatory care facilities for provisions relating to conveyance of certain real property under Alaska Native Claims Settlement Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
