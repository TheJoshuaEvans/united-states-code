{"tag":"section","attrib":{"id":"id62773c99-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1678"},"text":null,"children":[{"tag":"num","attrib":{"value":"1678"},"text":"§ 1678.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arizona as contract health service delivery area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62773c9a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1678/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State of Arizona shall be designated as a contract health service delivery area by the Service for the purpose of providing contract health care services to members of Indian tribes in the State of Arizona.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62773c9b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1678/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Service shall not curtail any health care services provided to Indians residing on reservations in the State of Arizona if the curtailment is due to the provision of contract services in that State pursuant to the designation of the State as a contract health service delivery area by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62773c9c-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s808"},"text":"Pub. L. 94–437, title VIII, § 808","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62773c9d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62773c9e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62773c9f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s808"},"text":"Section 808 of Pub. L. 94–437","children":[],"tail":" is based on section 192(1) of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62773ca0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1678, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s808"},"text":"Pub. L. 94–437, title VIII, § 808","children":[],"tail":", formerly title VII, § 708, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/537/s8/b"},"text":"Pub. L. 96–537, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-17"},