{"tag":"section","attrib":{"id":"id62e9ad84-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348"},"text":null,"children":[{"tag":"num","attrib":{"value":"5348"},"text":"§ 5348.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of student count","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62e9ad85-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of sections 5342 to 5348 of this title, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62e9ad86-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting party","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contracting party” means an entity that has a contract through a program authorized under sections 5342 to 5348 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62e9ad87-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible entity” means an entity that is eligible to apply for a contract for a supplemental or operational support program under sections 5342 to 5348 of this title, as outlined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5342"},"text":"section 5342 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62e9ad88-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing contracting party","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “existing contracting party” means a contracting party that has a contract under sections 5342 to 5348 of this title that is in effect on ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62e9ad89-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" JOM Modernization Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “JOM Modernization Act” means the Johnson-O’Malley Supplemental Indian Education Program Modernization Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62e9ad8a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New contracting party","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “new contracting party” means an entity that enters into a contract under sections 5342 to 5348 of this title after ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62e9ad8b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62e9ad8c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of the number of eligible Indian students","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62e9ad8d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial determinations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62e9ad8e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make an initial determination of the number of eligible Indian students served or potentially served by each eligible entity in accordance with subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62e9ad8f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process for making the initial determination","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62e9ad90-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preliminary report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":", the Secretary shall publish a preliminary report describing the number of eligible Indian students served or potentially served by each eligible entity, using the most applicable and accurate data (as determined by the Secretary in consultation with eligible entities) from the fiscal year preceding the fiscal year for which the initial determination is to be made from—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id62e9ad91-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/b/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of the Census;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62e9ad92-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/b/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Center for Education Statistics; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62e9ad93-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/b/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Indian Education of the Department of Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62e9ad94-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data reconciliation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To improve the accuracy of the preliminary report described in clause (i) prior to publishing, the Secretary shall reconcile the data described in the preliminary report with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62e9ad95-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each existing contracting party’s data regarding the number of eligible Indian students served by the existing contracting party for the fiscal year preceding the fiscal year for which the initial determination is made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62e9ad96-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifiable tribal enrollment information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62e9ad97-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comment period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After publishing the preliminary report under clause (i) in accordance with clause (ii), the Secretary shall establish a 60-day comment period to gain feedback about the preliminary report from eligible entities, which the Secretary shall take into consideration in preparing the final report described in clause (iv).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62e9ad98-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after concluding the consultation described in clause (iii), the Secretary shall publish a final report on the initial determination of the number of eligible Indian students served or potentially served by each eligible entity, including justification for not including any feedback gained during such consultation, if applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62e9ad99-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent academic years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each academic year following the fiscal year for which an initial determination is made under paragraph (1) to determine the number of eligible Indian students served or potentially served by a contracting party, the Secretary shall determine the number of eligible Indian students served by the contracting party based on the reported eligible Indian student count numbers identified through the reporting process described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62e9ad9a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting party student count reporting compliance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62e9ad9b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each academic year following the fiscal year for which an initial determination is made under subsection (b) to determine the number of eligible Indian students served or potentially served by a contracting party, the contracting party shall submit to the Secretary a report describing the number of eligible Indian students who were served using amounts allocated to such party under sections 5342 to 5348 of this title during the previous fiscal year. The report shall also include an accounting of the amounts and purposes for which the contract funds were expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62e9ad9c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to comply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A contracting party that fails to submit a report under paragraph (1) shall receive no amounts under sections 5342 to 5348 of this title for the fiscal year following the academic year for which the report should have been submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62e9ad9d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide contracting parties with timely information relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62e9ad9e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initial and final reporting deadlines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62e9ad9f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consequences of failure to comply outlined in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62e9ada0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Bureau of Indian Education, shall provide technical assistance and training on compliance with the reporting requirements of this subsection to contracting parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62e9ada1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62e9ada2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prepare an annual report, including the most recent determination of the number of eligible Indian students served by each contracting party, recommendations on appropriate funding levels for the program based on such determination, and an assessment of the contracts under sections 5342 to 5348 of this title that the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62e9ada3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include in the budget request of the Department of the Interior for each fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62e9ada4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall submit to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62e9ada5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Indian Affairs of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62e9ada6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subcommittee on Interior, Environment, and Related Agencies of the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62e9ada7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Education and the Workforce of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62e9ada8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/d/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subcommittee on Interior, Environment, and Related Agencies of the Committee on Appropriations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62e9ada9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall make publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62e9adaa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of preparation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prepare the report under paragraph (1) in a manner so as to prevent or minimize new administrative burdens on contracting parties receiving funds under sections 5342 to 5348 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62e9adab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hold harmless","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62e9adac-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial hold harmless","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62e9adad-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided under subparagraph (B) and subject to subparagraphs (C) and (D), for a fiscal year, an existing contracting party shall not receive an amount under sections 5342 to 5348 of this title that is less than the amount that such existing contracting party received under sections 5342 to 5348 of this title for the fiscal year preceding ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62e9adae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62e9adaf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An existing contracting party shall receive an amount under sections 5342 to 5348 of this title for a fiscal year that is less than the amount that the existing contracting party received under sections 5342 to 5348 of this title for the fiscal year preceding ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":", if one or more of the following conditions is met:"}],"tail":null},{"tag":"subclause","attrib":{"id":"id62e9adb0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/e/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The existing contracting party failed to submit a complete report described in subsection (c) that was most recently due from the date of the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62e9adb1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/e/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations of contract or law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary has found that the existing contracting party has violated the terms of a contract entered into under sections 5342 to 5348 of this title or has otherwise violated Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62e9adb2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/e/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student count decrease","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The number of eligible Indian students reported by such existing contracting party under subsection (c) has decreased below the number of eligible Indian students served by the existing contracting party in the fiscal year preceding ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62e9adb3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of funding reduction for existing contracting parties reporting decreased student counts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A reduction in an amount pursuant to clause (i)(III) shall not be done in such a manner that the existing contracting party receives an amount of funding per eligible Indian student that is less than the amount of funding per eligible Indian student such party received for the fiscal year preceding ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62e9adb4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratable reductions in appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the funds available under sections 5342 to 5348 of this title for a fiscal year are insufficient to pay the full amounts that all existing contracting parties are eligible to receive under subparagraph (A) for the fiscal year, the Secretary shall ratably reduce those amounts for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62e9adb5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This paragraph shall cease to be effective 4 years after ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62e9adb6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum decrease after 4 years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning 4 years after ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":", no contracting party shall receive for a fiscal year more than a 10 percent decrease in funding per eligible Indian student from the previous fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62e9adb7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding allocation and reform","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62e9adb8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding reform","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make recommendations for legislation to increase the amount of funds available per eligible Indian student through contracts under sections 5342 to 5348 of this title to equal to or greater than the amount of funds that were available per eligible Indian student through contracts under sections 5342 to 5348 of this title for fiscal year 1995, and attempt to identify additional sources of funding that do not reallocate existing funds otherwise utilized by Indian students served—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62e9adb9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Bureau of Indian Education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62e9adba-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under title VI of the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7401"},"text":"20 U.S.C. 7401","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62e9adbb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increases in program funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62e9adbc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (e) and subparagraph (B), for any fiscal year for which the amount appropriated to carry out sections 5342 to 5348 of this title exceeds the amount appropriated to carry out sections 5342 to 5348 of this title for the preceding fiscal year, the excess amounts shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62e9adbd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be allocated only to those contracting parties that did not receive their full per student funding allocation for the previous fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62e9adbe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be allocated first to new contracting parties that did not receive their full per student funding allocation for the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62e9adbf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parity in funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall have no effect after the first fiscal year for which each contracting party receives their full per student funding allocation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62e9adc0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increased geographical and tribal participation in the Johnson-O’Malley supplementary education program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the Secretary shall consult with Indian tribes and contact State educational agencies, local educational agencies, and Alaska Native organizations that have not previously entered into a contract under sections 5342 to 5348 of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62e9adc1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the interest of the Indian tribes, State educational agencies, local educational agencies, and Alaska Native organizations, in entering into such contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62e9adc2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to share information relating to the process for entering into a contract under sections 5342 to 5348 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62e9adc3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62e9adc4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":", the Secretary, acting through the Director of the Bureau of Indian Education, shall undertake and complete a rulemaking process, following the provisions of subchapter II of chapter 5 of title 5, to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62e9adc5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine how the regulatory definition of “eligible Indian student” may be revised to clarify eligibility requirements for contracting parties under sections 5342 to 5348 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62e9adc6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine, as necessary, how the funding formula described in section 273.31 of title 25, Code of Federal Regulations (as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":") may be clarified and revised to ensure full participation of contracting parties and provide clarity on the funding process under sections 5342 to 5348 of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62e9adc7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise reconcile and modernize the rules to comport with the activities of the contracting parties under sections 5342 to 5348 of this title as of ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62e9adc8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date the rulemaking under paragraph (1) is complete, the Secretary shall submit a report to Congress describing the results of such rulemaking and necessary recommendations to ensure the full implementation of such rulemaking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62e9adc9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student privacy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that data is collected and each report is prepared under this section in a manner that protects the rights of eligible Indian students in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232g"},"text":"section 1232g of title 20","children":[],"tail":" (commonly referred to as the Family Educational Rights and Privacy Act of 1974)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ec1eca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after the final report described in subsection (b)(1)(B)(iv) is published, the Comptroller General shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ec1ecb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct a review of the implementation of this section during the preceding 2-year period, including any factors impacting—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ec1ecc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accuracy of the determinations of the number of eligible Indian students under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1ecd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the communication between the Bureau of Indian Education and contracting parties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1ece-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/j/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts by the Bureau of Indian Education to ensure accurate and sufficient distribution of funding for Indian students;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1ecf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit a report describing the results of the review under paragraph (1) to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ec1ed0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Indian Affairs of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1ed1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subcommittee on Interior, Environment, and Related Agencies of the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1ed2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/j/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subcommittee on Indian, Insular and Alaska Native Affairs of the Committee on Natural Resources of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1ed3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/j/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subcommittee on Interior, Environment, and Related Agencies of the Committee on Appropriations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1ed4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such report publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ec1ed5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ec1ed6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creates a new program or duplicates program activities under sections 5342 to 5348 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1ed7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5348/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" replaces or diminishes the effect of regulations to carry out sections 5342 to 5348 of this title existing on the day before ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":", unless expressly provided in this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62ec1ed8-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-04-16/ch147/s7"},"text":"Apr. 16, 1934, ch. 147, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/