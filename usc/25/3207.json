{"tag":"section","attrib":{"id":"id62b7a1bb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207"},"text":null,"children":[{"tag":"num","attrib":{"value":"3207"},"text":"§ 3207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Character investigations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b7a1bc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By Secretary of the Interior and Secretary of Health and Human Services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary and the Secretary of Health and Human Services shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b7a1bd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compile a list of all authorized positions within their respective departments the duties and responsibilities of which involve regular contact with, or control over, Indian children,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a1be-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an investigation of the character of each individual who is employed, or is being considered for employment, by the respective Secretary in a position listed pursuant to paragraph (1), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a1bf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe by regulations minimum standards of character that each of such individuals must meet to be appointed to such positions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a1c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The minimum standards of character that are to be prescribed under this section shall ensure that none of the individuals appointed to positions described in subsection (a) have been found guilty of, or entered a plea of nolo contendere or guilty to, any felonious offense, or any of two or more misdemeanor offenses, under Federal, State, or tribal law involving crimes of violence; sexual assault, molestation, exploitation, contact or prostitution; crimes against persons; or offenses committed against children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a1c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations by Indian tribes and tribal organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Indian tribe or tribal organization that receives funds under the Indian Self-Determination and Education Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.] or the Tribally Controlled Schools Act of 1988 ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2501"},"text":"25 U.S.C. 2501","children":[],"tail":" et seq.] shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b7a1c2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an investigation of the character of each individual who is employed, or is being considered for employment, by such tribe or tribal organization in a position that involves regular contact with, or control over, Indian children, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a1c3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ individuals in those positions only if the individuals meet standards of character, no less stringent than those prescribed under subsection (a), as the Indian tribe or tribal organization shall establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a1c4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By tribal social services agency for foster care placements in tribal court proceedings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b7a1c5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b7a1c6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered individual” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b7a1c7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual 18 years of age or older; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b7a1c8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual who the tribal social services agency determines is subject to a criminal records check under paragraph (2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a1c9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foster care placement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “foster care placement” means any action removing an Indian child from a parent or Indian custodian for temporary placement in a foster home or institution or the home of a guardian or conservator if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b7a1ca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the parent or Indian custodian cannot have the child returned on demand; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b7a1cb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62b7a1cc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parental rights have not been terminated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62b7a1cd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parental rights have been terminated but the child has not been permanently placed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a1ce-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian custodian","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Indian custodian” means any Indian—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b7a1cf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has legal custody of an Indian child under tribal law or custom or under State law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b7a1d0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to whom temporary physical care, custody, and control has been transferred by the parent of the child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a1d1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “parent” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b7a1d2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any biological parent of an Indian child; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b7a1d3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Indian who has lawfully adopted an Indian child, including adoptions under tribal law or custom.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a1d4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal court","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tribal court” means a court—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b7a1d5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with jurisdiction over foster care placements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b7a1d6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62b7a1d7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/E/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Court of Indian Offenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62b7a1d8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/E/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a court established and operated under the code or custom of an Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62b7a1d9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/E/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other administrative body of an Indian tribe that is vested with authority over foster care placements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a1da-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal social services agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tribal social services agency” means the agency of an Indian tribe that has the primary responsibility for carrying out foster care licensing or approval (as of the date on which the proceeding described in paragraph (2)(A) commences) for the Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a1db-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal records check before foster care placement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b7a1dc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (3), no foster care placement shall be finally approved and no foster care license shall be issued until the tribal social services agency—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b7a1dd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completes a criminal records check of each covered individual who resides in the household or is employed at the institution in which the foster care placement will be made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b7a1de-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concludes that each covered individual described in clause (i) meets such standards as the Indian tribe shall establish in accordance with subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a1df-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards of placement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The standards described in subparagraph (A)(ii) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b7a1e0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" requirements that each tribal social services agency described in subparagraph (A)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62b7a1e1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform criminal records checks, including fingerprint-based checks of national crime information databases (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s534/f/3"},"text":"section 534(f)(3) of title 28","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62b7a1e2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" check any abuse registries maintained by the Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62b7a1e3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" check any child abuse and neglect registry maintained by the State in which the covered individual resides for information on the covered individual, and request any other State in which the covered individual resided in the preceding 5 years, to enable the tribal social services agency to check any child abuse and neglect registry maintained by that State for such information; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b7a1e4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other additional requirement that the Indian tribe determines is necessary and permissible within the existing authority of the Indian tribe, such as the creation of voluntary agreements with State entities in order to facilitate the sharing of information related to the performance of criminal records checks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a1e5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), no foster care placement shall be ordered in any proceeding described in subparagraph (A) if an investigation described in clause (i) of that subparagraph reveals that a covered individual described in that clause has been found by a Federal, State, or tribal court to have committed any crime listed in clause (i) or (ii) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s671/a/20/A"},"text":"section 671(a)(20)(A) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a1e6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency placement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (2) shall not apply to an emergency foster care placement, as determined by a tribal social services agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a1e7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recertification of foster homes or institutions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b7a1e8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2016-06-03"},"text":"June 3, 2016","children":[],"tail":", each Indian tribe shall establish procedures to recertify homes or institutions in which foster care placements are made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a1e9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The procedures described in subparagraph (A) shall include, at a minimum, periodic intervals at which the home or institution shall be subject to recertification to ensure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b7a1ea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety of the home or institution for the Indian child; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b7a1eb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that each covered individual who resides in the home or is employed at the institution is subject to a criminal records check in accordance with this subsection, including any covered individual who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62b7a1ec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resides in the home or is employed at the institution on the date on which the procedures established under subparagraph (A) commences; ","children":[{"tag":"ref","attrib":{"idref":"fn002211"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002211"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “commence;”."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62b7a1ed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" did not reside in the home or was not employed at the institution on the date on which the investigation described in paragraph (2)(A)(i) was completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a1ee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance issued by the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The procedures established under subparagraph (A) shall be subject to any regulation or guidance issued by the Secretary that is in accordance with the purpose of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a1ef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2016-06-03"},"text":"June 3, 2016","children":[],"tail":", and after consultation with Indian tribes, the Secretary shall issue guidance regarding—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b7a1f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" procedures for a criminal records check of any covered individual who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b7a1f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resides in the home or is employed at the institution in which the foster care placement is made after the date on which the investigation described in paragraph (2)(A)(i) is completed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b7a1f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was not the subject of an investigation described in paragraph (2)(A)(i) before the foster care placement was made;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a1f3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" self-reporting requirements for foster care homes or institutions in which any covered individual described in subparagraph (A) resides if the head of the household or the operator of the institution has knowledge that the covered individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b7a1f4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been found by a Federal, State, or tribal court to have committed any crime listed in clause (i) or (ii) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s671/a/20/A"},"text":"section 671(a)(20)(A) of title 42","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b7a1f5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is listed on a registry described in clause (II) or (III) of paragraph (2)(B)(i);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a1f6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promising practices used by Indian tribes to address emergency foster care placement procedures under paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a1f7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3207/d/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for certifying compliance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b7a1f8-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIV/s408"},"text":"Pub. L. 101–630, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4551"},"text":"104 Stat. 4551","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tVIII/s814"},"text":"Pub. L. 106–568, title VIII, § 814","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2918"},"text":"114 Stat. 2918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/165/s2"},"text":"Pub. L. 114–165, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-03"},"text":"June 3, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/415"},"text":"130 Stat. 415","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62b7a1f9-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62b7a1fa-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62b7a1fb-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which is classified principally to chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Tribally Controlled Schools Act of 1988, referred to in subsec. (c), is part B (§§ 5201–5212) of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/385"},"text":"102 Stat. 385","children":[],"tail":", which is classified generally to chapter 27 (§ 2501 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2501"},"text":"section 2501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d)(5)(D), was in the original “this Act” and was translated as reading “this title”, meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630"},"text":"Pub. L. 101–630","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4544"},"text":"104 Stat. 4544","children":[],"tail":", known as the Indian Child Protection and Family Violence Prevention Act, which is classified principally to this chapter, to reflect the probable intent of Congress. For complete classification of title IV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3201"},"text":"section 3201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62b7a1fc-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/165"},"text":"Pub. L. 114–165","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568"},"text":"Pub. L. 106–568","children":[],"tail":" substituted “any felonious offense, or any of two or more misdemeanor offenses,” for “any offense” and “crimes against persons; or offenses committed against children” for “or crimes against persons”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
