{"tag":"section","attrib":{"id":"id62b075cb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3054"},"text":null,"children":[{"tag":"num","attrib":{"value":"3054"},"text":"§ 3054.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary closure for traditional and cultural purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b075cc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3054/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition of historic use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretary shall ensure access to National Forest System land by Indians for traditional and cultural purposes, in accordance with subsection (b), in recognition of the historic use by Indians of National Forest System land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b075cd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3054/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closing land from public access","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b075ce-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3054/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to close","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the approval by the Secretary of a request from an Indian tribe, the Secretary may temporarily close from public access specifically identified National Forest System land to protect the privacy of tribal activities for traditional and cultural purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b075cf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3054/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A closure of National Forest System land under paragraph (1) shall affect the smallest practicable area for the minimum period necessary for activities of the applicable Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b075d0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3054/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Access by Indian tribes to National Forest System land under this subsection shall be consistent with the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/341"},"text":"Public Law 95–341","children":[],"tail":" (commonly known as the American Indian Religious Freedom Act; "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1996"},"text":"42 U.S.C. 1996","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b075d1-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVIII/s8104"},"text":"Pub. L. 110–234, title VIII, § 8104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1288"},"text":"122 Stat. 1288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246