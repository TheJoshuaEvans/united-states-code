{"tag":"section","attrib":{"id":"id62d1e099-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4222"},"text":null,"children":[{"tag":"num","attrib":{"value":"4222"},"text":"§ 4222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Block grants for affordable housing activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d1e09a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4222/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, the Secretary shall (to the extent amounts are made available to carry out this subchapter) make a grant under this subchapter to the Department of Hawaiian Home Lands to carry out affordable housing activities for Native Hawaiian families who are eligible to reside on the Hawaiian Home Lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e09b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4222/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d1e09c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4222/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make a grant under this subchapter to the Department of Hawaiian Home Lands for a fiscal year only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d1e09d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4222/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director has submitted to the Secretary a housing plan for that fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d1e09e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4222/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4224"},"text":"section 4224 of this title","children":[],"tail":" that the housing plan complies with the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e09f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4222/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive the applicability of the requirements under paragraph (1), in part, if the Secretary finds that the Department of Hawaiian Home Lands has not complied or cannot comply with those requirements due to circumstances beyond the control of the Department of Hawaiian Home Lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e0a0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4222/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds for affordable housing activities under plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (e), amounts provided under a grant under this section may be used only for affordable housing activities under this subchapter that are consistent with a housing plan approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4224"},"text":"section 4224 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e0a1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4222/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d1e0a2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4222/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, by regulation, authorize the Department of Hawaiian Home Lands to use a percentage of any grant amounts received under this subchapter for any reasonable administrative and planning expenses of the Department relating to carrying out this subchapter and activities assisted with those amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e0a3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4222/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative and planning expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The administrative and planning expenses referred to in paragraph (1) include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d1e0a4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4222/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs for salaries of individuals engaged in administering and managing affordable housing activities assisted with grant amounts provided under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d1e0a5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4222/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses incurred in preparing a housing plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e0a6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4222/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public-private partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall make all reasonable efforts, consistent with the purposes of this subchapter, to maximize participation by the private sector, including nonprofit organizations and for-profit entities, in implementing a housing plan that has been approved by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d1e0a7-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s802"},"text":"Pub. L. 104–330, title VIII, § 802","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s203"},"text":"Pub. L. 106–568, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2877"},"text":"114 Stat. 2877","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s513"},"text":"Pub. L. 106–569, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2971"},"text":"114 Stat. 2971","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d1e0a8-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d1e0a9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62d1e0aa-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s203"},"text":"Pub. L. 106–568, § 203","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":", enacted identical sections 802 of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":". This section is based on the text of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s802"},"text":"section 802 of Pub. L. 104–330","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
