{"tag":"section","attrib":{"id":"id628a4f0b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007"},"text":null,"children":[{"tag":"num","attrib":{"value":"2007"},"text":"§ 2007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment formula","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id628a4f0c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors considered; revision to reflect standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628a4f0d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish, by regulation adopted in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2017"},"text":"section 2017 of this title","children":[],"tail":", a formula for determining the minimum annual amount of funds necessary to sustain each Bureau-funded school. In establishing such formula, the Secretary shall consider—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628a4f0e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of eligible Indian students served and total student population of the school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4f0f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" special cost factors, such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id628a4f10-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the isolation of the school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628a4f11-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for special staffing, transportation, or educational programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628a4f12-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food and housing costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628a4f13-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance and repair costs associated with the physical condition of the educational facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628a4f14-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special transportation and other costs of isolated and small schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628a4f15-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of home-living (dormitory) arrangements, where determined necessary by a tribal governing body or designated school board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628a4f16-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs associated with greater lengths of service by education personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628a4f17-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/1/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of therapeutic programs for students requiring such programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628a4f18-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/1/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special costs for gifted and talented students;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4f19-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of providing academic services which are at least equivalent to those provided by public schools in the State in which the school is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4f1a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the available funding will enable the school involved to comply with the accreditation standards applicable to the school under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2001"},"text":"section 2001 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4f1b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other relevant factors as the Secretary determines are appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628a4f1c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of formula","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628a4f1d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the establishment of the standards required in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2002"},"text":"section 2002 of this title","children":[],"tail":", the Secretary shall revise the formula established under this subsection to reflect the cost of funding such standards."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4f1e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of formula","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2003-01-01"},"text":"January 1, 2003","children":[],"tail":", the Secretary shall review the formula established under this section and shall take such steps as are necessary to increase the availability of counseling and therapeutic programs for students in off-reservation home-living (dormitory) schools and other Bureau-operated residential facilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4f1f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Concurrent with such action, the Secretary shall review the standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2002"},"text":"section 2002 of this title","children":[],"tail":" to be certain that adequate provision is made for parental notification regarding, and consent for, such counseling and therapeutic programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628a4f20-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pro rata allotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, Federal funds appropriated for the general local operation of Bureau-funded schools shall be allotted pro rata in accordance with the formula established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628a4f21-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual adjustment; reservation of amount for school board activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628a4f22-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For fiscal year 2003, and for each subsequent fiscal year, the Secretary shall adjust the formula established under subsection (a) to ensure that the formula does the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628a4f23-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Uses a weighted unit of 1.2 for each eligible Indian student enrolled in the seventh and eighth grades of the school in considering the number of eligible Indian students served by the school.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4f24-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Considers a school with an enrollment of less than 50 eligible Indian students as having an average daily attendance of 50 eligible Indian students for purposes of implementing the adjustment factor for small schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4f25-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Takes into account the provision of residential services on less than a 9-month basis at a school when the school board and supervisor of the school determine that a less than 9-month basis will be implemented for the school year involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4f26-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Uses a weighted unit of 2.0 for each eligible Indian student that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id628a4f27-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is gifted and talented; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628a4f28-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled in the school on a full-time basis,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in considering the number of eligible Indian students served by the school.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4f29-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Uses a weighted unit of 0.25 for each eligible Indian student who is enrolled in a year-long credit course in an Indian or Native language as part of the regular curriculum of a school, in considering the number of eligible Indian students served by such school. The adjustment required under this subparagraph shall be used for such school after—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id628a4f2a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the certification of the Indian or Native language curriculum by the school board of such school to the Secretary, together with an estimate of the number of full-time students expected to be enrolled in the curriculum in the second school year for which the certification is made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628a4f2b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funds appropriated for allotment under this section are designated by the appropriations Act appropriating such funds as the amount necessary to implement such adjustment at such school without reducing allotments made under this section to any school by virtue of such adjustment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628a4f2c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628a4f2d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the funds allotted in accordance with the formula established under subsection (a) for each Bureau school, the local school board of such school may reserve an amount which does not exceed the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id628a4f2e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $8,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628a4f2f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lesser of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id628a4f30-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id628a4f31-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 percent of such allotted funds,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for school board activities for such school, including (notwithstanding any other provision of law) meeting expenses and the cost of membership in, and support of, organizations engaged in activities on behalf of Indian education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4f32-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id628a4f33-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each local school board, and any agency school board that serves as a local school board for any grant or contract school, shall ensure that each individual who is a new member of the school board receives, within 1 year after the individual becomes a member of the school board, 40 hours of training relevant to that individual’s service on the board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628a4f34-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such training may include training concerning legal issues pertaining to Bureau-funded schools, legal issues pertaining to school boards, ethics, and other topics determined to be appropriate by the school board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628a4f35-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The training described in this subparagraph shall not be required, but is recommended, for a tribal governing body that serves in the capacity of a school board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628a4f36-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of amount for emergencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628a4f37-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reserve from the funds available for distribution for each fiscal year under this section an amount that, in the aggregate, equals 1 percent of the funds available for such purpose for that fiscal year, to be used, at the discretion of the Director of the Office of Indian Education Programs, to meet emergencies and unforeseen contingencies affecting the education programs funded under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628a4f38-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds reserved under this subsection may be expended only for education services or programs, including emergency repairs of educational facilities, at a schoolsite (as defined by section 2503(c)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002119"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002119"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “2502(c)(2)”."}],"tail":" of this title)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628a4f39-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds reserved under this subsection shall remain available without fiscal year limitation until expended. However, the aggregate amount available from all fiscal years may not exceed 1 percent of the current year funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628a4f3a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When the Secretary makes funds available under this subsection, the Secretary shall report such action to the appropriate committees of Congress within the annual budget submission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628a4f3b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Supplemental appropriations enacted to meet increased pay costs attributable to school level personnel shall be distributed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628a4f3c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible Indian student defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible Indian student” means a student who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628a4f3d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of, or is at least one-fourth degree Indian blood descendant of a member of, a tribe that is eligible for the special programs and services provided by the United States through the Bureau to Indians because of their status as Indians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628a4f3e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resides on or near a reservation or meets the criteria for attendance at a Bureau off-reservation home-living school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628a4f3f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled in a Bureau-funded school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628a4f40-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tuition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628a4f41-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No eligible Indian student or a student attending a Bureau school under paragraph (2)(C) may be charged tuition for attendance at a Bureau school or contract or grant school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628a4f42-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attendance of non-Indian students at Bureau schools","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may permit the attendance at a Bureau school of a student who is not an eligible Indian student if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628a4f43-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the student’s attendance will not adversely affect the school’s program for eligible Indian students because of cost, overcrowding, or violation of standards or accreditation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4f44-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the school board consents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4f45-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the student is a dependent of a Bureau, Indian Health Service, or tribal government employee who lives on or near the school site; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628a4f46-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tuition is paid for the student that is not more than the tuition charged by the nearest public school district for out-of-district students and shall be in addition to the school’s allocation under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628a4f47-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attendance of non-Indian students at contract and grant schools","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The school board of a contract or grant school may permit students who are not eligible Indian students under this subsection to attend its contract school or grant school. Any tuition collected for those students shall be in addition to funding received under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628a4f48-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds available without fiscal year limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, at the election of the school board of a Bureau school made at any time during the fiscal year, a portion equal to not more than 15 percent of the funds allocated with respect to a school under this section for any fiscal year shall remain available to the school for expenditure without fiscal year limitation. The Assistant Secretary shall take such steps as are necessary to implement this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628a4f49-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Students at Richfield dormitory, Richfield, Utah","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628a4f4a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Tuition for the instruction of each out-of-State Indian student in a home-living situation at the Richfield dormitory in Richfield, Utah, who attends Sevier County high schools in Richfield, Utah, for an academic year, shall be paid from Indian school equalization program funds authorized in this section and section 2009 ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" of this title, at a rate not to exceed the weighted amount provided for under subsection (b) for a student for that year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628a4f4b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2007/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No administrative cost funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No additional administrative cost funds shall be provided under this chapter to pay for administrative costs relating to the instruction of the students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id628a4f4c-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1127"},"text":"Pub. L. 95–561, title XI, § 1127","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1042"},"text":"Pub. L. 107–110, title X, § 1042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2028"},"text":"115 Stat. 2028","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id628a4f4d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id628a4f4e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id628a4f4f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2007, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1127"},"text":"Pub. L. 95–561, title XI, § 1127","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s381"},"text":"Pub. L. 103–382, title III, § 381","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3989"},"text":"108 Stat. 3989","children":[],"tail":", related to allotment formula, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2007, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1127"},"text":"Pub. L. 95–561, title XI, § 1127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2320"},"text":"92 Stat. 2320","children":[],"tail":", related to policies and procedures for implementation of transferred administrative functions, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id628a4f50-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id628a4f51-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
