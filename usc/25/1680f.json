{"tag":"section","attrib":{"id":"id62773cff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1680f"},"text":"§ 1680f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Health Service and Department of Veterans Affairs health facilities and services sharing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62773d00-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility study and report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall examine the feasibility of entering into an arrangement for the sharing of medical facilities and services between the Indian Health Service and the Department of Veterans Affairs and shall, in accordance with subsection (b), prepare a report on the feasibility of such an arrangement and submit such report to the Congress by no later than ","children":[{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62773d01-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonimpairment of service quality, eligibility, or priority of access","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not take any action under this section or under subchapter IV of chapter 81 of title 38 which would impair—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62773d02-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the priority access of any Indian to health care services provided through the Indian Health Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62773d03-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quality of health care services provided to any Indian through the Indian Health Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62773d04-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the priority access of any veteran to health care services provided by the Department of Veterans Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62773d05-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680f/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quality of health care services provided to any veteran by the Department of Veterans Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279ad06-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680f/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligibility of any Indian to receive health services through the Indian Health Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279ad07-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680f/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligibility of any Indian who is a veteran to receive health services through the Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6279ad08-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross utilization of services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6279ad09-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1988-12-23"},"text":"December 23, 1988","children":[],"tail":", the Director of the Indian Health Service and the Secretary of Veterans Affairs shall implement an agreement under which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6279ad0a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680f/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals in the vicinity of Roosevelt, Utah, who are eligible for health care from the Department of Veterans Affairs could obtain health care services at the facilities of the Indian Health Service located at Fort Duchesne, Utah; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ad0b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680f/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals eligible for health care from the Indian Health Service at Fort Duchesne, Utah, could obtain health care services at the George E. Wahlen Department of Veterans Affairs Medical Center located in Salt Lake City, Utah.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279ad0c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1990-11-23"},"text":"November 23, 1990","children":[],"tail":", the Secretary and the Secretary of Veterans Affairs shall jointly submit a report to the Congress on the health care services provided as a result of paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6279ad0d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to health services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed as creating any right of a veteran to obtain health services from the Indian Health Service except as provided in an agreement under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6279ad0e-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s816"},"text":"Pub. L. 94–437, title VIII, § 816","children":[],"tail":", formerly title VII, § 716, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tVII/s710"},"text":"Pub. L. 100–713, title VII, § 710","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4832"},"text":"102 Stat. 4832","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13/j/2"},"text":"Pub. L. 102–54, § 13(j)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/276"},"text":"105 Stat. 276","children":[],"tail":"; renumbered title VIII, § 816, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s701/a"},"text":"Pub. L. 102–573, title VII, § 701(a)","children":[],"tail":", (b), title IX, § 902(9), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4572"},"text":"106 Stat. 4572","children":[],"tail":", 4592; "},{"tag":"ref","attrib":{"href":"/us/pl/108/170/tII/s244"},"text":"Pub. L. 108–170, title II, § 244","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2054"},"text":"117 Stat. 2054","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6279ad0f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6279ad10-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6279ad11-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170"},"text":"Pub. L. 108–170","children":[],"tail":" substituted “George E. Wahlen Department of Veterans Affairs Medical Center” for “Department of Veterans Affairs medical center”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s902/9"},"text":"Pub. L. 102–573, § 902(9)","children":[],"tail":", amended section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsecs. (a), (b)(3), (4), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13/j/2/A"},"text":"Pub. L. 102–54, § 13(j)(2)(A)","children":[],"tail":", substituted “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13/j/2/B"},"text":"Pub. L. 102–54, § 13(j)(2)(B)","children":[],"tail":", substituted “Not later than "},{"tag":"date","attrib":{"date":"1988-12-23"},"text":"December 23, 1988","children":[],"tail":", the Director of the Indian Health Service and the Secretary of Veterans Affairs shall” for “Within 30 days after "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"November 23, 1988","children":[],"tail":", the Director of the Indian Health Service and the Administrator of Veterans’ Affairs are authorized and directed to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13/j/2/A"},"text":"Pub. L. 102–54, § 13(j)(2)(A)","children":[],"tail":", substituted “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13/j/2/C"},"text":"Pub. L. 102–54, § 13(j)(2)(C)","children":[],"tail":", substituted “Not later than "},{"tag":"date","attrib":{"date":"1990-11-23"},"text":"November 23, 1990","children":[],"tail":", the Secretary and the Secretary of Veterans Affairs shall” for “Not later than 2 years after "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"November 23, 1988","children":[],"tail":", the Secretary and the Administrator of Veterans’ Affairs shall”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6279ad12-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6279ad13-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Designation of George E. Wahlen Department of Veterans Affairs Medical Center","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170/tII/s244"},"text":"Pub. L. 108–170, title II, § 244","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2054"},"text":"117 Stat. 2054","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/170/tII/s244"},"text":"“The Department of Veterans Affairs Medical Center in Salt Lake City, Utah, shall after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":"] be known and designated as the ‘George E. Wahlen Department of Veterans Affairs Medical Center’. Any references to such facility in any law, regulation, map, document, record, or other paper of the United States shall be considered to be a reference to the George E. Wahlen Department of Veterans Affairs Medical Center.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
