{"tag":"section","attrib":{"id":"id62d90bb6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5109"},"text":null,"children":[{"tag":"num","attrib":{"value":"5109"},"text":"§ 5109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian forestry units; rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is directed to make rules and regulations for the operation and management of Indian forestry units on the principle of sustained-yield management, to restrict the number of livestock grazed on Indian range units to the estimated carrying capacity of such ranges, and to promulgate such other rules and regulations as may be necessary to protect the range from deterioration, to prevent soil erosion, to assure full utilization of the range, and like purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62d90bb7-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch576/s6"},"text":"June 18, 1934, ch. 576, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/986"},"text":"48 Stat. 986","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d90bb8-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d90bb9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62d90bba-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s466"},"text":"section 466 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
