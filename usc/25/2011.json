{"tag":"section","attrib":{"id":"id628cc110-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2011"},"text":null,"children":[{"tag":"num","attrib":{"value":"2011"},"text":"§ 2011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy for Indian control of Indian education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id628cc111-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitation of Indian control","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be the policy of the United States acting through the Secretary, in carrying out the functions of the Bureau, to facilitate Indian control of Indian affairs in all matters relating to education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628cc112-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with tribes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628cc113-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2011/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All actions under this Act shall be done with active consultation with tribes. The United States acting through the Secretary and tribes shall work in a government-to-government relationship to ensure quality education for all tribal members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628cc114-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2011/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628cc115-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2011/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “consultation” means a process involving the open discussion and joint deliberation of all options with respect to potential issues or changes between the Bureau and all interested parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc116-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2011/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discussion and joint deliberation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During discussions and joint deliberations, interested parties (including tribes and school officials) shall be given an opportunity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id628cc117-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2011/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to present issues (including proposals regarding changes in current practices or programs) that will be considered for future action by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628cc118-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2011/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to participate and discuss the options presented, or to present alternatives, with the views and concerns of the interested parties given effect unless the Secretary determines, from information available from or presented by the interested parties during one or more of the discussions and deliberations, that there is a substantial reason for another course of action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc119-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2011/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Explanation by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to any Member of Congress, within 18 days of the receipt of a written request by such Member, a written explanation of any decision made by the Secretary which is not consistent with the views of the interested parties described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id628cc11a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1131"},"text":"Pub. L. 95–561, title XI, § 1131","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1042"},"text":"Pub. L. 107–110, title X, § 1042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2043"},"text":"115 Stat. 2043","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id628cc11b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","childr