{"tag":"section","attrib":{"id":"id6268e5b0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1638g"},"text":"§ 1638g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mobile health stations demonstration program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id626b55b1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id626b55b2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible tribal consortium","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible tribal consortium” means a consortium composed of 2 or more Service units between which a mobile health station can be transported by road in up to 8 hours. A Service unit operated by the Service or by an Indian tribe or tribal organization shall be equally eligible for participation in such consortium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626b55b3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mobile health station","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “mobile health station” means a health care unit that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id626b55b4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is constructed, maintained, and capable of being transported within a semi-trailer truck or similar vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id626b55b5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is equipped for the provision of 1 or more specialty health care services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id626b55b6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can be equipped to be docked to a stationary health care facility when appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626b55b7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specialty health care service","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id626b55b8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “specialty health care service” means a health care service which requires the services of a health care professional with specialized knowledge or experience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id626b55b9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “specialty health care service” includes any service relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id626b55ba-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dialysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id626b55bb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surgery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id626b55bc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mammography;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id626b55bd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dentistry; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id626b55be-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/a/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other specialty health care service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626b55bf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, shall establish a demonstration program under which the Secretary shall provide at least 3 mobile health station projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626b55c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a mobile health station under the demonstration program, an eligible tribal consortium shall submit to the Secretary,","children":[{"tag":"ref","attrib":{"idref":"fn002071"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002071"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" a petition at such time, in such manner, and containing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id626b55c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the Indian population to be served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626b55c2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the specialty service or services for which the mobile health station is requested and the extent to which such service or services are currently available to the Indian population to be served; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626b55c3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626b55c4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall use amounts made available to carry out the demonstration program under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id626b55c5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id626b55c6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish, purchase, lease, or maintain mobile health stations for the eligible tribal consortia selected for projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id626b55c7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide, through the mobile health station, such specialty health care services as the affected eligible tribal consortium determines to be necessary for the Indian population served;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626b55c8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to employ an existing mobile health station (regardless of whether the mobile health station is owned or rented and operated by the Service) to provide specialty health care services to an eligible tribal consortium; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626b55c9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish, purchase, or maintain docking equipment for a mobile health station, including the establishment or maintenance of such equipment at a modular component health care facility (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1638f/a"},"text":"section 1638f(a) of this title","children":[],"tail":"), if applicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626b55ca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date on which the demonstration program is established under subsection (b) and annually thereafter, the Secretary, acting through the Service, shall submit to Congress a report describing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id626b55cb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each activity carried out under the demonstration program including an evaluation of the success of the activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626b55cc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential benefits of increased use of mobile health stations to provide specialty health care services for Indian communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626b55cd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638g/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $5,000,000 per year to carry out the demonstration program under this section for the first 5 fiscal years, and such sums as may be needed to carry out the program in subsequent fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id626b55ce-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tIII/s313"},"text":"Pub. L. 94–437, title III, § 313","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id626b55cf-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id626b55d0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id626b55d1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s313"},"text":"Section 313 of Pub. L. 94–437","children":[],"tail":" is based on section 147 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
