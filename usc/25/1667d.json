{"tag":"section","attrib":{"id":"id6274cbc0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1667d"},"text":"§ 1667d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of predoctoral psychology and psychiatry interns","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out such activities as the Secretary determines to be necessary to encourage Indian tribes, tribal organizations, and other mental health care providers to obtain the services of predoctoral psychology and psychiatry interns—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6274cbc1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the quantity of patients served by the Indian tribes, tribal organizations, and other mental health care providers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cbc2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of recruitment and retention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6274cbc3-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s725"},"text":"Pub. L. 94–437, title VII, § 725","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6274cbc4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6274cbc5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6274cbc6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s725"},"text":"Section 725 of Pub. L. 94–437","children":[],"tail":" is based on section 181 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
