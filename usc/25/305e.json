{"tag":"section","attrib":{"id":"id6223c52b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e"},"text":null,"children":[{"tag":"num","attrib":{"value":"305e"},"text":"§ 305e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cause of action for misrepresentation of Indian produced goods","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6223c52c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6223c52d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Indian” means an individual that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6223c52e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of an Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6223c52f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is certified as an Indian artisan by an Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6223c530-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian product” has the meaning given the term in any regulation promulgated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6223c531-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6223c532-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6223c533-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Indian tribe” includes, for purposes of this section only, an Indian group that has been formally recognized as an Indian tribe by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6223c534-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State legislature;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6223c535-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6223c536-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another similar organization vested with State legislative tribal recognition authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6223c537-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6223c538-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctive or equitable relief; damages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person specified in subsection (d) may, in a civil action in a court of competent jurisdiction, bring an action against a person who, directly or indirectly, offers or displays for sale or sells a good, with or without a Government trademark, in a manner that falsely suggests it is Indian produced, an Indian product, or the product of a particular Indian or Indian tribe or Indian arts and crafts organization, resident within the United States, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6223c539-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain injunctive or other equitable relief; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6223c53a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recover the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6223c53b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treble damages; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6223c53c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of each aggrieved individual Indian, Indian tribe, or Indian arts and crafts organization, not less than $1,000 for each day on which the offer or display for sale or sale continues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of paragraph (2)(A), damages shall include any and all gross profits accrued by the defendant as a result of the activities found to violate this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6223c53d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Punitive damages; attorney’s fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the relief specified in subsection (b), the court may award punitive damages and the costs of the civil action and a reasonable attorney’s fee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6223c53e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons that may initiate civil actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6223c53f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A civil action under subsection (b) may be initiated by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6223c540-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Attorney General, at the request of the Secretary acting on behalf of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6223c541-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6223c542-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6223c543-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian arts and crafts organization;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6223c544-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an Indian tribe, acting on behalf of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6223c545-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6223c546-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of that Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6223c547-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian arts and crafts organization;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6223c548-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6223c549-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian arts and crafts organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6223c54a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of amounts recovered","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6223c54b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), an amount recovered in a civil action under this section shall be paid to the Indian tribe, the Indian, or the Indian arts and crafts organization on the behalf of which the civil action was initiated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6223c54c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6223c54d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney General","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a civil action initiated under paragraph (1)(A), the Attorney General may deduct from the amount—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6223c54e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the cost of the civil action and reasonable attorney’s fees awarded under subsection (c), to be deposited in the Treasury and credited to appropriations available to the Attorney General on the date on which the amount is recovered; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6223c54f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the costs of investigation awarded under subsection (c), to reimburse the Board for the activities of the Board relating to the civil action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6223c550-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a civil action initiated under paragraph (1)(B), the Indian tribe may deduct from the amount—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6223c551-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the cost of the civil action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6223c552-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/d/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable attorney’s fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6223c553-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any provision of this section is held invalid, it is the intent of Congress that the remaining provisions of this section shall continue in full force and effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6223c554-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s305e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2000-11-09"},"text":"November 9, 2000","children":[],"tail":", the Board shall promulgate regulations to include in the definition of the term “Indian product” specific examples of such product to provide guidance to Indian artisans as well as to purveyors and consumers of Indian arts and crafts, as defined under this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6223c555-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-27/ch748/s6"},"text":"Aug. 27, 1935, ch. 748, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/644/tI/s105"},"text":"Pub. L. 101–644, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4664"},"text":"104 Stat. 4664","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/497/s2"},"text":"Pub. L. 106–497, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2219"},"text":"114 Stat. 2219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tI/s102/b"},"text":"Pub. L. 111–211, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2259"},"text":"124 Stat. 2259","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6223c556-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6223c557-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6223c558-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-27/ch748"},"text":"act Aug. 27, 1935, ch. 748","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/891"},"text":"49 Stat. 891","children":[],"tail":", which is classified generally to section 305 et seq. of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6223c559-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-27/ch748/s6"},"text":"act Aug. 27, 1935, ch. 748, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/893"},"text":"49 Stat. 893","children":[],"tail":", related to offering for sale without trade mark goods as Indian goods, prior to repeal by acts "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645/s21"},"text":"June 25, 1948, ch. 645, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/862"},"text":"62 Stat. 862","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s39"},"text":"June 25, 1948, ch. 646, § 39","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/992"},"text":"62 Stat. 992","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1159"},"text":"section 1159 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6223c55a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s102/b/3"},"text":"Pub. L. 111–211, § 102(b)(3)","children":[],"tail":", added subsec. (a). Former subsec. (a) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib"