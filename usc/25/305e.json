p","attrib":{},"text":"Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/497/s2/2/A"},"text":"Pub. L. 106–497, § 2(2)(A)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/497/s2/2/B"},"text":"Pub. L. 106–497, § 2(2)(B)","children":[],"tail":", designated existing text as cl. (i) and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/497/s2/3"},"text":"Pub. L. 106–497, § 2(3)","children":[],"tail":", inserted “subject to subsection (f) of this section,” before “the terms”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/497/s2/4"},"text":"Pub. L. 106–497, § 2(4)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6223c55b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6223c55c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Certification of Indian Artisans","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/644/tI/s107"},"text":"Pub. L. 101–644, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4665"},"text":"104 Stat. 4665","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/644/tI/s107"},"text":"“For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1159"},"text":"section 1159 of title 18","children":[],"tail":", United States Code, and section 6 of the Act entitled ‘An Act to promote the development of Indian arts and crafts and to create a board to assist therein, and for other purposes’ ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s305"},"text":"25 U.S.C. 305","children":[],"tail":" et seq.) ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s305e"},"text":"25 U.S.C. 305e","children":[],"tail":"] an Indian tribe may not impose a fee in certifying an individual as an Indian artisan. For the purposes of this section, the term ‘Indian tribe’ has the same meaning given such term in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1159/c/3"},"text":"section 1159(c)(3) of title 18","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
