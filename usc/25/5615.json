{"tag":"section","attrib":{"id":"id62f59481-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5615"},"text":null,"children":[{"tag":"num","attrib":{"value":"5615"},"text":"§ 5615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of subchapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f59482-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5615/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5614"},"text":"section 5614 of this title","children":[],"tail":" and this section, nothing in this subchapter or an Indian trust asset management plan approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5613"},"text":"section 5613 of this title","children":[],"tail":" shall independently diminish, increase, create, or otherwise affect the liability of the United States or an Indian tribe participating in the project for any loss resulting from the management of an Indian trust asset under an Indian trust asset management plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f59483-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5615/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deviation from standard practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States shall not be liable to any party (including any Indian tribe) for any term of, or any loss resulting from the terms of, an Indian trust asset management plan that provides for management of a trust asset at a less-stringent standard than the Secretary would otherwise require or adhere to in absence of an Indian trust asset management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f59484-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5615/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of termination of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (b) applies to losses resulting from a transaction or activity described in that subsection even if the Indian trust asset management plan is terminated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5613/d"},"text":"section 5613(d) of this title","children":[],"tail":" or rescinded under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5614/h"},"text":"section 5614(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f59485-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5615/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other laws","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f59486-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5615/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in sections 5613 and 5614 of this title and subsection (e), nothing in this subchapter amends or otherwise affects the application of any treaty, statute, regulation, or Executive order that is applicable to Indian trust assets or the management or administration of Indian trust assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f59487-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5615/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Self-Determination Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter limits or otherwise affects the authority of an Indian tribe, including an Indian tribe participating in the project, to enter into and carry out a contract, compact, or other agreement under the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.) "},{"tag":"ref","attrib":{"idref":"fn002283"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002283"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" (including regulations)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f59488-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5615/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian tribe may submit to the Secretary tribal regulations described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5614/b"},"text":"section 5614(b) of this title","children":[],"tail":" governing forest land management activities for review and approval under this subchapter if the Indian tribe does not submit or intend to submit an Indian trust asset management plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f59489-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5615/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter enhances, diminishes, or otherwise affects the trust responsibility of the United States to Indian tribes or individual Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f5948a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/178/tII/s206"},"text":"Pub. L. 114–178, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/439"},"text":"130 Stat. 439","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62f5948b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62f5948c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62f5948d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of this title prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
