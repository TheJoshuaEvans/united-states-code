{"tag":"section","attrib":{"id":"id62d1dfe1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4168"},"text":null,"children":[{"tag":"num","attrib":{"value":"4168"},"text":"§ 4168.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each recipient shall make any housing plan, policy, or annual report prepared by the recipient available to the general public.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62d1dfe2-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tIV/s408"},"text":"Pub. L. 104–330, title IV, § 408","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s595/e/14/A"},"text":"Pub. L. 105–276, title V, § 595(e)(14)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2658"},"text":"112 Stat. 2658","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
