{"tag":"section","attrib":{"id":"id621c995e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s185"},"text":null,"children":[{"tag":"num","attrib":{"value":"185"},"text":"§ 185.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of Indians desiring civilized life","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever any Indian, being a member of any band or tribe with whom the Government has or shall have entered into treaty stipulations, being desirous to adopt the habits of civilized life, has had a portion of the lands belonging to his tribe allotted to him in severalty, in pursuance of such treaty stipulations, the agent and superintendent of such tribe shall take such measures, not inconsistent with law, as may be necessary to protect such Indian in the quiet enjoyment of the lands so allotted to him.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621c995f-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2119.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621c9960-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621c9961-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id621c9962-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2119 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1862-06-14/ch101/s1"},"text":"act June 14, 1862, ch. 101, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/427"},"text":"12 Stat. 427","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id621c9963-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id621c9964-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Indian Agents","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The services of Indian agents have been dispensed with. See note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s64"},"text":"section 64 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id621c9965-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id621c9966-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
