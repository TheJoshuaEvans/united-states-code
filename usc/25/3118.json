{"tag":"section","attrib":{"id":"id62b7a139-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3118"},"text":null,"children":[{"tag":"num","attrib":{"value":"3118"},"text":"§ 3118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided by this chapter, the Secretary is directed to promulgate final regulations for the implementation of the ","children":[{"tag":"ref","attrib":{"idref":"fn002208"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002208"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “this”."}],"tail":" chapter within eighteen months from "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":". All regulations promulgated pursuant to this chapter shall be developed by the Secretary with the participation of the affected Indian tribes."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62b7a13a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIII/s319"},"text":"Pub. L. 101–630, title III, § 319","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4544"},"text":"104 Stat. 4544","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
