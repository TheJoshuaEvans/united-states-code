{"tag":"section","attrib":{"id":"id62669b52-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1623"},"text":null,"children":[{"tag":"num","attrib":{"value":"1623"},"text":"§ 1623.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules relating to Indians","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62669b53-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1623/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No Cost-sharing for Indians with income at or below 300 percent of poverty enrolled in coverage through a State Exchange","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions prohibiting cost sharing for Indians enrolled in any qualified health plan in the individual market through an Exchange, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18071/d"},"text":"section 18071(d) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62669b54-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1623/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payer of last resort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Health programs operated by the Indian Health Service, Indian tribes, tribal organizations, and Urban Indian organizations (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"section 1603 of this title","children":[],"tail":") shall be the payer of last resort for services provided by such Service, tribes, or organizations to individuals eligible for services through such programs, notwithstanding any Federal, State, or local law to the contrary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62669b55-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tII/s2901/a"},"text":"Pub. L. 111–148, title II, § 2901(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/333"},"text":"124 Stat. 333","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62669b56-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62669b57-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62669b58-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsecs. (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s2901"},"text":"section 2901 of Pub. L. 111–148","children":[],"tail":". Subsections (c) and (d) of section 2901 amended sections 1396a and 1320b–9, respectively, of Title 42, The Public Health and Welfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Patient Protection and Affordable Care Act, and not as part of the Indian Health Care Improvement Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
