{"tag":"section","attrib":{"id":"id6217df41-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s132"},"text":null,"children":[{"tag":"num","attrib":{"value":"132"},"text":"§ 132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mode of distribution of goods","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever goods and merchandise are delivered to the chiefs of a tribe, for the tribe, such goods and merchandise shall be turned over by the agent or superintendent of such tribe to the chiefs in bulk, and in the original package, as nearly as practicable, and in the presence of the headmen of the tribe, if practicable, to be distributed to the tribe by the chiefs in such manner as the chiefs may deem best, in the presence of the agent or superintendent.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6217df42-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2090.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6217df43-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6217df44-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6217df45-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2090 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1869-04-10/ch16/s2"},"text":"act Apr. 10, 1869, ch. 16, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/16/39"},"text":"16 Stat. 39","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6217df46-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6217df47-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Indian Agents","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The services of Indian agents have been dispensed with. See note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s64"},"text":"section 64 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
