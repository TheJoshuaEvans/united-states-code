{"tag":"section","attrib":{"id":"id62c84411-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4044"},"text":null,"children":[{"tag":"num","attrib":{"value":"4044"},"text":"§ 4044.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reconciliation report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall transmit to the Committee on Natural Resources of the House of Representatives and the Committee on Indian Affairs of the Senate, by ","children":[{"tag":"date","attrib":{"date":"1996-05-31"},"text":"May 31, 1996","children":[],"tail":", a report identifying for each tribal trust fund account for which the Secretary is responsible a balance reconciled as of "},{"tag":"date","attrib":{"date":"1995-09-30"},"text":"September 30, 1995","children":[],"tail":". In carrying out this section, the Secretary shall consult with the Special Trustee. The report shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c84412-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4044/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the Secretary’s methodology in reconciling trust fund accounts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c84413-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4044/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" attestations by each account holder that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62c84414-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4044/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has provided the account holder with as full and complete accounting as possible of the account holder’s funds to the earliest possible date, and that the account holder accepts the balance as reconciled by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c84415-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4044/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the account holder disputes the balance of the account holder’s account as reconciled by the Secretary and statement explaining why the account holder disputes the Secretary’s reconciled balance; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c84416-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4044/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement by the Secretary with regard to each account balance disputed by the account holder outlining efforts the Secretary will undertake to resolve the dispute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c84417-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/412/tIII/s304"},"text":"Pub. L. 103–412, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4248"},"text":"108 Stat. 4248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c84418-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62c84419-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62c8441a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Settlement of Tribal Claims","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/153/s1"},"text":"Pub. L. 107–153, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-19"},"text":"Mar. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/79"},"text":"116 Stat. 79","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/158/s1"},"text":"Pub. L. 109–158, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-30"},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2954"},"text":"119 Stat. 2954","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/158/s1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, for purposes of determining the date on which an Indian tribe received a reconciliation report for purposes of applying a statute of limitations, any such report provided to or received by an Indian tribe in response to section 304 of the American Indian Trust Fund Management Reform Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4044"},"text":"25 U.S.C. 4044","children":[],"tail":") shall be deemed to have been received by the Indian tribe on "},{"tag":"date","attrib":{"date":"2000-12-31"},"text":"December 31, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statement of Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) is solely intended to provide recipients of reconciliation reports with the opportunity to postpone the filing of claims, or to facilitate the voluntary dismissal of claims, to encourage settlement negotiations with the United States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
