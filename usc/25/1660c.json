{"tag":"section","attrib":{"id":"id6270102a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1660c"},"text":"§ 1660c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Urban NIAAA transferred programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6270102b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, within the Branch of Urban Health Programs of the Service, make grants or enter into contracts for the administration of urban Indian alcohol programs that were originally established under the National Institute on Alcoholism and Alcohol Abuse (hereafter in this section referred to as “NIAAA”) and transferred to the Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6270102c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants provided or contracts entered into under this section shall be used to provide support for the continuation of alcohol prevention and treatment services for urban Indian populations and such other objectives as are agreed upon between the Service and a recipient of a grant or contract under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6270102d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Urban Indian organizations that operate Indian alcohol programs originally funded under NIAAA and subsequently transferred to the Service are eligible for grants or contracts under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6270102e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Combination of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, the Secretary may combine NIAAA alcohol funds with other substance abuse funds currently administered through the Branch of Urban Health Programs of the Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6270102f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall evaluate and report to the Congress on the activities of programs funded under this section at least every 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62701030-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tV/s513"},"text":"Pub. L. 94–437, title V, § 513","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tV/s504"},"text":"Pub. L. 102–573, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4570"},"text":"106 Stat. 4570","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/362/tVI/s602/a"},"text":"Pub. L. 105–362, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3286"},"text":"112 Stat. 3286","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62701031-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62701032-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62701033-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/362"},"text":"Pub. L. 105–362","children":[],"tail":" substituted “every 5 years” for “every two years”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62701034-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62701035-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (e) of this section relating to reporting to Congress on the activities of programs funded under this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 97 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
