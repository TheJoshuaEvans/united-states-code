{"tag":"section","attrib":{"id":"id62f59416-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612"},"text":null,"children":[{"tag":"num","attrib":{"value":"5612"},"text":"§ 5612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of demonstration project; selection of participating Indian tribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f59417-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and carry out an Indian trust asset management demonstration project, in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f59418-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of participating Indian tribes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f59419-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Indian tribe shall be eligible to participate in the project if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f5941a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian tribe submits to the Secretary an application under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f5941b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary approves the application of the Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f5941c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f5941d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide a written notice to each Indian tribe approved to participate in the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f5941e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A notice under subparagraph (A) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62f5941f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement that the application of the Indian tribe has been approved by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62f59420-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that the Indian tribe shall submit to the Secretary a proposed Indian trust asset management plan in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5613"},"text":"section 5613 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f59421-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f59422-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to participate in the project, an Indian tribe shall submit to the Secretary a written application in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f59423-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall consider an application under this subsection only if the application—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f59424-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a copy of a resolution or other appropriate action by the governing body of the Indian tribe, as determined by the Secretary, in support of or authorizing the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f59425-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is received by the Secretary after ","children":[{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f59426-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states that the Indian tribe is requesting to participate in the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f59427-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The project—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f59428-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remain in effect for a period of 10 years after ","children":[{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":"; but"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f59429-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5612/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be extended at the discretion of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f5942a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/178/tII/s203"},"text":"Pub. L. 114–178, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/433"},"text":"130 Stat. 433","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
