{"tag":"section","attrib":{"id":"id622154a2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s292a"},"text":null,"children":[{"tag":"num","attrib":{"value":"292a"},"text":"§ 292a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discontinuance of boarding and day schools having small attendance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All reservation and nonreservation boarding schools with an average attendance in any year of less than forty-five and eighty pupils, respectively, shall be discontinued on or before the beginning of the ensuing fiscal year. The pupils in schools so discontinued shall be transferred first, if possible, to Indian day schools or State public schools; second, to adjacent reservation or nonreservation boarding schools, to the limit of the capacity of said schools: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That all day schools with an average attendance in any year of less than eight shall be discontinued on or before the beginning of the ensuing fiscal year: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That all moneys appropriated for any school discontinued pursuant to this section or for other cause shall be returned immediately to the Treasury of the United States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id622154a3-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-03-04/ch705"},"text":"Mar. 4, 1929, ch. 705","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1576"},"text":"45 Stat. 1576","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id622154a4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id622154a5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id622154a6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Interior Department Appropriation Act, 1930. Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1928-03-07/ch137"},"text":"Mar. 7, 1928, ch. 137","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/215"},"text":"45 Stat. 215","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1927-01-12/ch27"},"text":"Jan. 12, 1927, ch. 27","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/947"},"text":"44 Stat. 947","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-10/ch277"},"text":"May 10, 1926, ch. 277","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/468"},"text":"44 Stat. 468","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch462"},"text":"Mar. 3, 1925, ch. 462","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1155"},"text":"43 Stat. 1155","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1924-06-05/ch264"},"text":"June 5, 1924, ch. 264","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/404"},"text":"43 Stat. 404","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/a