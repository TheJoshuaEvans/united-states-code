{"tag":"section","attrib":{"id":"id62c5f944-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3746"},"text":null,"children":[{"tag":"num","attrib":{"value":"3746"},"text":"§ 3746.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal immunity","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to affect, modify, diminish, or otherwise impair the sovereign immunity from suit enjoyed by Indian tribes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62c5f945-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/177/tIII/s306"},"text":"Pub. L. 103–177, title III, § 306","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/435/s12/b"},"text":"Pub. L. 103–435, § 12(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4572"},"text":"108 Stat. 4572","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
