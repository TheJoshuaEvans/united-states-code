{"tag":"section","attrib":{"id":"id62ae046a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2901"},"text":null,"children":[{"tag":"num","attrib":{"value":"2901"},"text":"§ 2901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae046b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the cultures and languages of Native Americans is unique and the United States has the responsibility to act together with Native Americans to ensure the survival of these unique cultures and languages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae046c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special status is accorded Native Americans in the United States, a status that recognizes distinct cultural and political rights, including the right to continue separate identities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae046d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the traditional languages of Native Americans are an integral part of their cultures and identities and form the basic medium for the transmission, and thus survival, of Native American cultures, literatures, histories, religions, political institutions, and values;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae046e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2901/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a widespread practice of treating Native Americans ","children":[{"tag":"ref","attrib":{"idref":"fn002194"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002194"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “American”."}],"tail":" languages as if they were anachronisms;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae046f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2901/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a lack of clear, comprehensive, and consistent Federal policy on treatment of Native American languages which has often resulted in acts of suppression and extermination of Native American languages and cultures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0470-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2901/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is convincing evidence that student achievement and performance, community and school pride, and educational opportunity is clearly and directly tied to respect for, and support of, the first language of the child or student;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0471-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2901/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is clearly in the interests of the United States, individual States, and territories to encourage the full academic and human potential achievements of all students and citizens and to take steps to realize these ends;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0472-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2901/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acts of suppression and extermination directed against Native American languages and cultures are in conflict with the United States policy of self-determination for Native Americans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0473-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2901/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" languages are the means of communication for the full range of human experiences and are critical to the survival of cultural and political integrity of any people; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae0474-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2901/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" language provides a direct and powerful means of promoting international communication by people who share languages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62ae0475-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/477/tI/s102"},"text":"Pub. L. 101–477, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-30"},"text":"Oct. 30, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1153"},"text":"104 Stat. 1153","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ae0476-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62ae0477-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id62ae0478-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2023 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/337/s1"},"text":"Pub. L. 117–337, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6153"},"text":"136 Stat. 6153","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/337/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2907"},"text":"section 2907 of this title","children":[],"tail":" and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2905"},"text":"section 2905 of this title","children":[],"tail":"] may be cited as the ‘Durbin Feeling Native American Languages Act of 2022’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id62ae0479-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/477/tI/s101"},"text":"Pub. L. 101–477, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-30"},"text":"Oct. 30, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1153"},"text":"104 Stat. 1153","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/477/tI/s101"},"text":"“This title [enacting this chapter] may be cited as the ‘Native American Languages Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
