{"tag":"section","attrib":{"id":"id62346703-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s385a"},"text":null,"children":[{"tag":"num","attrib":{"value":"385a"},"text":"§ 385a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Irrigation projects; deposit of assessments as trust fund; disposition of fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1946-08-07"},"text":"August 7, 1946","children":[],"tail":", collections made from water users on each Indian irrigation project on account of assessments levied to meet the cost of operating and maintaining such project shall be deposited into the Treasury for credit to a trust-fund account pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1321"},"text":"section 1321 of title 31","children":[],"tail":", and shall be available for expenditure in carrying out the purposes for which collected."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62346704-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-07/ch802/s1"},"text":"Aug. 7, 1946, ch. 802, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/895"},"text":"60 Stat. 895","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62346705-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62346706-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62346707-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":