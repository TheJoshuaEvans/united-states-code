{"tag":"section","attrib":{"id":"id62cab4d1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112"},"text":null,"children":[{"tag":"num","attrib":{"value":"4112"},"text":"§ 4112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian housing plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62cab4d2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cab4d3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cab4d4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an Indian tribe to submit to the Secretary, by not later than 75 days before the beginning of each tribal program year, a 1-year housing plan for the Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab4d5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the tribally designated housing entity for the tribe to submit the plan as provided in subsection (c) for the tribe; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab4d6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the review of such plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cab4d7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1-year plan requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cab4d8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A housing plan of an Indian tribe under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cab4d9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in such form as the Secretary may prescribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab4da-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain the information described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cab4db-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A housing plan shall include the following information with respect to the tribal program year for which assistance under this chapter is made available:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cab4dc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of planned activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A statement of planned activities, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62cab4dd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of household to receive assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab4de-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types and levels of assistance to be provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab4df-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of units planned to be produced;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab4e0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62cab4e1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any housing to be demolished or disposed of;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62cab4e2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a timetable for the demolition or disposition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62cab4e3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/A/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information required by the Secretary with respect to the demolition or disposition;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab4e4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the manner in which the recipient will protect and maintain the viability of housing owned and operated by the recipient that was developed under a contract between the Secretary and an Indian housing authority pursuant to the United States Housing Act of 1937 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"42 U.S.C. 1437","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab4e5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outcomes anticipated to be achieved by the recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab4e6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of needs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A statement of the housing needs of the low-income Indian families residing in the jurisdiction of the Indian tribe, and the means by which those needs will be addressed during the applicable period, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62cab4e7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the estimated housing needs and the need for assistance for the low-income Indian families in the jurisdiction, including a description of the manner in which the geographical distribution of assistance is consistent with the geographical needs and needs for various categories of housing assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab4e8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the estimated housing needs for all Indian families in the jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab4e9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial resources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An operating budget for the recipient, in such form as the Secretary may prescribe, that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62cab4ea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification and description of the financial resources reasonably available to the recipient to carry out the purposes of this chapter, including an explanation of the manner in which amounts made available will leverage additional resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab4eb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the uses to which those resources will be committed, including eligible and required affordable housing activities under subchapter II and administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cab4ec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of compliance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Evidence of compliance with the requirements of this chapter, including, as appropriate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62cab4ed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that, in carrying out this chapter, the recipient will comply with the applicable provisions of title II of the Civil Rights Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1301"},"text":"25 U.S.C. 1301","children":[],"tail":" et seq.) and other applicable Federal laws and regulations;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab4ee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that the recipient will maintain adequate insurance coverage for housing units that are owned and operated or assisted with grant amounts provided under this chapter, in compliance with such requirements as the Secretary may establish;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab4ef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that policies are in effect and are available for review by the Secretary and the public governing the eligibility, admission, and occupancy of families for housing assisted with grant amounts provided under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab4f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that policies are in effect and are available for review by the Secretary and the public governing rents and homebuyer payments charged, including the methods by which the rents or homebuyer payments are determined, for housing assisted with grant amounts provided under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab4f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that policies are in effect and are available for review by the Secretary and the public governing the management and maintenance of housing assisted with grant amounts provided under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cab4f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/b/2/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that the recipient will comply with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4114/b"},"text":"section 4114(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cab4f3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of tribally designated housing entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A plan under this section for an Indian tribe may be prepared and submitted on behalf of the tribe by the tribally designated housing entity for the tribe, but only if such plan contains a certification by the recognized tribal government of the grant beneficiary that such tribe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cd24f4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has had an opportunity to review the plan and has authorized the submission of the plan by the housing entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cd24f5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has delegated to such tribally designated housing entity the authority to submit a plan on behalf of the tribe without prior review by the tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cd24f6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A plan under this section may cover more than 1 Indian tribe, but only if the certification requirements under subsection (c) are complied with by each such grant beneficiary covered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cd24f7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4112/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements relating to the contents of plans under this section shall be established by regulation, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4116"},"text":"section 4116 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62cd24f8-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tI/s102"},"text":"Pub. L. 104–330, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4023"},"text":"110 Stat. 4023","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s595/e/5"},"text":"Pub. L. 105–276, title V, § 595(e)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2657"},"text":"112 Stat. 2657","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tX/s1003/b"},"text":"Pub. L. 106–568, title X, § 1003(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2926"},"text":"114 Stat. 2926","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s503/b"},"text":"Pub. L. 106–569, title V, § 503(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2962"},"text":"114 Stat. 2962","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/411/tI/s102"},"text":"Pub. L. 110–411, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4321"},"text":"122 Stat. 4321","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62cd24f9-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62cd24fa-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62cd24fb-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(2), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", known as the Native American Housing Assistance and Self-Determination Act of 1996. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The United States Housing Act of 1937, referred to in subsec. (b)(2)(A)(v), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"act Sept. 1, 1937, ch. 896","children":[],"tail":", as revised generally by "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/tII/s201/a"},"text":"Pub. L. 93–383, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/653"},"text":"88 Stat. 653","children":[],"tail":", which is classified generally to chapter 8 (§ 1437 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"section 1437 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1968, referred to in subsec. (b)(2)(D)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284"},"text":"Pub. L. 90–284","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/73"},"text":"82 Stat. 73","children":[],"tail":". Title II of the Act, popularly known as the Indian Civil Rights Act of 1968, is classified generally to subchapter I (§ 1301 et seq.) of chapter 15 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"section 3601 of Title 42","children":[],"tail":", The Public Health and Welfare, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62cd24fc-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/411/s102/1/A"},"text":"Pub. L. 110–411, § 102(1)(A)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A) which read as follows: “for an Indian tribe to submit to the Secretary, for each fiscal year, a housing plan under this section for the tribe; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/411/s102/1/B"},"text":"Pub. L. 110–411, § 102(1)(B)","children":[],"tail":", substituted “subsection (c)” for “subsection (d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/411/s102/2"},"text":"Pub. L. 110–411, § 102(2)","children":[],"tail":", (3), added subsec. (b), redesignated subsec. (d) as (c), and struck out former subsecs. (b) and (c) which required housing plans to contain certain information relating to a 5-year period and a 1-year period, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/411/s102/3"},"text":"Pub. L. 110–411, § 102(3)","children":[],"tail":", (4), redesignated subsec. (e) as (d) and substituted “subsection (c)” for “subsection (d)”. Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/411/s102/3"},"text":"Pub. L. 110–411, § 102(3)","children":[],"tail":", redesignated subsecs. (e) and (f) as (d) and (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s1003/b"},"text":"Pub. L. 106–568, § 1003(b)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s503/b"},"text":"Pub. L. 106–569, § 503(b)","children":[],"tail":", amended subsec. (c) identically, adding par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s1003/c"},"text":"Pub. L. 106–568, § 1003(c)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s503/c"},"text":"Pub. L. 106–569, § 503(c)","children":[],"tail":", amended section identically, redesignating subsec. (g) as (f) and striking out heading and text of former subsec. (f). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Separate requirements","children":[],"tail":".—The Secretary may—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) establish requirements for submission of plans under this section and the information to be included in such plans applicable to small Indian tribes and small tribally designated housing entities; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) waive any requirements under this section that the Secretary determines are burdensome or unnecessary for such tribes and housing entities.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Small tribes","children":[],"tail":".—The Secretary may define small Indian tribes and small tribally designated housing entities based on the number of dwelling units assisted under this subchapter by the tribe or housing entity or owned or operated pursuant to a contract under the United States Housing Act of 1937 between the Secretary and the Indian housing authority for the tribe.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276"},"text":"Pub. L. 105–276","children":[],"tail":" redesignated par. (1) as (1)(A), par. (2) as (1)(B), and par. (3) as (2), and inserted “or” at end of par. (1)(A)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62cd24fd-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id62cd24fe-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date provided by the Secretary of Housing and Urban Development pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4116/a"},"text":"section 4116(a) of this title","children":[],"tail":" to provide for timely submission and review of Indian housing plans as necessary for the provision of assistance under this chapter in fiscal year 1998, see "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4113/e"},"text":"section 4113(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
