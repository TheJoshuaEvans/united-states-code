{"tag":"section","attrib":{"id":"id628f0b06-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2018"},"text":null,"children":[{"tag":"num","attrib":{"value":"2018"},"text":"§ 2018.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional meetings and negotiated rulemaking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id628f0b07-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2018/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to publishing any proposed regulations under subsection (b)(1), and prior to establishing the negotiated rulemaking committee under subsection (b)(3), the Secretary shall convene regional meetings to consult with personnel of the Office of Indian Education Programs, educators at Bureau schools, and tribal officials, parents, teachers, administrators, and school board members of tribes served by Bureau-funded schools to provide guidance to the Secretary on the content of regulations authorized to be promulgated under this chapter and the Tribally Controlled Schools Act of 1988 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2501"},"text":"25 U.S.C. 2501","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0b08-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2018/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiated rulemaking","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628f0b09-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2018/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding sections 563(a) and 565(a) of title 5, the Secretary shall promulgate regulations authorized under subsection (a) and under the Tribally Controlled Schools Act of 1988 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2501"},"text":"25 U.S.C. 2501","children":[],"tail":" et seq.], in accordance with the negotiated rulemaking procedures provided for under subchapter III of chapter 5 of title 5, and shall publish final regulations in the Federal Register."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628f0b0a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2018/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If draft regulations implementing this chapter and the Tribally Controlled Schools Act of 1988 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2501"},"text":"25 U.S.C. 2501","children":[],"tail":" et seq.] are not promulgated in final form within 18 months after "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", the Secretary shall notify the appropriate committees of Congress of which draft regulations were not promulgated in final form by the deadline and the reason such final regulations were not promulgated."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628f0b0b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2018/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking committee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a negotiated rulemaking committee to carry out this subsection. In establishing such committee, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628f0b0c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2018/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply the procedures provided for under subchapter III of chapter 5 of title 5 in a manner that reflects the unique government-to-government relationship between Indian tribes and the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628f0b0d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2018/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the membership of the committee includes only representatives of the Federal Government and of tribes served by Bureau-funded schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628f0b0e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2018/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select the tribal representatives of the committee from among individuals nominated by the representatives of the tribal and tribally operated schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628f0b0f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2018/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure, to the maximum extent possible, that the tribal representative membership on the committee reflects the proportionate share of students from tribes served by the Bureau-funded school system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628f0b10-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2018/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with chapter 10 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628f0b11-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2018/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out this section using the general administrative funds of the Department of the Interior. In accordance with subchapter III of chapter 5 of title 5 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1006/d"},"text":"section 1006(d) of title 5","children":[],"tail":", payment of costs associated with negotiated rulemaking shall include the reasonable expenses of committee members."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0b12-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2018/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of section","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628f0b13-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2018/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supremacy of provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall supersede any conflicting regulations in effect on the day before the date of enactment of this chapter, and the Secretary may repeal any regulation that is inconsistent with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628f0b14-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2018/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may modify regulations promulgated under this section or the Tribally Controlled Schools Act of 1988 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2501"},"text":"25 U.S.C. 2501","children":[],"tail":" et seq.], only in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id628f0b15-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1138"},"text":"Pub. L. 95–561, title XI, § 1138","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1042"},"text":"Pub. L. 107–110, title X, § 1042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2057"},"text":"115 Stat. 2057","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/182"},"text":"Pub. L. 117–286, § 4(a)(182)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4326"},"text":"136 Stat. 4326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id628f0b16-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id628f0b17-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id628f0b18-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Tribally Controlled Schools Act of 1988, referred to in subsecs. (a), (b)(1), (2), and (c)(2), is part B (§ 5201–5212) of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/385"},"text":"102 Stat. 385","children":[],"tail":", as amended, which is classified generally to chapter 27 (§ 2501 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2501"},"text":"section 2501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this chapter, referred to in subsec. (c)(1), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":", which amended this chapter generally and was approved "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id628f0b19-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2018, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1138"},"text":"Pub. L. 95–561, title XI, § 1138","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s381"},"text":"Pub. L. 103–382, title III, § 381","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4011"},"text":"108 Stat. 4011","children":[],"tail":", related to rights of Indian students, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2016"},"text":"section 2016 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2018, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1138"},"text":"Pub. L. 95–561, title XI, § 1138","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2327"},"text":"92 Stat. 2327","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/511/tV/s510"},"text":"Pub. L. 98–511, title V, § 510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2397"},"text":"98 Stat. 2397","children":[],"tail":", related to regulations implementing administrative provisions, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id628f0b1a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(3)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/182/A"},"text":"Pub. L. 117–286, § 4(a)(182)(A)","children":[],"tail":", substituted “chapter 10 of title 5.” for “the Federal Advisory Committee Act (5 U.S.C. App.).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/182/B"},"text":"Pub. L. 117–286, § 4(a)(182)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1006/d"},"text":"section 1006(d) of title 5","children":[],"tail":",” for “section 7(d) of the Federal Advisory Committee Act,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id628f0b1b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id628f0b1c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
