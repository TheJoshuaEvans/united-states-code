{"tag":"section","attrib":{"id":"id62669b28-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621v"},"text":null,"children":[{"tag":"num","attrib":{"value":"1621v"},"text":"§ 1621v.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offices of Indian Men’s Health and Indian Women’s Health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62669b29-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621v/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Indian Men’s Health","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62669b2a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621v/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish within the Service an office, to be known as the “Office of Indian Men’s Health”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62669b2b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621v/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62669b2c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621v/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Indian Men’s Health shall be headed by a director, to be appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62669b2d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621v/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The director shall coordinate and promote the health status of Indian men in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62669b2e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621v/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Secretary, acting through the Service, shall submit to Congress a report describing—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62669b2f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621v/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity carried out by the director as of the date on which the report is prepared; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62669b30-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621v/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any finding of the director with respect to the health of Indian men.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62669b31-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621v/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Indian Women’s Health","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, shall establish an office, to be known as the “Office of Indian Women’s Health”, to monitor and improve the quality of health care for Indian women (including urban Indian women) of all ages through the planning and delivery of programs administered by the Service, in order to improve and enhance the treatment models of care for Indian women.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62669b32-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tII/s223"},"text":"Pub. L. 94–437, title II, § 223","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tII/s216"},"text":"Pub. L. 102–573, title II, § 216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4559"},"text":"106 Stat. 4559","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62669b33-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62669b34-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62669b35-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" is based on section 136 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62669b36-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" substituted “Offices of Indian Men’s Health and Indian Women’s Health” for “Office of Indian Women’s Health Care” in section catchline, added subsec. (a), designated existing provisions as subsec. (b), inserted subsec. (b) heading, substituted “The Secretary, acting through the Service, shall establish an office, to be known as the ‘Office of Indian Women’s Health’, to” for “There is established within the Service an Office of Indian Women’s Health Care to oversee efforts of the Service to”, and inserted “(including urban Indian women)” before “of all ages”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
