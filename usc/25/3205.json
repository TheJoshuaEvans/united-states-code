{"tag":"section","attrib":{"id":"id62b7a1ad-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3205"},"text":null,"children":[{"tag":"num","attrib":{"value":"3205"},"text":"§ 3205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":", the Family Educational Rights and Privacy Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232g"},"text":"20 U.S.C. 1232g","children":[],"tail":"), or any other provision of law, agencies of any Indian tribe, of any State, or of the Federal Government that investigate and treat incidents of abuse of children may provide information and records to those agencies of any Indian tribe, any State, or the Federal Government that need to know the information in performance of their duties. For purposes of this section, Indian tribal governments shall be treated the same as other Federal Government entities."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62b7a1ae-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIV/s406"},"text":"Pub. L. 101–630, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4550"},"text":"104 Stat. 4550","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62b7a1af-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62b7a1b0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62b7a1b1-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Family Educational Rights and Privacy Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232g"},"text":"20 U.S.C. 1232g","children":[],"tail":"), referred to in text, is "},{"tag":"ref","attrib":{"href":"/us/pl/93/380/tV/s513"},"text":"section 513 of title V of Pub. L. 93–380","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/571"},"text":"88 Stat. 571","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232g"},"text":"section 1232g of Title 20","children":[],"tail":", Education, and provisions set out as notes under sections 1221 and 1232g of Title 20. For complete classification of this Act to the Code, see Short Title of 1974 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221"},"text":"section 1221 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
