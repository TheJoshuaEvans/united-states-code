{"tag":"section","attrib":{"id":"id62d90bbb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5110"},"text":null,"children":[{"tag":"num","attrib":{"value":"5110"},"text":"§ 5110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New Indian reservations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is hereby authorized to proclaim new Indian reservations on lands acquired pursuant to any authority conferred by this Act, or to add such lands to existing reservations: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That lands added to existing reservations shall be designated for the exclusive use of Indians entitled by enrollment or by tribal membership to residence at such reservations."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62d90bbc-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch576/s7"},"text":"June 18, 1934, ch. 576, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/986"},"text":"48 Stat. 986","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d90bbd-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d90bbe-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62d90bbf-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch576"},"text":"act June 18, 1934, ch. 576","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/984"},"text":"48 Stat. 984","children":[],"tail":", popularly known as the Indian Reorganization Act, which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5101"},"text":"section 5101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62d90bc0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s467"},"text":"section 467 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
