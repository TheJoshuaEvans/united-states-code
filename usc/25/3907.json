{"tag":"section","attrib":{"id":"id62c8436d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3907"},"text":null,"children":[{"tag":"num","attrib":{"value":"3907"},"text":"§ 3907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c8436e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c8436f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The activities required to be performed by the Director under this chapter shall be coordinated with activities related to solid waste and sanitation facilities funded pursuant to other authorizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c84370-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/399/s8"},"text":"Pub. L. 103–399, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4168"},"text":"108 Stat. 4168","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
