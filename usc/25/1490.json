{"tag":"section","attrib":{"id":"id6255d20e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1490"},"text":null,"children":[{"tag":"num","attrib":{"value":"1490"},"text":"§ 1490.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maturity of loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The maturity of any loan guaranteed or insured hereunder shall not exceed thirty years.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6255d20f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/tII/s210"},"text":"Pub. L. 93–262, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/80"},"text":"88 Stat. 80","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
