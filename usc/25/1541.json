{"tag":"section","attrib":{"id":"id62584361-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1541"},"text":null,"children":[{"tag":"num","attrib":{"value":"1541"},"text":"§ 1541.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competent management and technical assistance for economic enterprises","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Prior to and concurrent with the making or guaranteeing of any loan under subchapters I and II of this chapter and with the making of a grant under subchapter IV of this chapter, the purpose of which is to fund the development of an economic enterprise, the Secretary shall insure that the loan or grant applicant shall be provided competent management and technical assistance for preparation of the application and/or administration of funds granted consistent with the nature of the enterprise proposed to be or in fact funded.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62584362-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/tV/s501"},"text":"Pub. L. 93–262, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/83"},"text":"88 Stat. 83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/449/s12"},"text":"Pub. L. 98–449, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-04"},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1726"},"text":"98 Stat. 1726","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62584363-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62584364-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62584365-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/449"},"text":"Pub. L. 98–449","children":[],"tail":" amended section generally, inserting “Prior to and” and “for preparation of the application and/or administration of funds granted”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
