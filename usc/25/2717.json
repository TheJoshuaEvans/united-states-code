{"tag":"section","attrib":{"id":"id62a948cf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2717"},"text":null,"children":[{"tag":"num","attrib":{"value":"2717"},"text":"§ 2717.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62a948d0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2717/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a948d1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2717/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall establish a schedule of fees to be paid to the Commission annually by each gaming operation that conducts a class II or class III gaming activity that is regulated by this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a948d2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2717/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a948d3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2717/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The rate of the fees imposed under the schedule established under paragraph (1) shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62a948d4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2717/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no more than 2.5 percent of the first $1,500,000, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a948d5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2717/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no more than 5 percent of amounts in excess of the first $1,500,000,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"of the gross revenues from each activity regulated by this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a948d6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2717/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount of all fees imposed during any fiscal year under the schedule established under paragraph (1) shall not exceed 0.080 percent of the gross gaming revenues of all gaming operations subject to regulation under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a948d7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2717/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission, by a vote of not less than two of its members, shall annually adopt the rate of the fees authorized by this section which shall be payable to the Commission on a quarterly basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a948d8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2717/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to pay the fees imposed under the schedule established under paragraph (1) shall, subject to the regulations of the Commission, be grounds for revocation of the approval of the Chairman of any license, ordinance, or resolution required under this chapter for the operation of gaming.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a948d9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2717/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent that revenue derived from fees imposed under the schedule established under paragraph (1) are not expended or committed at the close of any fiscal year, such surplus funds shall be credited to each gaming activity on a pro rata basis against such fees imposed for the succeeding year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a948da-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2717/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, gross revenues shall constitute the annual total amount of money wagered, less any amounts paid out as prizes or paid for prizes awarded and less allowance for amortization of capital expenditures for structures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a948db-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2717/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a948dc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2717/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission, in coordination with the Secretary and in conjunction with the fiscal year of the United States, shall adopt an annual budget for the expenses and operation of the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a948dd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2717/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The budget of the Commission may include a request for appropriations, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2718"},"text":"section 2718 of this title","children":[],"tail":", in an amount equal the amount of funds derived from assessments authorized by subsection (a) for the fiscal year preceding the fiscal year for which the appropriation request is made."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a948de-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2717/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The request for appropriations pursuant to paragraph (2) shall be subject to the approval of the Secretary and shall be included as a part of the budget request of the Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62a948df-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497/s18"},"text":"Pub. L. 100–497, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2484"},"text":"102 Stat. 2484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/83/tI/s123/a/1"},"text":"Pub. L. 105–83, title I, § 123(a)(1)","children":[],"tail":"–(2)(B), "},{"tag":"date","attrib":{"date":"1997-11-14"},"text":"Nov. 14, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1566"},"text":"111 Stat. 1566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/221/tIII/s301/b"},"text":"Pub. L. 109–221, title III, § 301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-05-12"},"text":"May 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/341"},"text":"120 Stat. 341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62a948e0-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62a948e1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62a948e2-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(1), (2), (4), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497"},"text":"Pub. L. 100–497","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2467"},"text":"102 Stat. 2467","children":[],"tail":", known as the Indian Gaming Regulatory Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2701"},"text":"section 2701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62a948e3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221"},"text":"Pub. L. 109–221","children":[],"tail":" added subpar. (B) and struck out former subpar. (B) which read as follows: “The total amount of all fees imposed during any fiscal year under the schedule established under paragraph (1) shall not exceed $8,000,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/83/s123/a/1"},"text":"Pub. L. 105–83, § 123(a)(1)","children":[],"tail":", substituted “gaming operation that conducts a class II or class III gaming activity” for “class II gaming activity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/83/s123/a/2/A"},"text":"Pub. L. 105–83, § 123(a)(2)(A)","children":[],"tail":", substituted “no more than 2.5 percent” for “no less than 0.5 percent nor more than 2.5 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/83/s123/a/2/B"},"text":"Pub. L. 105–83, § 123(a)(2)(B)","children":[],"tail":", substituted “$8,000,000” for “$1,500,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62a948e4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62a948e5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application to Self-Regulated Tribes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/83/tI/s123/a/2/C"},"text":"Pub. L. 105–83, title I, § 123(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-14"},"text":"Nov. 14, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1566"},"text":"111 Stat. 1566","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tIII/s338"},"text":"Pub. L. 105–277, div. A, § 101(e) [title III, § 338]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–295, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dA/s101/e/tIII/s338"},"text":"“[N]othing in subsection (a) of this section [amending this section] shall apply to the Mississippi Band of Choctaw.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
