{"tag":"section","attrib":{"id":"id62ec1f1b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361"},"text":null,"children":[{"tag":"num","attrib":{"value":"5361"},"text":"§ 5361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ec1f1c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compact","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “compact” means a self-governance compact entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5364"},"text":"section 5364 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f1d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction program; construction project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “construction program” or “construction project” means a Tribal undertaking relating to the administration, planning, environmental determination, design, construction, repair, improvement, or expansion of roads, bridges, buildings, structures, systems, or other facilities for purposes of housing, law enforcement, detention, sanitation, water supply, education, administration, community, health, irrigation, agriculture, conservation, flood control, transportation, or port facilities, or for other Tribal purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f1e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f1f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “funding agreement” means a funding agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5363"},"text":"section 5363 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f20-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gross mismanagement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “gross mismanagement” means a significant violation, shown by a preponderance of the evidence, of a compact, funding agreement, or statutory or regulatory requirement applicable to Federal funds for a program administered by an Indian Tribe under a compact or funding agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f21-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inherent Federal function","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “inherent Federal function” means a Federal function that may not legally be delegated to an Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f22-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-BIA program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “non-BIA program” means all or a portion of a program, function, service, or activity that is administered by any bureau, service, office, or agency of the Department of the Interior other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ec1f23-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Indian Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1f24-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Assistant Secretary for Indian Affairs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1f25-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Special Trustee for American Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f26-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means any program, function, service, or activity (or portion thereof) within the Department that is included in a funding agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f27-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f28-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Self-determination contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “self-determination contract” means a self-determination contract entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"section 5321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f29-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Self-governance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “self-governance” means the Tribal Self-Governance Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5362"},"text":"section 5362 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f2a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal share","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Tribal share” means the portion of all funds and resources of an Indian Tribe that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ec1f2b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support any program within the Bureau of Indian Affairs, the Office of the Special Trustee for American Indians, or the Office of the Assistant Secretary for Indian Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1f2c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not required by the Secretary for the performance of an inherent Federal function.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f2d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal water rights settlement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Tribal water rights settlement” means any settlement, compact, or other agreement expressly ratified or approved by an Act of Congress that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ec1f2e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an Indian Tribe and the United States as parties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1f2f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5361/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantifies or otherwise defines any water right of the Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62ec1f30-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tIV/s401"},"text":"Pub. L. 93–638, title IV, § 401","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/413/tII/s204"},"text":"Pub. L. 103–413, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4271"},"text":"108 Stat. 4271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/180/tI/s101/b"},"text":"Pub. L. 116–180, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-21"},"text":"Oct. 21, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/858"},"text":"134 Stat. 858","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ec1f31-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62ec1f32-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62ec1f33-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s458aa"},"text":"section 458aa of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62ec1f34-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/180"},"text":"Pub. L. 116–180","children":[],"tail":" amended section generally. Prior to amendment, section related to establishment of a Tribal Self-Governance program. See "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5362"},"text":"section 5362 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62ec1f35-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id62ec1f36-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of this subchapter as the “Tribal Self-Governance Act of 1994”, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/413/s201"},"text":"section 201 of Pub. L. 103–413","children":[],"tail":", set out as a Short Title of 1994 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62ec1f37-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/180/tI/s101/a"},"text":"Pub. L. 116–180, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-21"},"text":"Oct. 21, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/857"},"text":"134 Stat. 857","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/180/tI/s101/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Nothing in this Act [see Short Title of 2020 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":"], or the amendments made by this Act, shall be construed—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to modify, limit, expand, or otherwise affect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the authority of the Secretary of the Interior, as provided for under the Indian Self-Determination and Education Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.] (as in effect on the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2020-10-21"},"text":"Oct. 21, 2020","children":[],"tail":"]), regarding—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inclusion of any non-BIA program (as defined in section 401 of the Indian Self-Determination and Education Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5361"},"text":"25 U.S.C. 5361","children":[],"tail":"]) in a self-determination contract or funding agreement under section 403(c) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5363/c"},"text":"25 U.S.C. 5363(c)","children":[],"tail":"] (as so in effect); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of any contract or agreement described in clause (i) that is in effect on the day described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the meaning, application, or effect of any Tribal water rights settlement, including the performance required of a party thereto or any payment or funding obligation thereunder;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority, jurisdiction, or responsibility of a State to manage, control, or regulate fish and wildlife under State law (including regulations) on land or water in the State, including Federal public land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except for the authority provided to the Secretary as described in subparagraph (A), the applicability or effect of any Federal law related to the protection or management of fish or wildlife; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any treaty-reserved right or other right of any Indian Tribe as recognized by any other means, including treaties or agreements with the United States, Executive orders, statutes, regulations, or case law; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize any provision of a contract or agreement that is not consistent with the terms of a Tribal water rights settlement.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62ec1f38-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of Other Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/180/tII/s201/d"},"text":"Pub. L. 116–180, title II, § 201(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-21"},"text":"Oct. 21, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/879"},"text":"134 Stat. 879","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/180/tII/s201/d"},"text":"“Sections 4, 5, 6, 7, 102(c), 104, 105(a)(1), 105(f), 110, and 111 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":", 5305, 5306, 5307, 5321(c), 5323, 5324(a)(1), 5324(f), 5331, and 5332) and section 314 of the Department of the Interior and Related Agencies Appropriations Act, 1991 ("},{"tag":"ref","attrib":{"href":"/us/pl/101/512"},"text":"Public Law 101–512","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/104/1959"},"text":"104 Stat. 1959","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" note], apply to compacts and funding agreements entered into under title IV of the Indian Self-Determination and Education Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5361"},"text":"25 U.S.C. 5361","children":[],"tail":" et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62ec1f39-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Statement of Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/413/tII/s202"},"text":"Pub. L. 103–413, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4270"},"text":"108 Stat. 4270","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/413/tII/s202"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tribal right of self-government flows from the inherent sovereignty of Indian tribes and nations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States recognizes a special government-to-government relationship with Indian tribes, including the right of the tribes to self-governance, as reflected in the Constitution, treaties, Federal statutes, and the course of dealings of the United States with Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" although progress has been made, the Federal bureaucracy, with its centralized rules and regulations, has eroded tribal self-governance and dominates tribal affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Tribal Self-Governance Demonstration Project [see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tIII"},"text":"Pub. L. 93–638, title III","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/100/472/tII/s209"},"text":"Pub. L. 100–472, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-05"},"text":"Oct. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2296"},"text":"102 Stat. 2296","children":[],"tail":", formerly set out as a note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450f"},"text":"25 U.S.C. 450f","children":[],"tail":"] was designed to improve and perpetuate the government-to-government relationship between Indian tribes and the United States and to strengthen tribal control over Federal funding and program management; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Congress has reviewed the results of the Tribal Self-Governance Demonstration Project and finds that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transferring control to tribal governments, upon tribal request, over funding and decisionmaking for Federal programs, services, functions, and activities, or portions thereof, is an effective way to implement the Federal policy of government-to-government relations with Indian tribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transferring control to tribal governments, upon tribal request, over funding and decisionmaking for Federal programs, services, functions, and activities strengthens the Federal policy of Indian self-determination.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62ec1f3a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Declaration of Policy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/413/tII/s203"},"text":"Pub. L. 103–413, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4271"},"text":"108 Stat. 4271","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/413/tII/s203"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“It is the policy of this title [enacting this subchapter] to permanently establish and implement tribal self-governance—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable the United States to maintain and improve its unique and continuing relationship with, and responsibility to, Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to permit each Indian tribe to choose the extent of the participation of such tribe in self-governance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coexist with the provisions of the Indian Self-Determination Act [title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":"] relating to the provision of Indian services by designated Federal agencies;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure the continuation of the trust responsibility of the United States to Indian tribes and Indian individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to permit an orderly transition from Federal domination of programs and services to provide Indian tribes with meaningful authority to plan, conduct, redesign, and administer programs, services, functions, and activities that meet the needs of the individual tribal communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for an orderly transition through a planned and measurable parallel reduction in the Federal bureaucracy.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
