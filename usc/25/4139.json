{"tag":"section","attrib":{"id":"id62cf6ee2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4139"},"text":null,"children":[{"tag":"num","attrib":{"value":"4139"},"text":"§ 4139.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance with affordable housing requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If a recipient uses grant amounts to provide affordable housing under this subchapter, and at any time during the useful life of the housing the recipient does not comply with the requirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4135/a/2"},"text":"section 4135(a)(2) of this title","children":[],"tail":", the Secretary shall take appropriate action under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4161/a"},"text":"section 4161(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62cf6ee3-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tII/s209"},"text":"Pub. L. 104–330, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4035"},"text":"110 Stat. 4035","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s595/c"},"text":"Pub. L. 105–276, title V, § 595(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2656"},"text":"112 Stat. 2656","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tX/s1003/f/1"},"text":"Pub. L. 106–568, title X, § 1003(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2927"},"text":"114 Stat. 2927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s503/e/1"},"text":"Pub. L. 106–569, title V, § 503(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2962"},"text":"114 Stat. 2962","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62cf6ee4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62cf6ee5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62cf6ee6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568"},"text":"Pub. L. 106–568","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569"},"text":"Pub. L. 106–569","children":[],"tail":" generally amended section catchline and text identically. Prior to amendment, text read as follows: “If a recipient uses grant amounts to provide affordable housing under activities under this subchapter and, at any time during the useful life of the housing the housing does not comply with the requirement under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4135/a/2"},"text":"section 4135(a)(2) of this title","children":[],"tail":", the Secretary shall reduce future grant payments on behalf of the grant beneficiary by an amount equal to the grant amounts used for such housing (under the authority under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4161/a/2"},"text":"section 4161(a)(2) of this title","children":[],"tail":") or require repayment to the Secretary of an amount equal to such grant amounts.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276"},"text":"Pub. L. 105–276","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4135/a/2"},"text":"section 4135(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62cf6ee7-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id62cf6ee8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s107"},"text":"section 107 of Pub. L. 104–330","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
