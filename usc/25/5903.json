{"tag":"section","attrib":{"id":"id62fa4f20-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5903"},"text":null,"children":[{"tag":"num","attrib":{"value":"5903"},"text":"§ 5903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Realty Ombudsman position","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62fa4f21-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish within the Division of Real Estate Services of the Bureau the position of Realty Ombudsman, who shall report directly to the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62fa4f22-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Realty Ombudsman shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62fa4f23-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the applicable Bureau offices are meeting the mortgage review and processing deadlines established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5902/a"},"text":"section 5902(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62fa4f24-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the applicable Bureau offices comply with the notices required under subsections (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5902"},"text":"section 5902 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62fa4f25-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5903/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" serve as a liaison to other Federal agencies, including by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62fa4f26-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5903/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring the Bureau is responsive to all of the inquiries from the relevant Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62fa4f27-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5903/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" helping to facilitate communications between the relevant Federal agencies and the Bureau on matters relating to mortgages on Indian land;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62fa4f28-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5903/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive inquiries, questions, and complaints directly from Indian Tribes, members of Indian Tribes, and lenders in regard to executed residential leasehold mortgages, business leasehold mortgages, land mortgages, or right-of-way documents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62fa4f29-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5903/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the intermediary between the Indian Tribes, members of Indian Tribes, and lenders and the Bureau in responding to inquiries and questions and resolving complaints.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62fa4f2a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/88/s4"},"text":"Pub. L. 119–88, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-05-04"},"text":"May 4, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/816"},"text":"140 Stat. 816","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
