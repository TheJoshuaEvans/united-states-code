{"tag":"section","attrib":{"id":"id62cf6fb4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165"},"text":null,"children":[{"tag":"num","attrib":{"value":"4165"},"text":"§ 4165.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and audit by Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62cf6fb5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements under chapter 75 of title 31","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity designated by an Indian tribe as a housing entity shall be treated, for purposes of chapter 75 of title 31, as a non-Federal entity that is subject to the audit requirements that apply to non-Federal entities under that chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cf6fb6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional reviews and audits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cf6fb7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any audit or review under subsection (a), to the extent the Secretary determines such action to be appropriate, the Secretary may conduct an audit or review of a recipient in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cf6fb8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determine whether the recipient—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62cf6fb9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has carried out—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62cf6fba-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165/b/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible activities in a timely manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62cf6fbb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165/b/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible activities and certification in accordance with this chapter and other applicable law;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cf6fbc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a continuing capacity to carry out eligible activities in a timely manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cf6fbd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in compliance with the Indian housing plan of the recipient; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cf6fbe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verify the accuracy of information contained in any performance report submitted by the recipient under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4164"},"text":"section 4164 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6fbf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On-site visits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, the reviews and audits conducted under this subsection shall include on-site visits by the appropriate official of the Department of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cf6fc0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cf6fc1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide each recipient that is the subject of a report made by the Secretary under this section notice that the recipient may review and comment on the report during a period of not less than 30 days after the date on which notice is issued under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6fc2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After taking into consideration any comments of the recipient under paragraph (1), the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cf6fc3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may revise the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cf6fc4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 30 days after the date on which those comments are received, shall make the comments and the report (with any revisions made under subparagraph (A)) readily available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cf6fc5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4165/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of reviews","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4161/a"},"text":"section 4161(a) of this title","children":[],"tail":", after reviewing the reports and audits relating to a recipient that are submitted to the Secretary under this section, the Secretary may adjust the amount of a grant made to a recipient under this chapter in accordance with the findings of the Secretary with respect to those reports and audits."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62cf6fc6-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tIV/s405"},"text":"Pub. L. 104–330, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4040"},"text":"110 Stat. 4040","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tX/s1003/f/2"},"text":"Pub. L. 106–568, title X, § 1003(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2927"},"text":"114 Stat. 2927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s503/e/2"},"text":"Pub. L. 106–569, title V, § 503(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2963"},"text":"114 Stat. 2963","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62cf6fc7-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62cf6fc8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62cf6fc9-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b)(1)(A)(i)(II) and (d), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", known as the Native American Housing Assistance and Self-Determination Act of 1996. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62cf6fca-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568"},"text":"Pub. L. 106–568","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569"},"text":"Pub. L. 106–569","children":[],"tail":" amended section identically, reenacting section catchline without change and amending text generally. Prior to amendment, section required the Secretary to make reviews and audits of recipients’ activities and performance, to prepare reports, and to make adjustments in amounts of annual grants under this chapter based on the reviews and audits."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62cf6fcb-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id62cf6fcc-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s107"},"text":"section 107 of Pub. L. 104–330","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
