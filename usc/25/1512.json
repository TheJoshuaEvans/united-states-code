{"tag":"section","attrib":{"id":"id6255d249-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1512"},"text":null,"children":[{"tag":"num","attrib":{"value":"1512"},"text":"§ 1512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for interest payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for fiscal year 1985, and for each fiscal year thereafter, an amount which does not exceed $5,500,000 for purposes of making interest payments authorized under this subchapter. Sums appropriated under this section, shall remain available until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6255d24a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/tIII/s302"},"text":"Pub. L. 93–262, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/82"},"text":"88 Stat. 82","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/449/s8"},"text":"Pub. L. 98–449, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-04"},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1725"},"text":"98 Stat. 1725","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6255d24b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6255d24c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6255d24d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/449"},"text":"Pub. L. 98–449","children":[],"tail":" amended section generally, substituting provisions authorizing appropriations for payment of interest under this subchapter for provisions authorizing appropriations for the Indian Loan Guarantee and Insurance Fund, interest subsidies and administrative expenses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
