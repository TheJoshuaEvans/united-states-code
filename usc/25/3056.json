{"tag":"section","attrib":{"id":"id62b075e3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056"},"text":null,"children":[{"tag":"num","attrib":{"value":"3056"},"text":"§ 3056.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on disclosure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b075e4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondisclosure of information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b075e5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not disclose under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" (commonly known as the “Freedom of Information Act”), information relating to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b075e6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (b)(l),","children":[{"tag":"ref","attrib":{"idref":"fn002203"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002203"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “(b)(1),”."}],"tail":" human remains or cultural items reburied on National Forest System land under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3053"},"text":"section 3053 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b075e7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to subsection (b)(2), resources, cultural items, uses, or activities that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b075e8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a traditional and cultural purpose; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b075e9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are provided to the Secretary by an Indian or Indian tribe under an express expectation of confidentiality in the context of forest and rangeland research activities carried out under the authority of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b075ea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on disclosure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b)(2), the Secretary shall not be required to disclose information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" (commonly known as the “Freedom of Information Act”), concerning the identity, use, or specific location in the National Forest System of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b075eb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a site or resource used for traditional and cultural purposes by an Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b075ec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any cultural items not covered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3053"},"text":"section 3053 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b075ed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited release of information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b075ee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reburial","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may disclose information described in subsection (a)(l)(A) ","children":[{"tag":"ref","attrib":{"idref":"fn002204"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002204"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “(a)(1)(A)”."}],"tail":" if, before the disclosure, the Secretary—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b075ef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consults with an affected Indian tribe or lineal descendent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b075f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determines that disclosure of the information—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b075f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would advance the purposes of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b075f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to protect the human remains or cultural items from harm, theft, or destruction; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b075f3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attempts to mitigate any adverse impacts identified by an Indian tribe or lineal descendant that reasonably could be expected to result from disclosure of the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b075f4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with appropriate Indian tribes, may disclose information described under paragraph (1)(B) or (2) of subsection (a) if the Secretary determines that disclosure of the information to the public—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b075f5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would advance the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b075f6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would not create an unreasonable risk of harm, theft, or destruction of the resource, site, or object, including individual organic or inorganic specimens; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b075f7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3056/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be consistent with other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b075f8-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVIII/s8106"},"text":"Pub. L. 110–234, title VIII, § 8106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1288"},"text":"122 Stat. 1288","children":[],"tail":"; "},{"ta