{"tag":"section","attrib":{"id":"id62c5f93a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3743"},"text":null,"children":[{"tag":"num","attrib":{"value":"3743"},"text":"§ 3743.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Severability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter, or the application of any provision of this chapter to any person or circumstance, is held invalid, the application of such provision or circumstance and the remainder of this chapter shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62c5f93b-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/177/tIII/s303"},"text":"Pub. L. 103–177, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2022"},"text":"107 Stat. 2022","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
