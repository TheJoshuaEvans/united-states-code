{"tag":"section","attrib":{"id":"id62ec1f3b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362"},"text":null,"children":[{"tag":"num","attrib":{"value":"5362"},"text":"§ 5362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal Self-Governance Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62ec1f3c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and carry out a program within the Department to be known as the “Tribal Self-Governance Program”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ec1f3d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of participating Indian Tribes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ec1f3e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ec1f3f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Office of Self-Governance, may select not more than 50 new Indian Tribes per year from those tribes eligible under subsection (c) to participate in self-governance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1f40-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the request of each participating Indian Tribe, 2 or more otherwise eligible Indian Tribes may be treated as a single Indian Tribe for the purpose of participating in self-governance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f41-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other authorized Indian Tribe or Tribal organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an Indian Tribe authorizes another Indian Tribe or a Tribal organization to plan for or carry out a program on its behalf under this subchapter, the authorized Indian Tribe or Tribal organization shall have the rights and responsibilities of the authorizing Indian Tribe (except as otherwise provided in the authorizing resolution).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f42-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint participation as organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Two or more Indian Tribes that are not otherwise eligible under subsection (c) may be treated as a single Indian Tribe for the purpose of participating in self-governance as a Tribal organization if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ec1f43-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each Indian Tribe so requests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1f44-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Tribal organization itself, or at least one of the Indian Tribes participating in the Tribal organization, is eligible under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f45-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal withdrawal from a Tribal organization","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ec1f46-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian Tribe that withdraws from participation in a Tribal organization, in whole or in part, shall be entitled to participate in self-governance if the Indian Tribe is eligible under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1f47-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of withdrawal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an Indian Tribe withdraws from participation in a Tribal organization, the Indian Tribe shall be entitled to its Tribal share of funds and resources supporting the programs that the Indian Tribe is entitled to carry out under the compact and funding agreement of the Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1f48-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in self-governance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The withdrawal of an Indian Tribe from a Tribal organization shall not affect the eligibility of the Tribal organization to participate in self-governance on behalf of one or more other Indian Tribes, if the Tribal organization still qualifies under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1f49-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal process","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62ec1f4a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian Tribe may, by Tribal resolution, fully or partially withdraw its Tribal share of any program in a funding agreement from a participating Tribal organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ec1f4b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Indian Tribe shall provide a copy of the Tribal resolution described in clause (i) to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ec1f4c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62ec1f4d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/D/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A withdrawal under clause (i) shall become effective on the date that is specified in the Tribal resolution and mutually agreed upon by the Secretary, the withdrawing Indian Tribe, and the Tribal organization that signed the compact and funding agreement on behalf of the withdrawing Indian Tribe or Tribal organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62ec1f4e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/D/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No specified date","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the absence of a date specified in the resolution, the withdrawal shall become effective on—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id62ec1f4f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/D/iii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the earlier of—","children":[],"tail":null},{"tag":"subitem","attrib":{"id":"id62ec1f50-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/D/iii/II/aa/AA"},"text":null,"children":[{"tag":"num","attrib":{"value":"AA"},"text":"(AA)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 year after the date of submission of the request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subitem","attrib":{"id":"id62ec1f51-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/D/iii/II/aa/BB"},"text":null,"children":[{"tag":"num","attrib":{"value":"BB"},"text":"(BB)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the funding agreement expires; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id62ec1f52-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/D/iii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such date as may be mutually agreed upon by the Secretary, the withdrawing Indian Tribe, and the Tribal organization that signed the compact and funding agreement on behalf of the withdrawing Indian Tribe or Tribal organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1f53-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an Indian Tribe or Tribal organization eligible to enter into a self-determination contract or a compact or funding agreement fully or partially withdraws from a participating Tribal organization, the withdrawing Indian Tribe—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62ec1f54-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may elect to enter into a self-determination contract or compact, in which case—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62ec1f55-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/E/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the withdrawing Indian Tribe or Tribal organization shall be entitled to its Tribal share of unexpended funds and resources supporting the programs that the Indian Tribe will be carrying out under its own self-determination contract or compact and funding agreement (calculated on the same basis as the funds were initially allocated to the funding agreement of the Tribal organization); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62ec1f56-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/E/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funds referred to in subclause (I) shall be withdrawn by the Secretary from the funding agreement of the Tribal organization and transferred to the withdrawing Indian Tribe, on the condition that sections 5321 and 5324(i) of this title, as appropriate, shall apply to the withdrawing Indian Tribe; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ec1f57-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may elect not to enter into a self-determination contract or compact, in which case all unexpended funds and resources associated with the withdrawing Indian Tribe’s returned programs (calculated on the same basis as the funds were initially allocated to the funding agreement of the Tribal organization) shall be returned by the Tribal organization to the Secretary for operation of the programs included in the withdrawal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1f58-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return to mature contract status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an Indian Tribe elects to operate all or some programs carried out under a compact or funding agreement under this subchapter through a self-determination contract under subchapter I, at the option of the Indian Tribe, the resulting self-determination contract shall be a mature self-determination contract as long as the Indian Tribe meets the requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/h"},"text":"section 5304(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ec1f59-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to participate in self-governance, an Indian Tribe shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ec1f5a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successfully complete the planning phase described in subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f5b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request participation in self-governance by resolution or other official action by the Tribal governing body; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f5c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate, for the 3 fiscal years preceding the date on which the Indian Tribe requests participation, financial stability and financial management capability as evidenced by the Indian Tribe having no uncorrected significant and material audit exceptions in the required annual audit of its self-determination or self-governance agreements with any Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ec1f5d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning phase","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ec1f5e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian Tribe seeking to begin participation in self-governance shall complete a planning phase as provided in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f5f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The planning phase shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ec1f60-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be conducted to the satisfaction of the Indian Tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1f61-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62ec1f62-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legal and budgetary research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ec1f63-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" internal Tribal government planning, training, and organizational preparation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ec1f64-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ec1f65-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, an Indian Tribe or Tribal organization that meets the requirements of paragraphs (2) and (3) of subsection (c) shall be eligible for grants—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ec1f66-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to plan for participation in self-governance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ec1f67-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to negotiate the terms of participation by the Indian Tribe or Tribal organization in self-governance, as set forth in a compact and a funding agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ec1f68-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5362/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt of grant not required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Receipt of a grant under paragraph (1) shall not be a requirement of participation in self-governance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62ec1f69-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tIV/s402"},"text":"Pub. L. 93–638, title IV, § 402","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/413/tII/s204"},"text":"Pub. L. 103–413, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4272"},"text":"108 Stat. 4272","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/d/tI/s117"},"text":"Pub. L. 104–208, div. A, title I, § 101(d) [title I, § 117]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-181"},"text":"110 Stat. 3009–181","children":[],"tail":", 3009–201; "},{"tag":"ref","attrib":{"href":"/us/pl/116/180/tI/s101/c"},"text":"Pub. L. 116–180, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-21"},"text":"Oct. 21, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/859"},"text":"134 Stat. 859","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ec1f6a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62ec1f6b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62ec1f6c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter I, referred to in subsec. (b)(4)(F), was in the original “title I”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", known as the Indian Self-Determination Act, which is classified principally to subchapter I (§ 5321 et seq.) of this chapter. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62ec1f6d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s458bb"},"text":"section 458bb of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62ec1f6e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/180"},"text":"Pub. L. 116–180","children":[],"tail":" amended section generally. Prior to amendment, section related to selection of Indian tribes to participate in Self-Governance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “In addition to those Indian tribes participating in Self-Governance under subsection (a) of this section, the Secretary, acting through the Director of the Office of Self-Governance, may select up to 20 new tribes per year from the applicant pool described in subsection (c) of this section to participate in Self-Governance.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
