{"tag":"section","attrib":{"id":"id62f34ade-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5393"},"text":null,"children":[{"tag":"num","attrib":{"value":"5393"},"text":"§ 5393.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget request","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f34adf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5393/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of annual budget request","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34ae0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5393/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall identify in the annual budget request submitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" all funds necessary to fully fund all funding agreements authorized under this subchapter, including funds specifically identified to fund tribal base budgets. All funds so appropriated shall be apportioned to the Indian Health Service. Such funds shall be provided to the Office of Tribal Self-Governance which shall be responsible for distribution of all funds provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5385"},"text":"section 5385 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34ae1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5393/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to authorize the Indian Health Service to reduce the amount of funds that a self-governance tribe is otherwise entitled to receive under its funding agreement or other applicable law, whether or not such funds are apportioned to the Office of Tribal Self-Governance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34ae2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5393/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Present funding; shortfalls","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In such budget request, the President shall identify the level of need presently funded and any shortfall in funding (including direct program and contract support costs) for each Indian tribe, either directly by the Secretary of Health and Human Services, under self-determination contracts, or under compacts and funding agreements authorized under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f34ae3-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tV/s513"},"text":"Pub. L. 93–638, title V, § 513","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/260/s4"},"text":"Pub. L. 106–260, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-18"},"text":"Aug. 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/727"},"text":"114 Stat. 727","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62f34ae4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62f34ae5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62f34ae6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s458aaa–12"},"text":"section 458aaa–12 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
