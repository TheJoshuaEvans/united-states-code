{"tag":"section","attrib":{"id":"id621323d7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s60"},"text":null,"children":[{"tag":"num","attrib":{"value":"60"},"text":"§ 60.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation prescribed to be in full","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The several compensations prescribed by title 28 of the Revised Statutes shall be in full of all emoluments or allowances whatsoever. But where necessary, a reasonable allowance or provision may be made for offices and office contingencies.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621323d8-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2076.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621323d9-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621323da-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id621323db-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title 28 of the Revised Statutes, referred to in text, was in the original “this title”, meaning title 28 of the Revised Statutes, consisting of R.S. §§ 2039 to 2157. For complete classification of R.S. §§ 2039 to 2157 to the Code, see Tables.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id621323dc-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2076 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1834-06-30/ch162/s10"},"text":"act June 30, 1834, ch. 162, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/737"},"text":"4 Stat. 737","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
