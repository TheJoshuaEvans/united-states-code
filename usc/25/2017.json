{"tag":"section","attrib":{"id":"id628f0af5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2017"},"text":null,"children":[{"tag":"num","attrib":{"value":"2017"},"text":"§ 2017.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id628f0af6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2017/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628f0af7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2017/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may promulgate only such regulations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628f0af8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2017/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as are necessary to ensure compliance with the specific provisions of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628f0af9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2017/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the Secretary is authorized to promulgate pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2510"},"text":"section 2510 of this title","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002131"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002131"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “2509”."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628f0afa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2017/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In promulgating the regulations, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628f0afb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2017/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish proposed regulations in the Federal Register; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628f0afc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2017/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a period of not less than 120 days for public comment and consultation on the regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628f0afd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2017/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations shall contain, immediately following each regulatory section, a citation to any statutory provision providing authority to promulgate such regulatory section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0afe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2017/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this Act shall supersede any conflicting provisions of law (including any conflicting regulations) in effect on the day before the date of enactment of this Act and the Secretary is authorized to repeal any regulation inconsistent with the provisions of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id628f0aff-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1137"},"text":"Pub. L. 95–561, title XI, § 1137","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1042"},"text":"Pub. L. 107–110, title X, § 1042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2056"},"text":"115 Stat. 2056","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id628f0b00-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id628f0b01-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id628f0b02-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561"},"text":"Pub. L. 95