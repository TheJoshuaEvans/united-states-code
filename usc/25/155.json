{"tag":"section","attrib":{"id":"id621a289d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s155"},"text":null,"children":[{"tag":"num","attrib":{"value":"155"},"text":"§ 155.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of miscellaneous revenues from Indian reservations, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All miscellaneous revenues derived from Indian reservations, agencies, and schools, except those of the Five Civilized Tribes and not the result of the labor of any member of such tribe, which are not required by existing law to be otherwise disposed of, shall be covered into the Treasury of the United States under the caption “Indian moneys, proceeds of labor”, and are made available for expenditure, in the discretion of the Secretary of the Interior, for the benefit of the Indian tribes, agencies, and schools on whose behalf they are collected, subject, however, to the limitations as to tribal funds, imposed by sections 123 and 142 ","children":[{"tag":"ref","attrib":{"idref":"fn002008"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002008"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621a289e-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1883-03-03/ch141/s2"},"text":"Mar. 3, 1883, ch. 141, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/22/590"},"text":"22 Stat. 590","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1887-03-02/ch320"},"text":"Mar. 2, 1887, ch. 320","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/463"},"text":"24 Stat. 463","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1926-05-17/ch309/s1"},"text":"May 17, 1926, ch. 309, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/560"},"text":"44 Stat. 560","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1928-05-29/ch901/s1/68"},"text":"May 29, 1928, ch. 901, § 1(68)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/991"},"text":"45 Stat. 991","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621a289f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621a28a0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id621a28a1-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s142"},"text":"Section 142 of this title","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1928-05-29/ch901/s1/87"},"text":"act May 29, 1928, ch. 901, § 1(87)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/992"},"text":"45 Stat. 992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id621a28a2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"id621a28a3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1928-05-29"},"text":"May 29, 1928","children":[],"tail":", repealed the provisions of acts "},{"tag":"date","attrib":{"date":"1883-03-03"},"text":"Mar. 3, 1883","children":[],"tail":" and "},{"tag":"date","attrib":{"date":"1887-03-02"},"text":"Mar. 2, 1887","children":[],"tail":", which related to Indian moneys, proceeds of labor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id621a28a4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id621a28a5-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
