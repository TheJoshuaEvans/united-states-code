{"tag":"section","attrib":{"id":"id62f34b80-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5413"},"text":null,"children":[{"tag":"num","attrib":{"value":"5413"},"text":"§ 5413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative services and support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f34b81-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of support by Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), during the 5-year period beginning on the date on which the Foundation is established, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34b82-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5413/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide personnel, facilities, and other administrative support services to the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b83-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5413/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide funds for initial operating costs and to reimburse the travel expenses of the members of the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b84-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5413/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall require and accept reimbursements from the Foundation for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f34b85-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5413/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services provided under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f34b86-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5413/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds provided under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b87-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Reimbursements accepted under subsection (a)(3)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34b88-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5413/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be deposited in the Treasury of the United States to the credit of the applicable appropriations account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b89-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5413/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be chargeable for the cost of providing services described in subsection (a)(1) and travel expenses described in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b8a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5413/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of certain services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may continue to provide facilities and necessary support services to the Foundation after the termination of the 5-year period specified in subsection (a) if the facilities and services are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34b8b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5413/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b8c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5413/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided on reimbursable cost basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f34b8d-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tVII/s703"},"text":"Pub. L. 93–638, title VII, § 703","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s231/c"},"text":"Pub. L. 111–211, title II, § 231(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2277"},"text":"124 Stat. 2277","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62f34b8e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62f34b8f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62f34b90-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s458ccc–2"},"text":"section 458ccc–2 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
