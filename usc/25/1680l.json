{"tag":"section","attrib":{"id":"id6279ad3e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680l"},"text":null,"children":[{"tag":"num","attrib":{"value":"1680l"},"text":"§ 1680l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shared services for long-term care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6279ad3f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term care","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6279ad40-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary, acting through the Service, is authorized to provide directly, or enter into contracts or compacts under the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.) "},{"tag":"ref","attrib":{"idref":"fn002096"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002096"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" with Indian tribes or tribal organizations for, the delivery of long-term care (including health care services associated with long-term care) provided in a facility to Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279ad41-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each agreement under paragraph (1) shall provide for the sharing of staff or other services between the Service or a tribal health program and a long-term care or related facility owned and operated (directly or through a contract or compact under the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.)) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" by the Indian tribe or tribal organization."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6279ad42-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement entered into pursuant to subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6279ad43-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680l/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, at the request of the Indian tribe or tribal organization, delegate to the Indian tribe or tribal organization such powers of supervision and control over Service employees as the Secretary determines to be necessary to carry out the purposes of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279ad44-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680l/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide that expenses (including salaries) relating to services that are shared between the Service and the tribal health program be allocated proportionately between the Service and the Indian tribe or tribal organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279ad45-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680l/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may authorize the Indian tribe or tribal organization to construct, renovate, or expand a long-term care or other similar facility (including the construction of a facility attached to a Service facility).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6279ad46-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any nursing facility provided for under this section shall meet the requirements for nursing facilities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396r"},"text":"section 1396r of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6279ad47-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide such technical and other assistance as may be necessary to enable applicants to comply with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6279ad48-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680l/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of existing or underused facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall encourage the use of existing facilities that are underused, or allow the use of swing beds, for long-term or similar care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6279ad49-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s822"},"text":"Pub. L. 94–437, title VIII, § 822","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVIII/s810"},"text":"Pub. L. 102–573, title VIII, § 810","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4588"},"text":"106 Stat. 4588","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6279ad4a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6279ad4b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6279ad4c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.), referred to in subsec. (a), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of this title prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6279ad4d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" is based on section 124(b) of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6279ad4e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" amended section generally. Prior to amendment, section related to shared services demonstration project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
