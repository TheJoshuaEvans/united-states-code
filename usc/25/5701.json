{"tag":"section","attrib":{"id":"id62f804d4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5701"},"text":null,"children":[{"tag":"num","attrib":{"value":"5701"},"text":"§ 5701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f804d5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to clarify the responsibilities of Federal, State, Tribal, and local law enforcement agencies with respect to responding to cases of missing or murdered Indians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f804d6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase coordination and communication among Federal, State, Tribal, and local law enforcement agencies, including medical examiner and coroner offices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f804d7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to empower Tribal governments with the resources and information necessary to effectively respond to cases of missing or murdered Indians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f804d8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5701/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the collection of data related to missing or murdered Indian men, women, and children, regardless of where they reside, and the sharing of information among Federal, State, and Tribal officials responsible for responding to and investigating cases of missing or murdered Indians.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f804d9-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/165/s2"},"text":"Pub. L. 116–165, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-10"},"text":"Oct. 10, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/760"},"text":"134 Stat. 760","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62f804da-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62f804db-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62f804dc-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/165"},"text":"Pub. L. 116–165","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-10"},"text":"Oct. 10, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/760"},"text":"134 Stat. 760","children":[],"tail":", known as Savanna’s Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62f804dd-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id62f804de-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/165/s1"},"text":"Pub. L. 116–165, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-10"},"text":"Oct. 10, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/760"},"text":"134 Stat. 760","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/165/s1"},"text":"“This Act [enacting this chapter and amending sections 10452, 10461, and 20126 of Title 34, Crime Control and Law Enforcement] may be cited as ‘Savanna’s Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
