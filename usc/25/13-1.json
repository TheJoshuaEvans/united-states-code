{"tag":"section","attrib":{"id":"id620bf7ae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s13–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"13–1"},"text":"§ 13–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for funds for basic educational support through parent committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Such sums as are needed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":" are authorized to be appropriated to provide funds for basic educational support through parent committees under the Act of "},{"tag":"date","attrib":{"date":"1934-04-16"},"text":"April 16, 1934","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5342"},"text":"25 U.S.C. 5342","children":[],"tail":" et seq.], to those public schools educating Indian students and whose total sum of Federal, State, and local funds is insufficient to bring the education of the enrolled Indian students to a level equal to the level of education provided non-Indian students in the public schools in which they are enrolled where the absence of such support would result in the closing of schools or the reduction in quality of the education program afforded Indian students attending public schools."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id620bf7af-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1103/b"},"text":"Pub. L. 95–561, title XI, § 1103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2316"},"text":"92 Stat. 2316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id620bf7b0-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":