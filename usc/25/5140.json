{"tag":"section","attrib":{"id":"id62db56b0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5140"},"text":null,"children":[{"tag":"num","attrib":{"value":"5140"},"text":"§ 5140.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgaged property governed by State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Trust or restricted tribal or tribal corporation property mortgaged pursuant to sections 5136 to 5143 of this title shall be subject to foreclosure and sale or conveyance in lieu of foreclosure, free of such trust or restrictions, in accordance with the laws of the State in which the property is located.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62db56b1-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/229/s4"},"text":"Pub. L. 91–229, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-11"},"text":"Apr. 11, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/120"},"text":"84 Stat. 120","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62db56b2-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62db56b3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62db56b4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s491"},"text":"section 491 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
