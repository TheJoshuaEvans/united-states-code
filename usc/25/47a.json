{"tag":"section","attrib":{"id":"id6213239e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s47a"},"text":null,"children":[{"tag":"num","attrib":{"value":"47a"},"text":"§ 47a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security required by Secretary; contracts with Indian-owned economic enterprise; public work","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, in his discretion, may require security other than bonds required by sections 3131 and 3133 of title 40 when entering into a contract with an Indian-owned economic enterprise pursuant to the provisions of the Act of ","children":[{"tag":"date","attrib":{"date":"1910-06-25"},"text":"June 25, 1910","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s47"},"text":"25 U.S.C. 47","children":[],"tail":"), for the construction, alteration, or repair of any public work of the United States: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That, the alternative form of security provides the United States with adequate security for performance and payment."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6213239f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/449/s11"},"text":"Pub. L. 98–449, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-04"},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1726"},"text":"98 Stat. 1726","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621323a0-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621323a1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id621323a2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Sections 3131 and 3133 of title 40” substituted in text for “the Miller Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s270a"},"text":"40 U.S.C. 270a","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
