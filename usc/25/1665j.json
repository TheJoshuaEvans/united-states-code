{"tag":"section","attrib":{"id":"id627281bf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1665j"},"text":"§ 1665j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Behavioral health program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id627281c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovative programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1665a"},"text":"section 1665a of this title","children":[],"tail":", may plan, develop, implement, and carry out programs to deliver innovative community-based behavioral health services to Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627281c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards; criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award a grant for a project under subsection (a) to an Indian tribe or tribal organization and may consider the following criteria:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627281c2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project will address significant unmet behavioral health needs among Indians.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627281c3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project will serve a significant number of Indians.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627281c4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665j/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project has the potential to deliver services in an efficient and effective manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627281c5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665j/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Indian tribe or tribal organization has the administrative and financial capability to administer the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627281c6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665j/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project may deliver services in a manner consistent with traditional health care practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627281c7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665j/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project is coordinated with, and avoids duplication of, existing services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627281c8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection,","children":[{"tag":"ref","attrib":{"idref":"fn002089"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002089"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section,”."}],"tail":" the Secretary shall, in evaluating project applications or proposals, use the same criteria that the Secretary uses in evaluating any other application or proposal for such funding."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id627281c9-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s711"},"text":"Pub. L. 94–437, title VII, § 711","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id627281ca-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id627281cb-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id627281cc-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s711"},"text":"Section 711 of Pub. L. 94–437","children":[],"tail":" is based on section 181 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id627281cd-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1665j, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s711"},"text":"Pub. L. 94–437, title VII, § 711","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s702/a"},"text":"Pub. L. 102–573, title VII, § 702(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4580"},"text":"106 Stat. 4580","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/313/s2/f"},"text":"Pub. L. 104–313, § 2(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3822"},"text":"110 Stat. 3822","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s901/d"},"text":"Pub. L. 105–244, title IX, § 901(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1828"},"text":"112 Stat. 1828","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/256/s13/a"},"text":"Pub. L. 105–256, § 13(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-14"},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1900"},"text":"112 Stat. 1900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s941/k/2/I/iii"},"text":"Pub. L. 110–315, title IX, § 941(k)(2)(I)(iii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3467"},"text":"122 Stat. 3467","children":[],"tail":", authorized substance abuse counselor education demonstration projects, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
