{"tag":"section","attrib":{"id":"id62f59497-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633"},"text":null,"children":[{"tag":"num","attrib":{"value":"5633"},"text":"§ 5633.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary for Indian Affairs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f59498-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of position","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary may establish in the Department the position of Under Secretary for Indian Affairs, who shall report directly to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f59499-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f5949a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Under Secretary shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f5949b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The individual serving as the Assistant Secretary for Indian Affairs on ","children":[{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", may assume the position of Under Secretary without appointment under paragraph (1), if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f5949c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that individual was appointed as Assistant Secretary for Indian Affairs by the President, by and with the advice and consent of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f5949d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", the Secretary approves the assumption."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f5949e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any other duties directed by the Secretary, the Under Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f5949f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the Special Trustee for American Indians to ensure an orderly transition of the functions of the Special Trustee to one or more appropriate agencies, offices, or bureaus within the Department, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f594a0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the maximum extent practicable, supervise and coordinate activities and policies of the BIA with activities and policies of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f594a1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Reclamation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f594a2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Land Management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f594a3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Natural Resources Revenue;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f594a4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Park Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f594a5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Fish and Wildlife Service; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f594a6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for regular consultation with Indians and Indian tribes that own interests in trust resources and trust fund accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f594a7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f594a8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary may appoint and fix the compensation of such officers and employees as the Under Secretary determines to be necessary to carry out any function transferred under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f594a9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided by law—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f594aa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any officer or employee described in paragraph (1) shall be appointed in accordance with the civil service laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f594ab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compensation of such an officer or employee shall be fixed in accordance with title 5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f594ac-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5633/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in appointing or otherwise hiring any employee, the Under Secretary shall give preference to Indians in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5116"},"text":"section 5116 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f594ad-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/178/tIII/s303"},"text":"Pub. L. 114–178, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/440"},"text":"130 Stat. 440","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
