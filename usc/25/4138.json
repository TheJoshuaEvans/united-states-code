{"tag":"section","attrib":{"id":"id62cf6ed7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4138"},"text":null,"children":[{"tag":"num","attrib":{"value":"4138"},"text":"§ 4138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62cf6ed8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4138/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, except as provided in subsection (b), the National Crime Information Center, police departments, and other law enforcement agencies shall, upon request, provide information to Indian tribes or tribally designated housing entities regarding the criminal conviction records of applicants for employment, and of adult applicants for, or tenants of, housing assisted with grant amounts provided to such tribe or entity under this chapter for purposes of applicant screening, lease enforcement, and eviction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cf6ed9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4138/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A law enforcement agency described in subsection (a) shall provide information under this paragraph relating to any criminal conviction of a juvenile only to the extent that the release of such information is authorized under the law of the applicable State, tribe, or locality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cf6eda-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4138/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian tribe or tribally designated housing entity receiving information under this section may use such information only for the purposes provided in this section and such information may not be disclosed to any person who is not an officer, employee, or authorized representative of the tribe or entity or the owner of housing assisted under this chapter, and who has a job-related need to have access to the information for the purposes under this section. For judicial eviction proceedings, disclosures may be made to the extent necessary. The Secretary shall, by regulation, establish procedures necessary to ensure that information provided under this section to any tribe or entity is used, and confidentiality is maintained, as required under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62cf6edb-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tII/s208"},"text":"Pub. L. 104–330, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4035"},"text":"110 Stat. 4035","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s595/e/10"},"text":"Pub. L. 105–276, title V, § 595(e)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2658"},"text":"112 Stat. 2658","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/411/tII/s205"},"text":"Pub. L. 110–411, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4326"},"text":"122 Stat. 4326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62cf6edc-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62cf6edd-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62cf6ede-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (c), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", known as the Native American Housing Assistance and Self-Determination Act of 1996. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62cf6edf-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/411"},"text":"Pub. L. 110–411","children":[],"tail":" inserted “applicants for employment, and of” after “records of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/s595/e/10/A"},"text":"Pub. L. 105–276, § 595(e)(10)(A)","children":[],"tail":", substituted “subsection (b)” for “paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/s595/e/10/B"},"text":"Pub. L. 105–276, § 595(e)(10)(B)","children":[],"tail":", substituted “subsection (a)” for “paragraph (1)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62cf6ee0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id62cf6ee1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s107"},"text":"section 107 of Pub. L. 104–330","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
