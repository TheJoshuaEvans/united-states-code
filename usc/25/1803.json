{"tag":"section","attrib":{"id":"id627e68d9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1803"},"text":null,"children":[{"tag":"num","attrib":{"value":"1803"},"text":"§ 1803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id627e68da-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, subject to appropriations, make grants pursuant to this subchapter to tribally controlled colleges or universities to aid in the post-secondary education of Indian students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627e68db-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of funds; limitations on uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants made pursuant to this subchapter shall go into the general operating funds of the institution to defray, at the determination of the tribally controlled college or university, expenditures for academic, educational, and administrative purposes and for the operation and maintenance of the college or university. Funds provided pursuant to this subchapter shall not be used in connection with religious worship or sectarian instruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id627e68dc-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/tI/s102"},"text":"Pub. L. 95–471, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1326"},"text":"92 Stat. 1326","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/192/s3/a"},"text":"Pub. L. 98–192, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1336"},"text":"97 Stat. 1336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s901/b/5"},"text":"Pub. L. 105–244, title IX, § 901(b)(5)","children":[],"tail":", (6), (12), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1828"},"text":"112 Stat. 1828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id627e68dd-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id627e68de-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id627e68df-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/6"},"text":"Pub. L. 105–244, § 901(b)(6)","children":[],"tail":", substituted “colleges or universities” for “community colleges”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/5"},"text":"Pub. L. 105–244, § 901(b)(5)","children":[],"tail":", (12), substituted “controlled college or university” for “controlled community college” and “the college or university” for “the college”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192/s3/a/1"},"text":"Pub. L. 98–192, § 3(a)(1)","children":[],"tail":", substituted “shall, subject to appropriations,” for “is authorized to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192/s3/a/2"},"text":"Pub. L. 98–192, § 3(a)(2)","children":[],"tail":", substituted “to defray, at the determination of the tribally controlled community college, expenditures for academic, educational, and administrative purposes and for the operation and maintenance of the college” for “to defray the expense of activities related to education programs for Indian students”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id627e68e0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id627e68e1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
