{"tag":"section","attrib":{"id":"id62db569f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5137"},"text":null,"children":[{"tag":"num","attrib":{"value":"5137"},"text":"§ 5137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of duplicative appraisals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other law (including regulations), in making loans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5136"},"text":"section 5136 of this title","children":[],"tail":", borrowers who are Indian tribes, members of Indian tribes, or tribal corporations shall only be required to obtain 1 appraisal under an appraisal standard recognized as of "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", by the Secretary or the Secretary of the Interior."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62db56a0-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tV/s5403"},"text":"Pub. L. 113–79, title V, § 5403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/840"},"text":"128 Stat. 840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62db56a1-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62db56a2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62db56a3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"