{"tag":"section","attrib":{"id":"id627010e9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1665a"},"text":"§ 1665a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Behavioral health prevention and treatment services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id627010ea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627010eb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To authorize and direct the Secretary, acting through the Service, Indian tribes, and tribal organizations, to develop a comprehensive behavioral health prevention and treatment program which emphasizes collaboration among alcohol and substance abuse, social services, and mental health programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627010ec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide information, direction, and guidance relating to mental illness and dysfunction and self-destructive behavior, including child abuse and family violence, to those Federal, tribal, State, and local agencies responsible for programs in Indian communities in areas of health care, education, social services, child and family welfare, alcohol and substance abuse, law enforcement, and judicial services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627010ed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assist Indian tribes to identify services and resources available to address mental illness and dysfunctional and self-destructive behavior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627010ee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide authority and opportunities for Indian tribes and tribal organizations to develop, implement, and coordinate with community-based programs which include identification, prevention, education, referral, and treatment services, including through multidisciplinary resource teams.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627010ef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure that Indians, as citizens of the United States and of the States in which they reside, have the same access to behavioral health services to which all citizens have access.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627010f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To modify or supplement existing programs and authorities in the areas identified in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627010f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627010f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Service, Indian tribes, and tribal organizations, shall encourage Indian tribes and tribal organizations to develop tribal plans, and urban Indian organizations to develop local plans, and for all such groups to participate in developing areawide plans for Indian Behavioral Health Services. The plans shall include, to the extent feasible, the following components:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id627010f3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An assessment of the scope of alcohol or other substance abuse, mental illness, and dysfunctional and self-destructive behavior, including suicide, child abuse, and family violence, among Indians, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id627010f4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Indians served who are directly or indirectly affected by such illness or behavior; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id627010f5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the financial and human cost attributable to such illness or behavior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id627010f6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the existing and additional resources necessary for the prevention and treatment of such illness and behavior, including an assessment of the progress toward achieving the availability of the full continuum of care described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id627010f7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimate of the additional funding needed by the Service, Indian tribes, tribal organizations, and urban Indian organizations to meet their responsibilities under the plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627010f8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National clearinghouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, shall coordinate with existing national clearinghouses and information centers to include at the clearinghouses and centers plans and reports on the outcomes of such plans developed by Indian tribes, tribal organizations, urban Indian organizations, and Service areas relating to behavioral health. The Secretary shall ensure access to these plans and outcomes by any Indian tribe, tribal organization, urban Indian organization, or the Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627010f9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide technical assistance to Indian tribes, tribal organizations, and urban Indian organizations in preparation of plans under this section and in developing standards of care that may be used and adopted locally.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627010fa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Service, shall provide, to the extent feasible and if funding is available, programs including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627010fb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive care","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A comprehensive continuum of behavioral health care which provides—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id627010fc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based prevention, intervention, outpatient, and behavioral health aftercare;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id627010fd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detoxification (social and medical);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id627010fe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acute hospitalization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id627010ff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intensive outpatient/day treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701100-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residential treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701101-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transitional living for those needing a temporary, stable living environment that is supportive of treatment and recovery goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701102-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency shelter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701103-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intensive case management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701104-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diagnostic services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701105-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotion of healthy approaches to risk and safety issues, including injury prevention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62701106-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child care","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Behavioral health services for Indians from birth through age 17, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62701107-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preschool and school age fetal alcohol spectrum disorder services, including assessment and behavioral intervention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701108-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental health and substance abuse services (emotional, organic, alcohol, drug, inhalant, and tobacco);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701109-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification and treatment of co-occurring disorders and comorbidity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6270110a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevention of alcohol, drug, inhalant, and tobacco use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6270110b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early intervention, treatment, and aftercare;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6270110c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotion of healthy approaches to risk and safety issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6270110d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification and treatment of neglect and physical, mental, and sexual abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6270110e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adult care","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Behavioral health services for Indians from age 18 through 55, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6270110f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early intervention, treatment, and aftercare;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701110-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental health and substance abuse services (emotional, alcohol, drug, inhalant, and tobacco), including sex specific services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701111-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification and treatment of co-occurring disorders (dual diagnosis) and comorbidity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701112-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotion of healthy approaches for risk-related behavior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701113-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treatment services for women at risk of giving birth to a child with a fetal alcohol spectrum disorder; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701114-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sex specific treatment for sexual assault and domestic violence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62701115-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family care","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Behavioral health services for families, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62701116-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early intervention, treatment, and aftercare for affected families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701117-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treatment for sexual assault and domestic violence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62701118-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotion of healthy approaches relating to parenting, domestic violence, and other abuse issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62701119-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elder care","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Behavioral health services for Indians 56 years of age and older, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6270111a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early intervention, treatment, and aftercare;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6270111b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental health and substance abuse services (emotional, alcohol, drug, inhalant, and tobacco), including sex specific services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6270111c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification and treatment of co-occurring disorders (dual diagnosis) and comorbidity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6270111d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotion of healthy approaches to managing conditions related to aging;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6270111e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sex specific treatment for sexual assault, domestic violence, neglect, physical and mental abuse and exploitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6270111f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/c/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification and treatment of dementias regardless of cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62701120-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community behavioral health plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62701121-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The governing body of any Indian tribe, tribal organization, or urban Indian organization may adopt a resolution for the establishment of a community behavioral health plan providing for the identification and coordination of available resources and programs to identify, prevent, or treat substance abuse, mental illness, or dysfunctional and self-destructive behavior, including child abuse and family violence, among its members or its service population. This plan should include behavioral health services, social services, intensive outpatient services, and continuing aftercare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62701122-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of an Indian tribe, tribal organization, or urban Indian organization, the Bureau of Indian Affairs and the Service shall cooperate with and provide technical assistance to the Indian tribe, tribal organization, or urban Indian organization in the development and implementation of such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62701123-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, Indian tribes, and tribal organizations, may make funding available to Indian tribes and tribal organizations which adopt a resolution pursuant to paragraph (1) to obtain technical assistance for the development of a community behavioral health plan and to provide administrative support in the implementation of such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62701124-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination for availability of services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, shall coordinate behavioral health planning, to the extent feasible, with other Federal agencies and with State agencies, to encourage comprehensive behavioral health services for Indians regardless of their place of residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62701125-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mental health care need assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Secretary, acting through the Service, shall make an assessment of the need for inpatient mental health care among Indians and the availability and cost of inpatient mental health facilities which can meet such need. In making such assessment, the Secretary shall consider the possible conversion of existing, underused Service hospital beds into psychiatric units to meet such need."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62701126-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s702"},"text":"Pub. L. 94–437, title VII, § 702","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62701127-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62701128-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62701129-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s702"},"text":"Section 702 of Pub. L. 94–437","children":[],"tail":" is based on section 181 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6270112a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1665a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s702"},"text":"Pub. L. 94–437, title VII, § 702","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s702/a"},"text":"Pub. L. 102–573, title VII, § 702(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4573"},"text":"106 Stat. 4573","children":[],"tail":", provided for Indian Health Service program, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
