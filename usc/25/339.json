{"tag":"section","attrib":{"id":"id622d3b09-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s339"},"text":null,"children":[{"tag":"num","attrib":{"value":"339"},"text":"§ 339.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribes excepted from certain provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this act shall not extend to the territory occupied by the Cherokees, Creeks, Choctaws, Chickasaws, Seminoles, and Osage, Miamies and Peorias, and Sacs and Foxes, in Oklahoma, nor to any of the reservations of the Seneca Nation of New York Indians in the State of New York, nor to that strip of territory in the State of Nebraska adjoining the Sioux Nation on the south added by Executive order.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id622d3b0a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-02-08/ch119/s8"},"text":"Feb. 8, 1887, ch. 119, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/391"},"text":"24 Stat. 391","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id622d3b0b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id622d3b0c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id622d3b0d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-02-08/ch119"},"text":"act Feb. 8, 1887, ch. 119","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/388"},"text":"24 Stat. 388","children":[],"tail":", and is popularly known as the Indian General Allotment Act. For classification of this act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s331"},"text":"section 331 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id622d3b0e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id622d3b0f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sacs and Foxes; Missouri Indians","children":[],"tail":null},{"tag":"p","attrib":{},"text":"No allotment of lands was to be made or annuities of money to be paid to any of the Sacs and Foxes of the Missouri Indians who were not enrolled as members of the tribe on ","children":[{"tag":"date","attrib":{"date":"1890-01-01"},"text":"Jan. 1, 1890","children":[],"tail":", by a proviso annexed to "},{"tag":"ref","attrib":{"href":"/us/act/1891-02-28/ch383/s5"},"text":"act Feb. 28, 1891, ch. 383, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/796"},"text":"26 Stat. 796","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
