{"tag":"section","attrib":{"id":"id6255d234-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1497a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1497a"},"text":"§ 1497a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental surety bond guarantee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6255d235-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1497a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount; eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to provide a supplemental surety bond guarantee, not to exceed 20 percent of any loss, for any Indian individual or economic enterprise eligible for a surety guarantee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s694b"},"text":"section 694b of title 15","children":[],"tail":", so that the aggregate of the two guarantees is 100 percent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d236-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1497a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide a supplemental guarantee under this section only if the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6255d237-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1497a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian individual or economic enterprise has secured or will likely secure a surety bond guarantee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s694b"},"text":"section 694b of title 15","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6255d238-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1497a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supplemental guarantee is necessary for the Indian individual or economic enterprise to secure a surety bond;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6255d239-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1497a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no more than 25 percent of the surety’s business is comprised of bonds guaranteed pursuant to this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6255d23a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1497a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the surety will provide appropriate technical assistance and advice to, and monitor the performance of, the Indian individual or economic enterprise for the prevention or mitigation of a loss.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d23b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1497a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees and charges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rules and regulations promulgated by the Secretary to carry out this section shall include the setting of reasonable fees to be paid by the Indian individual or economic enterprise and reasonable premium charges to be paid by sureties. In setting fees and charges, the Secretary may take into consideration the cost to the surety of providing the services required by paragraph (4) of subsection (b). The receipts from the fees and charges shall be deposited in the Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1497/a"},"text":"section 1497(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6255d23c-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/tII/s218"},"text":"Pub. L. 93–262, title II, § 218","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/442/s5/a"},"text":"Pub. L. 100–442, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-22"},"text":"Sept. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1764"},"text":"102 Stat. 1764","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6255d23d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6255d23e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6255d23f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/s218"},"text":"section 218 of Pub. L. 93–262","children":[],"tail":" was renumbered section 219 by "},{"tag":"ref","attrib":{"href":"/us/pl/100/442"},"text":"Pub. L. 100–442","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1498"},"text":"section 1498 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
