{"tag":"section","attrib":{"id":"id629d625a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2414a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2414a"},"text":"§ 2414a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id629d625b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2414a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the development of the Memorandum of Agreement required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2411"},"text":"section 2411 of this title","children":[],"tail":", the Secretary of the Interior, the Attorney General, and the Secretary of Health and Human Services shall review and consider—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id629d625c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2414a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the various programs established by Federal law providing health services and benefits to Indian tribes, including those relating to mental health and alcohol and substance abuse prevention and treatment,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d625d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2414a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal, State and local, and private health resources and programs,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d625e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2414a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where facilities to provide such treatment are or should be located, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d625f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2414a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of public and private alcohol and substance abuse treatment programs in operation on ","children":[{"tag":"date","attrib":{"date":"1986-10-27"},"text":"October 27, 1986","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to determine their applicability and relevance in carrying out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629d6260-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2414a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The results of the review conducted under subsection (a) shall be provided to every Indian tribe as soon as possible for their consideration and use in the development or modification of a Tribal Action Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629d6261-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4208A"},"text":"Pub. L. 99–570, title IV, § 4208A","children":[],"tail":", formerly § 4224, "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-148"},"text":"100 Stat. 3207–148","children":[],"tail":"; renumbered § 4208A, "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s702/b/1"},"text":"Pub. L. 102–573, title VII, § 702(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4582"},"text":"106 Stat. 4582","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s241/a/4"},"text":"Pub. L. 111–211, title II, § 241(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2289"},"text":"124 Stat. 2289","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id629d6262-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id629d6263-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id629d6264-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2471"},"text":"section 2471 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/102/573"},"text":"Pub. L. 102–573","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/a/4"},"text":"Pub. L. 111–211, § 241(a)(4)","children":[],"tail":", which directed amendment of section 4208a of the Indian Alcohol and Substance Abuse Prevention and Treatment Act of 1986, was executed to this section, which is section 4208A of the Act, to reflect the probable intent of Congress. See 2010 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id629d6265-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211"},"text":"Pub. L. 111–211","children":[],"tail":" inserted “, the Attorney General,” after “the Secretary of the Interior” in introductory provisions. See Codification note above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
