{"tag":"section","attrib":{"id":"id626b55f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1642"},"text":null,"children":[{"tag":"num","attrib":{"value":"1642"},"text":"§ 1642.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchasing health care coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id626b55f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1642/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Insofar as amounts are made available under law (including a provision of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s301"},"text":"42 U.S.C. 301","children":[],"tail":" et seq.], the Indian Self-Determination and Education Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.),"},{"tag":"ref","attrib":{"idref":"fn002075"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002075"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or other law, other than under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1644"},"text":"section 1644 of this title","children":[],"tail":") to Indian tribes, tribal organizations, and urban Indian organizations for health benefits for Service beneficiaries, Indian tribes, tribal organizations, and urban Indian organizations may use such amounts to purchase health benefits coverage (including coverage for a service, or service within a contract health service delivery area, or any portion of a contract health service delivery area that would otherwise be provided as a contract health service) for such beneficiaries in any manner, including through—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id626b55f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1642/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribally owned and operated health care plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626b55f3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1642/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or locally authorized or licensed health care plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626b55f4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1642/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a health insurance provider or managed care organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626b55f5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1642/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a self-insured plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626b55f6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1642/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a high deductible or health savings account plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626b55f7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1642/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial need","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purchase of coverage under subsection (a) by an Indian tribe, tribal organization, or urban Indian organization may be based on the financial needs of such beneficiaries (as determined by the 1 or more Indian tribes being served based on a schedule of income levels developed or implemented by such 1 ore ","children":[{"tag":"ref","attrib":{"idref":"fn002076"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002076"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “or”."}],"tail":" more Indian tribes)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626b55f8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1642/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses for self-insured plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a self-insured plan under subsection (a)(4), the amounts may be used for expenses of operating the plan, including administration and insurance to limit the financial risks to the entity offering the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626b55f9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1642/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as affecting the use of any amounts not referred to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id626b55fa-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tIV/s402"},"text":"Pub. L. 94–437, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1409"},"text":"90 Stat. 1409","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tIV/s401/a"},"text":"Pub. L. 100–713, title IV, § 401(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4818"},"text":"102 Stat. 4818","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tIV/s401/b/1"},"text":"Pub. L. 102–573, title IV, § 401(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4565"},"text":"106 Stat. 4565","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id626b55fb-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id626b55fc-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id626b55fd-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":", which is classified generally to chapter 7 (§ 301 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.), referred to in subsec. (a), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of this title prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id626b55fe-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" is based on section 152 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior to general amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573"},"text":"Pub. L. 102–573","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/437/s402"},"text":"section 402 of Pub. L. 94–437","children":[],"tail":", in subsec. (a) enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396j"},"text":"section 1396j of Title 42","children":[],"tail":", The Public Health and Welfare, in subsecs. (b) to (d) enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396j"},"text":"section 1396j of Title 42","children":[],"tail":" (of which subsecs. (c) and (d) were restated in this section), and in subsec. (e) amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396d"},"text":"section 1396d of Title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id626b55ff-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" amended section generally. Prior to amendment, section related to treatment of payments under medicaid program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573"},"text":"Pub. L. 102–573","children":[],"tail":" amended section generally, substituting subsecs. (a) and (b) for former subsecs. (a) to (e). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/713/s401/b"},"text":"Pub. L. 100–713, § 401(b)","children":[],"tail":", struck out subsec. (b) which authorized Secretary of Health and Human Services to enter into agreements to reimburse State agencies for health care and services provided in Indian Health Service facilities to Indians eligible for medical assistance under title XIX of the Social Security Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/713/s401/a"},"text":"Pub. L. 100–713, § 401(a)","children":[],"tail":", substituted “skilled nursing facility, or any other type of facility which provides services of a type otherwise covered under a State plan for medical assistance approved under title XIX of the Social Security Act” for “or skilled nursing facility”, “such a State plan” for “a State plan approved under title XIX of the Social Security Act”, and “In making payments from such fund, the Secretary shall ensure that each service unit of the Indian Health Service receives at least 50 percent of the amounts to which the facilities of the Indian Health Service, for which such service unit makes collections, are entitled by reason of section 1911 of the Social Security Act, if such amount is necessary for the purpose of making improvements in such facilities in order to achieve compliance with the conditions and requirements of title XIX of the Social Security Act. This subsection shall” for “The preceding sentence shall”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id626b5600-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id626b5601-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/tIV/s401/b/2"},"text":"Pub. L. 102–573, title IV, § 401(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4565"},"text":"106 Stat. 4565","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/573/tIV/s401/b/2"},"text":"“The increase (from 50 percent) in the percentage of the payments from the fund to be made to each service unit of the Service specified in the amendment made by paragraph (1) [amending this section] shall take effect beginning with payments made on ","children":[{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id626b5602-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/713/tIV/s401/c"},"text":"Pub. L. 100–713, title IV, § 401(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4818"},"text":"102 Stat. 4818","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/713/tIV/s401/c"},"text":"“The amendments made by this section [amending this section] shall apply to services performed on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
