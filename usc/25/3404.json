{"tag":"section","attrib":{"id":"id62ba132c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404"},"text":null,"children":[{"tag":"num","attrib":{"value":"3404"},"text":"§ 3404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs affected","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62ba132d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs affected","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ba132e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The programs that may be integrated pursuant to a plan approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3407"},"text":"section 3407 of this title","children":[],"tail":" shall be only programs—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ba132f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" implemented for the purpose of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62ba1330-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" job training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ba1331-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" welfare to work and tribal work experience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ba1332-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating or enhancing employment opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62bc5c23-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" skill development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62bc5c24-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting Indian youth and adults to succeed in the workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62bc5c25-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging self-sufficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62bc5c26-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" familiarizing individual participants with the world of work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62bc5c27-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/1/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the creation of job opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62bc5c28-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/1/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic development; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62bc5c29-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/1/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any services related to the activities described in clauses (i) through (x); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5c2a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under which an Indian tribe or members of an Indian tribe—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62bc5c2b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are eligible to receive funds—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62bc5c2c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a statutory or administrative formula making funds available to an Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62bc5c2d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based solely or in part on their status as Indians under Federal law; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62bc5c2e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have secured funds as a result of a noncompetitive process or a specific designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c2f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of block grant funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, programs funded by block grant funds provided to an Indian tribe, regardless of whether the block grant is for the benefit of the Indian tribe because of the status of the Indian tribe or the status of the beneficiaries the grant serves, shall be eligible to be integrated into the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5c30-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in cooperation with the Attorney General, the Secretary of Agriculture, the Secretary of Commerce, the Secretary of Education, the Secretary of Energy, the Secretary of Health and Human Services, the Secretary of Homeland Security, the Secretary of Housing and Urban Development, the Secretary of Labor, the Secretary of Transportation, and the Secretary of Veterans Affairs, after the Secretary approves a plan submitted by an Indian tribe or tribal organization under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3407"},"text":"section 3407 of this title","children":[],"tail":", authorize the Indian tribe or tribal organization, as applicable, to coordinate, in accordance with the plan, federally funded employment, training, and related services programs and funding in a manner that integrates the programs and funding into a consolidated and comprehensive program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62bc5c31-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/477/s5"},"text":"Pub. L. 102–477, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2302"},"text":"106 Stat. 2302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tXI/s1103/b"},"text":"Pub. L. 106–568, title XI, § 1103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2931"},"text":"114 Stat. 2931","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/93/s6"},"text":"Pub. L. 115–93, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-18"},"text":"Dec. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2027"},"text":"131 Stat. 2027","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62bc5c32-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62bc5c33-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62bc5c34-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/93"},"text":"Pub. L. 115–93","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “The programs that may be integrated in a demonstration project under any such plan referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3403"},"text":"section 3403 of this title","children":[],"tail":" shall include any program under which an Indian tribe is eligible for receipt of funds under a statutory or administrative formula for the purposes of assisting Indian youth and adults to succeed in the workforce, encouraging self-sufficiency, familiarizing Indian Youth and adults with the world of work, facilitating the creation of job opportunities and any services related to these activities.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568"},"text":"Pub. L. 106–568","children":[],"tail":" substituted “assisting Indian youth and adults to succeed in the workforce, encouraging self-sufficiency, familiarizing Indian Youth and adults with the world of work, facilitating the creation of job opportunities and any services related to these activities” for “job training, tribal work experience, employment opportunities, or skill development, or any program designed for the enhancement of job opportunities or employment training”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
