{"tag":"section","attrib":{"id":"id629fd3c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2441"},"text":null,"children":[{"tag":"num","attrib":{"value":"2441"},"text":"§ 2441.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id629fd3c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2441/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement and judicial services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the development of the Memorandum of Agreement required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2411"},"text":"section 2411 of this title","children":[],"tail":", the Secretary of the Interior, the Attorney General, and the Secretary of Health and Human Services, in cooperation with the Attorney General of the United States, shall review and consider—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id629fd3c2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2441/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the various programs established by Federal law providing law enforcement or judicial services for Indian tribes, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629fd3c3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2441/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal and State and local law enforcement and judicial programs and systems","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to determine their applicability and relevance in carrying out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629fd3c4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2441/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The results of the review conducted pursuant to subsection (a) shall be made available to every Indian tribe as soon as possible for their consideration and use in the development and modification of a Tribal Action Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629fd3c5-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4215"},"text":"Pub. L. 99–570, title IV, § 4215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-145"},"text":"100 Stat. 3207–145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s241/d"},"text":"Pub. L. 111–211, title II, § 241(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2290"},"text":"124 Stat. 2290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id629fd3c6-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id629fd3c7-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id629fd3c8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211"},"text":"Pub. L. 111–211","children":[],"tail":" inserted “, the Attorney General,” after “the Secretary of the Interior” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
