{"tag":"section","attrib":{"id":"id6217ded4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s114"},"text":null,"children":[{"tag":"num","attrib":{"value":"114"},"text":"§ 114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of annuities in coin","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury is authorized to pay in coin such of the annuities as by the terms of any treaty of the United States with any Indian tribe are required to be paid in coin.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6217ded5-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2081.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6217ded6-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6217ded7-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6217ded8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2081 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1865-03-03/ch127/s3"},"text":"act Mar. 3, 1865, ch. 127, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/561"},"text":"13 Stat. 561","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
