{"tag":"section","attrib":{"id":"id62584359-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1523"},"text":null,"children":[{"tag":"num","attrib":{"value":"1523"},"text":"§ 1523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated not to exceed the sum of $10,000,000 per year for fiscal year 1986 and each fiscal year thereafter for the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6258435a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/tIV/s403"},"text":"Pub. L. 93–262, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/83"},"text":"88 Stat. 83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/68"},"text":"Pub. L. 95–68","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-07-20"},"text":"July 20, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/272"},"text":"91 Stat. 272","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/449/s10"},"text":"Pub. L. 98–449, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-04"},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1726"},"text":"98 Stat. 1726","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6258435b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6258435c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6258435d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/449"},"text":"Pub. L. 98–449","children":[],"tail":" amended section generally, substituting “$10,000,000” for “$14,000,000” and “1986 and each fiscal year thereafter” for “1978 and 1979”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/68"},"text":"Pub. L. 95–68","children":[],"tail":" substituted “$14,000,000 for each of the fiscal years 1978 and 1979” for “$10,000,000 for each of the fiscal years 1975, 1976, and 1977”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
