{"tag":"section","attrib":{"id":"id62321de6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s376"},"text":null,"children":[{"tag":"num","attrib":{"value":"376"},"text":"§ 376.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oaths in investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1914-08-01"},"text":"August 1, 1914","children":[],"tail":", any officer or employee appointed or designated by the Secretary of the Interior or the Commissioner of Indian Affairs as special examiner in heirship cases shall be authorized to administer oaths in investigations committed to him: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That the provisions of this paragraph shall not apply to the Osage Indians nor to the Five Civilized Tribes of Indians in Oklahoma."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62321de7-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-08-01/ch222/s1"},"text":"Aug. 1, 1914, ch. 222, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/586"},"text":"38 Stat. 586","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62321de8-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id62321de9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id62321dea-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
