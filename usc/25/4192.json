{"tag":"section","attrib":{"id":"id62d1e011-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4192"},"text":null,"children":[{"tag":"num","attrib":{"value":"4192"},"text":"§ 4192.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security and repayment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d1e012-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4192/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements on issuer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To assure the repayment of notes or other obligations and charges incurred under this subchapter and as a condition for receiving such guarantees, the Secretary shall require the Indian tribe or housing entity issuing such notes or obligations to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d1e013-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4192/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into a contract, in a form acceptable to the Secretary, for repayment of notes or other obligations guaranteed under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e014-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4192/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pledge any grant for which the issuer may become eligible under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e015-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4192/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate that the extent of such issuance and guarantee under this subchapter is within the financial capacity of the tribe and is not likely to impair the ability to use grant amounts under subchapter I, taking into consideration the requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4133/b"},"text":"section 4133(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e016-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4192/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish, at the discretion of the Secretary, such other security as may be deemed appropriate by the Secretary in making such guarantees, including increments in local tax receipts generated by the activities assisted under this chapter or disposition proceeds from the sale of land or rehabilitated property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e017-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4192/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment from grant amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d1e018-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4192/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may apply grants pledged pursuant to subsection (a)(2) to any repayments due the United States as a result of such guarantees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e019-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4192/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants allocated under this chapter for an Indian tribe or housing entity (including program income derived therefrom) may be used to pay principal and interest due (including such servicing, underwriting, and other costs as may be specified in regulations issued by the Secretary) on notes or other obligations guaranteed pursuant to this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e01a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4192/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full faith and credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The full faith and credit of the United States is pledged to the payment of all guarantees made under this subchapter. Any such guarantee made by the Secretary shall be conclusive evidence of the eligibility of the obligations for such guarantee with respect to principal and interest, and the validity of any such guarantee so made shall be incontestable in the hands of a holder of the guaranteed obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d1e01b-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVI/s602"},"text":"Pub. L. 104–330, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4046"},"text":"110 Stat. 4046","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d1e01c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d1e01d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62d1e01e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", known as the Native American Housing Assistance and Self-Determination Act of 1996. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62d1e01f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id62d1e020-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s606"},"text":"section 606 of Pub. L. 104–330","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4191"},"text":"section 4191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
