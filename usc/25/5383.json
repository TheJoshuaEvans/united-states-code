{"tag":"section","attrib":{"id":"id62f0d9f9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383"},"text":null,"children":[{"tag":"num","attrib":{"value":"5383"},"text":"§ 5383.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of participating Indian tribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f0d9fa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Indian tribe that is participating in the Tribal Self-Governance Demonstration Project under title III ","children":[{"tag":"ref","attrib":{"idref":"fn002274"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002274"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" on "},{"tag":"date","attrib":{"date":"2000-08-18"},"text":"August 18, 2000","children":[],"tail":", may elect to participate in self-governance under this subchapter under existing authority as reflected in tribal resolution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f0d9fb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional participants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f0d9fc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to those Indian tribes participating in self-governance under subsection (a) of this section, each year an additional 50 Indian tribes that meet the eligibility criteria specified in subsection (c) of this section shall be entitled to participate in self-governance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f0d9fd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain Indian tribes","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f0d9fe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian tribe that has withdrawn from participation in an inter-tribal consortium or tribal organization, in whole or in part, shall be entitled to participate in self-governance provided the Indian tribe meets the eligibility criteria specified in subsection (c) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f0d9ff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of withdrawal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an Indian tribe has withdrawn from participation in an inter-tribal consortium or tribal organization, that Indian tribe shall be entitled to its tribal share of funds supporting those programs, services, functions, and activities (or portions thereof) that the Indian tribe will be carrying out under the compact and funding agreement of the Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f0da00-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in self-governance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In no event shall the withdrawal of an Indian tribe from an inter-tribal consortium or tribal organization affect the eligibility of the inter-tribal consortium or tribal organization to participate in self-governance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f0da01-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicant pool","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f0da02-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The qualified applicant pool for self-governance shall consist of each Indian tribe that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f0da03-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successfully completes the planning phase described in subsection (d) of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f0da04-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has requested participation in self-governance by resolution or other official action by the governing body of each Indian tribe to be served; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f0da05-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has demonstrated, for 3 fiscal years, financial stability and financial management capability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f0da06-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for determining financial stability and financial management capacity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, evidence that, during the 3-year period referred to in paragraph (1)(C), an Indian tribe had no uncorrected significant and material audit exceptions in the required annual audit of the Indian tribe’s self-determination contracts or self-governance funding agreements with any Federal agency shall be conclusive evidence of the required stability and capability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f0da07-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning phase","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Indian tribe seeking participation in self-governance shall complete a planning phase. The planning phase shall be conducted to the satisfaction of the Indian tribe and shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f0da08-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legal and budgetary research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f0da09-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" internal tribal government planning and organizational preparation relating to the administration of health care programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f0da0a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, any Indian tribe meeting the requirements of paragraph (1)(B) and (C) of subsection (c) of this section shall be eligible for grants—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f0da0b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to plan for participation in self-governance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f0da0c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to negotiate the terms of participation by the Indian tribe or tribal organization in self-governance, as set forth in a compact and a funding agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f0da0d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5383/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt of grant not required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Receipt of a grant under subsection (e) of this section shall not be a requirement of participation in self-governance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f0da0e-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tV/s503"},"text":"Pub. L. 93–638, title V, § 503","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/260/s4"},"text":"Pub. L. 106–260, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-18"},"text":"Aug. 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/714"},"text":"114 Stat. 714","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62f0da0f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62f0da10-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62f0da11-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title III, referred to in subsec. (a), means title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/100/472/tII/s209"},"text":"Pub. L. 100–472, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-05"},"text":"Oct. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2296"},"text":"102 Stat. 2296","children":[],"tail":", which was set out as a note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450f"},"text":"section 450f of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/260/s10"},"text":"Pub. L. 106–260, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-18"},"text":"Aug. 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/734"},"text":"114 Stat. 734","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62f0da12-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s458aaa–2"},"text":"section 458aaa–2 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/s503"},"text":"section 503 of Pub. L. 93–638","children":[],"tail":" was renumbered section 803 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5423"},"text":"section 5423 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
