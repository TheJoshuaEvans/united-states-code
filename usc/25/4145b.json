{"tag":"section","attrib":{"id":"id62cf6eff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145b"},"text":null,"children":[{"tag":"num","attrib":{"value":"4145b"},"text":"§ 4145b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts for housing activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62cf6f00-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible housing activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts made available for use under this part by a recipient for an Indian tribe shall be used only for housing activities, as selected at the discretion of the recipient and described in the Indian housing plan for the Indian tribe pursuant to section 4112(b)(6) ","children":[{"tag":"ref","attrib":{"idref":"fn002238"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002238"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4112/b"},"text":"Section 4112(b) of this title","children":[],"tail":" does not contain a par. (6)."}],"tail":" of this title, for the construction, acquisition, or rehabilitation of housing or infrastructure in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4132"},"text":"section 4132 of this title","children":[],"tail":" to provide a benefit to families described in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4131/b/1"},"text":"section 4131(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cf6f01-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on certain activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available for use under this part may not be used for commercial or economic development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62cf6f02-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tII/s233"},"text":"Pub. L. 104–330, title II, § 233","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/411/tII/s206/a/2"},"text":"Pub. L. 110–411, title II, § 206(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4327"},"text":"122 Stat. 4327","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
