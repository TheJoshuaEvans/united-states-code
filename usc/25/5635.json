{"tag":"section","attrib":{"id":"id62f594bd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5635"},"text":null,"children":[{"tag":"num","attrib":{"value":"5635"},"text":"§ 5635.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appraisals and valuations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f594be-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5635/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5634"},"text":"section 5634 of this title","children":[],"tail":", not later than 18 months after "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", the Secretary, in consultation with Indian tribes and tribal organizations, shall ensure that appraisals and valuations of Indian trust property are administered by a single bureau, agency, or other administrative entity within the Department."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f594bf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5635/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", the Secretary shall establish and publish in the Federal Register minimum qualifications for individuals to prepare appraisals and valuations of Indian trust property."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f594c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5635/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which an Indian tribe or Indian beneficiary submits to the Secretary an appraisal or valuation that satisfies the minimum qualifications described in subsection (b), and that submission acknowledges the intent of the Indian tribe or beneficiary to have the appraisal or valuation considered under this section, the appraisal or valuation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f594c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5635/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not require any additional review or approval by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f594c2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5635/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be considered to be final for purposes of effectuating the transaction for which the appraisal or valuation is required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f594c3-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/178/tIII/s305"},"text":"Pub. L. 114–178, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/441"},"text":"130 Stat. 441","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
