{"tag":"section","attrib":{"id":"id62d69a80-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302"},"text":null,"children":[{"tag":"num","attrib":{"value":"4302"},"text":"§ 4302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d69a81-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of Native American Business Development appointed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4303/a/2"},"text":"section 4303(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69a82-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible entity” means an Indian Tribe or Tribal organization, an Indian arts and crafts organization, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s305a"},"text":"section 305a of this title","children":[],"tail":", a Tribal enterprise, a Tribal marketing cooperative (as that term is defined by the Secretary, in consultation with the Secretary of the Interior), or any other Indian-owned business."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69a83-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/d"},"text":"section 5304(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69a84-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian goods and services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Indian goods and services” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d69a85-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian goods, within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s305a"},"text":"section 305a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69a86-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" goods produced or originated by an eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69a87-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services provided by eligible entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69a88-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian lands","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d69a89-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Indian lands” includes lands under the definition of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d69a8a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Indian country” under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1151"},"text":"section 1151 of title 18","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d69a8b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “reservation” under—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62d69a8c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/5/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1452/d"},"text":"section 1452(d) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d69a8d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/5/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1903/10"},"text":"section 1903(10) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69a8e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Former Indian reservations in Oklahoma","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of applying ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1452/d"},"text":"section 1452(d) of this title","children":[],"tail":" under subparagraph (A)(ii), the term “former Indian reservations in Oklahoma” shall be construed to include lands that are—"}],"tail":null},{"tag":"clause","attrib":{"id":"id62d69a8f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the jurisdictional areas of an Oklahoma Indian Tribe (as determined by the Secretary of the Interior); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d69a90-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognized by the Secretary of the Interior as eligible for trust land status under part 151 of title 25, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2000-11-07"},"text":"November 7, 2000","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69a91-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian-owned business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian-owned business” means an entity organized for the conduct of trade or commerce with respect to which at least 50 percent of the property interests of the entity are owned by Indians or Indian Tribes (or a combination thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69a92-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian Tribe” has the meaning given the term “Indian tribe” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"section 5304(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69a93-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Office” means the Office of Native American Business Development established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4303/a/1"},"text":"section 4303(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69a94-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69a95-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal enterprise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Tribal enterprise” means a commercial activity or business managed or controlled by an Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69a96-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4302/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Tribal organization” has the meaning given that term in section 5304(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d69a97-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/464/s3"},"text":"Pub. L. 106–464, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2013"},"text":"114 Stat. 2013","children":[],"tail":"; "},{"tag":"ref","attrib":