{"tag":"section","attrib":{"id":"id621c9987-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s193"},"text":null,"children":[{"tag":"num","attrib":{"value":"193"},"text":"§ 193.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceedings against goods seized for certain violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When goods or other property shall be seized for any violation of title 28 of the Revised Statutes it shall be lawful for the person prosecuting on behalf of the United States to proceed against such goods, or other property, in the manner directed to be observed in the case of goods, wares, or merchandise brought into the United States in violation of the revenue laws.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621c9988-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2125.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621c9989-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621c998a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id621c998b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title 28 of the Revised Statutes, referred to in text, was in the original “this Title”, meaning title 28 of the Revised Statutes, consisting of R.S. §§ 2039 to 2157. For complete classification of R.S. §§ 2039 to 2157 to the Code, see Tables.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id621c998c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2125 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1834-06-30/ch161/s28"},"text":"act June 30, 1834, ch. 161, § 28","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/734"},"text":"4 Stat. 734","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
