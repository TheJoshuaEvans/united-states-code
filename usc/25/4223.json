{"tag":"section","attrib":{"id":"id62d1e0ab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223"},"text":null,"children":[{"tag":"num","attrib":{"value":"4223"},"text":"§ 4223.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d1e0ac-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d1e0ad-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the Director to submit a housing plan under this section for each fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e0ae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the review of each plan submitted under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e0af-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Five-year plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each housing plan under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d1e0b0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in a form prescribed by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e0b1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contain, with respect to the 5-year period beginning with the fiscal year for which the plan is submitted, the following information:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d1e0b2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mission statement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A general statement of the mission of the Department of Hawaiian Home Lands to serve the needs of the low-income families to be served by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d1e0b3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Goals and objectives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A statement of the goals and objectives of the Department of Hawaiian Home Lands to enable the Department to serve the needs identified in subparagraph (A) during the period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d1e0b4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities plans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An overview of the activities planned during the period including an analysis of the manner in which the activities will enable the Department to meet its mission, goals, and objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d429a5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" One-year plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A housing plan under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d429a6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in a form prescribed by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d429a7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contain the following information relating to the fiscal year for which the assistance under this subchapter is to be made available:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d429a8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Goals and objectives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A statement of the goals and objectives to be accomplished during the period covered by the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d429a9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statement of needs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A statement of the housing needs of the low-income families served by the Department and the means by which those needs will be addressed during the period covered by the plan, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d429aa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the estimated housing needs and the need for assistance for the low-income families to be served by the Department, including a description of the manner in which the geographical distribution of assistance is consistent with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62d429ab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographical needs of those families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d429ac-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" needs for various categories of housing assistance; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d429ad-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the estimated housing needs for all families to be served by the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d429ae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial resources","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An operating budget for the Department of Hawaiian Home Lands, in a form prescribed by the Secretary, that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d429af-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification and a description of the financial resources reasonably available to the Department to carry out the purposes of this subchapter, including an explanation of the manner in which amounts made available will be used to leverage additional resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d429b0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the uses to which the resources described in clause (i) will be committed, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62d429b1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible and required affordable housing activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d429b2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d429b3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affordable housing resources","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A statement of the affordable housing resources currently available at the time of the submittal of the plan and to be made available during the period covered by the plan, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d429b4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the significant characteristics of the housing market in the State of Hawaii, including the availability of housing from other public sources, private market housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d429b5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the manner in which the characteristics referred to in clause (i) influence the decision of the Department of Hawaiian Home Lands to use grant amounts to be provided under this subchapter for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62d429b6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rental assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d429b7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production of new units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d429b8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of existing units; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d429b9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rehabilitation of units;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d429ba-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the structure, coordination, and means of cooperation between the Department of Hawaiian Home Lands and any other governmental entities in the development, submission, or implementation of housing plans, including a description of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62d429bb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the involvement of private, public, and nonprofit organizations and institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d429bc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of loan guarantees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715z–13b"},"text":"section 1715z–13b of title 12","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d429bd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other housing assistance provided by the United States, including loans, grants, and mortgage insurance;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d429be-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the manner in which the plan will address the needs identified pursuant to subparagraph (C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d429bf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62d429c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any existing or anticipated homeownership programs and rental programs to be carried out during the period covered by the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d429c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements and assistance available under the programs referred to in subclause (I);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d429c2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62d429c3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/vi/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any existing or anticipated housing rehabilitation programs necessary to ensure the long-term viability of the housing to be carried out during the period covered by the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d429c4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/vi/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements and assistance available under the programs referred to in subclause (I);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d429c5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62d429c6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/vii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" all other existing or anticipated housing assistance provided by the Department of Hawaiian Home Lands during the period covered by the plan, including—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id62d429c7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/vii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transitional housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id62d429c8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/vii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" homeless housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id62d429c9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/vii/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" college housing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id62d429ca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/vii/I/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supportive services housing; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d429cb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/vii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements and assistance available under such programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d429cc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62d429cd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/viii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any housing to be demolished or disposed of;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d429ce-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/viii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a timetable for that demolition or disposition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d429cf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/viii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information required by the Secretary with respect to that demolition or disposition;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d429d0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the manner in which the Department of Hawaiian Home Lands will coordinate with welfare agencies in the State of Hawaii to ensure that residents of the affordable housing will be provided with access to resources to assist in obtaining employment and achieving self-sufficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d429d1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the requirements established by the Department of Hawaiian Home Lands to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62d429d2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/x/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the safety of residents of the affordable housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d429d3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/x/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the undertaking of crime prevention measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d429d4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/x/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow resident input and involvement, including the establishment of resident organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d429d5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/x/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow for the coordination of crime prevention activities between the Department and local law enforcement officials; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d429d6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/D/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the entities that will carry out the activities under the plan, including the organizational capacity and key personnel of the entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d429d7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification of compliance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Evidence of compliance that shall include, as appropriate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d429d8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a certification that the Department of Hawaiian Home Lands will comply with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62d429d9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/E/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title VI of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d"},"text":"42 U.S.C. 2000d","children":[],"tail":" et seq.) or with the Fair Housing Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"42 U.S.C. 3601","children":[],"tail":" et seq.) in carrying out this subchapter, to the extent that such title "},{"tag":"ref","attrib":{"idref":"fn002242"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002242"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Codification note below."}],"tail":" is applicable; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d429da-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/E/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other applicable Federal statutes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d429db-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that the Department will require adequate insurance coverage for housing units that are owned and operated or assisted with grant amounts provided under this subchapter, in compliance with such requirements as may be established by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d429dc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that policies are in effect and are available for review by the Secretary and the public governing the eligibility, admission, and occupancy of families for housing assisted with grant amounts provided under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d429dd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that policies are in effect and are available for review by the Secretary and the public governing rents charged, including the methods by which such rents or homebuyer payments are determined, for housing assisted with grant amounts provided under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d429de-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/c/2/E/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that policies are in effect and are available for review by the Secretary and the public governing the management and maintenance of housing assisted with grant amounts provided under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d429df-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of civil rights statutes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d429e0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent that the requirements of title VI of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d"},"text":"42 U.S.C. 2000d","children":[],"tail":" et seq.) or of the Fair Housing Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"42 U.S.C. 3601","children":[],"tail":" et seq.) apply to assistance provided under this subchapter, nothing in the requirements concerning discrimination on the basis of race shall be construed to prevent the provision of assistance under this subchapter—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d429e1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Department of Hawaiian Home Lands on the basis that the Department served Native Hawaiians; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d429e2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an eligible family on the basis that the family is a Native Hawaiian family.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d429e3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Program eligibility under this subchapter may be restricted to Native Hawaiians. Subject to the preceding sentence, no person may be discriminated against on the basis of race, color, national origin, religion, sex, familial status, or disability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d429e4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4223/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of nonprofit organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receiving grant amounts under this subchapter, the Department of Hawaiian Home Lands shall, to the extent practicable, provide for private nonprofit organizations experienced in the planning and development of affordable housing for Native Hawaiians to carry out affordable housing activities with those grant amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d429e5-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s803"},"text":"Pub. L. 104–330, title VIII, § 803","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s203"},"text":"Pub. L. 106–568, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2878"},"text":"114 Stat. 2878","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s513"},"text":"Pub. L. 106–569, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2971"},"text":"114 Stat. 2971","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d429e6-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d429e7-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62d429e8-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1964, referred to in subsecs. (c)(2)(E)(i)(I) and (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Pub. L. 88–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/241"},"text":"78 Stat. 241","children":[],"tail":". Title VI of the Act is classified generally to subchapter V (§ 2000d et seq.) of chapter 21 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"section 2000a of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Fair Housing Act, referred to in subsecs. (c)(2)(E)(i)(I) and (d)(1), is title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284"},"text":"Pub. L. 90–284","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/81"},"text":"82 Stat. 81","children":[],"tail":", which is classified principally to subchapter I (§ 3601 et seq.) of chapter 45 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"section 3601 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62d429e9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s203"},"text":"Pub. L. 106–568, § 203","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":", enacted substantially identical sections 803 of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":". This section is based on the text of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s803"},"text":"section 803 of Pub. L. 104–330","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s803"},"text":"Section 803 of Pub. L. 104–330","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/568"},"text":"Pub. L. 106–568","children":[],"tail":", referred to title VIII of the Act popularly known as the Civil Rights Act of 1968 instead of the Fair Housing Act in subsecs. (c)(2)(E)(i)(I) and (d)(1). Title VIII of the Civil Rights Act of 1968 is title VIII of "},{"tag":"ref","attrib":{"href":"/us/pl/90/284"},"text":"Pub. L. 90–284","children":[],"tail":" which is known as the Fair Housing Act, see References in Text note above. The reference to “such title” in subsec. (c)(2)(E)(i)(I) probably refers to title VI of the Civil Rights Act of 1964 and title VIII of the Civil Rights Act of 1968 (the Fair Housing Act)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
