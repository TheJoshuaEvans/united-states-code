{"tag":"section","attrib":{"id":"id6217df11-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s122"},"text":null,"children":[{"tag":"num","attrib":{"value":"122"},"text":"§ 122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on application of tribal funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No funds belonging to any Indian tribe with which treaty relations exist shall be applied in any manner not authorized by such treaty, or by express provisions of law; nor shall money appropriated to execute a treaty be transferred or applied to any other purpose, unless expressly authorized by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6217df12-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2097.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6217df13-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6217df14-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6217df15-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2097 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1866-07-26/ch266/s2"},"text":"act July 26, 1866, ch. 266, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/14/280"},"text":"14 Stat. 280","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
