{"tag":"section","attrib":{"id":"id62215491-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s287"},"text":null,"children":[{"tag":"num","attrib":{"value":"287"},"text":"§ 287.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taking child to school in another State without written consent","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No Indian child shall be taken from any school in any State or Territory to a school in any other State against its will or without the written consent of its parents.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62215492-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1896-06-10/ch398/s1"},"text":"June 10, 1896, ch. 398, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/29/348"},"text":"29 Stat. 348","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
