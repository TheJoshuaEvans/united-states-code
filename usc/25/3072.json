{"tag":"section","attrib":{"id":"id62b2e622-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072"},"text":null,"children":[{"tag":"num","attrib":{"value":"3072"},"text":"§ 3072.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b2e623-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Archaeological resource","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “archaeological resource” means an archaeological resource (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s470bb"},"text":"section 470bb of title 16","children":[],"tail":") that is Native American."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e624-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cultural affiliation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cultural affiliation” means that there is a relationship of shared group identity that can be reasonably traced historically or prehistorically between a present day Indian Tribe or Native Hawaiian organization and an identifiable earlier group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e625-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cultural item","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cultural item” means any 1 or more cultural items (as defined in section 2 of the Native American Graves Protection and Repatriation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"25 U.S.C. 3001","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e626-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian Tribe” has the meaning given the term “Indian tribe” in section 2 of the Native American Graves Protection and Repatriation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"25 U.S.C. 3001","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e627-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Item Prohibited from Exportation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Item Prohibited from Exportation” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b2e628-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a cultural item prohibited from being trafficked, including through sale, purchase, use for profit, or transport for sale or profit, by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b2e629-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1170/b"},"text":"section 1170(b) of title 18","children":[],"tail":", as added by the Native American Graves Protection and Repatriation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"25 U.S.C. 3001","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b2e62a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal law or treaty; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e62b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an archaeological resource prohibited from being trafficked, including through sale, purchase, exchange, transport, receipt, or offer to sell, purchase, or exchange, including in interstate or foreign commerce, by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b2e62c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (b) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s470ee"},"text":"section 470ee of title 16","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b2e62d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal law or treaty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e62e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Item Requiring Export Certification","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b2e62f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Item Requiring Export Certification” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b2e630-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cultural item; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b2e631-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an archaeological resource.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e632-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Item Requiring Export Certification” does not include an item described in clause (i) or (ii) of subparagraph (A) for which an Indian Tribe or Native Hawaiian organization with a cultural affiliation with the item has provided a certificate authorizing exportation of the item.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e633-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Native American” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b2e634-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native American (as defined in section 2 of the Native American Graves Protection and Repatriation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"25 U.S.C. 3001","children":[],"tail":")); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e635-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native Hawaiian (as so defined).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e636-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native Hawaiian organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Native Hawaiian organization” has the meaning given the term in section 2 of the Native American Graves Protection and Repatriation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"25 U.S.C. 3001","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e637-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e638-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tangible cultural heritage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tangible cultural heritage” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b2e639-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native American human remains; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e63a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3072/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" culturally, historically, or archaeologically significant objects, resources, patrimony, or other items that are affiliated with a Native American culture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b2e63b-4962-11f1-add1-b56d3fa293fa"},"text":"(","