{"tag":"section","attrib":{"id":"id6210b340-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s40"},"text":null,"children":[{"tag":"num","attrib":{"value":"40"},"text":"§ 40.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limits of superintendencies, agencies, and sub­agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The limits of each superintendency, agency, and subagency shall be established by the Secretary of the Interior, either by tribes or geographical boundaries.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6210b341-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2066.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6210b342-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6210b343-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6210b344-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2066 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1834-06-30/ch162/s7"},"text":"June 30, 1834, ch. 162, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/736"},"text":"4 Stat. 736","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1847-03-03/ch66/s1"},"text":"Mar. 3, 1847, ch. 66, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/203"},"text":"9 Stat. 203","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6210b345-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id6210b346-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
