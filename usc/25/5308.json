{"tag":"section","attrib":{"id":"id62e0378d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5308"},"text":null,"children":[{"tag":"num","attrib":{"value":"5308"},"text":"§ 5308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant and cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter shall not be subject to the requirements of chapter 63 of title 31: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That a grant agreement or a cooperative agreement may be utilized in lieu of a contract under section 5321 "},{"tag":"ref","attrib":{"idref":"fn002255"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002255"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Codification note below."}],"tail":" of this title when mutually agreed to by the appropriate Secretary and the tribal organization involved."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62e0378e-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/s9"},"text":"Pub. L. 93–638, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/250/s1"},"text":"Pub. L. 98–250, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-04-03"},"text":"Apr. 3, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/118"},"text":"98 Stat. 118","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/301/s2/a/5"},"text":"Pub. L. 101–301, § 2(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-24"},"text":"May 24, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/206"},"text":"104 Stat. 206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62e0378f-4962-11f