38/s103/c"},"text":"section 103(c) of Pub. L. 93–638","children":[],"tail":" were repealed and the remainder of "},{"tag":"ref","attrib":{"href":"/us/pl/93/638/s103"},"text":"section 103 of Pub. L. 93–638","children":[],"tail":" was redesignated as section 102(d) by "},{"tag":"ref","attrib":{"href":"/us/pl/100/472/tII/s201/b/1"},"text":"Pub. L. 100–472, title II, § 201(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-05"},"text":"Oct. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2289"},"text":"102 Stat. 2289","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450e–1"},"text":"section 450e–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62e03793-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/301"},"text":"Pub. L. 101–301","children":[],"tail":" substituted “chapter 63 of title 31” for “the Federal Grant and Cooperative Agreement Act of 1977 ("},{"tag":"ref","attrib":{"href":"/us/pl/95/224"},"text":"Pub. L. 95–224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/92/3"},"text":"92 Stat. 3","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
