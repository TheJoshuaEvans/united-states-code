{"tag":"section","attrib":{"id":"id621c992f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s174"},"text":null,"children":[{"tag":"num","attrib":{"value":"174"},"text":"§ 174.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Superintendence by President over tribes west of Mississippi","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized to exercise general superintendence and care over any tribe or nation which was removed upon an exchange of territory under authority of the act of ","children":[{"tag":"date","attrib":{"date":"1830-05-28"},"text":"May 28, 1830","children":[],"tail":", “to provide for an exchange of lands with the Indians residing in any of the States or Territories, and for their removal west of the Mississippi;” and to cause such tribe or nation to be protected, at their new residence, against all interruption or disturbance from any other tribe or nation of Indians, or from any other person or persons whatever."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621c9930-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2114.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621c9931-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621c9932-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id621c9933-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2114 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1830-05-28/ch148"},"text":"act May 28, 1830, ch. 148","children":[],"tail":", §§ 7, 8, "},{"tag":"ref","attrib":{"href":"/us/stat/4/412"},"text":"4 Stat. 412","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id621c9934-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id621c9935-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"American Indian Policy Review Commission","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/580"},"text":"Pub. L. 93–580","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1910"},"text":"88 Stat. 1910","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/94/80"},"text":"Pub. L. 94–80","children":[],"tail":", §§ 1–4, "},{"tag":"date","attrib":{"date":"1975-08-09"},"text":"Aug. 9, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/415"},"text":"89 Stat. 415","children":[],"tail":", 416; "},{"tag":"ref","attrib":{"href":"/us/pl/95/5"},"text":"Pub. L. 95–5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-02-17"},"text":"Feb. 17, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/13"},"text":"91 Stat. 13","children":[],"tail":", provided for the establishment, membership, etc., of the American Indian Policy Review Commission, and for investigations, studies, and a final report respecting Indian tribal government affairs, with the Commission to cease to exist three months after submission of the final report but not later than "},{"tag":"date","attrib":{"date":"1977-06-30"},"text":"June 30, 1977","children":[],"tail":", and Congressional committee reports to Congress within two years after referral to committee of the final report by the President of the Senate and Speaker of the House."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
