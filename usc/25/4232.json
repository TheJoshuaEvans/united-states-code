{"tag":"section","attrib":{"id":"id62d42a97-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4232"},"text":null,"children":[{"tag":"num","attrib":{"value":"4232"},"text":"§ 4232.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income requirement and income targeting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d42a98-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4232/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Housing shall qualify for affordable housing for purposes of this subchapter only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42a99-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4232/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each dwelling unit in the housing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42a9a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4232/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of rental housing, is made available for occupancy only by a family that is a low-income family at the time of the initial occupancy of that family of that unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42a9b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4232/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of housing for homeownership, is made available for purchase only by a family that is a low-income family at the time of purchase; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42a9c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4232/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each dwelling unit in the housing will remain affordable, according to binding commitments satisfactory to the Secretary, for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42a9d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4232/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remaining useful life of the property (as determined by the Secretary) without regard to the term of the mortgage or to transfer of ownership; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42a9e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4232/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such other period as the Secretary determines is the longest feasible period of time consistent with sound economics and the purposes of this subchapter, except upon a foreclosure by a lender (or upon other transfer in lieu of foreclosure) if that action—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d42a9f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4232/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recognizes any contractual or legal rights of any public agency, nonprofit sponsor, or other person or entity to take an action that would—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62d42aa0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4232/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoid termination of low-income affordability, in the case of foreclosure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d42aa1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4232/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer ownership in lieu of foreclosure; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d42aa2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4232/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not for the purpose of avoiding low-income affordability restrictions, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42aa3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4232/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a), housing assistance pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4228/a/2/B"},"text":"section 4228(a)(2)(B) of this title","children":[],"tail":" shall be considered affordable housing for purposes of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d42aa4-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s813"},"text":"Pub. L. 104–330, title VIII, § 813","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s203"},"text":"Pub. L. 106–568, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2888"},"text":"114 Stat. 2888","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s513"},"text":"Pub. L. 106–569, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2982"},"text":"114 Stat. 2982","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d42aa5-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d42aa6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62d42aa7-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s203"},"text":"Pub. L. 106–568, § 203","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":", enacted identical sections 813 of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":". This section is based on the text of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s813"},"text":"section 813 of Pub. L. 104–330","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
