{"tag":"section","attrib":{"id":"id62773c42-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1674"},"text":null,"children":[{"tag":"num","attrib":{"value":"1674"},"text":"§ 1674.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leases with Indian tribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62773c43-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1674/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the Secretary is authorized, in carrying out the purposes of this chapter, to enter into leases with Indian tribes for periods not in excess of twenty years. Property leased by the Secretary from an Indian tribe may be reconstructed or renovated by the Secretary pursuant to an agreement with such Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62773c44-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1674/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may enter into leases, contracts, and other legal agreements with Indian tribes or tribal organizations which hold—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62773c45-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1674/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title to;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62773c46-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1674/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a leasehold interest in; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62773c47-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1674/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a beneficial interest in (where title is held by the United States in trust for the benefit of a tribe);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"facilities used for the administration and delivery of health services by the Service or by programs operated by Indian tribes or tribal organizations to compensate such Indian tribes or tribal organizations for costs associated with the use of such facilities for such purposes. Such costs include rent, depreciation based on the useful life of the building, principal and interest paid or accrued, operation and maintenance expenses, and other expenses determined by regulation to be allowable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62773c48-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s804"},"text":"Pub. L. 94–437, title VIII, § 804","children":[],"tail":", formerly title VII, § 704, "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1414"},"text":"90 Stat. 1414","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/537/s8/a"},"text":"Pub. L. 96–537, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-17"},"text":"Dec. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3179"},"text":"94 Stat. 3179","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tVII/s701"},"text":"Pub. L. 100–713, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4826"},"text":"102 Stat. 4826","children":[],"tail":"; renumbered title VIII, § 804, "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s701/a"},"text":"Pub. L. 102–573, title VII, § 701(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4572"},"text":"106 Stat. 4572","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62773c49-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62773c4a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62773c4b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437"},"text":"Pub. L. 94–437","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1400"},"text":"90 Stat. 1400","children":[],"tail":", known as the Indian Health Care Improvement Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62773c4c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/713"},"text":"Pub. L. 100–713","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/537"},"text":"Pub. L. 96–537","children":[],"tail":" inserted provision that property leased by the Secretary from an Indian tribe may be reconstructed or renovated by the Secretary pursuant to an agreement with such Indian tribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
