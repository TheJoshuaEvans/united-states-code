{"tag":"section","attrib":{"id":"id62321dd1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s374"},"text":null,"children":[{"tag":"num","attrib":{"value":"374"},"text":"§ 374.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attendance of witnesses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The authority delegated to judges of the United States courts by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t35/s24"},"text":"section 24 of title 35","children":[],"tail":" is conferred upon the Secretary of the Interior to require the attendance of witnesses at hearings, upon proper showing by any of the parties to determine the heirs of decedents, held in accordance with sections 372 and 373 of this title, under such rules and regulations as he may prescribe."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62321dd2-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-08-01/ch222/s1"},"text":"Aug. 1, 1914, ch. 222, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/586"},"text":"38 Stat. 586","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62321dd3-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62321dd4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62321dd5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t35/s24"},"text":"Section 24 of title 35","children":[],"tail":"” substituted i