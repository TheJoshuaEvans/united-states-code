{"tag":"section","attrib":{"id":"id6217deec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s117b"},"text":null,"children":[{"tag":"num","attrib":{"value":"117b"},"text":"§ 117b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6217deed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s117b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Previous contractual obligations; tax exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds distributed under sections 117a to 117c of this title shall not be liable for the payment of previously contracted obligations except as may be provided by the governing body of the tribe and distributions of such funds shall be subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1973-10-19/s7"},"text":"section 7 of the Act of October 19, 1973","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/87/466"},"text":"87 Stat. 466","children":[],"tail":"), as amended ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1407"},"text":"25 U.S.C. 1407","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6217deee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s117b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds appropriated in satisfaction of judgments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in sections 117a to 117c of this title shall affect the requirements of the Act of ","children":[{"tag":"date","attrib":{"date":"1973-10-19"},"text":"October 19, 1973","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/87/466"},"text":"87 Stat. 466","children":[],"tail":"), as amended ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1401"},"text":"25 U.S.C. 1401","children":[],"tail":" et seq.], or of any plan approved thereunder, with respect to the use or distribution of funds subject to that Act: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That per capita payments made pursuant to a plan approved under that Act may be made by an Indian tribe as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s117a"},"text":"section 117a of this title","children":[],"tail":" if all other provisions of the 1973 Act are met, including but not limited to, the protection of the interests of minors and incompetents in such funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6217deef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s117b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shoshone Tribe and Arapaho Tribe of the Wind River Reservation, Wyoming","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in sections 117a to 117c of this title, except the provisions of subsection (a) of this section, shall apply to the Shoshone Tribe and the Arapahoe ","children":[{"tag":"ref","attrib":{"idref":"fn002007"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002007"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Arapaho”."}],"tail":" Tribe of the Wind River Reservation, Wyoming."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6217def0-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/64/s2"},"text":"Pub. L. 98–64, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-02"},"text":"Aug. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/365"},"text":"97 Stat. 365","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6217def1-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6217def2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6217def3-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1973-10-19"},"text":"October 19, 1973","children":[],"tail":", referred to in subsec. (b), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/134"},"text":"Pub. L. 93–134","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-19"},"text":"Oct. 19, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/466"},"text":"87 Stat. 466","children":[],"tail":", known as the Indian Tribal Judgment Funds Use or Distribution Act, which is classified generally to chapter 16 (§ 1401 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1401/c"},"text":"section 1401(c) of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
