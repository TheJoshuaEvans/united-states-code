{"tag":"section","attrib":{"id":"id62346734-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s389d"},"text":null,"children":[{"tag":"num","attrib":{"value":"389d"},"text":"§ 389d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall have power to make such rules and regulations as may be necessary to carry out the provisions of sections 389 to 389e of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62346735-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-22/ch692/s5"},"text":"June 22, 1936, ch. 692, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1804"},"text":"49 Stat. 1804","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
