{"tag":"section","attrib":{"id":"id629af142-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218"},"text":null,"children":[{"tag":"num","attrib":{"value":"2218"},"text":"§ 2218.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of leases, rights-of-way, and sales of natural resources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id629af143-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval by the Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629af144-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary may approve any lease or agreement that affects individually owned allotted land or any other land held in trust or restricted status by the Secretary on behalf of an Indian, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id629af145-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owners of not less than the applicable percentage (determined under subsection (b)) of the undivided interest in the allotted land that is covered by the lease or agreement consent in writing to the lease or agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629af146-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that approving the lease or agreement is in the best interest of the owners of the undivided interest in the allotted land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629af147-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to apply to leases involving coal or uranium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629af148-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “allotted land” includes any land held in trust or restricted status by the Secretary on behalf of one or more Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629af149-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable percentage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629af14a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Percentage interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The applicable percentage referred to in subsection (a)(1) shall be determined as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id629af14b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there are 5 or fewer owners of the undivided interest in the allotted land, the applicable percentage shall be 90 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629af14c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there are more than 5 such owners, but fewer than 11 such owners, the applicable percentage shall be 80 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629af14d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there are more than 10 such owners, but fewer than 20 such owners, the applicable percentage shall be 60 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629af14e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there are 20 or more such owners, the applicable percentage shall be a majority of the interests in the allotted land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629af14f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of owners","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id629af150-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, in determining the number of owners of, and their interests in, the undivided interest in the allotted land with respect to a lease or agreement, the Secretary shall make such determination based on the records of the Department of the Interior that identify the owners of such lands and their interests and the number of owners of such land on the date on which the lease or agreement involved is submitted to the Secretary under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629af151-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subparagraph (A) shall be construed to authorize the Secretary to treat an Indian tribe as the owner of an interest in allotted land that did not escheat to the tribe pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2206"},"text":"section 2206 of this title","children":[],"tail":" as a result of the Supreme Court’s decision in Babbitt v. Youpee (117 S "},{"tag":"ref","attrib":{"idref":"fn002146"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002146"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":" Ct. 727 (1997))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629af152-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary to sign lease or agreement on behalf of certain owners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may give written consent to a lease or agreement under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629af153-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on behalf of the individual Indian owner if the owner is deceased and the heirs to, or devisees of, the interest of the deceased owner have not been determined; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629af154-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on behalf of any heir or devisee referred to in paragraph (1) if the heir or devisee has been determined but cannot be located ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629af155-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of approval","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629af156-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to all parties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id629af157-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), a lease or agreement approved by the Secretary under subsection (a) shall be binding on the parties described in subparagraph (B), to the same extent as if all of the owners of the undivided interest in allotted land covered under the lease or agreement consented to the lease or agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629af158-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of parties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The parties referred to in subparagraph (A) are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id629af159-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owners of the undivided interest in the allotted land covered under the lease or agreement referred to in such subparagraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id629af15a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other parties to the lease or agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629af15b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribe not treated as party to lease; no effect on tribal sovereignty, immunity","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id629af15c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (B) shall apply with respect to any undivided interest in allotted land held by the Secretary in trust for a tribe if a lease or agreement under subsection (a) is otherwise applicable to such undivided interest by reason of this section even though the Indian tribe did not consent to the lease or agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629af15d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of lease","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The lease or agreement described in subparagraph (A) shall apply to the portion of the undivided interest in allotted land described in such paragraph (including entitlement of the Indian tribe to payment under the lease or agreement), and the Indian tribe shall not be treated as being a party to the lease or agreement. Nothing in this section (or in the lease or agreement) shall be construed to affect the sovereignty of the Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629af15e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of proceeds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629af15f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proceeds derived from a lease or agreement that is approved by the Secretary under subsection (a) shall be distributed to all owners of undivided interest in the allotted land covered under the lease or agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629af160-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amounts distributed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the proceeds under paragraph (1) that are distributed to each owner under that paragraph shall be determined in accordance with the portion of the undivided interest in the allotted land covered under the lease or agreement that is owned by that owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629af161-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to amend or modify the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/188"},"text":"Public Law 105–188","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s396"},"text":"25 U.S.C. 396","children":[],"tail":" note), the American Indian Agricultural Resources Management Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3701"},"text":"25 U.S.C. 3701","children":[],"tail":" et seq.), title II of the Indian Land Consolidation Act Amendments of 2000, or any other Act that provides specific standards for the percentage of ownership interest that must approve a lease or agreement on a specified reservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629af162-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2218/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to supersede, repeal, or modify any general or specific statute authorizing the grant or approval of any type of land use transaction involving fractional interests in trust or restricted land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629af163-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/459/tII/s219"},"text":"Pub. L. 97–459, title II, § 219","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/462/tI/s103/6"},"text":"Pub. L. 106–462, title I, § 103(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2004"},"text":"114 Stat. 2004","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/10"},"text":"Pub. L. 108–374, § 6(a)(10)","children":[],"tail":", (11), "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1804"},"text":"118 Stat. 1804","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id629af164-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id629af165-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id629af166-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The American Indian Agricultural Resources Management Act, referred to in subsec. (f), probably means the American Indian Agricultural Resource Management Act, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/177"},"text":"Pub. L. 103–177","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2011"},"text":"107 Stat. 2011","children":[],"tail":", as amended, which is classified generally to chapter 39 (§ 3701 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3701"},"text":"section 3701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Land Consolidation Act Amendments of 2000, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/462"},"text":"Pub. L. 106–462","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1991"},"text":"114 Stat. 1991","children":[],"tail":". Title II of the Act enacted provisions classified as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s396"},"text":"section 396 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2000 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2201"},"text":"section 2201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (g), was in the original “this Act”, which was translated as reading “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/459"},"text":"Pub. L. 97–459","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id629af167-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/10"},"text":"Pub. L. 108–374, § 6(a)(10)","children":[],"tail":", substituted “90” for “100”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/11"},"text":"Pub. L. 108–374, § 6(a)(11)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
