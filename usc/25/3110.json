{"tag":"section","attrib":{"id":"id62b53089-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3110"},"text":null,"children":[{"tag":"num","attrib":{"value":"3110"},"text":"§ 3110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal forestry programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b5308a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish within the Bureau of Indian Affairs a program to provide financial support to forestry programs established by an Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b5308b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support allocation formula; criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b5308c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3110/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, with the participation of Indian tribes with Indian forest lands, shall establish, and promulgate by regulations, a formula—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b5308d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3110/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the determination of Indian tribes eligible for such support,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b5308e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3110/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the provision of levels of assistance for the forestry programs of such tribes, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b5308f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3110/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allocation of base support funds to such tribes under the program established pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53090-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3110/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The formula established pursuant to this subsection shall provide funding necessary to support—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b53091-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3110/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one professional forester, including fringe benefits and support costs, for each eligible tribe, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b53092-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3110/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one additional professional forester or forest technician, including fringe benefits and support costs, for each level of assistance for which an eligible Indian tribe qualifies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53093-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3110/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any fiscal year that appropriations are not sufficient to fully fund tribal forestry programs at each level of assistance under the formula required to be established in this section, available funds for each level of assistance shall be evenly divided among the tribes qualifying for that level of assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b53094-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIII/s311"},"text":"Pub. L. 101–630, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4538"},"text":"104 Stat. 4538","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
