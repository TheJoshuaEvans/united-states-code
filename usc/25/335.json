{"tag":"section","attrib":{"id":"id622d3af0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s335"},"text":null,"children":[{"tag":"num","attrib":{"value":"335"},"text":"§ 335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of provisions as to allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Unless otherwise specifically provided, the provisions of the Act of ","children":[{"tag":"date","attrib":{"date":"1887-02-08"},"text":"February 8, 1887","children":[],"tail":" (Twenty-fourth Statutes at Large, page 388), as amended, are extended to all lands heretofore purchased or which may be purchased by authority of Congress for the use or benefit of any individual Indian or band or tribe of Indians."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id622d3af1-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1923-02-14/ch76"},"text":"Feb. 14, 1923, ch. 76","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1246"},"text":"42 Stat. 1246","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id622d3af2-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id622d3af3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id622d3af4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1887-02-08"},"text":"February 8, 1887","children":[],"tail":", referred to in text, is popularly known as the Indian General Allotment Act. For classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s331"},"text":"section 331 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
