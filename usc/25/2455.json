{"tag":"section","attrib":{"id":"id629fd404-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2455"},"text":null,"children":[{"tag":"num","attrib":{"value":"2455"},"text":"§ 2455.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement and judicial report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id629fd405-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2455/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compilation of law enforcement data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior, with respect to the administration of any law enforcement or judicial services program by the Bureau of Indian Affairs, either directly or through contracts under the Indian Self-Determination Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.], shall require the compilation of data relating to calls and encounters, arrests and detentions, and disposition of cases by Bureau of Indian Affairs or tribal law enforcement or judicial personnel involving Indians where it is determined that alcohol or substance abuse is a contributing factor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629fd406-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2455/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral of data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The data compiled pursuant to subsection (a) shall be provided annually to the affected Indian tribe and Tribal Coordinating Committee to assist them in developing or modifying a Tribal Action Plan and shall also be submitted to the Indian Health Service ","children":[{"tag":"ref","attrib":{"idref":"fn002161"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002161"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “service”."}],"tail":" unit director who will have the responsibility for compiling a tribal comprehensive report as provided in section 2477 "},{"tag":"ref","attrib":{"idref":"fn002162"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002162"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629fd407-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2455/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall insure that the data is compiled and reported in a manner which will preserve the confidentiality of the families and individuals involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629fd408-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4222"},"text":"Pub. L. 99–570, title IV, § 4222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-148"},"text":"100 Stat. 3207–148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id629fd409-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id629fd40a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id629fd40b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination Act, referred to in subsec. (a), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2206"},"text":"88 Stat. 2206","children":[],"tail":", which is classified principally to subchapter I (§ 5321 et seq.) of chapter 46 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2477"},"text":"Section 2477 of this title","children":[],"tail":", referred to in subsec. (b), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s702/b/2"},"text":"Pub. L. 102–573, title VII, § 702(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4582"},"text":"106 Stat. 4582","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
