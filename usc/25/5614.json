{"tag":"section","attrib":{"id":"id62f59451-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614"},"text":null,"children":[{"tag":"num","attrib":{"value":"5614"},"text":"§ 5614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest land management and surface leasing activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f59452-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f59453-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest land management activity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “forest land management activity” means any activity described in section 304(4) of the National Indian Forest Resources Management Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3103/4"},"text":"25 U.S.C. 3103(4)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f59454-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interested party","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “interested party” means an Indian or non-Indian individual, entity, or government the interests of which could be adversely affected by a tribal trust land leasing decision made by an applicable Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f59455-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surface leasing transaction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “surface leasing transaction” means a residential, business, agricultural, or wind or solar resource lease of land the title to which is held—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f59456-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in trust by the United States for the benefit of an Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f59457-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in fee by an Indian tribe, subject to restrictions against alienation under Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f59458-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval by Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may approve an Indian trust asset management plan that includes a provision authorizing the Indian tribe to enter into, approve, and carry out a surface leasing transaction or forest land management activity without approval of the Secretary, regardless of whether the surface leasing transaction or forest land management activity would require such an approval under otherwise applicable law (including regulations), if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f59459-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resolution or other action of the governing body of the Indian tribe referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5612/c/2/A"},"text":"section 5612(c)(2)(A) of this title","children":[],"tail":" expressly authorizes the inclusion of the provision in the Indian trust asset management plan; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f5945a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Indian tribe has adopted regulations expressly incorporated by reference into the Indian trust asset management plan that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f5945b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to a surface leasing transaction—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62f5945c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been approved by the Secretary pursuant to subsection (h)(4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s415"},"text":"section 415 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62f5945d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have not yet been approved by the Secretary in accordance with clause (i), but that the Secretary determines at or prior to the time of approval under this paragraph meet the requirements of subsection (h)(3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s415"},"text":"section 415 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f5945e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to forest land management activities, the Secretary determines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62f5945f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the regulations of the Secretary adopted under the National Indian Forest Resources Management Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3101"},"text":"25 U.S.C. 3101","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62f59460-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for an environmental review process that includes—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62f59461-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification and evaluation of any significant effects of the proposed action on the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62f59462-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a process consistent with the regulations referred to in clause (i) for ensuring that—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id62f59463-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/b/2/B/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public is informed of, and has a reasonable opportunity to comment on, any significant environmental impacts of the proposed forest land management activity identified by the Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id62f59464-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/b/2/B/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian tribe provides responses to relevant and substantive public comments on any such impacts before the Indian tribe approves the forest land management activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f59465-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of transactions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f59466-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the discretion of the Indian tribe, an Indian trust asset management plan may authorize the Indian tribe to carry out a surface leasing transaction, a forest land management activity, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f59467-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of specific transactions and activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the discretion of the Indian tribe, the Indian tribe may include in the integrated resource management plan any 1 or more of the transactions and activities authorized to be included in the plan under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f59468-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f59469-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical assistance, on request of an Indian tribe, for development of a regulatory environmental review process required under subsection (b)(2)(B)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f5946a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Self-Determination and Education Assistance Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The technical assistance to be provided by the Secretary pursuant to paragraph (1) may be made available through contracts, grants, or agreements entered into in accordance with, and made available to entities eligible for, contracts, grants, or agreements under the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.)."},{"tag":"ref","attrib":{"idref":"fn002281"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002281"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f5946b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal environmental review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (b), if an Indian tribe carries out a project or activity funded by a Federal agency, the Indian tribe shall have the authority to rely on the environmental review process of the applicable Federal agency, rather than any tribal environmental review process under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f5946c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documentation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an Indian tribe executes a surface leasing transaction or forest land management activity, pursuant to tribal regulations under subsection (b)(2), the Indian tribe shall provide to the Secretary ","children":[{"tag":"ref","attrib":{"idref":"fn002282"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002282"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by a dash."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f5946d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the surface leasing transaction or forest land management activity documents, including any amendments to, or renewals of, the applicable transaction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f5946e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of tribal regulations, a surface leasing transaction, or forest land management activities that allow payments to be made directly to the Indian tribe, documentation of the payments that is sufficient to enable the Secretary to discharge the trust responsibility of the United States under subsection (g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f5946f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust responsibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f59470-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States shall not be liable for losses sustained—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f59471-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an Indian tribe as a result of the execution of any forest land management activity pursuant to tribal regulations under subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f59472-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any party to a lease executed pursuant to tribal regulations under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f59473-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to the authority of the Secretary to fulfill the trust obligation of the United States to Indian tribes under Federal law (including regulations), the Secretary may, on reasonable notice from the applicable Indian tribe and at the discretion of the Secretary, enforce the provisions of, or cancel, any lease executed by the Indian tribe under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f59474-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f59475-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An interested party, after exhausting any applicable tribal remedies, may submit to the Secretary a petition, at such time and in such form as the Secretary determines to be appropriate, to review the compliance of an applicable Indian tribe with any tribal regulations approved by the Secretary under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f59476-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines under paragraph (1) that a violation of tribal regulations has occurred, the Secretary may take any action the Secretary determines to be necessary to remedy the violation, including rescinding the approval of the tribal regulations and reassuming responsibility for the approval of leases of tribal trust land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f59477-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documentation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines under paragraph (1) that a violation of tribal regulations has occurred and a remedy is necessary, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f59478-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a written determination with respect to the regulations that have been violated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f59479-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the applicable Indian tribe a written notice of the alleged violation, together with the written determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f5947a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/h/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prior to the exercise of any remedy, the rescission of the approval of the regulation involved, or the reassumption of the trust asset transaction approval responsibilities, provide to the applicable Indian tribe—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62f5947b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/h/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a hearing on the record; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62f5947c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5614/h/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reasonable opportunity to cure the alleged violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f5947d-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/178/tII/s205"},"text":"Pub. L. 114–178, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/436"},"text":"130 Stat. 436","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62f5947e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62f5947f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62f59480-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Indian Forest Resources Management Act, referred to in subsec. (b)(2)(B)(i), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630"},"text":"Pub. L. 101–630","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4532"},"text":"104 Stat. 4532","children":[],"tail":", which is classified generally to chapter 33 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3101"},"text":"section 3101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of this title prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
