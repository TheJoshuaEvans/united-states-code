{"tag":"section","attrib":{"id":"id62d42b2d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4240"},"text":null,"children":[{"tag":"num","attrib":{"value":"4240"},"text":"§ 4240.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and audit by Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d42b2e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4240/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42b2f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4240/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, not less frequently than on an annual basis, make such reviews and audits as may be necessary or appropriate to determine whether—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42b30-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4240/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Director has—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d42b31-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4240/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carried out eligible activities under this subchapter in a timely manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d42b32-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4240/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carried out and made certifications in accordance with the requirements and the primary objectives of this subchapter and with other applicable laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d42b33-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4240/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a continuing capacity to carry out the eligible activities in a timely manner;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42b34-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4240/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director has complied with the housing plan submitted by the Director under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42b35-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4240/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance reports of the Department under section 4240 ","children":[{"tag":"ref","attrib":{"idref":"fn002245"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002245"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “4239”."}],"tail":" of this title are accurate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42b36-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4240/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Onsite visits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each review conducted under this section shall, to the extent practicable, include onsite visits by employees of the Department of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42b37-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4240/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall give the Department of Hawaiian Home Lands not less than 30 days to review and comment on a report under this subsection. After taking into consideration the comments of the Department, the Secretary may revise the report and shall make the comments of the Department and the report with any revisions, readily available to the public not later than 30 days after receipt of the comments of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d69a38-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4240/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of reviews","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make appropriate adjustments in the amount of annual grants under this subchapter in accordance with the findings of the Secretary pursuant to reviews and audits under this section. The Secretary may adjust, reduce, or withdraw grant amounts, or take other action as appropriate in accordance with the reviews and audits of the Secretary under this section, except that grant amounts already expended on affordable housing activities may not be recaptured or deducted from future assistance provided to the Department of Hawaiian Home Lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d69a39-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s821"},"text":"Pub. L. 104–330, title VIII, § 821","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s203"},"text":"Pub. L. 106–568, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2894"},"text":"114 Stat. 2894","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s513"},"text":"Pub. L. 106–569, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2988"},"text":"114 Stat. 2988","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d69a3a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d69a3b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62d69a3c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s203"},"text":"Pub. L. 106–568, § 203","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":", enacted identical sections 821 of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":". This section is based on the text of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s821"},"text":"section 821 of Pub. L. 104–330","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
