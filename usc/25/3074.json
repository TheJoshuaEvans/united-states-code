{"tag":"section","attrib":{"id":"id62b2e6be-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3074"},"text":null,"children":[{"tag":"num","attrib":{"value":"3074"},"text":"§ 3074.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary return of tangible cultural heritage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b2e6bf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3074/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liaison","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Secretary of State shall each designate a liaison to facilitate the voluntary return of tangible cultural heritage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b2e6c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3074/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trainings and workshops","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The liaisons designated under subsection (a) shall offer to representatives of Indian Tribes and Native Hawaiian organizations and collectors, dealers, and other individuals and organizations trainings and workshops regarding the voluntary return of tangible cultural heritage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b2e6c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3074/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referrals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b2e6c2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3074/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall refer individuals and organizations to 1 or more Indian Tribes and Native Hawaiian organizations with a cultural affiliation to tangible cultural heritage for the purpose of facilitating the voluntary return of tangible cultural heritage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e6c3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3074/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall compile a list of representatives from each Indian Tribe and Native Hawaiian organization for purposes of referral under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e6c4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3074/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with Indian Tribes, Native Hawaiian organizations, and the Native working group convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3076/a"},"text":"section 3076(a) of this title","children":[],"tail":" before making a referral under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e6c5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3074/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third-party experts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use third parties with relevant expertise, including institutions of higher education, museums, dealers, and collector organizations, in determining to which Indian Tribe or Native Hawaiian organization an individual or organization should be referred under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b2e6c6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3074/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section imposes on any individual or entity any additional penalties or legal liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b2e6c7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3074/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax documentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In facilitating the voluntary return of tangible cultural heritage under this section, the Secretary shall include provision of tax documentation for a deductible gift to an Indian Tribe or Native Hawaiian organization, if the recipient Indian Tribe or Native Hawaiian organization consents to the provision of tax documentation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b2e6c8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3074/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repatriation under Native American Graves Protection and Repatriation Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The voluntary return provisions of this section shall apply to a specific item of tangible cultural heritage only to the extent that the repatriation provisions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3005"},"text":"section 3005 of this title","children":[],"tail":" do not apply to the item of tangible cultural heritage."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b2e6c9-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/258/s6"},"text":"Pub. L. 117–258, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-21"},"text":"Dec. 21, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2382"},"text":"136 Stat. 2382","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
