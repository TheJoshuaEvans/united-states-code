{"tag":"section","attrib":{"id":"id6279add0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684"},"text":null,"children":[{"tag":"num","attrib":{"value":"1684"},"text":"§ 1684.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency plan for Indian safety and health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6279add1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a fund, to be known as the “Emergency Fund for Indian Safety and Health” (referred to in this section as the “Fund”), consisting of such amounts as are appropriated to the Fund under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6279add2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers to Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6279add3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Fund, out of funds of the Treasury not otherwise appropriated, $1,602,619,000 for the 5-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279add4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts deposited in the Fund under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6279add5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made available without further appropriation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279add6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in addition to amounts made available under any other provision of law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279add7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6279add8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures from Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On request by the Attorney General, the Secretary of the Interior, or the Secretary of Health and Human Services, the Secretary of the Treasury shall transfer from the Fund to the Attorney General, the Secretary of the Interior, or the Secretary of Health and Human Services, as appropriate, such amounts as the Attorney General, the Secretary of the Interior, or the Secretary of Health and Human Services determines to be necessary to carry out the emergency plan under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6279add9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6279adda-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts required to be transferred to the Fund under this section shall be transferred at least monthly from the general fund of the Treasury to the Fund on the basis of estimates made by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279addb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Proper adjustment shall be made in amounts subsequently transferred to the extent prior estimates were in excess of or less than the amounts required to be transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6279addc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remaining amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts remaining in the Fund on September 30 of an applicable fiscal year may be used by the Attorney General, the Secretary of the Interior, or the Secretary of Health and Human Services to carry out the emergency plan under subsection (f) for any subsequent fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6279addd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", the Attorney General, the Secretary of the Interior, and the Secretary of Health and Human Services, in consultation with Indian tribes (as defined in section 4 of the Indian Self-Determination and Education Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"25 U.S.C. 450b","children":[],"tail":")),"},{"tag":"ref","attrib":{"idref":"fn002102"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002102"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall jointly establish an emergency plan that addresses law enforcement, water, and health care needs of Indian tribes under which, for each of fiscal years 2010 through 2019, of amounts in the Fund—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6279adde-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Attorney General shall use—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6279addf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 18.5 percent for the construction, rehabilitation, and replacement of Federal Indian detention facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ade0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1.5 percent to investigate and prosecute crimes in Indian country (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1151"},"text":"section 1151 of title 18","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ade1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1.5 percent for use by the Office of Justice Programs for Indian and Alaska Native programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ade2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 0.5 percent to provide assistance to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6279ade3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/f/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parties to cross-deputization or other cooperative agreements between State or local governments and Indian tribes (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5130"},"text":"section 5130 of this title","children":[],"tail":") carrying out law enforcement activities in Indian country; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6279ade4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/f/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State of Alaska (including political subdivisions of that State) for carrying out the Village Public Safety Officer Program and law enforcement activities on Alaska Native land (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3902"},"text":"section 3902 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279ade5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of the Interior shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6279ade6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposit 15.5 percent in the public safety and justice account of the Bureau of Indian Affairs for use by the Office of Justice Services of the Bureau in providing law enforcement or detention services, directly or through contracts or compacts with Indian tribes under the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.); "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ade7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use not more than $602,619,000 to implement requirements of Indian water settlement agreements that are approved by Congress (or the legislation to implement such an agreement) under which the United States shall plan, design, rehabilitate, or construct, or provide financial assistance for the planning, design, rehabilitation, or construction of, water supply or delivery infrastructure that will serve an Indian tribe (as defined in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"25 U.S.C. 450b","children":[],"tail":")); "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279ade8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of Health and Human Services, acting through the Director of the Indian Health Service, shall use 12.5 percent to provide, directly or through contracts or compacts with Indian tribes under the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.)— "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6279ade9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contract health services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279adea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction, rehabilitation, and replacement of Indian health facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279adeb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1684/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" domestic and community sanitation facilities serving members of Indian tribes (as defined in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"25 U.S.C. 450b","children":[],"tail":")) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2004a"},"text":"section 2004a of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id627bf7dc-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/293/tVI/s601"},"text":"Pub. L. 110–293, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2968"},"text":"122 Stat. 2968","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/291/tVIII/s831"},"text":"Pub. L. 111–291, title VIII, § 831","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-08"},"text":"Dec. 8, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3163"},"text":"124 Stat. 3163","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id627bf7dd-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id627bf7de-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id627bf7df-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of this title prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of this title. Section 4 of the Act was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"section 450b of this title","children":[],"tail":" prior to editorial reclassification as "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id627bf7e0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Tom Lantos and Henry J. Hyde United States Global Leadership Against HIV/AIDS, Tuberculosis, and Malaria Reauthorization Act of 2008, and not as part of the Indian Health Care Improvement Act which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s443c"},"text":"section 443c of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id627bf7e1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/291/s831/1"},"text":"Pub. L. 111–291, § 831(1)","children":[],"tail":", substituted “$1,602,619,000” for “$2,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/291/s831/2"},"text":"Pub. L. 111–291, § 831(2)","children":[],"tail":", substituted “not more than $602,619,000” for “50 percent”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
