{"tag":"section","attrib":{"id":"id62e9ad6e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5345"},"text":null,"children":[{"tag":"num","attrib":{"value":"5345"},"text":"§ 5345.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for education in public schools; submission of education plan by contractor as prerequisite; criteria for approval of plan by Secretary of the Interior; participation by non-Indian students","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall not enter into any contract for the education of Indians unless the prospective contractor has submitted to, and has had approved by the Secretary of the Interior, an education plan, which plan, in the determination of the Secretary, contains educational objectives which adequately address the educational needs of the Indian students who are to be beneficiaries of the contract and assures that the contract is capable of meeting such objectives: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That where students other than Indian students participate in such programs, money expended under such contract shall be prorated to cover the participation of only the Indian students."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62e9ad6f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-04-16/ch147/s4"},"text":"Apr. 16, 1934, ch. 147, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/638/tII/s202"},"text":"Pub. L. 93–638, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2213"},"text":"88 Stat. 2213","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62e9ad70-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62e9ad71-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62e9ad72-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s455"},"text":"section 455 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62e9ad73-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-04-16/ch147"},"text":"act Apr. 16, 1934, ch. 147","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/596"},"text":"48 Stat. 596","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-04/ch490"},"text":"June 4, 1936, ch. 490","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1458"},"text":"49 Stat. 1458","children":[],"tail":", directed Secretary of the Interior to report to Congress any contracts made under provisions of sections 5342 to 5344 of this title, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/86/533/s1/15"},"text":"Pub. L. 86–533, § 1(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-29"},"text":"June 29, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/248"},"text":"74 Stat. 248","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tai