{"tag":"section","attrib":{"id":"id62773cfb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1680e"},"text":"§ 1680e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract health services for the Trenton Service Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62773cfc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service to Turtle Mountain Band","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, is directed to provide contract health services to members of the Turtle Mountain Band of Chippewa Indians that reside in the Trenton Service Area of Divide, McKenzie, and Williams counties in the State of North Dakota and the adjoining counties of Richland, Roosevelt, and Sheridan in the State of Montana.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62773cfd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Band member eligibility not expanded","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed as expanding the eligibility of members of the Turtle Mountain Band of Chippewa Indians for health services provided by the Service beyond the scope of eligibility for such health services that applied on ","children":[{"tag":"date","attrib":{"date":"1986-05-01"},"text":"May 1, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62773cfe-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s815"},"text":"Pub. L. 94–437, title VIII, § 815","children":[],"tail":", formerly title VII, § 715, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tVII/s709"},"text":"Pub. L. 100–713, title VII, § 709","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4831"},"text":"102 Stat. 4831","children":[],"tail":"; renumbered title VIII, § 815, "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s701/a"},"text":"Pub. L. 102–573, title VII, § 701(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4572"},"text":"106 Stat. 4572","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
