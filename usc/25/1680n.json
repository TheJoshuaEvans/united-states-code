{"tag":"section","attrib":{"id":"id6279ad54-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680n"},"text":null,"children":[{"tag":"num","attrib":{"value":"1680n"},"text":"§ 1680n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for Indian reservations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6279ad55-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities and projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"1992-10-29"},"text":"October 29, 1992","children":[],"tail":", the Bureau of Indian Affairs and the Service shall, in all matters involving the reorganization or development of Service facilities, or in the establishment of related employment projects to address unemployment conditions in economically depressed areas, give priority to locating such facilities and projects on Indian lands if requested by the Indian tribe with jurisdiction over such lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6279ad56-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Indian lands” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “Indian lands” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6279ad57-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680n/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all lands within the limits of any Indian reservation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279ad58-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680n/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any lands title which is held in trust by the United States for the benefit of any Indian tribe or individual Indian, or held by any Indian tribe or individual Indian subject to restriction by the United States against alienation and over which an Indian tribe exercises governmental power.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6279ad59-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s824"},"text":"Pub. L. 94–437, title VIII, § 824","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVIII/s812"},"text":"Pub. L. 102–573, title VIII, § 812","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4589"},"text":"106 Stat. 4589","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
