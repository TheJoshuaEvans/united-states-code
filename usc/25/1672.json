{"tag":"section","attrib":{"id":"id6274cc39-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1672"},"text":null,"children":[{"tag":"num","attrib":{"value":"1672"},"text":"§ 1672.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Prior to any revision of or amendment to rules or regulations promulgated pursuant to this chapter, the Secretary shall consult with Indian tribes and appropriate national or regional Indian organizations and shall publish any proposed revision or amendment in the Federal Register not less than sixty days prior to the effective date of such revision or amendment in order to provide adequate notice to, and receive comments from, other interested parties.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62773c3a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s802"},"text":"Pub. L. 94–437, title VIII, § 802","children":[],"tail":", formerly title VII, § 702, "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1413"},"text":"90 Stat. 1413","children":[],"tail":"; renumbered title VIII, § 802, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s701/a"},"text":"Pub. L. 102–573, title VII, § 701(a)","children":[],"tail":", (b), title VIII, § 802, "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4572"},"text":"106 Stat. 4572","children":[],"tail":", 4585.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62773c3b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62773c3c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62773c3d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437"},"text":"Pub. L. 94–437","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1400"},"text":"90 Stat. 1400","children":[],"tail":", known as the Indian Health Care Improvement Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62773c3e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s802"},"text":"Pub. L. 102–573, § 802","children":[],"tail":", amended section generally, substituting present provisions for former provisions relating in subsec. (a) to consideration, formulation, proposal, and promulgation of regulations and in subsec. (b) to revision and amendment of regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
