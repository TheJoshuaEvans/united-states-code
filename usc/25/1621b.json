{"tag":"section","attrib":{"id":"id6261b869-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1621b"},"text":"§ 1621b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health promotion and disease prevention services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6261b86a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, shall provide health promotion and disease prevention services to Indians so as to achieve the health status objectives set forth in section 1602(b) ","children":[{"tag":"ref","attrib":{"idref":"fn002044"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002044"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6261b86b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation statement for Presidential budget","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to the President for inclusion in each statement which is required to be submitted to the Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1671"},"text":"section 1671 of this title","children":[],"tail":" an evaluation of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6261b86c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health promotion and disease prevention needs of Indians,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6261b86d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health promotion and disease prevention activities which would best meet such needs,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6261b86e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the internal capacity of the Service to meet such needs, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6261b86f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resources which would be required to enable the Service to undertake the health promotion and disease prevention activities necessary to meet such needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6261b870-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tII/s203"},"text":"Pub. L. 94–437, title II, § 203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tII/s203/c"},"text":"Pub. L. 100–713, title II, § 203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4805"},"text":"102 Stat. 4805","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tII/s203"},"text":"Pub. L. 102–573, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4546"},"text":"106 Stat. 4546","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6261b871-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6261b872-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6261b873-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1602"},"text":"Section 1602 of this title","children":[],"tail":", referred to in subsec. (a), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":", and, as so amended, no longer contains a subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6261b874-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s203/1"},"text":"Pub. L. 102–573, § 203(1)","children":[],"tail":", inserted before period at end “so as to achieve the health status objectives set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1602/b"},"text":"section 1602(b) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s203/2"},"text":"Pub. L. 102–573, § 203(2)","children":[],"tail":", in introductory provisions, substituted “section 1671” for “section 1621(f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s203/3"},"text":"Pub. L. 102–573, § 203(3)","children":[],"tail":", struck out subsec. (c) which directed establishment of between 1 and 4 health-related demonstration projects to terminate 30 months after "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6261b875-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6261b876-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings on Health Promotion and Disease Prevention","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/713/tII/s203/a"},"text":"Pub. L. 100–713, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4804"},"text":"102 Stat. 4804","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/713/tII/s203/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds that health promotion and disease prevention activities will—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the health and well being of Indians, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the expenses for medical care of Indians.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
