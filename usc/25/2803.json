{"tag":"section","attrib":{"id":"id62abba7c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803"},"text":null,"children":[{"tag":"num","attrib":{"value":"2803"},"text":"§ 2803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement authority","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may charge employees of the Bureau with law enforcement responsibilities and may authorize those employees to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62abba7d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry firearms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abba7e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" execute or serve warrants, summonses, or other orders relating to a crime committed in Indian country and issued under the laws of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62abba7f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States (including those issued by a Court of Indian Offenses under regulations prescribed by the Secretary or offenses processed by the Central Violations Bureau); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62abba80-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe if authorized by the Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abba81-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make an arrest without a warrant for an offense committed in Indian country if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62abba82-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is committed in the presence of the employee,","children":[{"tag":"ref","attrib":{"idref":"fn002190"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002190"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62abba83-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is a felony and the employee has probable cause to believe that the person to be arrested has committed, or is committing, the felony;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62abba84-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is a misdemeanor crime of domestic violence, dating violence, stalking, or violation of a protection order and has, as an element, the use or attempted use of physical force, or the threatened use of a deadly weapon, committed by a current or former spouse, parent, or guardian of the victim, by a person with whom the victim shares a child in common, by a person who is cohabitating with or has cohabited with the victim as a spouse, parent, or guardian, or by a person similarly situated to a spouse, parent or guardian of the victim, and the employee has probable cause to believe that the person to be arrested has committed, or is committing the crime; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62abba85-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62abba86-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the offense involves—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62abba87-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/3/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a misdemeanor controlled substance offense in violation of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id62abba88-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/3/D/i/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"21 U.S.C. 801","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id62abba89-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/3/D/i/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title IX of the Personal Responsibility and Work Opportunity Reconciliation Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s862a"},"text":"21 U.S.C. 862a","children":[],"tail":" et seq.); "},{"tag":"ref","attrib":{"idref":"fn002191"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002191"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" or"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id62abba8a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/3/D/i/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s865"},"text":"section 865 of title 21","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62abba8b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/3/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a misdemeanor firearms offense in violation of chapter 44 of title 18;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62abba8c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/3/D/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a misdemeanor assault in violation of chapter 7 of title 18; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62abba8d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/3/D/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a misdemeanor liquor trafficking offense in violation of chapter 59 of title 18; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62abba8e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee has probable cause to believe that the individual to be arrested has committed, or is committing, the crime;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abba8f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer and pay a reward for services or information, or purchase evidence, assisting in the detection or investigation of the commission of an offense committed in Indian country or in the arrest of an offender against the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abba90-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make inquiries of any person, and administer to, or take from, any person an oath, affirmation, or affidavit, concerning any matter relevant to the enforcement or carrying out in Indian country of a law of either the United States or an Indian tribe that has authorized the employee to enforce or carry out tribal laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abba91-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wear a prescribed uniform and badge or carry prescribed credentials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abba92-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform any other law enforcement related duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abba93-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2803/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when requested, assist (with or without reimbursement) any Federal, tribal, State, or local law enforcement agency in the enforcement or carrying out of the laws or regulations the agency enforces or administers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62abba94-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/379/s4"},"text":"Pub. L. 101–379, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/475"},"text":"104 Stat. 475","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tIX/s908/b"},"text":"Pub. L. 109–162, title IX, § 908(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3083"},"text":"119 Stat. 3083","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s211/c"},"text":"Pub. L. 111–211, title II, § 211(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2266"},"text":"124 Stat. 2266","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62abba95-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62abba96-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62abba97-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Controlled Substances Act, referred to in par. (3)(D)(i)(I)(aa), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1242"},"text":"84 Stat. 1242","children":[],"tail":", which is classified principally to subchapter I (§ 801 et seq.) of chapter 13 of Title 21, Food and Drugs. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Personal Responsibility and Work Opportunity Reconciliation Act of 1996, referred to in par. (3)(D)(i)(I)(bb), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2105"},"text":"110 Stat. 2105","children":[],"tail":". Title IX of the Act enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s862b"},"text":"section 862b of Title 21","children":[],"tail":", Food and Drugs, "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12392"},"text":"section 12392 of Title 34","children":[],"tail":", Crime Control and Law Enforcement, and sections 608a and 710 of Title 42, The Public Health and Welfare, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693b"},"text":"section 1693b of Title 15","children":[],"tail":", Commerce and Trade, "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s32"},"text":"section 32 of Title 26","children":[],"tail":", Internal Revenue Code, and sections 1396a, 1396g, 1397a, 1397b, 1437d, 1437f, and 1437z of Title 42, and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s32"},"text":"section 32 of Title 26","children":[],"tail":" and sections 601, 710, and 1396a of Title 42. For complete classification of this Act to the Code, see Short Title of 1996 Amendments note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62abba98-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s211/c/1"},"text":"Pub. L. 111–211, § 211(c)(1)","children":[],"tail":", substituted “or offenses processed by the Central Violations Bureau); or” for “), or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s211/c/2/B"},"text":"Pub. L. 111–211, § 211(c)(2)(B)","children":[],"tail":", substituted “probable cause” for “reasonable grounds”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s211/c/2/A"},"text":"Pub. L. 111–211, § 211(c)(2)(A)","children":[],"tail":", (C), (D), added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Par. (3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" added subpar. (C)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
