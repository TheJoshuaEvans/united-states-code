{"tag":"section","attrib":{"id":"id629fd3f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2453"},"text":null,"children":[{"tag":"num","attrib":{"value":"2453"},"text":"§ 2453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Juvenile detention centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id629fd3f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2453/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629fd3f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2453/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall construct or renovate and staff new or existing juvenile detention centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629fd3f3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2453/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction and operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the construction and operation of the centers is consistent with the Juvenile Justice and Delinquency Prevention Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11101"},"text":"34 U.S.C. 11101","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629fd3f4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2453/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id629fd3f5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2453/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", the Secretary and the Attorney General, in consultation with tribal leaders and tribal justice officials, shall develop a long-term plan for the construction, renovation, and operation of Indian juvenile detention and treatment centers and alternatives to detention for juvenile offenders."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629fd3f6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2453/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan under subparagraph (A) shall require the Bureau of Indian Education and the Indian Health Service to coordinate with tribal and Bureau of Indian Affairs juvenile detention centers to provide services to those centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629fd3f7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2453/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629fd3f8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2453/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of constructing or renovating juvenile detention centers as provided in subsection (a), there are authorized to be appropriated $10,000,000 for each of fiscal years 2011 through 2015.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629fd3f9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2453/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of staffing and operating juvenile detention centers, there are authorized to be appropriated $7,000,000 for each of fiscal years 2011 through 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629fd3fa-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4220"},"text":"Pub. L. 99–570, title IV, § 4220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-147"},"text":"100 Stat. 3207–147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2211"},"text":"Pub. L. 100–690, title II, § 2211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4219"},"text":"102 Stat. 4219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s703/10"},"text":"Pub. L. 102–573, title VII, § 703(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4584"},"text":"106 Stat. 4584","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s241/g"},"text":"Pub. L. 111–211, title II, § 241(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2291"},"text":"124 Stat. 2291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id629fd3fb-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id629fd3fc-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id629fd3fd-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Juvenile Justice and Delinquency Prevention Act of 1974, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415"},"text":"Pub. L. 93–415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1109"},"text":"88 Stat. 1109","children":[],"tail":", which is classified principally to chapter 111 (§ 11101 et seq.) of Title 34, Crime Control and Law Enforcement. For complete classification of this Act to the Code, see Short Title of 1974 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of Title 34","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id629fd3fe-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/g/1"},"text":"Pub. L. 111–211, § 241(g)(1)","children":[],"tail":", designated first sentence as par. (1) and second sentence as par. (2), inserted headings, and added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/g/2/A"},"text":"Pub. L. 111–211, § 241(g)(2)(A)","children":[],"tail":", substituted “for each of fiscal years 2011 through 2015” for “for fiscal year 1993 and such sums as may be necessary for each of the fiscal years 1994, 1995, 1996, 1997, 1998, 1999, and 2000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s241/g/2"},"text":"Pub. L. 111–211, § 241(g)(2)","children":[],"tail":", substituted “for each of fiscal years 2011 through 2015” for “for fiscal year 1993 and such sums as may be necessary for each of the fiscal years 1994, 1995, 1996, 1997, 1998, 1999, and 2000” and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573"},"text":"Pub. L. 102–573","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) For the purpose of constructing or renovating juvenile detention centers as provided in subsection (a), there is authorized to be appropriated $10,000,000 for the fiscal year 1989 and $5,000,000 for each of the fiscal years 1990 and 1991.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) For the purpose of staffing and operating juvenile detention centers, there is authorized to be appropriated $5,000,000 for each of the fiscal years 1989 and 1990. An amount equal to the amount of funds appropriated pursuant to this paragraph for fiscal year 1990 shall be included in the base budget of the Bureau of Indian Affairs and funding thereafter shall be pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “For the purpose of subsection (a), there is authorized to be appropriated $10,000,000 for construction and renovation for each of the fiscal years 1987, 1988, and 1989, and $5,000,000 for staffing and operation for each of the fiscal years 1987, 1988, and 1989.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
