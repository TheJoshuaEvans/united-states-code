{"tag":"section","attrib":{"id":"id6255d1d3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1481"},"text":null,"children":[{"tag":"num","attrib":{"value":"1481"},"text":"§ 1481.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan guaranties and insurance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6255d1d4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1481/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to provide access to private money sources which otherwise would not be available, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6255d1d5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1481/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guarantee not to exceed 90 per centum of the unpaid principal and interest due on any loan made to any organization of Indians having a form or organization satisfactory to the Secretary, and to individual Indians; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6255d1d6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1481/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insure loans under an agreement approved by the Secretary whereby the lender will be reimbursed for losses in an amount not to exceed 15 per centum of the aggregate of such loans made by it, but not to exceed 90 per centum of the loss on any one loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d1d7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1481/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible borrowers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may guarantee or insure loans under subsection (a) to both for-profit and nonprofit borrowers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6255d1d8-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/tII/s201"},"text":"Pub. L. 93–262, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/79"},"text":"88 Stat. 79","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/449/s4"},"text":"Pub. L. 98–449, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-04"},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1725"},"text":"98 Stat. 1725","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/221/tIV/s401/a"},"text":"Pub. L. 109–221, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-05-12"},"text":"May 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/341"},"text":"120 Stat. 341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6255d1d9-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6255d1da-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6255d1db-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221/s401/a/1"},"text":"Pub. L. 109–221, § 401(a)(1)","children":[],"tail":", (2), (4), inserted section catchline, designated existing provisions as subsec. (a) and inserted heading, substituted “the Secretary may—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) guarantee”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"for “Secretary is authorized (a) to guarantee”, and added subsec. (b).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221/s401/a/3"},"text":"Pub. L. 109–221, § 401(a)(3)","children":[],"tail":", which directed substitution of “members; or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) insure”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"for “members; and (b) in lieu of such guaranty, to insure”, was executed by making the substitution for “and (b) in lieu of such guaranty, to insure” to reflect the probable intent of Congress and the amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/449"},"text":"Pub. L. 98–449","children":[],"tail":". See 1984 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/449"},"text":"Pub. L. 98–449","children":[],"tail":" struck out “who are not members of or eligible for membership in an organization which is making loans to its members” before “; and (b)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
