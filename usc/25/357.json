{"tag":"section","attrib":{"id":"id62321d81-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s357"},"text":null,"children":[{"tag":"num","attrib":{"value":"357"},"text":"§ 357.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condemnation of lands under laws of States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Lands allotted in severalty to Indians may be condemned for any public purpose under the laws of the State or Territory where located in the same manner as land owned in fee may be condemned, and the money awarded as damages shall be paid to the allottee.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62321d82-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch832/s3"},"text":"Mar. 3, 1901, ch. 832, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/1084"},"text":"31 Stat. 1084","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62321d83-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62321d84-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62321d85-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of the second paragraph of section 3 of act ","children":[{"tag":"date","attrib":{"date":"1901-03-03"},"text":"Mar. 3, 1901","children":[],"tail":". The first paragraph of such section 3 is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s319"},"text":"section 319 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
