{"tag":"section","attrib":{"id":"id62d1e063-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4211"},"text":null,"children":[{"tag":"num","attrib":{"value":"4211"},"text":"§ 4211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 50-year leasehold interest in trust or restricted lands for housing purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d1e064-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4211/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to lease","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, any trust or restricted Indian lands, whether tribally or individually owned, may be leased by the Indian owners, subject to the approval of the affected Indian tribe and the Secretary of the Interior, for housing development and residential purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e065-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4211/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each lease pursuant to subsection (a) shall be for a term not exceeding 50 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e066-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4211/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section may not be construed to repeal, limit, or affect any authority to lease any trust or restricted Indian lands that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d1e067-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4211/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is conferred by or pursuant to any other provision of law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d1e068-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4211/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for leases for any period exceeding 50 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d1e069-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4211/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Self-implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section is intended to be self-implementing and shall not require the issuance of any rule, regulation, or order to take effect as provided in section 705.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d1e06a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVII/s702"},"text":"Pub. L. 104–330, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4050"},"text":"110 Stat. 4050","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d1e06b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d1e06c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62d1e06d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 705, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/s705"},"text":"section 705 of Pub. L. 104–330","children":[],"tail":", which is set out as an Effective Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62d1e06e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id62d1e06f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVII/s705"},"text":"Pub. L. 104–330, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4052"},"text":"110 Stat. 4052","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/330/tVII/s705"},"text":"“This title [enacting this subchapter and amending sections 1715z–13a and 1721 of Title 12, Banks and Banking, and sections 11902 to 11905 of Title 42, The Public Health and Welfare] and the amendments made by this title (but not including the amendments made by section 704 [amending sections 11902 to 11905 of Title 42]) shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
