{"tag":"section","attrib":{"id":"id6209864a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"§ 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commissioner of Indian Affairs shall, under the direction of the Secretary of the Interior, and agreeably to such regulations as the President may prescribe, have the management of all Indian affairs and of all matters arising out of Indian relations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6209864b-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 463.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6209864c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6209864d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6209864e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 463 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1832-07-09/ch174/s1"},"text":"July 9, 1832, ch. 174, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/564"},"text":"4 Stat. 564","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1868-07-27/ch259/s1"},"text":"July 27, 1868, ch. 259, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/15/228"},"text":"15 Stat. 228","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6209864f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id62098650-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"All supervisory and appellate powers and duties in regard to Indian affairs theretofore vested in Secretary of the Treasury were thereafter to be exercised and performed by Secretary of the Interior under provisions of section 1 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1868-07-27/ch259"},"text":"act July 27, 1868, ch. 259","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/15/228"},"text":"15 Stat. 228","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Appointment by President of a Commissioner of Indian Affairs to act under direction of Secretary of War was provided for by section 1 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1832-07-09/ch174"},"text":"act July 9, 1832, ch. 174","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/564"},"text":"4 Stat. 564","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id62098651-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id62098652-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
