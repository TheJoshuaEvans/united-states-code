{"tag":"section","attrib":{"id":"id62f34b39-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412"},"text":null,"children":[{"tag":"num","attrib":{"value":"5412"},"text":"§ 5412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Law Enforcement Foundation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f34b3a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34b3b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", the Secretary shall establish, under the laws of the District of Columbia and in accordance with this subchapter, a foundation, to be known as the “Indian Law Enforcement Foundation”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b3c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding determinations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No funds, gift, property, or other item of value (including any interest accrued on such an item) acquired by the Foundation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f34b3d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be taken into consideration for purposes of determining Federal appropriations relating to the provision of public safety or justice services to Indians; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f34b3e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise limit, diminish, or affect the Federal responsibility for the provision of public safety or justice services to Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b3f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nature of corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34b40-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be a charitable and nonprofit federally chartered corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b41-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be an agency or instrumentality of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b42-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Place of incorporation and domicile","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall be incorporated and domiciled in the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b43-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34b44-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage, accept, and administer, in accordance with the terms of each donation, private gifts of real and personal property, and any income from or interest in such gifts, for the benefit of, or in support of, public safety and justice services in American Indian and Alaska Native communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b45-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Office of Justice Services of the Bureau of Indian Affairs and Indian tribal governments in funding and conducting activities and providing education to advance and support the provision of public safety and justice services in American Indian and Alaska Native communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b46-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee for the Establishment of the Indian Law Enforcement Foundation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34b47-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a committee, to be known as the “Committee for the Establishment of the Indian Law Enforcement Foundation”, to assist the Secretary in establishing the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b48-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", the Committee shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f34b49-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such activities as are necessary to incorporate the Foundation under the laws of the District of Columbia, including acting as incorporators of the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f34b4a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the Foundation qualifies for and maintains the status required to carry out this section, until the date on which the Board is established;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f34b4b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the constitution and initial bylaws of the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f34b4c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the initial operation of the Foundation, including providing for temporary or interim quarters, equipment, and staff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f34b4d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint the initial members of the Board in accordance with the constitution and initial bylaws of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b4e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Directors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34b4f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Directors shall be the governing body of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b50-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may exercise, or provide for the exercise of, the powers of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b51-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f34b52-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the number of members of the Board, the manner of selection of the members (including the filling of vacancies), and the terms of office of the members shall be as provided in the constitution and bylaws of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f34b53-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62f34b54-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/f/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall be composed of not less than 7 members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62f34b55-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/f/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial voting members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The initial voting members of the Board—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62f34b56-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/f/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be appointed by the Committee not later than 180 days after the date on which the Foundation is established; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62f34b57-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/f/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall serve for staggered terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62f34b58-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/f/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Board shall be United States citizens with knowledge or experience regarding public safety and justice in Indian and Alaska Native communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f34b59-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board shall not receive compensation for service as a member, but shall be reimbursed for actual and necessary travel and subsistence expenses incurred in the performance of the duties of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b5a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34b5b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The officers of the Foundation shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f34b5c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Secretary, elected from among the members of the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f34b5d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other officers provided for in the constitution and bylaws of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b5e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief operating officer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f34b5f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the Secretary of the Foundation may serve, at the direction of the Board, as the chief operating officer of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f34b60-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may appoint a chief operating officer in lieu of the Secretary of the Foundation under subparagraph (A), who shall serve at the direction of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b61-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The manner of election, term of office, and duties of the officers of the Foundation shall be as provided in the constitution and bylaws of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b62-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34b63-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall adopt a constitution and bylaws for the management of the property of the Foundation and the regulation of the affairs of the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b64-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may adopt and alter a corporate seal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b65-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b66-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may acquire (through gift or otherwise), own, lease, encumber, and transfer real or personal property as necessary or convenient to carry out the purposes of the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b67-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may sue and be sued; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b68-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may perform any other act necessary and proper to carry out the purposes of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b69-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal office","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34b6a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The principal office of the Foundation shall be located in the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b6b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities; offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The activities of the Foundation may be conducted, and offices may be maintained, throughout the United States in accordance with the constitution and bylaws of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b6c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall comply with the law on service of process of each State in which the Foundation is incorporated and of each State in which the Foundation carries on activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b6d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of officers, employees, and agents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34b6e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall be liable for the acts of the officers, employees, and agents of the Foundation acting within the scope of the authority of the officers, employees, and agents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b6f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board shall be personally liable only for gross negligence in the performance of the duties of the member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b70-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f34b71-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on spending","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning with the fiscal year following the first full fiscal year during which the Foundation is in operation, the administrative costs of the Foundation shall not exceed the percentage described in paragraph (2) of the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f34b72-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/l/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts transferred to the Foundation under subsection (n) during the preceding fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f34b73-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/l/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donations received from private sources during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b74-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Percentages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The percentages referred to in paragraph (1) are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f34b75-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/l/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the first 2 fiscal years described in that paragraph, 25 percent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f34b76-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/l/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the following fiscal year, 20 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f34b77-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/l/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each fiscal year thereafter, 15 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b78-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and hiring","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appointment of officers and employees of the Foundation shall be subject to the availability of funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f34b79-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/l/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board or officer, employee, or agent of the Foundation shall not by reason of association with the Foundation be considered to be an officer, employee, or agent of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b7a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall comply with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s10101"},"text":"section 10101 of title 36","children":[],"tail":" as if the Foundation were a corporation under part B of subtitle II of that title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f34b7b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5412/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of fiscal years 2011 through 2015, out of any unobligated amounts available to the Secretary, the Secretary may use to carry out this section not more than $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f34b7c-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tVII/s702"},"text":"Pub. L. 93–638, title VII, § 702","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s231/c"},"text":"Pub. L. 111–211, title II, § 231(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2274"},"text":"124 Stat. 2274","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62f34b7d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62f34b7e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62f34b7f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s458ccc–1"},"text":"section 458ccc–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
