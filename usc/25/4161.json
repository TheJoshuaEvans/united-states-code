{"tag":"section","attrib":{"id":"id62cf6f5b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161"},"text":null,"children":[{"tag":"num","attrib":{"value":"4161"},"text":"§ 4161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies for noncompliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62cf6f5c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by Secretary affecting grant amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cf6f5d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), if the Secretary finds after reasonable notice and opportunity for hearing that a recipient of assistance under this chapter has failed to comply substantially with any provision of this chapter, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cf6f5e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate payments under this chapter to the recipient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cf6f5f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce payments under this chapter to the recipient by an amount equal to the amount of such payments that were not expended in accordance with this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cf6f60-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the availability of payments under this chapter to programs, projects, or activities not affected by such failure to comply; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cf6f61-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of noncompliance described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4162/b"},"text":"section 4162(b) of this title","children":[],"tail":", provide a replacement tribally designated housing entity for the recipient, under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4162"},"text":"section 4162 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6f62-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial noncompliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The failure of a recipient to comply with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4152/b/1"},"text":"section 4152(b)(1) of this title","children":[],"tail":" regarding the reporting of low-income dwelling units shall not, in itself, be considered to be substantial noncompliance for purposes of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6f63-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuance of actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary takes an action under subparagraph (A), (B), or (C) of paragraph (1), the Secretary shall continue such action until the Secretary determines that the failure to comply has ceased.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6f64-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain actions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cf6f65-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subsection, if the Secretary makes a determination that the failure of a recipient of assistance under this chapter to comply substantially with any material provision (as that term is defined by the Secretary) of this chapter is resulting, and would continue to result, in a continuing expenditure of Federal funds in a manner that is not authorized by law, the Secretary may take an action described in paragraph (1)(C) before conducting a hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cf6f66-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedural requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary takes an action described in subparagraph (A), the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62cf6f67-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide notice to the recipient at the time that the Secretary takes that action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cf6f68-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a hearing not later than 60 days after the date on which the Secretary provides notice under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cf6f69-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon completion of a hearing under this paragraph, the Secretary shall make a determination regarding whether to continue taking the action that is the subject of the hearing, or take another action under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cf6f6a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance because of technical incapacity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cf6f6b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary makes a finding under subsection (a), but determines that the failure to comply substantially with the provisions of this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cf6f6c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a pattern or practice of activities constituting willful noncompliance, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cf6f6d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a result of the limited capability or capacity of the recipient,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary may provide technical assistance for the recipient (directly or indirectly) that is designed to increase the capability and capacity of the recipient to administer assistance provided under this chapter in compliance with the requirements under this chapter, if the recipient enters into a performance agreement with the Secretary that specifies the compliance objectives that the recipient will be required to achieve by the termination date of the performance agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6f6e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The period of a performance agreement described in paragraph (1) shall be for 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6f6f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the termination of a performance agreement entered into under paragraph (1), the Secretary shall review the performance of the recipient that is a party to the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6f70-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, on the basis of a review under paragraph (3), the Secretary determines that the recipient—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cf6f71-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has made a good faith effort to meet the compliance objectives specified in the agreement, the Secretary may enter into an additional performance agreement for the period specified in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cf6f72-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has failed to make a good faith effort to meet applicable compliance objectives, the Secretary shall determine the recipient to have failed to comply substantially with this chapter, and the recipient shall be subject to an action under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cf6f73-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral for civil action","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cf6f74-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In lieu of, or in addition to, any action authorized by subsection (a), if the Secretary has reason to believe that a recipient has failed to comply substantially with any provision of this chapter, the Secretary may refer the matter to the Attorney General of the United States with a recommendation that an appropriate civil action be instituted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6f75-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon such a referral, the Attorney General may bring a civil action in any United States district court having venue thereof for such relief as may be appropriate, including an action to recover the amount of the assistance furnished under this chapter that was not expended in accordance with it, or for mandatory or injunctive relief.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cf6f76-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cf6f77-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any recipient who receives notice under subsection (a) of the termination, reduction, or limitation of payments under this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cf6f78-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, not later than 60 days after receiving such notice, file with the United States Court of Appeals for the circuit in which such State is located, or in the United States Court of Appeals for the District of Columbia, a petition for review of the action of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cf6f79-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon the filing of any petition under subparagraph (A), shall forthwith transmit copies of the petition to the Secretary and the Attorney General of the United States, who shall represent the Secretary in the litigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6f7a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall file in the court a record of the proceeding on which the Secretary based the action, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2112"},"text":"section 2112 of title 28","children":[],"tail":". No objection to the action of the Secretary shall be considered by the court unless such objection has been urged before the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6f7b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cf6f7c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court shall have jurisdiction to affirm or modify the action of the Secretary or to set it aside in whole or in part. The findings of fact by the Secretary, if supported by substantial evidence on the record considered as a whole, shall be conclusive. The court may order additional evidence to be taken by the Secretary, and to be made part of the record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cf6f7d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62cf6f7e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may modify the findings of fact of the Secretary, or make new findings, by reason of the new evidence so taken and filed with the court; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cf6f7f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall file—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62cf6f80-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/d/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such modified or new findings, which findings with respect to questions of fact shall be conclusive if supported by substantial evidence on the record considered as a whole; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62cf6f81-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/d/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recommendation of the Secretary, if any, for the modification or setting aside of the original action of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6f82-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4161/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the filing of the record with the court, the jurisdiction of the court shall be exclusive and its judgment shall be final, except that such judgment shall be subject to review by the Supreme Court of the United States upon writ of certiorari or certification as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1254"},"text":"section 1254 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62cf6f83-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tIV/s401"},"text":"Pub. L. 104–330, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4037"},"text":"110 Stat. 4037","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tX/s1003/h"},"text":"Pub. L. 106–568, title X, § 1003(h)","children":[],"tail":", (i), "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2928"},"text":"114 Stat. 2928","children":[],"tail":", 2929; "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s503/g"},"text":"Pub. L. 106–569, title V, § 503(g)","children":[],"tail":", (h), "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2964"},"text":"114 Stat. 2964","children":[],"tail":", 2965; "},{"tag":"ref","attrib":{"href":"/us/pl/110/411/tIV/s401"},"text":"Pub. L. 110–411, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4330"},"text":"122 Stat. 4330","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62cf6f84-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62cf6f85-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62cf6f86-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", known as the Native American Housing Assistance and Self-Determination Act of 1996. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62cf6f87-4962-11f1-add1-b56d3fa293fa"},"text":null,"child