{"tag":"section","attrib":{"id":"id62d42aa8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4233"},"text":null,"children":[{"tag":"num","attrib":{"value":"4233"},"text":"§ 4233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease requirements and tenant selection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d42aa9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4233/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except to the extent otherwise provided by or inconsistent with the laws of the State of Hawaii, in renting dwelling units in affordable housing assisted with grant amounts provided under this subchapter, the Director, owner, or manager shall use leases that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42aaa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4233/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not contain unreasonable terms and conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42aab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4233/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the Director, owner, or manager to maintain the housing in compliance with applicable housing codes and quality standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42aac-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4233/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the Director, owner, or manager to give adequate written notice of termination of the lease, which shall be the period of time required under applicable State or local law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42aad-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4233/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify that, with respect to any notice of eviction or termination, notwithstanding any State or local law, a resident shall be informed of the opportunity, before any hearing or trial, to examine any relevant documents, record, or regulations directly related to the eviction or termination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42aae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4233/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that the Director, owner, or manager may not terminate the tenancy, during the term of the lease, except for serious or repeated violation of the terms and conditions of the lease, violation of applicable Federal, State, or local law, or for other good cause; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42aaf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4233/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide that the Director, owner, or manager may terminate the tenancy of a resident for any activity, engaged in by the resident, any member of the household of the resident, or any guest or other person under the control of the resident, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42ab0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4233/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" threatens the health or safety of, or right to peaceful enjoyment of the premises by, other residents or employees of the Department, owner, or manager;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42ab1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4233/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" threatens the health or safety of, or right to peaceful enjoyment of their premises by, persons residing in the immediate vicinity of the premises; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42ab2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4233/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is criminal activity (including drug-related criminal activity) on or off the premises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42ab3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4233/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tenant or homebuyer selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition to receiving grant amounts under this subchapter, the Director shall adopt and use written tenant and homebuyer selection policies and criteria that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42ab4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4233/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the purpose of providing housing for low-income families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42ab5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4233/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are reasonably related to program eligibility and the ability of the applicant to perform the obligations of the lease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42ab6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4233/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42ab7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4233/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the selection of tenants and homebuyers from a written waiting list in accordance with the policies and goals set forth in an applicable housing plan approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42ab8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4233/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prompt notification in writing of any rejected applicant of the grounds for that rejection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d42ab9-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s814"},"text":"Pub. L. 104–330, title VIII, § 814","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s203"},"text":"Pub. L. 106–568, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2889"},"text":"114 Stat. 2889","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s513"},"text":"Pub. L. 106–569, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2983"},"text":"114 Stat. 2983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d42aba-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d42abb-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62d42abc-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s203"},"text":"Pub. L. 106–568, § 203","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":", enacted identical sections 814 of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":". This section is based on the text of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s814"},"text":"section 814 of Pub. L. 104–330","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
