{"tag":"section","attrib":{"id":"id62db5641-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5125"},"text":null,"children":[{"tag":"num","attrib":{"value":"5125"},"text":"§ 5125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance optional","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This Act shall not apply to any reservation wherein a majority of the adult Indians, voting at a special election duly called by the Secretary of the Interior, shall vote against its application. It shall be the duty of the Secretary of the Interior, within one year after ","children":[{"tag":"date","attrib":{"date":"1934-06-18"},"text":"June 18, 1934","children":[],"tail":", to call such an election, which election shall be held by secret ballot upon thirty days’ notice."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62db5642-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch576/s18"},"text":"June 18, 1934, ch. 576, § 18","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/988"},"text":"48 Stat. 988","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62db5643-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62db5644-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62db5645-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch576"},"text":"act June 18, 1934, ch. 576","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/984"},"text":"48 Stat. 984","children":[],"tail":", popularly known as the Indian Reorganization Act, which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5101"},"text":"section 5101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62db5646-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s478"},"text":"section 478 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62db5647-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62db5648-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Extensions of Time","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The time for holding an election under this section was extended to ","children":[{"tag":"date","attrib":{"date":"1936-06-18"},"text":"June 18, 1936","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/act/1935-06-15/ch260/s2"},"text":"act June 15, 1935, ch. 260, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/378"},"text":"49 Stat. 378","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1935-06-15/ch260/s3"},"text":"Act June 15, 1935, ch. 260, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/378"},"text":"49 Stat. 378","children":[],"tail":", provided that the periods of trust or the restrictions on alienation of Indian lands should be extended to "},{"tag":"date","attrib":{"date":"1936-12-31"},"text":"Dec. 31, 1936","children":[],"tail":", in case of a vote against the application of sections 5101 to 5103, 5107 to 5113, 5115, 5116, 5118, 5120, 5121, 5123 to 5125, and 5129 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
