{"tag":"section","attrib":{"id":"id62215497-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s290"},"text":null,"children":[{"tag":"num","attrib":{"value":"290"},"text":"§ 290.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of pupils under 14 at Government expense","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No Indian pupil under the age of fourteen years shall be transported at Government expense to any Indian school beyond the limits of the State or Territory in which the parents of such child reside or of the adjoining State or Territory.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62215498-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-03/ch263"},"text":"Mar. 3, 1909, ch. 263","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/783"},"text":"35 Stat. 783","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
