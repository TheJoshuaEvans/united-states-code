{"tag":"section","attrib":{"id":"id62773cef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1680d"},"text":"§ 1680d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Infant and maternal mortality; fetal alcohol syndrome","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"By no later than ","children":[{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":", the Secretary shall develop and begin implementation of a plan to achieve the following objectives by "},{"tag":"date","attrib":{"date":"1994-01-01"},"text":"January 1, 1994","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62773cf0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reduction of the rate of Indian infant mortality in each area office of the Service to the lower of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62773cf1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" twelve deaths per one thousand live births, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62773cf2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of infant mortality applicable to the United States population as a whole;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62773cf3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reduction of the rate of maternal mortality in each area office of the Service to the lower of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62773cf4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" five deaths per one hundred thousand live births, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62773cf5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of maternal mortality applicable to the United States population as a whole; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62773cf6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduction of the rate of fetal alcohol syndrome among Indians served by, or on behalf of, the Service to one per one thousand live births.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62773cf7-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s814"},"text":"Pub. L. 94–437, title VIII, § 814","children":[],"tail":", formerly title VII, § 714, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tVII/s708"},"text":"Pub. L. 100–713, title VII, § 708","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4831"},"text":"102 Stat. 4831","children":[],"tail":"; renumbered title VIII, §