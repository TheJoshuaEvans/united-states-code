{"tag":"section","attrib":{"id":"id629d6256-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2414"},"text":null,"children":[{"tag":"num","attrib":{"value":"2414"},"text":"§ 2414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional intent in construction of laws","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the intent of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629d6257-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2414/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific Federal laws, and administrative regulations promulgated thereunder, establishing programs of the Bureau of Indian Affairs, the Indian Health Service, and other Federal agencies, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d6258-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2414/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general Federal laws, including laws limiting augmentation of Federal appropriations or encouraging joint or cooperative funding,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be liberally construed and administered to achieve the purposes of this chapter.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629d6259-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4208"},"text":"Pub. L. 99–570, title IV, § 4208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-142"},"text":"100 Stat. 3207–142","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
