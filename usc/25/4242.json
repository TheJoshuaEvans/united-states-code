{"tag":"section","attrib":{"id":"id62d69a43-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4242"},"text":null,"children":[{"tag":"num","attrib":{"value":"4242"},"text":"§ 4242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d69a44-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4242/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the conclusion of each fiscal year in which assistance under this subchapter is made available, the Secretary shall submit to Congress a report that contains—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d69a45-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4242/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the progress made in accomplishing the objectives of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69a46-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4242/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the use of funds available under this subchapter during the preceding fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69a47-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4242/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the aggregate outstanding loan guarantees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715z–13b"},"text":"section 1715z–13b of title 12","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d69a48-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4242/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require the Director to submit to the Secretary such reports and other information as may be necessary in order for the Secretary to prepare the report required under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d69a49-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s823"},"text":"Pub. L. 104–330, title VIII, § 823","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s203"},"text":"Pub. L. 106–568, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2895"},"text":"114 Stat. 2895","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s513"},"text":"Pub. L. 106–569, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2989"},"text":"114 Stat. 2989","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d69a4a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d69a4b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes