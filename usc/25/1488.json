{"tag":"section","attrib":{"id":"id6255d20a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1488"},"text":null,"children":[{"tag":"num","attrib":{"value":"1488"},"text":"§ 1488.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lenders authorized to make loans; decrease or increase of liability under the guaranty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Loans guaranteed hereunder may be made by any lender satisfactory to the Secretary, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1486"},"text":"section 1486 of this title","children":[],"tail":". The liability under the guaranty shall decrease or increase pro rata with any decrease or increase in the unpaid portion of the obligation."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6255d20b-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/tII/s208"},"text":"Pub. L. 93–262, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/80"},"text":"88 Stat. 80","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
