{"tag":"section","attrib":{"id":"id626b5603-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1643"},"text":null,"children":[{"tag":"num","attrib":{"value":"1643"},"text":"§ 1643.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount and use of funds reimbursed through medicare and medicaid available to Indian Health Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to the President, for inclusion in the report required to be transmitted to the Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1671"},"text":"section 1671 of this title","children":[],"tail":", an accounting on the amount and use of funds made available to the Service pursuant to this subchapter as a result of reimbursements through titles XVIII and XIX of the Social Security Act, as amended ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq., 1396 et seq.]."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id626b5604-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tIV/s403"},"text":"Pub. L. 94–437, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1410"},"text":"90 Stat. 1410","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tIV/s402"},"text":"Pub. L. 102–573, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4566"},"text":"106 Stat. 4566","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id626b5605-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"edito