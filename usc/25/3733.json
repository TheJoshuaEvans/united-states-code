{"tag":"section","attrib":{"id":"id62c5f925-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3733"},"text":null,"children":[{"tag":"num","attrib":{"value":"3733"},"text":"§ 3733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreement between Department of the Interior and Indian tribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c5f926-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3733/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c5f927-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3733/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62c5f928-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3733/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To facilitate the administration of the programs and activities of the Department of the Interior, the Secretary may negotiate and enter into cooperative agreements with Indian tribes to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62c5f929-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3733/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in cooperative manpower and job training,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62c5f92a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3733/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and publish cooperative agricultural education and resource planning materials, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62c5f92b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3733/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform land and facility improvements and other activities related to land and natural resource management and development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c5f92c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3733/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may enter into these agreements when the Secretary determines the interest of Indians and Indian tribes will be benefited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c5f92d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3733/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In cooperative agreements entered into under paragraph (1), the Secretary may advance or reimburse funds to contractors from any appropriated funds available for similar kinds of work or by furnishing or sharing materials, supplies, facilities, or equipment without regard to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3324"},"text":"section 3324 of title 31","children":[],"tail":" relating to the advance of public moneys."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c5f92e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3733/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any agreement authorized by this section, Indian tribes and their employees may perform cooperative work under the supervision of the Department of the Interior in emergencies or otherwise as mutually agreed to, but shall not be deemed to be Federal employees other than for the purposes of sections 2671 through 2680 of title 28 and sections 8101 through 8193 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c5f92f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3733/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to limit the authority of the Secretary to enter into cooperative agreements otherwise authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c5f930-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/177/tII/s203"},"text":"Pub. L. 103–177, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2021"},"text":"107 Stat. 2021","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
