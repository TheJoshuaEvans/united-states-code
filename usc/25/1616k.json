{"tag":"section","attrib":{"id":"id625f6eab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1616k"},"text":"§ 1616k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nursing residency program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id625f6eac-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, shall establish a program to enable licensed practical nurses, licensed vocational nurses, and registered nurses who are working in an Indian health program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1616a/a/2/A"},"text":"section 1616a(a)(2)(A) of this title","children":[],"tail":"), and have done so for a period of not less than one year, to pursue advanced training."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625f6ead-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program components","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such program shall include a combination of education and work study in an Indian health program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1616a/a/2/A"},"text":"section 1616a(a)(2)(A) of this title","children":[],"tail":") leading to an associate or bachelor’s degree (in the case of a licensed practical nurse or licensed vocational nurse) or a bachelor’s degree (in the case of a registered nurse) or a Master’s degree."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625f6eae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service obligation of program participant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual who participates in a program under subsection (a), where the educational costs are paid by the Service, shall incur an obligation to serve in an Indian health program for a period of obligated service equal to at least three times the period of time during which the individual participates in such program. In the event that the individual fails to complete such obligated service, the United States shall be entitled to recover from such individual an amount determined in accordance with the formula specified in subsection (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1616a"},"text":"section 1616a of this title","children":[],"tail":" in the manner provided for in such subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id625f6eaf-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tI/s118"},"text":"Pub. L. 94–437, title I, § 118","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tI/s104/e"},"text":"Pub. L. 102–573, title I, § 104(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4534"},"text":"106 Stat. 4534","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/435/s16/b"},"text":"Pub. L. 103–435, § 16(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4573"},"text":"108 Stat. 4573","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id625f6eb0-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id625f6eb1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id625f6eb2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/435"},"text":"Pub. L. 103–435","children":[],"tail":" inserted before period at end “or a Master’s degree”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
