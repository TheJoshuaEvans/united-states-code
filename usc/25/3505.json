{"tag":"section","attrib":{"id":"id62c11735-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505"},"text":null,"children":[{"tag":"num","attrib":{"value":"3505"},"text":"§ 3505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal power marketing administrations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c11736-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c11737-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Administrator” means the Administrator of the Bonneville Power Administration and the Administrator of the Western Area Power Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11738-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “power marketing administration” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62c11739-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bonneville Power Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c1173a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Western Area Power Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c1173b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other power administration the power allocation of which is used by or for the benefit of an Indian tribe located in the service area of the administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c1173c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouragement of Indian tribal energy development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Administrator shall encourage Indian tribal energy development by taking such actions as the Administrators determine to be appropriate, including administration of programs of the power marketing administration, in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c1173d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by Administrators","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, in accordance with laws in existence on ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c1173e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each Administrator shall consider the unique relationship that exists between the United States and Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c1173f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" power allocations from the Western Area Power Administration to Indian tribes may be used to meet firming and reserve needs of Indian-owned energy projects on Indian land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11740-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Western Area Power Administration may purchase non-federally generated power from Indian tribes to meet the firming and reserve requirements of the Western Area Power Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11741-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each Administrator shall not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62c11742-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay more than the prevailing market price for an energy product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c11743-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain less than prevailing market terms and conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c11744-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for transmission system use","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c11745-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Administrator may provide technical assistance to Indian tribes seeking to use the high-voltage transmission system for delivery of electric power.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11746-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The costs of technical assistance provided under paragraph (1) shall be funded—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62c11747-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Secretary of Energy using nonreimbursable funds appropriated for that purpose; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c11748-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any appropriate Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c11749-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power allocation study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary of Energy shall submit to Congress a report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c1174a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the use by Indian tribes of Federal power allocations of the power marketing administration (or power sold by the Southwestern Power Administration) to or for the benefit of Indian tribes in a service area of the power marketing administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c1174b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62c1174c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of power allocated to, or used for the benefit of, Indian tribes by the Western Area Power Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c1174d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of power sold to Indian tribes by any other power marketing administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c1174e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" barriers that impede tribal access to and use of Federal power, including an assessment of opportunities to remove those barriers and improve the ability of power marketing administrations to deliver Federal power.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c1174f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3505/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $750,000, non-reimbursable, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c11750-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXVI/s2605"},"text":"Pub. L. 102–486, title XXVI, § 2605","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tV/s503/a"},"text":"Pub. L. 109–58, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/776"},"text":"119 Stat. 776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c11751-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62c11752-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62c11753-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3505, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXVI/s2605"},"text":"Pub. L. 102–486, title XXVI, § 2605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3115"},"text":"106 Stat. 3115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s10/e/1"},"text":"Pub. L. 103–437, § 10(e)(1)","children":[],"tail":", (2)(D), "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4589"},"text":"108 Stat. 4589","children":[],"tail":", related to Indian Energy Resource Commission, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
