{"tag":"section","attrib":{"id":"id62b53121-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3115b"},"text":"§ 3115b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal forest management demonstration project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b53122-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior and the Secretary may carry out demonstration projects by which federally recognized Indian Tribes or Tribal organizations may contract to perform administrative, management, and other functions of programs of the Tribal Forest Protection Act of 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3115a"},"text":"25 U.S.C. 3115a","children":[],"tail":" et seq.) through contracts entered into under the Indian Self-Determination and Education Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b53123-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any contract or project carried out under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b53124-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on National Forest System land, the Secretary shall carry out all functions delegated to the Secretary of the Interior under the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53125-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary or the Secretary of the Interior, as applicable, shall make any decisions required to be made under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b53126-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b53127-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Tribal Forest Protection Act of 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3115a"},"text":"25 U.S.C. 3115a","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53128-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3115b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contract or project shall be entered into under, and in accordance with, section 403(b)(2) of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5363/b/2"},"text":"25 U.S.C. 5363(b)(2)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b53129-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8703"},"text":"Pub. L. 115–334, title VIII, § 8703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4877"},"text":"132 Stat. 4877","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62b5312a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62b5312b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62b5312c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Tribal Forest Protection Act of 2004, referred to in subsecs. (a) and (b)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/278"},"text":"Pub. L. 108–278","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-22"},"text":"July 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/868"},"text":"118 Stat. 868","children":[],"tail":". For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/278/s1"},"text":"section 1 of Pub. L. 108–278","children":[],"tail":", set out as a Short Title of 2004 Amendment note under "