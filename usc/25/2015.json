{"tag":"section","attrib":{"id":"id628f0ade-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2015"},"text":null,"children":[{"tag":"num","attrib":{"value":"2015"},"text":"§ 2015.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report; audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id628f0adf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2015/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to each appropriate committee of Congress, all Bureau-funded schools, and the tribal governing bodies of such schools, a detailed annual report on the state of education within the Bureau, and any problems encountered in Indian education during the period covered by the report, that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628f0ae0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2015/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suggestions for the improvement of the Bureau educational system and for increasing tribal or local Indian control of such system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628f0ae1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2015/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the status of tribally controlled community colleges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0ae2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2015/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annual budget request for the education programs of the Bureau, as submitted as part of the President’s next annual budget request under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" shall include the plans required by sections 2001(c), 2002(c), and 2004(c) "},{"tag":"ref","attrib":{"idref":"fn002130"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002130"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “2005(c)”."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0ae3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2015/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial and compliance audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Department of the Interior shall establish a system to ensure that financial and compliance audits, based upon the extent to which a school described in subsection (a) has complied with the local financial plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2010"},"text":"section 2010 of this title","children":[],"tail":", are conducted of each Bureau-operated school at least once every 3 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0ae4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2015/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative evaluation of schools","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall, at least once every 3 to 5 years, conduct a comprehensive evaluation of Bureau-operated schools. Such evaluation shall be in addition to any other program review or evaluation that may be required under Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id628f0ae5-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1135"},"text":"Pub. L. 95–561, title XI, § 1135","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1042"},"text":"Pub. L. 107–110, title X, § 1042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2056"},"text":"115 Stat. 2056","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id628f0ae6-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id628f0ae7-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id628f0ae8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2015, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1135"},"text":"Pub. L. 95–561, title XI, § 1135","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s381"},"text":"Pub. L. 103–382, title III, § 381","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4010"},"text":"108 Stat. 4010","children":[],"tail":", related to uniform education procedures and practices, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2015, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1135"},"text":"Pub. L. 95–561, title XI, § 1135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2327"},"text":"92 Stat. 2327","children":[],"tail":", related to recruitment policy for Indian educators and promotion plan for Bureau employees, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id628f0ae9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id628f0aea-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20",