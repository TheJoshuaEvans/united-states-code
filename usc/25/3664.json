{"tag":"section","attrib":{"id":"id62c38838-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3664"},"text":null,"children":[{"tag":"num","attrib":{"value":"3664"},"text":"§ 3664.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No offset","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No Federal agency shall offset funds made available pursuant to this chapter for Indian tribal court membership organizations or Indian legal services organizations against other funds otherwise available for use in connection with technical or legal assistance to tribal justice systems or members of Indian tribes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62c38839-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/559/tI/s104"},"text":"Pub. L. 106–559, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2781"},"text":"114 Stat. 2781","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
