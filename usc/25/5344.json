{"tag":"section","attrib":{"id":"id62e9ad68-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5344"},"text":null,"children":[{"tag":"num","attrib":{"value":"5344"},"text":"§ 5344.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations; minimum standards of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to perform any and all acts and to make such rules and regulations, including minimum standards of service, as may be necessary and proper for the purpose of carrying the provisions of sections 5342 to 5348 of this title into effect: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That such minimum standards of service are not less than the highest maintained by the States or Territories within which said contract or contracts, as herein provided, are to be effective."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62e9ad69-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-04-16/ch147/s3"},"text":"Apr. 16, 1934, ch. 147, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/596"},"text":"48 Stat. 596","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-04/ch490/s3"},"text":"June 4, 1936, ch. 490, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1459"},"text":"49 Stat. 1459","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62e9ad6a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62e9ad6b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62e9ad6c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s454"},"text":"section 454 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62e9ad6d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1936—Act ","children":[{"tag":"date","attrib":{"date":"1936-06-04"},"text":"June 4, 1936","children":[],"tail":", substituted “within which” for “with which”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
