{"tag":"section","attrib":{"id":"id62d69a4d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4243"},"text":null,"children":[{"tag":"num","attrib":{"value":"4243"},"text":"§ 4243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Department of Housing and Urban Development for grants under this subchapter such sums as may be necessary for each of fiscal years 2001, 2002, 2003, 2004, and 2005.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62d69a4e-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s824"},"text":"Pub. L. 104–330, title VIII, § 824","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s203"},"text":"Pub. L. 106–568, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2895"},"text":"114 Stat. 2895","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s513"},"text":"Pub. L. 106–569, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2989"},"text":"114 Stat. 2989","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d69a4f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d69a50-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62d69a51-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s203"},"text":"Pub. L. 106–568, § 203","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":", enacted substantially identical sections 824 of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":". This section is based on the text of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s824"},"text":"section 824 of Pub. L. 104–330","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s824"},"text":"Section 824 of Pub. L. 104–330","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/s203"},"text":"Pub. L. 106–568, § 203","children":[],"tail":", authorized appropriations for fiscal years 2000 to 2004, instead of fiscal years 2001 to 2005."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
