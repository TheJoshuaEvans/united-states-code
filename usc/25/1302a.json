{"tag":"section","attrib":{"id":"id624ea740-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1302a"},"text":"§ 1302a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau of Prisons tribal prisoner program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id624ea741-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"March 15, 2022","children":[],"tail":", the Director of the Bureau of Prisons shall establish a program under which the Bureau of Prisons shall accept offenders convicted in tribal court pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1302"},"text":"section 1302 of this title","children":[],"tail":" (as amended by this section), subject to the conditions described in paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea742-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id624ea743-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of participation in the program described in paragraph (1), the tribal court shall submit to the Attorney General a request for confinement of the offender, for approval by the Attorney General (or a designee) by not later than 30 days after the date of submission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id624ea744-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Requests for confinement shall be limited to offenders convicted of a violent crime (comparable to the violent crimes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1153/a"},"text":"section 1153(a) of title 18","children":[],"tail":") for which the sentence includes a term of imprisonment of 1 or more years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id624ea745-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Custody conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The imprisonment by the Bureau of Prisons shall be subject to the conditions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s5003"},"text":"section 5003 of title 18","children":[],"tail":", regarding the custody of State offenders, except that the offender shall be placed in the nearest available and appropriate Federal facility, and imprisoned at the expense of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id624ea746-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cap","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau of Prisons shall confine not more than 100 tribal offenders at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea747-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rescinding requests","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id624ea748-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The applicable tribal government shall retain the authority to rescind the request for confinement of a tribal offender by the Bureau of Prisons under this paragraph at any time during the sentence of the offender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id624ea749-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return to tribal custody","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On rescission of a request under subparagraph (A), a tribal offender shall be returned to tribal custody.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea74a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reassessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If tribal court demand for participation in this program exceeds 100 tribal offenders, a representative of the Bureau of Prisons shall notify Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id624ea74b-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s234/c"},"text":"Pub. L. 111–211, title II, § 234(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2281"},"text":"124 Stat. 2281","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tVIII/s803"},"text":"Pub. L. 117–103, div. W, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/898"},"text":"136 Stat. 898","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id624ea74c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id624ea74d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id624ea74e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1302"},"text":"Section 1302 of this title","children":[],"tail":" (as amended by this section), referred to in par. (1), is "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1302"},"text":"section 1302 of this title","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/s234"},"text":"section 234 of Pub. L. 111–211","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id624ea74f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1302"},"text":"section 1302 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Tribal Law and Order Act of 2010, and not as part of the Indian Civil Rights Act of 1968 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id624ea750-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s803/1"},"text":"Pub. L. 117–103, § 803(1)","children":[],"tail":", (2), struck out “pilot” before “program” in section catchline and wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s803/3"},"text":"Pub. L. 117–103, § 803(3)","children":[],"tail":", substituted “Not later than 120 days after "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"March 15, 2022","children":[],"tail":"” for “Not later than 120 days after "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s803/4"},"text":"Pub. L. 117–103, § 803(4)","children":[],"tail":", substituted “1 or more years” for “2 or more years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s803/5"},"text":"Pub. L. 117–103, § 803(5)","children":[],"tail":", struck out pars. (5) and (6) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—Not later than 3 years after the date of establishment of the pilot program, the Attorney General shall submit to Congress a report describing the status of the program, including recommendations regarding the future of the program, if any."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—Except as otherwise provided by an Act of Congress, the pilot program under this paragraph shall expire on the date that is 4 years after the date on which the program is established.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id624ea751-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id624ea752-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “tribal government” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s203/a"},"text":"section 203(a) of Pub. L. 111–211","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2801"},"text":"section 2801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
