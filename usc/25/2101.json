{"tag":"section","attrib":{"id":"id62917b97-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2101"},"text":null,"children":[{"tag":"num","attrib":{"value":"2101"},"text":"§ 2101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62917b98-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian” means any individual Indian or Alaska Native who owns land or interests in land the title to which is held in trust by the United States or is subject to a restriction against alienation imposed by the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62917b99-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian tribe” means any Indian tribe, band, nation, pueblo, community, rancheria, colony, or other group which owns land or interests in land title to which is held in trust by the United States or is subject to a restriction against alienation imposed by the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62917b9a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62917b9b-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/382/s2"},"text":"Pub. L. 97–382, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-22"},"text":"Dec. 22, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1938"},"text":"96 Stat. 1938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62917b9c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62917b9d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id62917b9e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/382/s1"},"text":"Pub. L. 97–382, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-22"},"text":"Dec. 22, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1938"},"text":"96 Stat. 1938","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/382/s1"},"text":"“That this Act [enacting this chapter] may be cited as the ‘Indian Mineral Development Act of 1982’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
