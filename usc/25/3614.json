{"tag":"section","attrib":{"id":"id62c117d9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3614"},"text":null,"children":[{"tag":"num","attrib":{"value":"3614"},"text":"§ 3614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal judicial conferences","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to provide funds to tribal judicial conferences, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3611"},"text":"section 3611 of this title","children":[],"tail":", pursuant to contracts entered into under the authority of the Indian Self-Determination and Education Assistance Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.] for the development, enhancement, and continuing operation of tribal justice systems of Indian tribes which are members of such conference. Funds provided under this section may be used for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c117da-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3614/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employment of judges, magistrates, court counselors, court clerks, court administrators, bailiffs, probation officers, officers of the court, or dispute resolution facilitators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c117db-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3614/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, revision, and publication of tribal codes, rules of practice, rules of procedure, and standards of judicial performance and conduct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c117dc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3614/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition, development, and maintenance of a law library and computer assisted legal research capacities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c117dd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3614/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training programs and continuing education for tribal judicial personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c117de-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3614/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and operation of records management systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c117df-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3614/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning for the development, enhancement, and operation of tribal justice systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c117e0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3614/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the development and operation of other innovative and culturally relevant programs and projects, including (but not limited to) programs and projects for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62c117e1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3614/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative dispute resolution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c117e2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3614/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal victims assistance or victims services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c117e3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3614/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal probation services or diversion programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c117e4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3614/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" juvenile services and multidisciplinary investigations of child abuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c117e5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3614/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" traditional tribal judicial practices, traditional justice systems, and traditional methods of dispute resolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c117e6-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/176/tI/s104"},"text":"Pub. L. 103–176, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2008"},"text":"107 Stat. 2008","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c117e7-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62c117e8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62c117e9-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which is classified principally to chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
