{"tag":"section","attrib":{"id":"id62c11754-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506"},"text":null,"children":[{"tag":"num","attrib":{"value":"3506"},"text":"§ 3506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wind and hydropower feasibility study","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c11755-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy, in coordination with the Secretary of the Army and the Secretary, shall conduct a study of the cost and feasibility of developing a demonstration project that uses wind energy generated by Indian tribes and hydropower generated by the Army Corps of Engineers on the Missouri River to supply firming power to the Western Area Power Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c11756-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c11757-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the economic and engineering feasibility of blending wind energy and hydropower generated from the Missouri River dams operated by the Army Corps of Engineers, including an assessment of the costs and benefits of blending wind energy and hydropower compared to current sources used for firming power to the Western Area Power Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11758-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review historical and projected requirements for, patterns of availability and use of, and reasons for historical patterns concerning the availability of firming power;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11759-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the wind energy resource potential on tribal land and projected cost savings through a blend of wind and hydropower over a 30-year period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c1175a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine seasonal capacity needs and associated transmission upgrades for integration of tribal wind generation and identify costs associated with these activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c1175b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an independent tribal engineer and a Western Area Power Administration customer representative as study team members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c1175c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate, to the extent appropriate, the results of the Dakotas Wind Transmission study prepared by the Western Area Power Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c1175d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary of Energy, the Secretary, and the Secretary of the Army shall submit to Congress a report that describes the results of the study, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c1175e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis and comparison of the potential energy cost or benefits to the customers of the Western Area Power Administration through the use of combined wind and hydropower;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c1175f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an economic and engineering evaluation of whether a combined wind and hydropower system can reduce reservoir fluctuation, enhance efficient and reliable energy production, and provide Missouri River management flexibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11760-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if found feasible, recommendations for a demonstration project to be carried out by the Western Area Power Administration, in partnership with an Indian tribal government or tribal energy development organization, and Western Area Power Administration customers to demonstrate the feasibility and potential of using wind energy produced on Indian land to supply firming energy to the Western Area Power Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11761-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an identification of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62c11762-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic and environmental costs of, or benefits to be realized through, a Federal-tribal-customer partnership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c11763-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which a Federal-tribal-customer partnership could contribute to the energy security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c11764-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c11765-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $1,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c11766-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3506/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonreimbursability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Costs incurred by the Secretary in carrying out this section shall be nonreimbursable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c11767-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXVI/s2606"},"text":"Pub. L. 102–486, title XXVI, § 2606","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tV/s503/a"},"text":"Pub. L. 109–58, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/777"},"text":"119 Stat. 777","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/325/tI/s105/c"},"text":"Pub. L. 115–325, title I, § 105(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-18"},"text":"Dec. 18, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4456"},"text":"132 Stat. 4456","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c11768-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62c11769-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62c1176a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3506, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXVI/s2606"},"text":"Pub. L. 102–486, title XXVI, § 2606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3118"},"text":"106 Stat. 3118","children":[],"tail":", related to tribal government energy assistance program, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62c1176b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325"},"text":"Pub. L. 115–325","children":[],"tail":" substituted “energy development” for “energy resource development”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
