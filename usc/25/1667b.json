{"tag":"section","attrib":{"id":"id6274cb4e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1667b"},"text":"§ 1667b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian youth telemental health demonstration project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6274cb4f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6274cb50-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Service, is authorized to carry out a demonstration project to award grants for the provision of telemental health services to Indian youth who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cb51-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have expressed suicidal ideas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb52-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have attempted suicide; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb53-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have behavioral health conditions that increase or could increase the risk of suicide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cb54-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under paragraph (1) shall be awarded to Indian tribes and tribal organizations that operate 1 or more facilities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cb55-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located in an area with documented disproportionately high rates of suicide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb56-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reporting active clinical telehealth capabilities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb57-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offering school-based telemental health services to Indian youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cb58-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants under this section for a period of up to 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cb59-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum number of grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not more than 5 grants shall be provided under paragraph (1), with priority consideration given to Indian tribes and tribal organizations that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cb5a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve a particular community or geographic area in which there is a demonstrated need to address Indian youth suicide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb5b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into collaborative partnerships with Service or other tribal health programs or facilities to provide services under this demonstration project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb5c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve an isolated community or geographic area that has limited or no access to behavioral health services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb5d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate a detention facility at which Indian youth are detained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cb5e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing and carrying out the demonstration project under this subsection, the Secretary shall consult with the Administration as the Federal agency focused on mental health issues, including suicide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6274cb5f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6274cb60-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Indian tribe or tribal organization shall use a grant received under subsection (a) for the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cb61-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To provide telemental health services to Indian youth, including the provision of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cb62-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" psychotherapy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cb63-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" psychiatric assessments and diagnostic interviews, therapies for mental health conditions predisposing to suicide, and treatment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cb64-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alcohol and substance abuse treatment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb65-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide clinician-interactive medical advice, guidance and training, assistance in diagnosis and interpretation, crisis counseling and intervention, and related assistance to Service or tribal clinicians and health services providers working with youth being served under the demonstration project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb66-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assist, educate, and train community leaders, health education professionals and paraprofessionals, tribal outreach workers, and family members who work with the youth receiving telemental health services under the demonstration project, including with identification of suicidal tendencies, crisis intervention and suicide prevention, emergency skill development, and building and expanding networks among those individuals and with State and local health services providers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb67-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To develop and distribute culturally appropriate community educational materials regarding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cb68-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suicide prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cb69-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suicide education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cb6a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/b/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suicide screening;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cb6b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/b/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suicide intervention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cb6c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/b/1/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways to mobilize communities with respect to the identification of risk factors for suicide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb6d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To conduct data collection and reporting relating to Indian youth suicide prevention efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cb6e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Traditional health care practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the purposes described in paragraph (1), an Indian tribe or tribal organization may use and promote the traditional health care practices of the Indian tribes of the youth to be served.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6274cb6f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6274cb70-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), to be eligible to receive a grant under subsection (a), an Indian tribe or tribal organization shall prepare and submit to the Secretary an application, at such time, in such manner, and containing such information as the Secretary may require, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cb71-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the project that the Indian tribe or tribal organization will carry out using the funds provided under the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb72-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the manner in which the project funded under the grant would—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cb73-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the telemental health care needs of the Indian youth population to be served by the project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cb74-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the access of the Indian youth population to be served to suicide prevention and treatment services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb75-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence of support for the project from the local community to be served by the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb76-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the families and leadership of the communities or populations to be served by the project would be involved in the development and ongoing operations of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb77-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan to involve the tribal community of the youth who are provided services by the project in planning and evaluating the behavioral health care and suicide prevention efforts provided, in order to ensure the integration of community, clinical, environmental, and cultural components of the treatment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb78-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for sustaining the project after Federal assistance for the demonstration project has terminated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cb79-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Efficiency of grant application process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out such measures as the Secretary determines to be necessary to maximize the time and workload efficiency of the process by which Indian tribes and tribal organizations apply for grants under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6274cb7a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, shall encourage Indian tribes and tribal organizations receiving grants under this section to collaborate to enable comparisons regarding best practices across projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6274cb7b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each grant recipient shall submit to the Secretary an annual report that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6274cb7c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the number of telemental health services provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cb7d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any other information that the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6274cb7e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6274cb7f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cb80-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after the date on which the first grant is awarded under this section, the Secretary shall submit to the Committee on Indian Affairs of the Senate and the Committee on Natural Resources and the Committee on Energy and Commerce of the House of Representatives a report that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cb81-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes each project funded by a grant under this section during the preceding 2-year period, including a description of the level of success achieved by the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cb82-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluates whether the demonstration project should be continued during the period beginning on the date of termination of funding for the demonstration project under subsection (g) and ending on the date on which the final report is submitted under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb83-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of demonstration project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On a determination by the Secretary under clause (ii) of subparagraph (A) that the demonstration project should be continued, the Secretary may carry out the demonstration project during the period described in that clause using such sums otherwise made available to the Secretary as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cb84-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 270 days after the date of termination of funding for the demonstration project under subsection (g), the Secretary shall submit to the Committee on Indian Affairs of the Senate and the Committee on Natural Resources and the Committee on Energy and Commerce of the House of Representatives a final report that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cb85-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the results of the projects funded by grants awarded under this section, including any data available that indicate the number of attempted suicides;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb86-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluates the impact of the telemental health services funded by the grants in reducing the number of completed suicides among Indian youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb87-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" evaluates whether the demonstration project should be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cb88-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/f/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanded to provide more than 5 grants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cb89-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/f/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designated as a permanent program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb8a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluates the benefits of expanding the demonstration project to include urban Indian organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6274cb8b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $1,500,000 for each of fiscal years 2010 through 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6274cb8c-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s723"},"text":"Pub. L. 94–437, title VII, § 723","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6274cb8d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6274cb8e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6274cb8f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s723"},"text":"Section 723 of Pub. L. 94–437","children":[],"tail":" is based on section 181 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
