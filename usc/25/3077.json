{"tag":"section","attrib":{"id":"id62b2e6f7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3077"},"text":null,"children":[{"tag":"num","attrib":{"value":"3077"},"text":"§ 3077.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment under Freedom of Information Act","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b2e6f8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3077/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), the following information shall be exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b2e6f9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3077/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information that a representative of an Indian Tribe or Native Hawaiian organization—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b2e6fa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3077/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to a Federal agency pursuant to this chapter or an amendment made by this Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b2e6fb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3077/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designates as sensitive or private according to Native American custom, law, culture, or religion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b2e6fc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3077/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information that any person submits to a Federal agency pursuant to this chapter or an amendment made by this Act that relates to an item for which an export certification is denied under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b2e6fd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3077/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), this chapter shall be considered a statute described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/3/B"},"text":"section 552(b)(3)(B) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b2e6fe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3077/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian Tribe or Native Hawaiian organization may request and shall receive its own information, as described in subsection (a), from the Federal agency to which the Indian Tribe or Native Hawaiian organization submitted the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b2e6ff-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/258/s9"},"text":"Pub. L. 117–258, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-21"},"text":"Dec. 21, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2385"},"text":"136 Stat. 2385","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62b2e700-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62b2e701-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62b2e702-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/258"},"text":"Pub. L. 117–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-21"},"text":"Dec. 21, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2372"},"text":"136 Stat. 2372","children":[],"tail":", known as the Safeguard Tribal Objects of Patrimony Act of 2021, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3071"},"text":"section 3071 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"An amendment made by this Act, referred to in subsec. (a)(1)(A), (2), means the amendment made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/258"},"text":"Pub. L. 117–258","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1170"},"text":"section 1170 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
