{"tag":"section","attrib":{"id":"id62ee69c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5374"},"text":null,"children":[{"tag":"num","attrib":{"value":"5374"},"text":"§ 5374.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of circulars, policies, manuals, guidance, and rules","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Unless expressly agreed to by a participating Indian Tribe in a compact or funding agreement, the participating Indian Tribe shall not be subject to any agency circular, policy, manual, guidance, or rule adopted by the Department, except for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee69c2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5374/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligibility provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5324/g"},"text":"section 5324(g) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee69c3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5374/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations promulgated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5373"},"text":"section 5373 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62ee69c4-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tIV/s414"},"text":"Pub. L. 93–638, title IV, § 414","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/180/tI/s101/e"},"text":"Pub. L. 116–180, title I, § 101(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-21"},"text":"Oct. 21, 2020","children":[],"tail":", "},{"tag":"re