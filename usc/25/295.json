{"tag":"section","attrib":{"id":"id622154c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s295"},"text":null,"children":[{"tag":"num","attrib":{"value":"295"},"text":"§ 295.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision of expenditure of appropriations for school purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All expenditure of money herein or after ","children":[{"tag":"date","attrib":{"date":"1908-04-30"},"text":"April 30, 1908","children":[],"tail":", appropriated for school purposes among the Indians, shall be at all times under the supervision and direction of the Commissioner of Indian Affairs, and in all respects in conformity with such conditions, rules, and regulations as to the conduct and methods of instruction and expenditure of money as may be from time to time prescribed by him, subject to the supervision of the Secretary of the Interior."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id622154c1-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1908-04-30/ch153"},"text":"Apr. 30, 1908, ch. 153","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/72"},"text":"35 Stat. 72","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id622154c2-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id622154c3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id622154c4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1908-04-30"},"text":"Apr. 30, 1908","children":[],"tail":", embodied restrictions as to the amount which might be expended for the annual support and education of any one pupil and specified the method for determining the number of pupils in any school entitled to the per capita allowance provided for by the act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id622154c5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id622154c6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"School and Employment Transportation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Separate appropriations for collection and transportation of pupils to and from Indian schools, etc., with a proviso that a specified part of the amount so appropriated may be used in placing Indian youths in employment in industrial pursuits were made by the following appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch462"},"text":"Mar. 3, 1925, ch. 462","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1155"},"text":"43 Stat. 1155","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1922-05-24/ch199"},"text":"May 24, 1922, ch. 199","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/562"},"text":"42 Stat. 562","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id622154c7-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id622154c8-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
