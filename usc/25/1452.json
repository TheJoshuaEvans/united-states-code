{"tag":"section","attrib":{"id":"id6255d1a7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1452"},"text":null,"children":[{"tag":"num","attrib":{"value":"1452"},"text":"§ 1452.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this chapter, the term—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6255d1a8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1452/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d1a9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1452/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian” means any person who is a member of any Indian tribe, band, group, pueblo, or community which is recognized by the Federal Government as eligible for services from the Bureau of Indian Affairs and any “Native” as defined in the Alaska Native Claims Settlement Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d1aa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1452/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Tribe” means any Indian tribe, band, group, pueblo, or community, including Native villages and Native groups (including corporations organized by Kenai, Juneau, Sitka, and Kodiak) as defined in the Alaska Native Claims Settlement Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.], which is recognized by the Federal Government as eligible for services from the Bureau of Indian Affairs."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d1ab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1452/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Reservation” includes Indian reservations, public domain Indian allotments, former Indian reservations in Oklahoma, and land held by incorporated Native groups, regional corporations, and village corporations under the provisions of the Alaska Native Claims Settlement Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d1ac-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1452/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Economic enterprise” means any Indian-owned (as defined by the Secretary of the Interior) commercial, industrial, or business activity established or organized for the purpose of profit: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That such Indian ownership shall constitute not less than 51 per centum of the enterprise."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d1ad-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1452/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Organization”, unless otherwise specified, shall be the governing body of any Indian tribe, as defined in subsection (c), or entity established or recognized by such governing body for the purpose of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d1ae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1452/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Other organizations” means any non-Indian individual, firm, corporation, partnership, or association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d1af-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1452/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Surety” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s694a"},"text":"section 694a of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6255d1b0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1452/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Surety Bond” means a bid bond, payment bond, or performance bond as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s694a"},"text":"section 694a of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6255d1b1-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/s3"},"text":"Pub. L. 93–262, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/77"},"text":"88 Stat. 77","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/442/s5/b"},"text":"Pub. L. 100–442, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-22"},"text":"Sept. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1764"},"text":"102 Stat. 1764","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6255d1b2-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6255d1b3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6255d1b4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Alaska Native Claims Settlement Act, referred to in pars. (b) to (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6255d1b5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Pars. (h), (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/442"},"text":"Pub. L. 100–442","children":[],"tail":" added pars. (h) and (i)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
