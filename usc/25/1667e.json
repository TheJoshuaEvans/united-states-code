{"tag":"section","attrib":{"id":"id6274cbc7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1667e"},"text":"§ 1667e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian youth life skills development demonstration program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6274cbc8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this section is to authorize the Secretary, acting through the Administration, to carry out a demonstration program to test the effectiveness of a culturally compatible, school-based, life skills curriculum for the prevention of Indian and Alaska Native adolescent suicide, including through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6274cbc9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the establishment of tribal partnerships to develop and implement such a curriculum, in cooperation with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cbca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" behavioral health professionals, with a priority for tribal partnerships cooperating with mental health professionals employed by the Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbcb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal or local school agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbcc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parent and community groups;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cbcd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the provision by the Administration or the Service of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cbce-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical expertise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbcf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clinicians, analysts, and educators, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cbd0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training for teachers, school administrators, and community members to implement the curriculum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cbd1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of advisory councils composed of parents, educators, community members, trained peers, and others to provide advice regarding the curriculum and other components of the demonstration program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cbd2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of culturally appropriate support measures to supplement the effectiveness of the curriculum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cbd3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects modeled after evidence-based projects, such as programs evaluated and published in relevant literature.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6274cbd4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6274cbd5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cbd6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Curriculum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “curriculum” means the culturally compatible, school-based, life skills curriculum for the prevention of Indian and Alaska Native adolescent suicide identified by the Secretary under paragraph (2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbd7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cbd8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cbd9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribal organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cbda-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other tribally authorized entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cbdb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any partnership composed of 2 or more entities described in clause (i), (ii), or (iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cbdc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Administration, may establish and carry out a demonstration program under which the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cbdd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify a culturally compatible, school-based, life skills curriculum for the prevention of Indian and Alaska Native adolescent suicide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbde-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the Indian tribes that are at greatest risk for adolescent suicide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbdf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" invite those Indian tribes to participate in the demonstration program by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cbe0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responding to a comprehensive program requirement request of the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cbe1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitting, through an eligible entity, an application in accordance with paragraph (4); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbe2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide grants to the Indian tribes identified under subparagraph (B) and eligible entities to implement the curriculum with respect to Indian and Alaska Native youths who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cbe3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are between the ages of 10 and 19; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cbe4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attend school in a region that is at risk of high youth suicide rates, as determined by the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cbe5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cbe6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of a grant provided under the demonstration program under this section shall be not less than 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbe7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide not more than 5 grants under the demonstration program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbe8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The grants provided under this section shall be of equal amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbe9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain schools","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting eligible entities to receive grants under this section, the Secretary shall ensure that not less than 1 demonstration program shall be carried out at each of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cbea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a school operated by the Bureau of Indian Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cbeb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Tribal ","children":[{"tag":"ref","attrib":{"idref":"fn002090"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002090"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" school; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cbec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a school receiving payments under section 7702 or 7703 of title 20.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cbed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under the demonstration program, an eligible entity shall submit to the Secretary an application, at such time, in such manner, and containing such information as the Secretary may require, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cbee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that, in implementing the curriculum, the eligible entity will collaborate with 1 or more local educational agencies, including elementary schools, middle schools, and high schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assurance that the eligible entity will collaborate, for the purpose of curriculum development, implementation, and training and technical assistance, with 1 or more—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cbf0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit entities with demonstrated expertise regarding the development of culturally sensitive, school-based, youth suicide prevention and intervention programs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cbf1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education with demonstrated interest and knowledge regarding culturally sensitive, school-based, life skills youth suicide prevention and intervention programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbf2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the curriculum will be carried out in an academic setting in conjunction with at least 1 classroom teacher not less frequently than twice each school week for the duration of the academic year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbf3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the methods by which curriculum participants will be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cbf4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" screened for mental health at-risk indicators; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cbf5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if needed and on a case-by-case basis, referred to a mental health clinician for further assessment and treatment and with crisis response capability; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbf6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assurance that supportive services will be provided to curriculum participants identified as high-risk participants, including referral, counseling, and follow-up services for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cbf7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/4/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drug or alcohol abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cbf8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/4/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sexual or domestic abuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cbf9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/4/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depression and other relevant mental health concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cbfa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Indian tribe identified under paragraph (2)(B) or an eligible entity may use a grant provided under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cbfb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and implement the curriculum in a school-based setting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbfc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to establish an advisory council—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cbfd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advise the Indian tribe or eligible entity regarding curriculum development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cbfe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide support services identified as necessary by the community being served by the Indian tribe or eligible entity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to appoint and train a school- and community-based cultural resource liaison, who will act as an intermediary among the Indian tribe or eligible entity, the applicable school administrators, and the advisory council established by the Indian tribe or eligible entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cc00-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish an on-site, school-based, MA- or PhD-level mental health practitioner (employed by the Service, if practicable) to work with tribal educators and other personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cc01-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the training of peer counselors to assist in carrying out the curriculum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cc02-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to procure technical and training support from nonprofit or State entities or institutions of higher education identified by the community being served by the Indian tribe or eligible entity as the best suited to develop and implement the curriculum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cc03-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to train teachers and school administrators to effectively carry out the curriculum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cc04-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish an effective referral procedure and network;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cc05-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/5/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify and develop culturally compatible curriculum support measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cc06-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/5/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain educational materials and other resources from the Administration or other appropriate entities to ensure the success of the demonstration program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cc07-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/b/5/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to evaluate the effectiveness of the curriculum in preventing Indian and Alaska Native adolescent suicide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6274cc08-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Using such amounts made available pursuant to subsection (e) as the Secretary determines to be appropriate, the Secretary shall conduct, directly or through a grant, contract, or cooperative agreement with an entity that has experience regarding the development and operation of successful culturally compatible, school-based, life skills suicide prevention and intervention programs or evaluations, an annual evaluation of the demonstration program under this section, including an evaluation of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6274cc09-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the curriculum in preventing Indian and Alaska Native adolescent suicide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cc0a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas for program improvement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cc0b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional development of the goals and objectives of the demonstration program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6274cc0c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6274cc0d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), not later than 180 days after the date of termination of the demonstration program, the Secretary shall submit to the Committee on Indian Affairs and the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Natural Resources and the Committee on Education and Labor of the House of Representatives a final report that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cc0e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the results of the program of each Indian tribe or eligible entity under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cc0f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluates the effectiveness of the curriculum in preventing Indian and Alaska Native adolescent suicide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cc10-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" makes recommendations regarding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cc11-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expansion of the demonstration program under this section to additional eligible entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cc12-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designating the demonstration program as a permanent program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cc13-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/d/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and distributing the curriculum through the Suicide Prevention Resource Center of the Administration; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cc14-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporates any public comments received under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cc15-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide a notice of the report under paragraph (1) and an opportunity for public comment on the report for a period of not less than 90 days before submitting the report to Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6274cc16-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $1,000,000 for each of fiscal years 2010 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6274cc17-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s726"},"text":"Pub. L. 94–437, title VII, § 726","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/qq"},"text":"Pub. L. 114–95, title IX, § 9215(qq)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2181"},"text":"129 Stat. 2181","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6274cc18-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6274cc19-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6274cc1a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s726"},"text":"Section 726 of Pub. L. 94–437","children":[],"tail":" is based on section 181 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6274cc1b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(3)(D)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to section 7702 or 7703 of title 20."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6274cc1c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6274cc1d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6274cc1e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
