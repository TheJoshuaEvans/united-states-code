{"tag":"section","attrib":{"id":"id6298a7d2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2211"},"text":null,"children":[{"tag":"num","attrib":{"value":"2211"},"text":"§ 2211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing body of tribe; construction of chapter as not vesting with authority not authorized by tribal constitution or by-laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed as vesting the governing body of an Indian tribe with any authority which is not authorized by the constitution and by-laws or other organizational document of such tribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6298a7d3-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/459/tII/s212"},"text":"Pub. L. 97–459, title II, § 212","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/608/s1/5"},"text":"Pub. L. 98–608, § 1(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3173"},"text":"98 Stat. 3173","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6298a7d4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6298a7d5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6298a7d6-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, which was translated as reading “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/459"},"text":"Pub. L. 97–459","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
