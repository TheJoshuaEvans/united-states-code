{"tag":"section","attrib":{"id":"id626d9fe4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657"},"text":null,"children":[{"tag":"num","attrib":{"value":"1657"},"text":"§ 1657.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id626d9fe5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year during which an urban Indian organization receives or expends funds pursuant to a contract entered into, or a grant received, pursuant to this subchapter, such organization shall submit to the Secretary a quarterly report including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id626d9fe6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a contract or grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1653"},"text":"section 1653 of this title","children":[],"tail":", information gathered pursuant to clauses (10) and (11) of subsection (a) of such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626d9fe7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on activities conducted by the organization pursuant to the contract or grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626d9fe8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accounting of the amounts and purposes for which Federal funds were expended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626d9fe9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626d9fea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit by Secretary and Comptroller General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reports and records of the urban Indian organization with respect to a contract or grant under this subchapter shall be subject to audit by the Secretary and the Comptroller General of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626d9feb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost of annual private audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allow as a cost of any contract or grant entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1653"},"text":"section 1653 of this title","children":[],"tail":" the cost of an annual private audit conducted by a certified public accountant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626d9fec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health status, services, and areas of unmet needs; child welfare","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id626d9fed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, acting through the Service, shall submit a report to the Congress not later than ","children":[{"tag":"date","attrib":{"date":"1992-03-31"},"text":"March 31, 1992","children":[],"tail":", evaluating—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id626d9fee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health status of urban Indians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id626d9fef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the services provided to Indians through this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id626d9ff0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas of unmet needs in urban areas served under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id626d9ff1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas of unmet needs in urban areas not served under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626d9ff2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In preparing the report under paragraph (1), the Secretary shall consult with urban Indian health providers and may contract with a national organization representing urban Indian health concerns to conduct any aspect of the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id626d9ff3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary and the Secretary of the Interior shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id626d9ff4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the status of the welfare of urban Indian children, including the volume of child protection cases, the prevalence of child sexual abuse, and the extent of urban Indian coordination with tribal authorities with respect to child sexual abuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id626d9ff5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1657/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a report on the assessment required under subparagraph (A), together with recommended legislation to improve Indian child protection in urban Indian populations, to the Congress no later than ","children":[{"tag":"date","attrib":{"date":"1992-03-31"},"text":"March 31, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id626d9ff6-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tV/s507"},"text":"Pub. L. 94–437, title V, § 507","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tV/s501"},"text":"Pub. L. 100–713, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4823"},"text":"102 Stat. 4823","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/630/tV/s507"},"text":"Pub. L. 101–630, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4566"},"text":"104 Stat. 4566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tV/s501/b/5"},"text":"Pub. L. 102–573, title V, § 501(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4568"},"text":"106 Stat. 4568","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id626d9ff7-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id626d9ff8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id626d9ff9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1657, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tV/s507"},"text":"Pub. L. 94–437, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1412"},"text":"90 Stat. 1412","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/537/s7"},"text":"Pub. L. 96–537, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-17"},"text":"Dec. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3179"},"text":"94 Stat. 3179","children":[],"tail":", related to review of program by Secretary and report to Congress, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/100/713"},"text":"Pub. L. 100–713","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id626d9ffa-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s501/b/5/A"},"text":"Pub. L. 102–573, § 501(b)(5)(A)","children":[],"tail":", inserted “, or a grant received,” after “entered into” in introductory provisions and “or grant” after “contract” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s501/b/5/B"},"text":"Pub. L. 102–573, § 501(b)(5)(B)","children":[],"tail":", inserted “or grant” after “contract”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630"},"text":"Pub. L. 101–630","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
