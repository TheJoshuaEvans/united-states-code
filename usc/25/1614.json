{"tag":"section","attrib":{"id":"id625a8d59-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1614"},"text":null,"children":[{"tag":"num","attrib":{"value":"1614"},"text":"§ 1614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian health service extern programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id625a8d5a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1614/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment of scholarship grantees during non­academic periods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual who receives a scholarship grant pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1613a"},"text":"section 1613a of this title","children":[],"tail":" shall be entitled to employment in the Service during any nonacademic period of the year. Periods of employment pursuant to this subsection shall not be counted in determining the fulfillment of the service obligation incurred as a condition of the scholarship grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625a8d5b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1614/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment of medical and other students during nonacademic periods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual enrolled in a course of study in the health professions may be employed by the Service during any nonacademic period of the year. Any such employment shall not exceed one hundred and twenty days during any calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625a8d5c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1614/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment without regard to competitive personnel system or agency personnel limitation; compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any employment pursuant to this section shall be made without regard to any competitive personnel system or agency personnel limitation and to a position which will enable the individual so employed to receive practical experience in the health profession in which he or she is engaged in study. Any individual so employed shall receive payment for his or her services comparable to the salary he or she would receive if he or she were employed in the competitive system. Any individual so employed shall not be counted against any employment ceiling affecting the Service or the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id625a8d5d-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tI/s105"},"text":"Pub. L. 94–437, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1404"},"text":"90 Stat. 1404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/83/tIII/s307/n/2"},"text":"Pub. L. 95–83, title III, § 307(n)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-01"},"text":"Aug. 1, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/393"},"text":"91 Stat. 393","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/537/s3/c"},"text":"Pub. L. 96–537, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-17"},"text":"Dec. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3174"},"text":"94 Stat. 3174","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tI/s103"},"text":"Pub. L. 100–713, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4786"},"text":"102 Stat. 4786","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tI"},"text":"Pub. L. 102–573, title I","children":[],"tail":", §§ 102(e), 117(b)(2), title IX, § 902(2)(B), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4532"},"text":"106 Stat. 4532","children":[],"tail":", 4544, 4591.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id625a8d5e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id625a8d5f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id625a8d60-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s102/e/1"},"text":"Pub. L. 102–573, § 102(e)(1)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1613a"},"text":"section 1613a of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254r"},"text":"section 254r of title 42","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s102/e/2"},"text":"Pub. L. 102–573, § 102(e)(2)","children":[],"tail":", substituted “course of study in the health professions” for “school of medicine, osteopathy, dentistry, veterinary medicine, optometry, podiatry, pharmacy, public health, nursing, or allied health professions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s902/2/B"},"text":"Pub. L. 102–573, § 902(2)(B)","children":[],"tail":", substituted “Department of Health and Human Services” for “Department of Health, Education, and Welfare”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s117/b/2"},"text":"Pub. L. 102–573, § 117(b)(2)","children":[],"tail":", struck out subsec. (d) which authorized appropriations for fiscal years 1989 to 1992."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/713"},"text":"Pub. L. 100–713","children":[],"tail":" amended subsec. (d) generally. Prior to amendment, subsec. (d) read as follows: “There are authorized to be appropriated for the purpose of this section: $600,000 for fiscal year 1978, $800,000 for fiscal year 1979, and $1,000,000 for fiscal year 1980. There are authorized to be appropriated to carry out this section $990,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":", $1,140,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":", $1,310,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1983-09-30"},"text":"September 30, 1983","children":[],"tail":", and $1,510,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1984-09-30"},"text":"September 30, 1984","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (d). ","children":[