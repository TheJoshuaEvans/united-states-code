{"tag":"section","attrib":{"id":"id62a48e28-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2509"},"text":null,"children":[{"tag":"num","attrib":{"value":"2509"},"text":"§ 2509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to issue regulations relating to the discharge of duties specifically assigned to the Secretary in this chapter. For all other matters relating to the details of planning, developing, implementing, and evaluating grants under this chapter, the Secretary shall not issue regulations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62a48e29-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5210"},"text":"Pub. L. 100–297, title V, § 5210","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1043"},"text":"Pub. L. 107–110, title X, § 1043","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2077"},"text":"115 Stat. 2077","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62a48e2a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62a48e2b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62a48e2c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2509, ","children":[{"tag":"ref","att