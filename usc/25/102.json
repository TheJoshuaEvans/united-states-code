{"tag":"section","attrib":{"id":"id62156dab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s102"},"text":null,"children":[{"tag":"num","attrib":{"value":"102"},"text":"§ 102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of costs for furnishing coal for Indian Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The cost of inspection, storage, transportation, and so forth, of coal for the Indian Service shall be paid from the support fund of the school or agency for which the coal is purchased.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62156dac-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-02-14/ch75/s1"},"text":"Feb. 14, 1920, ch. 75, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/412"},"text":"41 Stat. 412","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62156dad-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62156dae-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id62156daf-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Archivist transferred to Administrator of General Services by section 104(a) of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288/tI"},"text":"act June 30, 1949, ch. 288, title I","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/381"},"text":"63 Stat. 381","children":[],"tail":". See text of, and Historical and Revision Notes under, "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2102"},"text":"section 2102 of Title 44","children":[],"tail":", Public Printing and Documents. Transfer of functions effective "},{"tag":"date","attrib":{"date":"1949-07-01"},"text":"July 1, 1949","children":[],"tail":", see section 605, formerly § 505, of "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"act June 30, 1949, ch. 288","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/403"},"text":"63 Stat. 403","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-05/ch849/s6/a"},"text":"Sept. 5, 1950, ch. 849, § 6(a)","children":[],"tail":", (b), "},{"tag":"ref","attrib":{"href":"/us/stat/64/583"},"text":"64 Stat. 583","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id62156db0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id62156db1-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
