{"tag":"section","attrib":{"id":"id62d69adb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305"},"text":null,"children":[{"tag":"num","attrib":{"value":"4305"},"text":"§ 4305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intertribal tourism demonstration projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d69adc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program to conduct tourism projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d69add-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director, shall conduct a Native American tourism program to facilitate the development and conduct of tourism demonstration projects by Indian Tribes, on a Tribal, intertribal, or regional basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69ade-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d69adf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under the program established under this section, in order to assist in the development and promotion of tourism on and in the vicinity of Indian lands, the Secretary, acting through the Director, shall, in coordination with the Under Secretary of Agriculture for Rural Development, assist eligible entities in the planning, development, and implementation of tourism development demonstration projects that meet the criteria described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69ae0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting tourism development demonstration projects under this section, the Secretary, acting through the Director, shall select projects that have the potential to increase travel and tourism revenues by attracting visitors to Indian lands and lands in the vicinity of Indian lands, including projects that provide for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d69ae1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and distribution of educational and promotional materials pertaining to attractions located on and near Indian lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d69ae2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of educational resources to assist in private and public tourism development on and in the vicinity of Indian lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d69ae3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination of tourism-related joint ventures and cooperative efforts between eligible entities and appropriate State and local governments that have jurisdiction over areas in the vicinity of Indian lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69ae4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out the program under this section, the Secretary, acting through the Director, may award grants or enter into other appropriate arrangements with Indian Tribes, Tribal organizations, intertribal consortia, or other Tribal entities that the Secretary, in consultation with the Director, determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69ae5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Locations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing for tourism development demonstration projects under the program under this section, the Secretary, acting through the Director, shall provide for a demonstration project to be conducted—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d69ae6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for Indians of the Four Corners area located in the area adjacent to the border between Arizona, Utah, Colorado, and New Mexico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69ae7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for Indians of the northwestern area that is commonly known as the Great Northwest (as determined by the Secretary);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69ae8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the Oklahoma Indians in Oklahoma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69ae9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the Indians of the Great Plains area (as determined by the Secretary); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69aea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for Alaska Natives in Alaska.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d69aeb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director, shall provide financial assistance, technical assistance, and administrative services to participants that the Secretary, acting through the Director, selects to carry out a tourism development project under this section, with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d69aec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" feasibility studies conducted as part of that project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69aed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" market analyses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69aee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participation in tourism and trade missions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69aef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activity that the Secretary, in consultation with the Director, determines to be appropriate to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d69af0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Infrastructure development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The demonstration projects conducted under this section shall include provisions to facilitate the development and financing of infrastructure, including the development of Indian reservation roads in a manner consistent with title 23.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d69af1-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/464/s6"},"text":"Pub. L. 106–464, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2016"},"text":"114 Stat. 2016","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/261/s3/e/2"},"text":"Pub. L. 116–261, § 3(e)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2020-12-30"},"text":"Dec. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3311"},"text":"134 Stat. 3311","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d69af2-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d69af3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62d69af4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/261"},"text":"Pub. L. 116–261","children":[],"tail":" substituted “Tribes” for “tribes” and “Tribal” for “tribal”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/261"},"text":"Pub. L. 116–261","children":[],"tail":" substituted “Tribes” for “tribes” and “Tribal” for “tribal” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
