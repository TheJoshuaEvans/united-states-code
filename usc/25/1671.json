{"tag":"section","attrib":{"id":"id6274cc23-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1671"},"text":null,"children":[{"tag":"num","attrib":{"value":"1671"},"text":"§ 1671.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President shall, at the time the budget is submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", for each fiscal year transmit to the Congress a report containing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6274cc24-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1671/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report on the progress made in meeting the objectives of this chapter, including a review of programs established or assisted pursuant to this chapter and an assessment and recommendations of additional programs or additional assistance necessary to, at a minimum, provide health services to Indians, and ensure a health status for Indians, which are at a parity with the health services available to and the health status of, the general population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cc25-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1671/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report on whether, and to what extent, new national health care programs, benefits, initiatives, or financing systems have had an impact on the purposes of this chapter and any steps that the Secretary may have taken to consult with Indian tribes to address such impact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cc26-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1671/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a report on the use of health services by Indians—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cc27-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1671/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a national and area or other relevant geographical basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cc28-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1671/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by gender and age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cc29-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1671/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by source of payment and type of service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cc2a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1671/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comparing such rates of use with rates of use among comparable non-Indian populations.","children":[{"tag":"ref","attrib":{"idref":"fn002091"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002091"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cc2b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1671/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a separate statement which specifies the amount of funds requested to carry out the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1621"},"text":"section 1621 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cc2c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1671/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a separate statement of the total amount obligated or expended in the most recently completed fiscal year to achieve each of the objectives described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1680d"},"text":"section 1680d of this title","children":[],"tail":", relating to infant and maternal mortality and fetal alcohol syndrome;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cc2d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1671/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reports required by sections 1602(d),","children":[{"tag":"ref","attrib":{"idref":"fn002092"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002092"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" 1616a(n), 1621b(b), 1621h(j), 1631(c), 1632(g), 1634(a)(3), 1643, 1665g(e),"},{"tag":"ref","attrib":{"idref":"fn002092"},"text":"2","children":[],"tail":" and 1680g(a), and 1680"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(f) "},{"tag":"ref","attrib":{"idref":"fn002092"},"text":"2","children":[],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cc2e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1671/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 1995, the report required by sections 1665a(c)(3) ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" and 1665"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(b) "},{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cc2f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1671/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 1997, the interim report required by section 1637(h)(1) ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cc30-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1671/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 1999, the reports required by sections 1637(h)(2),","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" 1660b(b),"},{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" 1665j(f),"},{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" and 1680k(g) "},{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6274cc31-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s801"},"text":"Pub. L. 94–437, title VIII, § 801","children":[],"tail":", formerly title VII, § 701, "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","childr