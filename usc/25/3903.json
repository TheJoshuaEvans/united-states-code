{"tag":"section","attrib":{"id":"id62c84347-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3903"},"text":null,"children":[{"tag":"num","attrib":{"value":"3903"},"text":"§ 3903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory of open dumps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c84348-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and inventory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"1994-10-22"},"text":"October 22, 1994","children":[],"tail":", the Director shall conduct a study and inventory of open dumps on Indian lands and Alaska Native lands. The inventory shall list the geographic location of all open dumps, an evaluation of the contents of each dump, and an assessment of the relative severity of the threat to public health and the environment posed by each dump. Such assessment shall be carried out cooperatively with the Administrator of the Environmental Protection Agency. The Director shall obtain the concurrence of the Administrator in the determination of relative severity made by any such assessment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c84349-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon completion of the study and inventory under subsection (a), the Director shall report to the Congress, and update such report annually—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c8434a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current priority of Indian and Alaska Native solid waste deficiencies,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c8434b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methodology of determining the priority listing,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c8434c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3903/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of funding needed to effectively close or bring into compliance all open dumps on Indian lands or Alaska Native lands, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c8434d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3903/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress made in addressing Indian and Alaska Native solid waste deficiencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c8434e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 10-year plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall develop and begin implementation of a 10-year plan to address solid waste disposal needs on Indian lands and Alaska Native lands. This 10-year plan shall identify—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c8434f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3903/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of funding needed to effectively close or bring into compliance with applicable Federal standards any open dumps located on Indian lands and Alaska Native lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c84350-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3903/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of funding needed to develop comprehensive solid waste management plans for every Indian tribal government and Alaska Native entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c84351-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/399/s4"},"text":"Pub. L. 103–399, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4166"},"text":"108 Stat. 4166","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
