{"tag":"section","attrib":{"id":"id621f0b2e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s262"},"text":null,"children":[{"tag":"num","attrib":{"value":"262"},"text":"§ 262.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons permitted to trade with Indians","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person desiring to trade with the Indians on any Indian reservation shall, upon establishing the fact, to the satisfaction of the Commissioner of Indian Affairs, that he is a proper person to engage in such trade, be permitted to do so under such rules and regulations as the Commissioner of Indian Affairs may prescribe for the protection of said Indians.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621f0b2f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch832/s1"},"text":"Mar. 3, 1901, ch. 832, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/1066"},"text":"31 Stat. 1066","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1903-03-03/ch994/s10"},"text":"Mar. 3, 1903, ch. 994, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/1009"},"text":"32 Stat. 1009","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621f0b30-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621f0b31-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id621f0b32-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1901-03-03"},"text":"Mar. 3, 1901","children":[],"tail":", restricted provisions to the Osages and the Osage Indian Reservation. Act "},{"tag":"date","attrib":{"date":"1903-03-03"},"text":"Mar. 3, 1903","children":[],"tail":", extended the provisions to all Indian reservations."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id621f0b33-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id621f0b34-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
