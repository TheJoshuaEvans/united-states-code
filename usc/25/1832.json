{"tag":"section","attrib":{"id":"id6280b29c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1832"},"text":null,"children":[{"tag":"num","attrib":{"value":"1832"},"text":"§ 1832.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program; program agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6280b29d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1832/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From the amount appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1836"},"text":"section 1836 of this title","children":[],"tail":", the Secretary shall establish a program of making endowment grants to tribally controlled colleges or universities which are current recipients of assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1807"},"text":"section 1807 of this title","children":[],"tail":" or under section 3 of the Navajo Community College Act. No such college or university shall be ineligible for such a grant for a fiscal year by reason of the receipt of such a grant for a preceding fiscal year, but no such college or university shall be eligible for such a grant for a fiscal year if such college or university has been awarded a grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1065"},"text":"section 1065 of title 20","children":[],"tail":" for such fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6280b29e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1832/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No grant for the establishment of an endowment fund by a tribally controlled college or university shall be made unless such college or university enters into an agreement with the Secretary which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6280b29f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1832/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for the investment and maintenance of a trust fund, the corpus and earnings of which shall be invested in the same manner as funds are invested under paragraph (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1065/c"},"text":"section 1065(c) of title 20","children":[],"tail":", except that for purposes of this paragraph, the term “trust fund” means a fund established by an institution of higher education or by a foundation that is exempt from taxation and is maintained for the purpose of generating income for the support of the institution, and may include real estate;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6280b2a0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1832/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides for the deposit in such trust fund of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6280b2a1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1832/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal capital contributions made from funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1836"},"text":"section 1836 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6280b2a2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1832/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a capital contribution by such college or university in an amount (or of a value) equal to half of the amount of each Federal capital contribution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6280b2a3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1832/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any earnings of the funds so deposited;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6280b2a4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1832/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides that such funds will be deposited in such a manner as to insure the accumulation of interest thereon at a rate not less than that generally available for similar funds deposited at the banking or savings institution for the same period or periods of time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6280b2a5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1832/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides that, if at any time such college or university withdraws any capital contribution made by that college or university, an amount of Federal capital contribution equal to twice the amount of (or value of) such withdrawal shall be withdrawn and returned to the Secretary for reallocation to other colleges or universities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6280b2a6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1832/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides that no part of the net earnings of such trust fund will inure to the benefit of any private person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6280b2a7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1832/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes such other provisions as may be necessary to protect the financial interest of the United States and promote the purpose of this subchapter and as are agreed to by the Secretary and the college or university, including a description of recordkeeping procedures for the expenditure of accumulated interest which will allow the Secretary to audit and monitor programs and activities conducted with such interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6280b2a8-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/tIII/s302"},"text":"Pub. L. 95–471, title III, § 302","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/192/s13"},"text":"Pub. L. 98–192, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1341"},"text":"97 Stat. 1341","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/477/s1/d/1/A"},"text":"Pub. L. 101–477, § 1(d)(1)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"1990-10-30"},"text":"Oct. 30, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1152"},"text":"104 Stat. 1152","children":[],"tail":", 1153; "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s383"},"text":"Pub. L. 103–382, title III, § 383","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4018"},"text":"108 Stat. 4018","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s901/b/5"},"text":"Pub. L. 105–244, title IX, § 901(b)(5)","children":[],"tail":"–(7), (12), (14), (15), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1828"},"text":"112 Stat. 1828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6280b2a9-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6280b2aa-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6280b2ab-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3 of the Navajo Community College Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/189/s3"},"text":"section 3 of Pub. L. 92–189","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-15"},"text":"Dec. 15, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/646"},"text":"85 Stat. 646","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s640b"},"text":"section 640b of this title","children":[],"tail":" and was omitted from the Code as being of special and not general application."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6280b2ac-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/6"},"text":"Pub. L. 105–244, § 901(b)(6)","children":[],"tail":", (7), substituted “colleges or universities” for “community colleges” and substituted “such college or university” for “such college” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/5"},"text":"Pub. L. 105–244, § 901(b)(5)","children":[],"tail":", (7), in introductory provisions, substituted “controlled college or university” for “controlled community college” and “such college or university” for “such college”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/7"},"text":"Pub. L. 105–244, § 901(b)(7)","children":[],"tail":", substituted “such college or university” for “such college”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/7"},"text":"Pub. L. 105–244, § 901(b)(7)","children":[],"tail":", (14), (15), substituted “such college or university” for “such college”, “that college or university” for “that college”, and “other colleges or universities” for “other colleges”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/12"},"text":"Pub. L. 105–244, § 901(b)(12)","children":[],"tail":", substituted “the college or university” for “the college”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s383/1"},"text":"Pub. L. 103–382, § 383(1)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1065"},"text":"section 1065 of title 20","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1065a"},"text":"section 1065a of title 20","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s383/2/A"},"text":"Pub. L. 103–382, § 383(2)(A)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “provides for the establishment and maintenance of a trust fund at a federally insured banking or savings institution;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s383/2/B"},"text":"Pub. L. 103–382, § 383(2)(B)","children":[],"tail":", struck out “same” before “banking or savings institution”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/477/s1/d/1/A"},"text":"Pub. L. 101–477, § 1(d)(1)(A)","children":[],"tail":", substituted “(or of a value) equal to half of” for “equal to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/477/s1/d/1/B"},"text":"Pub. L. 101–477, § 1(d)(1)(B)","children":[],"tail":", substituted “an amount of Federal capital contribution equal to twice the amount of (or value of) such withdrawal” for “an equal amount of Federal capital contribution”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6280b2ad-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6280b2ae-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6280b2af-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/477/s1/d/2"},"text":"Pub. L. 101–477, § 1(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-30"},"text":"Oct. 30, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1153"},"text":"104 Stat. 1153","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/477/s1/d/2"},"text":"“The amendments made by paragraphs (A) through (E) of subsection (a) [probably means subpars. (A) to (E) of subsec. (d)(1), amending this section and sections 1834 and 1835 of this title] shall take effect ","children":[{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
