{"tag":"section","attrib":{"id":"id62bc5c80-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3408"},"text":null,"children":[{"tag":"num","attrib":{"value":"3408"},"text":"§ 3408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Job creation activities authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62bc5c81-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan submitted by a tribal government may involve the expenditure of funds for the creation of employment opportunities and for the development of the economic resources of the tribal government or of individual Indian people if such expenditures are consistent with an overall regional economic activity which has a reasonable likelihood of success and consistent with the purposes specifically applicable to Indian programs in the statute under which the funds are authorized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5c82-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Job creation opportunities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5c83-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3408/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provisions of law, including any requirement of a program that is integrated under a plan under this chapter, a tribal government may use a percentage of the funds made available under this chapter (as determined under paragraph (2)) for the creation of employment opportunities, including providing private sector training placement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3409"},"text":"section 3409 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c84-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3408/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of percentage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The percentage of funds that a tribal government may use under this subsection is the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62bc5c85-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3408/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of unemployment in the service area of the tribe up to a maximum of 25 percent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5c86-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3408/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5c87-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3408/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funds used for an expenditure described in subsection (a) may only include funds made available to the Indian tribe by a Federal agency under a statutory or administrative formula.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62bc5c88-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/477/s9"},"text":"Pub. L. 102–477, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2303"},"text":"106 Stat. 2303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tXI/s1103/e"},"text":"Pub. L. 106–568, title XI, § 1103(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2932"},"text":"114 Stat. 2932","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62bc5c89-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62bc5c8a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62bc5c8b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568"},"text":"Pub. L. 106–568","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
