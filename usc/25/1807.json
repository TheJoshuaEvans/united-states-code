{"tag":"section","attrib":{"id":"id627e6910-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1807"},"text":null,"children":[{"tag":"num","attrib":{"value":"1807"},"text":"§ 1807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to tribally controlled colleges or universities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id627e6911-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1807/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of applications; necessity of eligibility study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants shall be made under this subchapter only in response to applications by tribally controlled colleges or universities. Such applications shall be submitted at such time, in such manner, and will contain or be accompanied by such information as the Secretary may reasonably require pursuant to regulations. Such application shall include a description of recordkeeping procedures for the expenditure of funds received under this chapter which will allow the Secretary to audit and monitor programs conducted with such funds. The Secretary shall not consider any grant application unless a ","children":[{"tag":"ref","attrib":{"idref":"fn002107"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002107"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “an”."}],"tail":" eligibility study has been conducted under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1806"},"text":"section 1806 of this title","children":[],"tail":" and it has been found that the applying college or university will service a reasonable student population."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627e6912-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1807/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of support; factors considered","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Secretary of Education to determine the reasonable number of students required to support a tribally controlled college or university. Consideration shall be given to such factors as tribal and cultural differences, isolation, the presence of alternate education sources, and proposed curriculum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627e6913-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1807/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority and number of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Priority in grants shall be given to institutions which are operating on ","children":[{"tag":"date","attrib":{"date":"1978-10-17"},"text":"October 17, 1978","children":[],"tail":", and which have a history of service to the Indian people. In the first year for which funds are appropriated to carry out this section, the number of grants shall be limited to not less than eight nor more than fifteen."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627e6914-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1807/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with national Indian organizations and tribal governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants pursuant to this section, the Secretary shall, to the extent practicable, consult with national Indian organizations and with tribal governments chartering the institutions being considered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id627e6915-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/tI/s107"},"text":"Pub. L. 95–471, title I, § 107","children":[],"tail":", formerly § 106, "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1327"},"text":"92 Stat. 1327","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/375/tI/s108/c"},"text":"Pub. L. 97–375, title I, § 108(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1820"},"text":"96 Stat. 1820","children":[],"tail":"; renumbered § 107 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/192"},"text":"Pub. L. 98–192","children":[],"tail":", §§ 3(b), 4(a)(1), (b)(2), 6(b), "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1336"},"text":"97 Stat. 1336","children":[],"tail":", 1337; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s901/b/4"},"text":"Pub. L. 105–244, title IX, § 901(b)(4)","children":[],"tail":"–(6), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1828"},"text":"112 Stat. 1828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id627e6916-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id627e6917-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id627e6918-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/4"},"text":"Pub. L. 105–244, § 901(b)(4)","children":[],"tail":", substituted “colleges or universities” for “community colleges” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/5"},"text":"Pub. L. 105–244, § 901(b)(5)","children":[],"tail":", (6), substituted “colleges or universities” for “community colleges” and “college or university” for “community college”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/5"},"text":"Pub. L. 105–244, § 901(b)(5)","children":[],"tail":", substituted “college or university” for “community college”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192/s6/b/1"},"text":"Pub. L. 98–192, § 6(b)(1)","children":[],"tail":", substituted “eligibility” for “feasibility”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192/s4/b/2"},"text":"Pub. L. 98–192, § 4(b)(2)","children":[],"tail":", made a technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1806"},"text":"section 1806 of this title","children":[],"tail":" to reflect renumbering of that section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192/s3/b"},"text":"Pub. L. 98–192, § 3(b)","children":[],"tail":", inserted provision that such application include a description of the recordkeeping procedures for expenditure of funds as will allow Secretary to audit and monitor programs conducted with such funds."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192/s6/b/2"},"text":"Pub. L. 98–192, § 6(b)(2)","children":[],"tail":", substituted “Secretary of Education” for “Assistant Secretary of Education of the Department of Health, Education, and Welfare”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/375"},"text":"Pub. L. 97–375","children":[],"tail":" struck out subsec. (e) which directed the Secretary to report to Congress on Jan. 15 of each year the current status of tribally controlled community colleges and his recommendations for needed action."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id627e6919-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id627e691a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
