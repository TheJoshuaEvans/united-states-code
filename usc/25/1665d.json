{"tag":"section","attrib":{"id":"id62728157-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1665d"},"text":"§ 1665d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mental health technician program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62728158-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":", the Secretary shall establish and maintain a mental health technician program within the Service which—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62728159-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for the training of Indians as mental health technicians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6272815a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employs such technicians in the provision of community-based mental health care that includes identification, prevention, education, referral, and treatment services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6272815b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paraprofessional training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (a), the Secretary, acting through the Service, shall provide high-standard paraprofessional training in mental health care necessary to provide quality care to the Indian communities to be served. Such training shall be based upon a curriculum developed or approved by the Secretary which combines education in the theory of mental health care with supervised practical experience in the provision of such care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6272815c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision and evaluation of technicians","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, shall supervise and evaluate the mental health technicians in the training program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6272815d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Traditional health care practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, shall ensure that the program established pursuant to this section involves the use and promotion of the traditional health care practices of the Indian tribes to be served.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6272815e-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s705"},"text":"Pub. L. 94–437, title VII, § 705","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6272815f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62728160-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62728161-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s705"},"text":"Section 705 of Pub. L. 94–437","children":[],"tail":" is based on section 181 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62728162-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1665d, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s705"},"text":"Pub. L. 94–437, title VII, § 705","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s702/a"},"text":"Pub. L. 102–573, title VII, § 702(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4576"},"text":"106 Stat. 4576","children":[],"tail":", provided for program of training and community education about alcohol and substance abuse, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
