{"tag":"section","attrib":{"id":"id62c843c6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4027"},"text":null,"children":[{"tag":"num","attrib":{"value":"4027"},"text":"§ 4027.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"By submitting or approving a plan under this subchapter, neither the tribe nor the Secretary shall be deemed to have accepted the account balance as accurate or to have waived any rights regarding such balance and to seek compensation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62c843c7-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/412/tII/s207"},"text":"Pub. L. 103–412, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4243"},"text":"108 Stat. 4243","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
