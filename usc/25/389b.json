{"tag":"section","attrib":{"id":"id62346730-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s389b"},"text":null,"children":[{"tag":"num","attrib":{"value":"389b"},"text":"§ 389b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elimination to permanently nonirrigable lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where the Secretary finds that any such lands are permanently nonirrigable he may, with the consent of the landowner, eliminate such lands from the project.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62346731-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-22/ch692/s3"},"text":"June 22, 1936, ch. 692, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1804"},"text":"49 Stat. 1804","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
