{"tag":"section","attrib":{"id":"id625cfe21-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1616e"},"text":"§ 1616e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nursing program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id625cfe22-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Service, shall provide grants to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625cfe23-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public or private schools of nursing,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe24-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribally controlled community colleges and tribally controlled postsecondary vocational institutions (as defined in section 2397h(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002038"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002038"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 20), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe25-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nurse midwife programs, and nurse practitioner programs, that are provided by any public or private institution,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for the purpose of increasing the number of nurses, nurse midwives, and nurse practitioners who deliver health care services to Indians.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe26-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants provided under subsection (a) may be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625cfe27-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruit individuals for programs which train individuals to be nurses, nurse midwives, or nurse practitioners,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe28-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide scholarships to individuals enrolled in such programs that may pay the tuition charged for such program and other expenses incurred in connection with such program, including books, fees, room and board, and stipends for living expenses,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe29-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a program that encourages nurses, nurse midwives, and nurse practitioners to provide, or continue to provide, health care services to Indians,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe2a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a program that increases the skills of, and provides continuing education to, nurses, nurse midwives, and nurse practitioners, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe2b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide any program that is designed to achieve the purpose described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe2c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each application for a grant under subsection (a) shall include such information as the Secretary may require to establish the connection between the program of the applicant and a health care facility that primarily serves Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe2d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing grants under subsection (a), the Secretary shall extend a preference to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625cfe2e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that provide a preference to Indians,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe2f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that train nurse midwives or nurse practitioners,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe30-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that are interdisciplinary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe31-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that are conducted in cooperation with a center for gifted and talented Indian students established under section 2624(a) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe32-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quentin N. Burdick American Indians Into Nursing Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide one of the grants authorized under subsection (a) to establish and maintain a program at the University of North Dakota to be known as the “Quentin N. Burdick American Indians Into Nursing Program”. Such program shall, to the maximum extent feasible, coordinate with the Quentin N. Burdick Indian Health Programs established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1616g/b"},"text":"section 1616g(b) of this title","children":[],"tail":" and the Quentin N. Burdick American Indians Into Psychology Program established under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1621p/b"},"text":"section 1621p(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe33-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service obligation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The active duty service obligation prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254m"},"text":"section 254m of title 42","children":[],"tail":" shall be met by each individual who receives training or assistance described in paragraph (1) or (2) of subsection (b) that is funded by a grant provided under subsection (a). Such obligation shall be met by service—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id625cfe34-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/f/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the Indian Health Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625cfe35-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/f/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a program conducted under a contract entered into under the Indian Self-Determination Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625cfe36-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/f/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a program assisted under subchapter IV of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625cfe37-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/f/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the private practice of nursing if, as determined by the Secretary, in accordance with guidelines promulgated by the Secretary, such practice is situated in a physician or other health professional shortage area and addresses the health care needs of a substantial number of Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe38-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning with fiscal year 1993, of the amounts appropriated under the authority of this subchapter for each fiscal year to be used to carry out this section, not less than $1,000,000 shall be used to provide grants under subsection (a) for the training of nurse midwives, nurse anesthetists, and nurse practitioners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id625cfe39-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tI/s112"},"text":"Pub. L. 94–437, title I, § 112","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tI/s108"},"text":"Pub. L. 100–713, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4795"},"text":"102 Stat. 4795","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tI"},"text":"Pub. L. 102–573, title I","children":[],"tail":", §§ 104(b), (c), 114(a), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4533"},"text":"106 Stat. 4533","children":[],"tail":", 4543.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id625cfe3a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id625cfe3b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id625cfe3c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2397h"},"text":"Section 2397h of title 20","children":[],"tail":", referred to in subsec. (a)(2), was omitted in the general amendment of chapter 44 (§ 2301 et seq.) of Title 20, Education, by "},{"tag":"ref","attrib":{"href":"/us/pl/105/332/s1/b"},"text":"Pub. L. 105–332, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3076"},"text":"112 Stat. 3076","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2624"},"text":"Section 2624 of this title","children":[],"tail":", referred to in subsec. (d)(4), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s367"},"text":"Pub. L. 103–382, title III, § 367","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3976"},"text":"108 Stat. 3976","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination Act, referred to in subsec. (f)(B), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2206"},"text":"88 Stat. 2206","children":[],"tail":", which is classified principally to subchapter I (§ 5321 et seq.) of chapter 46 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id625cfe3d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s114/a"},"text":"Pub. L. 102–573, § 114(a)","children":[],"tail":", inserted “and tribally controlled postsecondary vocational institutions (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2397h/2"},"text":"section 2397h(2) of title 20","children":[],"tail":")” after “community colleges”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s104/b"},"text":"Pub. L. 102–573, § 104(b)","children":[],"tail":", added subsec. (e) and redesignated former subsec. (e) as (f). Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s104/c"},"text":"Pub. L. 102–573, § 104(c)","children":[],"tail":", amended subsec. (g) generally. Prior to amendment, subsec. (g) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) There are authorized to be appropriated for each of the fiscal years 1990, 1991, and 1992, $5,000,000 for the purpose of carrying out the provisions of this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Of the amounts appropriated under the authority of paragraph (1) for each fiscal year, the Secretary shall use at least $1,000,000 to provide grants under subsection (a) for the training of nurse midwives.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s104/b/1"},"text":"Pub. L. 102–573, § 104(b)(1)","children":[],"tail":", redesignated subsec. (f) as (g)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
