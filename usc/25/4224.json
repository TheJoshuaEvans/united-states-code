{"tag":"section","attrib":{"id":"id62d429ea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224"},"text":null,"children":[{"tag":"num","attrib":{"value":"4224"},"text":"§ 4224.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d429eb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and notice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d429ec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d429ed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a review of a housing plan submitted to the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":" to ensure that the plan complies with the requirements of that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d429ee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall have the discretion to review a plan referred to in subparagraph (A) only to the extent that the Secretary considers that the review is necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d429ef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d429f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after receiving a plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":", the Secretary shall notify the Director of the Department of Hawaiian Home Lands whether the plan complies with the requirements under that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d429f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of failure of Secretary to take action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, if the Secretary does not notify the Director, as required under this subsection and subsection (b), upon the expiration of the 60-day period described in subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d429f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan shall be considered to have been determined to comply with the requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d429f3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director shall be considered to have been notified of compliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d429f4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of reasons for determination of noncompliance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that a plan submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":" does not comply with the requirements of that section, the Secretary shall specify in the notice under subsection (a)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d429f5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons for noncompliance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d429f6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any modifications necessary for the plan to meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d429f7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d429f8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After the Director of the Department of Hawaiian Home Lands submits a housing plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":", or any amendment or modification to the plan to the Secretary, to the extent that the Secretary considers such action to be necessary to make a determination under this subsection, the Secretary shall review the plan (including any amendments or modifications thereto) to determine whether the contents of the plan—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d429f9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the information required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":" to be contained in the housing plan;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d429fa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with information and data available to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d429fb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not prohibited by or inconsistent with any provision of this chapter or any other applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d429fc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incomplete plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines under this subsection that any of the appropriate certifications required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223/c/2/E"},"text":"section 4223(c)(2)(E) of this title","children":[],"tail":" are not included in a plan, the plan shall be considered to be incomplete."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d429fd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates to plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d429fe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), after a plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":" has been submitted for a fiscal year, the Director of the Department of Hawaiian Home Lands may comply with the provisions of that section for any succeeding fiscal year (with respect to information included for the 5-year period under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223/b"},"text":"section 4223(b) of this title","children":[],"tail":" or for the 1-year period under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223/c"},"text":"section 4223(c) of this title","children":[],"tail":") by submitting only such information regarding such changes as may be necessary to update the plan previously submitted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d429ff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complete plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall submit a complete plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":" not later than 4 years after submitting an initial plan under that section, and not less frequently than every 4 years thereafter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42a00-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4224/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":" shall take effect on the date provided by the Secretary pursuant to section 4227(a) "},{"tag":"ref","attrib":{"idref":"fn002243"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002243"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “4227”."}],"tail":" of this title to provide for timely submission and review of the housing plan as necessary for the provision of assistance under this subchapter for fiscal year 2001."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d42a01-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s804"},"text":"Pub. L. 104–330, title VIII, § 804","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s203"},"text":"Pub. L. 106–568, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2881"},"text":"114 Stat. 2881","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s513"},"text":"Pub. L. 106–569, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2975"},"text":"114 Stat. 2975","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d42a02-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d42a03-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62d42a04-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c)(1)(C), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", known as the Native American Housing Assistance and Self-Determination Act of 1996. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62d42a05-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s203"},"text":"Pub. L. 106–568, § 203","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":", enacted substantially identical sections 804 of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":". This section is based on the text of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s804"},"text":"section 804 of Pub. L. 104–330","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
