{"tag":"section","attrib":{"id":"id62bc5c8c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3409"},"text":null,"children":[{"tag":"num","attrib":{"value":"3409"},"text":"§ 3409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer training placements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62bc5c8d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3409/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), an Indian tribe that has in place an approved plan under this chapter may use the funds made available for the plan under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5c8e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3409/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to place participants in training positions with employers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c8f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3409/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay the participants a training allowance or wage for a training period of not more than 24 months, which may be nonconsecutive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5c90-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3409/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Indian tribe may carry out subsection (a) only if the Indian tribe enters into a written agreement with each applicable employer under which the employer shall agree—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5c91-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3409/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide on-the-job training to the participants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c92-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3409/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on satisfactory completion of the training period described in subsection (a)(2), to prioritize the provision of permanent employment to the participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62bc5c93-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/477/s10"},"text":"Pub. L. 102–477, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2304"},"text":"106 Stat. 2304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/93/s10"},"text":"Pub. L. 115–93, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-18"},"text":"Dec. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2032"},"text":"131 Stat. 2032","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62bc5c94-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62bc5c95-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62bc5c96-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/93"},"text":"Pub. L. 115–93","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “A tribal government participating in a demonstration program under this chapter is authorized to utilize funds available under such plan to place participants in training positions with private employers and pay such participants a training allowance or wage for a period not to exceed 12 months, if the tribal government obtains a written agreement from the private employer to provide on-the-job training to such participants and, upon satisfactory completion of the training period, to guarantee permanent employment to such participants for a minimum of 12 months.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
