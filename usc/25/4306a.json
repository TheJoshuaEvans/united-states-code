{"tag":"section","attrib":{"id":"id62d69afe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4306a"},"text":"§ 4306a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian community development initiatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d69aff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-30"},"text":"December 30, 2020","children":[],"tail":", the Secretary, the Secretary of the Interior, and the Secretary of the Treasury shall coordinate—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d69b00-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to develop initiatives that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d69b01-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" encourage, promote, and provide education regarding investments in Indian communities through—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d69b02-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan guarantee program of Bureau of Indian Affairs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1481"},"text":"section 1481 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d69b03-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs carried out using amounts in the Community Development Financial Institutions Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4703/a"},"text":"section 4703(a) of title 12","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d69b04-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other capital development programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69b05-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine and develop alternatives that would qualify as collateral for financing in Indian communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69b06-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide entrepreneur and other training relating to economic development through tribally controlled colleges and universities and other Indian organizations with experience in providing such training;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69b07-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to consult with Indian Tribes and with the Securities and Exchange Commission to study, and collaborate to establish, regulatory changes necessary to qualify an Indian Tribe as an accredited investor for the purposes of sections 230.500 through 230.508 of title 17, Code of Federal Regulations (or successor regulations), consistent with the goals of promoting capital formation and ensuring qualifying Indian Tribes have the ability to withstand investment loss, on a basis comparable to other legal entities that qualify as accredited investors who are not natural persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69b08-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify regulatory, legal, or other barriers to increasing investment, business, and economic development, including qualifying or approving collateral structures, measurements of economic strength, and contributions of Indian economies in Indian communities through the Authority established under section 4 of the Indian Tribal Regulatory Reform and Business Development Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4301"},"text":"25 U.S.C. 4301","children":[],"tail":" note);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69b09-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure consultation with Indian Tribes regarding increasing investment in Indian communities and the development of the report required in paragraph (5); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69b0a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not less than once every 2 years, to provide a report to Congress regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d69b0b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvements to Indian communities resulting from such initiatives and recommendations for promoting sustained growth of the Tribal economies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69b0c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results of the study and collaboration regarding the necessary changes referenced in paragraph (2) and the impact of allowing Indian Tribes to qualify as an accredited investor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69b0d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identified regulatory, legal, and other barriers referenced in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d69b0e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For assistance provided pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4707"},"text":"section 4707 of title 12","children":[],"tail":" to benefit Native Community Development Financial Institutions, as defined by the Secretary of the Treasury, section 4707(e) of such title shall not apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d69b0f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Economic Development Feasibility Study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d69b10-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Government Accountability Office shall conduct a study and, not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2020-12-30"},"text":"December 30, 2020","children":[],"tail":", submit to the Committee on Indian Affairs of the Senate and the Committee on Natural Resources of the House of Representatives a report on the findings of the study and recommendations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69b11-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study shall include an assessment of each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d69b12-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The study shall assess current Federal capitalization and related programs and services that are available to assist Indian communities with business and economic development, including manufacturing, physical infrastructure (such as telecommunications and broadband), community development, and facilities construction for such purposes. For each of the Federal programs and services identified, the study shall assess the current use and demand by Indian Tribes, individuals, businesses, and communities of the programs, the capital needs of Indian Tribes, businesses, and communities related to economic development, the extent to which the programs and services overlap or are duplicative, and the extent that similar programs have been used to assist non-Indian communities compared to the extent used for Indian communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69b13-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financing assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study shall assess and quantify the extent of assistance provided to non-Indian borrowers and to Indian (both Tribal and individual) borrowers (including information about such assistance as a percentage of need for Indian borrowers and for non-Indian borrowers, assistance to Indian borrowers and to non-Indian borrowers as a percentage of total applicants, and such assistance to Indian borrowers as individuals as compared to such assistance to Indian Tribes) through the loan programs, the loan guarantee programs, or bond guarantee programs of the—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d69b14-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d69b15-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d69b16-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Housing and Urban Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d69b17-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d69b18-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Small Business Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d69b19-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Community Development Financial Institutions Fund of the Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69b1a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax incentives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study shall assess and quantify the extent of the assistance and allocations afforded for non-Indian projects and for Indian projects pursuant to each of the following tax incentive programs:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d69b1b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" New market tax credit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d69b1c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Low income housing tax credit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d69b1d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Investment tax credit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d69b1e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Renewable energy tax incentives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d69b1f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Accelerated depreciation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d69b20-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4306a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal investment incentive","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The study shall assess various alternative incentives that could be provided to enable and encourage Tribal governments to invest in an Indian community development investment fund or bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d69b21-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/464/s8"},"text":"Pub. L. 106–464, § 8","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/261/s3/d/2"},"text":"Pub. L. 116–261, § 3(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-30"},"text":"Dec. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3308"},"text":"134 Stat. 3308","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d90b22-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d90b23-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62d90b24-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4 of the Indian Tribal Regulatory Reform and Business Development Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4301"},"text":"25 U.S.C. 4301","children":[],"tail":" note), referred to in subsec. (a)(3), is "},{"tag":"ref","attrib":{"href":"/us/pl/106/447/s4"},"text":"section 4 of Pub. L. 106–447","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62d90b25-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/464/s8"},"text":"section 8 of Pub. L. 106–464","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4307"},"text":"section 4307 of this title","children":[],"tail":", was redesignated "},{"tag":"ref","attrib":{"href":"/us/pl/106/464/s10"},"text":"section 10 of Pub. L. 106–464","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/116/261/s3/d/1"},"text":"Pub. L. 116–261, § 3(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-30"},"text":"Dec. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3308"},"text":"134 Stat. 3308","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
