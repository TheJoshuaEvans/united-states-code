{"tag":"section","attrib":{"id":"id6236d8bb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s402"},"text":null,"children":[{"tag":"num","attrib":{"value":"402"},"text":"§ 402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leases of surplus lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The surplus lands of any tribe may be leased for farming purposes by the council of such tribe under the same rules and regulations and for the same term of years as was on ","children":[{"tag":"date","attrib":{"date":"1894-08-15"},"text":"August 15, 1894","children":[],"tail":", allowed in the case of leases for grazing purposes."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6236d8bc-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1894-08-15/ch290/s1"},"text":"Aug. 15, 1894, ch. 290, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/305"},"text":"28 Stat. 305","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
