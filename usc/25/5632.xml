<section xmlns="http://xml.house.gov/schemas/uslm/1.0" style="-uslm-lc:I80" id="id62f59491-4962-11f1-add1-b56d3fa293fa" identifier="/us/usc/t25/s5632"><num value="5632">§ 5632.</num><heading> Definitions</heading>
<chapeau style="-uslm-lc:I11" class="indent0">In this subchapter:</chapeau><paragraph style="-uslm-lc:I79" class="indent3 firstIndent-2" id="id62f59492-4962-11f1-add1-b56d3fa293fa" identifier="/us/usc/t25/s5632/1"><num value="1" class="bold">(1)</num><heading class="bold"> BIA</heading><content><p style="-uslm-lc:I12" class="indent1">The term “BIA” means the Bureau of Indian Affairs.</p>
</content>
</paragraph>
<paragraph style="-uslm-lc:I79" class="indent3 firstIndent-2" id="id62f59493-4962-11f1-add1-b56d3fa293fa" identifier="/us/usc/t25/s5632/2"><num value="2" class="bold">(2)</num><heading class="bold"> Department</heading><content><p style="-uslm-lc:I12" class="indent1">The term “Department” means the Department of the Interior.</p>
</content>
</paragraph>
<paragraph style="-uslm-lc:I79" class="indent3 firstIndent-2" id="id62f59494-4962-11f1-add1-b56d3fa293fa" identifier="/us/usc/t25/s5632/3"><num value="3" class="bold">(3)</num><heading class="bold"> Secretary</heading><content><p style="-uslm-lc:I12" class="indent1">The term “Secretary” means the Secretary of the Interior.</p>
</content>
</paragraph>
<paragraph style="-uslm-lc:I79" class="indent3 firstIndent-2" id="id62f59495-4962-11f1-add1-b56d3fa293fa" identifier="/us/usc/t25/s5632/4"><num value="4" class="bold">(4)</num><heading class="bold"> Under Secretary</heading><content><p style="-uslm-lc:I12" class="indent1">The term “Under Secretary” means the Under Secretary for Indian Affairs established under <ref href="/us/usc/t25/s5633/a">section 5633(a) of this title</ref>.</p>
</content>
</paragraph>
<sourceCredit id="id62f59496-4962-11f1-add1-b56d3fa293fa">(<ref href="/us/pl/114/178/tIII/s302">Pub. L. 114–178, title III, § 302</ref>, <date date="2016-06-22">June 22, 2016</date>, <ref href="/us/stat/130/439">130 Stat. 439</ref>.)</sourceCredit>
</section>
