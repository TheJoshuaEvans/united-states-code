{"tag":"section","attrib":{"id":"id62642a4a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1621j"},"text":"§ 1621j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" California contract health services demonstration program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62642a4b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a demonstration program to evaluate the use of a contract care intermediary to improve the accessibility of health services to California Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62642a4c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement with California Rural Indian Health Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62642a4d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In establishing such program, the Secretary shall enter into an agreement with the California Rural Indian Health Board to reimburse the Board for costs (including reasonable administrative costs) incurred, during the period of the demonstration program, in providing medical treatment under contract to California Indians described in section 1679(b) ","children":[{"tag":"ref","attrib":{"idref":"fn002051"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002051"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title throughout the California contract health services delivery area described in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1680"},"text":"section 1680 of this title","children":[],"tail":" with respect to high-cost contract care cases."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a4e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 5 percent of the amounts provided to the Board under this section for any fiscal year may be for reimbursement for administrative expenses incurred by the Board during such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a4f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621j/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No payment may be made for treatment provided under the demonstration program to the extent payment may be made for such treatment under the Catastrophic Health Emergency Fund described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1621a"},"text":"section 1621a of this title","children":[],"tail":" or from amounts appropriated or otherwise made available to the California contract health service delivery area for a fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62642a50-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established an advisory board which shall advise the California Rural Indian Health Board in carrying out the demonstration pursuant to this section. The advisory board shall be composed of representatives, selected by the California Rural Indian Health Board, from not less than 8 tribal health programs serving California Indians covered under such demonstration, at least one half of whom are not affiliated with the California Rural Indian Health Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62642a51-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement and termination dates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The demonstration program described in this section shall begin on ","children":[{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":", and shall terminate on "},{"tag":"date","attrib":{"date":"1997-09-30"},"text":"September 30, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62642a52-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621j/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1998-07-01"},"text":"July 1, 1998","children":[],"tail":", the California Rural Indian Health Board shall submit to the Secretary a report on the demonstration program carried out under this section, including a statement of its findings regarding the impact of using a contract care intermediary on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62642a53-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621j/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to needed health services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a54-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621j/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waiting periods for receiving such services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a55-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621j/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efficient management of high-cost contract care cases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62642a56-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621j/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “High-cost contract care cases” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, the term “high-cost contract care cases” means those cases in which the cost of the medical treatment provided to an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62642a57-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621j/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would otherwise be eligible for reimbursement from the Catastrophic Health Emergency Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1621a"},"text":"section 1621a of this title","children":[],"tail":", except that the cost of such treatment does not meet the threshold cost requirement established pursuant to section 1621a(b)(2) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62642a58-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621j/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exceeds $1,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62642a59-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tII/s211"},"text":"Pub. L. 94–437, title II, § 211","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tII/s206/c"},"text":"Pub. L. 102–573, title II, § 206(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4549"},"text":"106 Stat. 4549","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/313/s2/c"},"text":"Pub. L. 104–313, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3822"},"text":"110 Stat. 3822","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62642a5a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62642a5b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62642a5c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1679"},"text":"Section 1679 of this title","children":[],"tail":", referred to in subsec. (b)(1), was repealed and a new section 1679 was enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":". Provisions describing California Indians, similar to those that appeared in former section 1679(b) are now contained in new section 1679(a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1621a"},"text":"Section 1621a of this title","children":[],"tail":", referred to in subsec. (f)(1), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":", and, as so amended, no longer contains a subsec. (b)(2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62642a5d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" is based on section 101(b)(3) of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62642a5e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" struck out subsec. (g) which authorized appropriations for fiscal years 1996 through 2000."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/313"},"text":"Pub. L. 104–313","children":[],"tail":" substituted “1996 through 2000” for “1993, 1994, 1995, 1996, and 1997”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62642a5f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62642a60-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Boards","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory boards established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a board established by the President or an officer of the Federal Government, such board is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a board established by Congress, its duration is otherwise provided by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
