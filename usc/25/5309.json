{"tag":"section","attrib":{"id":"id62e03794-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5309"},"text":null,"children":[{"tag":"num","attrib":{"value":"5309"},"text":"§ 5309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of excess funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Beginning in fiscal year 1998 and thereafter, where the actual costs of construction projects under self-determination contracts, compacts, or grants, pursuant to Public Laws 93–638, 103–413, or 100–297, are less than the estimated costs thereof, use of the resulting excess funds shall be determined by the appropriate Secretary after consultation with the tribes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62e03795-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/83/tIII/s310"},"text":"Pub. L. 105–83, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-14"},"text":"Nov. 14, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1590"},"text":"111 Stat. 1590","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62e03796-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62e03797-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62e03798-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Public Law 93–638","children":[],"tail":", referre