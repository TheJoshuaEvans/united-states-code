{"tag":"section","attrib":{"id":"id6268e596-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1638f"},"text":"§ 1638f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian country modular component facilities demonstration program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6268e597-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of modular component health care facility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “modular component health care facility” means a health care facility that is constructed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6268e598-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" off-site using prefabricated component units for subsequent transport to the destination location; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e599-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represents ","children":[{"tag":"ref","attrib":{"idref":"fn002068"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002068"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" a more economical method for provision of health care facility "},{"tag":"ref","attrib":{"idref":"fn002069"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002069"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “provision of a health care facility”."}],"tail":" than a traditionally constructed health care building."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6268e59a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, shall establish a demonstration program under which the Secretary shall award no less than 3 grants for purchase, installation and maintenance of modular component health care facilities in Indian communities for provision of health care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6268e59b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of locations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6268e59c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petitions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6268e59d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall solicit from Indian tribes petitions for location of the modular component health care facilities in the Service areas of the petitioning Indian tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6268e59e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, an Indian tribe or tribal organization must submit to the Secretary a petition to construct a modular component health care facility in the Indian community of the Indian tribe, at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e59f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting the location of each modular component health care facility to be provided under the demonstration program, the Secretary shall give priority to projects already on the Indian Health Service facilities construction priority list and petitions which demonstrate that erection of a modular component health facility—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6268e5a0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is more economical than construction of a traditionally constructed health care facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6268e5a1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can be constructed and erected on the selected location in less time than traditional construction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6268e5a2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can adequately house the health care services needed by the Indian population to be served.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e5a3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A modular component health care facility project selected for participation in the demonstration program shall not be eligible for entry on the facilities construction priorities list entitled “IHS Health Care Facilities FY 2011 Planned Construction Budget” and dated ","children":[{"tag":"date","attrib":{"date":"2009-05-07"},"text":"May 7, 2009","children":[],"tail":" (or any successor list)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6268e5a4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6268e5a5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian tribe may submit a petition under subsection (c)(1)(B) regardless of whether the Indian tribe is a party to any contract or compact under the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.)."},{"tag":"ref","attrib":{"idref":"fn002070"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002070"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e5a6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the election of an Indian tribe or tribal organization selected for participation in the demonstration program, the funds provided for the project shall be subject to the provisions of the Indian Self-Determination and Education Assistance Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6268e5a7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date on which funds are made available for the demonstration program and annually thereafter, the Secretary shall submit to Congress a report describing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6268e5a8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each activity carried out under the demonstration program, including an evaluation of the success of the activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6268e5a9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential benefits of increased use of modular component health care facilities in other Indian communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6268e5aa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1638f/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $50,000,000 to carry out the demonstration program under this section for the first 5 fiscal years, and such sums as may be necessary to carry out the program in subsequent fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6268e5ab-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tIII/s312"},"text":"Pub. L. 94–437, title III, § 312","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6268e5ac-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6268e5ad-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6268e5ae-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.), referred to in subsec. (d), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of this title prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6268e5af-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s312"},"text":"Section 312 of Pub. L. 94–437","children":[],"tail":" is based on section 146 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
