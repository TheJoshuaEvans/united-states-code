{"tag":"section","attrib":{"id":"id62c843a4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4022"},"text":null,"children":[{"tag":"num","attrib":{"value":"4022"},"text":"§ 4022.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary withdrawal from trust funds program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c843a5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4022/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian tribe may, in accordance with this section, submit a plan to withdraw some or all funds held in trust for such tribe by the United States and managed by the Secretary through the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c843a6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4022/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall approve such plan within 90 days of receipt and when approving the plan, the Secretary shall obtain the advice of the Special Trustee or prior to the appointment of such Special Trustee, the Director of the Office of Trust Fund Management within the Bureau. Such plan shall meet the following conditions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c843a7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4022/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such plan has been approved by the appropriate Indian tribe and is accompanied by a resolution from the tribal governing body approving the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c843a8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4022/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary determines such plan to be reasonable after considering all appropriate factors, including (but not limited to) the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62c843a9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4022/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The capability and experience of the individuals or institutions that will be managing the trust funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c843aa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4022/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The protection against substantial loss of principal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c843ab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4022/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissolution of trust responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on the date funds are withdrawn pursuant to this section, any trust responsibility or liability of the United States with respect to such funds shall cease except as provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4027"},"text":"section 4027 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c843ac-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/412/tII/s202"},"text":"Pub. L. 103–412, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4242"},"text":"108 Stat. 4242","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
