{"tag":"section","attrib":{"id":"id62b5306a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3106"},"text":null,"children":[{"tag":"num","attrib":{"value":"3106"},"text":"§ 3106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest trespass","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b5306b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties; regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months from ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":", the Secretary shall issue regulations that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b5306c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish civil penalties for the commission of forest trespass which provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b5306d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3106/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collection of the value of the products illegally removed plus a penalty of double their value,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b5306e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3106/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collection of the costs associated with damage to the Indian forest land caused by the act of trespass, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b5306f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3106/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collection of the costs associated with enforcement of the regulations, including field examination and survey, damage appraisal, investigation assistance and reports, witness expenses, demand letters, court costs, and attorney fees;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53070-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate responsibility with the Department of the Interior for the detection and investigation of forest trespass; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53071-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3106/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth responsibilities and procedures for the assessment and collection of civil penalties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b53072-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proceeds of civil penalties collected under this section shall be treated as proceeds from the sale of forest products from the Indian forest lands upon which such trespass occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b53073-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concurrent jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Indian tribes which adopt the regulations promulgated by the Secretary pursuant to subsection (a) shall have concurrent civil jurisdiction to enforce the provisions of this section and the regulation promulgated thereunder. The Bureau of Indian Affairs and other agencies of the Federal Government shall, at the request of the tribe, defer to tribal prosecutions of forest trespass cases. Tribal court judgments regarding forest trespass shall be entitled to full faith and credit in Federal and State courts to the same extent as a Federal court judgment obtained under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b53074-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIII/s307"},"text":"Pub. L. 101–630, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4537"},"text":"104 Stat. 4537","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
