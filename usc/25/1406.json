{"tag":"section","attrib":{"id":"id62538895-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1406"},"text":null,"children":[{"tag":"num","attrib":{"value":"1406"},"text":"§ 1406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62538896-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1406/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate rules and regulations to implement this chapter no later than the end of the one hundred and eighty-day period beginning on ","children":[{"tag":"date","attrib":{"date":"1973-10-19"},"text":"October 19, 1973","children":[],"tail":". Among other things, such rules and regulations shall provide for adequate notice to all entities and persons who may receive funds under any Indian judgment of all relevant procedures pursuant to this chapter concerning any such judgment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62538897-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1406/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication in Federal Register","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No later than sixty days prior to the promulgation of such rules and regulations the Secretary shall publish the proposed rules and regulations in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62538898-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1406/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No later than thirty days prior to the promulgation of such rules and regulations, the Secretary shall provide, with adequate public notice, the opportunity for hearings on the proposed rules and regulations, once published, to all interested parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62538899-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/134/s6"},"text":"Pub. L. 93–134, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-19"},"text":"Oct. 19, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/468"},"text":"87 Stat. 468","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
