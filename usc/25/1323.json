{"tag":"section","attrib":{"id":"id62538836-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1323"},"text":null,"children":[{"tag":"num","attrib":{"value":"1323"},"text":"§ 1323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retrocession of jurisdiction by State","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62538837-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance by United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States is authorized to accept a retrocession by any State of all or any measure of the criminal or civil jurisdiction, or both, acquired by such State pursuant to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1162"},"text":"section 1162 of title 18","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1360"},"text":"section 1360 of title 28","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/act/1953-08-15/s7"},"text":"section 7 of the Act of August 15, 1953","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/67/588"},"text":"67 Stat. 588","children":[],"tail":"), as it was in effect prior to its repeal by subsection (b) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62538838-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeal of statutory provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1953-08-15/s7"},"text":"Section 7 of the Act of August 15, 1953","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/67/588"},"text":"67 Stat. 588","children":[],"tail":"), is hereby repealed, but such repeal shall not affect any cession of jurisdiction made pursuant to such section prior to its repeal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62538839-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284/tIV/s403"},"text":"Pub. L. 90–284, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/79"},"text":"82 Stat. 79","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6253883a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6253883b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6253883c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1953-08-15/s7"},"text":"Section 7 of the Act of August 15, 1953","children":[],"tail":", referred to in text, is section 7 of "},{"tag":"ref","attrib":{"href":"/us/act/1953-08-15/ch505"},"text":"act Aug. 15, 1953, ch. 505","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/588"},"text":"67 Stat. 588","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1360"},"text":"section 1360 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6253883d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"id6253883e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 11435. Designating Secretary of the Interior To Accept Retrocession of Jurisdiction by State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 11435, ","children":[{"tag":"date","attrib":{"date":"1968-11-21"},"text":"Nov. 21, 1968","children":[],"tail":", 33 F.R. 17339, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By virtue of the authority vested in me by section 465 of the Revised Statutes (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s9"},"text":"25 U.S.C. 9","children":[],"tail":") and as President of the United States, the Secretary of the Interior is hereby designated and empowered to exercise, without the approval, ratification, or other action of the President or of any other officer of the United States, any and all authority conferred upon the United States by "},{"tag":"ref","attrib":{"href":"/us/act/1968-04-11/s403/a"},"text":"Section 403(a) of the Act of April 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/79"},"text":"82 Stat. 79","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1323/a"},"text":"25 U.S.C. 1323(a)","children":[],"tail":"): "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That acceptance of retrocession of all or any measure of civil or criminal jurisdiction, or both, by the Secretary hereunder shall be effected by publication in the "},{"tag":"inline","attrib":{},"text":"Federal Register","children":[],"tail":" of a notice which shall specify the jurisdiction retroceded and the effective date of the retrocession: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That acceptance of such retrocession of criminal jurisdiction shall be effected only after consultation by the Secretary with the Attorney General."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Lyndon B. Johnson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
