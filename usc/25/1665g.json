37/s708"},"text":"Section 708 of Pub. L. 94–437","children":[],"tail":" is based on section 181 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id627281ac-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1665g, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s708"},"text":"Pub. L. 94–437, title VII, § 708","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s702/a"},"text":"Pub. L. 102–573, title VII, § 702(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4578"},"text":"106 Stat. 4578","children":[],"tail":", provided for grants to Indian tribes and tribal organizations to establish fetal alcohol syndrome and fetal alcohol effect programs, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
