{"tag":"section","attrib":{"id":"id6272817c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1665g"},"text":"§ 1665g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian youth program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6272817d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detoxification and rehabilitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1665a"},"text":"section 1665a of this title","children":[],"tail":", shall develop and implement a program for acute detoxification and treatment for Indian youths, including behavioral health services. The program shall include regional treatment centers designed to include detoxification and rehabilitation for both sexes on a referral basis and programs developed and implemented by Indian tribes or tribal organizations at the local level under the Indian Self-Determination and Education Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.)."},{"tag":"ref","attrib":{"idref":"fn002087"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002087"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" Regional centers shall be integrated with the intake and rehabilitation programs based in the referring Indian community."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6272817e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alcohol and substance abuse treatment centers or facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6272817f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62728180-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, shall construct, renovate, or, as necessary, purchase, and appropriately staff and operate, at least 1 youth regional treatment center or treatment network in each area under the jurisdiction of an area office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728181-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area office in California","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this subsection, the area office in California shall be considered to be 2 area offices, 1 office whose jurisdiction shall be considered to encompass the northern area of the State of California, and 1 office whose jurisdiction shall be considered to encompass the remainder of the State of California for the purpose of implementing California treatment networks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728182-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of staffing and operating such centers or facilities, funding shall be pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728183-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A youth treatment center constructed or purchased under this subsection shall be constructed or purchased at a location within the area described in paragraph (1) agreed upon (by appropriate tribal resolution) by a majority of the Indian tribes to be served by such center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728184-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific provision of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62728185-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this subchapter, the Secretary may, from amounts authorized to be appropriated for the purposes of carrying out this section, make funds available to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62728186-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Tanana Chiefs Conference, Incorporated, for the purpose of leasing, constructing, renovating, operating, and maintaining a residential youth treatment facility in Fairbanks, Alaska; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62728187-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Southeast Alaska Regional Health Corporation to staff and operate a residential youth treatment facility without regard to the proviso set forth in section 4(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of the Indian Self-Determination and Education Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"25 U.S.C. 450b","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"))."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728188-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of services to eligible youths","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until additional residential youth treatment facilities are established in Alaska pursuant to this section, the facilities specified in subparagraph (A) shall make every effort to provide services to all eligible Indian youths residing in Alaska.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62728189-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intermediate adolescent behavioral health services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6272818a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Service, may provide intermediate behavioral health services, which may, if feasible and appropriate, incorporate systems of care, to Indian children and adolescents, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6272818b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pretreatment assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272818c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inpatient, outpatient, and aftercare services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272818d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272818e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suicide prevention and crisis intervention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272818f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevention and treatment of mental illness and dysfunctional and self-destructive behavior, including child abuse and family violence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728190-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds provided under this subsection may be used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62728191-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to construct or renovate an existing health facility to provide intermediate behavioral health services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728192-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to hire behavioral health professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728193-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to staff, operate, and maintain an intermediate mental health facility, group home, sober housing, transitional housing or similar facilities, or youth shelter where intermediate behavioral health services are being provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728194-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make renovations and hire appropriate staff to convert existing hospital beds into adolescent psychiatric units; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728195-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for intensive home- and community-based services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728196-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, shall, in consultation with Indian tribes and tribal organizations, establish criteria for the review and approval of applications or proposals for funding made available pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62728197-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally owned structures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62728198-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with Indian tribes and tribal organizations, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62728199-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and use, where appropriate, federally owned structures suitable for local residential or regional behavioral health treatment for Indian youths; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272819a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish guidelines for determining the suitability of any such federally owned structure to be used for local residential or regional behavioral health treatment for Indian youths.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6272819b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions for use of structure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any structure described in paragraph (1) may be used under such terms and conditions as may be agreed upon by the Secretary and the agency having responsibility for the structure and any Indian tribe or tribal organization operating the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6272819c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rehabilitation and aftercare services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6272819d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, Indian tribes, or tribal organizations, in cooperation with the Secretary of the Interior, shall develop and implement within each Service unit, community-based rehabilitation and follow-up services for Indian youths who are having significant behavioral health problems, and require long-term treatment, community reintegration, and monitoring to support the Indian youths after their return to their home community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6272819e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Services under paragraph (1) shall be provided by trained staff within the community who can assist the Indian youths in their continuing development of self-image, positive problem-solving skills, and nonalcohol or substance abusing behaviors. Such staff may include alcohol and substance abuse counselors, mental health professionals, and other health professionals and paraprofessionals, including community health representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6272819f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of family in youth treatment program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing the treatment and other services to Indian youths authorized by this section, the Secretary, acting through the Service, shall provide for the inclusion of family members of such youths in the treatment programs or other services as may be appropriate. Not less than 10 percent of the funds appropriated for the purposes of carrying out subsection (e) shall be used for outpatient care of adult family members related to the treatment of an Indian youth under that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627281a0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multidrug abuse program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, shall provide, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1665a"},"text":"section 1665a of this title","children":[],"tail":", programs and services to prevent and treat the abuse of multiple forms of substances, including alcohol, drugs, inhalants, and tobacco, among Indian youths residing in Indian communities, on or near reservations, and in urban areas and provide appropriate mental health services to address the incidence of mental illness among such youths."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627281a1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian youth mental health","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Service, shall collect data for the report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1671"},"text":"section 1671 of this title","children":[],"tail":" with respect to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id627281a2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Indian youth who are being provided mental health services through the Service and tribal health programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627281a3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of, and costs associated with, the mental health services provided for Indian youth through the Service and tribal health programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627281a4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of youth referred to the Service or tribal health programs for mental health services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627281a5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Indian youth provided residential treatment for mental health and behavioral problems through the Service and tribal health programs, reported separately for on- and off-reservation facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627281a6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665g/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the services described in paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id627281a7-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s708"},"text":"Pub. L. 94–437, title VII, § 708","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id627281a8-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"