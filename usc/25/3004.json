{"tag":"section","attrib":{"id":"id62b0752c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3004"},"text":null,"children":[{"tag":"num","attrib":{"value":"3004"},"text":"§ 3004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summary for unassociated funerary objects, sacred objects, and cultural patrimony","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b0752d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal agency or museum which has possession or control over holdings or collections of Native American unassociated funerary objects, sacred objects, or objects of cultural patrimony shall provide a written summary of such objects based upon available information held by such agency or museum. The summary shall describe the scope of the collection, kinds of objects included, reference to geographical location, means and period of acquisition and cultural affiliation, where readily ascertainable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b0752e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b0752f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3004/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The summary required under subsection (a) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b07530-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3004/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in lieu of an object-by-object inventory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b07531-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3004/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" followed by consultation with tribal government and Native Hawaiian organization officials and traditional religious leaders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b07532-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3004/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completed by not later than the date that is 3 years after ","children":[{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b07533-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3004/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon request, Indian Tribes ","children":[{"tag":"ref","attrib":{"idref":"fn002198"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002198"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" and Native Hawaiian organizations shall have access to records, catalogues, relevant studies or other pertinent data for the limited purposes of determining the geographic origin, cultural affiliation, and basic facts surrounding acquisition and accession of Native American objects subject to this section. Such information shall be provided in a reasonable manner to be agreed upon by all parties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b07534-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/601/s6"},"text":"Pub. L. 101–601, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3053"},"text":"104 Stat. 3053","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
