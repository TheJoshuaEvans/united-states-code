{"tag":"section","attrib":{"id":"id6280b234-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1810"},"text":null,"children":[{"tag":"num","attrib":{"value":"1810"},"text":"§ 1810.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6280b235-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1810/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6280b236-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1810/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated, for the purpose of carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1805"},"text":"section 1805 of this title","children":[],"tail":", $3,200,000 for fiscal year 2009 and such sums as may be necessary for each of the five succeeding fiscal years."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6280b237-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1810/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated for the purpose of carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1807"},"text":"section 1807 of this title","children":[],"tail":", such sums as may be necessary for fiscal year 2009 and such sums as may be necessary for each of the five succeeding fiscal years."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6280b238-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1810/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated for the purpose of carrying out sections 1812(b) and 1813 of this title, such sums as may be necessary for fiscal year 2009 and such sums as may be necessary for each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6280b239-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1810/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds appropriated pursuant to the authorizations under this section for the fiscal year 2009 and for each of the five succeeding fiscal years shall be transferred by the Secretary of the Treasury through the most expeditious method available, with each of the tribally controlled colleges or universities being designated as its own certifying agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6280b23a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1810/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6280b23b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1810/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of affording adequate notice of funding available under this chapter, amounts appropriated in an appropriation Act for any fiscal year to carry out this chapter shall become available for obligation on July 1 of that fiscal year and shall remain available until September 30 of the succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6280b23c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1810/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to effect a transition to the forward funding method of timing appropriation action described in paragraph (1), there are authorized to be appropriated, in an appropriation Act or Acts for the same fiscal year, two separate appropriations to carry out this chapter, the first of which shall not be subject to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6280b23d-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/tI/s110"},"text":"Pub. L. 95–471, title I, § 110","children":[],"tail":", formerly § 109, "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1328"},"text":"92 Stat. 1328","children":[],"tail":"; renumbered § 110 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/192"},"text":"Pub. L. 98–192","children":[],"tail":", §§ 4(a)(1), 9, "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1336"},"text":"97 Stat. 1336","children":[],"tail":", 1337; "},{"tag":"ref","attrib":{"href":"/us/pl/99/428/s2/a"},"text":"Pub. L. 99–428, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"Sept. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/982"},"text":"100 Stat. 982","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/477/s1/b"},"text":"Pub. L. 101–477, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-30"},"text":"Oct. 30, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1152"},"text":"104 Stat. 1152","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tXIII/s1301/a"},"text":"Pub. L. 102–325, title XIII, § 1301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"t