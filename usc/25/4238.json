{"tag":"section","attrib":{"id":"id62d42b07-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4238"},"text":null,"children":[{"tag":"num","attrib":{"value":"4238"},"text":"§ 4238.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring of compliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d42b08-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4238/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforceable agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42b09-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4238/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, through binding contractual agreements with owners or other authorized entities, shall ensure long-term compliance with the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42b0a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4238/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Measures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The measures referred to in paragraph (1) shall provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42b0b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4238/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent allowable by Federal and State law, the enforcement of the provisions of this subchapter by the Department and the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42b0c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4238/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remedies for breach of the provisions referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42b0d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4238/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic monitoring","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42b0e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4238/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than annually, the Director shall review the activities conducted and housing assisted under this subchapter to assess compliance with the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42b0f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4238/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each review under paragraph (1) shall include onsite inspection of housing to determine compliance with applicable requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42b10-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4238/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Results","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The results of each review under paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42b11-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4238/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" included in a performance report of the Director submitted to the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4239"},"text":"section 4239 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42b12-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4238/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42b13-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4238/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish such performance measures as may be necessary to assess compliance with the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d42b14-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s819"},"text":"Pub. L. 104–330, title VIII, § 819","children":[],"tail":", a