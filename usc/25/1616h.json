{"tag":"section","attrib":{"id":"id625cfe66-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1616h"},"text":"§ 1616h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health training programs of community colleges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id625cfe67-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625cfe68-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, acting through the Service, shall award grants to community colleges for the purpose of assisting the community college in the establishment of programs which provide education in a health profession leading to a degree or diploma in a health profession for individuals who desire to practice such profession on an Indian reservation or in a tribal clinic.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe69-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of any grant awarded to a community college under paragraph (1) for the first year in which such a grant is provided to the community college shall not exceed $100,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe6a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625cfe6b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, acting through the Service, shall award grants to community colleges that have established a program described in subsection (a)(1) for the purpose of maintaining the program and recruiting students for the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe6c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Grants may only be made under this section to a community college which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id625cfe6d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is accredited,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625cfe6e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has access to a hospital facility, Service facility, or hospital that could provide training of nurses or health professionals,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625cfe6f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has entered into an agreement with an accredited college or university medical school, the terms of which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id625cfe70-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a program that enhances the transition and recruitment of students into advanced baccalaureate or graduate programs which train health professionals, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id625cfe71-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stipulate certifications necessary to approve internship and field placement opportunities at service unit facilities of the Service or at tribal health facilities,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625cfe72-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a qualified staff which has the appropriate certifications, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625cfe73-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is capable of obtaining State or regional accreditation of the program described in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe74-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements and technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall encourage community colleges described in subsection (b)(2) to establish and maintain programs described in subsection (a)(1) by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625cfe75-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entering into agreements with such colleges for the provision of qualified personnel of the Service to teach courses of study in such programs, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe76-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance and support to such colleges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe77-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced training","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any program receiving assistance under this section that is conducted with respect to a health profession shall also offer courses of study which provide advanced training for any health professional who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625cfe78-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has already received a degree or diploma in such health profession, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe79-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides clinical services on an Indian reservation, at a Service facility, or at a tribal clinic.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such courses of study may be offered in conjunction with the college or university with which the community college has entered into the agreement required under subsection (b)(2)(C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625f6e7a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625f6e7b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “community college” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id625f6e7c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a junior or community college that is a tribally controlled college or university, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625f6e7d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a junior or community college.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6e7e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “tribally controlled college or university” has the meaning given to such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801/a/4"},"text":"section 1801(a)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6e7f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616h/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “junior or community college” has the meaning given to such term by section 1058(e) ","children":[{"tag":"ref","attrib":{"idref":"fn002040"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002040"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 20."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id625f6e80-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tI/s115"},"text":"Pub. L. 94–437, title I, § 115","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tI/s109"},"text":"Pub. L. 100–713, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4797"},"text":"102 Stat. 4797","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tI/s117/b/7"},"text":"Pub. L. 102–573, title I, § 117(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4544"},"text":"106 Stat. 4544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s901/d"},"text":"Pub. L. 105–244, title IX, § 901(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1828"},"text":"112 Stat. 1828","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s941/k/2/I/ii"},"text":"Pub. L. 110–315, title IX, § 941(k)(2)(I)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3467"},"text":"122 Stat. 3467","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id625f6e81-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id625f6e82-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id625f6e83-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1058"},"text":"Section 1058 of title 20","children":[],"tail":", referred to in subsec. (e)(3), was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIII/s303/b/1"},"text":"Pub. L. 105–244, title III, § 303(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1639"},"text":"112 Stat. 1639","children":[],"tail":", which redesignated subsecs. (d) and (e) as (e) and (f), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id625f6e84-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (e)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s941/k/2/I/ii/I"},"text":"Pub. L. 110–315, § 941(k)(2)(I)(ii)(I)","children":[],"tail":", substituted “a junior or community college that is a tribally controlled college or university” for “a tribally controlled community college”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s941/k/2/I/ii/II"},"text":"Pub. L. 110–315, § 941(k)(2)(I)(ii)(II)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “The term ‘tribally controlled community college’ has the meaning given to such term by "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801/4"},"text":"section 1801(4) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801/4"},"text":"section 1801(4) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573"},"text":"Pub. L. 102–573","children":[],"tail":" struck out subsec. (f) which authorized appropriations for fiscal years 1990 to 1992."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id625f6e85-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id625f6e86-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
