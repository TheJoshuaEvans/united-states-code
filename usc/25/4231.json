{"tag":"section","attrib":{"id":"id62d42a88-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4231"},"text":null,"children":[{"tag":"num","attrib":{"value":"4231"},"text":"§ 4231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of investments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d42a89-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4231/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4230"},"text":"section 4230 of this title","children":[],"tail":" and an applicable housing plan approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":", the Director shall have—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42a8a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4231/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the discretion to use grant amounts for affordable housing activities through the use of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42a8b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4231/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equity investments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42a8c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4231/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest-bearing loans or advances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparag