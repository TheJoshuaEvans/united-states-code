{"tag":"section","attrib":{"id":"id62ba1280-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3303"},"text":null,"children":[{"tag":"num","attrib":{"value":"3303"},"text":"§ 3303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62ba1281-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, from the amounts appropriated for the purpose of supporting higher education grants for Indian students under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":", make grants to Indian tribes in accordance with the requirements of this subchapter to permit those tribes to provide financial assistance to individual Indian students for the cost of attendance at institutions of higher education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ba1282-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on Secretary’s authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not place any restrictions on the use of funds provided to an Indian tribe under this subchapter that is not expressly authorized by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ba1283-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on Federal responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this subchapter shall not affect any trust responsibilities of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ba1284-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No termination for administrative convenience","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants provided under this subchapter may not be terminated, modified, suspended, or reduced only for the convenience of the administering agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62ba1285-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/tXIII/s1313"},"text":"Pub. L. 102–325, title XIII, § 1313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/798"},"text":"106 Stat. 798","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
