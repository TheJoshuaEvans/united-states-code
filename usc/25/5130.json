{"tag":"section","attrib":{"id":"id62db5665-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5130"},"text":null,"children":[{"tag":"num","attrib":{"value":"5130"},"text":"§ 5130.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this title: ","children":[{"tag":"ref","attrib":{"idref":"fn002249"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002249"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62db5666-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5130/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62db5667-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5130/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Indian tribe” means any Indian or Alaska Native tribe, band, nation, pueblo, village or community that the Secretary of the Interior acknowledges to exist as an Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62db5668-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5130/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “list” means the list of recognized tribes published by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5131"},"text":"section 5131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62db5669-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/454/tI/s102"},"text":"Pub. L. 103–454, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4791"},"text":"108 Stat. 4791","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62db566a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62db566b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62db566c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in introductory provisions, is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/454"},"text":"Pub. L. 103–454","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4791"},"text":"108 Stat. 4791","children":[],"tail":", which enacted this section, "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5131"},"text":"section 5131 of this title","children":[],"tail":", and provisions set out as a note below. For complete classification of this title to the Code, see Short Title of 1994 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5101"},"text":"section 5101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62db566d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s479a"},"text":"section 479a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62db566e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id62db566f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5131"},"text":"section 5131 of this title","children":[],"tail":" as the “Federally Recognized Indian Tribe List Act of 1994”, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/454/s101"},"text":"section 101 of Pub. L. 103–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5101"},"text":"section 5101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62db5670-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/454/tI/s103"},"text":"Pub. L. 103–454, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4791"},"text":"108 Stat. 4791","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/454/tI/s103"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Constitution, as interpreted by Federal case law, invests Congress with plenary authority over Indian Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ancillary to that authority, the United States has a trust responsibility to recognized Indian tribes, maintains a government-to-government relationship with those tribes, and recognizes the sovereignty of those tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribes presently may be recognized by Act of Congress; by the administrative procedures set forth in part 83 of the Code of Federal Regulations denominated ‘Procedures for Establishing that an American Indian Group Exists as an Indian Tribe;’ or by a decision of a United States court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribe which has been recognized in one of these manners may not be terminated except by an Act of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress has expressly repudiated the policy of terminating recognized Indian tribes, and has actively sought to restore recognition to tribes that previously have been terminated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior is charged with the responsibility of keeping a list of all federally recognized tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the list published by the Secretary should be accurate, regularly updated, and regularly published, since it is used by the various departments and agencies of the United States to determine the eligibility of certain groups to receive services from the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the list of federally recognized tribes which the Secretary publishes should reflect all of the federally recognized Indian tribes in the United States which are eligible for the special programs and services provided by the United States to Indians because of their status as Indians.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
