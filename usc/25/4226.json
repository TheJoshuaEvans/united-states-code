{"tag":"section","attrib":{"id":"id62d42a18-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226"},"text":null,"children":[{"tag":"num","attrib":{"value":"4226"},"text":"§ 4226.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d42a19-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42a1a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42a1b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may carry out the alternative environmental protection procedures described in subparagraph (B) in order to ensure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d42a1c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the policies of the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) and other provisions of law that further the purposes of such Act (as specified in regulations issued by the Secretary) are most effectively implemented in connection with the expenditure of grant amounts provided under this subchapter; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d42a1d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the public undiminished protection of the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42a1e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative environmental protection procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In lieu of applying environmental protection procedures otherwise applicable, the Secretary may by regulation provide for the release of funds for specific projects to the Department of Hawaiian Home Lands if the Director of the Department assumes all of the responsibilities for environmental review, decisionmaking, and action under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.), and such other provisions of law as the regulations of the Secretary specify, that would apply to the Secretary were the Secretary to undertake those projects as Federal projects."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42a1f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42a20-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue regulations to carry out this section only after consultation with the Council on Environmental Quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42a21-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations issued under this paragraph shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d42a22-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the monitoring of the environmental reviews performed under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d42a23-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the discretion of the Secretary, facilitate training for the performance of such reviews; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d42a24-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the suspension or termination of the assumption of responsibilities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42a25-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on assumed responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The duty of the Secretary under paragraph (2)(B) shall not be construed to limit or reduce any responsibility assumed by the Department of Hawaiian Home Lands for grant amounts with respect to any specific release of funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42a26-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42a27-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall authorize the release of funds subject to the procedures under this section only if, not less than 15 days before that approval and before any commitment of funds to such projects, the Director of the Department of Hawaiian Home Lands submits to the Secretary a request for such release accompanied by a certification that meets the requirements of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42a28-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The approval of the Secretary of a certification described in paragraph (1) shall be deemed to satisfy the responsibilities of the Secretary under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) and such other provisions of law as the regulations of the Secretary specify to the extent that those responsibilities relate to the releases of funds for projects that are covered by that certification."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d42a29-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A certification under the procedures under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42a2a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in a form acceptable to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42a2b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be executed by the Director of the Department of Hawaiian Home Lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42a2c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify that the Department of Hawaiian Home Lands has fully carried out its responsibilities as described under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42a2d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" specify that the Director—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42a2e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consents to assume the status of a responsible Federal official under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) and each provision of law specified in regulations issued by the Secretary to the extent that those laws apply by reason of subsection (a); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42a2f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4226/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is authorized and consents on behalf of the Department of Hawaiian Home Lands and the Director to accept the jurisdiction of the Federal courts for the purpose of enforcement of the responsibilities of the Director of the Department of Hawaiian Home Lands as such an official.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d42a30-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s806"},"text":"Pub. L. 104–330, title VIII, § 806","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s203"},"text":"Pub. L. 106–568, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2883"},"text":"114 Stat. 2883","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s513"},"text":"Pub. L. 106–569, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2977"},"text":"114 Stat. 2977","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d42a31-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d42a32-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62d42a33-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsecs. (a)(1), (b)(2), and (c)(4)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62d42a34-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s203"},"text":"Pub. L. 106–568, § 203","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":", enacted substantially identical sections 806 of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":". This section is based on the text of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s806"},"text":"section 806 of Pub. L. 104–330","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
