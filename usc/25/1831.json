{"tag":"section","attrib":{"id":"id6280b295-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1831"},"text":null,"children":[{"tag":"num","attrib":{"value":"1831"},"text":"§ 1831.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the purpose of this subchapter to provide grants for the encouragement of endowment funds for the operation and improvement of tribally controlled colleges or universities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6280b296-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/tIII/s301"},"text":"Pub. L. 95–471, title III, § 301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/192/s13"},"text":"Pub. L. 98–192, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1341"},"text":"97 Stat. 1341","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s901/b/6"},"text":"Pub. L. 105–244, title IX, § 901(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1828"},"text":"112 Stat. 1828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6280b297-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6280b298-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6280b299-4962-11f1-add1-b56d3fa293fa"},"text":null