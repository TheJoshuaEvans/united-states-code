{"tag":"section","attrib":{"id":"id6272821f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667"},"text":null,"children":[{"tag":"num","attrib":{"value":"1667"},"text":"§ 1667.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62728220-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62728221-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62728222-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of suicide of American Indians and Alaska Natives is 1.9 times higher than the national average rate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728223-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the rate of suicide of Indian and Alaska Native youth aged 15 through 24 is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62728224-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3.5 times the national average rate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62728225-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest rate of any population group in the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728226-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" many risk behaviors and contributing factors for suicide are more prevalent in Indian country than in other areas, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62728227-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" history of previous suicide attempts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728228-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family history of suicide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728229-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" history of depression or other mental illness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272822a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alcohol or drug abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272822b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health disparities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272822c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stressful life events and losses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272822d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" easy access to lethal methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272822e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exposure to the suicidal behavior of others;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272822f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" isolation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728230-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incarceration;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728231-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" according to national data for 2005, suicide was the second-leading cause of death for Indians and Alaska Natives of both sexes aged 10 through 34;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728232-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62728233-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the suicide rates of Indian and Alaska Native males aged 15 through 24 are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62728234-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as compared to suicide rates of males of any other racial group, up to 4 times greater; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62728235-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as compared to suicide rates of females of any other racial group, up to 11 times greater; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728236-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data demonstrates that, over their lifetimes, females attempt suicide 2 to 3 times more often than males;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728237-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62728238-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribes, especially Indian tribes located in the Great Plains, have experienced epidemic levels of suicide, up to 10 times the national average; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728239-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suicide clustering in Indian country affects entire tribal communities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6272823a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" death rates for Indians and Alaska Natives are statistically underestimated because many areas of Indian country lack the proper resources to identify and monitor the presence of disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6272823b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6272823c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian Health Service experiences health professional shortages, with physician vacancy rates of approximately 17 percent, and nursing vacancy rates of approximately 18 percent, in 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272823d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent of all teens who die by suicide suffer from a diagnosable mental illness at time of death;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272823e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than ½ of teens who die by suicide have never been seen by a mental health provider; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6272823f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ⅓ of health needs in Indian country relate to mental health;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728240-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" often, the lack of resources of Indian tribes and the remote nature of Indian reservations make it difficult to meet the requirements necessary to access Federal assistance, including grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728241-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Substance Abuse and Mental Health Services Administration and the Service have established specific initiatives to combat youth suicide in Indian country and among Indians and Alaska Natives throughout the United States, including the National Suicide Prevention Initiative of the Service, which has worked with Service, tribal, and urban Indian health programs since 2003;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728242-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the National Strategy for Suicide Prevention was established in 2001 through a Department of Health and Human Services collaboration among—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62728243-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Substance Abuse and Mental Health Services Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728244-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728245-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Centers for Disease Control and Prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728246-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institutes of Health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62728247-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/10/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Health Resources and Services Administration; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728248-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Service and other agencies of the Department of Health and Human Services use information technology and other programs to address the suicide prevention and mental health needs of Indians and Alaska Natives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62728249-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this part are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6272824a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to authorize the Secretary to carry out a demonstration project to test the use of telemental health services in suicide prevention, intervention, and treatment of Indian youth, including through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6272824b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of psychotherapy, psychiatric assessments, diagnostic interviews, therapies for mental health conditions predisposing to suicide, and alcohol and substance abuse treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb3c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of clinical expertise to, consultation services with, and medical advice and training for frontline health care providers working with Indian youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb3d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and related support for community leaders, family members, and health and education workers who work with Indian youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb3e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of culturally relevant educational materials on suicide; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb3f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data collection and reporting;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cb40-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage Indian tribes, tribal organizations, and other mental health care providers serving residents of Indian country to obtain the services of predoctoral psychology and psychiatry interns; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cb41-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the provision of mental health care services to Indian youth through existing grant programs of the Substance Abuse and Mental Health Services Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6274cb42-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s721"},"text":"Pub. L. 94–437, title VII, § 721","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6274cb43-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6274cb44-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6274cb45-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s721"},"text":"Section 721 of Pub. L. 94–437","children":[],"tail":" is based on section 181 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
