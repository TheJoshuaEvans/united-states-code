{"tag":"section","attrib":{"id":"id62bc5ccb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413"},"text":null,"children":[{"tag":"num","attrib":{"value":"3413"},"text":"§ 3413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62bc5ccc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5ccd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62bc5cce-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation and reallocation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, all amounts transferred to a tribe pursuant to an approved plan may be consolidated, reallocated, and rebudgeted as specified in the approved plan to best meet the employment, training, and related needs of the local community served by the Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5ccf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts used to carry out a plan approved under this chapter shall be administered in such manner as the Secretary determines to be appropriate to ensure the amounts are spent on activities authorized under the approved plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5cd0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section interferes with the ability of the Secretary or the lead agency to use accounting procedures that conform to generally accepted accounting principles, auditing procedures, and safeguarding of funds that conform to chapter 75 of title 31 (commonly known as the “Single Audit Act of 1984”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5cd1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate records and audits not required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law (including regulations and circulars of any agency (including Office of Management and Budget Circular A–133)), an Indian tribe that has in place an approved plan under this chapter shall not be required—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62bc5cd2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain separate records that trace any service or activity conducted under the approved plan to the program for which the funds were initially authorized or transferred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5cd3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allocate expenditures among such a program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5cd4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to audit expenditures by the original source of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5cd5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5cd6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds transferred to an Indian tribe under this chapter that are not obligated or expended prior to the beginning of the fiscal year after the fiscal year for which the funds were appropriated shall remain available for obligation or expenditure without fiscal year limitation, subject to the condition that the funds shall be obligated or expended in accordance with the approved plan of the Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5cd7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No additional documentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Indian tribe shall not be required to provide any additional justification or documentation of the purposes of the approved plan as a condition of receiving or expending the funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5cd8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indirect costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, an Indian tribe shall be entitled to recover 100 percent of any indirect costs incurred by the Indian tribe as a result of the transfer of funds to the Indian tribe under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5cd9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5cda-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All administrative costs may be commingled and participating Indian tribes shall be entitled to the full amount of such costs (under each program or department’s regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5cdb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount equal to the difference between the amount of the commingled funds and the actual administrative cost of the programs, as described in paragraph (1), shall be considered to be properly spent for Federal audit purposes if the amount is used to achieve the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5cdc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, any funds transferred to an Indian tribe under this chapter shall be treated as non-Federal funds for purposes of meeting matching requirements under any other Federal law, except those administered by the Department of Labor or the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5cdd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following provisions of law shall apply to plans approved under this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5cde-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 314 of the Department of the Interior and Related Agencies Appropriations Act, 1991 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/512"},"text":"Public Law 101–512","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/104/1959"},"text":"104 Stat. 1959","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" note])."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5cdf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 171 of title 28 (commonly known as the “Federal Tort Claims Act”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62bc5ce0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest or other income","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5ce1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian tribe shall be entitled to retain interest earned on any funds transferred to the tribe under an approved plan and such interest shall not diminish the amount of funds the Indian tribe is authorized to receive under the plan in the year the interest is earned or in any subsequent fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5ce2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3413/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prudent investment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds transferred under a plan shall be managed in accordance with the prudent investment standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62bc5ce3-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/477/s14"},"text":"Pub. L. 102–477, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2305"},"text":"106 Stat. 2305","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/93/s14"},"text":"Pub. L. 115–93, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-18"},"text":"Dec. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2035"},"text":"131 Stat. 2035","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62bc5ce4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62bc5ce5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62bc5ce6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/93"},"text":"Pub. L. 115–93","children":[],"tail":" substituted “Administration of funds” for “Administration of funds and overage” in section catchline, added subsecs. (a) to (c) and (e) to (g), redesignated former subsec. (b) as (d) and designated existing provisions as par. (1), inserted heading, substituted “regulations)” for “regulations), and no overage shall be counted for Federal audit purposes, provided that the overage is used for the purposes provided for under this chapter”, and added par. (2), and struck out former subsec. (a) which related to administration of funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
