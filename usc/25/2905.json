{"tag":"section","attrib":{"id":"id62ae049b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2905"},"text":null,"children":[{"tag":"num","attrib":{"value":"2905"},"text":"§ 2905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62ae049c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President shall direct the heads of the various Federal departments, agencies, and instrumentalities to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae049d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2905/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate their policies and procedures in consultation with Indian tribes and other Native American governing bodies as well as traditional leaders and educators in order to determine and implement changes needed to bring the policies and procedures into compliance with the provisions of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae049e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2905/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give the greatest effect possible in making such evaluations, absent a clear specific Federal statutory requirement to the contrary, to the policies and procedures which will give the broadest effect to the provisions of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae049f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2905/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the laws which they administer and make recommendations to the President on amendments needed to bring such laws into compliance with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae04a0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" By no later than the date that is 1 year after ","children":[{"tag":"date","attrib":{"date":"1990-10-30"},"text":"October 30, 1990","children":[],"tail":", the President shall submit to the Congress a report containing recommendations for amendments to Federal laws that are needed to bring such laws into compliance with the provisions of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ae04a1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation; report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2023-01-05"},"text":"January 5, 2023","children":[],"tail":", the President shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ae04a2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2905/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the heads of the various Federal departments, agencies, and instrumentalities to carry out an evaluation described in subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ae04a3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2905/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to Congress a report that describes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62ae04a4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2905/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the evaluations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62ae04a5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2905/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the recommendations of the Secretary of the Interior, the Secretary of Health and Human Services, and the Secretary of Education, after consultation with Indian tribes, traditional leaders, and representatives of Native American language communities, for amendments to Federal laws that are needed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62ae04a6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2905/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to bring the Federal laws into compliance with this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ae04a7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2905/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve interagency coordination for purposes of supporting revitalization, maintenance, and use of Native American languages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62ae04a8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2905/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce duplication, inefficiencies, and barriers Native American language communities face in accessing Federal programs to support efforts to revitalize, maintain, or increase the use of Native American languages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62ae04a9-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/477/tI/s106"},"text":"Pub. L. 101–477, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-30"},"text":"Oct. 30, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1156"},"text":"104 Stat. 1156","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/337/s2/a"},"text":"Pub. L. 117–337, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6153"},"text":"136 Stat. 6153","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ae04aa-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62ae04ab-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62ae04ac-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c)(2)(B)(i), was in the original “this Act” and was translated as reading “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/477"},"text":"Pub. L. 101–477","children":[],"tail":", known as the Native American Languages Act, which is classified generally to this chapter, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62ae04ad-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/337"},"text":"Pub. L. 117–337","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
