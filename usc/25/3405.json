{"tag":"section","attrib":{"id":"id62bc5c35-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3405"},"text":null,"children":[{"tag":"num","attrib":{"value":"3405"},"text":"§ 3405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan requirements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A plan submitted to the Secretary for approval under this chapter shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5c36-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3405/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the programs to be integrated and consolidated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c37-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3405/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be consistent with the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c38-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3405/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62bc5c39-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3405/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive strategy identifying the full range of potential employment opportunities on and near the service area of the Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5c3a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3405/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the education, training, and related services to be provided to assist Indians to access those employment opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5c3b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3405/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the way in which services and program funds are to be integrated, consolidated, and delivered; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5c3c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3405/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results expected, including the expected number of program participants in unsubsidized employment during the second quarter after exit from the program, from the plan;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c3d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3405/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the projected expenditures under the plan in a single budget covering all consolidated funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c3e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3405/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any agency of the Indian tribe to be involved in the delivery of the services integrated under the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c3f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3405/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any statutory provisions, regulations, policies, or procedures that the Indian tribe believes need to be waived to implement the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5c40-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3405/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be approved by the governing body of the Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62bc5c41-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/477/s6"},"text":"Pub. L. 102–477, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2303"},"text":"106 Stat. 2303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/93/s7"},"text":"Pub. L. 115–93, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-18"},"text":"Dec. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2028"},"text":"131 Stat. 2028","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62bc5c42-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62bc5c43-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62bc5c44-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/93"},"text":"Pub. L. 115–93","children":[],"tail":" amended section generally. Prior to amendment, section related to plan requirements, consisting of eight pars."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
