{"tag":"section","attrib":{"id":"id62321dcf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s373c"},"text":null,"children":[{"tag":"num","attrib":{"value":"373c"},"text":"§ 373c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sections 373a and 373b as inapplicable to certain Indians","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of sections 373a and 373b of this title shall not apply to the Indians of the Five Civilized Tribes or the Osage Reservation, in Oklahoma.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62321dd0-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1942-11-24/ch640/s3"},"text":"Nov. 24, 1942, ch. 640, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/1022"},"text":"56 Stat. 1022","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
