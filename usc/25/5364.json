{"tag":"section","attrib":{"id":"id62ee68a5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5364"},"text":null,"children":[{"tag":"num","attrib":{"value":"5364"},"text":"§ 5364.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compacts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62ee68a6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5364/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall negotiate and enter into a written compact with each Indian Tribe participating in self-governance in a manner consistent with the trust responsibility of the Federal Government, treaty obligations, and the government-to-government relationship between Indian Tribes and the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee68a7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5364/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A compact under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee68a8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5364/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify and affirm the general terms of the government-to-government relationship between the Indian Tribe and the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee68a9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5364/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include such terms as the parties intend shall control during the term of the compact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee68aa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5364/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A compact under subsection (a) may be amended only by agreement of the parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee68ab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5364/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The effective date of a compact under subsection (a) shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee68ac-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5364/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the execution of the compact by the parties; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee68ad-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5364/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such date as is mutually agreed upon by the parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee68ae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5364/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A compact under subsection (a) shall remain in effect—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee68af-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5364/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for so long as permitted by Federal law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee68b0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5364/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" until termination by written agreement, retrocession, or reassumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62ee68b1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5364/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing compacts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Indian Tribe participating in self-governance under this subchapter, as in effect on ","children":[{"tag":"date","attrib":{"date":"2020-10-21"},"text":"October 21, 2020","children":[],"tail":", shall have the option at any time after that date—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62ee68b2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5364/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to retain its negotiated compact (in whole or in part) to the extent that the provisions of the compact are not directly contrary to any express provision of this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62ee68b3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5364/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to negotiate a new compact in a manner consistent with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62ee68b4-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tIV/s404"},"text":"Pub. L. 93–638, title IV, § 404","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/180/tI/s101/e"},"text":"Pub. L. 116–180, title I, § 101(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-21"},"text":"Oct. 21, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/864"},"text":"134 Stat. 864","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ee68b5-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62ee68b6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62ee68b7-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5364, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tIV/s404"},"text":"Pub. L. 93–638, title IV, § 404","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/413/tII/s204"},"text":"Pub. L. 103–413, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4275"},"text":"108 Stat. 4275","children":[],"tail":", related to identification of funds in annual budget request, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/116/180/tI/s101/e"},"text":"Pub. L. 116–180, title I, § 101(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-21"},"text":"Oct. 21, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/864"},"text":"134 Stat. 864","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5371"},"text":"section 5371 of this title","children":[],"tail":". Such section was formerly classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s458dd"},"text":"section 458dd of this title","children":[],"tail":" prior to editorial reclassification and renumbering as section 5364."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
