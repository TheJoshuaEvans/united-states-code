{"tag":"section","attrib":{"id":"id6255d1e0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1484"},"text":null,"children":[{"tag":"num","attrib":{"value":"1484"},"text":"§ 1484.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for loan; approval by Secretary; issuance of certificate; limitations on amount of loans to individual Indians or economic enterprises; review by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The application for a loan to be guaranteed hereunder shall be submitted to the Secretary for approval. The Secretary may review each loan application individually and independently from the lender. Upon approval, the Secretary shall issue a certificate as evidence of the guaranty. Such certificate shall be issued only when, in the judgment of the Secretary, there is a reasonable prospect of repayment. No loan to an individual Indian may be guaranteed or insured which would cause the total unpaid principal indebtedness to exceed $500,000. No loan to an economic enterprise (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1452"},"text":"section 1452 of this title","children":[],"tail":") in excess of $250,000, or such lower amount as the Secretary may determine to be appropriate, shall be insured unless prior approval of the loan is obtained from the Secretary."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6255d1e1-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/tII/s204"},"text":"Pub. L. 93–262, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/79"},"text":"88 Stat. 79","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/449/s5"},"text":"Pub. L. 98–449, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-04"},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1725"},"text":"98 Stat. 1725","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/442/s1"},"text":"Pub. L. 100–442, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-22"},"text":"Sept. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1763"},"text":"102 Stat. 1763","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/644/tIII/s303/b"},"text":"Pub. L. 101–644, title III, § 303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4668"},"text":"104 Stat. 4668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/331/tI/s103/a"},"text":"Pub. L. 107–331, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-13"},"text":"Dec. 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2836"},"text":"116 Stat. 2836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6255d1e2-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6255d1e3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6255d1e4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/331"},"text":"Pub. L. 107–331","children":[],"tail":" substituted “$250,000” for “$100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/644"},"text":"Pub. L. 101–644","children":[],"tail":" struck out “prior” before “approval” in first sentence and substituted “may review” for “shall review” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/442"},"text":"Pub. L. 100–442","children":[],"tail":" substituted “$500,000” for “$350,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/449"},"text":"Pub. L. 98–449","children":[],"tail":" substituted “$350,000” for “$100,000”, and inserted after first sentence “The Secretary shall review each loan application individually and independently from the lender.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
