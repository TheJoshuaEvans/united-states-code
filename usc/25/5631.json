{"tag":"section","attrib":{"id":"id62f5948f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5631"},"text":null,"children":[{"tag":"num","attrib":{"value":"5631"},"text":"§ 5631.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this subchapter is to ensure a more efficient and streamlined administration of duties of the Secretary of the Interior with respect to providing services and programs to Indians and Indian tribes, including the management of Indian trust resources.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62f59490-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/178/tIII/s301"},"text":"Pub. L. 114–178, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/439"},"text":"130 Stat. 439","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
