{"tag":"section","attrib":{"id":"id62f0da13-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5384"},"text":null,"children":[{"tag":"num","attrib":{"value":"5384"},"text":"§ 5384.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compacts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f0da14-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5384/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compact required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall negotiate and enter into a written compact with each Indian tribe participating in self-governance in a manner consistent with the Federal Government’s trust responsibility, treaty obligations, and the government-to-government relationship between Indian tribes and the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f0da15-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5384/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each compact required under subsection (a) of this section shall set forth the general terms of the government-to-government relationship between the Indian tribe and the Secretary, including such terms as the parties intend shall control year after year. Such compacts may only be amended by mutual agreement of the parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f0da16-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5384/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing compacts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Indian tribe participating in the Tribal Self-Governance Demonstration Project under title III ","children":[{"tag":"ref","attrib":{"idref":"fn002275"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002275"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" on "},{"tag":"date","attrib":{"date":"2000-08-18"},"text":"August 18, 2000","children":[],"tail":", shall have the option at any time after "},{"tag":"date","attrib":{"date":"2000-08-18"},"text":"August 18, 2000","children":[],"tail":", to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f0da17-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5384/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain the Tribal Self-Governance Demonstration Project compact of that Indian tribe (in whole or in part) to the extent that the provisions of that funding agreement are not directly contrary to any express provision of this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f0da18-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5384/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instead of retaining a compact or portion thereof under paragraph (1), negotiate a new compact in a manner consistent with the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f0da19-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5384/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term and effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The effective date of a compact shall be the date of the approval and execution by the Indian tribe or another date agreed upon by the parties, and shall remain in effect for so long as permitted by Federal law or until terminated by mutual written agreement, retrocession, or reassumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f0da1a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tV/s504"},"text":"Pub. L. 93–638, title V, § 504","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/260/s4"},"text":"Pub. L. 106–260, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-18"},"text":"Aug. 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/715"},"text":"114 Stat. 715","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62f0da1b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62f0da1c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62f0da1d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title III, referred to in subsec. (c), means title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/100/472/tII/s209"},"text":"Pub. L. 100–472, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-05"},"text":"Oct. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2296"},"text":"102 Stat. 2296","children":[],"tail":", and amended, which was set out as a note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450f"},"text":"section 450f of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/260/s10"},"text":"Pub. L. 106–260, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-18"},"text":"Aug. 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/734"},"text":"114 Stat. 734","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62f0da1e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s458aaa–3"},"text":"section 458aaa–3 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
