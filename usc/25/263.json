{"tag":"section","attrib":{"id":"id621f0b35-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s263"},"text":null,"children":[{"tag":"num","attrib":{"value":"263"},"text":"§ 263.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of trade by President","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized, whenever in his opinion the public interest may require the same, to prohibit the introduction of goods, or of any particular article, into the country belonging to any Indian tribe, and to direct all licenses to trade with such tribe to be revoked, and all applications therefor to be rejected. No trader to any other tribe shall, so long as such prohibition may continue, trade with any Indians of or for the tribe against which such prohibition is issued.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621f0b36-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2132.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621f0b37-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621f0b38-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id621f0b39-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2132 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1834-06-30/ch161/s3"},"text":"act June 30, 1834, ch. 161, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/729"},"text":"4 Stat. 729","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
