{"tag":"section","attrib":{"id":"id62ae0499-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2904"},"text":null,"children":[{"tag":"num","attrib":{"value":"2904"},"text":"§ 2904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The right of Native Americans to express themselves through the use of Native American languages shall not be restricted in any public proceeding, including publicly supported education programs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62ae049a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/477/tI/s105"},"text":"Pub. L. 101–477, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-30"},"text":"Oct. 30, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1155"},"text":"104 Stat. 1155","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
