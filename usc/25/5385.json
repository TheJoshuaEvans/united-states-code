{"tag":"section","attrib":{"id":"id62f0da1f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385"},"text":null,"children":[{"tag":"num","attrib":{"value":"5385"},"text":"§ 5385.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62f0da20-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding agreement required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall negotiate and enter into a written funding agreement with each Indian tribe participating in self-governance in a manner consistent with the Federal Government’s trust responsibility, treaty obligations, and the government-to-government relationship between Indian tribes and the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f0da21-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f0da22-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each funding agreement required under subsection (a) of this section shall, as determined by the Indian tribe, authorize the Indian tribe to plan, conduct, consolidate, administer, and receive full tribal share funding, including tribal shares of discretionary Indian Health Service competitive grants (excluding congressionally earmarked competitive grants), for all programs, services, functions, and activities (or portions thereof), that are carried out for the benefit of Indians because of their status as Indians without regard to the agency or office of the Indian Health Service within which the program, service, function, or activity (or portion thereof) is performed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f0da23-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of certain programs, services, functions, and activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such programs, services, functions, or activities (or portions thereof) include all programs, services, functions, activities (or portions thereof), including grants (which may be added to a funding agreement after an award of such grants), with respect to which Indian tribes or Indians are primary or significant beneficiaries, administered by the Department of Health and Human Services through the Indian Health Service and all local, field, service unit, area, regional, and central headquarters or national office functions so administered under the authority of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f0da24-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f0da25-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1934-04-16"},"text":"April 16, 1934","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/48/596"},"text":"48 Stat. 596","children":[],"tail":"; chapter 147; "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s452"},"text":"25 U.S.C. 452","children":[],"tail":" et seq.); "},{"tag":"ref","attrib":{"idref":"fn002276"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002276"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f0da26-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1954-08-05"},"text":"August 5, 1954","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/68/674"},"text":"68 Stat. 674","children":[],"tail":"; chapter 658) ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2001"},"text":"42 U.S.C. 2001","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f0da27-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian Health Care Improvement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1601"},"text":"25 U.S.C. 1601","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f0da28-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian Alcohol and Substance Abuse Prevention and Treatment Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2401"},"text":"25 U.S.C. 2401","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f0da29-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Act of Congress authorizing any agency of the Department of Health and Human Services to administer, carry out, or provide financial assistance to such a program, service, function or activity (or portions thereof) described in this section that is carried out for the benefit of Indians because of their status as Indians; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f0da2a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Act of Congress authorizing such a program, service, function, or activity (or portions thereof) carried out for the benefit of Indians under which appropriations are made available to any agency other than an agency within the Department of Health and Human Services, in any case in which the Secretary administers that program, service, function, or activity (or portion thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f0da2b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion in compact or funding agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall not be a requirement that an Indian tribe or Indians be identified in the authorizing statute for a program or element of a program to be eligible for inclusion in a compact or funding agreement under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f0da2c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding agreement terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each funding agreement under this subchapter shall set forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f0da2d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terms that generally identify the programs, services, functions, and activities (or portions thereof) to be performed or administered; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f0da2e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the items identified in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62f0da2f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the general budget category assigned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f0da30-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funds to be provided, including those funds to be provided on a recurring basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f0da31-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time and method of transfer of the funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f0da32-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the responsibilities of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62f0da33-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other provision with respect to which the Indian tribe and the Secretary agree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f0da34-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent funding agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Absent notification from an Indian tribe that is withdrawing or retroceding the operation of one or more programs, services, functions, or activities (or portions thereof) identified in a funding agreement, or unless otherwise agreed to by the parties, each funding agreement shall remain in full force and effect until a subsequent funding agreement is executed, and the terms of the subsequent funding agreement shall be retroactive to the end of the term of the preceding funding agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f0da35-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing funding agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Indian tribe participating in the Tribal Self-Governance Demonstration Project established under title III ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" on "},{"tag":"date","attrib":{"date":"2000-08-18"},"text":"August 18, 2000","children":[],"tail":", shall have the option at any time thereafter to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62f0da36-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain the Tribal Self-Governance Demonstration Project funding agreement of that Indian tribe (in whole or in part) to the extent that the provisions of that funding agreement are not directly contrary to any express provision of this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62f0da37-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instead of retaining a funding agreement or portion thereof under paragraph (1), negotiate a new funding agreement in a manner consistent with the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62f0da38-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5385/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stable base funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the option of an Indian tribe, a funding agreement may provide for a stable base budget specifying the recurring funds (including, for purposes of this provision, funds available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5325/a"},"text":"section 5325(a) of this title","children":[],"tail":") to be transferred to such Indian tribe, for such period as may be specified in the funding agreement, subject to annual adjustment only to reflect changes in congressional appropriations by sub-sub activity excluding earmarks."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62f0da39-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638/tV/s505"},"text":"Pub. L. 93–638, title V, § 505","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/260/s4"},"text":"Pub. L. 106–260, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-18"},"text":"Aug. 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/716"},"text":"114 Stat. 716","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62f0da3a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62f0da3b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62f0da3c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1934-04-16"},"text":"April 16, 1934","children":[],"tail":", referred to in subsec. (b)(2)(B), is "},{"tag":"ref","attrib":{"href":"/us/act/1934-04-16/ch147"},"text":"act Apr. 16, 1934, ch. 147","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/596"},"text":"48 Stat. 596","children":[],"tail":", popularly known as the Johnson-O’Malley Act, which was classified generally to section 452 et seq. of this title prior to editorial reclassification as section 5342 et seq. of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1954-08-05"},"text":"August 5, 1954","children":[],"tail":", referred to in subsec. (b)(2)(C), is "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-05/ch658"},"text":"act Aug. 5, 1954, ch. 658","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/674"},"text":"68 Stat. 674","children":[],"tail":", which is classified generally to subchapter I (§ 2001 et seq.) of chapter 22 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Health Care Improvement Act, referred to in subsec. (b)(2)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437"},"text":"Pub. L. 94–437","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1400"},"text":"90 Stat. 1400","children":[],"tail":", which is classified principally to chapter 18 (§ 1601 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Alcohol and Substance Abuse Prevention and Treatment Act of 1986, referred to in subsec. (b)(2)(E), is subtitle C of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570"},"text":"Pub. L. 99–570","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-137"},"text":"100 Stat. 3207–137","children":[],"tail":", which is classified generally to chapter 26 (§ 2401 et seq.) of this title. For complete classification of subtitle C to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2401"},"text":"section 2401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title III, referred to in subsec. (f), means title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/100/472/tII/s209"},"text":"Pub. L. 100–472, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-05"},"text":"Oct. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2296"},"text":"102 Stat. 2296","children":[],"tail":", which was set out as a note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450f"},"text":"section 450f of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/260/s10"},"text":"Pub. L. 106–260, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-18"},"text":"Aug. 18, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/734"},"text":"114 Stat. 734","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62f0da3d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s458aaa–4"},"text":"section 458aaa–4 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
