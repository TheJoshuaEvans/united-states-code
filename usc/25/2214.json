{"tag":"section","attrib":{"id":"id6298a810-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2214"},"text":null,"children":[{"tag":"num","attrib":{"value":"2214"},"text":"§ 2214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishing fair market value","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the Secretary may develop a system for establishing the fair market value of various types of lands and improvements. Such a system may include determinations of fair market value based on appropriate geographic units as determined by the Secretary. Such a system may govern the amounts offered for the purchase of interests in trust or restricted land under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6298a811-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/459/tII/s215"},"text":"Pub. L. 97–459, title II, § 215","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/462/tI/s103/6"},"text":"Pub. L. 106–462, title I, § 103(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2002"},"text":"114 Stat. 2002","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/7"},"text":"Pub. L. 108–374, § 6(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1802"},"text":"118 Stat. 1802","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/157/s6"},"text":"Pub. L. 109–157, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-30"},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2952"},"text":"119 Stat. 2952"