{"tag":"section","attrib":{"id":"id62832404-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1863"},"text":null,"children":[{"tag":"num","attrib":{"value":"1863"},"text":"§ 1863.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62832405-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1863/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (4) and (8) of subsection (a), and subsection (b), of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801"},"text":"section 1801 of this title","children":[],"tail":", sections 1805, 1808, 1811, 1812 and 1813 of this title, subchapters II and III of this chapter, and title II "},{"tag":"ref","attrib":{"idref":"fn002114"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002114"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall not apply to this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62832406-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1863/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian self-determination and education assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available pursuant to this subchapter shall be subject to the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.)."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62832407-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1863/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to receive","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A tribally controlled postsecondary career and technical institution selected for a fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1862/b"},"text":"section 1862(b) of this title","children":[],"tail":" may elect to receive funds pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1862"},"text":"section 1862 of this title","children":[],"tail":" in accordance with an agreement between the tribally controlled postsecondary career and technical institution and the Secretary under the Indian Self-Determination and Education Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.)"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" if the agreement is in existence on "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62832408-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1863/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Eligibility for, or receipt of, assistance under this subchapter shall not preclude the eligibility of a tribally controlled postsecondary career and technical institution to receive Federal financial assistance under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62832409-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1863/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any program under the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"20 U.S.C. 1001","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6283240a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1863/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any program under the Carl D. Perkins Career and Technical Education Act of 2006 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2301"},"text":"20 U.S.C. 2301","children":[],"tail":" et seq.]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6283240b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1863/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any other applicable program under which a benefit is provided for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6283240c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1863/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6283240d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1863/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community colleges; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6283240e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1863/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" postsecondary educational institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6283240f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/tV/s503"},"text":"Pub. L. 95–471, title V, § 503","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s941/j/1"},"text":"Pub. L. 110–315, title IX, § 941(j)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3464"},"text":"122 Stat. 3464","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62832410-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62832411-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62832412-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title II, referred to in subsec. (a), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471"},"text":"Pub. L. 95–471","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1329"},"text":"92 Stat. 1329","children":[],"tail":", known as the Navajo Community College Assistance Act of 1978, which enacted former "},{"tag":"ref","attrib":{"href":"/u