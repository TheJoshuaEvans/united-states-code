{"tag":"section","attrib":{"id":"id620e41dc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s13f"},"text":null,"children":[{"tag":"num","attrib":{"value":"13f"},"text":"§ 13f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal priority allocations in Alaska","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id620e41dd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s13f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, with respect to amounts made available for tribal priority allocations in Alaska, such amounts on and after ","children":[{"tag":"date","attrib":{"date":"2000-10-11"},"text":"October 11, 2000","children":[],"tail":", shall only be provided to tribes the membership of which on June 1 of the preceding fiscal year is composed of at least 25 individuals who are Natives (as such term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602/b"},"text":"section 1602(b) of title 43","children":[],"tail":") who reside in the area generally known as the village for such tribe."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id620e41de-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s13f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts that would have been made available for tribal priority allocations in Alaska but for the limitation contained in subsection (a) shall be provided to the respective Alaska Native regional nonprofit corporation (as listed in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s103/a/2"},"text":"section 103(a)(2) of Public Law 104–193","children":[],"tail":","},{"tag":"ref","attrib":{"idref":"fn002004"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002004"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" "},{"tag":"ref","attrib":{"href":"/us/stat/110/2159"},"text":"110 Stat. 2159","children":[],"tail":") for the respective region in which a tribe subject to subsection (a) is located, notwithstanding any resolution authorized under federal "},{"tag":"ref","attrib":{"idref":"fn002005"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002005"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" law to the contrary."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id620e41df-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/291/tI/s122"},"text":"Pub. L. 106–291, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-11"},"text":"Oct. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/944"},"text":"114 Stat. 944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/20/tII/s2608"},"text":"Pub. L. 107–20, title II, § 2608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-07-24"},"text":"July 24, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/178"},"text":"115 Stat. 178","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id620e41e0-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id620e41e1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id620e41e2-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s103/a/2"},"text":"Section 103(a)(2) of Public Law 104–193","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2159"},"text":"110 Stat. 2159","children":[],"tail":", referred to in subsec. (b), enacted section 419 of "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s619"},"text":"section 619 of Title 42","children":[],"tail":", The Public Health and Welfare, and contains a listing of Alaska Native regional nonprofit corporations."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id620e41e3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/20"},"text":"Pub. L. 107–20","children":[],"tail":" inserted “on and after "},{"tag":"date","attrib":{"date":"2000-10-11"},"text":"October 11, 2000","children":[],"tail":",” after “such amounts” and substituted “June 1 of the preceding fiscal year” for “"},{"tag":"date","attrib":{"date":"2000-06-01"},"text":"June 1, 2000","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
