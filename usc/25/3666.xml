<note style="-uslm-lc:I74" role="crossHeading" topic="editorialNotes" id="id62c38854-4962-11f1-add1-b56d3fa293fa"><heading class="centered"><b>Editorial Notes</b></heading></note>
<note style="-uslm-lc:I74" topic="amendments" id="id62c38855-4962-11f1-add1-b56d3fa293fa"><heading class="centered smallCaps">Amendments</heading><p style="-uslm-lc:I21" class="indent0">2010—<ref href="/us/pl/111/211/s242/b/3/A">Pub. L. 111–211, § 242(b)(3)(A)</ref>, substituted “2011 through 2015” for “2000 through 2004”.</p>
</note>
