{"tag":"section","attrib":{"id":"id62b7a1a2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3204"},"text":null,"children":[{"tag":"num","attrib":{"value":"3204"},"text":"§ 3204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Central registry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b7a1a3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation of study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Health and Human Services and the Attorney General of the United States, is hereby authorized and directed to prepare a written study on the feasibility of, and need for, the establishment of a Central Register for reports or information on the abuse of children in Indian country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a1a4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study conducted pursuant to subsection (a) shall include, but shall not be limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b7a1a5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3204/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for, and purpose of, a Central Register;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a1a6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3204/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the examination of due process implication of the maintenance of such a register;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a1a7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3204/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extension of access to information contained in the register;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a1a8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3204/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need and process for expunging information from the register;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a1a9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3204/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types, and duration of maintenance, of information in the register; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a1aa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3204/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the classes of persons who should be covered by such register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a1ab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3204/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall complete the study conducted pursuant to this section and shall submit such study, together with recommendations and draft legislation to implement such recommendations, to the Congress within 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b7a1ac-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIV/s405"},"text":"Pub. L. 101–630, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4549"},"text":"104 Stat. 4549","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
