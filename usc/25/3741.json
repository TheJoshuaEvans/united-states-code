{"tag":"section","attrib":{"id":"id62c5f936-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3741"},"text":null,"children":[{"tag":"num","attrib":{"value":"3741"},"text":"§ 3741.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided by this chapter, the Secretary shall promulgate final regulations for the implementation of this chapter within 24 months after ","children":[{"tag":"date","attrib":{"date":"1993-12-03"},"text":"December 3, 1993","children":[],"tail":". All regulations promulgated pursuant to this chapter shall be developed by the Secretary with the participation of the affected Indian tribes."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62c5f937-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/177/tIII/s301"},"text":"Pub. L. 103–177, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2022"},"text":"107 Stat. 2022","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
