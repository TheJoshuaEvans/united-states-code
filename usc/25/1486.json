{"tag":"section","attrib":{"id":"id6255d203-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1486"},"text":null,"children":[{"tag":"num","attrib":{"value":"1486"},"text":"§ 1486.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans ineligible for guaranty or insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Loans made by any agency or instrumentality of the Federal Government (not including an eligible Community Development Finance Institution), or by an organization of Indians from funds borrowed from the United States, and loans the interest on which is not included in gross income for the purposes of chapter 1 of title 26 shall not be eligible for guaranty or insurance hereunder.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6255d204-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/tII/s206"},"text":"Pub. L. 93–262, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/80"},"text":"88 Stat. 80","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/221/tIV/s401/c"},"text":"Pub. L. 109–221, title IV, § 401(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-05-12"},"text":"May 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/342"},"text":"120 Stat. 342","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6255d205-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6255d206-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6255d207-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/221"},"text":"Pub. L. 109–221","children":[],"tail":" inserted “(not including an eligible Community Development Finance Institution)” after “Government”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
