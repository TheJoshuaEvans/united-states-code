{"tag":"section","attrib":{"id":"id625cfdf4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1616a–1"},"text":"§ 1616a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarship and Loan Repayment Recovery Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id625cfdf5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616a–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a fund to be known as the Indian Health Scholarship and Loan Repayment Recovery Fund (hereafter in this section referred to as the “Fund”). The Fund shall consist of such amounts as may be appropriated to the Fund under subsection (b). Amounts appropriated for the Fund shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfdf6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616a–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, there is authorized to be appropriated to the Fund an amount equal to the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625cfdf7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616a–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the amount collected during the preceding fiscal year by the Federal Government pursuant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id625cfdf8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616a–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the liability of individuals under subparagraph (A) or (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1613a/b/5"},"text":"section 1613a(b)(5) of this title","children":[],"tail":" for the breach of contracts entered into under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1613a"},"text":"section 1613a of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625cfdf9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616a–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the liability of individuals under section 1616a(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of this title for the breach of contracts entered into under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1616a"},"text":"section 1616a of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfdfa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616a–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of interest accruing during the preceding fiscal year on obligations held in the Fund pursuant to subsection (d) and the amount of proceeds from the sale or redemption of such obligations during such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfdfb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616a–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625cfdfc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616a–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amounts in the Fund and available pursuant to appropriation Acts may be expended by the Secretary, acting through the Service, to make payments to an Indian tribe or tribal organization administering a health care program pursuant to a contract entered into under the Indian Self-Determination Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.]—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id625cfdfd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616a–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which a scholarship recipient under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1613a"},"text":"section 1613a of this title","children":[],"tail":" or a loan repayment program participant under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1616a"},"text":"section 1616a of this title","children":[],"tail":" has been assigned to meet the obligated service requirements pursuant to "},{"tag":"ref","attrib":{"idref":"fn002037"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002037"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “to such”."}],"tail":" sections; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625cfdfe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616a–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has a need for a health professional to provide health care services as a result of such recipient or participant having breached the contract entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1613a"},"text":"section 1613a of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1616a"},"text":"section 1616a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfdff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616a–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Indian tribe or tribal organization receiving payments pursuant to paragraph (1) may expend the payments to recruit and employ, directly or by contract, health professionals to provide health care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe00-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616a–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of excess funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625cfe01-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616a–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury shall invest such amounts of the Fund as such Secretary determines are not required to meet current withdrawals from the Fund. Such investments may be made only in interest-bearing obligations of the United States. For such purpose, such obligations may be acquired on original issue at the issue price, or by purchase of outstanding obligations at the market price.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe02-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616a–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any obligation acquired by the Fund may be sold by the Secretary of the Treasury at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id625cfe03-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tI/s108A"},"text":"Pub. L. 94–437, title I, § 108A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tI/s110"},"text":"Pub. L. 102–573, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4538"},"text":"106 Stat. 4538","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id625cfe04-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id625cfe05-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id625cfe06-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination Act, referred to in subsec. (c)(1), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2206"},"text":"88 Stat. 2206","children":[],"tail":", which is classified principally to subchapter I (§ 5321 et seq.) of chapter 46 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
