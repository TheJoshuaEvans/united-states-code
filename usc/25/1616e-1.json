{"tag":"section","attrib":{"id":"id625cfe3e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1616e–1"},"text":"§ 1616e–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nursing school clinics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id625cfe3f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the authority of the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1616e/a/1"},"text":"section 1616e(a)(1) of this title","children":[],"tail":", the Secretary, acting through the Service, is authorized to provide grants to public or private schools of nursing for the purpose of establishing, developing, operating, and administering clinics to address the health care needs of Indians, and to provide primary health care services to Indians who reside on or within 50 miles of Indian country, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1151"},"text":"section 1151 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe40-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants provided under subsection (a) may be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625cfe41-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish clinics, to be run and staffed by the faculty and students of a grantee school, to provide primary care services in areas in or within 50 miles of Indian country (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1151"},"text":"section 1151 of title 18","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe42-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide clinical training, program development, faculty enhancement, and student scholarships in a manner that would benefit such clinics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625cfe43-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out any other activities determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe44-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants under this section in such amounts and subject to such conditions as the Secretary deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe45-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The clinics established under this section shall be designed to provide nursing students with a structured clinical experience that is similar in nature to that provided by residency training programs for physicians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe46-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625cfe47-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616e–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization to use amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of amounts appropriated to carry out this subchapter for each of the fiscal years 1993 through 2000 not more than $5,000,000 may be used to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id625cfe48-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tI/s112A"},"text":"Pub. L. 94–437, title I, § 112A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tI/s104/f"},"text":"Pub. L. 102–573, title I, § 104(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4534"},"text":"106 Stat. 4534","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
