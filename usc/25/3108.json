{"tag":"section","attrib":{"id":"id62b53079-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3108"},"text":null,"children":[{"tag":"num","attrib":{"value":"3108"},"text":"§ 3108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial recognition of tribal laws","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Subject to the Secretary’s responsibilities as reflected in sections 3101(2) and 3102(1) of this title and unless otherwise prohibited by Federal statutory law, the Secretary shall comply with tribal laws pertaining to Indian forest lands, including laws regulating the environment or historic or cultural preservation, and shall cooperate with the enforcement of such laws on Indian forest lands. Such cooperation shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b5307a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3108/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in the enforcement of such laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b5307b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3108/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of notice of such laws to persons or entities undertaking activities on Indian forest lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b5307c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3108/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon the request of an Indian tribe, the appearance in tribal forums.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b5307d-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIII/s309"},"text":"Pub. L. 101–630, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4538"},"text":"104 Stat. 4538","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
