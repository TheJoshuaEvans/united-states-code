{"tag":"section","attrib":{"id":"id62b5304c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3104"},"text":null,"children":[{"tag":"num","attrib":{"value":"3104"},"text":"§ 3104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of Indian forest land","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b5304d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall undertake forest land management activities on Indian forest land, either directly or through contracts, cooperative agreements, or grants under the Indian Self-Determination Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b5304e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Indian forest land management activities undertaken by the Secretary shall be designed to achieve the following objectives—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b5304f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the development, maintenance, and enhancement of Indian forest land in a perpetually productive state in accordance with the principles of sustained yield and with the standards and objectives set forth in forest management plans by providing effective management and protection through the application of sound silvicultural and economic principles to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b53050-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3104/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the harvesting of forest products,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b53051-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3104/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forestation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b53052-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3104/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" timber stand improvement, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b53053-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3104/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other forestry practices;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53054-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regulation of Indian forest lands through the development and implementation, with the full and active consultation and participation of the appropriate Indian tribe, of forest management plans which are supported by written tribal objectives and forest marketing programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53055-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regulation of Indian forest lands in a manner that will ensure the use of good method and order in harvesting so as to make possible, on a sustained yield basis, continuous productivity and a perpetual forest business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53056-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3104/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of Indian forest lands and associated value-added industries by Indians and Indian tribes to promote self-sustaining communities, so that Indians may receive from their Indian forest land not only stumpage value, but also the benefit of all the labor and profit that such Indian forest land is capable of yielding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53057-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3104/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retention of Indian forest land in its natural state when an Indian tribe determines that the recreational, cultural, aesthetic, or traditional values of the Indian forest land represents the highest and best use of the land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53058-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3104/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management and protection of forest resources to retain the beneficial effects to Indian forest lands of regulating water run-off and minimizing soil erosion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b53059-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3104/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance and improvement of timber productivity, grazing, wildlife, fisheries, recreation, aesthetic, cultural and other traditional values.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b5305a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIII/s305"},"text":"Pub. L. 101–630, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4535"},"text":"104 Stat. 4535","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62b5305b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62b5305c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62b5305d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination Act, referred to in subsec. (a), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2206"},"text":"88 Stat. 2206","children":[],"tail":", which is classified principally to subchapter I (§ 5321 et seq.) of chapter 46 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
