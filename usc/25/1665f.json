{"tag":"section","attrib":{"id":"id6272816f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1665f"},"text":"§ 1665f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian women treatment programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62728170-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1665a"},"text":"section 1665a of this title","children":[],"tail":", may make grants to Indian tribes, tribal organizations, and urban Indian organizations to develop and implement a comprehensive behavioral health program of prevention, intervention, treatment, and relapse prevention services that specifically addresses the cultural, historical, social, and child care needs of Indian women, regardless of age."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62728171-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant made pursuant to this section may be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62728172-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and provide community training, education, and prevention programs for Indian women relating to behavioral health issues, including fetal alcohol spectrum disorders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728173-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify and provide psychological services, counseling, advocacy, support, and relapse prevention to Indian women and their families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62728174-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop prevention and intervention models for Indian women which incorporate traditional health care practices, cultural values, and community and family involvement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62728175-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with Indian tribes and tribal organizations, shall establish criteria for the review and approval of applications and proposals for funding under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62728176-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds for urban Indian organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"20 percent of the funds appropriated pursuant to this section shall be used to make grants to urban Indian organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62728177-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s707"},"text":"Pub. L. 94–437, title VII, § 707","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62728178-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62728179-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6272817a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s707"},"text":"Section 707 of Pub. L. 94–437","children":[],"tail":" is based on section 181 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6272817b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1665f, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s707"},"text":"Pub. L. 94–437, title VII, § 707","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s702/a"},"text":"Pub. L. 102–573, title VII, § 702(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4577"},"text":"106 Stat. 4577","children":[],"tail":", related to compilation of data and preparation of reports on cases of alcohol or substance abuse in which Indian Health Service personnel or services were involved, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
