{"tag":"section","attrib":{"id":"id62d42a3a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228"},"text":null,"children":[{"tag":"num","attrib":{"value":"4228"},"text":"§ 4228.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affordable housing activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d42a3b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002244"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002244"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (b) has been enacted."}],"tail":" National objectives and eligible families"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42a3c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Primary objective","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The national objectives of this subchapter are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42a3d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist and promote affordable housing activities to develop, maintain, and operate affordable housing in safe and healthy environments for occupancy by low-income Native Hawaiian families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42a3e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure better access to private mortgage markets and to promote self-sufficiency of low-income Native Hawaiian families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42a3f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate activities to provide housing for low-income Native Hawaiian families with Federal, State, and local activities to further economic and community development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42a40-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to plan for and integrate infrastructure resources on the Hawaiian Home Lands with housing development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42a41-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d42a42-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the development of private capital markets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d42a43-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the markets referred to in clause (i) to operate and grow, thereby benefiting Native Hawaiian communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42a44-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible families","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62d42a45-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided under subparagraph (B), assistance for eligible housing activities under this subchapter shall be limited to low-income Native Hawaiian families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42a46-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception to low-income requirement","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d42a47-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may provide assistance for homeownership activities under—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62d42a48-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4229/b"},"text":"section 4229(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d42a49-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" model activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4229/f"},"text":"section 4229(f) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62d42a4a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loan guarantee activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715z–13b"},"text":"section 1715z–13b of title 12","children":[],"tail":" to Native Hawaiian families who are not low-income families, to the extent that the Secretary approves the activities under that section to address a need for housing for those families that cannot be reasonably met without that assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d42a4b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish limitations on the amount of assistance that may be provided under this subchapter for activities for families that are not low-income families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42a4c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other families","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1), the Director may provide housing or housing assistance provided through affordable housing activities assisted with grant amounts under this subchapter to a family that is not composed of Native Hawaiians if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d42a4d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department determines that the presence of the family in the housing involved is essential to the well-being of Native Hawaiian families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d42a4e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for housing for the family cannot be reasonably met without the assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42a4f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62d42a50-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A housing plan submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4223"},"text":"section 4223 of this title","children":[],"tail":" may authorize a preference, for housing or housing assistance provided through affordable housing activities assisted with grant amounts provided under this subchapter to be provided, to the extent practicable, to families that are eligible to reside on the Hawaiian Home Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62d42a51-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which a housing plan provides for preference described in clause (i), the Director shall ensure that housing activities that are assisted with grant amounts under this subchapter are subject to that preference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62d42a52-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4228/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of nonprofit organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receiving grant amounts under this subchapter, the Department of Hawaiian Home Lands, shall to the extent practicable, provide for private nonprofit organizations experienced in the planning and development of affordable housing for Native Hawaiians to carry out affordable housing activities with those grant amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d42a53-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s809"},"text":"Pub. L. 104–330, title VIII, § 809","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s203"},"text":"Pub. L. 106–568, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2885"},"text":"114 Stat. 2885","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tV/s513"},"text":"Pub. L. 106–569, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2979"},"text":"114 Stat. 2979","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d42a54-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d42a55-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62d42a56-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568/s203"},"text":"Pub. L. 106–568, § 203","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":", enacted identical sections 809 of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":". This section is based on the text of "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s809"},"text":"section 809 of Pub. L. 104–330","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s513"},"text":"Pub. L. 106–569, § 513","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
