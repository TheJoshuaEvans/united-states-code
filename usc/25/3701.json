{"tag":"section","attrib":{"id":"id62c3886d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3701"},"text":null,"children":[{"tag":"num","attrib":{"value":"3701"},"text":"§ 3701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds and declares that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c3886e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States and Indian tribes have a government to government relationship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c3886f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States has a trust responsibility to protect, conserve, utilize, and manage Indian agricultural lands consistent with its fiduciary obligation and its unique relationship with Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c38870-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian agricultural lands are renewable and manageable natural resources which are vital to the economic, social, and cultural welfare of many Indian tribes and their members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c38871-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3701/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and management of Indian agricultural lands in accordance with integrated resource management plans will ensure proper management of Indian agricultural lands and will produce increased economic returns, enhance Indian self-determination, promote employment opportunities, and improve the social and economic well-being of Indian and surrounding communities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c38872-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/177/s2"},"text":"Pub. L. 103–177, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2011"},"text":"107 Stat. 2011","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c38873-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62c38874-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id62c38875-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/177/s1"},"text":"Pub. L. 103–177, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2011"},"text":"107 Stat. 2011","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/177/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘American Indian Agricultural Resource Management Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
