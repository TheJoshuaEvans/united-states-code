{"tag":"section","attrib":{"id":"id628f0aeb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2016"},"text":null,"children":[{"tag":"num","attrib":{"value":"2016"},"text":"§ 2016.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of Indian students","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such rules and regulations as are necessary to ensure the constitutional and civil rights of Indian students attending Bureau-funded schools, including such students’ rights to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628f0aec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2016/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" privacy under the laws of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628f0aed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2016/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" freedom of religion and expression; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628f0aee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2016/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" due process in connection with disciplinary actions, suspensions, and expulsions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id628f0aef-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1136"},"text":"Pub. L. 95–561, title XI, § 1136","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1042"},"text":"Pub. L. 107–110, title X, § 1042","children":[],"tail":", "},{"tag":"date","att