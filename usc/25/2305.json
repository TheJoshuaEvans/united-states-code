{"tag":"section","attrib":{"id":"id629af1bb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2305"},"text":null,"children":[{"tag":"num","attrib":{"value":"2305"},"text":"§ 2305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge and barring of claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id629af1bc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment and acceptance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The payment and acceptance of any claim, after its determination in accordance with this chapter, shall be a full discharge to the United States or any State or political subdivision thereof of all claims and demands touching any of the matters involved in the controversy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629af1bd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims filed prior to ","children":[{"tag":"date","attrib":{"date":"1984-10-19"},"text":"October 19, 1984","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter shall not affect claims arising from any unauthorized disbursement which were filed in any court of competent jurisdiction prior to ","children":[{"tag":"date","attrib":{"date":"1984-10-19"},"text":"October 19, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629af1be-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/500/s6"},"text":"Pub. L. 98–500, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2318"},"text":"98 Stat. 2318","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
