{"tag":"section","attrib":{"id":"id62669aed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621q"},"text":null,"children":[{"tag":"num","attrib":{"value":"1621q"},"text":"§ 1621q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention, control, and elimination of communicable and infectious diseases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62669aee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Service, and after consultation with the Centers for Disease Control and Prevention, may make grants available to Indian tribes and tribal organizations for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62669aef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621q/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Projects for the prevention, control, and elimination of communicable and infectious diseases, including tuberculosis, hepatitis, HIV, respiratory syncytial virus, hanta virus, sexually transmitted diseases, and H. pylori.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62669af0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621q/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public information and education programs for the prevention, control, and elimination of communicable and infectious diseases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62669af1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621q/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Education, training, and clinical skills improvement activities in the prevention, control, and elimination of communicable and infectious diseases for health professionals, including allied health professionals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62669af2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621q/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Demonstration projects for the screening, treatment, and prevention of hepatitis C virus (HCV).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62669af3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide funding under subsection (a) only if an application or proposal for funding is submitted to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62669af4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621q/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with health agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Indian tribes and tribal organizations receiving funding under this section are encouraged to coordinate their activities with the Centers for Disease Control and Prevention and State and local health agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62669af5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621q/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance; report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62669af6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621q/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, at the request of an Indian tribe or tribal organization, provide technical assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62669af7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1621q/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall prepare and submit a report to Congress biennially on the use of funds under this section and on the progress made toward the prevention, control, and elimination of communicable and infectious diseases among Indians and urban Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62669af8-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tII/s218"},"text":"Pub. L. 94–437, title II, § 218","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tII/s214"},"text":"Pub. L. 102–573, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4556"},"text":"106 Stat. 4556","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s10/e/1"},"text":"Pub. L. 103–437, § 10(e)(1)","children":[],"tail":", (2)(B), "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4589"},"text":"108 Stat. 4589","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62669af9-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62669afa-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62669afb-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" is based on section 133 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62669afc-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" amended section generally. Prior to amendment, section related to grants to Indian tribes and tribal organizations for prevention, control, and elimination of tuberculosis."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Committee on Indian” for “Select Committee on Indian” and “Natural Resources” for “Interior and Insular Affairs”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62669afd-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62669afe-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coverage of Testing for COVID–19 at No Cost Sharing for Indians Receiving Purchased/Referred Care","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/127/dF/s6007"},"text":"Pub. L. 116–127, div. F, § 6007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-18"},"text":"Mar. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/208"},"text":"134 Stat. 208","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/127/dF/s6007"},"text":"“The Secretary of Health and Human Services shall cover, without the imposition of any cost sharing requirements, the cost of providing any COVID–19 related items and services as described in paragraph (1) of section 6001(a) [of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/127"},"text":"Pub. L. 116–127","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–5"},"text":"42 U.S.C. 1320b–5","children":[],"tail":" note] (or the administration of such products) or visits described in paragraph (2) of such section furnished during any portion of the emergency period defined in paragraph (1)(B) of section 1135(g) of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s320b–5/g"},"text":"42 U.S.C. 320b–5(g)","children":[],"tail":" [1320b–5(g)]) beginning on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2020-03-18"},"text":"Mar. 18, 2020","children":[],"tail":"] to Indians (as defined in section 4 of the Indian Health Care Improvement Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"25 U.S.C. 1603","children":[],"tail":")) receiving health services through the Indian Health Service, including through an Urban Indian Organization, regardless of whether such items or services have been authorized under the purchased/referred care system funded by the Indian Health Service or is covered as a health service of the Indian Health Service.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
