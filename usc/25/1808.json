{"tag":"section","attrib":{"id":"id627e691b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1808"},"text":null,"children":[{"tag":"num","attrib":{"value":"1808"},"text":"§ 1808.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id627e691c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1808/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627e691d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1808/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1811"},"text":"section 1811 of this title","children":[],"tail":", the Secretary shall, subject to appropriations, grant for each academic year to each tribally controlled college or university having an application approved by the Secretary an amount equal to the product obtained by multiplying—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id627e691e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1808/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian student count at such college or university during the academic year preceding the academic year for which such funds are being made available, as determined by the Secretary in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801/a/8"},"text":"section 1801(a)(8) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id627e691f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1808/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $8,000, as adjusted annually for inflation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e6920-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1808/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant under paragraph (1) shall not exceed an amount equal to the total cost of the education program provided by the applicable tribally controlled college or university.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627e6921-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1808/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance installment payments; adjustments; methods of payment; interest or investment income; types of investments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627e6922-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1808/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall make payments, pursuant to grants under this chapter, of not less than 95 percent of the funds available for allotment by October 15 or no later than 14 days after appropriations become available, with a payment equal to the remainder of any grant to which a grantee is entitled to be made no later than January 1 of each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e6923-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1808/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the Secretary shall not, in disbursing funds provided under this subchapter, use any method of payment which was not used during fiscal year 1987 in the disbursement of funds provided under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e6924-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1808/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id627e6925-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1808/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any provision of law other than subparagraph (B), any interest or investment income that accrues on any funds provided under this subchapter after such funds are paid to the tribally controlled college or university and before such funds are expended for the purpose for which such funds were provided under this subchapter shall be the property of the tribally controlled college or university and shall not be taken into account by any officer or employee of the Federal Government in determining whether to provide assistance, or the amount of assistance, to the tribally controlled college or university under any provision of Federal law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id627e6926-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1808/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All interest or investment income described in subparagraph (A) shall be expended by the tribally controlled college or university by no later than the close of the fiscal year succeeding the fiscal year in which such interest or investment income accrues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e6927-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1808/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds provided under this subchapter may only be invested by the tribally controlled college or university in obligations of the United States or in obligations or securities that are guaranteed or insured by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627e6928-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1808/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounting by recipient institutions; data collection system","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627e6929-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1808/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each institution receiving payments under this subchapter shall annually provide to the Secretary an accurate and detailed accounting of its operating and maintenance expenses and such other information concerning costs as the Secretary may request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627e692a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1808/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, in consultation with the National Center for Education Statistics, establish a data collection system for the purpose of obtaining accurate information with respect to the needs and costs of operation and maintenance of tribally controlled colleges or universities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627e692b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1808/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as interfering with, or suspending the obligation of the Bureau for, the implementation of all legislative provisions enacted prior to ","children":[{"tag":"date","attrib":{"date":"1988-04-28"},"text":"April 28, 1988","children":[],"tail":", specifically including those of "},{"tag":"ref","attrib":{"href":"/us/pl/98/192"},"text":"Public Law 98–192","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id627e692c-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/tI/s108"},"text":"Pub. L. 95–471, title I, § 108","children":[],"tail":", formerly § 107, "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1327"},"text":"92 Stat. 1327","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/375/tI/s108/c"},"text":"Pub. L. 97–375, title I, § 108(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1820"},"text":"96 Stat. 1820","children":[],"tail":"; renumbered § 108 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/192"},"text":"Pub. L. 98–192","children":[],"tail":", §§ 4(a)(1), 7, "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1336"},"text":"97 Stat. 1336","children":[],"tail":", 1337; "},{"tag":"ref","attrib":{"href":"/us/pl/99/428/s4"},"text":"Pub. L. 99–428, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"Sept. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/983"},"text":"100 Stat. 983","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5402/a"},"text":"Pub. L. 100–297, title V, § 5402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/415"},"text":"102 Stat. 415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/427/s24"},"text":"Pub. L. 100–427, § 24","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1613"},"text":"102 Stat. 1613","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/477/s1/a"},"text":"Pub. L. 101–477, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-30"},"text":"Oct. 30, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1152"},"text":"104 Stat. 1152","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s901/a/1"},"text":"Pub. L. 105–244, title IX, § 901(a)(1)","children":[],"tail":", (b)(5)–(7), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1827"},"text":"112 Stat. 1827","children":[],"tail":", 1828; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s941/f"},"text":"Pub. L. 110–315, title IX, § 941(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3462"},"text":"122 Stat. 3462","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id627e692d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id627e692e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id627e692f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192"},"text":"Public Law 98–192","children":[],"tail":", referred to in subsec. (d), is "},{"tag":"ref","attrib":{"href":"/us/pl/98/192"},"text":"Pub. L. 98–192","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1335"},"text":"97 Stat. 1335","children":[],"tail":", which enacted sections 1804a and 1831 to 1836 of this title, amended former section 640c–1 and sections 1801 to 1803 and 1805 to 1813 of this title, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1815"},"text":"section 1815 of this title","children":[],"tail":". For complete classification of "},{"tag":"ref","attrib":{"href":"/us/pl/98/192"},"text":"Pub. L. 98–192","children":[],"tail":" to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id627e6930-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" inserted subsec. (a) and par. (1) headings, designated introductory provisions and pars. (1) and (2) as par. (1), redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, of par. (1), in introductory provisions, substituted “Except as provided in paragraph (2) and "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1811"},"text":"section 1811 of this title","children":[],"tail":",” for “Except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1811"},"text":"section 1811 of this title","children":[],"tail":",”, “approved by the Secretary” for “approved by him”, and “product obtained by multiplying” for “product of”, in subpar. (A), substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801/a/8"},"text":"section 1801(a)(8) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801/a/7"},"text":"section 1801(a)(7) of this title","children":[],"tail":"”, in subpar. (B), substituted “$8,000, as adjusted annually for inflation.” for “$6,000,”, added par. (2), and struck out former concluding provisions which read as follows: “except that no grant shall exceed the total cost of the education program provided by such college or university.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/a/1"},"text":"Pub. L. 105–244, § 901(a)(1)","children":[],"tail":", (b)(5), (7), substituted “controlled college or university” for “controlled community college” in introductory provisions, “such college or university” for “such college” in par. (1) and concluding provisions, and “$6,000” for “$5,820” in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/5"},"text":"Pub. L. 105–244, § 901(b)(5)","children":[],"tail":", substituted “college or university” for “community college” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/6"},"text":"Pub. L. 105–244, § 901(b)(6)","children":[],"tail":", substituted “colleges or universities” for “community colleges”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/477/s1/a/1"},"text":"Pub. L. 101–477, § 1(a)(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “the Indian student count at such college during such academic year, as determined by the Secretary in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801/a/7"},"text":"section 1801(a)(7) of this title","children":[],"tail":"; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/477/s1/a/2"},"text":"Pub. L. 101–477, § 1(a)(2)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “The Secretary shall make payments, pursuant to grants under this subchapter, in advance installments of not less than 40 per centum of the funds available for allotment, based on anticipated or actual numbers of full-time equivalent Indian students or such other factors as determined by the Secretary. Adjustments for overpayments and underpayments shall be applied to the remainder of such funds and such remainder shall be delivered no later than July 1 of each year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/477/s1/a/3"},"text":"Pub. L. 101–477, § 1(a)(3)","children":[],"tail":", redesignated subsec. (c), relating to construction of section, as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":" designated existing provisions as par. (1) and added pars. (2) to (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/427"},"text":"Pub. L. 100–427","children":[],"tail":" added subsec. (c) relating to construction of section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/428"},"text":"Pub. L. 99–428","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) $4,000 for fiscal year 1984,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) $5,025 for fiscal year 1985,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) $5,415 for fiscal year 1986, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) $5,820 for fiscal year 1987,”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/192"},"text":"Pub. L. 98–192","children":[],"tail":" amended subsec. (a) generally, substituting provision establishing a formula premised on Indian student count at each tribally controlled community college on which funding is to be based for provision which directing the Secretary to grant an amount equal to $4,000 for each full-time equivalent Indian student in attendance during the academic year to each tribally controlled community college having an application approved by the Secretary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/375"},"text":"Pub. L. 97–375","children":[],"tail":" struck out pro­vision directing Secretary to report annually to Congress on needs of tribally controlled community colleges."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6280b221-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6280b222-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6280b223-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date and applicability of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/s6303"},"text":"section 6303 of Pub. L. 100–297","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1071"},"text":"section 1071 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
