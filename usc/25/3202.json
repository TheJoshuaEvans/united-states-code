{"tag":"section","attrib":{"id":"id62b7a15f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202"},"text":null,"children":[{"tag":"num","attrib":{"value":"3202"},"text":"§ 3202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b7a160-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Bureau” means the Bureau of Indian Affairs of the Department of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a161-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “child” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b7a162-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not married, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a163-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not attained 18 years of age;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a164-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “child abuse” includes but is not limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b7a165-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in any case in which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b7a166-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62b7a167-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child is dead or exhibits evidence of skin bruising, bleeding, malnutrition, failure to thrive, burns, fracture of any bone, subdural hematoma, soft tissue swelling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62b7a168-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such condition is not justifiably explained or may not be the product of an accidental occurrence; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b7a169-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child is subjected to sexual assault, sexual molestation, sexual exploitation, sexual contact, or prostitution; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a16a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any case in which a child is subjected to sexual assault, sexual molestation, sexual exploitation, sexual contact, or prostitution;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a16b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “child neglect” includes but is not limited to, negligent treatment or maltreatment of a child by a person, including a person responsible for the child’s welfare, under circumstances which indicate that the child’s health or welfare is harmed or threatened thereby;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a16c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “family violence” means any act, or threatened act, of violence, including any forceful detention of an individual, which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b7a16d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results, or threatens to result, in physical or mental injury, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a16e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is committed by an individual against another individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62b7a16f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to whom such person is, or was, related by blood or marriage or otherwise legally related, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62b7a170-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with whom such person is, or was, residing;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a171-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian” means any individual who is a member of an Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a172-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian child” has the meaning given to such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1903/4"},"text":"section 1903(4) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a173-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian country” has the meaning given to such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1151"},"text":"section 1151 of title 18","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a174-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian reservation” means any Indian reservation, public domain Indian allotment, former Indian reservation in Oklahoma, or lands held by incorporated Native groups, regional corporations, or village corporations under the provisions of the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a175-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian tribe” and “tribal organization” have the respective meanings given to each of such terms under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a176-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “inter-tribal consortium” means a partnership between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b7a177-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe or tribal organization of an Indian tribe, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a178-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more Indian tribes or tribal organizations of one or more other Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a179-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “local child protective services agency” means that agency of the Federal Government, of a State, or of an Indian tribe that has the primary responsibility for child protection on any Indian reservation or within any community in Indian country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a17a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “local law enforcement agency” means that Federal, tribal, or State law enforcement agency that has the primary responsibility for the investigation of an instance of alleged child abuse within the portion of Indian country involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a17b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “persons responsible for a child’s welfare” means any person who has legal or other recognized duty for the care and safety of a child, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b7a17c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee or volunteer of a children’s residential facility, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a17d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person providing out-of-home care, education, or services to children;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a17e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “related assistance”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b7a17f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes counseling and self-help services to abusers, victims, and dependents in family violence situations (which shall include counseling of all family members to the extent feasible) and referrals for appropriate health-care services (including alcohol and drug abuse treatment), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a180-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include food, clothing, child care, transportation, and emergency services for victims of family violence and their dependents;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a181-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a182-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “shelter” means the provision of temporary refuge and related assistance in compliance with applicable Federal and tribal laws and regulations governing the provision, on a regular basis, of shelter, safe homes, meals, and related assistance to victims of family violence or their dependents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a183-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3202/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Service” means the Indian Health Service of the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b7a184-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIV/s403"},"text":"Pub. L. 101–630, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4545"},"text":"104 Stat. 4545","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/160/s2/1"},"text":"Pub. L. 118–160, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2567"},"text":"138 Stat. 2567","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62b7a185-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62b7a186-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62b7a187-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630"},"text":"Pub. L. 101–630","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4544"},"text":"104 Stat. 4544","children":[],"tail":", known as the Indian Child Protection and Family Violence Prevention Act, which is classified principally to this chapter. For complete classification of title IV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3201"},"text":"section 3201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Alaska Native Claims Settlement Act, referred to in par. (9), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62b7a188-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Par. (3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/160"},"text":"Pub. L. 118–160","children":[],"tail":" amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “any case in which—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) a child is dead or exhibits evidence of skin bruising, bleeding, malnutrition, failure to thrive, burns, fracture of any bone, subdural hematoma, soft tissue swelling, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) such condition is not justifiably explained or may not be the product of an accidental occurrence; and”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
