{"tag":"section","attrib":{"id":"id625f6f19-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616p"},"text":null,"children":[{"tag":"num","attrib":{"value":"1616p"},"text":"§ 1616p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health professional chronic shortage demonstration programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id625f6f1a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, may fund demonstration programs for Indian health programs to address the chronic shortages of health professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625f6f1b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes of programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of demonstration programs under subsection (a) shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625f6f1c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616p/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide direct clinical and practical experience within an Indian health program to health profession students and residents from medical schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6f1d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616p/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the quality of health care for Indians by ensuring access to qualified health professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6f1e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616p/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide academic and scholarly opportunities for health professionals serving Indians by identifying all academic and scholarly resources of the region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625f6f1f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616p/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide training and support for alternative provider types, such as community health representatives, and community health aides.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625f6f20-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616p/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The demonstration programs established pursuant to subsection (a) shall incorporate a program advisory board, which may be composed of representatives of tribal governments, Indian health programs, and Indian communities in the areas to be served by the demonstration programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id625f6f21-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tI/s123"},"text":"Pub. 