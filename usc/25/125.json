{"tag":"section","attrib":{"id":"id6217df25-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s125"},"text":null,"children":[{"tag":"num","attrib":{"value":"125"},"text":"§ 125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure of moneys of tribes of Quapaw Agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No moneys shall be expended from tribal or individual funds belonging to the Quapaw or other tribes of Indians of the Quapaw Agency in the State of Oklahoma without specific authority of law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6217df26-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1919-06-30/ch4/s17"},"text":"June 30, 1919, ch. 4, § 17","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/20"},"text":"41 Stat. 20","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
