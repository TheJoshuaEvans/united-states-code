{"tag":"section","attrib":{"id":"id62d90b9e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5106"},"text":null,"children":[{"tag":"num","attrib":{"value":"5106"},"text":"§ 5106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds appropriated under section 5108","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying into effect the land-purchase provision of this Act, the Secretary of the Interior is authorized to use so much as may be necessary of any funds heretofore or hereafter appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5108"},"text":"section 5108 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62d90b9f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-10/ch662/s4"},"text":"Aug. 10, 1939, ch. 662, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1351"},"text":"53 Stat. 1351","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d90ba0-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d90ba1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62d90ba2-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-10/ch662"},"text":"act Aug. 10, 1939, ch. 662","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1351"},"text"