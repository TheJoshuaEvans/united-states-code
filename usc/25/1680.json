{"tag":"section","attrib":{"id":"id62773cb7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680"},"text":null,"children":[{"tag":"num","attrib":{"value":"1680"},"text":"§ 1680.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" California as a contract health service delivery area","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The State of California, excluding the counties of Alameda, Contra Costa, Los Angeles, Marin, Orange, Sacramento, San Francisco, San Mateo, Santa Clara, Kern, Merced, Monterey, Napa, San Benito, San Joaquin, San Luis Obispo, Santa Cruz, Solano, Stanislaus, and Ventura shall be designated as a contract health service delivery area by the Service for the purpose of providing contract health services to Indians in such State.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62773cb8-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s810"},"text":"Pub. L. 94–437, title VIII, § 810","children":[],"tail":", formerly title VII, § 710, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/537/s8/b"},"text":"Pub. L. 96–537, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-17"},"text":"Dec. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3181"},"text":"94 Stat. 3181","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tVII/s704"},"text":"Pub. L. 100–713, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4828"},"text":"102 Stat. 4828","children":[],"tail":"; renumbered title VIII, § 810, "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s701/a"},"text":"Pub. L. 102–573, title VII, § 701(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4572"},"text":"106 Stat. 4572","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62773cb9-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62773cba-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62773cbb-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/713"},"text":"Pub. L. 100–713","children":[],"tail":" inserted section catchline and amended text generally, substituting provisions designating parts of California as a contract health service delivery area for former provisions which authorized a demonstration project for lifting personnel ceilings for the Indian Health Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
