{"tag":"section","attrib":{"id":"id62a48dff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507"},"text":null,"children":[{"tag":"num","attrib":{"value":"2507"},"text":"§ 2507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application with respect to Indian Self-Determination and Education Assistance Act","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62a48e00-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain provisions to apply to grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following provisions of the Indian Self-Determination and Education Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.] (and any subsequent revisions thereto or renumbering thereof), shall apply to grants provided under this chapter:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a48e01-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 5(f) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5305/f"},"text":"25 U.S.C. 5305(f)","children":[],"tail":"] (relating to single agency audit)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e02-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 6 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5306"},"text":"25 U.S.C. 5306","children":[],"tail":"] (relating to criminal activities; penalties)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e03-