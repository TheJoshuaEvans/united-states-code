","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 108(c) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5329/c"},"text":"25 U.S.C. 5329(c)","children":[],"tail":"] (Model Agreements provisions (1)(a)(5) "},{"tag":"ref","attrib":{"idref":"fn002175"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002175"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “1(b)(5)”."}],"tail":" (relating to limitations of costs), (1)(a)(7) "},{"tag":"ref","attrib":{"idref":"fn002176"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002176"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “1(b)(7)”."}],"tail":" (relating to records and monitoring), (1)(a)(8) "},{"tag":"ref","attrib":{"idref":"fn002177"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002177"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “1(b)(8)”."}],"tail":" (relating to property), and (a)(1)(9) "},{"tag":"ref","attrib":{"idref":"fn002178"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002178"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. Probably should be “1(b)(9)”."}],"tail":" (relating to availability of funds)."},{"tag":"ref","attrib":{"idref":"fn002179"},"text":"5","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002179"},"text":null,"children":[{"tag":"num","attrib":{},"text":"5","children":[],"tail":" So in original. There probably should be a second closing parenthesis."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e0c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 109 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5330"},"text":"25 U.S.C. 5330","children":[],"tail":"] (relating to reassumption)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e0d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 111 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5332"},"text":"25 U.S.C. 5332","children":[],"tail":"] (relating to sovereign immunity and trusteeship rights unaffected)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a48e0e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election for grant in lieu of contract","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a48e0f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Contractors for activities to which this chapter applies who have entered into a contract under the Indian Self-Determination and Education Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.] that is in effect on "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", may, by giving notice to the Secretary, elect to have the provisions of this chapter apply to such activity in lieu of such contract."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e10-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any election made under paragraph (1) shall take effect on the first day of July immediately following the date of such election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e11-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which the first day of July immediately following the date of an election under paragraph (1) is less than 60 days after such election, such election shall not take effect until the first day of July of ","children":[{"tag":"ref","attrib":{"idref":"fn002180"},"text":"6","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002180"},"text":null,"children":[{"tag":"num","attrib":{},"text":"6","children":[],"tail":" So in original. Probably should be followed by “the”."}],"tail":" year following the year in which the election is made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a48e12-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No duplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds may be provided under any contract entered into under the Indian Self-Determination and Education Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.] to pay any expenses incurred in providing any program or services if a grant has been made under this chapter to pay such expenses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a48e13-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers and carryovers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a48e14-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Buildings, equipment, supplies, materials","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A tribe or tribal organization assuming the operation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a48e15-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Bureau school with assistance under this chapter shall be entitled to the transfer or use of buildings, equipment, supplies, and materials to the same extent as if it were contracting under the Indian Self-Determination and Education Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a48e16-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract school with assistance under this chapter shall be entitled to the transfer or use of buildings, equipment, supplies, and materials that were used in the operation of the contract school to the same extent as if it were contracting under the Indian Self-Determination and Education Assistance Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e17-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any tribe or tribal organization which assumes operation of a Bureau school with assistance under this chapter and any tribe or tribal organization which elects to operate a school with assistance under this chapter rather that ","children":[{"tag":"ref","attrib":{"idref":"fn002181"},"text":"7","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002181"},"text":null,"children":[{"tag":"num","attrib":{},"text":"7","children":[],"tail":" So in original. Probably should be “than”."}],"tail":" to continue as a contract school shall be entitled to any funds which would carryover from the previous fiscal year as if such school were operated as a contract school."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a48e18-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for school improvement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any tribe or tribal organization that assumes operation of a Bureau school or a contract school with assistance under this chapter shall be eligible for funding for the improvement, alteration, replacement, and repair of facilities to the same extent as a Bureau school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a48e19-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2507/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions, problems, and disputes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any exception or problem cited in an audit conducted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2505/b/1"},"text":"section 2505(b)(1) of this title","children":[],"tail":", any dispute regarding a grant authorized to be made pursuant to this chapter or any amendment to such grant, and any dispute involving an administrative cost grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2008"},"text":"section 2008 of this title","children":[],"tail":" shall be administered under the provisions governing such exceptions, problems, or disputes in the case of contracts under the Indian Self-Determination and Education Assistance Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.]. The Equal Access to Justice Act shall apply to administrative appeals filed after "},{"tag":"date","attrib":{"date":"1988-09-08"},"text":"September 8, 1988","children":[],"tail":", by grantees regarding a grant under this chapter, including an administrative cost grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62a48e1a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5208"},"text":"Pub. L. 100–297,