{"tag":"section","attrib":{"id":"id6280b2bf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1835"},"text":null,"children":[{"tag":"num","attrib":{"value":"1835"},"text":"§ 1835.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6280b2c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1835/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From the amount appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1836"},"text":"section 1836 of this title","children":[],"tail":", the Secretary shall allocate to each tribally controlled college or university which is eligible for an endowment grant under this subchapter an amount for a Federal capital contribution equal to twice the value of the property or the amount which such college or university demonstrates has been placed within the control of, or irrevocably committed to the use of, the college or university and is available for deposit as a capital contribution of that college or university in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1832/b/2/B"},"text":"section 1832(b)(2)(B) of this title","children":[],"tail":", except that the maximum amount which may be so allocated to any such college or university for any fiscal year shall not exceed $750,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6280b2c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1835/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If for any fiscal year the amount appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1836"},"text":"section 1836 of this title","children":[],"tail":" is not sufficient to allocate to each tribally controlled college or university an amount equal to twice the value of the property or the amount demonstrated by such college or university pursuant to subsection (a), then the amount of the allocation to each such college or university shall be ratably reduced."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6280b2c2-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/tIII/s305"},"text":"Pub. L. 95–471, title III, § 305","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/192/s13"},"text":"Pub. L. 98–192, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1342"},"text":"97 Stat. 1342","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/477/s1/d/1/D"},"text":"Pub. L. 101–477, § 1(d)(1)(D)","children":[],"tail":", (E), "},{"tag":"date","attrib":{"date":"1990-10-30"},"text":"Oct. 30, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1153"},"text":"104 Stat. 1153","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s901/b/5"},"text":"Pub. L. 105–244, title IX, § 901(b)(5)","children":[],"tail":", (7), (12), (14), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1828"},"text":"112 Stat. 1828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id628323c3-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id628323c4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id628323c5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" substituted “controlled college or university” for “controlled community college”, “such college or university” for “such college” in two places, “the college or university” for “the college”, and “that college or university” for “that college”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s901/b/5"},"text":"Pub. L. 105–244, § 901(b)(5)","children":[],"tail":", (7), substituted “controlled college or university” for “controlled community college” and substituted “such college or university” for “such college” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/477"},"text":"Pub. L. 101–477","children":[],"tail":" inserted “twice the value of the property or” after “equal to” in subsecs. (a) and (b) and substituted “$750,000” for “$350,000” in subsec. (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id628323c6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id628323c7-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id628323c8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/477"},"text":"Pub. L. 101–477","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"Oct. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/477/s1/d/2"},"text":"section 1(d)(2) of Pub. L. 101–477","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1832"},"text":"section 1832 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
