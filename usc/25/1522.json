{"tag":"section","attrib":{"id":"id62584351-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1522"},"text":null,"children":[{"tag":"num","attrib":{"value":"1522"},"text":"§ 1522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62584352-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1522/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant in excess of $100,000 in the case of an Indian and $250,000 in the case of an Indian tribe, or such lower amount as the Secretary may determine to be appropriate, may be made under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62584353-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1522/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financing from other sources; inability to obtain funds; applicant’s financial resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant may be made only to an applicant who, in the opinion of the Secretary, is unable to obtain adequate financing for its economic enterprise from other sources: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That prior to making any grant under this subchapter, the Secretary shall assure that, where practical, the applicant has reasonably made available for the economic enterprise funds from the applicant’s own financial resources."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62584354-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1522/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Percentage requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant may be made to an applicant who is unable to obtain at least 60 per centum of the necessary funds for the economic enterprise from other sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62584355-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/tIV/s402"},"text":"Pub. L. 93–262, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/83"},"text":"88 Stat. 83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/449/s9"},"text":"Pub. L. 98–449, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-04"},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1725"},"text":"98 Stat. 1725","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62584356-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62584357-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62584358-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/449"},"text":"Pub. L. 98–449","children":[],"tail":" amended subsec. (a) generally, substituting provisions setting forth different levels of maximum grant amounts in cases of Indians and Indian tribes for provisions providing a maximum of $50,000 in cases of both Indians and Indian tribes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
