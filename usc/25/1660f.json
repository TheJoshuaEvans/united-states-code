{"tag":"section","attrib":{"id":"id62701047-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1660f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1660f"},"text":"§ 1660f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community Health Representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Service, may enter into contracts with, and make grants to, urban Indian organizations for the employment of Indians trained as health service providers through the Community Health Representative Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1616"},"text":"section 1616 of this title","children":[],"tail":" in the provision of health care, health promotion, and disease prevention services to urban Indians."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62701048-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tV/s516"},"text":"Pub. L. 94–437, title V, § 516","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62701049-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6270104a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6270104b-4962-11f1-add1-b56d3fa293fa"},"text":null,"childre