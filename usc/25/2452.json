{"tag":"section","attrib":{"id":"id629fd3e6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2452"},"text":null,"children":[{"tag":"num","attrib":{"value":"2452"},"text":"§ 2452.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical assessment and treatment of juvenile offenders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id629fd3e7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2452/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and implementation of procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Memorandum of Agreement entered into pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2411"},"text":"section 2411 of this title","children":[],"tail":" shall include a specific provision for the development and implementation at each Bureau of Indian Affair "},{"tag":"ref","attrib":{"idref":"fn002158"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002158"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Affairs”."}],"tail":" agency and Indian Health Service "},{"tag":"ref","attrib":{"idref":"fn002159"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002159"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by “service”."}],"tail":" unit of a procedure for the emergency medical assessment and treatment of every Indian youth arrested or detained by Bureau of Indian Affairs or tribal law enforcement personnel for an offense relating to or involving alcohol or substance abuse. The medical assessment required by this subsection—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id629fd3e8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2452/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be conducted to determine the mental or physical state of the individual assessed so that appropriate steps can be taken to protect the individual’s health and well-being,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629fd3e9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2452/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall occur as soon as possible after the arrest or detention of an Indian youth, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629fd3ea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2452/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be provided by the Indian Health Service, either through its direct or contract health service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629fd3eb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2452/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain committed youth","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Indian Health Service shall not refuse to provide necessary interim treatment for any Indian youth referred pursuant to subsection (a) who has been charged or is being prosecuted for any crime unless such referral is prohibited by a court of competent jurisdiction or the youth is determined by a court of competent jurisdiction to be a danger to others.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629fd3ec-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4219"},"text":"Pub. L. 99–570, title IV, § 4219","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-147"},"text":"100 Stat. 3207–147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2210"},"text":"Pub. L. 100–690, title II, § 2210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4219"},"text":"102 Stat. 4219","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id629fd3ed-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id629fd3ee-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id629fd3ef-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
