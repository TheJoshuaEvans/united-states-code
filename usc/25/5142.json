{"tag":"section","attrib":{"id":"id62db56bc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5142"},"text":null,"children":[{"tag":"num","attrib":{"value":"5142"},"text":"§ 5142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of unpaid principal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62db56bd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5142/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture may, on the application of the borrower of a loan or loans made under sections 5136 to 5143 of this title, reduce the unpaid principal balance of such loan or loans to the current fair market value of the land purchased with the proceeds of the loan or loans if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62db56be-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5142/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of the land has declined by at least 25 percent since such land was purchased by the borrower;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62db56bf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5142/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the land has been held by the borrower for a period of at least 5 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62db56c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5142/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior finds that the borrower has insufficient income to both repay the loan or loans and provide normal tribal governmental services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62db56c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5142/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fair market value","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62db56c2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5142/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appraisal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Current fair market value under subsection (a) of this section shall be determined through an appraisal by an independent qualified fee appraiser, selected by mutual agreement between the borrower and the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62db56c3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5142/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cost of appraisals undertaken under paragraph (1) shall be paid by the borrower.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62db56c4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5142/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Decisions of the Secretary of Agriculture under this section shall be appealable in accordance with the provisions of section 333B ","children":[{"tag":"ref","attrib":{"idref":"fn002251"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002251"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Consolidated Farm and Rural Development Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1983b"},"text":"7 U.S.C. 1983b","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62db56c5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5142/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Future applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A borrower that had a loan or loans reduced under this section shall not submit an application for another reduction on such loan or loans for a period of 5 years after the initial reduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62db56c6-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/229/s6"},"text":"Pub. L. 91–229, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/82/tIII/s303"},"text":"Pub. L. 101–82, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-14"},"text":"Aug. 14, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/583"},"text":"103 Stat. 583","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62db56c7-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62db56c8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62db56c9-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 333B of the Consolidated Farm and Rural Development Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1983b"},"text":"7 U.S.C. 1983b","children":[],"tail":"), referred to in subsec. (c), probably means "},{"tag":"ref","attrib":{"href":"/us/pl/87/128/s333B"},"text":"section 333B of Pub. L. 87–128","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXIII/s1313/a"},"text":"Pub. L. 99–198, title XIII, § 1313(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1525"},"text":"99 Stat. 1525","children":[],"tail":", and amended, which related to appeals from adverse decisions under the Act, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s281/c"},"text":"Pub. L. 103–354, title II, § 281(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3233"},"text":"108 Stat. 3233","children":[],"tail":", and enactment of a new "},{"tag":"ref","attrib":{"href":"/us/pl/87/128/s333B"},"text":"section 333B of Pub. L. 87–128","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tV/s5301"},"text":"Pub. L. 110–234, title V, § 5301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1147"},"text":"122 Stat. 1147","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tV/s5301"},"text":"Pub. L. 110–246, title V, § 5301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1908"},"text":"122 Stat. 1908","children":[],"tail":", which established a beginning farmers’ pilot program."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62db56ca-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/229/s6"},"text":"section 6 of Pub. L. 91–229","children":[],"tail":" was added by "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVIII/s1854/b"},"text":"Pub. L. 101–624, title XVIII, § 1854(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3837"},"text":"104 Stat. 3837","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5143"},"text":"section 5143 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s493"},"text":"section 493 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
