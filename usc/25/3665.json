{"tag":"section","attrib":{"id":"id62c3883a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665"},"text":null,"children":[{"tag":"num","attrib":{"value":"3665"},"text":"§ 3665.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal authority","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall be construed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c3883b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encroach upon or diminish in any way the inherent sovereign authority of each tribal government to determine the role of the tribal justice system within the tribal government or to enact and enforce tribal laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c3883c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diminish in any way the authority of tribal governments to appoint personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c3883d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impair the rights of each tribal government to determine the nature of its own legal system or the appointment of authority within the tribal government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c3883e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alter in any way any tribal traditional dispute resolution fora;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c3883f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imply that any tribal justice system is an instrumentality of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c38840-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3665/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diminish the trust responsibility of the United States to Indian tribal governments and tribal justice systems of such governments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c38841-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/559/tI/s105"},"text":"Pub. L. 106–559, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2781"},"text":"114 Stat. 2781","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
