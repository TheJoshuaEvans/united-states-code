{"tag":"section","attrib":{"id":"id62bc5d30-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502"},"text":null,"children":[{"tag":"num","attrib":{"value":"3502"},"text":"§ 3502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribal energy resource development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62bc5d31-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of the Interior program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5d32-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assist Indian tribes in the development of energy resources and further the goal of Indian self-determination, the Secretary shall establish and implement an Indian energy resource development program to assist consenting Indian tribes and tribal energy development organizations in achieving the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd33-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out the Program, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62becd34-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide development grants to Indian tribes and tribal energy development organizations for use in developing or obtaining the managerial and technical capacity needed to develop energy resources on Indian land, and to properly account for resulting energy production and revenues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd35-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide grants to Indian tribes and tribal energy development organizations for use in carrying out projects to promote the integration of energy resources, and to process, use, or develop those energy resources, on Indian land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd36-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide low-interest loans to Indian tribes and tribal energy development organizations for use in the promotion of energy resource development on Indian land and integration of energy resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd37-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide grants and technical assistance to an appropriate tribal environmental organization, as determined by the Secretary, that represents multiple Indian tribes to establish a national resource center to develop tribal capacity to establish and carry out tribal environmental programs in support of energy-related programs and activities under this chapter, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62becd38-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training programs for tribal environmental officials, program managers, and other governmental representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62becd39-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of model environmental policies and tribal laws, including tribal environmental review codes, and the creation and maintenance of a clearinghouse of best environmental management practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62becd3a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommended standards for reviewing the implementation of tribal environmental laws and policies within tribal judicial or other tribal appeals systems; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd3b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with each applicable Indian tribe before adopting or approving a well spacing program or plan applicable to the energy resources of that Indian tribe or the members of that Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd3c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated to carry out this subsection such sums as are necessary for each of fiscal years 2006 through 2016.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd3d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62becd3e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program established by paragraph (1), the Secretary shall provide technical assistance to interested Indian tribes to develop energy plans, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62becd3f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans for electrification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62becd40-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans for oil and gas permitting, renewable energy permitting, energy efficiency, electricity generation, transmission planning, water planning, and other planning relating to energy issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62becd41-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans for the development of energy resources and to ensure the protection of natural, historic, and cultural resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62becd42-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other plans that would assist an Indian tribe in the development or use of energy resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd43-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In establishing the program under paragraph (1), the Secretary shall work in cooperation with the Office of Indian Energy Policy and Programs of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62becd44-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Energy Indian energy education planning and management assistance program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62becd45-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall establish programs to assist consenting Indian tribes in meeting energy education, research and development, planning, and management needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd46-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out this subsection, the Director may provide grants, on a competitive basis, to an Indian tribe, intertribal organization, or tribal energy development organization for use in carrying out—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62becd47-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy, energy efficiency, and energy conservation programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd48-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies and other activities supporting tribal acquisitions of energy supplies, services, and facilities, including the creation of tribal utilities to assist in securing electricity to promote electrification of homes and businesses on Indian land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd49-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities to increase the capacity of Indian tribes to manage energy development and energy efficiency programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd4a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning, construction, development, operation, maintenance, and improvement of tribal electrical generation, transmission, and distribution facilities located on Indian land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd4b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development, construction, and interconnection of electric power transmission facilities located on Indian land with other electric transmission facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd4c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical and scientific resources","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to providing grants to Indian tribes under this subsection, the Secretary shall collaborate with the Directors of the National Laboratories in making the full array of technical and scientific resources of the Department of Energy available for tribal energy activities and projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd4d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62becd4e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director shall develop a program to support and implement research projects that provide Indian tribes with opportunities to participate in carbon sequestration practices on Indian land, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62becd4f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geologic sequestration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62becd50-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forest sequestration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62becd51-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural sequestration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62becd52-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other sequestration opportunities the Director considers to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd53-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The activities carried out under subparagraph (A) shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62becd54-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinated with other carbon sequestration research and development programs conducted by the Secretary of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62becd55-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducted to determine methods consistent with existing standardized measurement protocols to account and report the quantity of carbon dioxide or other greenhouse gases sequestered in projects that may be implemented on Indian land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62becd56-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewed periodically to collect and distribute to Indian tribes information on carbon sequestration practices that will increase the sequestration of carbon without threatening the social and economic well-being of Indian tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd57-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62becd58-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director, in consultation with Indian tribes, may develop a formula for providing grants under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd59-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In providing a grant under this subsection, the Director shall give priority to any application received from an Indian tribe with inadequate electric service (as determined by the Director).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd5a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In providing a grant under this subsection for an activity to provide, or expand the provision of, electricity on Indian land, the Director shall encourage cooperative arrangements between Indian tribes and utilities that provide service to Indian tribes, as the Director determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd5b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy may reduce any applicable cost share required of an Indian tribe, intertribal organization, or tribal energy development organization in order to receive a grant under this subsection to not less than 10 percent if the Indian tribe, intertribal organization, or tribal energy development organization meets criteria developed by the Secretary of Energy, including financial need.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd5c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"Section 16352 of title 42","children":[],"tail":" shall not apply to assistance provided under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd5d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy may issue such regulations as the Secretary determines to be necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd5e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated to carry out this subsection $30,000,000 for each of fiscal years 2021 through 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62becd5f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Energy loan guarantee program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62becd60-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraphs (2) and (4), the Secretary of Energy may provide loan guarantees (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a"},"text":"section 661a of title 2","children":[],"tail":", except that a loan guarantee may guarantee any debt obligation of a non-Federal borrower to any Eligible Lender (as defined in section 609.2 of title 10, Code of Federal Regulations)) for the unpaid principal and interest due on any loan made to an Indian tribe or a tribal energy development organization for energy development."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd61-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In providing a loan guarantee under this subsection for an activity to provide, or expand the provision of, electricity on Indian land, the Secretary of Energy shall encourage cooperative arrangements between Indian tribes and utilities that provide service to Indian tribes, as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd62-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A loan guaranteed under this subsection shall be made by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62becd63-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial institution subject to examination by the Secretary of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd64-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe, from funds of the Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd65-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribal energy development organization, from funds of the tribal energy development organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd66-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate outstanding amount guaranteed by the Secretary of Energy at any time under this subsection shall not exceed $20,000,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd67-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-12-18"},"text":"December 18, 2018","children":[],"tail":", the Secretary of Energy shall issue such regulations as the Secretary of Energy determines are necessary to carry out this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd68-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated such sums as are necessary to carry out this subsection, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd69-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary of Energy shall submit to Congress a report on the financing requirements of Indian tribes for energy development on Indian land."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62becd6a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62becd6b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In purchasing electricity or any other energy product or byproduct, a Federal agency or department may give preference to an energy and resource production enterprise, partnership, consortium, corporation, or other type of business organization the majority of the interest in which is owned and controlled by 1 or more Indian tribes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62becd6c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out this subsection, a Federal agency or department shall not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62becd6d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay more than the prevailing market price for an energy product or byproduct; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62becd6e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3502/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain less than prevailing market terms and conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62becd6f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXVI/s2602"},"text":"Pub. L. 102–486, title XXVI, § 2602","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tV/s503/a"},"text":"Pub. L. 109–58, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/765"},"text":"119 Stat. 765","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/325/tI"},"text":"Pub. L. 115–325, title I","children":[],"tail":", §§ 101, 104, 105(b), "},{"tag":"date","attrib":{"date":"2018-12-18"},"text":"Dec. 18, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4445"},"text":"132 Stat. 4445","children":[],"tail":", 4455, 4456; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tVIII/s8013/b"},"text":"Pub. L. 116–260, div. Z, title VIII, § 8013(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2592"},"text":"134 Stat. 2592","children":[],"tail":", 2593; "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/tV/s50145/b"},"text":"Pub. L. 117–169, title V, § 50145(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2046"},"text":"136 Stat. 2046","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62becd70-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62becd71-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62becd72-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", referred to in subsec. (c)(7), was in the original “the date of enactment of this section”, which was translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", which amended this chapter generally, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62becd73-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3502, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXVI/s2602"},"text":"Pub. L. 102–486, title XXVI, § 2602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3113"},"text":"106 Stat. 3113","children":[],"tail":", related to tribal consultation in implementing provisions, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62becd74-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":" substituted “, except that a loan guarantee may guarantee any debt obligation of a non-Federal borrower to any Eligible Lender (as defined in section 609.2 of title 10, Code of Federal Regulations)) for” for “) for an amount equal to not more than 90 percent of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/s50145/b/2"},"text":"Pub. L. 117–169, § 50145(b)(2)","children":[],"tail":", substituted “$20,000,000,000” for “$2,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(5)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s8013/b"},"text":"Pub. L. 116–260, § 8013(b)","children":[],"tail":", added subpars. (D) and (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s8013/c"},"text":"Pub. L. 116–260, § 8013(c)","children":[],"tail":", substituted “$30,000,000 for each of fiscal years 2021 through 2025” for “$20,000,000 for each of fiscal years 2006 through 2016”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325/s105/b/1/A"},"text":"Pub. L. 115–325, § 105(b)(1)(A)","children":[],"tail":", substituted “tribal energy development organizations” for “tribal energy resource development organizations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325/s105/b/1/B"},"text":"Pub. L. 115–325, § 105(b)(1)(B)","children":[],"tail":", substituted “tribal energy development organizations” for “tribal energy resource development organizations” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325/s101/a/1"},"text":"Pub. L. 115–325, § 101(a)(1)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325/s101/a/2"},"text":"Pub. L. 115–325, § 101(a)(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325"},"text":"Pub. L. 115–325","children":[],"tail":", §§ 101(b)(1), 105(b)(2), substituted “Indian tribe, intertribal organization, or tribal energy development organization” for “Indian tribe or tribal energy resource development organization” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C) to (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325/s101/b/2"},"text":"Pub. L. 115–325, § 101(b)(2)","children":[],"tail":", (3), added subpar. (C) and redesignated former subpars. (C) and (D) as (D) and (E), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325/s104"},"text":"Pub. L. 115–325, § 104","children":[],"tail":", added par. (3) and redesignated former pars. (3) to (6) as (4) to (7), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325/s101/c/1"},"text":"Pub. L. 115–325, § 101(c)(1)","children":[],"tail":", inserted “or a tribal energy development organization” after “Indian tribe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325/s101/c/2/A"},"text":"Pub. L. 115–325, § 101(c)(2)(A)","children":[],"tail":", substituted “guaranteed” for “guarantee” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325/s101/c/2/B"},"text":"Pub. L. 115–325, § 101(c)(2)(B)","children":[],"tail":"–(D), added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325/s101/c/3"},"text":"Pub. L. 115–325, § 101(c)(3)","children":[],"tail":", substituted “Not later than 1 year after "},{"tag":"date","attrib":{"date":"2018-12-18"},"text":"December 18, 2018","children":[],"tail":", the Secretary of Energy shall” for “The Secretary of Energy may”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62becd75-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62becd76-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Tribal Energy Loan Guarantee Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dD/tIII"},"text":"Pub. L. 117–328, div. D, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4637"},"text":"136 Stat. 4637","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dD/tIII"},"text":"“That in this fiscal year and subsequent fiscal years, under section 2602(c) of the Energy Policy Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3502/c"},"text":"25 U.S.C. 3502(c)","children":[],"tail":"), the Secretary of Energy may also provide direct loans, as defined in section 502 of the Congressional Budget Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a"},"text":"2 U.S.C. 661a","children":[],"tail":"): "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That such direct loans shall be made through the Federal Financing Bank, with the full faith and credit of the United States Government on the principal and interest: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That any funds previously appropriated for the cost of loan guarantees under section 2602(c) of the Energy Policy Act of 1992 ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3502/c"},"text":"25 U.S.C. 3502(c)","children":[],"tail":") may also be used, in this fiscal year and subsequent fiscal years, for the cost of direct loans provided under such section of such Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
