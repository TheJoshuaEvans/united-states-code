{"tag":"section","attrib":{"id":"id62098639-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"§ 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner of Indian Affairs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be in the Department of the Interior a Commissioner of Indian Affairs, who shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6209863a-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 462.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6209863b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6209863c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6209863d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 462 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1832-07-09/ch174/s1"},"text":"act July 9, 1832, ch. 174, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/564"},"text":"4 Stat. 564","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of this section relating to compensation of the Commissioner were omitted as obsolete. The position is in level V of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6209863e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id6209863f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
