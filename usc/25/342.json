{"tag":"section","attrib":{"id":"id622fac1a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s342"},"text":null,"children":[{"tag":"num","attrib":{"value":"342"},"text":"§ 342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of Southern Utes to new reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this act shall be so construed as to prevent the removal of the Southern Ute Indians from their present reservation in southwestern Colorado to a new reservation by and with the consent of a majority of the adult male members of said tribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id622fac1b-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-02-08/ch119/s11"},"text":"Feb. 8, 1887, ch. 119, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/391"},"text":"24 Stat. 391","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id622fac1c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id622fac1d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id622fac1e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-02-08/ch119"},"text":"act Feb. 8, 1887, ch. 119","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/388"},"text":"24 Stat. 388","children":[],"tail":", and is popularly known as the Indian General Allotment Act. For classification of this act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s331"},"text":"section 331 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
