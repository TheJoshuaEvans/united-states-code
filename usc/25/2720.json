{"tag":"section","attrib":{"id":"id62a9490d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2720"},"text":null,"children":[{"tag":"num","attrib":{"value":"2720"},"text":"§ 2720.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Consistent with the requirements of this chapter, sections 1301, 1302, 1303 and 1304 of title 18 shall not apply to any gaming conducted by an Indian tribe pursuant to this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62a9490e-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497/s21"},"text":"Pub. L. 100–497, § 21","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2486"},"text":"102 Stat. 2486","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62a9490f-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62a94910-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62a94911-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497"},"text":"Pub. L. 100–497","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2467"},"text":"102 Stat. 2467","children":[],"tail":", known as the Indian Gaming Regulatory Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2701"},"text":"section 2701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
