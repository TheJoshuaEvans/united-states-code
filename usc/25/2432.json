{"tag":"section","attrib":{"id":"id629d6290-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2432"},"text":null,"children":[{"tag":"num","attrib":{"value":"2432"},"text":"§ 2432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian education programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id629d6291-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2432/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summer youth programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629d6292-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2432/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of the Indian Alcohol and Substance Abuse Program, in coordination with the Assistant Secretary for Indian Affairs, shall develop and implement programs in tribal schools and schools funded by the Bureau of Indian Education (subject to the approval of the local school board or contract school board) to determine the effectiveness of summer youth programs in advancing the purposes and goals of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d6293-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2432/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of the Indian Alcohol and Substance Abuse Program and the Assistant Secretary shall defray all costs associated with the actual operation and support of the summer youth programs in a school from funds appropriated to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d6294-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2432/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out the programs under this subsection $5,000,000 for each of fiscal years 2011 through 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629d6295-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2432/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Federal financial assistance made available to public or private schools because of the enrollment of Indian children pursuant to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629d6296-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2432/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1934-04-16"},"text":"April 16, 1934","children":[],"tail":", as amended by the Indian Education Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s452"},"text":"25 U.S.C. 452","children":[],"tail":" et seq.),"},{"tag":"ref","attrib":{"idref":"fn002154"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002154"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d6297-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2432/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian Elementary and Secondary School Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s241aa"},"text":"20 U.S.C. 241aa","children":[],"tail":" et seq.),"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d6298-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2432/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian Education Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3385"},"text":"20 U.S.C. 3385","children":[],"tail":"),"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may be used to support a program of instruction relating to alcohol and substance abuse prevention and treatment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629d6299-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4212"},"text":"Pub. L. 99–570, title IV, § 4212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-144"},"text":"100 Stat. 3207–144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2206"},"text":"Pub. L. 100–690, title II, § 2206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4218"},"text":"102 Stat. 4218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s703/4"},"text":"Pub. L. 102–573, title VII, § 703(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4583"},"text":"106 Stat. 4583","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s241/b"},"text":"Pub. L. 111–211, title II, § 241(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2289"},"text":"124 Stat. 2289","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id629d629a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id629d629b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id629d629c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570"},"text":"Pub. L. 99–570","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207"},"text":"100 Stat. 3207","children":[],"tail":", known as the Anti-Drug Abuse Act of 1986. For complete classification of this Act to the Code, see Short Title of 1986 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of Title 21","children":[],"tail":", Food and Drugs, and Tables."}],"tail":"\n"}