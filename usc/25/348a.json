{"tag":"section","attrib":{"id":"id622fac45-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s348a"},"text":null,"children":[{"tag":"num","attrib":{"value":"348a"},"text":"§ 348a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of trust period for Indians of Klamath River Reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The period of trust on lands allotted to Indians of the Klamath River Reservation, California, which expired ","children":[{"tag":"date","attrib":{"date":"1919-07-31"},"text":"July 31, 1919","children":[],"tail":", and the legal title to which is still in the United States, is reimposed and extended for a period of twenty-five years from "},{"tag":"date","attrib":{"date":"1919-07-31"},"text":"July 31, 1919","children":[],"tail":": "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That further extension of the period of trust may be made by the President, in his discretion, as provided by section 348 and "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s391"},"text":"section 391 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id622fac46-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1942-12-24/ch814"},"text":"Dec. 24, 1942, ch. 814","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/1081"},"text":"56 Stat. 1081","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
