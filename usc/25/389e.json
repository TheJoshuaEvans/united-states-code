{"tag":"section","attrib":{"id":"id62346736-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s389e"},"text":null,"children":[{"tag":"num","attrib":{"value":"389e"},"text":"§ 389e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions taken to be included in report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall include in the report to Congress required pursuant to section 389a ","children":[{"tag":"ref","attrib":{"idref":"fn002019"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002019"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should refer to section 386a."}],"tail":" of this title, a description of actions taken under the provisions of sections 389 to 389e of this title during the preceding fiscal year. No proceedings under such sections shall become effective until approved by the Congress."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62346737-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-22/ch692/s6"},"text":"June 22, 1936, ch. 692, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1804"},"text":"49 Stat. 1804","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/470/tII/s206/b"},"text":"Pub. L. 96–470, title II, § 206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-19"},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2244"},"text":"94 Stat. 2244","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62346738-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62346739-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"headin