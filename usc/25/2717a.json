{"tag":"section","attrib":{"id":"id62a948e6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2717a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2717a"},"text":"§ 2717a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of class II gaming activity fees to carry out duties of Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In fiscal year 1990 and thereafter, fees collected pursuant to and as limited by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2717"},"text":"section 2717 of this title","children":[],"tail":" shall be available to carry out the duties of the Commission, to remain available until expended."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62a948e7-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/121/tI"},"text":"Pub. L. 101–121, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-10-23"},"text":"Oct. 23, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/718"},"text":"103 Stat. 718","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62a948e8-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62a948e9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62a948ea-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of the Interior and Related Agencies Appropriations Act, 1990, and not as part of the Indian Gaming Regulatory Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
