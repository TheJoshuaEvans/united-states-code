{"tag":"section","attrib":{"id":"id6298a7d7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212"},"text":null,"children":[{"tag":"num","attrib":{"value":"2212"},"text":"§ 2212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fractional interest acquisition program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6298a7d8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition by Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6298a7d9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire, at the discretion of the Secretary and with the consent of the owner, or from an heir during probate in accordance with section 2206(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of this title and at fair market value, any fractional interest in trust or restricted lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6298a7da-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit the report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2217"},"text":"section 2217 of this title","children":[],"tail":" concerning how the fractional interest acquisition program should be enhanced to increase the resources made available to Indian tribes and individual Indian landowners."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6298a7db-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interests held in trust","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2213"},"text":"section 2213 of this title","children":[],"tail":", the Secretary shall immediately hold interests acquired under this chapter in trust for the recognized tribal government that exercises jurisdiction over the land involved."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6298a7dc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In implementing subsection (a), the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6298a7dd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall promote the policies provided for in section 102 of the Indian Land Consolidation Act Amendments of 2000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6298a7de-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may give priority to the acquisition of fractional interests representing 2 percent or less of a parcel of trust or restricted land, especially those interests that would have escheated to a tribe but for the Supreme Court’s decision in Babbitt v. Youpee (117 S ","children":[{"tag":"ref","attrib":{"idref":"fn002144"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002144"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":" Ct. 727 (1997));"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6298a7df-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6298a7e0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consult with the tribal government that exercises jurisdiction over the land involved in determining which tracts to acquire on a reservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6298a7e1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall coordinate the acquisition activities with the acquisition program of the tribal government that exercises jurisdiction over the land involved, including a tribal land consolidation plan approved pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2203"},"text":"section 2203 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6298a7e2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into agreements (such agreements will not be subject to the provisions of the Indian Self-Determination and Education Assistance Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.]) with the tribal government that exercises jurisdiction over the land involved or a subordinate entity of the tribal government to carry out some or all of the Secretary’s land acquisition program; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6298a7e3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall minimize the administrative costs associated with the land acquisition program through the use of policies and procedures designed to accommodate the voluntary sale of interests under this section, notwithstanding the existence of any otherwise applicable policy, procedure, or regulation, through the elimination of duplicate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6298a7e4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conveyance documents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6298a7e5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative proceedings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6298a7e6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transactions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6298a7e7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of interest to Indian landowners","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6298a7e8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyance at request","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6298a7e9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the request of any Indian who owns an undivided interest in a parcel of trust or restricted land, the Secretary shall convey an interest in such parcel acquired under this section to the Indian landowner—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6298a7ea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on payment by the Indian landowner of the amount paid for the interest by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6298a7eb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6298a7ec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/c/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian referred to in this subparagraph provides assurances that the purchase price will be paid by pledging revenue from any source, including trust resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6298a7ed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/c/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the purchase price will be paid in a timely and efficient manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6298a7ee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a conveyance under this subsection, the Secretary shall not approve an application to terminate the trust status or remove the restrictions of such an interest unless the interest is subject to a foreclosure of a mortgage in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5135"},"text":"section 5135 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6298a7ef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple owners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If more than one Indian owner requests an interest under paragraph (1), the Secretary shall convey the interest to the Indian owner who owns the largest percentage of the undivided interest in the parcel of trust or restricted land involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6298a7f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an Indian tribe that has jurisdiction over a parcel of trust or restricted land owns an undivided interest in a parcel of such land, such interest may only be acquired under paragraph (1) with the consent of such Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6298a7f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2212/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $75,000,000 for fiscal year 2005, $95,000,000 for fiscal year 2006, and $145,000,000 for each of fiscal years 2007 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6298a7f2-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/459/tII/s213"},"text":"Pub. L. 97–459, title II, § 213","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/462/tI/s103/6"},"text":"Pub. L. 106–462, title I, § 103(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1999"},"text":"114 Stat. 1999","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/5"},"text":"Pub. L. 108–374, § 6(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1800"},"text":"118 Stat. 1800","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/157/s5"},"text":"Pub. L. 109–157, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-30"},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2952"},"text":"119 Stat. 2952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/453/tII/s207/d"},"text":"Pub. L. 110–453, title II, § 207(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-02"},"text":"Dec. 2, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5033"},"text":"122 Stat. 5033","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6298a7f3-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6298a7f4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6298a7f5-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(3), was in the original “this Act”, which was translated as reading “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/459"},"text":"Pub. L. 97–459","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 102 of the Indian Land Consolidation Act Amendments of 2000, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/462/s102"},"text":"section 102 of Pub. L. 106–462","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act of 1974, referred to in subsec. (b)(3)(C), probably means the Indian Self-Determination and Education Assistance Act, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which is classified principally to chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6298a7f6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/453"},"text":"Pub. L. 110–453","children":[],"tail":" substituted “section 2206("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")” for “section 2206(p)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/157/s5/1"},"text":"Pub. L. 109–157, § 5(1)","children":[],"tail":", amended section catchline generally making technical correction to section designation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/157/s5/2"},"text":"Pub. L. 109–157, § 5(2)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2206/p"},"text":"section 2206(p) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/5/A"},"text":"Pub. L. 108–374, § 6(a)(5)(A)","children":[],"tail":", substituted “Fractional interest acquisition program” for “Pilot program for the acquisition of fractional interests” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/5/B/i"},"text":"Pub. L. 108–374, § 6(a)(5)(B)(i)","children":[],"tail":", inserted “or from an heir during probate in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2206/p"},"text":"section 2206(p) of this title","children":[],"tail":"” after “owner,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/5/B/ii"},"text":"Pub. L. 108–374, § 6(a)(5)(B)(ii)","children":[],"tail":", (iii), reenacted heading without change, substituted “The Secretary shall submit” for “"},{"tag":"inline","attrib":{},"text":"(B) Required report","children":[],"tail":".—Prior to expiration of the authority provided for in subparagraph (A), the Secretary shall submit” and “how the fractional interest acquisition program should be enhanced to increase the resources made” for “whether the program to acquire fractional interests should be extended or altered to make resources”, and struck out heading and text of subpar. (A). Text of subpar. (A) read as follows: “The Secretary shall have the authority to acquire interests in trust or restricted lands under this section during the 3-year period beginning on the date of certification that is referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2206/g/5"},"text":"section 2206(g)(5) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/5/C"},"text":"Pub. L. 108–374, § 6(a)(5)(C)","children":[],"tail":", added par. (4) and struck out former par. (4) which read as follows: “shall minimize the administrative costs associated with the land acquisition program.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/5/D/i/I"},"text":"Pub. L. 108–374, § 6(a)(5)(D)(i)(I)","children":[],"tail":"–(III), substituted “an undivided interest” for “at least 5 percent of the undivided interest”, inserted “in such parcel” after “the Secretary shall convey an interest”, and substituted “landowner—” and cls. (i) and (ii) for “landowner upon payment by the Indian landowner of the amount paid for the interest by the Secretary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/5/D/i/IV"},"text":"Pub. L. 108–374, § 6(a)(5)(D)(i)(IV)","children":[],"tail":", inserted “unless the interest is subject to a foreclosure of a mortgage in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5135"},"text":"section 5135 of this title","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/5/D/ii"},"text":"Pub. L. 108–374, § 6(a)(5)(D)(ii)","children":[],"tail":", substituted “an undivided interest” for “10 percent or more of the undivided interests”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/5/E"},"text":"Pub. L. 108–374, § 6(a)(5)(E)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6298a7f7-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6298a7f8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/157"},"text":"Pub. L. 109–157","children":[],"tail":" effective as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/108/374"},"text":"Pub. L. 108–374","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/157/s9"},"text":"section 9 of Pub. L. 109–157","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5107"},"text":"section 5107 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
