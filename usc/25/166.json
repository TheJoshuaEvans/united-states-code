{"tag":"section","attrib":{"id":"id621c9919-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s166"},"text":null,"children":[{"tag":"num","attrib":{"value":"166"},"text":"§ 166.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The activities of the Department of the Interior associated with the Department’s consultation with Indian tribes and organizations related to the management of funds held in trust by the United States for Indian tribes shall be exempt from chapter 10 of title 5.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621c991a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/435/s19"},"text":"Pub. L. 103–435, § 19","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4574"},"text":"108 Stat. 4574","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/180"},"text":"Pub. L. 117–286, § 4(a)(180)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4325"},"text":"136 Stat. 4325","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621c991b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621c991c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id621c991d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “Federal Advisory Committee Act” in section catchline and “chapter 10 of title 5.” for “the Federal Advisory Committee Act (5 U.S.C. App.).” in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
