{"tag":"section","attrib":{"id":"id621a2893-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s153"},"text":null,"children":[{"tag":"num","attrib":{"value":"153"},"text":"§ 153.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation to carry out treaties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All sums that are or may be required to be paid, and all moneys that are or may be required to be invested by the treaties mentioned in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s152"},"text":"section 152 of this title","children":[],"tail":" are appropriated in conformity to them, and shall be drawn from the Treasury as other public moneys are drawn therefrom, under such instructions as may from time to time be given by the President."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621a2894-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 2094.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621a2895-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id621a2896-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id621a2897-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2094 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1837-01-09/ch1/s2"},"text":"act Jan. 9, 1837, ch. 1, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/5/135"},"text":"5 Stat. 135","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
