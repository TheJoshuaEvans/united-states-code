{"tag":"section","attrib":{"id":"id62b075ff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3057"},"text":null,"children":[{"tag":"num","attrib":{"value":"3057"},"text":"§ 3057.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Severability and savings provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b07600-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3057/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Severability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter, or the application of any provision of this chapter to any person or circumstance is held invalid, the application of such provision or circumstance and the remainder of this chapter shall not be affected thereby.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b07601-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3057/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b07602-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3057/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diminishes or expands the trust responsibility of the United States to Indian tribes, or any legal obligation or remedy resulting from that responsibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b07603-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3057/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":