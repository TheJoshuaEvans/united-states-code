{"tag":"section","attrib":{"id":"id6217df1d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s123b"},"text":null,"children":[{"tag":"num","attrib":{"value":"123b"},"text":"§ 123b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal funds for traveling and other expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1938-05-09"},"text":"May 9, 1938","children":[],"tail":", tribal funds shall be available for appropriation by Congress for traveling and other expenses, including supplies and equipment, of members of tribal councils, business committees, or other tribal organizations, when engaged on business of the tribes."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6217df1e-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-05-09/ch187/s1"},"text":"May 9, 1938, ch. 187, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/315"},"text":"52 Stat. 315","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
