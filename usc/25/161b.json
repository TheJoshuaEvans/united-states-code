{"tag":"section","attrib":{"id":"id621a28df-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s161b"},"text":null,"children":[{"tag":"num","attrib":{"value":"161b"},"text":"§ 161b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Indian Money, Proceeds of Labor” fund; separate accounts for respective tribes; rate of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All tribal funds arising under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s155"},"text":"section 155 of this title","children":[],"tail":" on "},{"tag":"date","attrib":{"date":"1930-06-13"},"text":"June 13, 1930","children":[],"tail":", included in the fund “Indian Money, Proceeds of Labor”, shall, on and after "},{"tag":"date","attrib":{"date":"1930-07-01"},"text":"July 1, 1930","children":[],"tail":", be carried on the books of the Treasury Department in separate accounts for the respective tribes, and all such funds with account balances exceeding $500 shall bear simple interest at the rate of 4 per centum per annum from "},{"tag":"date","attrib":{"date":"1930-07-01"},"text":"July 1, 1930","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621a28e0-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-02-12/ch178/s2"},"text":"Feb. 12, 1929, ch. 178, § 2","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1930-06-13/ch483"},"text":"June 13, 1930, ch. 483","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/584"},"text":"46 Stat. 584","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
