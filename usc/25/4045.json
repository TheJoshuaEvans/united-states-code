{"tag":"section","attrib":{"id":"id62cab41b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4045"},"text":null,"children":[{"tag":"num","attrib":{"value":"4045"},"text":"§ 4045.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff and consultants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62cab41c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4045/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Special Trustee may employ such staff as the Special Trustee deems necessary. The Special Trustee may request staff assistance from within the Department and any office or Bureau thereof as the Special Trustee deems necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cab41d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4045/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent and in such amounts as may be provided in advance by appropriations Acts, the Special Trustee may enter into contracts and other arrangements with public agencies and with private persons and organizations for consulting services and make such payments as necessary to carry out the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62cab41e-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/412/tIII/s305"},"text":"Pub. L. 103–412, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4248"},"text":"108 Stat. 4248","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
