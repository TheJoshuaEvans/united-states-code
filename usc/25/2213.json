{"tag":"section","attrib":{"id":"id6298a7f9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213"},"text":null,"children":[{"tag":"num","attrib":{"value":"2213"},"text":"§ 2213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of acquired fractional interests; disposition of proceeds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6298a7fa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the conditions described in subsection (b)(1), an Indian tribe receiving a fractional interest under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2212"},"text":"section 2212 of this title","children":[],"tail":" may, as a tenant in common with the other owners of the trust or restricted lands, lease the interest, sell the resources, consent to the granting of rights-of-way, or engage in any other transaction affecting the trust or restricted land authorized by law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6298a7fb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of revenue from acquired interests to land consolidation program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6298a7fc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall have a lien on any revenue accruing to an interest described in subsection (a) until the Secretary provides for the removal of the lien under paragraph (3), (4), or (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6298a7fd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6298a7fe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Until the Secretary removes a lien from an interest in land under paragraph (1)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6298a7ff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any lease, resource sale contract, right-of-way, or other document evidencing a transaction affecting the interest shall contain a clause providing that all revenue derived from the interest shall be paid to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6298a800-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any revenue derived from any interest acquired by the Secretary in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2212"},"text":"section 2212 of this title","children":[],"tail":" shall be deposited in the fund created under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2215"},"text":"section 2215 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6298a801-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5123"},"text":"section 5123 of this title","children":[],"tail":", or any other provision of law, until the Secretary removes a lien from an interest in land under paragraph (1), the Secretary may approve a transaction covered under this section on behalf of an Indian tribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6298a802-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of liens after findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may remove a lien referred to in paragraph (1) if the Secretary makes a finding that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6298a803-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of administering the interest from which revenue accrues under the lien will equal or exceed the projected revenues for the parcel of land involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6298a804-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the discretion of the Secretary, it will take an unreasonable period of time for the parcel of land to generate revenue that equals the purchase price paid for the interest; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6298a805-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a subsequent decrease in the value of land or commodities associated with the parcel of land make it likely that the interest will be unable to generate revenue that equals the purchase price paid for the interest in a reasonable time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6298a806-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of liens upon payment into the acquisition fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall remove a lien referred to in paragraph (1) upon payment of an amount equal to the purchase price of that interest in land into the Acquisition Fund created under section 2215 ","children":[{"tag":"ref","attrib":{"idref":"fn002145"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002145"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, except where the tribe with jurisdiction over such interest in land authorizes the Secretary to continue the lien in order to generate additional acquisition funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6298a807-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other removal of liens","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, in consultation with tribal governments and other entities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2212/b/3"},"text":"section 2212(b)(3) of this title","children":[],"tail":", periodically remove liens referred to in paragraph (1) from interests in land acquired by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6298a808-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribe not treated as party to lease; no effect on tribal sovereignty, immunity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6298a809-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (2) shall apply with respect to any undivided interest in allotted land held by the Secretary in trust for a tribe if a lease or agreement under subsection (a) is otherwise applicable to such undivided interest by reason of this section even though the Indian tribe did not consent to the lease or agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6298a80a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2213/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of lease","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The lease or agreement described in paragraph (1) shall apply to the portion of the undivided interest in allotted land described in such paragraph (including entitlement of the Indian tribe to payment under the lease or agreement), and the Indian tribe shall not be treated as being a party to the lease or agreement. Nothing in this section (or in the lease or agreement) shall be construed to affect the sovereignty of the Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6298a80b-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/459/tII/s214"},"text":"Pub. L. 97–459, title II, § 214","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/462/tI/s103/6"},"text":"Pub. L. 106–462, title I, § 103(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2000"},"text":"114 Stat. 2000","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/374/s6/a/6"},"text":"Pub. L. 108–374, § 6(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1801"},"text":"118 Stat. 1801","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6298a80c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6298a80d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6298a80e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2215"},"text":"Section 2215 of this title","children":[],"tail":", referred to in the original in subsec. (b)(4), probably should have been “section 216”, meaning "},{"tag":"ref","attrib":{"href":"/us/pl/97/459/s216"},"text":"section 216 of Pub. L. 97–459","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2215"},"text":"section 2215 of this title","children":[],"tail":" and relates to the establishment of an Acquisition Fund. "},{"tag":"ref","attrib":{"href":"/us/pl/97/459"},"text":"Pub. L. 97–459","children":[],"tail":" does not contain a section 2215."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6298a80f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/374"},"text":"Pub. L. 108–374","children":[],"tail":" added subsec. (b) and struck out heading and text of former subsec. (b) which related to conditions applicable to the administration by Indian tribes of acquired fractional interests in trust or restricted lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
