{"tag":"section","attrib":{"id":"id62db5657-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5128"},"text":null,"children":[{"tag":"num","attrib":{"value":"5128"},"text":"§ 5128.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of laws and treaties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All laws, general and special, and all treaty provisions affecting any Indian reservation which has voted or may vote to exclude itself from the application of the Act of ","children":[{"tag":"date","attrib":{"date":"1934-06-18"},"text":"June 18, 1934","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/48/984"},"text":"48 Stat. 984","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5101"},"text":"25 U.S.C. 5101","children":[],"tail":" et seq.], shall be deemed to have been continuously effective as to such reservation, notwithstanding the passage of said Act of "},{"tag":"date","attrib":{"date":"1934-06-18"},"text":"June 18, 1934","children":[],"tail":". Nothing in the Act of "},{"tag":"date","attrib":{"date":"1934-06-18"},"text":"June 18, 1934","children":[],"tail":", shall be construed to abrogate or impair any rights guaranteed under any existing treaty with any Indian tribe, where such tribe voted not to exclude itself from the application of said Act."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62db5658-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-06-15/ch260/s4"},"text":"June 15, 1935, ch. 260, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/378"},"text":"49 Stat. 378","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62db5659-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62db565a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62db565b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1934-06-18"},"text":"June 18, 1934","children":[],"tail":", referred to in text, is "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch576"},"text":"act June 18, 1934, ch. 576","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/984"},"text":"48 Stat. 984","children":[],"tail":", popularly known as the Indian Reorganization Act, which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5101"},"text":"section 5101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62db565c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s478b"},"text":"section 478b of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
