{"tag":"section","attrib":{"id":"id627281ea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665l"},"text":null,"children":[{"tag":"num","attrib":{"value":"1665l"},"text":"§ 1665l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child sexual abuse prevention and treatment programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id627281eb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Service, shall establish, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1665a"},"text":"section 1665a of this title","children":[],"tail":", in every Service area, programs involving treatment for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id627281ec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" victims of sexual abuse who are Indian children or children in an Indian household; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627281ed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other members of the household or family of the victims described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627281ee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funding provided pursuant to this section shall be used for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id627281ef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665l/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop and provide community education and prevention programs related to sexual abuse of Indian children or children in an Indian household.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627281f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665l/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To identify and provide behavioral health treatment to victims of sexual abuse who are Indian children or children in an Indian household, and to their family members who are affected by sexual abuse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627281f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665l/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop prevention and intervention models which incorporate traditional health care practices, cultural values, and community involvement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id627281f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665l/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop and implement culturally sensitive assessment and diagnostic tools for use in Indian communities and urban centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id627281f3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1665l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The programs established under subsection (a) shall be carried out in coordination with programs and services authorized under the Indian Child Protection and Family Violence Prevention Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3201"},"text":"25 U.S.C. 3201","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id627281f4-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s713"},"text":"Pub. L. 94–437, title VII, § 713","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id627281f5-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id627281f6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id627281f7-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Child Protection and Family Violence Prevention Act, referred to in subsec. (c), is title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630"},"text":"Pub. L. 101–630","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4544"},"text":"104 Stat. 4544","children":[],"tail":", which is classified principally to chapter 34 (§ 3201 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3201"},"text":"section 3201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id627281f8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s713"},"text":"Section 713 of Pub. L. 94–437","children":[],"tail":" is based on section 181 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id627281f9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1665","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s713"},"text":"Pub. L. 94–437, title VII, § 713","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s702/a"},"text":"Pub. L. 102–573, title VII, § 702(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4581"},"text":"106 Stat. 4581","children":[],"tail":", provided for the conduct of the Alaska Native drug and alcohol abuse demonstration project, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
