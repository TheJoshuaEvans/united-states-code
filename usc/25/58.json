{"tag":"section","attrib":{"id":"id621323cb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s58"},"text":null,"children":[{"tag":"num","attrib":{"value":"58"},"text":"§ 58.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on number and kind of employment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The number and kind of employees at each agency shall be prescribed by the Secretary of the Interior and none other shall be employed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id621323cc-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1897-06-07/ch3"},"text":"June 7, 1897, ch. 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/90"},"text":"30 Stat. 90","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id621323cd-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id621323ce-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id621323cf-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Salary Restrictions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1912-04-18/ch83/s10"},"text":"Act Apr. 18, 1912, ch. 83, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/88"},"text":"37 Stat. 88","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/act/1918-05-25/ch86/s17"},"text":"act May 25, 1918, ch. 86, § 17","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/578"},"text":"40 Stat. 578","children":[],"tail":", excluded the Osage Agency from the provisions of act "},{"tag":"date","attrib":{"date":"1897-06-07"},"text":"June 7, 1897","children":[],"tail":", limiting the amount of money to be expended for salaries of regular employees at any one agency."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1929-02-26/ch323"},"text":"Act Feb. 26, 1929, ch. 323","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1307"},"text":"45 Stat. 1307","children":[],"tail":", which repealed a provision of "},{"tag":"ref","attrib":{"href":"/us/act/1912-08-24/ch388/s1"},"text":"act Aug. 24, 1912, ch. 388, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/521"},"text":"37 Stat. 521","children":[],"tail":", imposing a salary limitation of $15,000 at any one agency and $20,000 at a consolidated agency, was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s8/a"},"text":"Pub. L. 89–554, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/647"},"text":"80 Stat. 647","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id621323d0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id621323d1-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
