{"tag":"section","attrib":{"id":"id620e41bf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s13d–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"13d–2"},"text":"§ 13d–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment and general assistance payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id620e41c0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s13d–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior shall not disqualify from continued receipt of general assistance payments from the Bureau of Indian Affairs an otherwise eligible Indian for whom the Bureau is making or may make general assistance payments (or exclude such an individual from continued consideration in determining the amount of general assistance payments for a household) because the individual is enrolled (and is making satisfactory progress toward completion of a program or training that can reasonably be expected to lead to gainful employment) for at least half-time study or training in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id620e41c1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s13d–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a college assisted by the Bureau under the Tribally Controlled Colleges and Universities Assistance Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/92/1325"},"text":"92 Stat. 1325","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801"},"text":"25 U.S.C. 1801","children":[],"tail":") or the Navajo Community College Act ("},{"tag":"ref","attrib":{"href":"/us/stat/85/645"},"text":"85 Stat. 645","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s640a"},"text":"25 U.S.C. 640a","children":[],"tail":"); "},{"tag":"ref","attrib":{"idref":"fn002002"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002002"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id620e41c2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s13d–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education or a vocational school (as defined for purposes of any program of assistance to students under the Higher Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"20 U.S.C. 1001","children":[],"tail":" et seq.]);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id620e41c3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s13d–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a course the Secretary determines will lead to a high school diploma or an equivalent certificate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id620e41c4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s13d–2/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other programs or training approved by the Secretary or by tribal education, employment or training programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id620e41c5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s13d–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors not to be considered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the amount of general assistance provided by the Bureau of Indian Affairs, the Secretary of the Interior shall not include consideration of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id620e41c6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s13d–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional expenses in connection with the study or training described in subsection (a), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id620e41c7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s13d–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any financial assistance received by the individual as a student or trainee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id620e41c8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s13d–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on other eligibility requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section does not alter any eligibility requirement for general assistance from the Bureau of Indian Affairs other than the requirement to be available for employment and to seek employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id620e41c9-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5404"},"text":"Pub. L. 100–297, title V, § 5404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/416"},"text":"102 Stat. 416","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s901/d"},"text":"Pub. L. 105–244, title IX, § 901(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1828"},"text":"112 Stat. 1828","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1045"},"text":"Pub. L. 107–110, title X, § 1045","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2080"},"text":"115 Stat. 2080","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s941/k/2/G"},"text":"Pub. L. 110–315, title IX, § 941(k)(2)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3466"},"text":"122 Stat. 3466","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id620e41ca-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id620e41cb-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id620e41cc-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Tribally Controlled Colleges and Universities Assistance Act of 1978, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471"},"text":"Pub. L. 95–471","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1325"},"text":"92 Stat. 1325","children":[],"tail":", which is classified principally to chapter 20 (§ 1801 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Navajo Community College Act, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/189"},"text":"Pub. L. 92–189","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-15"},"text":"Dec. 15, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/646"},"text":"85 Stat. 646","children":[],"tail":", which was classified to section 640a et seq. of this title, and was omitted from the Code as being of special and not general application."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Higher Education Act of 1965, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1219"},"text":"79 Stat. 1219","children":[],"tail":", which is classified generally to chapter 28 (§ 1001 et seq.) of Title 20, Education. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id620e41cd-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" substituted “the Tribally Controlled Colleges and Universities Assistance Act of 1978” for “the Tribally Controlled College or University Assistance Act of 1978”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110/s1045/1"},"text":"Pub. L. 107–110, § 1045(1)","children":[],"tail":", added subsec. heading and introductory provisions and struck out former subsec. heading and introductory provisions. Former introductory provisions read as follows: “The Secretary of the Interior shall not disqualify from continued receipt of general assistance payments from the Bureau of Indian Affairs an otherwise eligible Indian for whom the Bureau has been making general assistance payments for at least 3 months (or exclude such an individual from continued consideration in determining the amount of general assistance payments for a household) because the individual is enrolled (and is making satisfactory progress toward completion of a program or training that can reasonably be expected to lead to gainful employment) for at least half-time study or training in—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110/s1045/2"},"text":"Pub. L. 107–110, § 1045(2)","children":[],"tail":", added par. (4) and struck out former par. (4) which read as follows: “other programs or training approved by the Secretary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" substituted “Tribally Controlled College or University Assistance Act of 1978” for “Tribally Controlled Community College Assistance Act of 1978”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id620e41ce-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id620e41cf-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id620e41d0-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id620e41d1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date and applicability of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/s6303"},"text":"section 6303 of Pub. L. 100–297","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1071"},"text":"section 1071 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
