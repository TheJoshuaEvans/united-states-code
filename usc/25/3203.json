{"tag":"section","attrib":{"id":"id62b7a189-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203"},"text":null,"children":[{"tag":"num","attrib":{"value":"3203"},"text":"§ 3203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b7a18a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a18b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of child abuse reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b7a18c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When a local law enforcement agency or local child protective services agency receives an initial report from any person of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b7a18d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the abuse of a child in Indian country, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a18e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions which would reasonably be expected to result in abuse of a child in Indian country, the receiving agency shall immediately notify appropriate officials of the other agency of such report and shall also submit, when prepared, a copy of the written report required under subsection (c) to such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a18f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Where a report of abuse involves an Indian child or where the alleged abuser is an Indian and where a preliminary inquiry indicates a criminal violation has occurred, the local law enforcement agency, if other than the Federal Bureau of Investigation, shall immediately report such occurrence to the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a190-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written report of child abuse","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b7a191-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Within 36 hours after receiving an initial report described in subsection (b), the receiving agency shall prepare a written report which shall include, if available—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b7a192-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, age, and sex of the child that is the subject of the report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a193-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grade and the school in which the child is currently enrolled;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a194-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the child’s parents or other person responsible for the child’s care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a195-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the alleged offender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a196-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the person who made the report to the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a197-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a brief narrative as to the nature and extent of the child’s injuries, including any previously known or suspected abuse of the child or the child’s siblings and the suspected date of the abuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a198-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information the agency or the person who made the report to the agency believes to be important to the investigation and disposition of the alleged abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b7a199-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62b7a19a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any local law enforcement agency or local child protective services agency that receives a report alleging abuse described in section 3202(3) ","children":[{"tag":"ref","attrib":{"idref":"fn002209"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002209"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title shall immediately initiate an investigation of such allegation and shall take immediate, appropriate steps to secure the safety and well-being of the child or children involved."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62b7a19b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon completion of the investigation of any report of alleged abuse that is made to a local law enforcement agency or local child protective services agency, such agency shall prepare a final written report on such allegation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b7a19c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3203/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of informant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The identity of any person making a report described in subsection (b)(1) shall not be disclosed, without the consent of the individual, to any person other than a court of competent jurisdiction or an employee of an Indian tribe, a State or the Federal Government who needs to know the information in the performance of such employee’s duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b7a19d-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIV/s404"},"text":"Pub. L. 101–630, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4547"},"text":"104 Stat. 4547","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62b7a19e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62b7a19f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62b7a1a0-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3202/3"},"text":"Section 3202(3) of this title","children":[],"tail":", referred to in subsec. (c)(2)(A), was in the original “section 503(3)” meaning "},{"tag":"ref","attrib":{"href":"/us/pl/101/630/s503/3"},"text":"section 503(3) of Pub. L. 101–630","children":[],"tail":", and was translated as reading section 403(3), which defines child abuse, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62b7a1a1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/s404"},"text":"section 404 of Pub. L. 101–630","children":[],"tail":". Subsec. (a) of section 404 enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1169"},"text":"section 1169 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
