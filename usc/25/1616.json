{"tag":"section","attrib":{"id":"id625a8d69-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616"},"text":null,"children":[{"tag":"num","attrib":{"value":"1616"},"text":"§ 1616.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community Health Representative Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id625a8d6a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":", the Secretary shall maintain a Community Health Representative Program under which the Service—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id625a8d6b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for the training of Indians as health paraprofessionals, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625a8d6c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses such paraprofessionals in the provision of health care, health promotion, and disease prevention services to Indian communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id625a8d6d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, acting through the Community Health Representative Program of the Service, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id625a8d6e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a high standard of training for paraprofessionals to Community Health Representatives to ensure that the Community Health Representatives provide quality health care, health promotion, and disease prevention services to the Indian communities served by such Program,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625a8d6f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in order to provide such training, develop and maintain a curriculum that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id625a8d70-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combines education in the theory of health care with supervised practical experience in the provision of health care, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id625a8d71-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides instruction and practical experience in health promotion and disease prevention activities, with appropriate consideration given to lifestyle factors that have an impact on Indian health status, such as alcoholism, family dysfunction, and poverty,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625a8d72-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a system which identifies the needs of Community Health Representatives for continuing education in health care, health promotion, and disease prevention and maintain programs that meet the needs for such continuing education,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625a8d73-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a system that provides close supervision of Community Health Representatives,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625a8d74-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a system under which the work of Community Health Representatives is reviewed and evaluated, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id625a8d75-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1616/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote traditional health care practices of the Indian tribes served consistent with the Service standards for the provision of health care, health promotion, and disease prevention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id625a8d76-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tI/s107"},"text":"Pub. L. 94–437, title I, § 107","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tI/s107"},"text":"Pub. L. 100–713, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4788"},"text":"102 Stat. 4788","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tI/s105"},"text":"Pub. L. 102–573, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4535"},"text":"106 Stat. 4535","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id625a8d77-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id625a8d78-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id625a8d79-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s105/1"},"text":"Pub. L. 102–573, § 105(1)","children":[],"tail":", inserted “and maintain” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s105/2"},"text":"Pub. L. 102–573, § 105(2)","children":[],"tail":", inserted at end “with appropriate consideration given to lifestyle factors that have an impact on Indian health status, such as alcoholism, family dysfunction, and poverty,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s105/3"},"text":"Pub. L. 102–573, § 105(3)","children":[],"tail":", substituted “maintain” for “develop” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s105/4"},"text":"Pub. L. 102–573, § 105(4)","children":[],"tail":", struck out “develop and” before “maintain”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s105/3"},"text":"Pub. L. 102–573, § 105(3)","children":[],"tail":", substituted “maintain” for “develop”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
