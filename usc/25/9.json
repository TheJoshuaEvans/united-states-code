{"tag":"section","attrib":{"id":"id620bf787-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"§ 9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations by President","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may prescribe such regulations as he may think fit for carrying into effect the various provisions of any act relating to Indian affairs, and for the settlement of the accounts of Indian affairs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id620bf788-4962-11f1-add1-b56d3fa293fa"},"text":"(R.S. § 465.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id620bf789-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id620bf78a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id620bf78b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 465 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1834-06-30/ch162/s17"},"text":"act June 30, 1834, ch. 162, § 17","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/738"},"text":"4 Stat. 738","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
