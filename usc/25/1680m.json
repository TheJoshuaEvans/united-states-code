{"tag":"section","attrib":{"id":"id6279ad4f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680m"},"text":null,"children":[{"tag":"num","attrib":{"value":"1680m"},"text":"§ 1680m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Results of demonstration projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the dissemination to Indian tribes of the findings and results of demonstration projects conducted under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6279ad50-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s823"},"text":"Pub. L. 94–437, title VIII, § 823","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVIII/s811"},"text":"Pub. L. 102–573, title VIII, § 811","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4589"},"text":"106 Stat. 4589","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6279ad51-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6279ad52-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6279ad53-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437"},"text":"Pub. L. 94–437","children":[],"tai