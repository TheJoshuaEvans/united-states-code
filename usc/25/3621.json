{"tag":"section","attrib":{"id":"id62c117eb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3621"},"text":null,"children":[{"tag":"num","attrib":{"value":"3621"},"text":"§ 3621.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal justice systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62c117ec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3621/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out sections 3611 and 3612 of this title, $7,000,000 for each of fiscal years 2011 through 2015. None of the funds provided under this subsection may be used for the administrative expenses of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c117ed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3621/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Base support funding for tribal justice systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3613"},"text":"section 3613 of this title","children":[],"tail":", $50,000,000 for each of fiscal years 2011 through 2015."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c117ee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3621/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses for Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated, for the administrative expenses of the Office, $500,000 for each of fiscal years 2011 through 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c117ef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3621/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses for tribal judicial conferences","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated, for the administrative expenses of tribal judicial conferences, $500,000 for each of fiscal years 2011 through 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c117f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3621/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For carrying out the survey under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3612"},"text":"section 3612 of this title","children":[],"tail":", there is authorized to be appropriated, in addition to the amount authorized under subsection (a) of this section, $400,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c117f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3621/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian priority system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated pursuant to the authorizations provided by this section and available for a tribal justice system shall not be subject to the Indian priority system. Nothing in this chapter shall preclude a tribal government from supplementing any funds received under this chapter with funds received from any other source including the Bureau or any other Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c117f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3621/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In allocating funds appropriated pursuant to the authorization contained in subsection (a) among the Bureau, Office, tribal governments and Courts of Indian Offenses, the Secretary shall take such actions as may be necessary to ensure that such allocation is carried out in a manner that is fair and equitable to all tribal governments and is proportionate to base support funding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3613"},"text":"section 3613 of this title","children":[],"tail":" received by the Bureau, Office, tribal governments, and Courts of Indian Offenses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62c117f3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3621/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No offset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No Federal agency shall offset funds made available pursuant to this chapter for tribal justice systems against other funds otherwise available for use in connection with tribal justice systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c117f4-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/176/tII/s201"},"text":"Pub. L. 103–176, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2009"},"text":"107 Stat. 2009","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/559/tII/s202"},"text":"Pub. L. 106–559, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2782"},"text":"114 Stat. 2782","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s242/a/2"},"text":"Pub. L. 111–211, title II, § 242(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2292"},"text":"124 Stat. 2292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c117f5-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62c117f6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62c117f7-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s242/a/2/A"},"text":"Pub. L. 111–211, § 242(a)(2)(A)","children":[],"tail":", substituted “sections 3611 and 3612 of this title” for “the provisions of sections 3611 and 3612 of this title” and “fiscal years 2011 through 2015” for “the fiscal years 2000 through 2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s242/a/2/B"},"text":"Pub. L. 111–211, § 242(a)(2)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3613"},"text":"section 3613 of this title","children":[],"tail":"” for “the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3613"},"text":"section 3613 of this title","children":[],"tail":"” and “fiscal years 2011 through 2015” for “the fiscal years 2000 through 2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s242/a/2/C"},"text":"Pub. L. 111–211, § 242(a)(2)(C)","children":[],"tail":", (D), substituted “fiscal years 2011 through 2015” for “the fiscal years 2000 through 2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsecs. (a) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/559"},"text":"Pub. L. 106–559","children":[],"tail":" substituted “2000 through 2007” for “1994, 1995, 1996, 1997, 1998, 1999, and 2000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
