{"tag":"section","attrib":{"id":"id627e68d2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1802"},"text":null,"children":[{"tag":"num","attrib":{"value":"1802"},"text":"§ 1802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the purpose of this subchapter to provide grants for the operation and improvement of tribally controlled colleges or universities to insure continued and expanded educational opportunities for Indian students, and to allow for the improvement and expansion of the physical resources of such institutions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id627e68d3-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/471/tI/s101"},"text":"Pub. L. 95–471, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1325"},"text":"92 Stat. 1325","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/192/s2"},"text":"Pub. L. 98–192, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1336"},"text":"97 Stat. 1336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s901/b/6"},"text":"Pub. L. 105–244, title IX, § 901(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1828"},"text":"112 Stat. 1828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id627e68d4-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id627e68d5-4962-11f