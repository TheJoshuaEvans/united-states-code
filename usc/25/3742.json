{"tag":"section","attrib":{"id":"id62c5f938-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3742"},"text":null,"children":[{"tag":"num","attrib":{"value":"3742"},"text":"§ 3742.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to diminish or expand the trust responsibility of the United States toward Indian trust lands or natural resources, or any legal obligation or remedy resulting therefrom.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62c5f939-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/177/tIII/s302"},"text":"Pub. L. 103–177, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2022"},"text":"107 Stat. 2022","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
