{"tag":"section","attrib":{"id":"id62a21d7b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504"},"text":null,"children":[{"tag":"num","attrib":{"value":"2504"},"text":"§ 2504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62a21d7c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a21d7d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A tribally controlled school is eligible for assistance under this chapter if the school—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21d7e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"1988-04-28"},"text":"April 28, 1988","children":[],"tail":", was a contract school under title XI of the Education Amendments of 1978 ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2000"},"text":"25 U.S.C. 2000","children":[],"tail":" et seq.] and the tribe or tribal organization operating the school submits to the Secretary a written notice of election to receive a grant under this chapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d7f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was a Bureau-operated school under title XI of the Education Amendments of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2000"},"text":"25 U.S.C. 2000","children":[],"tail":" et seq.] and has met the requirements of subsection (b);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d80-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a school for which the Bureau has not provided funds, but which has met the requirements of subsection (c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d81-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a school with respect to which an election has been made under paragraph (2) and which has met the requirements of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21d82-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New schools","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any application which has been submitted under the Indian Self-Determination and Education Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.] by an Indian tribe for a school which is not in operation on "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", shall be reviewed under the guidelines and regulations for applications submitted under the Indian Self-Determination and Education Assistance Act that were in effect at the time the application was submitted, unless the Indian tribe or tribal organization elects to have the application reviewed under the provisions of subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a21d83-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements for Bureau-funded schools and certain electing schools","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a21d84-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau-funded schools","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A school that was a Bureau-funded school under title XI of the Education Amendments of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2000"},"text":"25 U.S.C. 2000","children":[],"tail":" et seq.] on "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", and any school with respect to which an election is made under subsection (a)(2), meets the requirements of this subsection if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21d85-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Indian tribe or tribal organization that operates, or desires to operate, the school submits to the Secretary an application requesting that the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62a21d86-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer operation of the school to the Indian tribe or tribal organization, if the Indian tribe or tribal organization is not already operating the school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21d87-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a determination as to whether the school is eligible for assistance under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d88-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary makes a determination that the school is eligible for assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21d89-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain electing schools","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21d8a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"By not later than the date that is 120 days after the date on which an application is submitted to the Secretary under paragraph (1)(A), the Secretary shall determine—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62a21d8b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a school which is not being operated by the Indian tribe or tribal organization, whether to transfer operation of the school to the Indian tribe or tribal organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21d8c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the school is eligible for assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d8d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other determinations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In considering applications submitted under paragraph (1)(A), the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62a21d8e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall transfer operation of the school to the Indian tribe or tribal organization, if the tribe or tribal organization is not already operating the school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21d8f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall determine that the school is eligible for assistance under this chapter, unless the Secretary finds by clear and convincing evidence that the services to be provided by the Indian tribe or tribal organization will be deleterious to the welfare of the Indians served by the school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d90-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In considering applications submitted under paragraph (1)(A), the Secretary shall consider whether the Indian tribe or tribal organization would be deficient in operating the school with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62a21d91-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21d92-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bookkeeping and accounting procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21d93-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ability to adequately manage a school; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21d94-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequately trained personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a21d95-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements for a school which is not a Bureau-funded school","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a21d96-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A school which is not a Bureau-funded school under title XI of the Education Amendments of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2000"},"text":"25 U.S.C. 2000","children":[],"tail":" et seq.] meets the requirements of this subsection if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21d97-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian tribe or tribal organization that operates, or desires to operate, the school submits to the Secretary an application requesting a determination by the Secretary as to whether the school is eligible for assistance under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d98-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary makes a determination that a school is eligible for assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21d99-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for determination by Secretary","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21d9a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"By not later than the date that is 180 days after the date on which an application is submitted to the Secretary under paragraph (1)(A), the Secretary shall determine whether the school is eligible for assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21d9b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making the determination under subparagraph (A), the Secretary shall give equal consideration to each of the following factors:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62a21d9c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to the applicant’s proposal—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62a21d9d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of facilities or the potential to obtain or provide adequate facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62a21d9e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geographic and demographic factors in the affected areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62a21d9f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequacy of the applicant’s program plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62a21da0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/2/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geographic proximity of comparable public education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62a21da1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/2/B/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs as expressed by all affected parties, including but not limited to students, families, tribal governments at both the central and local levels, and school organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62a21da2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to all education services already available—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62a21da3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geographic and demographic factors in the affected areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62a21da4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequacy and comparability of programs already available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62a21da5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistency of available programs with tribal education codes or tribal legislation on education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62a21da6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/2/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the history and success of these services for the proposed population to be served, as determined from all factors including, if relevant, standardized examination performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21da7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic proximity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a determination under this paragraph that is primarily based upon the geographic proximity of comparable public education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21da8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Applications submitted under paragraph (1)(A) shall include information on the factors described in subparagraph (B)(i), but the applicant may also provide the Secretary such information relative to the factors described in subparagraph (B)(ii) as the applicant considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21da9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary fails to make a determination under subparagraph (A) with respect to an application within 180 days after the date on which the Secretary received the application, the Secretary shall be treated as having made a determination that the tribally controlled school is eligible for assistance under the title ","children":[{"tag":"ref","attrib":{"idref":"fn002170"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002170"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and the grant shall become effective 18 months after the date on which the Secretary received the application, or on an earlier date, at the Secretary’s discretion."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a21daa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of applications and reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a21dab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All applications and reports submitted to the Secretary under this chapter, and any amendments to such applications or reports, shall be filed with the education line officer designated by the Director of the Office of Indian Education Programs of the Bureau of Indian Affairs. The date on which such filing occurs shall, for purposes of this chapter, be treated as the date on which the application or amendment was submitted to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21dac-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supporting documentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any application that is submitted under this chapter shall be accompanied by a document indicating the action taken by the tribal governing body in authorizing such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a21dad-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date for approved applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided by subsection (c)(2)(E), a grant provided under this chapter, and any transfer of the operation of a Bureau school made under subsection (b), shall become effective beginning the academic year succeeding the fiscal year in which the application for the grant or transfer is made, or at an earlier date determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a21dae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62a21daf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the Secretary refuses to approve a grant under this chapter, to transfer operation of a Bureau school under subsection (b), or determines that a school is not eligible for assistance under this chapter, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62a21db0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state the objections in writing to the tribe or tribal organization within the allotted time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21db1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance to the tribe or tribal organization to overcome all stated objections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21db2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of the tribe or tribal organization, provide the tribe or tribal organization a hearing on the record under the same rules and regulations that apply under the Indian Self-Determination and Education Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62a21db3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an opportunity to appeal the objection raised.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62a21db4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timeline for reconsideration of amended applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reconsider any amended application submitted under this chapter within 60 days after the amended application is submitted to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62a21db5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2504/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall submit an annual report to the Congress on all applications received, and actions taken (including the costs associated with such actions), under this section at the same time that the President is required to submit to Congress the budget under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62a21db6-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5205"},"text":"Pub. L. 100–297, title V, § 5205","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1043"},"text":"Pub. L. 107–110, title X, § 1043","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2068"},"text":"115 Stat. 2068","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62a21db7-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62a21db8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62a21db9-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Education Amendments of 1978, referred to in subsecs. (a)(1)(A), (B), (b)(1), and (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561"},"text":"Pub. L. 95–561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2143"},"text":"92 Stat. 2143","children":[],"tail":". Title XI of the Act is classified principally to chapter 22 (§ 2000 et seq.) of this title. For complete classification of this Act to the Code, see Short Title of 1978 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education, and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in subsecs. (a)(2) and (f)(1)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which is classified principally to chapter 46 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The title, referred to in subsec. (c)(2)(E), probably should be “this part”, meaning part B of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":", known as the Tribally Controlled Schools Act of 1988, which is classified generally to this chapter. For complete classification of part B to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2501"},"text":"section 2501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62a21dba-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2504, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5205"},"text":"Pub. L. 100–297, title V, § 5205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/387"},"text":"102 Stat. 387","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/427/s10/c"},"text":"Pub. L. 100–427, § 10(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1608"},"text":"102 Stat. 1608","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/301/s5/g"},"text":"Pub. L. 101–301, § 5(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-24"},"text":"May 24, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/209"},"text":"104 Stat. 209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/119/s26/f"},"text":"Pub. L. 102–119, § 26(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-07"},"text":"Oct. 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/607"},"text":"105 Stat. 607","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII"},"text":"Pub. L. 103–382, title III","children":[],"tail":", §§ 382(a), (b), 394(m)(2), "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4017"},"text":"108 Stat. 4017","children":[],"tail":", 4029, related to composition of grants, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1043"},"text":"Pub. L. 107–110, title X, § 1043","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2063"},"text":"115 Stat. 2063","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2503"},"text":"section 2503 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62a21dbb-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id62a21dbc-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
