{"tag":"section","attrib":{"id":"id628cc0c5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010"},"text":null,"children":[{"tag":"num","attrib":{"value":"2010"},"text":"§ 2010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform direct funding and support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id628cc0c6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of system and forward funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628cc0c7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish, by regulation adopted in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2016"},"text":"section 2016 of this title","children":[],"tail":", a system for the direct funding and support of all Bureau-funded schools. Such system shall allot funds in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2007"},"text":"section 2007 of this title","children":[],"tail":". All amounts appropriated for distribution in accordance with this section shall be made available in accordance with paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628cc0c8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing for use of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628cc0c9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of affording adequate notice of funding available pursuant to the allotments made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2007"},"text":"section 2007 of this title","children":[],"tail":" and the allotments of funds for operation and maintenance of facilities, amounts appropriated in an appropriations Act for any fiscal year for such allotments—"}],"tail":null},{"tag":"clause","attrib":{"id":"id628cc0ca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall become available for obligation by the affected schools on July 1 of the fiscal year for which such allotments are appropriated without further action by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628cc0cb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remain available for obligation through the succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc0cc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, on the basis of the amounts appropriated as described in this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id628cc0cd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish, not later than July 1 of the fiscal year for which the amounts are appropriated, information indicating the amount of the allotments to be made to each affected school under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2007"},"text":"section 2007 of this title","children":[],"tail":", of 80 percent of such appropriated amounts; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628cc0ce-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish, not later than September 30 of such fiscal year, information indicating the amount of the allotments to be made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2007"},"text":"section 2007 of this title","children":[],"tail":", from the remaining 20 percent of such appropriated amounts, adjusted to reflect the actual student attendance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc0cf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overpayments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any overpayments made to tribal schools shall be returned to the Secretary not later than 30 days after the final determination that the school was overpaid pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628cc0d0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628cc0d1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law (including a regulation), the supervisor of a Bureau-operated school may expend an aggregate of not more than $50,000 of the amount allotted to the school under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2007"},"text":"section 2007 of this title","children":[],"tail":" to acquire materials, supplies, equipment, operation services, maintenance services, and other services for the school, and amounts received as operations and maintenance funds, funds received from the Department of Education, or funds received from other Federal sources, without competitive bidding if—"}],"tail":null},{"tag":"clause","attrib":{"id":"id628cc0d2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost for any single item acquired does not exceed $15,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628cc0d3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the school board approves the acquisition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628cc0d4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supervisor certifies that the cost is fair and reasonable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628cc0d5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the documents relating to the acquisition executed by the supervisor of the school or other school staff cite this paragraph as authority for the acquisition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628cc0d6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition transaction is documented in a journal maintained at the school that clearly identifies when the transaction occurred, the item that was acquired and from whom, the price paid, the quantities acquired, and any other information the supervisor or the school board considers to be relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc0d7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", the Secretary shall send notice of the provisions of this paragraph to each supervisor of a Bureau school and associated school board chairperson, the education line officer of each agency and area, and the Bureau division in charge of procurement, at both the local and national levels."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc0d8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application and guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Office shall be responsible for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id628cc0d9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the application of this paragraph, including the authorization of specific individuals to carry out this paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628cc0da-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that there is at least one such individual at each Bureau facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628cc0db-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of guidelines on the use of this paragraph and adequate training on such guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628cc0dc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of sequestration order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a sequestration order issued under the Balanced Budget and Emergency Deficit Control Act of 1985 reduces the amount of funds available for allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2007"},"text":"section 2007 of this title","children":[],"tail":" for any fiscal year by more than 7 percent of the amount of funds available for allotment under such section during the preceding fiscal year—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628cc0dd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to fund allotments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2007"},"text":"section 2007 of this title","children":[],"tail":", the Secretary, notwithstanding any other law, may use—"}],"tail":null},{"tag":"clause","attrib":{"id":"id628cc0de-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds appropriated for the operation of any Bureau-funded school that is closed or consolidated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628cc0df-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds appropriated for any program that has been curtailed at any Bureau school; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc0e0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may waive the application of the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2001/h"},"text":"section 2001(h) of this title","children":[],"tail":" with respect to the closure or consolidation of a school, or the curtailment of a program at a school, during such fiscal year if the funds described in clauses (i) and (ii) of subparagraph (A) with respect to such school are used to fund allotments made under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2007"},"text":"section 2007 of this title","children":[],"tail":" for such fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628cc0e1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local financial plans for expenditure of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628cc0e2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Bureau-operated school that receives an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2007"},"text":"section 2007 of this title","children":[],"tail":" shall prepare a local financial plan that specifies the manner in which the school will expend the funds made available under the allotment and ensures that the school will meet the accreditation requirements or standards for the school pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628cc0e3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local financial plan under paragraph (1) shall comply with all applicable Federal and tribal laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628cc0e4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation and revision","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628cc0e5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The financial plan for a school under subparagraph (A) ","children":[{"tag":"ref","attrib":{"idref":"fn002123"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002123"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “paragraph (1)”."}],"tail":" shall be prepared by the supervisor of the school in active consultation with the local school board for the school."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc0e6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of school board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The local school board for each school shall have the authority to ratify, reject, or amend such financial plan and, at the initiative of the local school board or in response to the supervisor of the school, to revise such financial plan to meet needs not foreseen at the time of preparation of the financial plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628cc0e7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of supervisor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The supervisor of the school—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628cc0e8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall implement the decisions of the school board relating to the financial plan under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc0e9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide the appropriate local union representative of the education employees of the school with copies of proposed financial plans relating to the school and all modifications and proposed modifications to the plans, and at the same time submit such copies to the local school board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc0ea-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may appeal any such action of the local school board to the appropriate education line officer of the Bureau agency by filing a written statement describing the action and the reasons the supervisor believes such action should be overturned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628cc0eb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628cc0ec-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A copy of each statement filed under paragraph (4)(C) shall be submitted to the local school board and such board shall be afforded an opportunity to respond, in writing, to such appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc0ed-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overturned actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After reviewing such written appeal and response, the appropriate education line officer may, for good cause, overturn the action of the local school board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc0ee-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission of determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appropriate education line officer shall transmit the determination of such appeal in the form of a written opinion to such board and to such supervisor identifying the reasons for overturning such action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628cc0ef-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal division of education, self-determination grant and contract funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may approve applications for funding tribal divisions of education and developing tribal codes of education, from funds made available pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5322/a"},"text":"section 5322(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628cc0f0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, a local school board may request technical assistance and training from the Secretary, and the Secretary shall, to the maximum extent practicable, provide those services and make appropriate provisions in the budget of the Office for the provision of those services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628cc0f1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summer program of academic and support services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628cc0f2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628cc0f3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A financial plan under subsection (b) for a school may include, at the discretion of the local administrator and the school board of such school, a provision for a summer program of academic and support services for students of the school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc0f4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any such program may include activities related to the prevention of alcohol and substance abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc0f5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summer use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary for Indian Affairs shall provide for the use of any such school facility during any summer in which such use is requested.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628cc0f6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of other funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, funds authorized under the Act of ","children":[{"tag":"date","attrib":{"date":"1934-04-16"},"text":"April 16, 1934","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5342"},"text":"25 U.S.C. 5342","children":[],"tail":" et seq.], and this Act may be used to augment the services provided in each summer program at the option, and under the control, of the tribe or Indian controlled school receiving such funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628cc0f7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and program coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary for Indian Affairs, acting through the Director of the Office, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628cc0f8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance and coordination for any program described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc0f9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, encourage the coordination of such programs with any other summer programs that might benefit Indian youth, regardless of the funding source or administrative entity of any such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628cc0fa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628cc0fb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628cc0fc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From funds allotted to a Bureau school under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2007"},"text":"section 2007 of this title","children":[],"tail":", the Secretary shall, if specifically requested by the appropriate tribal governing body, implement a cooperative agreement that is entered into between the tribe, the Bureau, the local school board, and a local public school district that meets the requirements of paragraph (2) and involves the school."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc0fd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tribe, the Bureau, the school board, and the local public school district shall determine the terms of an agreement entered into under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628cc0fe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement under paragraph (1) may, with respect to the Bureau school and schools in the school district involved, encompass coordination of all or any part of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628cc0ff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The academic program and curriculum, unless the Bureau school is accredited by a State or regional accrediting entity and would not continue to be so accredited if the agreement encompassed the program and curriculum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc100-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support services, including procurement and facilities maintenance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc101-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628cc102-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equal benefit and burden","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628cc103-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each agreement entered into under paragraph (1) shall confer a benefit upon the Bureau school commensurate with the burden assumed by the school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628cc104-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not be construed to require equal expenditures, or an exchange of similar services, by the Bureau school and schools in the school district.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628cc105-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Product or result of student projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, in a case in which there is agreement on action between the superintendent and the school board of a Bureau-funded school, the product or result of a project conducted in whole or in major part by a student may be given to that student upon the completion of such project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628cc106-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching fund requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628cc107-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Not considered Federal funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, funds received by a Bureau-funded school under this chapter for education-related activities (not including funds for construction, maintenance, and facilities improvement or repair) shall not be considered Federal funds for the purposes of a matching funds requirement for any Federal program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628cc108-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2010/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In considering an application from a Bureau-funded school for participation in a program or project that requires matching funds, the entity administering such program or project or awarding such grant shall not give positive or negative weight to such application based solely on the provisions of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id628cc109-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1130"},"text":"Pub. L. 95–561, title XI, § 1130","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1042"},"text":"Pub. L. 107–110, title X, § 1042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2039"},"text":"115 Stat. 2039","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id628cc10a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id628cc10b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id628cc10c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Balanced Budget and Emergency Deficit Control Act of 1985, referred to in subsec. (a)(4), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177"},"text":"Pub. L. 99–177","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-12"},"text":"Dec. 12, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1038"},"text":"99 Stat. 1038","children":[],"tail":", as amended which enacted chapter 20 (§ 900 et seq.) and sections 654 to 656 of Title 2, The Congress, amended sections 602, 622, 631 to 642, and 651 to 653 of Title 2, sections 1104 to 1106, and 1109 of Title 31, Money and Finance, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s911"},"text":"section 911 of Title 42","children":[],"tail":", The Public Health and Welfare, repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s661"},"text":"section 661 of Title 2","children":[],"tail":", enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s900"},"text":"section 900 of Title 2","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s911"},"text":"section 911 of Title 42","children":[],"tail":", and amended provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s621"},"text":"section 621 of Title 2","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s900"},"text":"section 900 of Title 2","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1934-04-16"},"text":"April 16, 1934","children":[],"tail":", referred to in subsec. (e)(2), is "},{"tag":"ref","attrib":{"href":"/us/act/1934-04-16/ch147"},"text":"act Apr. 16, 1934, ch. 147","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/596"},"text":"48 Stat. 596","children":[],"tail":", popularly known as the Johnson-O’Malley Act, which is classified generally to section 5342 et seq. of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (e)(2), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561"},"text":"Pub. L. 95–561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2143"},"text":"92 Stat. 2143","children":[],"tail":", known as the Education Amendments of 1978. For complete classification of this Act to the Code, see Short Title of 1978 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education, and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (h)(1), was in the original “this title”, meaning title XI (§ 1101 et seq.) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561"},"text":"Pub. L. 95–561","children":[],"tail":", which is classified principally to this chapter. For complete classification of title XI to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id628cc10d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2010, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1130"},"text":"Pub. L. 95–561, title XI, § 1130","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s381"},"text":"Pub. L. 103–382, title III, § 381","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3999"},"text":"108 Stat. 3999","children":[],"tail":", related to uniform direct funding and support, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2010, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1130"},"text":"Pub. L. 95–561, title XI, § 1130","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2321"},"text":"92 Stat. 2321","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/tV/s5111"},"text":"Pub. L. 100–297, title V, § 5111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/376"},"text":"102 Stat. 376","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/427/s7"},"text":"Pub. L. 100–427, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1605"},"text":"102 Stat. 1605","children":[],"tail":", related to policy for Indian control of Indian education, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id628cc10e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id628cc10f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
