{"tag":"section","attrib":{"id":"id62d69ac3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304"},"text":null,"children":[{"tag":"num","attrib":{"value":"4304"},"text":"§ 4304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American trade and export promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62d69ac4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director, shall carry out a Native American export and trade promotion program (referred to in this section as the “program”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d69ac5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of Federal programs and services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the Secretary, acting through the Director, and in cooperation with the heads of appropriate Federal agencies, shall ensure the coordination of Federal programs and services designed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d69ac6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop the economies of Indian Tribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69ac7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stimulate the demand for Indian goods and services that are available from eligible entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d69ac8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the duties described in subsection (b), the Secretary, acting through the Director, shall ensure the coordination of, or, as appropriate, carry out—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d69ac9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal programs designed to provide technical or financial assistance to eligible entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69aca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of promotional materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69acb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financing of appropriate trade missions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69acc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the marketing of Indian goods and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69acd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participation of appropriate Federal agencies or eligible entities in international trade fairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69ace-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activity related to the development of markets for Indian goods and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d69acf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conjunction with the activities described in subsection (c), the Secretary, acting through the Director, shall provide technical assistance and administrative services to eligible entities to assist those entities with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d69ad0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of appropriate markets for Indian goods and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69ad1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entering the markets referred to in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69ad2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with foreign or domestic laws and practices with respect to financial institutions with respect to the export and import of Indian goods and services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69ad3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entering into financial arrangements to provide for the export and import of Indian goods and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62d69ad4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the duties and activities described in subsections (b) and (c), the Secretary, acting through the Director, shall give priority to activities that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d69ad5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the greatest degree of economic benefits to Indians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d69ad6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4304/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster long-term stable international markets for Indian goods and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d69ad7-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/464/s5"},"text":"Pub. L. 106–464, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2016"},"text":"114 Stat. 2016","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/261/s3/e/2"},"text":"Pub. L. 116–261, § 3(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-30"},"text":"Dec. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3311"},"text":"134 Stat. 3311","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62d69ad8-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62d69ad9-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62d69ada-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/261"},"text":"Pub. L. 116–261","children":[],"tail":" substituted “Tribes” for “tribes”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
