{"tag":"section","attrib":{"id":"id629d6273-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2416"},"text":null,"children":[{"tag":"num","attrib":{"value":"2416"},"text":"§ 2416.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Newsletter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id629d6274-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2416/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior shall publish an alcohol and substance abuse newsletter in cooperation with the Secretary of Health and Human Services and the Secretary of Education to report on Indian alcohol and substance abuse projects and programs. The newsletter shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id629d6275-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2416/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be published once in each calendar quarter,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d6276-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2416/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include reviews of programs determined by the Secretary of the Interior to be exemplary and provide sufficient information to enable interested persons to obtain further information about such programs, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id629d6277-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2416/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be circulated without charge to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id629d6278-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2416/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" schools,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629d6279-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2416/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal offices,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629d627a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2416/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Bureau of Indian Affairs’ agency and area offices,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629d627b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2416/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian Health Service area and service unit offices,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629d627c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2416/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian Health Service alcohol programs, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id629d627d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2416/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other entities providing alcohol and substance abuse related services or resources to Indian people.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id629d627e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2416/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $500,000 for fiscal year 1993 and such sums as may be necessary for each of the fiscal years 1994, 1995, 1996, 1997, 1998, 1999, and 2000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id629d627f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4210"},"text":"Pub. L. 99–570, title IV, § 4210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-143"},"text":"100 Stat. 3207–143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2218"},"text":"Pub. L. 100–690, title II, § 2218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4222"},"text":"102 Stat. 4222","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tVII/s703/3"},"text":"Pub. L. 102–573, title VII, § 703(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4583"},"text":"106 Stat. 4583","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id629d6280-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id629d6281-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id629d6282-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573"},"text":"Pub. L. 102–573","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “There are authorized to be appropriated for each of the fiscal years 1989, 1990, 1991, and 1992, $300,000 to carry out the provisions of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" struck out “, not later than 120 days after "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"October 27, 1986","children":[],"tail":",” after “the Interior shall”, designated existing provisions as subsec. (a), and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
