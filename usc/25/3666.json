{"tag":"section","attrib":{"id":"id62c38851-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3666"},"text":null,"children":[{"tag":"num","attrib":{"value":"3666"},"text":"§ 3666.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out the activities under this subchapter, there are authorized to be appropriated such sums as are necessary for fiscal years 2011 through 2015.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62c38852-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/559/tI/s107"},"text":"Pub. L. 106–559, title I, § 107","children":[],"tail":", formerly § 106, "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2781"},"text":"114 Stat. 2781","children":[],"tail":"; renumbered § 107 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII"},"text":"Pub. L. 111–211, title II","children":[],"tail":", §§ 214(a)(2)(A), 242(b)(3)(A), "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2270"},"text":"124 Stat. 2270","children":[],"tail":", 2292.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c38853-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62c38854-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62c38855-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text"