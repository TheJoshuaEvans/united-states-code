{"tag":"section","attrib":{"id":"id62b0756c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3007"},"text":null,"children":[{"tag":"num","attrib":{"value":"3007"},"text":"§ 3007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62b0756d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any museum that fails to comply with the requirements of this chapter may be assessed a civil penalty by the Secretary of the Interior pursuant to procedures established by the Secretary through regulation. A penalty assessed under this subsection shall be determined on the record after opportunity for an agency hearing. Each violation under this subsection shall be a separate offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b0756e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a penalty assessed under subsection (a) shall be determined under regulations promulgated pursuant to this chapter, taking into account, in addition to other factors—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62b0756f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3007/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the archaeological, historical, or commercial value of the item involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b07570-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3007/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the damages suffered, both economic and noneconomic, by an aggrieved party,","children":[{"tag":"ref","attrib":{"idref":"fn002202"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002202"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should be a semicolon."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62b07571-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3007/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of violations that have occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b07572-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions to recover penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any museum fails to pay an assessment of a civil penalty pursuant to a final order of the Secretary that has been issued under subsection (a) and not appealed or after a final judgment has been rendered on appeal of such order, the Attorney General may institute a civil action in an appropriate district court of the United States to collect the penalty. In such action, the validity and amount of such penalty shall not be subject to review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62b07573-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3007/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoenas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In hearings held pursuant to subsection (a), subpoenas may be issued for the attendance and testimony of witnesses and the production of relevant papers, books, and documents. Witnesses so summoned shall be paid the same fees and mileage that are paid to witnesses in the courts of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62b07574-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/601/s9"},"text":"Pub. L. 101–601, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3057"},"text":"104 Stat. 3057","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62b07575-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62b07576-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62b07577-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/601"},"text":"Pub. L. 101–601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3048"},"text":"104 Stat. 3048","children":[],"tail":", known as the Native American Graves Protection and Repatriation Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"section 3001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
