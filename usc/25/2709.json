{"tag":"section","attrib":{"id":"id62a6d7f5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2709"},"text":null,"children":[{"tag":"num","attrib":{"value":"2709"},"text":"§ 2709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim authority to regulate gaming","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, the Secretary shall continue to exercise those authorities vested in the Secretary on the day before ","children":[{"tag":"date","attrib":{"date":"1988-10-17"},"text":"October 17, 1988","children":[],"tail":", relating to supervision of Indian gaming until such time as the Commission is organized and prescribes regulations. The Secretary shall provide staff and support assistance to facilitate an orderly transition to regulation of Indian gaming by the Commission."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62a6d7f6-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497/s10"},"text":"Pub. L. 100–497, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2472"},"text":"102 Stat. 2472","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62a6d7f7-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62a6d7f8-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62a6d7f9-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497"},"text":"Pub. L. 100–497","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2467"},"text":"102 Stat. 2467","children":[],"tail":", known as the Indian Gaming Regulatory Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2701"},"text":"section 2701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
