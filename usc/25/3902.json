{"tag":"section","attrib":{"id":"id62c84334-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3902"},"text":null,"children":[{"tag":"num","attrib":{"value":"3902"},"text":"§ 3902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62c84335-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closure or close","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “closure or close” means the termination of operations at open dumps on Indian land or Alaska Native land and bringing such dumps into compliance with applicable Federal standards and regulations, or standards promulgated by an Indian tribal government or Alaska Native entity, if such standards are more stringent than the Federal standards and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c84336-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Indian Health Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c84337-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3902/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Indian land” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62c84338-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3902/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land within the limits of any Indian reservation under the jurisdiction of the United States Government, notwithstanding the issuance of any patent, and including rights-of-way running through the reservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c84339-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3902/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dependent Indian communities within the borders of the United States whether within the original or subsequently acquired territory thereof, and whether within or without the limits of a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62c8433a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3902/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian allotments, the Indian titles to which have not been extinguished, including rights-of-way running through such allotments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c8433b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3902/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alaska Native land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Alaska Native land” means (A) land conveyed or to be conveyed pursuant to the Alaska Native Claims Settlement Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.], including any land reconveyed under section 14(c)(3) "},{"tag":"ref","attrib":{"idref":"fn002227"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002227"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1613/c/3"},"text":"43 U.S.C. 1613(c)(3)","children":[],"tail":"), and (B) land conveyed pursuant to the Act of "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"November 2, 1966","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1151"},"text":"16 U.S.C. 1151","children":[],"tail":" et seq.; commonly known as the “Fur Seal Act of 1966”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c8433c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3902/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribal government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribal government” means the governing body of any Indian tribe, band, nation, pueblo, or other organized group or community which is recognized as eligible for the special programs and services provided by the United States to Indians because of their status as Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c8433d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3902/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alaska Native entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Alaska Native entity” includes native corporations established pursuant to the Alaska Native Claims Settlement Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.] and any Alaska Native village or municipal entity which owns Alaska Native land."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c8433e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3902/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Open dump","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “open dump” means any facility or site where solid waste is disposed of which is not a sanitary landfill which meets the criteria promulgated under section 4004 of the Solid Waste Disposal Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6944"},"text":"42 U.S.C. 6944","children":[],"tail":") and which is not a facility for disposal of hazardous waste."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c8433f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3902/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postclosure maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “postclosure maintenance” means any activity undertaken at a closed solid waste management facility on Indian land or on Alaska Native land to maintain the integrity of containment features, monitor compliance with applicable performance standards, or remedy any situation or occurrence that violates regulations promulgated pursuant to subtitle D of the Solid Waste Disposal Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6941"},"text":"42 U.S.C. 6941","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c84340-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3902/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Service” means the Indian Health Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62c84341-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3902/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solid waste","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “solid waste” has the meaning provided that term by section 1004(27) of the Solid Waste Disposal Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6903"},"text":"42 U.S.C. 6903","children":[],"tail":") and any regulations promulgated thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62c84342-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/399/s3"},"text":"Pub. L. 103–399, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4164"},"text":"108 Stat. 4164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/109/s5"},"text":"Pub. L. 104–109, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-12"},"text":"Feb. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/764"},"text":"110 Stat. 764","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62c84343-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62c84344-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62c84345-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Alaska Native Claims Settlement Act, referred to in pars. (4) and (6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. Section 14(c)(3) of the Act was redesignated section 14(c)(1)(C) by "},{"tag":"ref","attrib":{"href":"/us/pl/119/23/s2/1"},"text":"Pub. L. 119–23, § 2(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2025-07-07"},"text":"July 7, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/403"},"text":"139 Stat. 403","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1613/c/1/C"},"text":"section 1613(c)(1)(C) of Title 43","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Fur Seal Act of 1966, referred to in par. (4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/702"},"text":"Pub. L. 89–702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1091"},"text":"80 Stat. 1091","children":[],"tail":", which is classified principally to chapter 24 (§ 1151 et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1151"},"text":"section 1151 of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Solid Waste Disposal Act, referred to in par. (8), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272"},"text":"Pub. L. 89–272","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-20"},"text":"Oct. 20, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/997"},"text":"79 Stat. 997","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/94/580/s2"},"text":"Pub. L. 94–580, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2795"},"text":"90 Stat. 2795","children":[],"tail":". Subtitle D of the Act is classified generally to subchapter IV (§ 6941 et seq.) of chapter 82 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6901"},"text":"section 6901 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62c84346-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/109"},"text":"Pub. L. 104–109","children":[],"tail":" substituted “section 4004 of the Solid Waste Disposal Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6944"},"text":"42 U.S.C. 6944","children":[],"tail":")” for “section 6944 of the Solid Waste Disposal Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6941"},"text":"42 U.S.C. 6941","children":[],"tail":" et seq.)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
