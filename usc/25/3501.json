{"tag":"section","attrib":{"id":"id62bc5d06-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501"},"text":null,"children":[{"tag":"num","attrib":{"value":"3501"},"text":"§ 3501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62bc5d07-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Director” means the Director of the Office of Indian Energy Policy and Programs, Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5d08-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Indian land” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62bc5d09-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any land located within the boundaries of an Indian reservation, pueblo, or rancheria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5d0a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any land not located within the boundaries of an Indian reservation, pueblo, or rancheria, the title to which is held—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62bc5d0b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in trust by the United States for the benefit of an Indian tribe or an individual Indian;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62bc5d0c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an Indian tribe or an individual Indian, subject to restriction against alienation under laws of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62bc5d0d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a dependent Indian community;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5d0e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land that is owned by an Indian tribe and was conveyed by the United States to a Native Corporation pursuant to the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.), or that was conveyed by the United States to a Native Corporation in exchange for such land;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5d0f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any land located in a census tract in which the majority of residents are Natives (as defined in section 3(b) of the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602/b"},"text":"43 U.S.C. 1602(b)","children":[],"tail":")); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5d10-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any land located in a census tract in which the majority of residents are persons who are enrolled members of a federally recognized Tribe or village.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5d11-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Indian reservation” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62bc5d12-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian reservation in existence in any State or States as of ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5d13-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public domain Indian allotment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5d14-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a dependent Indian community located within the borders of the United States, regardless of whether the community is located—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62bc5d15-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on original or acquired territory of the community; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62bc5d16-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within or outside the boundaries of any State or States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5d17-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62bc5d18-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Indian tribe” has the meaning given the term in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"25 U.S.C. 450b","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn002221"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002221"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5d19-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of paragraph (12) and sections 3503(b)(1)(C) and 3504 of this title, the term “Indian tribe” does not include any Native Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5d1a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “integration of energy resources” means any project or activity that promotes the location and operation of a facility (including any pipeline, gathering system, transportation system or facility, or electric transmission or distribution facility) on or near Indian land to process, refine, generate electricity from, or otherwise develop energy resources on, Indian land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5d1b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Native Corporation” has the meaning given the term in section 3 of the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602"},"text":"43 U.S.C. 1602","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5d1c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “organization” means a partnership, joint venture, limited liability company, or other unincorporated association or entity that is established to develop Indian energy resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5d1d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Program” means the Indian energy resource development program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3502/a"},"text":"section 3502(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5d1e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “qualified Indian tribe” means an Indian tribe that has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62bc5d1f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carried out a contract or compact under title I or IV of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.) for a period of not less than 3 consecutive years ending on the date on which the Indian tribe submits the application without material audit exception (or without any material audit exceptions that were not corrected within the 3-year period) relating to the management of tribal land or natural resources; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5d20-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantial experience in the administration, review, or evaluation of energy resource leases or agreements or has otherwise substantially participated in the administration, management, or development of energy resources located on the tribal land of the Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5d21-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5d22-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “sequestration” means the long-term separation, isolation, or removal of greenhouse gases from the atmosphere, including through a biological or geologic method such as reforestation or an underground reservoir.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5d23-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “tribal energy development organization” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62bc5d24-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any enterprise, partnership, consortium, corporation, or other type of business organization that is engaged in the development of energy resources and is wholly owned by an Indian tribe (including an organization incorporated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5124"},"text":"section 5124 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5203"},"text":"section 5203 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62bc5d25-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization of two or more entities, at least one of which is an Indian tribe, that has the written consent of the governing bodies of all Indian tribes participating in the organization to apply for a grant, loan, or other assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3502"},"text":"section 3502 of this title","children":[],"tail":" or to enter into a lease or business agreement with, or acquire a right-of-way from, an Indian tribe pursuant to subsection (a)(2)(A)(ii) or (b)(2)(B) of "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3504"},"text":"section 3504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62bc5d26-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s3501/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “tribal land” means any land or interests in land owned by any Indian tribe, title to which is held in trust by the United States, or is subject to a restriction against alienation under laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62bc5d27-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXVI/s2601"},"text":"Pub. L. 102–486, title XXVI, § 2601","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tV/s503/a"},"text":"Pub. L. 109–58, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/764"},"text":"119 Stat. 764","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/325/tI/s105/a"},"text":"Pub. L. 115–325, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-18"},"text":"Dec. 18, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4455"},"text":"132 Stat. 4455","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tVIII/s8013/a"},"text":"Pub. L. 116–260, div. Z, title VIII, § 8013(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2592"},"text":"134 Stat. 2592","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62bc5d28-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62bc5d29-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62bc5d2a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Alaska Native Claims Settlement Act, referred to in par. (2)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in pars. (4)(A) and (9)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":". Titles I and IV of the Act are classified principally to subchapter I (§ 5321 et seq.) and generally to subchapter IV (§ 5361 et seq.), respectively, of chapter 46 of this title. Section 4 of the Act was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"section 450b of this title","children":[],"tail":" prior to editorial reclassification as "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of this title","children":[],"tail":". For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/93/638/s1"},"text":"section 1 of Pub. L. 93–638","children":[],"tail":", set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id62bc5d2b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3501, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXVI/s2601"},"text":"Pub. L. 102–486, title XXVI, § 2601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3113"},"text":"106 Stat. 3113","children":[],"tail":", defined terms, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62bc5d2c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Par. (2)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added subpars. (D) and (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Pars. (9) to (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325/s105/a/1"},"text":"Pub. L. 115–325, § 105(a)(1)","children":[],"tail":", (2), added par. (9) and redesignated former pars. (9) and (10) as (10) and (11), respectively. Former par. (11) redesignated (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325/s105/a/3"},"text":"Pub. L. 115–325, § 105(a)(3)","children":[],"tail":", added par. (12) and struck out former par. (12) which read as follows: “The term ‘tribal energy resource development organization’ means an organization of two or more entities, at least one of which is an Indian tribe, that has the written consent of the governing bodies of all Indian tribes participating in the organization to apply for a grant, loan, or other assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3502"},"text":"section 3502 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/325/s105/a/1"},"text":"Pub. L. 115–325, § 105(a)(1)","children":[],"tail