{"tag":"section","attrib":{"id":"id62cf6f1b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145d"},"text":null,"children":[{"tag":"num","attrib":{"value":"4145d"},"text":"§ 4145d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62cf6f1c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During calendar year 2011, the Secretary shall conduct a review of the results achieved by the program under this part to determine—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cf6f1d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the housing constructed, acquired, or rehabilitated under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6f1e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects of the housing described in paragraph (1) on costs to low-income families of affordable housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6f1f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of each recipient in achieving the results intended to be achieved, as described in the Indian housing plan for the Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6f20-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for, and effectiveness of, extending the duration of the program and increasing the amount of grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4111"},"text":"section 4111 of this title","children":[],"tail":" that may be used under the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cf6f21-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":", the Secretary shall submit to Congress a report describing the information obtained pursuant to the review under subsection (a) (including any conclusions and recommendations of the Secretary with respect to the program under this part), including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cf6f22-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations regarding extension of the program for subsequent fiscal years and increasing the amounts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4145a/c"},"text":"section 4145a(c) of this title","children":[],"tail":" that may be used under the program; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6f23-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cf6f24-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62cf6f25-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145d/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific Indian tribes or recipients that should be prohibited from participating in the program for failure to achieve results; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cf6f26-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145d/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period for which such a prohibition should remain in effect; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cf6f27-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards and procedures by which Indian tribes or recipients may be prohibited from participating in the program for failure to achieve results.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cf6f28-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4145d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of information to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, recipients participating in the program under this part shall provide such information to the Secretary as the Secretary may request, in sufficient detail and in a timely manner sufficient to ensure that the review and report required by this section is accomplished in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62cf6f29-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tII/s235"},"text":"Pub. L. 104–330, title II, § 235","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/411/tII/s206/a/2"},"text":"Pub. L. 110–411, title II, § 206(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4328"},"text":"122 Stat. 4328","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62cf6f2a-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62cf6f2b-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62cf6f2c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", known as the Native American Housing Assistance and Self-Determination Act of 1996. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
