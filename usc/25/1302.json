{"tag":"section","attrib":{"id":"id624ea714-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302"},"text":null,"children":[{"tag":"num","attrib":{"value":"1302"},"text":"§ 1302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Constitutional rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id624ea715-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No Indian tribe in exercising powers of self-government shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id624ea716-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make or enforce any law prohibiting the free exercise of religion, or abridging the freedom of speech, or of the press, or the right of the people peaceably to assemble and to petition for a redress of grievances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea717-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violate the right of the people to be secure in their persons, houses, papers, and effects against unreasonable search and seizures, nor issue warrants, but upon probable cause, supported by oath or affirmation, and particularly describing the place to be searched and the person or thing to be seized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea718-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject any person for the same offense to be twice put in jeopardy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea719-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compel any person in any criminal case to be a witness against himself;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea71a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take any private property for a public use without just compensation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea71b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny to any person in a criminal proceeding the right to a speedy and public trial, to be informed of the nature and cause of the accusation, to be confronted with the witnesses against him, to have compulsory process for obtaining witnesses in his favor, and at his own expense to have the assistance of counsel for his defense (except as provided in subsection (b));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea71c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id624ea71d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require excessive bail, impose excessive fines, or inflict cruel and unusual punishments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id624ea71e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraph (C), impose for conviction of any 1 offense any penalty or punishment greater than imprisonment for a term of 1 year or a fine of $5,000, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id624ea71f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (b), impose for conviction of any 1 offense any penalty or punishment greater than imprisonment for a term of 3 years or a fine of $15,000, or both; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id624ea720-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/a/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose on a person in a criminal proceeding a total penalty or punishment greater than imprisonment for a term of 9 years;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea721-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny to any person within its jurisdiction the equal protection of its laws or deprive any person of liberty or property without due process of law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea722-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pass any bill of attainder or ex post facto law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea723-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny to any person accused of an offense punishable by imprisonment the right, upon request, to a trial by jury of not less than six persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id624ea724-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses subject to greater than 1-year imprisonment or a fine greater than $5,000","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A tribal court may subject a defendant to a term of imprisonment greater than 1 year but not to exceed 3 years for any 1 offense, or a fine greater than $5,000 but not to exceed $15,000, or both, if the defendant is a person accused of a criminal offense who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id624ea725-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been previously convicted of the same or a comparable offense by any jurisdiction in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea726-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is being prosecuted for an offense comparable to an offense that would be punishable by more than 1 year of imprisonment if prosecuted by the United States or any of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id624ea727-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of defendants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a criminal proceeding in which an Indian tribe, in exercising powers of self-government, imposes a total term of imprisonment of more than 1 year on a defendant, the Indian tribe shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id624ea728-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the defendant the right to effective assistance of counsel at least equal to that guaranteed by the United States Constitution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea729-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the expense of the tribal government, provide an indigent defendant the assistance of a defense attorney licensed to practice law by any jurisdiction in the United States that applies appropriate professional licensing standards and effectively ensures the competence and professional responsibility of its licensed attorneys;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea72a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require that the judge presiding over the criminal proceeding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id624ea72b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has sufficient legal training to preside over criminal proceedings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id624ea72c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is licensed to practice law by any jurisdiction in the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea72d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to charging the defendant, make publicly available the criminal laws (including regulations and interpretative documents), rules of evidence, and rules of criminal procedure (including rules governing the recusal of judges in appropriate circumstances) of the tribal government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea72e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a record of the criminal proceeding, including an audio or other recording of the trial proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id624ea72f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sentences","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a defendant sentenced in accordance with subsections (b) and (c), a tribal court may require the defendant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id624ea730-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to serve the sentence—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id624ea731-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a tribal correctional center that has been approved by the Bureau of Indian Affairs for long-term incarceration, in accordance with guidelines to be developed by the Bureau of Indian Affairs (in consultation with Indian tribes) not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id624ea732-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the nearest appropriate Federal facility, at the expense of the United States pursuant to the Bureau of Prisons tribal prisoner pilot program described in section 304(c) ","children":[{"tag":"ref","attrib":{"idref":"fn002022"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002022"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Tribal Law and Order Act of 2010;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id624ea733-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a State or local government-approved detention or correctional center pursuant to an agreement between the Indian tribe and the State or local government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id624ea734-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an alternative rehabilitation center of an Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id624ea735-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve another alternative form of punishment, as determined by the tribal court judge pursuant to tribal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id624ea736-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of offense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “offense” means a violation of a criminal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id624ea737-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1302/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section affects the obligation of the United States, or any State government that has been delegated authority by the United States, to investigate and prosecute any criminal violation in Indian country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id624ea738-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284/tII/s202"},"text":"Pub. L. 90–284, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/77"},"text":"82 Stat. 77","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4217"},"text":"Pub. L. 99–570, title IV, § 4217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-146"},"text":"100 Stat. 3207–146","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s234/a"},"text":"Pub. L. 111–211, title II, § 234(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2279"},"text":"124 Stat. 2279","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id624ea739-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id624ea73a-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id624ea73b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 304(c) of the Tribal Law and Order Act of 2010, referred to in subsec. (d)(1)(B), probably means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s234/c"},"text":"section 234(c) of title II of Pub. L. 111–211","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1302a"},"text":"section 1302a of this title","children":[],"tail":". See par. (13) of H. Con. Res. 304 (111th Congress), which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id624ea73c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s234/a/1"},"text":"Pub. L. 111–211, § 234(a)(1)","children":[],"tail":", designated existing provisions as subsec. (a) and inserted subsec. heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s234/a/2/A"},"text":"Pub. L. 111–211, § 234(a)(2)(A)","children":[],"tail":", inserted “(except as provided in subsection (b))” after “assistance of counsel for his defense”. Amendment was executed to reflect the probable intent of Congress, notwithstanding errors in the directory language in quoting the text to be inserted."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s234/a/2/B"},"text":"Pub. L. 111–211, § 234(a)(2)(B)","children":[],"tail":", added par. (7) and struck out former par. (7) which read as follows: “require excessive bail, impose excessive fines, inflict cruel and unusual punishments, and in no event impose for conviction of any one offense any penalty or punishment greater than imprisonment for a term of one year and a fine of $5,000, or both;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s234/a/3"},"text":"Pub. L. 111–211, § 234(a)(3)","children":[],"tail":", added subsecs. (b) to (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570"},"text":"Pub. L. 99–570","children":[],"tail":", which directed that “for a term of one year and a fine of $5,000, or both” be substituted for “for a term of six months and a fine of $500, or both”, was executed by making the substitution for “for a term of six months or a fine of $500, or both” as the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id624ea73d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id624ea73e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Bureau of Prisons Tribal Prisoner Pilot Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s234/c"},"text":"Pub. L. 111–211, title II, § 234(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2281"},"text":"124 Stat. 2281","children":[],"tail":", which related to establishment of tribal prisoner pilot program, was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1302a"},"text":"section 1302a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id624ea73f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4217"},"text":"Pub. L. 99–570, title IV, § 4217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-146"},"text":"100 Stat. 3207–146","children":[],"tail":", provided in part that amendment of par. (7) of this section was to “enhance the ability of tribal governments to prevent and penalize the traffic of illegal narcotics on Indian reservations”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
