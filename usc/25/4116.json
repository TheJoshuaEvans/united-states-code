{"tag":"section","attrib":{"id":"id62cd2547-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116"},"text":null,"children":[{"tag":"num","attrib":{"value":"4116"},"text":"§ 4116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62cd2548-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cd2549-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"October 26, 1996","children":[],"tail":", the Secretary shall, by notice issued in the Federal Register, establish any requirements necessary to provide for the transition (upon the effectiveness of this chapter and the amendments made by this chapter) from the provision of assistance for Indian tribes and Indian housing authorities under the United States Housing Act of 1937 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"42 U.S.C. 1437","children":[],"tail":" et seq.] and other related provisions of law to the provision of assistance in accordance with this chapter and the amendments made by this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cd254a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comments; general notice of proposed rulemaking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notice issued under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cd254b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invite public comments regarding such transition requirements and final regulations to carry out this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cd254c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a general notice of proposed rulemaking (for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s564/a"},"text":"section 564(a) of title 5","children":[],"tail":") of the final regulations under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cd254d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cd254e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue final regulations necessary to carry out this chapter not later than ","children":[{"tag":"date","attrib":{"date":"1997-09-01"},"text":"September 1, 1997","children":[],"tail":", and such regulations shall take effect not later than the effective date of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cd254f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiated rulemaking procedure","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cd2550-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding sections 563(a) and 565(a) of title 5, all regulations required under this chapter, including any regulations that may be required pursuant to amendments made to this chapter after ","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"October 26, 1996","children":[],"tail":", shall be issued according to a negotiated rulemaking procedure under subchapter III of chapter 5 of title 5."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cd2551-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62cd2552-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the date of enactment of the Native American Housing Assistance and Self-Determination Reauthorization Act of 2008 and any other Act to reauthorize this chapter, the Secretary shall establish a negotiated rulemaking committee, in accordance with the procedures under that subchapter, for the development of proposed regulations under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cd2553-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adaptation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing the negotiated rulemaking committee, the Secretary shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id62cd2554-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adapt the procedures under the subchapter described in clause (i) to the unique government-to-government relationship between the Indian tribes and the United States, and shall ensure that the membership of the committee include only representatives of the Federal Government and of geographically diverse small, medium, and large Indian tribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id62cd2555-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not preclude the participation of tribally designated housing entities should tribes elect to be represented by such entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cd2556-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent negotiated rulemaking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62cd2557-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiate a negotiated rulemaking in accordance with this section by not later than 90 days after the date of enactment of the Native American Housing Assistance and Self-Determination Reauthorization Act of 2008 and any other Act to reauthorize this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62cd2558-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promulgate regulations pursuant to this section by not later than 2 years after the date of enactment of the Native American Housing Assistance and Self-Determination Reauthorization Act of 2008 and any other Act to reauthorize this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cd2559-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than once every 7 years, the Secretary, in consultation with Indian tribes, shall review the regulations promulgated pursuant to this section in effect on the date on which the review is conducted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cd255a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect on ","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"October 26, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62cd255b-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tI/s106"},"text":"Pub. L. 104–330, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4029"},"text":"110 Stat. 4029","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/292/s6"},"text":"Pub. L. 107–292, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-13"},"text":"Nov. 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2054"},"text":"116 Stat. 2054","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/411/tI/s105"},"text":"Pub. L. 110–411, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4324"},"text":"122 Stat. 4324","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62cd255c-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62cd255d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62cd255e-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", known as the Native American Housing Assistance and Self-Determination Act of 1996. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For the effective date of this chapter, referred to in subsecs. (a)(1) and (b)(1), as ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s107"},"text":"section 107 of Pub. L. 104–330","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The United States Housing Act of 1937, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"act Sept. 1, 1937, ch. 896","children":[],"tail":", as revised generally by "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/tII/s201/a"},"text":"Pub. L. 93–383, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/653"},"text":"88 Stat. 653","children":[],"tail":", which is classified generally to chapter 8 (§ 1437 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"section 1437 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of the Native American Housing Assistance and Self-Determination Reauthorization Act of 2008, referred to in subsec. (b)(2)(B)(i), (C), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/411"},"text":"Pub. L. 110–411","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62cd255f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/411/s105/1"},"text":"Pub. L. 110–411, § 105(1)","children":[],"tail":", substituted “Not later than 180 days after the date of enactment of the Native American Housing Assistance and Self-Determination Reauthorization Act of 2008 and any other Act to reauthorize this chapter, the Secretary” for “The Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/411/s105/2"},"text":"Pub. L. 110–411, § 105(2)","children":[],"tail":", added subpars. (C) and (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/292"},"text":"Pub. L. 107–292","children":[],"tail":" inserted “, including any regulations that may be required pursuant to amendments made to this chapter after "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"October 26, 1996","children":[],"tail":",” after “required under this chapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
