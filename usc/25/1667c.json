{"tag":"section","attrib":{"id":"id6274cb90-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1667c"},"text":"§ 1667c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substance abuse and mental health services Administration grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6274cb91-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6274cb92-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Efficiency of grant application process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Administration, shall carry out such measures as the Secretary determines to be necessary to maximize the time and workload efficiency of the process by which Indian tribes and tribal organizations apply for grants under any program administered by the Administration, including by providing methods other than electronic methods of submitting applications for those grants, if necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cb93-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for certain grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cb94-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To fulfill the trust responsibility of the United States to Indian tribes, in awarding relevant grants pursuant to a program described in subparagraph (B), the Secretary shall take into consideration the needs of Indian tribes or tribal organizations, as applicable, that serve populations with documented high suicide rates, regardless of whether those Indian tribes or tribal organizations possess adequate personnel or infrastructure to fulfill all applicable requirements of the relevant program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb95-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of grant programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant program referred to in subparagraph (A) is a grant program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cb96-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administered by the Administration to fund activities relating to mental health, suicide prevention, or suicide-related risk factors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cb97-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which an Indian tribe or tribal organization is an eligible recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cb98-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification regarding Indian tribes and tribal organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, in applying for a grant under any program administered by the Administration, no Indian tribe or tribal organization shall be required to apply through a State or State agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cb99-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for affected States","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cb9a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cb9b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affected State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “affected State” means a State—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6274cb9c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/4/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the boundaries of which include 1 or more Indian tribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6274cb9d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/4/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application for a grant under any program administered by the Administration of which includes statewide data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cb9e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian population","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian population” means the total number of residents of an affected State who are Indian.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cb9f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition of receipt of a grant under any program administered by the Administration, each affected State shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cba0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe in the grant application—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6274cba1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian population of the affected State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6274cba2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contribution of that Indian population to the statewide data used by the affected State in the application; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cba3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demonstrate to the satisfaction of the Secretary that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6274cba4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" of the total amount of the grant, the affected State will allocate for use for the Indian population of the affected State an amount equal to the proportion that—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id6274cba5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/4/B/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian population of the affected State; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id6274cba6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/4/B/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total population of the affected State; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6274cba7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the affected State will take reasonable efforts to collaborate with each Indian tribe located within the affected State to carry out youth suicide prevention and treatment measures for members of the Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cba8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date of receipt of a grant described in subparagraph (B), an affected State shall submit to the Secretary a report describing the measures carried out by the affected State to ensure compliance with the requirements of subparagraph (B)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6274cba9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No non-Federal share requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, no Indian tribe or tribal organization shall be required to provide a non-Federal share of the cost of any project or activity carried out using a grant provided under any program administered by the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6274cbaa-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach for rural and isolated Indian tribes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Due to the rural, isolated nature of most Indian reservations and communities (especially those reservations and communities in the Great Plains region), the Secretary shall conduct outreach activities, with a particular emphasis on the provision of telemental health services, to achieve the purposes of this part with respect to Indian tribes located in rural, isolated areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6274cbab-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of other assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6274cbac-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Administration, shall carry out such measures (including monitoring and the provision of required assistance) as the Secretary determines to be necessary to ensure the provision of adequate suicide prevention and mental health services to Indian tribes described in paragraph (2), regardless of whether those Indian tribes possess adequate personnel or infrastructure—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cbad-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to submit an application for a grant under any program administered by the Administration, including due to problems relating to access to the Internet or other electronic means that may have resulted in previous obstacles to submission of a grant application; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbae-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fulfill all applicable requirements of the relevant program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cbaf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of Indian tribes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Indian tribe referred to in paragraph (1) is an Indian tribe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cbb0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the members of which experience—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6274cbb1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a high rate of youth suicide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cbb2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low socioeconomic status; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6274cbb3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extreme health disparity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbb4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located in a remote and isolated area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbb5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that lacks technology and communication infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cbb6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary such sums as the Secretary determines to be necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6274cbb7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early intervention and assessment services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6274cbb8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of affected entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “affected entity” means any entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6274cbb9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that receives a grant for suicide intervention, prevention, or treatment under a program administered by the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6274cbba-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population to be served by which includes Indian youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6274cbbb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1667c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Administration, shall ensure that each affected entity carrying out a youth suicide early intervention and prevention strategy described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–36/c/1"},"text":"section 290bb–36(c)(1) of title 42","children":[],"tail":", or any other youth suicide-related early intervention and assessment activity, provides training or education to individuals who interact frequently with the Indian youth to be served by the affected entity (including parents, teachers, coaches, and mentors) on identifying warning signs of Indian youth who are at risk of committing suicide."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6274cbbc-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVII/s724"},"text":"Pub. L. 94–437, title VII, § 724","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6274cbbd-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6274cbbe-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6274cbbf-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s724"},"text":"Section 724 of Pub. L. 94–437","children":[],"tail":" is based on section 181 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
