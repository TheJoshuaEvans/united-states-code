{"tag":"section","attrib":{"id":"id626d9f79-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1652"},"text":null,"children":[{"tag":"num","attrib":{"value":"1652"},"text":"§ 1652.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts with, and grants to, urban Indian organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id626d9f7a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1652/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":", the Secretary, acting through the Service, shall enter into contracts with, or make grants to, urban Indian organizations to assist the urban Indian organizations in the establishment and administration, within urban centers, of programs that meet the requirements of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626d9f7b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1652/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1656"},"text":"section 1656 of this title","children":[],"tail":", the Secretary, acting through the Service, shall include such conditions as the Secretary considers necessary to effect the purpose of this subchapter in any contract into which the Secretary enters with, or in any grant the Secretary makes to, any urban Indian organization pursuant to this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id626d9f7c-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tV/s502"},"text":"Pub. L. 94–437, title V, § 502","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tV/s501"},"text":"Pub. L. 100–713, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4820"},"text":"102 Stat. 4820","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tV/s501/a"},"text":"Pub. L. 102–573, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4567"},"text":"106 Stat. 4567","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id626d9f7d-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id626d9f7e-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id626d9f7f-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" is based on section 163(b) of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id626d9f80-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1652, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tV/s502"},"text":"Pub. L. 94–437, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1410"},"text":"90 Stat. 1410","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/537/s7"},"text":"Pub. L. 96–537, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-17"},"text":"Dec. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3177"},"text":"94 Stat. 3177","children":[],"tail":", related to contracts with urban and rural Indian organizations, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/100/713"},"text":"Pub. L. 100–713","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id626d9f81-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “Under authority of "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of this title","children":[],"tail":", the Secretary, through the Service, shall enter into contracts with, or make grants to, urban Indian organizations to assist such organizations in the establishment and administration, within the urban centers in which such organizations are situated, of programs which meet the requirements set forth in this subchapter. The Secretary, through the Service, shall include such conditions as the Secretary considers necessary to effect the purpose of this subchapter in any contract which the Secretary enters into with, or in any grant the Secretary makes to, any urban Indian organization pursuant to this subchapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573"},"text":"Pub. L. 102–573","children":[],"tail":" substituted “Contracts with, and grants to, urban Indian organizations” for “Contracts with urban Indian organizations” in section catchline, and in text substituted “contracts with, or make grants to,” for “contracts with” and inserted “, or in any grant the Secretary makes to,” after “enters into with”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
