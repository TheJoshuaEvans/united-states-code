{"tag":"section","attrib":{"id":"id62cf6ee9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4140"},"text":null,"children":[{"tag":"num","attrib":{"value":"4140"},"text":"§ 4140.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued use of amounts for affordable housing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any funds for programs for low-income housing under the United States Housing Act of 1937 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"42 U.S.C. 1437","children":[],"tail":" et seq.] that, on the date of the applicability of this chapter to an Indian tribe, are owned by, or in the possession or under the control of, the Indian housing authority for the tribe, including all reserves not otherwise obligated, shall be considered assistance under this chapter and subject to the provisions of this chapter relating to use of such assistance."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62cf6eea-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tII/s210"},"text":"Pub. L. 104–330, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4036"},"text":"110 Stat. 4036","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62cf6eeb-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62cf6eec-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62cf6eed-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading