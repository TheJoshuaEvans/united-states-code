{"tag":"section","attrib":{"id":"id6255d1ce-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1468"},"text":null,"children":[{"tag":"num","attrib":{"value":"1468"},"text":"§ 1468.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated, to provide capital and to restore any impairment of capital for the revolving loan fund $50,000,000 exclusive of prior authorizations and appropriations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6255d1cf-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/262/tI/s108"},"text":"Pub. L. 93–262, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-12"},"text":"Apr. 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/79"},"text":"88 Stat. 79","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
