{"tag":"section","attrib":{"id":"id62ddc715-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5210"},"text":null,"children":[{"tag":"num","attrib":{"value":"5210"},"text":"§ 5210.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of gross production taxes; method","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever restricted Indian lands in the State of Oklahoma are subject to gross production tax on minerals, including oil and gas, the Secretary of the Interior, in his discretion, may cause such tax or taxes due the State of Oklahoma to be paid in the manner provided for by the statutes of the State of Oklahoma.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62ddc716-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-08-25/ch772"},"text":"Aug. 25, 1937, ch. 772","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/806"},"text":"50 Stat. 806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62ddc717-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62ddc718-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62ddc719-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-26/ch831"},"text":"act June 26, 1936, ch. 831","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1967"},"text":"49 Stat. 1967","children":[],"tail":", which comprises this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s510"},"text":"section 510 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
