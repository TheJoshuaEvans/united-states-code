{"tag":"section","attrib":{"id":"id62d42abd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4234"},"text":null,"children":[{"tag":"num","attrib":{"value":"4234"},"text":"§ 4234.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If the Department of Hawaiian Home Lands uses grant amounts to provide affordable housing under activities under this subchapter and, at any time during the useful life of the housing, the housing does not comply with the requirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4232/a/2"},"text":"section 4232(a)(2) of this title","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id62d42abe-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4234/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce future grant payments on behalf of the Department by an amount equal to the grant amounts used for that housing (under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4238/a/2"},"text":"section 4238(a)(2) of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62d42abf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4234/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require repayment to the Secretary of any amount equal to those grant amounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62d42ac0-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVIII/s815"},"text":"Pub. L. 104–330, title VIII, § 815","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tII/s203"},"text":"Pub. L. 106–568, title I