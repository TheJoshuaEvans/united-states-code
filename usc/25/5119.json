{"tag":"section","attrib":{"id":"id62db55ff-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s5119"},"text":null,"children":[{"tag":"num","attrib":{"value":"5119"},"text":"§ 5119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to Alaska","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Sections 5101, 5108, 5110, 5111, 5121, 5124, and 5129 of this title shall after ","children":[{"tag":"date","attrib":{"date":"1936-05-01"},"text":"May 1, 1936","children":[],"tail":", apply to the Territory of Alaska: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That groups of Indians in Alaska not recognized prior to "},{"tag":"date","attrib":{"date":"1936-05-01"},"text":"May 1, 1936","children":[],"tail":", as bands or tribes, but having a common bond of occupation, or association, or residence within a well-defined neighborhood, community, or rural district, may organize to adopt constitutions and bylaws and to receive charters of incorporation and Federal loans under sections 5113, 5123, and 5124 of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id62db5600-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-01/ch254/s1"},"text":"May 1, 1936, ch. 254, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1250"},"text":"49 Stat. 1250","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62db5601-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62db5602-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id62db5603-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s362"},"text":"section 362 of Title 48","children":[],"tail":", Territories and Insular Possessions, prior to transfer to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s473a"},"text":"section 473a of this title","children":[],"tail":" and editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id62db5604-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id62db5605-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Admission of Alaska as State","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Admission of Alaska into the Union was accomplished ","children":[{"tag":"date","attrib":{"date":"1959-01-03"},"text":"Jan. 3, 1959","children":[],"tail":", on issuance of Proc. No. 3269, "},{"tag":"date","attrib":{"date":"1959-01-03"},"text":"Jan. 3, 1959","children":[],"tail":", 24 F.R. 81, 73 Stat. c16, as required by sections 1 and 8(c) of "},{"tag":"ref","attrib":{"href":"/us/pl/85/508"},"text":"Pub. L. 85–508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-07"},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/339"},"text":"72 Stat. 339","children":[],"tail":", set out as notes preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s21"},"text":"section 21 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
