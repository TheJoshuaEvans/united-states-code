{"tag":"section","attrib":{"id":"id626d9fd6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1656"},"text":null,"children":[{"tag":"num","attrib":{"value":"1656"},"text":"§ 1656.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other contract and grant requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id626d9fd7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1656/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal regulations; exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Contracts with urban Indian organizations entered into pursuant to this subchapter shall be in accordance with all Federal contracting laws and regulations except that, in the discretion of the Secretary, such contracts may be negotiated without advertising and need not conform to the provisions of sections 3131 and 3133 of title 40.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626d9fd8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1656/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments under any contracts or grants pursuant to this subchapter may be made in advance or by way of reimbursement and in such installments and on such conditions as the Secretary deems necessary to carry out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626d9fd9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1656/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision or amendment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any provision of law to the contrary, the Secretary may, at the request or consent of an urban Indian organization, revise or amend any contract entered into by the Secretary with such organization under this subchapter as necessary to carry out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626d9fda-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1656/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing Government facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In connection with any contract or grant entered into pursuant to this subchapter, the Secretary may permit an urban Indian organization to utilize, in carrying out such contract or grant, existing facilities owned by the Federal Government within the Secretary’s jurisdiction under such terms and conditions as may be agreed upon for the use and maintenance of such facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626d9fdb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1656/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform provision of services and assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Contracts with, or grants to, urban Indian organizations and regulations adopted pursuant to this subchapter shall include provisions to assure the fair and uniform provision to urban Indians of services and assistance under such contracts or grants by such organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id626d9fdc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1656/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for health care or referral services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Urban Indians, as defined in section 1603(f) ","children":[{"tag":"ref","attrib":{"idref":"fn002082"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002082"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, shall be eligible for health care or referral services provided pursuant to this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id626d9fdd-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tV/s506"},"text":"Pub. L. 94–437, title V, § 506","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tV/s501"},"text":"Pub. L. 100–713, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4823"},"text":"102 Stat. 4823","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tV/s501/b/4"},"text":"Pub. L. 102–573, title V, § 501(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4568"},"text":"106 Stat. 4568","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id626d9fde-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id626d9fdf-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id626d9fe0-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603/f"},"text":"Section 1603(f) of this title","children":[],"tail":", referred to in subsec. (f), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603/28"},"text":"section 1603(28) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id626d9fe1-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Sections 3131 and 3133 of title 40” substituted in subsec. (a) for “the Act of ","children":[{"tag":"date","attrib":{"date":"1935-08-24"},"text":"August 24, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s270a"},"text":"40 U.S.C. 270a","children":[],"tail":", et seq.)” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id626d9fe2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1656, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tV/s506"},"text":"Pub. L. 94–437, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1412"},"text":"90 Stat. 1412","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/537/s7"},"text":"Pub. L. 96–537, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-17"},"text":"Dec. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3179"},"text":"94 Stat. 3179","children":[],"tail":", authorized appropriations, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/100/713"},"text":"Pub. L. 100–713","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id626d9fe3-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s501/b/4/D"},"text":"Pub. L. 102–573, § 501(b)(4)(D)","children":[],"tail":", inserted “and grant” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s501/b/4/A"},"text":"Pub. L. 102–573, § 501(b)(4)(A)","children":[],"tail":", inserted “or grants” after “any contracts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s501/b/4/B"},"text":"Pub. L. 102–573, § 501(b)(4)(B)","children":[],"tail":", inserted “or grant” after “contract” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/573/s501/b/4/C"},"text":"Pub. L. 102–573, § 501(b)(4)(C)","children":[],"tail":", inserted “, or grants to,” after “Contracts with” and “or grants” after “such contracts”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
