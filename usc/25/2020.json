{"tag":"section","attrib":{"id":"id628f0b4a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020"},"text":null,"children":[{"tag":"num","attrib":{"value":"2020"},"text":"§ 2020.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal departments or divisions of education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id628f0b4b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Secretary shall make grants and provide technical assistance to tribes for the development and operation of tribal departments or divisions of education for the purpose of planning and coordinating all educational programs of the tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0b4c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a tribe to be eligible to receive a grant under this section, the governing body of the tribe shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0b4d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diversity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants under this section in a manner that fosters geographic and population diversity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0b4e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Tribes that receive grants under this section shall use the funds made available through the grants—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628f0b4f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate tribal control in all matters relating to the education of Indian children on reservations (and on former Indian reservations in Oklahoma);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628f0b50-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the development of coordinated educational programs (including all preschool, elementary, secondary, and higher or vocational educational programs funded by tribal, Federal, or other sources) on reservations (and on former Indian reservations in Oklahoma) by encouraging tribal administrative support of all Bureau-funded educational programs as well as encouraging tribal cooperation and coordination with entities carrying out all educational programs receiving financial support from other Federal agencies, State agencies, or private entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628f0b51-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the development and enforcement of tribal educational codes, including tribal educational policies and tribal standards applicable to curriculum, personnel, students, facilities, and support programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0b52-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under this section, the Secretary shall give priority to any application that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id628f0b53-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628f0b54-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances that the applicant serves three or more separate Bureau-funded schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628f0b55-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances from the applicant that the tribal department of education to be funded under this section will provide coordinating services and technical assistance to all of such schools;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628f0b56-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes assurances that all education programs for which funds are provided by such a contract or grant will be monitored and audited, by or through the tribal department of education, to ensure that the programs meet the requirements of law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id628f0b57-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides a plan and schedule that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id628f0b58-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id628f0b59-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assumption, by the tribal department of education, of all assets and functions of the Bureau agency office associated with the tribe, to the extent the assets and functions relate to education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id628f0b5a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination by the Bureau of such functions and office at the time of such assumption; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id628f0b5b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides that the assumption shall occur over the term of the grant made under this section, except that, when mutually agreeable to the tribal governing body and the Assistant Secretary, the period in which such assumption is to occur may be modified, reduced, or extended after the initial year of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0b5c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time period of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriated funds, a grant provided under this section shall be provided for a period of 3 years. If the performance of the grant recipient is satisfactory to the Secretary, the grant may be renewed for additional 3-year terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0b5d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms, conditions, or requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A tribe that receives a grant under this section shall comply with regulations relating to grants made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5322/a"},"text":"section 5322(a) of this title","children":[],"tail":" that are in effect on the date that the tribal governing body submits the application for the grant under subsection (b). The Secretary shall not impose any terms, conditions, or requirements on the provision of grants under this section that are not specified in this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id628f0b5e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2020/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $2,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id628f0b5f-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1140"},"text":"Pub. L. 95–561, title XI, § 1140","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1042"},"text":"Pub. L. 107–110, title X, § 1042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2059"},"text":"115 Stat. 2059","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id628f0b60-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id628f0b61-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id628f0b62-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2020, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1140"},"text":"Pub. L. 95–561, title XI, § 1140","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s381"},"text":"Pub. L. 103–382, title III, § 381","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4011"},"text":"108 Stat. 4011","children":[],"tail":", related to voluntary services, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2012"},"text":"section 2012 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2020, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXI/s1140"},"text":"Pub. L. 95–561, title XI, § 1140","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/511/tV/s511"},"text":"Pub. L. 98–511, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2397"},"text":"98 Stat. 2397","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/89/s8"},"text":"Pub. L. 99–89, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-15"},"text":"Aug. 15, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/383"},"text":"99 Stat. 383","children":[],"tail":", related to voluntary services, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id628f0b63-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id628f0b64-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
