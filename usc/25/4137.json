{"tag":"section","attrib":{"id":"id62cf6ebf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4137"},"text":null,"children":[{"tag":"num","attrib":{"value":"4137"},"text":"§ 4137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease requirements and tenant selection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62cf6ec0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4137/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except to the extent otherwise provided by or inconsistent with tribal law, in renting dwelling units in affordable housing assisted with grant amounts provided under this chapter, the owner or manager of the housing shall utilize leases that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cf6ec1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4137/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not contain unreasonable terms and conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6ec2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4137/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the owner or manager to maintain the housing in compliance with applicable housing codes and quality standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6ec3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4137/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the owner or manager to give adequate written notice of termination of the lease, which shall be the period of time required under State, tribal, or local law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6ec4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4137/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify that, with respect to any notice of eviction or termination, notwithstanding any State, tribal, or local law, a resident shall be informed of the opportunity, prior to any hearing or trial, to examine any relevant documents, records, or regulations directly related to the eviction or termination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6ec5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4137/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that the owner or manager may not terminate the tenancy, during the term of the lease, except for serious or repeated violation of the terms or conditions of the lease, violation of applicable Federal, State, tribal, or local law, or for other good cause; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6ec6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4137/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide that the owner or manager may terminate the tenancy of a resident for any activity, engaged in by the resident, any member of the household of the resident, or any guest or other person under the control of the resident, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cf6ec7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4137/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" threatens the health or safety of, or right to peaceful enjoyment of the premises by, other residents or employees of the owner or manager of the housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cf6ec8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4137/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" threatens the health or safety of, or right to peaceful enjoyment of their premises by, persons residing in the immediate vicinity of the premises; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cf6ec9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4137/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is criminal activity (including drug-related criminal activity) on or off the premises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62cf6eca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4137/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tenant and homebuyer selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The owner or manager of affordable rental housing assisted with grant amounts provided under this chapter shall adopt and utilize written tenant and homebuyer selection policies and criteria that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62cf6ecb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4137/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the purpose of providing housing for low-income families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6ecc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4137/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are reasonably related to program eligibility and the ability of the applicant to perform the obligations of the lease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62cf6ecd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4137/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62cf6ece-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4137/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the selection of tenants and homebuyers from a written waiting list in accordance with the policies and goals set forth in the Indian housing plan for the tribe that is the grant beneficiary of such grant amounts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62cf6ecf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s4137/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prompt notification in writing to any rejected applicant of that rejection and the grounds for that rejection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62cf6ed0-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/tII/s207"},"text":"Pub. L. 104–330, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4034"},"text":"110 Stat. 4034","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s595/b"},"text":"Pub. L. 105–276, title V, § 595(b)","children":[],"tail":", (e)(9), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2656"},"text":"112 Stat. 2656","children":[],"tail":", 2658.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62cf6ed1-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62cf6ed2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62cf6ed3-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", known as the Native American Housing Assistance and Self-Determination Act of 1996. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62cf6ed4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/s595/b/1"},"text":"Pub. L. 105–276, § 595(b)(1)","children":[],"tail":", (2), in heading substituted “Tenant and homebuyer selection” for “Tenant selection” and, in introductory provisions, inserted “and homebuyer” after “tenant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/s595/b/3"},"text":"Pub. L. 105–276, § 595(b)(3)","children":[],"tail":", inserted “and homebuyers” after “tenants”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/s595/e/9"},"text":"Pub. L. 105–276, § 595(e)(9)","children":[],"tail":", substituted “to any rejected applicant of that rejection and the grounds for that rejection” for “of any rejected applicant of the grounds for any rejection”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id62cf6ed5-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id62cf6ed6-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s107"},"text":"section 107 of Pub. L. 104–330","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
