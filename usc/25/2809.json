{"tag":"section","attrib":{"id":"id62abbac7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809"},"text":null,"children":[{"tag":"num","attrib":{"value":"2809"},"text":"§ 2809.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to tribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id62abbac8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination and data collection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62abbac9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigative coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (c), if a law enforcement officer or employee of any Federal department or agency terminates an investigation of an alleged violation of Federal criminal law in Indian country without referral for prosecution, the officer or employee shall coordinate with the appropriate tribal law enforcement officials regarding the status of the investigation and the use of evidence relevant to the case in a tribal court with authority over the crime alleged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abbaca-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Bureau of Investigation shall compile, on an annual basis and by Field Division, information regarding decisions not to refer to an appropriate prosecuting authority cases in which investigations had been opened into an alleged crime in Indian country, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62abbacb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of crimes alleged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62abbacc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statuses of the accused as Indians or non-Indians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62abbacd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statuses of the victims as Indians or non-Indians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62abbace-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons for deciding against referring the investigation for prosecution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abbacf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prosecutorial coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (c), if a United States Attorney declines to prosecute, or acts to terminate prosecution of, an alleged violation of Federal criminal law in Indian country, the United States Attorney shall coordinate with the appropriate tribal justice officials regarding the status of the investigation and the use of evidence relevant to the case in a tribal court with authority over the crime alleged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abbad0-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prosecution data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States Attorney shall submit to the Native American Issues Coordinator to compile, on an annual basis and by Federal judicial district, information regarding all declinations of alleged violations of Federal criminal law that occurred in Indian country that were referred for prosecution by law enforcement agencies, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62abbad1-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of crimes alleged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62abbad2-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statuses of the accused as Indians or non-Indians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62abbad3-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statuses of the victims as Indians or non-Indians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62abbad4-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons for deciding to decline or terminate the prosecutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62abbad5-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall submit to Congress annual reports containing, with respect to the applicable calendar year, the information compiled under paragraphs (2) and (4) of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62abbad6-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" organized—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id62abbad7-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the aggregate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id62abbad8-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id62abbad9-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the Federal Bureau of Investigation, by Field Division; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id62abbada-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for United States Attorneys, by Federal judicial district; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abbadb-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" including any relevant explanatory statements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id62abbadc-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of section","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id62abbadd-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section requires any Federal agency or official to transfer or disclose any confidential, privileged, or statutorily protected communication, information, or source to an official of any Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abbade-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Rules of Criminal Procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section affects or limits the requirements of Rule 6 of the Federal Rules of Criminal Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id62abbadf-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s2809/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall establish, by regulation, standards for the protection of the confidential or privileged communications, information, and sources described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id62abbae0-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/379/s10"},"text":"Pub. L. 101–379, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/477"},"text":"104 Stat. 477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s212"},"text":"Pub. L. 111–211, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2267"},"text":"124 Stat. 2267","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id62abbae1-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id62abbae2-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id62abbae3-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Rule 6 of the Federal Rules of Criminal Procedure, referred to in subsec. (c)(2), is set out in the Appendix to Title 18, Crimes and Criminal Procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id62abbae4-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211"},"text":"Pub. L. 111–211","children":[],"tail":" added subsecs. (a) to (c) and struck out former subsecs. (a) to (d) which related, respectively, to reports by law enforcement officials of the Bureau of Indian Affairs or Federal Bureau of Investigation, reports by United States attorneys, case files included within reports, and transfer or disclosure of confidential or privileged communication, information, or sources to tribal officials."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
