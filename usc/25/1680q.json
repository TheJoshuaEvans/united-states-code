{"tag":"section","attrib":{"id":"id6279ad68-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q"},"text":null,"children":[{"tag":"num","attrib":{"value":"1680q"},"text":"§ 1680q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prescription drug monitoring","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6279ad69-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6279ad6a-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in coordination with the Secretary of the Interior and the Attorney General, shall establish a prescription drug monitoring program, to be carried out at health care facilities of the Service, tribal health care facilities, and urban Indian health care facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279ad6b-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Secretary shall submit to the Committee on Indian Affairs of the Senate and the Committee on Natural Resources of the House of Representatives a report that describes—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6279ad6c-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of the Service, tribal health care facilities, and urban Indian health care facilities with respect to the prescription drug monitoring program under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ad6d-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planned development of that program, including any relevant statutory or administrative limitations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ad6e-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the means by which the program could be carried out in coordination with any State prescription drug monitoring program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6279ad6f-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abuse","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6279ad70-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General, in conjunction with the Secretary and the Secretary of the Interior, shall conduct—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6279ad71-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment of the capacity of, and support required by, relevant Federal and tribal agencies—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6279ad72-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out data collection and analysis regarding incidents of prescription drug abuse in Indian communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6279ad73-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exchange among those agencies and Indian health programs information relating to prescription drug abuse in Indian communities, including statutory and administrative requirements and limitations relating to that abuse; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ad74-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training for Indian health care providers, tribal leaders, law enforcement officers, and school officials regarding awareness and prevention of prescription drug abuse and strategies for improving agency responses to addressing prescription drug abuse in Indian communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6279ad75-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Attorney General shall submit to the Committee on Indian Affairs of the Senate and the Committee on Natural Resources of the House of Representatives a report that describes—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6279ad76-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity of Federal and tribal agencies to carry out data collection and analysis and information exchanges as described in paragraph (1)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ad77-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training conducted pursuant to paragraph (1)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ad78-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" infrastructure enhancements required to carry out the activities described in paragraph (1), if any; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6279ad79-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s1680q/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any statutory or administrative barriers to carrying out those activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6279ad7a-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tVIII/s827"},"text":"Pub. L. 94–437, title VIII, § 827","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6279ad7b-4962-11f1-add1-b56d3fa293fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6279ad7c-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6279ad7d-4962-11f1-add1-b56d3fa293fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/s827"},"text":"Section 827 of Pub. L. 94–437","children":[],"tail":" is based on section 196 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
