{"tag":"section","attrib":{"id":"id6210b358-4962-11f1-add1-b56d3fa293fa","identifier":"/us/usc/t25/s43"},"text":null,"children":[{"tag":"num","attrib":{"value":"43"},"text":"§ 43.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons paid for other services not paid for interpreting","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person employed by the United States and paid for any other service shall be paid for interpreting.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6210b359-4962-11f1-add1-b56d3fa293fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1910-04-04/ch140/s2"},"text":"Apr. 4, 1910, ch. 140, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/272"},"text":"36 Stat. 272","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
