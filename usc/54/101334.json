 title VIII, § 814(a)(6)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/4191"},"text":"110 Stat. 4191","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/106/176/tI/s120/a/1/A"},"text":"Pub. L. 106–176, title I, § 120(a)(1)(A)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Mar. 10, 2000","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/114/28"},"text":"114 Stat. 28","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “For those units of the National Park System for which the review required by paragraphs (3) and (5) has been completed” are omitted as obsolete. The words “or lease” are omitted to distinguish between leasing property and renting employee housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
