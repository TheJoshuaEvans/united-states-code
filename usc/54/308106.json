{"tag":"section","attrib":{"id":"idefa8f04d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308106"},"text":null,"children":[{"tag":"num","attrib":{"value":"308106"},"text":"§ 308106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates and improvements to Battlefield Reports","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after the date of the enactment of this section, and every 10 years thereafter, the Secretary shall submit to Congress a report that updates the Battlefield Reports to reflect—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa8f04e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308106/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preservation activities carried out at the battlefields in the period since the publication of the most recent Battlefield Reports update;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa8f04f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308106/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes in the condition, including core and study areas, of the battlefields during that period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa8f050-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308106/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant developments relating to the battlefields during that period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa8f051-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s157/e"},"text":"Pub. L. 118–234, title I, 