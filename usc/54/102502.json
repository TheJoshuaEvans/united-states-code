{"tag":"section","attrib":{"id":"idef8eb10a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102502"},"text":null,"children":[{"tag":"num","attrib":{"value":"102502"},"text":"§ 102502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of museum object","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8eb10b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102502/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “museum object” means an object that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8eb10c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102502/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" typically is movable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8eb10d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102502/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible to be, or is made part of, a museum, library, or archive collection through a formal procedure, such as accessioning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb10e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102502/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusions","children":[],"tail":".—"}],"tail":null},{"tag":"content","