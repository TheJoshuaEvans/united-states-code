}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/665/tI/s101/b/4"},"text":"Pub. L. 89–665, title I, § 101(b)(4)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/915"},"text":"80 Stat. 915","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/91/383/s11"},"text":"Pub. L. 91–383, § 11","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/94/458/s2"},"text":"Pub. L. 94–458, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 7, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/1942"},"text":"90 Stat. 1942","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/93/54/s1/d"},"text":"Pub. L. 93–54, § 1(d)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 1, 1973","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/87/139"},"text":"87 Stat. 139","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/205/tVI/s608/a/1"},"text":"Pub. L. 96–205, title VI, § 608(a)(1)","children":[],"tail":", (2), "},{"tag":"html:span","attrib":{},"text":"Mar. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/92"},"text":"94 Stat. 92","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/515/tII/s201/a"},"text":"Pub. L. 96–515, title II, § 201(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/2991"},"text":"94 Stat. 2991","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470a/b/6"},"text":"16 U.S.C. 470a(b)(6)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/665/tI/s101/b/6"},"text":"Pub. L. 89–665, title I, § 101(b)(6)","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/102/575/tXL/s4004/4"},"text":"Pub. L. 102–575, title XL, § 4004(4)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/4754"},"text":"106 Stat. 4754","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
