{"tag":"section","attrib":{"id":"idef9d09ac-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304"},"text":null,"children":[{"tag":"num","attrib":{"value":"302304"},"text":"§ 302304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and cooperative agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9d09ad-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State may carry out all or any part of its responsibilities under this chapter by contract or cooperative agreement with a qualified nonprofit organization or educational institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9d09ae-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9d09af-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9d09b0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to assist secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraphs (3) and (4), the Secretary may enter into contracts or cooperative agreements with a State Historic Preservation Officer for any State authorizing the Officer to assist the Secretary in carrying out one or more of the following responsibilities within that State:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef9d09b1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification and preservation of historic property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef9d09b2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Determination of the eligibility of property for listing on the National Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef9d09b3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Preparation of nominations for inclusion on the National Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef9d09b4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Maintenance of historical and archeological data bases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef9f79b5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evaluation of eligibility for Federal preservation incentives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9f79b6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to maintain national register","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in subparagraph (A) shall be construed to provide that any State Historic Preservation Officer or any other person other than the Secretary shall have the authority to maintain the National Register for properties in any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9f79b7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enter into a contract or cooperative agreement under paragraph (1) only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9f79b8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State Historic Preservation Officer has requested the additional responsibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9f79b9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has approved the State historic preservation program pursuant to sections 302301 and 302302 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9f79ba-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State Historic Preservation Officer agrees to carry out the additional responsibility in a timely and efficient manner acceptable to the Secretary and the Secretary determines that the Officer is fully capable of carrying out the responsibility in that manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9f79bb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State Historic Preservation Officer agrees to permit the Secretary to review and revise, as appropriate in the discretion of the Secretary, decisions made by the Officer pursuant to the contract or cooperative agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9f79bc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary and the State Historic Preservation Officer agree on the terms of additional financial assistance to the State, if there is to be any, for the costs of carrying out that responsibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9f79bd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establish conditions and criteria","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each significant program area under the Secretary’s authority, the Secretary shall establish specific conditions and criteria essential for the assumption by a State Historic Preservation Officer of the Secretary’s duties in each of those programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9f79be-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302304/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preservation programs and activities not diminished","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this chapter shall have the effect of diminishing the preservation programs and activities of the Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9f79bf-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3196"},"text":"128 Stat. 3196","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9f79c0-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9f79c1-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9f79c2-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"