{"tag":"section","attrib":{"id":"idefab60fc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703"},"text":null,"children":[{"tag":"num","attrib":{"value":"308703"},"text":"§ 308703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Maritime Heritage Grants Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefab60fd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established in the Department of the Interior the National Maritime Heritage Grants Program, to foster in the American public a greater awareness and appreciation of the role of maritime endeavors in our Nation’s history and culture. The Program shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab60fe-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual grants to the National Trust for subgrants administered by the National Trust for maritime heritage education projects under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab60ff-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants to State Historic Preservation Officers for maritime heritage preservation projects carried out or administered by those Officers under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab6100-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants for Maritime Heritage Education Projects.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab6101-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants to national trust","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, subject to paragraph (2), and the availability of amounts for that purpose under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s308704/b/1/A"},"text":"section 308704(b)(1)(A) of this title","children":[],"tail":", shall make an annual grant to the National Trust for maritime heritage education projects."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab6102-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of grants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts received by the National Trust as an annual grant under this subsection shall be used to make subgrants to State and local governments and private nonprofit organizations to carry out education projects that have been approved by the Secretary under subsection (f) and that consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefab6103-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assistance to any maritime museum or historical society for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefab6104-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing and new educational programs, exhibits, educational activities, conservation, and interpretation of artifacts and collections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefab6105-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minor improvements to educational and museum facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefab6106-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other similar activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6107-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" activities designed to encourage the preservation of traditional maritime skills, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefab6108-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building and operation of vessels of all sizes and types for educational purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefab6109-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special skills such as wood carving, sail making, and rigging;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefab610a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" traditional maritime art forms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefab610b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sail training;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab610c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other educational activities relating to historic maritime resources, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefab610d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maritime  educational  waterborne-experience programs in historic vessels or vessel reproductions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefab610e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maritime archeological field schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefab610f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational programs on other aspects of maritime history;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6110-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" heritage programs focusing on maritime historic resources, including maritime heritage trails and corridors; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6111-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction and use of reproductions of historic maritime resources for educational purposes, if a historic maritime resource no longer exists or would be damaged or consumed through direct use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab6112-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants for Maritime Heritage Preservation Projects.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab6113-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants to state historic preservation officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, acting through the National Maritime Initiative of the Service and subject to paragraph (2), and the availability of amounts for that purpose under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s308704/b/1/A"},"text":"section 308704(b)(1)(A) of this title","children":[],"tail":", shall make grants to State Historic Preservation Officers for maritime heritage preservation projects."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab6114-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of grants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts received by a State Historic Preservation Officer as a grant under this subsection shall be used by the Officer to carry out, or to make subgrants to local governments and private nonprofit organizations to carry out, projects that have been approved by the Secretary under subsection (f) for the preservation of historic maritime resources through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefab6115-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of historic maritime resources, including underwater archeological sites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6116-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition of historic maritime resources for the purposes of preservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6117-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repair, restoration, stabilization, maintenance, or other capital improvements to historic maritime resources, in accordance with standards prescribed by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6118-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research, recording (through drawings, photographs, or otherwise), planning (through feasibility studies, architectural and engineering services, or otherwise), and other services carried out as part of a preservation program for historic maritime resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab6119-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Direct Grant and Subgrant Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To qualify for a subgrant from the National Trust under subsection (b), or a direct grant to or a subgrant from a State Historic Preservation Officer under subsection (c), a person shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab611a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate that the project for which the direct grant or subgrant will be used has the potential for reaching a broad audience with an effective educational program based on American maritime history, technology, or the role of maritime endeavors in American culture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab611b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" match the amount of the direct grant or subgrant, on a 1-to-1 basis, with non-Federal assets from non-Federal sources, which may include cash or donated services fairly valued as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab611c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maintain records as may be reasonably necessary to fully disclose—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefab611d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and the disposition of the proceeds of the direct grant or subgrant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab611e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost of the project for which the direct grant or subgrant is made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab611f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other records as may be required by the Secretary, including such records as will facilitate an effective accounting for project funds;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab6120-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide access to the Secretary for the purposes of any required audit and examination of any records of the person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab6121-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a unit of State or local government, or a private nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab6122-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures, Terms, and Conditions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab6123-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An application for a subgrant under subsection (b), or a direct grant or subgrant under subsection (c), shall be submitted under procedures prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab6124-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and conditions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person may not receive a subgrant under subsection (b), or a direct grant or subgrant under subsection (c), unless the person agrees to assume, after completion of the project for which the direct grant or subgrant is awarded, the total cost of the continued maintenance, repair, and administration of any property for which the subgrant will be used in a manner satisfactory to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab6125-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation of, and Limitation on, Grant Funding.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab6126-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent feasible, the Secretary shall ensure that the amount made available under subsection (b) for maritime heritage education projects is equal to the amount made available under subsection (c) for maritime heritage preservation projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab6127-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount provided by the Secretary in a fiscal year as grants under this section for projects relating to historic maritime resources owned or operated by the Federal Government shall not exceed 40 percent of the total amount available for the fiscal year for grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab6128-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication of Direct Grant and Subgrant Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall publish annually in the Federal Register and otherwise as the Secretary considers appropriate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab6129-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a solicitation of applications for direct grants and subgrants under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab612a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of priorities for the making of those direct grants and subgrants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab612b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a single deadline for the submission of applications for those direct grants and subgrants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab612c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab612d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Direct Grant and Subgrant Administration.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab612e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibility.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefab612f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National trust","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Trust is responsible for administering subgrants for maritime heritage education projects under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6130-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary is responsible for administering direct grants for maritime heritage preservation projects under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6131-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State historic preservation officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"State Historic Preservation Officers are responsible for administering subgrants for maritime heritage preservation projects under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab6132-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The appropriate responsible party under paragraph (1) shall administer direct grants or subgrants by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefab6133-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publicizing the Program to prospective grantees, subgrantees, and the public at large, in cooperation with the Service, the Maritime Administration, and other appropriate government agencies and private institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6134-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" answering inquiries from the public, including providing information on the Program as requested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6135-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributing direct grant and subgrant applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6136-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receiving direct grant and subgrant applications and ensuring their completeness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6137-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/h/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" keeping records of all direct grant and subgrant awards and expenditures of funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6138-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/h/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring progress of projects carried out with direct grants and subgrants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6139-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/h/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing to the Secretary such progress reports as may be required by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab613a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance of Maritime Preservation Organizations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, the National Trust, and the State Historic Preservation Officers may, individually or jointly, enter into cooperative agreements with any private nonprofit organization with appropriate expertise in maritime preservation issues, or other qualified maritime preservation organizations, to assist in the administration of the Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab613b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to the Committee on Commerce, Science, and Transportation of the Senate, the Committee on Energy and Natural Resources of the Senate, the Committee on Natural Resources of the House of Representatives, the Committee on Armed Services of the House of Representatives, and the Committee on Transportation and Infrastructure of the House of Representatives an annual report on the Program, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab613c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of grant applications submitted and approved under the Program in the period covered by the report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab613d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of each project funded under the Program in the period covered by the report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab613e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results or accomplishments of each such project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab613f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308703/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommended priorities for achieving the policy set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s308701"},"text":"section 308701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefab6140-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3238"},"text":"128 Stat. 3238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3507/b"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3507(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2778"},"text":"130 Stat. 2778","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefab6141-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefab6142-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefab6143-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"308703","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s5403"},"text":"16 U.S.C. 5403","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/103/451/s4"},"text":"Pub. L. 103–451, § 4","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/4770"},"text":"108 Stat. 4770","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5403/j"},"text":"16 U.S.C. 5403(j)","children":[],"tail":" is omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5403/a/3"},"text":"16 U.S.C. 5403(a)(3)","children":[],"tail":" is omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b)(1) and (c)(1), the references are to paragraph (2) to correct errors in the source provisions.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(4), the word “records” is substituted for “books, documents, papers, and records” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5403/f/1"},"text":"16 U.S.C. 5403(f)(1)","children":[],"tail":" is omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g), the text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5403/g/2"},"text":"16 U.S.C. 5403(g)(2)","children":[],"tail":" is omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (h)(2), the text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5403/h/5"},"text":"16 U.S.C. 5403(h)(5)","children":[],"tail":" and (6) is omitted as obsolete."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefab6144-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefab6145-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3507/b"},"text":"Pub. L. 114–328, § 3507(b)","children":[],"tail":", substituted “under section 308704(b)(1)(A)” for “under section 308704(b)(1)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3507/c/1"},"text":"Pub. L. 114–328, § 3507(c)(1)","children":[],"tail":", in introductory provisions, substituted “the Committee on Commerce, Science, and Transportation of the Senate, the Committee on Energy and Natural Resources of the Senate, the Committee on Natural Resources of the House of Representatives, the Committee on Armed Services of the House of Representatives, and the Committee on Transportation and Infrastructure of the House of Representatives” for “Congress”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3507/c/3"},"text":"Pub. L. 114–328, § 3507(c)(3)","children":[],"tail":", added par. (1). Former par. (1) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3507/c/2"},"text":"Pub. L. 114–328, § 3507(c)(2)","children":[],"tail":", (4), redesignated par. (1) as (2) and inserted “detailed” before “description”. Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3507/c/2"},"text":"Pub. L. 114–328, § 3507(c)(2)","children":[],"tail":", redesignated pars. (2) and (3) as (3) and (4), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
