{"tag":"section","attrib":{"id":"idefa43459-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305101"},"text":null,"children":[{"tag":"num","attrib":{"value":"305101"},"text":"§ 305101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa4345a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Administrator” means the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa4345b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible entity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa4345c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305101/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any department or agency of the Federal Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa4345d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305101/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any department or agency of the State in which a historic light station is located, the local government of the community in which a historic light station is located, a nonprofit corporation, an educational agency, or a community development organization that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefa4345e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305101/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has agreed to comply with the conditions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s305104"},"text":"section 305104 of this title","children":[],"tail":" and to have the conditions recorded with the deed of title to the historic light station; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefa4345f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305101/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is financially able to maintain the historic light station in accordance with the conditions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s305104"},"text":"section 305104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa43460-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal aid to navigation.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa43461-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305101/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Federal aid to navigation” means any device, operated and maintained by the United States, external to a vessel or aircraft, intended to assist a navigator to determine position or safe course, or to warn of dangers or obstructions to navigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa43462-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305101/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Federal aid to navigation” includes a light, lens, lantern, antenna, sound signal, camera, sensor, piece of electronic navigation equipment, power source, or other piece of equipment associated with a device described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa43463-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Historic light station","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “historic light station” includes the light tower, lighthouse, keeper’s dwelling, garages, storage sheds, oil house, fog signal building, boat house, barn, pumphouse, tramhouse support structures, piers, walkways, underlying and appurtenant land and related real property and improvements associated with a historic light station that is a historic property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa43464-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3215"},"text":"128 Stat. 3215","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa43465-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa43466-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa43467-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"305101","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470w–7/e"},"text":"16 U.S.C. 470w–7(e)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/665/tIII/s308/e"},"text":"Pub. L. 89–665, title III, § 308(e)","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/106/355/s2"},"text":"Pub. L. 106–355, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 2000","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/114/1388"},"text":"114 Stat. 1388","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s470w–7/e/5"},"text":"16 U.S.C. 470w–7(e)(5)","children":[],"tail":" is omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (3)(A), the words “that is a historic property” are substituted for “provided that the ‘historic light station’ shall be included in or eligible for inclusion in the National Register of Historic Places” because of the definition of “historic property” in section 300308 of the new title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
