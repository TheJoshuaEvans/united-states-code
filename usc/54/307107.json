{"tag":"section","attrib":{"id":"idefa8efec-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307107"},"text":null,"children":[{"tag":"num","attrib":{"value":"307107"},"text":"§ 307107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations and bequests of money, personal property, and less than fee interests in historic property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa8efed-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Money and Personal Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may accept donations and bequests of money and personal property for the purposes of this division and shall hold, use, expend, and administer the money and personal property for those purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8efee-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Less Than Fee Interest in Historic Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may accept gifts or donations of less than fee interests in any historic property where the acceptance of an interest will facilitate the conservation or preservation of the historic property. Nothing in this section or in any provision of this division shall be construed to affect or impair any other authority of the Secretary under other provision of law to accept or acquire any property for conservation or preservation or for any other purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa8efef-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3232"},"text":"128 Stat. 3232","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa8eff0-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa8eff1-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa8eff2-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}]