{"tag":"section","attrib":{"id":"idefadaace-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102"},"text":null,"children":[{"tag":"num","attrib":{"value":"311102"},"text":"§ 311102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefadaacf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Department of the Interior the Preserve America Program, under which the Secretary, in partnership with the Council, may provide competitive grants to States, local governments (including local governments in the process of applying for designation as Preserve America Communities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s311103"},"text":"section 311103 of this title","children":[],"tail":", Indian tribes, communities designated as Preserve America Communities under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s311103"},"text":"section 311103 of this title","children":[],"tail":", State historic preservation offices, and tribal historic preservation offices to support preservation efforts through heritage tourism, education, and historic preservation planning activities."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadaad0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Projects.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadaad1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following projects shall be eligible for a grant under this chapter:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefadaad2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A project for the conduct of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefadaad3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on, and documentation of, the history of a community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefadaad4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surveys of the historic resources of a community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefadaad5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An education and interpretation project that conveys the history of a community or site.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefadaad6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A planning project (other than building rehabilitation) that advances economic development using heritage tourism and historic preservation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefadaad7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A training project that provides opportunities for professional development in areas that would aid a community in using and promoting its historic resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefadaad8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A project to support heritage tourism in a Preserve America Community designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s311103"},"text":"section 311103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefadaad9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other nonconstruction projects that identify or promote historic properties or provide for the education of the public about historic properties that are consistent with the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadaada-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In providing grants under this chapter, the Secretary shall provide only one grant to each eligible project selected for a grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadaadb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preference","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In providing grants under this chapter, the Secretary may give preference to projects that carry out the purposes of both the program and the Save America’s Treasures Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadaadc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation and Notification.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadaadd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall consult with the Council in preparing the list of projects to be provided grants for a fiscal year under the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadaade-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days before the date on which the Secretary provides grants for a fiscal year under the program, the Secretary shall submit to the Committee on Energy and Natural Resources and Committee on Appropriations of the Senate and the Committee on Natural Resources and Committee on Appropriations of the House of Representatives a list of any eligible projects that are to be provided grants under the program for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadaadf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost-Sharing Requirement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadaae0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The non-Federal share of the cost of carrying out a project provided a grant under this chapter shall be not less than 50 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadaae1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form of non-federal share","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The non-Federal share required under paragraph (1) shall be in the form of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefadaae2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cash; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefadaae3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donated supplies and related services, the value of which shall be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadaae4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311102/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that each applicant for a grant has the capacity to secure, and a feasible plan for securing, the non-Federal share for an eligible project required under paragraph (1) before a grant is provided to the eligible project under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefadaae5-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3247"},"text":"128 Stat. 3247","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefadaae6-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefadaae7-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefadaae8-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"311102","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s469n/c"},"text":"16 U.S.C. 469n(c)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/111/11/tVII"},"text":"Pub. L. 111–11, title VII","children":[],"tail":", subtitle D, § 7302(c), "},{"tag":"html:span","attrib":{},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/123/1214"},"text":"123 Stat. 1214","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
