{"tag":"section","attrib":{"id":"idef984d98-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200308"},"text":null,"children":[{"tag":"num","attrib":{"value":"200308"},"text":"§ 200308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for acquisition of land and water","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not more than $30,000,000 of the amount authorized to be appropriated from the Fund by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s200303"},"text":"section 200303 of this title","children":[],"tail":" may be obligated by contract during each fiscal year for the acquisition of land, water, or interest in land or water within areas specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s200306/a/2"},"text":"section 200306(a)(2) of this title","children":[],"tail":". The contract may be executed by the head of the department concerned, within limitations prescribed by the Secretary. The contract shall be a contractual obligation of the United States and shall be liquidated with money appropriated from the Fund specifically for liquidation of that contract obligation. No contract may be entered into for the acquisition of property pursuant to this section unless the acquisition is otherwise authorized by Federal law."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef984d99-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3179"},"text":"128 Stat. 3179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef984d9a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef984d9b-3a70