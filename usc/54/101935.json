{"tag":"section","attrib":{"id":"idef8c6676-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101935"},"text":null,"children":[{"tag":"num","attrib":{"value":"101935"},"text":"§ 101935.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8c6677-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101935/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revolving Fund","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established a revolving fund that shall be available to the Secretary without fiscal year limitation for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8c6678-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101935/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses necessary for the management, improvement, enhancement, operation, construction, and maintenance of commercial visitor services and facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c6679-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101935/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of possessory interest and leasehold surrender interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c667a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101935/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collection of Funds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8c667b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101935/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds collected by the Secretary pursuant to the contracts awarded under this subchapter shall be credited to the revolving fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c667c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101935/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is authorized to transfer to the revolving fund, without reimbursement, any additional funds or revenue in connection with the functions to be carried out under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c667d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101935/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts in the revolving fund shall be used by the Secretary in furtherance of the purposes of this title. No funds from this account may be used to decrease the availability of services and programs to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8c667e-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/tVII/s701"},"text":"Pub. L. 114–289, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1493"},"text":"130 Stat. 1493","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
