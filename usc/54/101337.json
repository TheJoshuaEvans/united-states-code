{"tag":"section","attrib":{"id":"idef853b74-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101337"},"text":null,"children":[{"tag":"num","attrib":{"value":"101337"},"text":"§ 101337.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leasing of seasonal employee quarters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef853b75-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101337/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may lease quarters at or near a System unit for use as seasonal quarters for field employees if the Secretary finds that there is a shortage of adequate and affordable seasonal quarters at or near the System unit and that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef853b76-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101337/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirement for the seasonal field employee quarters is temporary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef853b77-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101337/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leasing would be more cost-effective than construction of new seasonal field employee quarters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef853b78-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101337/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The rent charged to field employees under the lease shall be a rate based on the reasonable value of the quarters in accordance with requirements applicable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5911"},"text":"section 5911 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef853b79-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101337/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unrecovered Costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may pay the unrecovered costs of leasing seasonal quarters under this section from annual appropriations for the year in which the lease is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef853b7a-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3128"},"text":"128 Stat. 3128","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef853b7b-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef853b7c-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef853b7d-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"te