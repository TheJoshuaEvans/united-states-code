{"tag":"section","attrib":{"id":"idef9f7a73-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302907"},"text":null,"children":[{"tag":"num","attrib":{"value":"302907"},"text":"§ 302907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to Indian tribes and Native Hawaiian organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer a program of direct grants to Indian tribes and Native Hawaiian organizations for the purpose of carrying out this division as it pertains to Indian tribes and Native Hawaiian organizations. Matching fund requirements may be modified. Federal funds available to an Indian tribe or Native Hawaiian organization may be used as matching funds for the purposes of the Indian tribe’s or Native Hawaiian organization’s conducting its responsibilities pursuant to this subdivision.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef9f7a74-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3205"},"text":"128 Stat. 3205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9f7a75-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9f7a76-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9f7a77-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children