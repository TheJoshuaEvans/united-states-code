{"tag":"section","attrib":{"id":"idefa8f05e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308302"},"text":null,"children":[{"tag":"num","attrib":{"value":"308302"},"text":"§ 308302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa8f05f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment; Responsibilities of Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish in the Service the National Underground Railroad Network to Freedom. Under the national network, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa8f060-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce and disseminate appropriate educational materials, such as handbooks, maps, interpretive guides, or electronic information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa8f061-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into appropriate cooperative agreements and memoranda of understanding to provide technical assistance under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa8f062-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308302/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create and adopt an official, uniform symbol or device for the national network and issue regulations for its use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f063-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The national network shall encompass the following elements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa8f064-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All System units and programs of the Service determined by the Secretary to pertain to the Underground Railroad.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa8f065-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other Federal, State, local, and privately owned properties pertaining to the Underground Railroad that have a verifiable connection to the Underground Railroad and that are included on, or determined by the Secretary to be eligible for inclusion on, the National Register of Historic Places.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa8f066-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308302/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other governmental and nongovernmental facilities and programs of an educational, research, or interpretive nature that are directly related to the Underground Railroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f067-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative Agreements and Memoranda of Understanding","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To achieve the purposes of this chapter and to ensure effective coordination of the Federal and non-Federal elements of the national network with System units and programs of the Service, the Secretary may enter into cooperative agreements and memoranda of understanding with, and provide technical assistance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa8f068-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the heads of other Federal agencies, States, localities, regional governmental bodies, and private entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa8f069-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with the Secretary of State, to the governments of Canada, Mexico, and any appropriate country in the Caribbean.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa8f06a-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3234"},"text":"128 Stat. 3234","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa8f06b-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa8f06c-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa8f06d-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"308302","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s469"},"text":"16 U.S.C. 469","children":[],"tail":null},{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":"–1."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/105/203/s3"},"text":"Pub. L. 105–203, § 3","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 21, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/679"},"text":"112 Stat. 679","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/110/229/tIII"},"text":"Pub. L. 110–229, title III","children":[],"tail":", subtitle G, § 361(a)(1), "},{"tag":"html:span","attrib":{},"text":"May 8, 2008","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/122/801"},"text":"122 Stat. 801","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “a program to be known as” are omitted as unnecessary. The words “national network” are substituted for “program” because of the definition of “national network” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s308301"},"text":"section 308301 of this title","children":[],"tail":" and for consistency with subsections (b) and (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
