{"tag":"section","attrib":{"id":"idefa434e2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305304"},"text":null,"children":[{"tag":"num","attrib":{"value":"305304"},"text":"§ 305304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa434e3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in consultation with the Board, shall provide preservation technology and training grants to eligible applicants with a demonstrated institutional capability and commitment to the purposes of the Center, in order to ensure an effective and efficient system of research, information distribution, and skills training in all the related historic preservation fields.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa434e4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa434e5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Grants provided under this section shall be allocated in such a fashion as to reflect the diversity of the historic preservation fields and shall be geographically distributed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa434e6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limit on amount a recipient may receive","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No grant recipient may receive more than 10 percent of the grants allocated under this section within any year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa434e7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305304/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limit on administrative costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The total administrative costs, direct and indirect, charged for carrying out grants under this section may not exceed 25 percent of the aggregate costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa434e8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Applicants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Eligible applicants may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa434e9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal and non-Federal laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa434ea-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accredited museums;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa434eb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305304/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" universities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa434ec-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305304/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa434ed-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305304/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" System units and offices and Cooperative Park Study Units of the System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa434ee-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305304/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State Historic Preservation Offices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa434ef-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305304/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal preservation offices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa434f0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305304/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native Hawaiian organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa434f1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards and Methods","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Grants shall be awarded in accordance with accepted professional standards and methods, including peer review of projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa434f2-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3222"},"text":"128 Stat. 3222","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa434f3-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa434f4-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa434f5-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"