{"tag":"section","attrib":{"id":"idef79538b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507"},"text":null,"children":[{"tag":"num","attrib":{"value":"100507"},"text":"§ 100507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional areas for System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef79538c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monitoring Areas for Inclusion in System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall investigate, study, and continually monitor the welfare of areas whose resources exhibit qualities of national significance and that may have potential for inclusion in the System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef79538d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of List of Areas Recommended for Study for Potential Inclusion.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef79538e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When list is to be submitted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the beginning of each calendar year, with the annual budget submission, the Secretary shall submit to the Committee on Natural Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a list of areas recommended for study for potential inclusion in the System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef79538f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors to be considered","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the list to be submitted under this subsection, the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef795390-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the areas that have the greatest potential to meet the established criteria of national significance, suitability, and feasibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef795391-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" themes, sites, and resources not already adequately represented in the System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef795392-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public petitions and Congressional resolutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef795393-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accompanying synopsis","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Accompanying the annual listing of areas shall be a synopsis, for each report previously submitted, of the current and changed condition of the resource integrity of the area and other relevant factors, compiled as a result of continual periodic monitoring and embracing the period since the previous submission or initial report submission one year earlier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef795394-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional authorization required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No study of the potential of an area for inclusion in the System may be initiated except as provided by specific authorization of an Act of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef795395-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to conduct certain activities not limited","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section and sections 100901(b), 101702(b) and (c), and 102102 of this title do not limit the authority of the Service to conduct preliminary resource assessments, gather data on potential study areas, provide technical and planning assistance, prepare or process nominations for administrative designations, update previous studies, or complete reconnaissance surveys of individual areas requiring a total expenditure of less than $25,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef795396-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study of rivers or trails not affected","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply to or affect or alter the study of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef795397-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any river segment for potential addition to the national wild and scenic rivers system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef795398-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any trail for potential addition to the national trails system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef795399-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study of Areas for Potential Inclusion.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef79539a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study to be completed within 3 years","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall complete the study for each area for potential inclusion in the System within 3 complete fiscal years following the date on which funds are first made available for that purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef79539b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Opportunity for public involvement required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each study under this section shall be prepared with appropriate opportunity for public involvement, including at least one public meeting in the vicinity of the area under study, and after reasonable efforts to notify potentially affected landowners and State and local governments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef79539c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the study, the Secretary shall consider whether the area under study—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef79539d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possesses nationally significant natural or cultural resources and represents one of the most important examples of a particular resource type in the country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef79539e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a suitable and feasible addition to the System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef79539f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of study","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each study—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7953a0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with regard to the area being studied, shall consider—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef7953a1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rarity and integrity of the resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef7953a2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the threats to those resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef7953a3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether similar resources are already protected in the System or in other public or private ownership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef7953a4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public use potential;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef7953a5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/4/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interpretive and educational potential;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef7953a6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/4/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs associated with acquisition, development, and operation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef7953a7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/4/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the socioeconomic impacts of any designation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef7953a8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/4/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of local and general public support; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef7953a9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/4/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the area is of appropriate configuration to ensure long-term resource protection and visitor use;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7953aa-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consider whether direct Service management or alternative protection by other public agencies or the private sector is appropriate for the area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7953ab-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall identify what alternative or combination of alternatives would in the professional judgment of the Director be most effective and efficient in protecting significant resources and providing for public enjoyment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7953ac-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include any other information that the Secretary considers to be relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7953ad-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance with national environmental policy act of 1969","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each study shall be completed in compliance with the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7953ae-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendation of preferred management option","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The letter transmitting each completed study to Congress shall contain a recommendation regarding the Secretary’s preferred management option for the area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7953af-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"List of Areas Previously Studied.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7953b0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of list","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the beginning of each calendar year, with the annual budget submission, the Secretary shall submit to the Committee on Natural Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate, in numerical order of priority for addition to the System—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7953b1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of areas that have been previously studied that contain primarily historical resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7953b2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of areas that have been previously studied that contain primarily natural resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7953b3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing the lists, the Secretary should consider threats to resource values, cost escalation factors, and other factors listed in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7953b4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Areas eligible for inclusion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary should include on the lists only areas for which the supporting data are current and accurate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7953b5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"List of Areas That Exhibit Danger or Threats to the Integrity of Their Resources","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the beginning of each fiscal year, the Secretary shall submit to the Speaker of the House of Representatives and the President of the Senate a complete and current list of all areas listed on the Registry of Natural Landmarks, and areas of national significance listed on the National Register of Historic places, that exhibit known or anticipated damage or threats to the integrity of their resources, with notations as to the nature and severity of the damage or threats.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7953b6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports and Listings Printed as House Documents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report and annual listing described in this section shall be printed as a House document. If adequate supplies of previously printed identical reports remain available, newly submitted identical reports shall be omitted from printing on receipt by the Speaker of the House of Representatives of a joint letter from the chairman of the Committee on Natural Resources of the House of Representatives and the chairman of the Committee on Energy and Natural Resources of Senate indicating that to be the case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7953b7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Office","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall designate a single office to prepare all new area studies and to implement other functions under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7953b8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7953b9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Studies of potential new system units and monitoring the welfare of system unit resources","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To carry out studies for potential new System units and for monitoring the welfare of historical and natural resources referred to in subparagraphs (A) and (B) of subsection (d)(1), there is authorized to be appropriated not more than $1,000,000 for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7953ba-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monitoring welfare and integrity of national landmarks","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To monitor the welfare and integrity of the national landmarks, there is authorized to be appropriated not more than $1,500,000 for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7953bb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100507/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Carrying out subsections","children":[],"tail":" (b), (c), and "},{"tag":"ref","attrib":{"idref":"fn002002"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002002"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “"},{"tag":"inline","attrib":{},"text":"and","children":[],"tail":"”."}],"tail":" (g).—"}],"tail":null},{"tag":"content","attrib":{},"text":"To carry out subsections (b), (c), and (g), there is authorized to be appropriated $2,000,000 for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7953bc-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attr