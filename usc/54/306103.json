{"tag":"section","attrib":{"id":"idefa6a54a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306103"},"text":null,"children":[{"tag":"num","attrib":{"value":"306103"},"text":"§ 306103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordation of historic property prior to alteration or demolition","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each Federal agency shall initiate measures to ensure that where, as a result of Federal action or assistance carried out by the agency, a historic property is to be substantially altered or demolished—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa6a54b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" timely steps are taken to make or have made appropriate records; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa6a54c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the records are deposited, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302107"},"text":"section 302107 of this title","children":[],"tail":", in the Library of Congress or with such other appropriate agency as the Secretary may designate, for future use and reference."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa6a54d-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3226"},"text":"128 Stat. 3226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes