{"tag":"section","attrib":{"id":"idef8eb188-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103102"},"text":null,"children":[{"tag":"num","attrib":{"value":"103102"},"text":"§ 103102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations authorized and available for certain purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Appropriations for the Service are authorized and are available for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8eb189-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administration, protection, improvement, and maintenance of areas, under the jurisdiction of other Federal agencies, that are devoted to recreational use pursuant to cooperative agreements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb18a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary local transportation and subsistence in kind of individuals selected for employment or as cooperators, serving without other compensation, while attending fire protection training camps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb18b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administration, protection, maintenance, and improvement of the Chesapeake and Ohio Canal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb18c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational lectures in or in the vicinity of and with respect to System units, and services of field employees in cooperation with such nonprofit scientific and historical societies engaged in educational work in System units as the Secretary may designate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb18d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" travel expenses of employees attending—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8eb18e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103102/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal Government camps for training in forest fire prevention and suppression;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8eb18f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103102/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Bureau of Investigation National Police Academy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8eb190-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103102/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, or municipal schools for training in building fire prevention and suppression;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb191-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103102/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigation and establishment of water rights in accordance with local custom, laws, and decisions of courts, including the acquisition of water rights or of land or interests in land or rights-of-way for use and protection of water rights necessary or beneficial in the administration and public use of System units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb192-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103102/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" official telephone service in the field in the case of official telephones installed in private houses when authorized under regulations established by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb193-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103102/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of transportation for children in nearby communities to and from any System unit used in connection with organized recreation and interpretive programs of the Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8eb194-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3164"},"text":"128 Stat. 3164","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8eb195-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id"