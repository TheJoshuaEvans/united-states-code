il":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470w–7/b"},"text":"16 U.S.C. 470w–7(b)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/665/tIII/s308/b"},"text":"Pub. L. 89–665, title III, § 308(b)","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/106/355/s2"},"text":"Pub. L. 106–355, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 2000","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/114/1385"},"text":"114 Stat. 1385","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/106/400/s2"},"text":"Pub. L. 106–400, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/114/1675"},"text":"114 Stat. 1675","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa43484-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefa43485-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The McKinney-Vento Homeless Assistance Act, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77"},"text":"Pub. L. 100–77","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/482"},"text":"101 Stat. 482","children":[],"tail":", which is classified principally to chapter 119 (§ 11301 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11301"},"text":"section 11301 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 416(d) of the Coast Guard Authorization Act of 1998, referred to in subsec. (c)(1), which was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s93"},"text":"section 93 of Title 14","children":[],"tail":", Coast Guard, was transferred and is now set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s504"},"text":"section 504 of Title 14","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
