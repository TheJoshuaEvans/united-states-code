{"tag":"section","attrib":{"id":"idef7e0e83-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100803"},"text":null,"children":[{"tag":"num","attrib":{"value":"100803"},"text":"§ 100803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpretation and education evaluation and quality improvement","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may undertake a program of regular evaluation of interpretation and education programs to ensure that they—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7e0e84-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100803/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjust to how people learn and engage with the natural world and shared heritage as embodied in the System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0e85-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100803/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect different cultural backgrounds, ages, education, gender, abilities, ethnicity, and needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0e86-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100803/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate innovative approaches to management and appropriately incorporate emerging learning and communications technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0e87-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100803/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect current scientific and academic research, content, methods, and audience analysis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7e0e88-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/tIII/s301/a"},"text":"Pub. L. 114–289, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1487"},"text":"130 Stat. 1487","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
