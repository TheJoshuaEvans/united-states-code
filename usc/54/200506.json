{"tag":"section","attrib":{"id":"idef9a975d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200506"},"text":null,"children":[{"tag":"num","attrib":{"value":"200506"},"text":"§ 200506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share of project costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9a975e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9a975f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allowable sources","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The non-Federal share of project costs assisted under this chapter may be derived from general or special purpose State or local revenues, State categorical grants, special appropriations by State legislatures, donations of land, buildings, or building materials, and in-kind construction, technical, and planning services. Reasonable local costs of recovery action program development to meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s200504/a"},"text":"section 200504(a) of this title","children":[],"tail":" may be used as part of the local match only when the local government has not received a recovery action program grant."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9a9760-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-allowable sources","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No amount from the Land and Water Conservation Fund or from any other Federal grant program other than the community development block grant programs shall be used to match Federal grants under this program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9a9761-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Encouragement of States and Private Interests","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall encourage States and private interests to contribute, to the maximum extent possible, to the non-Federal share of project costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9a9762-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3185"},"text":"128 Stat. 3185","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9a9763-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9a9764-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9a9765-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"200506","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s2508"},"text":"16 U.S.C. 2508","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/625/tX/s1009"},"text":"Pub. L. 95–625, title X, § 1009","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/3543"},"text":"92 Stat. 3543","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “recovery” is added after “Reasonable local costs of”, and the words “a recovery action program grant” are substituted for “program development grants”, for clarity. See 36 CFR 72.32(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
