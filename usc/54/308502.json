{"tag":"section","attrib":{"id":"idefab60b9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308502"},"text":null,"children":[{"tag":"num","attrib":{"value":"308502"},"text":"§ 308502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National women’s rights history project partnerships network","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefab60ba-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make matching grants and give technical assistance for development of a network of governmental and nongovernmental entities (referred to in this section as the “network”), the purpose of which is to provide interpretive and educational program development of national women’s rights history, including historic preservation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab60bb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management of Network.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab60bc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Through a competitive process, the Secretary shall designate a nongovernmental managing entity to manage the network.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab60bd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The nongovernmental managing entity designated under paragraph (1) shall work in partnership with the Director and State historic preservation offices to coordinate operation of the network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab60be-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost-Sharing Requirement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab60bf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of any activity carried out using any assistance made available under this section shall be 50 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab60c0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State historic preservation offices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Matching grants for historic preservation specific to the network may be made available through State historic preservation offices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab60c1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $1,000,000 for each of fiscal years 2012 and 2013.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefab60c2-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3236"},"text":"128 Stat. 3236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefab60c3-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefab60c4-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefab60c5-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"308502","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s469m/c"},"text":"16 U.S.C. 469m(c)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/111/11/tVII"},"text":"Pub. L. 111–11, title VII","children":[],"tail":", subtitle B, § 7111(c), "},{"tag":"html:span","attrib":{},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/123/1200"},"text":"123 Stat. 1200","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “nongovernmental managing entity” are substituted for “nongovernmental managing network” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), reference to fiscal years 2009 to 2011 is omitted as obsolete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
