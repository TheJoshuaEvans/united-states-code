{"tag":"section","attrib":{"id":"idefab60d5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308603"},"text":null,"children":[{"tag":"num","attrib":{"value":"308603"},"text":"§ 308603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefab60d6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make grants to other Federal agencies, State, local, and Tribal governments, other public entities, educational institutions, historic preservation groups, and private nonprofit organizations in accordance with this chapter for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab60d7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308603/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of historic African-American burial grounds that may qualify for the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab60d8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308603/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preservation and restoration of African-American burial grounds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab60d9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308603/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interpretation of African-American burial grounds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab60da-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308603/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related research and documentation for historic African-American burial grounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab60db-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab60dc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308603/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $3,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab60dd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308603/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amounts made available for a fiscal year under paragraph (1) that are not used during that fiscal year shall be available for use under this section during any subsequent fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefab60de-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tVI/s643/a"},"text":"Pub. L. 117–328, div. DD, title VI, § 643(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5613"},"text":"136 Stat. 5613","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
