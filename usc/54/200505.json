{"tag":"section","attrib":{"id":"idef9a9754-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200505"},"text":null,"children":[{"tag":"num","attrib":{"value":"200505"},"text":"§ 200505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9a9755-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Match","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may increase rehabilitation grants or innovation grants authorized in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s200503"},"text":"section 200503 of this title","children":[],"tail":" by providing an additional match equal to the total match provided by a State of up to 15 percent of total project costs. The Federal matching amount shall not exceed 85 percent of total project cost."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9a9756-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adequate Implementation of Local Recovery Plans","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall encourage States to assist the Secretary in ensuring—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9a9757-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that local recovery plans and programs are adequately implemented by cooperating with the Secretary in monitoring local park and recreation recovery plans and programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9a9758-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistency of the plans and programs, where appropriate, with State recreation policies as set forth in statewide comprehensive outdoor recreation plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9a9759-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3185"},"text":"128 Stat. 3185","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9a975a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9a975b-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9a975c-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"t