{"tag":"section","attrib":{"id":"idef76e360-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100505"},"text":null,"children":[{"tag":"num","attrib":{"value":"100505"},"text":"§ 100505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic review of System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef76e361-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Secretary To Conduct Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall conduct a systematic and comprehensive review of certain aspects of the System and on a periodic basis (but not less often than every 3 years) submit to the Committee on Natural Resources and the Committee on Appropriations of the House of Representatives and the Committee on Energy and Natural Resources and the Committee on Appropriations of the Senate a report on the findings of the review, together with recommendations as the Secretary determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef76e362-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In conducting and preparing the report, the Secretary shall consult with appropriate officials of affected Federal, State, and local agencies and national, regional, and local organizations. The consultation shall include holding public hearings that the Secretary determines to be appropriate to provide a full opportunity for public comment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef76e363-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall contain the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef76e364-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100505/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A comprehensive listing of all authorized but unacquired parcels of land within the exterior boundaries of each System unit as of ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef795365-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100505/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A priority listing of all those unacquired parcels by System unit and for the System as a whole. The list shall describe the acreage and ownership of each parcel, the estimated cost of acquisition for each parcel (subject to any statutory acquisition limitations for the land), and the basis for the estimate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef795366-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100505/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An analysis and evaluation of the current and future needs of each System unit for resource management, interpretation, construction, operation and maintenance, personnel, and housing, together with an estimate of the costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef795367-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3099"},"text":"128 Stat. 3099","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef795368-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef795369-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef79536a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag