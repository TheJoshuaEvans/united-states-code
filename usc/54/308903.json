{"tag":"section","attrib":{"id":"idefadaa8a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903"},"text":null,"children":[{"tag":"num","attrib":{"value":"308903"},"text":"§ 308903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefadaa8b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the amounts made available for grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s308905"},"text":"section 308905 of this title","children":[],"tail":", not less than 50 percent shall be made available for grants for projects to preserve collections and historic property, to be distributed through a competitive grant process administered by the Secretary, subject to the selection criteria established under subsection (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadaa8c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application for Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be considered for a grant under the program an eligible entity shall submit to the Secretary an application containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadaa8d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collections and Historic Property Eligible for Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadaa8e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A collection or historic property shall be provided a grant under the program only if the Secretary determines that the collection or historic property is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefadaa8f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nationally significant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefadaa90-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" threatened or endangered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadaa91-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible collections","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A determination by the Secretary regarding the national significance of a collection under paragraph (1)(A) shall be made in consultation with the organizations described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s308902/b"},"text":"section 308902(b) of this title","children":[],"tail":", as appropriate."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadaa92-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible historic property","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a grant under the program, a historic property shall, as of the date of the grant application—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefadaa93-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be listed on the National Register of Historic Places at the national level of significance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefadaa94-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be designated as a National Historic Landmark.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadaa95-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection Criteria.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadaa96-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not provide a grant under this chapter to a project for a collection or historic property unless the project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefadaa97-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminates or substantially mitigates the threat of destruction or deterioration of the collection or historic property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefadaa98-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a clear public benefit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefadaa99-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is able to be completed on schedule and within the budget described in the grant application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadaa9a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preference","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In providing grants under this chapter, the Secretary may give preference to projects that carry out the purposes of both the program and the Preserve America Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadaa9b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In providing grants under this chapter, the Secretary shall provide only one grant to each project selected for a grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadaa9c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation and Notification by Secretary.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadaa9d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefadaa9e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subparagraph (B), the Secretary shall consult with the organizations described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s308902/b"},"text":"section 308902(b) of this title","children":[],"tail":" in preparing the list of projects to be provided grants for a fiscal year under the program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefadaa9f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s308902/b"},"text":"section 308902(b) of this title","children":[],"tail":" has submitted an application for a grant under the program, the organization shall be recused by the Secretary from the consultation requirements under subparagraph (A) and "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s308902/b"},"text":"section 308902(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadaaa0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days before the date on which the Secretary provides grants for a fiscal year under the program, the Secretary shall submit to the Committee on Energy and Natural Resources and Committee on Appropriations of the Senate and the Committee on Natural Resources and Committee on Appropriations of the House of Representatives a list of any eligible projects that are to be provided grants under the program for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadaaa1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost-Sharing Requirement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadaaa2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The non-Federal share of the cost of carrying out a project provided a grant under this chapter shall be not less than 50 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadaaa3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form of non-federal share","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The non-Federal share required under paragraph (1) shall be in the form of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefadaaa4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cash; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefadaaa5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donated supplies or related services, the value of which shall be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadaaa6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308903/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that each applicant for a grant has the capacity and a feasible plan for securing the non-Federal share for an eligible project required under paragraph (1) before a grant is provided to the eligible project under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefadaaa7-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3244"},"text":"128 Stat. 3244","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefadaaa8-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefadaaa9-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefadaaaa-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"308903","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s469"},"text":"16 U.S.C. 469","children":[],"tail":null},{"tag":"html:i","attrib":{},"text":"o","children":[],"tail":"(c)(2) through (7)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/111/11/tVII"},"text":"Pub. L. 111–11, title VII","children":[],"tail":", subtitle D, § 7303(c)(2) through (7), "},{"tag":"html:span","attrib":{},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/123/1217"},"text":"123 Stat. 1217","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (c), the word “competitive” is omitted for consistency in the chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(1)(A), the words “by the Secretary” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(1)(B), the word “organization” is substituted for “entity” for consistency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
