{"tag":"section","attrib":{"id":"idef82c9b9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101120"},"text":null,"children":[{"tag":"num","attrib":{"value":"101120"},"text":"§ 101120.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of local fundraising support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef82c9ba-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101120/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Park Foundation shall design and implement a comprehensive program to assist and promote philanthropic programs of support at the individual System unit level.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef82c9bb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101120/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program under subsection (a) shall be implemented to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef82c9bc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101120/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the creation of local nonprofit support organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef82c9bd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101120/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide support, national consistency, and management-improving suggestions for local nonprofit support organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef82c9be-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101120/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef82c9bf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101120/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include the greatest number of System units as is practicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef82c9c0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101120/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at a minimum shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef82c9c1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101120/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a standard adaptable organizational design format to establish and sustain responsible management of a local nonprofit support organization for support of a System unit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef82c9c2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101120/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standard and legally tenable bylaws and recommended money-handling procedures that can easily be adapted as applied to individual System units; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef82c9c3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101120/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a standard training curriculum to orient and expand the operating expertise of personnel employed by local nonprofit support organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef82c9c4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101120/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Park Foundation shall report the progress of the program under subsection (a) in the annual report of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef82c9c5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101120/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affiliations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef82c9c6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101120/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Charter or corporate bylaws","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section requires—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef82c9c7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101120/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit support organization or friends group to modify current practices or to affiliate with the National Park Foundation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef82c9c8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101120/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local nonprofit support organization, established as a result of this section, to be bound through its charter or corporate bylaws to be permanently affiliated with the National Park Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef82c9c9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101120/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An affiliation with the National Park Foundation shall be established only at the discretion of the governing board of a nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef82c9ca-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3122"},"text":"128 Stat. 3122","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef82c9cb-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef82c9cc-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef82c9cd-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"