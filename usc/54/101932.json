{"tag":"section","attrib":{"id":"idef8c666e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101932"},"text":null,"children":[{"tag":"num","attrib":{"value":"101932"},"text":"§ 101932.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award of commercial services contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8c666f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101932/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Competitive Selection Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (c), commercial services contracts shall be awarded by the Secretary through a competitive selection process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c6670-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101932/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Solicitation of Proposals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before awarding a new commercial services contract, the Secretary shall publicly solicit proposals for the contract, except as provided in subsection (c). In connection with such solicitation, the Secretary shall prepare a request for proposals and shall publish notice of its availability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8c6671-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/tVII/s701"},"text":"Pub. L. 114–289, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1493"},"text":"130 Stat. 1493","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
