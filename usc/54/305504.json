span","attrib":{},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/3003"},"text":"94 Stat. 3003","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “grant” is substituted for “grants-in-aid” for clarity and consistency in the revised division. See page 48 of H. Rept. 96–1457 (96th Cong., 2d Sess., 1980).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
