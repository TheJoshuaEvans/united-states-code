{"tag":"section","attrib":{"id":"idef984dff-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501"},"text":null,"children":[{"tag":"num","attrib":{"value":"200501"},"text":"§ 200501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef984e00-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"At-risk youth recreation grant.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef984e01-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “at-risk youth recreation grant” means a grant in a neighborhood or community with a high prevalence of crime, particularly violent crime or crime committed by youthful offenders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984e02-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “at-risk youth recreation grant” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef984e03-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rehabilitation grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef984e04-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an innovation grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef984e05-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a matching grant for continuing program support for a program of demonstrated value or success in providing constructive alternatives to youth at risk for engaging in criminal behavior, including a grant for operating, or coordinating, a recreation program or service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984e06-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional uses of rehabilitation grant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to the purposes specified in paragraph (8), a rehabilitation grant that serves as an at-risk youth recreation grant may be used for the provision of lighting, emergency phones, or any other capital improvement that will improve the security of an urban park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984e07-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General purpose local government","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “general purpose local government” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef984e08-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a city, county, town, township, village, or other general purpose political subdivision of a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984e09-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984e0a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Innovation grant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “innovation grant” means a matching grant to a local government to cover costs of personnel, facilities, equipment, supplies, or services designed to demonstrate innovative and cost-effective ways to augment park and recreation opportunities at the neighborhood level and to address common problems related to facility operations and improved delivery of recreation service, not including routine operation and maintenance activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984e0b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “maintenance” means all commonly accepted practices necessary to keep recreation areas and facilities operating in a state of good repair and to protect them from deterioration resulting from normal wear and tear.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984e0c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Private, nonprofit agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “private, nonprofit agency” means a community-based, nonprofit organization, corporation, or association organized for purposes of providing recreational, conservation, and educational services directly to urban residents on a neighborhood or communitywide basis through voluntary donations, voluntary labor, or public or private grants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984e0d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recovery action program grant.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef984e0e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “recovery action program grant” means a matching grant to a local government for development of local park and recreation recovery action programs to meet the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984e0f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recovery action program grant shall be used for resource and needs assessment, coordination, citizen involvement and planning, and program development activities to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef984e10-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage public definition of goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef984e11-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop priorities and strategies for overall recreation system recovery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984e12-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recreation area or facility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “recreation area or facility” means an indoor or outdoor park, building, site, or other facility that is dedicated to recreation purposes and administered by a public or private nonprofit agency to serve the recreation needs of community residents. Emphasis shall be on public facilities readily accessible to residential neighborhoods, including multiple-use community centers that have recreation as one of their primary purposes, but excluding major sports arenas, exhibition areas, and conference halls used primarily for commercial sports, spectator, or display activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984e13-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rehabilitation grant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “rehabilitation grant” means a matching capital grant to a local government for rebuilding, remodeling, expanding, or developing an existing outdoor or indoor recreation area or facility, including improvements in park landscapes, buildings, and support facilities, but excluding routine maintenance and upkeep activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984e14-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special purpose local government.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef984e15-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “special purpose local government” means a local or regional special district, public-purpose corporation, or other limited political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984e16-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “special purpose local government” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef984e17-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a park authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef984e18-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a park, conservation, water, or sanitary district; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef984e19-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/9/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a school district.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984e1a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200501/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” means a State, an instrumentality of a State approved by the Governor of the State, Puerto Rico, Guam, American Samoa, the Virgin Islands, and the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef984e1b-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3180"},"text":"128 Stat. 3180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef984e1c-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef984e1d-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef984e1e-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"200501","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s2503"},"text":"16 U.S.C. 2503","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/625/tX/s1004"},"text":"Pub. L. 95–625, title X, § 1004","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/3539"},"text":"92 Stat. 3539","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/322/tIII/s31502"},"text":"Pub. L. 103–322, title III, § 31502","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/1888"},"text":"108 Stat. 1888","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1)(C), the words “that serves as an at-risk youth recreation grant” are substituted for “referred to in paragraph (1) of this subsection” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (2), the word “parish” is omitted because of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s2"},"text":"1 U.S.C. 2","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef984e1f-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef984e20-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Statement of Purpose; Complementary Program Authorization; Terms and Conditions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/tX/s1003"},"text":"Pub. L. 95–625, title X, § 1003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3539"},"text":"92 Stat. 3539","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII"},"text":"Pub. L. 103–322, title III","children":[],"tail":", §§ 31501, 31505(b), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1888"},"text":"108 Stat. 1888","children":[],"tail":", 1890, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/322/tIII"},"text":"“The purpose of this title [now ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s200501"},"text":"54 U.S.C. 200501","children":[],"tail":" et seq.] is to authorize the Secretary [of the Interior] to establish an urban park and recreation recovery program which would provide Federal grants to economically hard-pressed communities specifically for the rehabilitation of critically needed recreation areas, facilities, and development of improved recreation programs. This program is intended to complement existing Federal programs such as the Land and Water Conservation Fund and Community Development Grant Programs by encouraging and stimulating local governments to revitalize their park and recreation systems and to make long-term commitments to continuing maintenance of these systems. Such assistance shall be subject to such terms and conditions as the Secretary considers appropriate and in the public interest to carry out the purposes of this title. It is further the purpose of this title to improve recreation facilities and expand recreation services in urban areas with a high incidence of crime and to help deter crime through the expansion of recreation opportunities for at-risk youth. It is the further purpose of this section [probably means title] to increase the security of urban parks and to promote collaboration between local agencies involved in parks and recreation, law enforcement, youth social services, and juvenile justice system.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
