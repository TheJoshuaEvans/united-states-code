{"tag":"section","attrib":{"id":"idef7e0ed6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904"},"text":null,"children":[{"tag":"num","attrib":{"value":"100904"},"text":"§ 100904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admission and special recreation use fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7e0ed7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"System Units at Which Entrance Fees or Admissions Fees Cannot Be Collected.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7e0ed8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withholding of amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 107 of the Department of the Interior and Related Agencies Appropriations Act, 1998 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/83"},"text":"Public Law 105–83","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1561"},"text":"111 Stat. 1561","children":[],"tail":"), the Secretary shall withhold from the special account under section 807(a) of the Federal Lands Recreation Enhancement Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6806/a"},"text":"16 U.S.C. 6806(a)","children":[],"tail":") 100 percent of the fees and charges collected in connection with any System unit at which entrance fees or admission fees cannot be collected by reason of deed restrictions."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0ed9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts withheld under paragraph (1) shall be retained by the Secretary and shall be available, without further appropriation, for expenditure by the Secretary for the System unit with respect to which the amounts were collected for the purposes of enhancing the quality of the visitor experience, protection of resources, repair and maintenance, interpretation, signage, habitat or facility enhancement, resource preservation, annual operation (including fee collection), maintenance, and law enforcement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7e0eda-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation of Funds to System Units.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7e0edb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation of funds on basis of need","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Ten percent of the funds made available to the Director under subsection (a) in each fiscal year shall be allocated among System units on the basis of need in a manner to be determined by the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0edc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation of funds based on expenses and based on fees collected.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7e0edd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Forty percent of the funds made available to the Director under subsection (a) in each fiscal year shall be allocated among System units in accordance with subparagraph (B) of this subsection and 50 percent shall be allocated in accordance with subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7e0ede-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation based on expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount allocated to each System unit under this paragraph for each fiscal year based on expenses shall be a fraction of the total allocation to all System units under this paragraph. The fraction for each System unit shall be determined by dividing the operating expenses at that System unit during the prior fiscal year by the total operating expenses at all System units during the prior fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7e0edf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation based on fees collected","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount allocated to each System unit under this paragraph for each fiscal year based on fees collected shall be a fraction of the total allocation to all System units under this paragraph. The fraction for each System unit shall be determined by dividing the user fees and admission fees collected under this section at that System unit during the prior fiscal year by the total of user fees and admission fees collected under this section at all System units during the prior fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0ee0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts allocated under this subsection to any System unit for any fiscal year and not expended in that fiscal year shall remain available for expenditure at that System unit until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7e0ee1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selling of Permits.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7e0ee2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to sell permits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"When authorized by the Secretary, volunteers at System units may sell permits and collect fees authorized or established pursuant to this section. The Secretary shall ensure that the volunteers have adequate training regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7e0ee3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of permits and the collection of fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7e0ee4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes and resources of the System units in which they are assigned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7e0ee5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of assistance and information to visitors to the System unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0ee6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Surety bond required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require a surety bond for any such volunteer performing services under this subsection. Funds available to the Service may be used to cover the cost of the surety bond. The Secretary may enter into arrangements with qualified public or private entities pursuant to which the entities may sell (without cost to the United States) annual admission permits (including Golden Eagle Passports) at any appropriate location. The arrangements shall require each such entity to reimburse the United States for the full amount to be received from the sale of the permits at or before the Secretary delivers the permits to the entity for sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef807fe7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Charge for Transportation Provided by Service for Viewing System Units.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef807fe8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Charge when transportation provided","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Where the Service provides transportation to view all or a portion of any System unit, the Director may impose a charge for the service in lieu of an admission fee under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef807fe9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention of charge and use of retained amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, half of the charges imposed under paragraph (1) shall be retained by the System unit at which the service was provided. The remainder shall be deposited in the same manner as receipts from fees collected pursuant to this section. Fifty percent of the amount retained shall be expended only for maintenance of transportation systems at the System unit where the charge was imposed. The remaining 50 percent of the retained amount shall be expended only for activities related to resource protection at those System units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef807fea-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Admission Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Where the primary public access to a System unit is provided by a concessioner, the Secretary may charge an admission fee at the System unit only to the extent that the total of the fee charged by the concessioner for access to the System unit and the admission fee does not exceed the maximum amount of the admission fee that could otherwise be imposed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef807feb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commercial Tour Use Fees.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef807fec-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of each System unit for which an admission fee is charged under this section, the Secretary shall establish a commercial tour use fee to be imposed on each vehicle entering the System unit for the purpose of providing commercial tour services within the System unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef807fed-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish the amount of fee per entry as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef807fee-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Twenty-five dollars per vehicle with a passenger capacity of 25 individuals or less.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef807fef-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fifty dollars per vehicle with a passenger capacity of more than 25 individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef807ff0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may periodically make reasonable adjustments to the commercial tour use fee imposed under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef807ff1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The commercial tour use fee imposed under this subsection shall not apply to the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef807ff2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vehicle transporting organized school groups or outings conducted for educational purposes by schools or other bona fide educational institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef807ff3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vehicle entering a System unit pursuant to a contract issued under subchapter II of chapter 1019 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef807ff4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall apply to aircraft entering the airspace of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef807ff5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Haleakala̅ Crater, Crater Cabins, the Scientific Research Reserve, Halemauu Trail, Kaupo Gap Trail, or any designated tourist viewpoint in Haleakala̅ National Park or of Grand Canyon National Park; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef807ff6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100904/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other System unit for the specific purpose of providing commercial tour services if the Secretary determines that the level of the services is equal to or greater than the level at the System units specified in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef807ff7-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3115"},"text":"128 Stat. 3115","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"typ