{"tag":"section","attrib":{"id":"idef936b90-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200102"},"text":null,"children":[{"tag":"num","attrib":{"value":"200102"},"text":"§ 200102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef936b91-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Council","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Council” means the Federal Interagency Council on Outdoor Recreation established under section 200104.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936b92-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal land and water management agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Federal land and water management agency” means the National Park Service, Bureau of Land Management, United States Fish and Wildlife Service, Bureau of Indian Affairs, Bureau of Reclamation, Forest Service, Corps of Engineers, and the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936b93-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal recreational lands and waters","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Federal recreational lands and waters” has the meaning given the term in section 802 of the Federal Lands Recreation Enhancement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6801"},"text":"16 U.S.C. 6801","children":[],"tail":") and also includes Federal lands and waters managed by the Bureau of Indian Affairs, Corps of Engineers, or National Oceanic and Atmospheric Administration."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936b94-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State”, to the extent practicable, as determined by the Secretary, includes Puerto Rico, Guam, American Samoa, the Virgin Islands, and the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936b95-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United States","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “United States”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef936b96-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200102/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936b97-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200102/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, as determined by the Secretary, includes Puerto Rico, Guam, American Samoa, the Virgin Islands, and the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef936b98-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3169"},"text":"128 Stat. 3169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s113/a"},"text":"Pub. L. 118–234, title I, § 113(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2839"},"text":"138 Stat. 2839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef936b99-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef936b9a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef936b9b-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":nu