{"tag":"section","attrib":{"id":"idef853b21-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101305"},"text":null,"children":[{"tag":"num","attrib":{"value":"101305"},"text":"§ 101305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses of System employees and dependents of deceased employees","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In the administration of the System, the Secretary may, under regulations the Secretary may prescribe, pay the travel expenses (including the costs of packing, crating, and transporting (including draying) personal property) of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef853b22-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101305/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees, on permanent change of station of the employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef853b23-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101305/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" dependents of deceased employees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef853b24-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101305/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the nearest housing reasonably available that is of a standard not less than that which is vacated, including compensation for not to exceed 60 days rental cost, in the case of an employee who occupied Federal Government housing and whose death requires the housing to be promptly vacated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef853b25-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101305/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the nearest port of entry in the conterminous 48 States in the case of an employee whose last permanent station was outside the conterminous 48 States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef853b26-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3125"},"text":"128 Stat. 3125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef853b27-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef853b28-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef853b29-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":