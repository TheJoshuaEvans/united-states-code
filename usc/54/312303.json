{"tag":"section","attrib":{"id":"idefadab4e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312303"},"text":null,"children":[{"tag":"num","attrib":{"value":"312303"},"text":"§ 312303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefadab4f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established a commission to be known as the Commission for the Preservation of America’s Heritage Abroad.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadab50-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall consist of 21 members appointed by the President, 7 of whom shall be appointed after consultation with the Speaker of the House of Representatives and 7 of whom shall be appointed after consultation with the President pro tempore of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadab51-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadab52-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), a member of the Commission shall be appointed for a term of 3 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab53-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member appointed to fill a vacancy on the Commission shall serve for the remainder of the term for which the member’s predecessor was appointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab54-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312303/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Member until successor appointed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member may retain membership on the Commission until the member’s successor has been appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadab55-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall designate the Chairman of the Commission from among its members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadab56-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312303/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall meet at least once every 6 months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadab57-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312303/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation and Expenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadab58-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312303/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members of the Commission shall receive no pay on account of their service on the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab59-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312303/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"While away from their homes or regular places of business in the performance of services for the Commission, members of the Commission shall be allowed travel expenses, including per diem in lieu of subsistence, in the same manner as individuals employed intermittently in the Government service are allowed expenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefadab5a-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3252"},"text":"128 Stat. 3252","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefadab5b-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefadab5c-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefadab5d-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revis