{"tag":"section","attrib":{"id":"idefa43433-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304108"},"text":null,"children":[{"tag":"num","attrib":{"value":"304108"},"text":"§ 304108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations, procedures, and guidelines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa43434-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council may promulgate regulations as it considers necessary to govern the implementation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s306108"},"text":"section 306108 of this title","children":[],"tail":" in its entirety."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa43435-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation by Local Governments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall by regulation establish such procedures as may be necessary to provide for participation by local governments in proceedings and other actions taken by the Council with respect to undertakings referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s306108"},"text":"section 306108 of this title","children":[],"tail":" that affect the local governments."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa43436-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption for Federal Programs or Undertakings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council, with the concurrence of the Secretary, shall promulgate regulations or guidelines, as appropriate, under which Federal programs or undertakings may be exempted from any or all of the requirements of this division when the exemption is determined to be consistent with the purposes of this division, taking into consideration the magnitude of the exempted undertaking or program and the likelihood of impairment of historic property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa43437-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3214"},"text":"128 Stat. 3214","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa43438-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa43439-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa4343a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},