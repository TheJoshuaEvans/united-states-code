{"tag":"section","attrib":{"id":"idefb28c1c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s320302"},"text":null,"children":[{"tag":"num","attrib":{"value":"320302"},"text":"§ 320302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefb28c1d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s320302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Grant Permit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, the Secretary of Agriculture, or the Secretary of the Army may grant a permit for the examination of ruins, the excavation of archeological sites, and the gathering of objects of antiquity on land under their respective jurisdictions to an institution that the Secretary concerned considers properly qualified to conduct the examination, excavation, or gathering, subject to such regulations as the Secretary concerned may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb28c1e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s320302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose of Examination, Excavation, or Gathering","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A permit may be granted only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefb28c1f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s320302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the examination, excavation, or gathering is undertaken for the benefit of a reputable museum, university, college, or other recognized scientific or educational institution, with a view to increasing the knowledge of the objects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb28c20-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s320302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gathering shall be made for permanent preservation in a public museum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb28c21-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3260"},"text":"128 Stat. 3260","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefb28c22-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefb28c23-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefb28c24-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"