{"tag":"section","attrib":{"id":"idefa4343b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304109"},"text":null,"children":[{"tag":"num","attrib":{"value":"304109"},"text":"§ 304109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget submission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa4343c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time and Manner of Submission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall submit its budget annually as a related agency of the Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa4343d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transmittal of Copies to Congressional Committees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever the Council submits any budget estimate or request to the President or the Office of Management and Budget, it shall concurrently transmit copies of that estimate or request to the Committee on Natural Resources and Committee on Appropriations of the House of Representatives and the Committee on Energy and Natural Resources and Committee on Appropriations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa4343e-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children"