{"tag":"section","attrib":{"id":"idef9d0930-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302101"},"text":null,"children":[{"tag":"num","attrib":{"value":"302101"},"text":"§ 302101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may expand and maintain a National Register of Historic Places composed of districts, sites, buildings, structures, and objects significant in American history, architecture, archeology, engineering, and culture.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef9d0931-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3191"},"text":"128 Stat. 3191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9d0932-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9d0933-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9d0934-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"302101","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470a/a/1/A"},"text":"16 U.S.C. 470a(a)(1)(A)","children":[],"tail":" (1st sentence)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/665/tI/s101/a/1/A"},"text":"Pub. L. 89–665, title I, § 101(a)(1)(A)","children":[],"tail":" (1st sentence), "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/915"},"text":"80 Stat. 915","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/91/383/s11"},"text":"Pub. L. 91–383, § 11","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/94/458/s2"},"text":"Pub. L. 94–458, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 7, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/1942"},"text":"90 Stat. 1942","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/93/54/s1/d"},"text":"Pub. L. 93–54, § 1(d)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 1, 1973","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/87/139"},"text":"87 Stat. 139","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/205/tVI/s608/a/1"},"text":"Pub. L. 96–205, title VI, § 608(a)(1)","children":[],"tail":", (2), "},{"tag":"html:span","attrib":{},"text":"Mar. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/92"},"text":"94 Stat. 92","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/515/tII/s201/a"},"text":"Pub. L. 96–515, title II, § 201(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/2988"},"text":"94 Stat. 2988","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef9d0935-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef9d0936-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Recovery of Fees for Review Services for Historic Preservation Tax Certification","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/3/tI"},"text":"Pub. L. 106–113, div. B, § 1000(a)(3) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–142, provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/113/dB/s1000/a/3/tI"},"text":"“That notwithstanding any other provision of law, the National Park Service may hereafter recover all fees derived from providing necessary review services associated with historic preservation tax certification, and such funds shall be available until expended without further appropriation for the costs of such review services”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef9d0937-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historically Black Colleges and Universities Historic Building Restoration and Preservation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/333/dI/tV/s507"},"text":"Pub. L. 104–333, div. I, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-11-12"},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4156"},"text":"110 Stat. 4156","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tI/s150"},"text":"Pub. L. 108–7, div. F, title I, § 150","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/245"},"text":"117 Stat. 245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2402"},"text":"Pub. L. 116–9, title II, § 2402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/747"},"text":"133 Stat. 747","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/9/tII/s2402"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Make Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"From the amounts made available to carry out the National Historic Preservation Act [see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s300101"},"text":"54 U.S.C. 300101","children":[],"tail":" et seq.], the Secretary of the Interior shall make grants in accordance with this section to eligible historically black colleges and universities for the preservation and restoration of historic buildings and structures on the campus of these institutions."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants made under subsection (a) shall be subject to the condition that the grantee covenants, for the period of time specified by the Secretary, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no alteration will be made in the property with respect to which the grant is made without the concurrence of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable public access to the property with respect to which the grant is made will be permitted by the grantee for interpretive and educational purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matching Requirement for Buildings and Structures Listed on the National Register of Historic Places.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided by paragraphs (2) and (3), the Secretary may obligate funds made available under this section for a grant with respect to a building or structure listed on, or eligible for listing on, the National Register of Historic Places only if the grantee agrees to match, from funds derived from non-Federal sources, the amount of the grant with an amount that is equal or greater than the grant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may waive paragraphs (1) and (3) with respect to a grant if the Secretary determines from circumstances that an extreme emergency exists or that such a waiver is in the public interest to assure the preservation of historically significant resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall not obligate funds made available under subsection (d)(2) for a grant with respect to a building or structure listed on, or eligible for listing on, the National Register of Historic Places unless the grantee agrees to provide, from funds derived from non-Federal sources, an amount that is equal to 30 percent of the total cost of the project for which the grant is provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding Provision.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under section 108 of the National Historic Preservation Act [see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s303101"},"text":"54 U.S.C. 303101","children":[],"tail":" to 303103], $29,000,000 shall be made available to carry out the purposes of this section. Of amounts made available pursuant to this section, $5,000,000 shall be available for grants to Fisk University, $2,500,000 shall be available for grants to Knoxville College, $2,000,000 shall be available for grants to Miles College, Alabama, $1,500,000 shall be available for grants to Talladega College, Alabama, $1,550,000 shall be available for grants to Selma University, Alabama, $250,000 shall be available for grants to Stillman College, Alabama, $200,000 shall be available for grants to Concordia College, Alabama, $2,900,000 shall be available for grants to Allen University, South Carolina, $1,000,000 shall be available for grants to Claflin College, South Carolina, $2,000,000 shall be available for grants to Voorhees College, South Carolina, $1,000,000 shall be available for grants to Rust College, Mississippi, and $3,000,000 shall be available for grants to Tougaloo College, Mississippi."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to amounts made available under paragraph (1), there is authorized to be appropriated from the Historic Preservation Fund to carry out this section $10,000,000 for each of fiscal years 2003 through 2008 and each of fiscal years 2019 through 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall develop such guidelines as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Historically black colleges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘historically black colleges and universities’ has the same meaning given the term ‘part B institution’ by section 322 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061"},"text":"20 U.S.C. 1061","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Historic building and structures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘historic building and structures’ means a building or structure listed on, or eligible for listing on, the National Register of Historic Places or designated a National Historic Landmark.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef9d0938-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Recommendations of Historic Properties for Preservation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXL/s4021"},"text":"Pub. L. 102–575, title XL, § 4021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4765"},"text":"106 Stat. 4765","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/575/tXL/s4021"},"text":"“The Secretary of the Interior, in consultation with the Advisory Council, shall seek to ensure that historic properties preserved under the National Historic Preservation Act [see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s300101"},"text":"54 U.S.C. 300101","children":[],"tail":" et seq.] fully reflect the historical experience of this nation.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
