{"tag":"section","attrib":{"id":"idef87851d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101703"},"text":null,"children":[{"tag":"num","attrib":{"value":"101703"},"text":"§ 101703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative management agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef87851e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To facilitate the administration of the System, the Secretary, under such terms and conditions as the Secretary considers advisable, may enter into an agreement with an eligible entity managing lands and waters located near a System unit to provide for cooperative management of either a System unit or the lands and waters located near a System unit to promote more effective and efficient management of a System unit. The Secretary may not transfer administration responsibilities for any System unit under this paragraph.","children":[{"tag":"ref","attrib":{"idref":"fn002009"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002009"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “this subsection”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef87851f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Goods and Services.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef878520-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under a cooperative management agreement, the Secretary may acquire by purchase, donation, or exchange from and provide to an eligible entity on a reimbursable basis goods and services to be used by the Secretary or the eligible entity in the cooperative management of land and waters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef878521-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Reimbursements received under this section may be credited to the appropriation current at the time reimbursements are received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef878522-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Co-location","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under the cooperative management agreement, the Secretary and an eligible entity may co-locate in offices and facilities owned or leased by either party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef878523-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employees.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef878524-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101703/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assignment of employee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may arrange an assignment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3372"},"text":"section 3372 of title 5","children":[],"tail":" of a Federal employee or an employee of an eligible entity as mutually agreed upon, for work on any Federal, State, local, or Tribal land."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef878525-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101703/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension of assignment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The assignment provided in paragraph (1) may be extended for any period of time determined by the Secretary and the eligible entity to be mutually beneficial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef878526-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101703/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef878527-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101703/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible entity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “eligible entity” means a State or local entity or any political subdivision thereof, or an Indian Tribe or Tribal organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef878528-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101703/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indian tribe","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Indian Tribe” has the meaning given the term in section 4(e) of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"25 U.S.C. 5304(e)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef878529-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101703/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” means each of the several States, the District of Columbia, and each territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef87852a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101703/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tribal organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Tribal organization” has the meaning given the term in section 4(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of the Indian Self-Determination and Education Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"1","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef87852b-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3136"},"text":"128 Stat. 3136","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s152"},"text":"Pub. L. 118–234, title I, § 152","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2867"},"text":"138 Stat. 2867","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef87852c-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef87852d-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef87852e-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},