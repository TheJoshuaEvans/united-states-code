ttrib":{"href":"/us/pl/118/234"},"text":"Pub. L. 118–234","children":[],"tail":" amended section generally. Prior to amendment, section related to cooperative management agreements."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef878531-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef878532-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorizing Cooperative Management Agreements Between the District of Columbia and the Secretary of the Interior","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2403"},"text":"Pub. L. 116–9, title II, § 2403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/747"},"text":"133 Stat. 747","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/9/tII/s2403"},"text":"“The Secretary [of the Interior] may enter into a cooperative management agreement with the District of Columbia in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s101703"},"text":"section 101703 of title 54","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
