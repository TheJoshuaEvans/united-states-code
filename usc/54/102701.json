{"tag":"section","attrib":{"id":"idef8eb129-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701"},"text":null,"children":[{"tag":"num","attrib":{"value":"102701"},"text":"§ 102701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement personnel within System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8eb12a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers and Employees of the Department of the Interior.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8eb12b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation authority of secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, pursuant to standards prescribed in regulations by the Secretary, may designate certain officers or employees of the Department of the Interior who shall maintain law and order and protect individuals and property within System units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb12c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Powers and duties of designees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the performance of the duties described in paragraph (1), the designated officers or employees may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8eb12d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry firearms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8eb12e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make arrests without warrant for any offense against the United States committed in the presence of the officer or employee, or for any felony cognizable under the laws of the United States if the officer or employee has reasonable grounds to believe that the individual to be arrested has committed or is committing the felony, provided the arrests occur within the System or the individual to be arrested is fleeing from the System to avoid arrest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8eb12f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute any warrant or other process issued by a court or officer of competent jurisdiction for the enforcement of the provisions of any Federal law or regulation issued pursuant to law arising out of an offense committed in the System or, where the individual subject to the warrant or process is in the System, in connection with any Federal offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8eb130-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct investigations of offenses against the United States committed in the System in the absence of investigation of the offenses by any other Federal law enforcement agency having investigative jurisdiction over the offense committed or with the concurrence of the other agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8eb131-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Police Officers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8eb132-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may designate officers and employees of any other Federal agency, or law enforcement personnel of a State or political subdivision of a State, when determined to be economical and in the public interest and with the concurrence of that agency, State, or subdivision, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8eb133-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" act as special police officers in System units when supplemental law enforcement personnel may be needed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8eb134-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise the powers and authority provided by subparagraphs (A) to (D) of subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb135-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation with states and political subdivisions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8eb136-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate, within the System, with any State or political subdivision of a State in the enforcement of supervision of the laws or ordinances of that State or subdivision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8eb137-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mutually waive, in any agreement pursuant to subparagraph (A) and paragraph (1) or pursuant to subparagraphs (A) and (B) of subsection (a)(2) with any State or political subdivision of a State where State law requires the waiver and indemnification, all civil claims against all the other parties to the agreement and, subject to available appropriations, indemnify and save harmless the other parties to the agreement from all claims by third parties for property damage or personal injury, that may arise out of the parties’ activities outside their respective jurisdictions under the agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8eb138-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide limited reimbursement, to a State or political subdivisions of a State, in accordance with such regulations as the Secretary may prescribe, where the State has ceded concurrent legislative jurisdiction over the affected area of the System, for expenditures incurred in connection with its activities within the System that were rendered pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb139-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supplemental authority; delegation of service law enforcement responsibilities not authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraphs (1) and (2) supplement the law enforcement responsibilities of the Service and do not authorize the delegation of law enforcement responsibilities of the Service to State or local governments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb13a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special police officers not deemed federal employees.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8eb13b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this subsection, a law enforcement officer of a State or political subdivision of a State designated to act as a special police officer under paragraph (1) shall not be deemed a Federal employee and shall not be subject to the provisions of law relating to Federal employment, including those relating to hours of work, rates of compensation, leave, unemployment compensation, and Federal benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8eb13c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A law enforcement officer of a State or political subdivision of a State, when acting as a special police officer under paragraph (1), is deemed to be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef8eb13d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal employee for purposes of sections 1346(b) and 2401(b) and chapter 171 of title 28; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef8eb13e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civil service employee of the United States within the meaning of the term “employee” as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of title 5","children":[],"tail":", for purposes of subchapter I of chapter 81 of title 5, relating to compensation to Federal employees for work injuries, and the provisions of subchapter I of chapter 81 of title 5 shall apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8eb13f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Investigative Jurisdiction and State Civil and Criminal Jurisdiction Not Preempted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section and sections 100101(b), 100502, 100507, 100751(b), 100754, 100901(b) and (c), 100906(a) and (d), 101302(b)(1) and (c) to (e), 101306, 101702(b) and (c), 101901, 102102, and 102702 of this title shall not be construed or applied to limit or restrict the investigative jurisdiction of any Federal law enforcement agency other than the Service, and nothing shall be construed or applied to affect any right of a State or political subdivision of a State to exercise civil and criminal jurisdiction within the System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8eb140-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3159"},"text":"128 Stat. 3159","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8eb141-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef8eb142-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef8eb143-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"102701","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s1a–6"},"text":"16 U.S.C. 1a–6","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/91/383/s10"},"text":"Pub. L. 91–383, § 10","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/94/458/s2"},"text":"Pub. L. 94–458, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 7, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/1941"},"text":"90 Stat. 1941","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/106/437/s2"},"text":"Pub. L. 106–437, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 6, 2000","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/114/1920"},"text":"114 Stat. 1920","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/108/352/s11"},"text":"Pub. L. 108–352, § 11","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 21, 2004","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/118/1397"},"text":"118 Stat. 1397","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “In addition to any other authority conferred by law” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
