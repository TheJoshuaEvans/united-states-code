{"tag":"section","attrib":{"id":"idefa1c40b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105"},"text":null,"children":[{"tag":"num","attrib":{"value":"304105"},"text":"§ 304105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa1c40c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There shall be an Executive Director of the Council who shall be appointed by the Chairman with the concurrence of the Council in the competitive service at a rate within the General Schedule, in the competitive service at a rate that may exceed the rate prescribed for the highest rate established for grade 15 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":", or in the Senior Executive Service under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3393"},"text":"section 3393 of title 5","children":[],"tail":". The Executive Director shall report directly to the Chairman and perform such functions and duties as the Chairman may prescribe."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa1c40d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Counsel and Appointment of Other Attorneys.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa1c40e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General counsel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall have a General Counsel, who shall be appointed by the Executive Director. The General Counsel shall report directly to the Executive Director and serve as the Council’s legal advisor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c40f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of other attorneys","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Executive Director shall appoint other attorneys as may be necessary to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa1c410-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the General Counsel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa1c411-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the Council in court when appropriate, including enforcement of agreements with Federal agencies to which the Council is a party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa1c412-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Department of Justice in handling litigation concerning the Council in court; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa1c413-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other legal duties and functions as the Executive Director and the Council may direct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa1c414-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment and Compensation of Officers and Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Executive Director of the Council may appoint and fix the compensation of officers and employees in the competitive service who are necessary to perform the functions of the Council at rates not to exceed that prescribed for the highest rate for grade 15 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":". The Executive Director, with the concurrence of the Chairman, may appoint and fix the compensation of not to exceed 5 employees in the competitive service at rates that exceed that prescribed for the highest rate established for grade 15 of the General Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":" or in the Senior Executive Service under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3393"},"text":"section 3393 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa1c415-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment and Compensation of Additional Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Executive Director may appoint and fix the compensation of such additional personnel as may be necessary to carry out the Council’s duties, without regard to the civil service laws and chapter 51 and subchapter III of chapter 53 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa1c416-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expert and Consultant Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Executive Director may procure expert and consultant services in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa1c417-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial and Administrative Services.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa1c418-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Services to be provided by secretary, agency, or private entity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Financial and administrative services (including those related to budgeting, accounting, financial reporting, personnel and procurement) shall be provided the Council by the Secretary or, at the discretion of the Council, another agency or private entity that reaches an agreement with the Council, for which payments shall be made in advance, or by reimbursement, from funds of the Council in such amounts as may be agreed on by the Chairman of the Council and the head of the agency or the authorized representative of the private entity that will provide the services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c419-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal agency regulations relating to collection apply","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When a Federal agency affords those services, the regulations of that agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5514/b"},"text":"section 5514(b) of title 5","children":[],"tail":" for the collection of indebtedness of personnel resulting from erroneous payments shall apply to the collection of erroneous payments made to or on behalf of a Council employee, and regulations of that agency under sections 1513(d) and 1514 of title 31 for the administrative control of funds shall apply to appropriations of the Council. The Council shall not be required to prescribe those regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa1c41a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funds, Personnel, Facilities, and Services.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa1c41b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provided by federal agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any Federal agency may provide the Council, with or without reimbursement as may be agreed on by the Chairman and the agency, with such funds, personnel, facilities, and services under its jurisdiction and control as may be needed by the Council to carry out its duties, to the extent that the funds, personnel, facilities, and services are requested by the Council and are otherwise available for that purpose. Any funds provided to the Council pursuant to this subsection shall be obligated by the end of the fiscal year following the fiscal year in which the funds are received by the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c41c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obtaining additional property, facilities, and services and receiving donations of money","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent of available appropriations, the Council may obtain by purchase, rental, donation, or otherwise additional property, facilities, and services as may be needed to carry out its duties and may receive donations of money for that purpose. The Executive Director may accept, hold, use, expend, and administer the property, facilities, services, and money for the purposes of this division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa1c41d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rights, Benefits, and Privileges of Transferred Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any employee in the competitive service of the United States transferred to the Council under section 207 of the National Historic Preservation Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/665"},"text":"Public Law 89–665","children":[],"tail":") retains all the rights, benefits, and privileges pertaining to the competitive service held prior to the transfer."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa1c41e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption From Chapter ","children":[],"tail":"10"},{"tag":"inline","attrib":{},"text":" of Title ","children":[],"tail":"5.—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council is exempt from chapter 10 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa1c41f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304105/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisions That Govern Operations of Council","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subchapter II of chapter 5 and chapter 7 of title 5 shall govern the operations of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa1c420-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3211"},"text":"128 Stat. 3211","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/289/tV/s501/c/3"},"text":"Pub. L. 114–289, title V, § 501(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1490"},"text":"130 Stat. 1490","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/331"},"text":"Pub. L. 117–286, § 4(a)(331)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4342"},"text":"136 Stat. 4342","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa1c421-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa1c422-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa1c423-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"304105(a) through (g)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470m"},"text":"16 U.S.C. 470m","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/665/tII/s205"},"text":"Pub. L. 89–665, title II, § 205","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/919"},"text":"80 Stat. 919","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/91/243/s1/g"},"text":"Pub. L. 91–243, § 1(g)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"May 9, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/204"},"text":"84 Stat. 204","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/94/422/tII/s201/7"},"text":"Pub. L. 94–422, title II, § 201(7)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 28, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/1321"},"text":"90 Stat. 1321","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/515/tIII/s301/i"},"text":"Pub. L. 96–515, title III, § 301(i)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/2999"},"text":"94 Stat. 2999","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/333/dI/tV/s509/c/4"},"text":"Pub. L. 104–333, div. I, title V, § 509(c)(4)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/4158"},"text":"110 Stat. 4158","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/106/176/tI/s109"},"text":"Pub. L. 106–176, title I, § 109","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Mar. 10, 2000","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/114/26"},"text":"114 Stat. 26","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/109/453/s1/e"},"text":"Pub. L. 109–453, § 1(e)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/120/3367"},"text":"120 Stat. 3367","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"304105(h)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470p"},"text":"16 U.S.C. 470p","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/665/tII"},"text":"Pub. L. 89–665, title II","children":[],"tail":", §§ 208, 209, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/94/422/tII/s201/9"},"text":"Pub. L. 94–422, title II, § 201(9)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 28, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/1322"},"text":"90 Stat. 1322","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"304105(i), (j)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470q"},"text":"16 U.S.C. 470q","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “at a rate within the Executive Schedule” are added to retain the ability to hire an Executive Director within the General Schedule. The words “in the competitive service at a rate that may exceed the rate prescribed for the highest rate established for grade 15 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":", or in the Senior Executive Service under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3393"},"text":"section 3393 of title 5","children":[],"tail":"” are added for consistency with the intent of the source provision language as it existed in 1966, which included all Federal employees. The language is updated to reflect the existence of the Senior Executive Service and senior level employees above grade 15."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “that exceed that prescribed for the highest rate established for grade 15 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":" or in the Senior Executive Service under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3393"},"text":"section 3393 of title 5","children":[],"tail":"” are substituted for “not to exceed that now or hereafter prescribed for the highest rate of grade 15 of the General Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":"” for consistency with the intent of the source provision language as it existed in 1966, which included all Federal employees. The language is updated to reflect the existence of the Senior Executive Service and senior level employees above grade 15."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “chapter 51 and subchapter III of chapter 53 of title 5” are substituted for “the Classification Act of 1949” because of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1966-09-06/s7/b"},"text":"section 7(b) of the Act of September 6, 1966","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Public Law 89–554","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":"), the 1st section of which enacted Title 5, United States Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(1), the word “Secretary” is substituted for “Department of the Interior” because of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1451"},"text":"43 U.S.C. 1451","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa1c424-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefa1c425-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 207 of the National Historic Preservation Act, referred to in subsec. (h), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/665/s207"},"text":"section 207 of Pub. L. 89–665","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/422/tII/s201/9"},"text":"Pub. L. 94–422, title II, § 201(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-28"},"text":"Sept. 28, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1322"},"text":"90 Stat. 1322","children":[],"tail":", which related to transfer of personnel and property by Department of the Interior to Advisory Council on Historic Preservation and was classified to section 470"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of Title 16, Conservation, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s7"},"text":"Pub. L. 113–287, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3272"},"text":"128 Stat. 3272","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefa1c426-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of Title 5” for “Federal Advisory Committee Act” in heading and “chapter 10 of title 5.” for “the Federal Advisory Committee Act (5 U.S.C. App.).” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289"},"text":"Pub. L. 114–289","children":[],"tail":" substituted “report directly to the Chairman” for “report directly to the Council” and “duties as the Chairman may prescribe” for “duties as the Council may prescribe”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
