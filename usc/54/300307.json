{"tag":"section","attrib":{"id":"idef9d08c7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300307"},"text":null,"children":[{"tag":"num","attrib":{"value":"300307"},"text":"§ 300307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historic preservation review commission","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this division, the term “historic preservation review commission” means a board, council, commission, or other similar collegial body—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9d08c8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300307/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is established by State or local legislation as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302503/a/2"},"text":"section 302503(a)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d08c9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300307/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the members of which are appointed by the chief elected official of a jurisdiction (unless State or local law provides for appointment by another official) from among—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9d08ca-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300307/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professionals in the disciplines of architecture, history, architectural history, planning, prehistoric and historic archeology, folklore, cultural anthropology, curation, conservation, and landscape architecture, or related disciplines, to the extent that those professionals are available in the community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9d08cb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300307/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other individuals who have demonstrated special interest, experience, or knowledge in history, architecture, or related disciplines and will provide for an adequate and qualified commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9d08cc-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3189"},"text":"128 Stat. 3189","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9d08cd-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9d08ce-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9d08cf-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}