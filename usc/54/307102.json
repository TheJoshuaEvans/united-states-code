{"tag":"section","attrib":{"id":"idefa8efc6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307102"},"text":null,"children":[{"tag":"num","attrib":{"value":"307102"},"text":"§ 307102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa8efc7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication in Federal Register","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No final regulation of the Secretary shall become effective prior to the expiration of 30 calendar days after it is published in the Federal Register during which either or both Houses of Congress are in session.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8efc8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disapproval of Regulation by Resolution of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulation shall not become effective if, within 90 calendar days of continuous session of Congress after the date of promulgation, both Houses of Congress adopt a concurrent resolution, the matter after the resolving clause of which is as follows: “That Congress disapproves the regulation promulgated by the Secretary dealing with the matter of         , which regulation was transmitted to Congress on         ,” the blank spaces in the resolution being appropriately filled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8efc9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure of Congress To Adopt Resolution of Disapproval of Regulation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If at the end of 60 calendar days of continuous session of Congress after the date of promulgation of a regulation, no committee of either House of Congress has reported or been discharged from further consideration of a concurrent resolution disapproving the regulation, and neither House has adopted such a resolution, the regulation may go into effect immediately. If, within the 60 calendar days, a committee has reported or been discharged from further consideration of such a resolution, the regulation may go into effect not sooner than 90 calendar days of continuous session of Congress after its promulgation unless disapproved as provided for.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8efca-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sessions of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa8efcb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307102/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuity of session is broken only by an adjournment sine die; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa8efcc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307102/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the days on which either House is not in session because of an adjournment of more than 3 days to a day certain are excluded in the computation of 60 and 90 calendar days of continuous session of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8efcd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307102/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Inaction or Rejection of Resolution of Disapproval Not Deemed Approval of Regulation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Congressional inaction on or rejection of a resolution of disapproval shall not be deemed an expression of approval of the regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa8efce-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3231"},"text":"128 Stat. 3231","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa8efcf-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa8efd0-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa8efd1-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"307102","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470w–6"},"text":"16 U.S.C. 470w–6","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","att