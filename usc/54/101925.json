{"tag":"section","attrib":{"id":"idef89f63a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925"},"text":null,"children":[{"tag":"num","attrib":{"value":"101925"},"text":"§ 101925.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial use authorizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef89f63b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent specified in this section, the Secretary, on request, may authorize a private person, corporation, or other entity to provide services to visitors to System units through a commercial use authorization. A commercial use authorization shall not be considered to be a concession contract under this subchapter and no other section of this subchapter shall be applicable to a commercial use authorization except where expressly stated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c663c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Issuance of Commercial Use Authorizations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8c663d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required determinations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority of this section may be used only to authorize provision of services that the Secretary determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8c663e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will have minimal impact on resources and values of a System unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8c663f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the purpose for which the System unit was established and with all applicable management plans and Service policies and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c6640-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements of commercial use authorization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8c6641-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require payment of a reasonable fee for issuance of a commercial use authorization, the fees to remain available without further appropriation to be used, at a minimum, to recover associated management and administrative costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8c6642-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that the provision of services under a commercial use authorization be accomplished in a manner consistent to the highest practicable degree with the preservation and conservation of System unit resources and values;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8c6643-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take appropriate steps to limit the liability of the United States arising from the provision of services under a commercial use authorization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8c6644-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have no authority under this section to issue more commercial use authorizations than are consistent with the preservation and proper management of System unit resources and values; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8c6645-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish other conditions for issuance of a commercial use authorization that the Secretary determines to be appropriate for the protection of visitors, provision of adequate and appropriate visitor services, and protection and proper management of System unit resources and values.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c6646-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any commercial use authorization shall be limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8c6647-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial operations with annual gross receipts of not more than $25,000 resulting from services originating and provided solely within a System unit pursuant to the commercial use authorization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c6648-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incidental use of resources of the System unit by commercial operations that provide services originating and terminating outside the boundaries of the System unit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c6649-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8c664a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses by organized children’s camps, outdoor clubs, and nonprofit institutions (including back country use); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8c664b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other uses, as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c664c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonprofit Institutions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nonprofit institutions are not required to obtain commercial use authorizations unless taxable income is derived by the institution from the authorized use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c664d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A commercial use authorization shall not provide for the construction of any structure, fixture, or improvement on federally-owned land within the boundaries of a System unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c664e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of any commercial use authorization shall not exceed 2 years. No preferential right of renewal or similar provisions for renewal shall be granted by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c664f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101925/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person, corporation, or other entity seeking or obtaining a commercial use authorization shall not be precluded from submitting a proposal for concession contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8c6650-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3150"},"text":"128 Stat. 3150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8c6651-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef8c6652-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef8c6653-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101925","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s5966"},"text":"16 U.S.C. 5966","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/105/391/tIV/s418"},"text":"Pub. L. 105–391, title IV, § 418","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/3516"},"text":"112 Stat. 3516","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
