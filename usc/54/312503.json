{"tag":"section","attrib":{"id":"idefadab8e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312503"},"text":null,"children":[{"tag":"num","attrib":{"value":"312503"},"text":"§ 312503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey and recovery by Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefadab8f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, on notification, in writing, by any Federal or State agency or appropriate historical or archeological authority that scientific, prehistorical, historical, or archeological data are being or may be irrevocably lost or destroyed by any Federal or federally assisted or licensed project, activity, or program, shall, if the Secretary determines that the data are significant and are being or may be irrevocably lost or destroyed and after reasonable notice to the agency responsible for funding or licensing the project, activity, or program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadab90-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct or cause to be conducted a survey and other investigation of the areas that are or may be affected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab91-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recover and preserve the data (including analysis and publication) that, in the opinion of the Secretary, are not being, but should be, recovered and preserved in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadab92-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When Survey or Recovery Not Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No survey or recovery work shall be required pursuant to this section that, in the determination of the head of the responsible agency, would impede Federal or federally assisted or licensed projects or activities undertaken in connection with any emergency, including projects or activities undertaken in anticipation of, or as a result of, a natural disaster.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadab93-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initiation of Survey","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall initiate the survey or recovery effort within—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadab94-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312503/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 days after notification pursuant to subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab95-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312503/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such time as may be agreed on with the head of the agency responsible for funding or licensing the project, activity, or program in all other cases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadab96-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation by Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall, unless otherwise agreed to in writing, compensate any person, association, or public entity damaged as a result of delays in construction or as a result of the temporary loss of the use of private or nonfederally owned land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefadab97-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3255"},"text":"128 Stat. 3255","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefadab98-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefadab99-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefadab9a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag"