":"/us/pl/86/523/s4"},"text":"Pub. L. 86–523, § 4","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/93/291/s1/3"},"text":"Pub. L. 93–291, § 1(3)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"May 24, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/174"},"text":"88 Stat. 174","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
