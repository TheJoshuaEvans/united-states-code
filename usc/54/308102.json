{"tag":"section","attrib":{"id":"idefa8f019-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308102"},"text":null,"children":[{"tag":"num","attrib":{"value":"308102"},"text":"§ 308102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa8f01a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Using the established national historic preservation program to the extent practicable, the Secretary shall encourage, support, assist, recognize, and work in partnership with citizens, Federal agencies, States, Tribes, local governments, other public entities, educational institutions, and nonprofit organizations in identifying, researching, evaluating, interpreting, and protecting historic battlefields and associated sites on a national, State, and local level.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f01b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To carry out subsection (a), the Secretary may use a cooperative agreement, grant, contract, or other generally adopted means of providing financial assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f01c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to carry out this section $3,000,000 for each fiscal year, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa8f01d-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3233"},"text":"128 Stat. 3233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s157/b"},"text":"Pub. L. 118–234, title I, § 157(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2879"},"text":"138 Stat. 2879","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa8f01e-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa8f01f-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa8f020-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":nul