{"tag":"section","attrib":{"id":"idefa4350e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305502"},"text":null,"children":[{"tag":"num","attrib":{"value":"305502"},"text":"§ 305502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreement to operate museum","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To provide a national center to commemorate and encourage the building arts and to preserve and maintain a nationally significant building that exemplifies the great achievements of the building arts in the United States, the Secretary and the Administrator of General Services shall enter into a cooperative agreement with the Committee for the operation of a National Building Museum in the Federal building located in the block bounded by Fourth Street, Fifth Street, F Street, and G Street, Northwest in Washington, District of Columbia. The cooperative agreement shall include provisions that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa4350f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305502/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the site available to the Committee without charge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa43510-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305502/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, subject to available appropriations, such maintenance, security, information, janitorial, and other services as may be necessary to ensure the preservation and operation of the site; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa43511-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305502/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe reasonable terms and conditions by which the Committee can fulfill its responsibilities under this division.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa43512-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3223"},"text":"128 Stat. 3223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa43513-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa43514-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa43515-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Secti