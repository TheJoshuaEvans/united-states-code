{"tag":"section","attrib":{"id":"idef8eb1a4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103301"},"text":null,"children":[{"tag":"num","attrib":{"value":"103301"},"text":"§ 103301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military maneuvers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To obtain practical benefits of great value to the country from the establishment of national military parks, the parks and their approaches are declared to be national fields for military maneuvers for the Regular Army or Regular Air Force and the National Guard or militia of the States. National military parks shall be opened for those purposes only in the discretion of the Secretary, and under such regulations as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef8eb1a5-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3165"},"text":"128 Stat. 3165","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8eb1a6-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef8eb1a7-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef8eb1a8-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"