{"tag":"section","attrib":{"id":"idef8eb144-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102702"},"text":null,"children":[{"tag":"num","attrib":{"value":"102702"},"text":"§ 102702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crime prevention assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8eb145-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations for Improvement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall direct the chief official responsible for law enforcement within the Service to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8eb146-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compile a list of System units with the highest rates of violent crime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb147-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations concerning capital improvements, and other measures, needed within the System to reduce the rates of violent crime, including the rate of sexual assault; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb148-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102702/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the information required by paragraphs (1) and (2) in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8eb149-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Based on the recommendations and list issued pursuant to subsection (a), the Secretary shall distribute the funds authorized by subsection (d) throughout the System. Priority shall be given to areas with the highest rates of sexual assault.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8eb14a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds provided under this section may be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8eb14b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase lighting within or adjacent to System units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb14c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide emergency phone lines to contact law enforcement or security personnel in areas within or adjacent to System units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb14d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102702/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase security or law enforcement personnel within or adjacent to System units; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb14e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102702/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any other project intended to increase the security and safety of System units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8eb14f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated out of the Violent Crime Reduction Trust Fund not more than $10,000,000 for the Secretary to take all necessary actions to seek to reduce the incidence of violent crime in the System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8eb150-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3161"},"text":"128 Stat. 3161","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8eb151-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","chi