{"tag":"section","attrib":{"id":"idefb01bb9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312508"},"text":null,"children":[{"tag":"num","attrib":{"value":"312508"},"text":"§ 312508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs for identification, surveys, evaluation, and data recovery with respect to historic property","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s312507/a"},"text":"section 312507(a) of this title","children":[],"tail":" or any other provision of law—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefb01bba-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312508/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification, surveys, and evaluation carried out with respect to historic property within project areas may be treated for purposes of any law or rule of law as planning costs of the project and not as costs of mitigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb01bbb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312508/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable costs for identification, surveys, evaluation, and data recovery carried out with respect to historic property within project areas may be charged to Federal licensees and permittees as a condition to the issuance of the license or permit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb01bbc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312508/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal agencies, with the concurrence of the Secretary and after notification of the Committee on Natural Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate, may waive, in appropriate cases, the 1 percent limitation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s312507/a"},"text":"section 312507(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb01bbd-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3256"},"text":"128 Stat. 3256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefb01bbe-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefb01bbf-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefb01bc0-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revise