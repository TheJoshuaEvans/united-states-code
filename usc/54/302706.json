{"tag":"section","attrib":{"id":"idef9f7a1e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302706"},"text":null,"children":[{"tag":"num","attrib":{"value":"302706"},"text":"§ 302706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for inclusion on National Register","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9f7a1f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Property of traditional religious and cultural importance to an Indian tribe or Native Hawaiian organization may be determined to be eligible for inclusion on the National Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9f7a20-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out its responsibilities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s306108"},"text":"section 306108 of this title","children":[],"tail":", a Federal agency shall consult with any Indian tribe or Native Hawaiian organization that attaches religious and cultural significance to property described in subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9f7a21-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hawaii","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out responsibilities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302303"},"text":"section 302303 of this title","children":[],"tail":", the State Historic Preservation Officer for Hawaii shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9f7a22-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302706/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with Native Hawaiian organizations in assessing the cultural significance of any property in determining whether to nominate the property to the National Register;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9f7a23-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302706/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with Native Hawaiian organizations in developing the cultural component of a preservation program or plan for the property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9f7a24-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302706/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into a memorandum of understanding or agreement with Native Hawaiian organizations for the assessment of the cultural significance of a property in determining whether to nominate the property to the National Register and to carry out the cultural component of the preservation program or plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9f7a25-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3201"},"text":"128 Stat. 3201","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9f7a26-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9f7a27-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9f7a28-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"302706","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470a/d/6"},"text":"16 U.S.C. 470a(d)(6)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/665/tI/s101/d/6"},"text":"Pub. L. 89–665, title I, § 101(d)(6)","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/102/575/tXL/s4006/a/2"},"text":"Pub. L. 102–575, title XL, § 4006(a)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/4757"},"text":"106 Stat. 4757","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
