{"tag":"section","attrib":{"id":"idef984d91-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200307"},"text":null,"children":[{"tag":"num","attrib":{"value":"200307"},"text":"§ 200307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of Fund amounts for publicity purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef984d92-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts derived from the sources listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s200302"},"text":"section 200302 of this title","children":[],"tail":" shall not be available for publicity purposes."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984d93-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Temporary Signing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a case where significant acquisition or development is initiated, appropriate standardized temporary signing shall be located on or near the affected site, to the extent feasible, so as to indicate the action taken is a product of funding made available through the Fund. The signing may indicate the percentage amounts and dollar amounts financed by Federal and non-Federal funds, and that the source of the funding includes amounts derived from Outer Continental Shelf receipts. The Secretary shall prescribe standards and guidelines for the usage of the signing to ensure consistency of design and application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef984d94-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3179"},"text":"128 Stat. 3179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef984d95-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef984d96-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef984d97-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{}