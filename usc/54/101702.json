{"tag":"section","attrib":{"id":"idef8784fc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702"},"text":null,"children":[{"tag":"num","attrib":{"value":"101702"},"text":"§ 101702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8784fd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Service Appropriated Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A cooperative agreement entered into by the Secretary that involves the transfer of Service appropriated funds to a State, local, or tribal government or other public entity, an educational institution, or a private nonprofit organization to carry out public purposes of a Service program is a cooperative agreement properly entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6305"},"text":"section 6305 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8784fe-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative Research and Training Programs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8784ff-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To facilitate the administration of the System, the Secretary, under such terms and conditions as the Secretary may consider advisable, may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef878500-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into cooperative agreements with public or private educational institutions, States, and political subdivisions of States to develop adequate, coordinated, cooperative research and training programs concerning the resources of the System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef878501-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to an agreement, accept from and make available to the cooperator technical and support staff, financial assistance for mutually agreed upon research projects, supplies and equipment, facilities, and administrative services relating to cooperative research units that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef878502-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of subsection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection does not waive any requirements for research projects that are subject to Federal procurement regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef878503-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sale of Products and Services Produced in the Conduct of Living Exhibits and Interpretive Demonstrations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To facilitate the administration of the System, the Secretary, under such terms and conditions as the Secretary considers advisable, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef878504-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sell at fair market value, without regard to the requirements of chapters 1 to 11 of title 40 and division C (except sections 3302, 3307(e), 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41, products and services produced in the conduct of living exhibits and interpretive demonstrations in System units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef878505-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts, including cooperative arrangements, with respect to living exhibits and interpretive demonstrations in System units; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef878506-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credit the proceeds from those sales and contracts to the appropriation bearing the cost of the exhibits and demonstrations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef878507-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative Agreements for System Unit Natural Resource Protection.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef878508-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may enter into cooperative agreements with State, local, or tribal governments, other Federal agencies, other public entities, educational institutions, private nonprofit organizations, or participating private landowners for the purpose of protecting natural resources of System units through collaborative efforts on land inside and outside the System units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef878509-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A cooperative agreement entered into under paragraph (1) shall provide clear and direct benefits to System unit natural resources and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef87850a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef87850b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preservation, conservation, and restoration of coastal and riparian systems, watersheds, and wetlands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef87850c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing, controlling, or eradicating invasive exotic species that are within a System unit or adjacent to a System unit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef87850d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restoration of natural resources, including native wildlife habitat or ecosystems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef87850e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a statement of purpose demonstrating how the agreement will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef87850f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance science-based natural resource stewardship at the System unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef878510-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefit the parties to the agreement;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef878511-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" specify any staff required and technical assistance to be provided by the Secretary or other parties to the agreement in support of activities inside and outside the System unit that will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef878512-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect natural resources of the System unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef878513-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefit the parties to the agreement;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef878514-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any materials, supplies, or equipment and any other resources that will be contributed by the parties to the agreement or by other Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef878515-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe any financial assistance to be provided by the Secretary or the partners to implement the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef878516-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that any expenditure by the Secretary pursuant to the agreement is determined by the Secretary to support the purposes of natural resource stewardship at a System unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef878517-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include such other terms and conditions as are agreed to by the Secretary and the other parties to the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef878518-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101702/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall not use any funds associated with an agreement entered into under paragraph (1) for the purposes of land acquisition, regulatory activity, or the development, maintenance, or operation of infrastructure, except for ancillary support facilities that the Secretary determines to be necessary for the completion of projects or activities identified in the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef878519-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3135"},"text":"128 Stat. 3135","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef87851a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef87851b-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef87851c-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101702(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s1g"},"text":"16 U.S.C. 1g","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/104/208/dA/tI/s101/d"},"text":"Pub. L. 104–208, div. A, title I, § 101(d)","children":[],"tail":" [title I (3d undesignated par. under heading “"},{"tag":"html:span","attrib":{},"text":"administrative provisions","children":[],"tail":"” under heading “"},{"tag":"html:span","attrib":{},"text":"National Park Service","children":[],"tail":"”)], "},{"tag":"html:span","attrib":{},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/3009-189"},"text":"110 Stat. 3009–189","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib