},{"tag":"html:a","attrib":{"href":"/us/stat/67/495"},"text":"67 Stat. 495","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/91/383/s2/a"},"text":"Pub. L. 91–383, § 2(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 18, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/826"},"text":"84 Stat. 826","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “and he may use applicable appropriations for the aforesaid system for the following purposes” are retained because the appropriation is to be used for something outside the System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
