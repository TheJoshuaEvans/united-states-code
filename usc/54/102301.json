{"tag":"section","attrib":{"id":"idef8c66b6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102301"},"text":null,"children":[{"tag":"num","attrib":{"value":"102301"},"text":"§ 102301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteers in parks program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8c66b7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may recruit, train, and accept, without regard to chapter 51 and subchapter III of chapter 53 of title 5 or regulations prescribed under that chapter or subchapter, the services of individuals without compensation as volunteers for or in aid of interpretive functions or other visitor services or activities in and related to System units and related areas. In accepting those services, the Secretary shall not permit the use of volunteers in hazardous duty or law enforcement work or in policymaking processes, or to displace any employee. The services of individuals whom the Secretary determines are skilled in performing hazardous activities may be accepted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c66b8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incidental Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide for incidental expenses of volunteers, such as transportation, uniforms, lodging, and subsistence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c66b9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Employee Status for Volunteers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8c66ba-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102301/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employment status of volunteers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this section, a volunteer shall not be deemed a Federal employee and shall not be subject to the provisions of law relating to Federal employment, including those relating to hours of work, rates of compensation, leave, unemployment compensation, and Federal employee benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c66bb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102301/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tort claims","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purpose of sections 1346(b) and 2401(b) and chapter 171 of title 28, a volunteer under this chapter shall be deemed a Federal employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c66bc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102301/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Volunteers deemed civil employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of subchapter I of chapter 81 of title 5, volunteers under this chapter shall be deemed civil employees of the United States within the meaning of the term “employee” as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of title 5","children":[],"tail":", and subchapter I of chapter 81 of title 5 shall apply."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c66bd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102301/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation for losses and damages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purpose of claims relating to damage to, or loss of, personal property of a volunteer incident to volunteer service, a volunteer under this chapter shall be deemed a Federal employee, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3721"},"text":"section 3721 of title 31","children":[],"tail":" shall apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c66be-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102301/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to carry out this section not more than $9,000,000 for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8c66bf-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3153"},"text":"128 Stat. 3153","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dF/tI/s118"},"text":"Pub. L. 113–235, div. F, title I, § 118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2421"},"text":"128 Stat. 2421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dG/tI/s114"},"text":"Pub. L. 114–113, div. G, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2550"},"text":"129 Stat. 2550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/289/tIII/s303"},"text":"Pub. L. 114–289, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1487"},"text":"130 Stat. 1487","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8c66c0-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idef8c66c1-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment Not Shown in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (d) of this section was derived from ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s18j"},"text":"section 18j of Title 16","children":[],"tail":", Conservation, which was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dF/tI/s118"},"text":"Pub. L. 113–235, div. F, title I, § 118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2421"},"text":"128 Stat. 2421","children":[],"tail":". For applicability of that amendment to this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/b"},"text":"section 6(b) of Pub. L. 113–287","children":[],"tail":", set out as a Transitional and Savings Provisions note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of this title","children":[],"tail":". Former "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s18j"},"text":"section 18j of Title 16","children":[],"tail":" was amended by striking “$3,500,000” and inserting “$5,000,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef8c66c2-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef8c66c3-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"