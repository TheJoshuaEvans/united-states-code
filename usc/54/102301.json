,"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"102301(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s18j"},"text":"16 U.S.C. 18j","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/91/357/s4"},"text":"Pub. L. 91–357, § 4","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 29, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/472"},"text":"84 Stat. 472","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/94/128"},"text":"Pub. L. 94–128","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 13, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/89/682"},"text":"89 Stat. 682","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/98/540/s1/a"},"text":"Pub. L. 98–540, § 1(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/2718"},"text":"98 Stat. 2718","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/333/dI/tVIII/s805"},"text":"Pub. L. 104–333, div. I, title VIII, § 805","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/4188"},"text":"110 Stat. 4188","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “chapter 51 and subchapter III of title 5” are substituted for “the civil service classification laws” for clarity and for consistency with other titles of the United States Code. The words “System units and related areas” are substituted for “areas administered by the Secretary through the National Park Service” for clarity and for consistency in the new title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “of volunteers” are added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the words “relating to compensation to Federal employees for work injuries” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “such sums as may be necessary” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef8c66c4-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef8c66c5-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289"},"text":"Pub. L. 114–289","children":[],"tail":" substituted “not more than $9,000,000” for “not more than $7,000,000”. See Amendment Subject to Availability of Appropriations note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" substituted “$7,000,000” for “$3,500,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef8c66c6-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef8c66c7-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment Subject to Availability of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/tIII/s303"},"text":"Pub. L. 114–289, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1487"},"text":"130 Stat. 1487","children":[],"tail":", provided that the amendment of this section by section 303 is subject to the availability of appropriations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
