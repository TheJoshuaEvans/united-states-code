{"tag":"section","attrib":{"id":"idef853b8c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101340"},"text":null,"children":[{"tag":"num","attrib":{"value":"101340"},"text":"§ 101340.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef853b8d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101340/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expenditure Shall Follow Priority Listing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Expenditure of any funds authorized and appropriated for new construction, repair, or rehabilitation of housing under this chapter shall follow the housing priority listing established by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s101339"},"text":"section 101339 of this title","children":[],"tail":", in sequential order, to the maximum extent practicable."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef853b8e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101340/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonconstruction Funds in Annual Budget Submittal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each fiscal year the President’s proposed budget to Congress shall include identification of nonconstruction funds to be spent for Service housing maintenance and operations that are in addition to rental receipts collected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef853b8f-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text