{"tag":"section","attrib":{"id":"idefab60e3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308605"},"text":null,"children":[{"tag":"num","attrib":{"value":"308605"},"text":"§ 308605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private property protection","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab60e4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308605/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizes the Secretary to require or affect the management or use of private property without the written consent of the owner of the private property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab60e5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308605/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibits the Secretary from providing land management guidance or requirements relating to private property as a condition of a grant provided to the owner of the private property under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab60e6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308605/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be construed as creating any new regulatory burden on any Federal, State, Tribal, or private entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefab60e7-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tVI/s643/a"},"text":"Pub. L. 117–328, div. DD, title VI, § 643(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5614"},"text":"136 Stat. 5614","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
