{"tag":"section","attrib":{"id":"idef853b41-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101332"},"text":null,"children":[{"tag":"num","attrib":{"value":"101332"},"text":"§ 101332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority of Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef853b42-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rental Housing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To enhance the ability of the Secretary, acting through the Director, to effectively manage System units, the Secretary may where necessary and justified—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef853b43-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101332/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available employee housing, on or off land under the administrative jurisdiction of the Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef853b44-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101332/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rent that housing to field employees at rates based on the reasonable value of the housing in accordance with requirements applicable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5911"},"text":"section 5911 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef853b45-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Joint Development Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may use authorities granted by statute in combination with one another in the furtherance of providing where necessary and justified affordable field employee housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef853b46-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101332/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction Limitations on Federal Land","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not utilize any land for the purposes of providing field employee housing under this subchapter that will affect a primary resource value of the area or adversely affect the mission of the Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef853b47-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101332/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rental Rates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent practicable, the Secretary shall establish rental rates for all quarters occupied by field employees of the Service that are based on the reasonable value of the quarters in accordance with requirements applicable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5911"},"text":"section 5911 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef853b48-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3126"},"text":"128 Stat. 3126","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef853b49-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef853b4a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef853b4b-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","a