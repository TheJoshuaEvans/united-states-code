ldren":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “or lease” are omitted to distinguish between leasing property and renting employee housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
