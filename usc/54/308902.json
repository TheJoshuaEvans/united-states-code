{"tag":"section","attrib":{"id":"idefab6193-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308902"},"text":null,"children":[{"tag":"num","attrib":{"value":"308902"},"text":"§ 308902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefab6194-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Department of the Interior the Save America’s Treasures Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab6195-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In consultation and partnership with the National Endowment for the Arts, the National Endowment for the Humanities, the Institute of Museum and Library Services, the National Trust for Historic Preservation in the United States, the National Conference of State Historic Preservation Officers, the National Association of Tribal Historic Preservation Officers, and the President’s Committee on the Arts and the Humanities, the Secretary shall use the amounts made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s308905"},"text":"section 308905 of this title","children":[],"tail":" to provide grants to eligible entities for projects to preserve nationally significant collections and historic property."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefab6196-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3244"},"text":"128 Stat. 3244","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefab6197-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefab6198-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefab6199-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"308902","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s469"},"text":"16 U.S.C. 469","children":[],"tail":null},{"tag":"html:i","attrib":{},"text":"o","children":[],"tail":"(a), (c)(1)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/111/11/tVII"},"text":"Pub. L. 111–11, title VII","children":[],"tail":", subtitle D, § 7303(a), (c)(1), "},{"tag":"html:span","attrib":{},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/123/1216"},"text":"123 Stat. 1216","children":[],"tail":", 1217."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “The purpose of this section is to authorize within the Department of the Interior the Save America’s Treasures Program” are omitted as unnecessary. The words “to be carried out by the Director of the National Park Service” are omitted because the definition of “Secretary” in section 308901 of the new title provides that the Secretary acts through the Director and because this is the only place in the chapter where the Director is mentioned.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “subject to paragraph (6)(A)(ii)” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
