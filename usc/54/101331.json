{"tag":"section","attrib":{"id":"idef853b36-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101331"},"text":null,"children":[{"tag":"num","attrib":{"value":"101331"},"text":"§ 101331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef853b37-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101331/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Field employee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “field employee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef853b38-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101331/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of the Service who is exclusively assigned by the Service to perform duties at a field unit, and the members of the employee’s family; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef853b39-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101331/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other individual who is authorized to occupy Federal Government quarters under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5911"},"text":"section 5911 of title 5","children":[],"tail":", and for whom there is no feasible alternative to the provision of Federal Government housing, and the members of the individual’s family."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef853b3a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101331/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Primary resource values","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “primary resource values” means resources that are specifically mentioned in the enabling legislation for that field unit or other resource value recognized under Federal statute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef853b3b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101331/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quarters","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “quarters” means quarters owned or leased by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef853b3c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101331/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Seasonal quarters","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “seasonal quarters” means quarters typically occupied by field employees who are hired on assignments of 6 months or less.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef853b3d-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3126"