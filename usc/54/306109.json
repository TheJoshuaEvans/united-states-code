{"tag":"section","attrib":{"id":"idefa6a56a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306109"},"text":null,"children":[{"tag":"num","attrib":{"value":"306109"},"text":"§ 306109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs of preservation as eligible project costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A Federal agency may include the costs of preservation activities of the agency under this division as eligible project costs in all undertakings of the agency or assisted by the agency. The eligible project costs may include amounts paid by a Federal agency to a State to be used in carrying out the preservation responsibilities of the Federal agency under this division, and reasonable costs may be charged to Federal licensees and permittees as a condition to the issuance of the license or permit.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefa6a56b-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3227"},"text":"128 Stat. 3227","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa6a56c-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa6a56d-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa6a56e-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"