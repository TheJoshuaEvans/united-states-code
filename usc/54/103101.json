{"tag":"section","attrib":{"id":"idef8eb175-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103101"},"text":null,"children":[{"tag":"num","attrib":{"value":"103101"},"text":"§ 103101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability and use of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8eb176-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credits of Receipts for Meals and Quarters Furnished Federal Government Employees in the Field","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Cash collections and payroll deductions made for meals and quarters furnished by the Service to employees of the Federal Government in the field and to cooperating agencies may be credited as a reimbursement to the current appropriation for the administration of the System unit in which the accommodations are furnished.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8eb177-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability for Expense of Recording Donated Land","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Appropriations made for the Service shall be available for any expenses incident to the preparation and recording of title evidence covering land to be donated to the United States for administration by the Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8eb178-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds for Law Enforcement and Emergencies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8eb179-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103101/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds, not to exceed $500,000 per incident, available to the Service may be used, with the approval of the Secretary, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8eb17a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103101/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain law and order in emergency and other unforeseen law enforcement situations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8eb17b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103101/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct emergency search and rescue operations in the System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb17c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103101/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Replenishment of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary expends funds under paragraph (1), the funds shall be replenished by a supplemental appropriation for which the Secretary shall make a request as promptly as possible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8eb17d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contribution for Annuity Benefits.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8eb17e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103101/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Necessary amounts are appropriated for reimbursement, pursuant to the Policemen and Firemen’s Retirement and Disability Act amendments of 1957 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/157"},"text":"Public Law 85–157","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/391"},"text":"71 Stat. 391","children":[],"tail":"), to the District of Columbia on a monthly basis for benefit payments by the District of Columbia to United States Park Police annuitants under section 12 of the Policemen and Firemen’s Retirement and Disability Act (ch. 433, "},{"tag":"ref","attrib":{"href":"/us/stat/39/718"},"text":"39 Stat. 718","children":[],"tail":"), to the extent that those payments exceed contributions made by active Park Police members covered under the Policemen and Firemen’s Retirement and Disability Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8eb17f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103101/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonavailability of appropriations to the service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Appropriations made to the Service are not available for the purpose of making reimbursements under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8eb180-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103101/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waterproof Footwear","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Appropriations for the Service that are available for the purchase of equipment may be used for purchase of waterproof footwear, which shall be regarded and listed as System equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8eb181-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3163"},"text":"128 Stat. 3163","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/74/dC/tI/s123"},"text":"Pub. L. 119–74, div. C, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-01-23"},"text":"Jan. 23, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/125"},"text":"140 Stat. 125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8eb182-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id"