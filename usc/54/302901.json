{"tag":"section","attrib":{"id":"idef9f7a2b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302901"},"text":null,"children":[{"tag":"num","attrib":{"value":"302901"},"text":"§ 302901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awarding of grants and availability of grant funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9f7a2c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No grant may be made under this division unless application for the grant is submitted to the Secretary in accordance with regulations and procedures prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9f7a2d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Not Treated as Taxable Income","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No grant made pursuant to this division shall be treated as taxable income for purposes of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"26 U.S.C. 1","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9f7a2e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302901/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall make funding available to individual States and the National Trust as soon as practicable after execution of a grant agreement. For purposes of administration, grants to individual States and the National Trust each shall be deemed to be one grant and shall be administered by the Service as one grant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9f7a2f-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3202"},"text":"128 Stat. 3202","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9f7a30-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9f7a31-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9f7a32-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attri