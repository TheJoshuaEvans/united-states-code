{"tag":"section","attrib":{"id":"idef7b9e32-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100735"},"text":null,"children":[{"tag":"num","attrib":{"value":"100735"},"text":"§ 100735.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions for just compensation by mining claim holders","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The holder of any patented or unpatented mining claim subject to this subchapter that believes the holder has suffered a loss by operation of this subchapter, or by orders or regulations issued pursuant to this subchapter, may bring a civil action in United States district court to recover just compensation, which shall be awarded if the court finds that the loss constitutes a taking of property compensable under the Constitution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef7b9e33-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3110"},"text":"128 Stat. 3110","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7b9e34-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef7b9e35-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef7b9e36-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text