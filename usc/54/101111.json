{"tag":"section","attrib":{"id":"idef82c96d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101111"},"text":null,"children":[{"tag":"num","attrib":{"value":"101111"},"text":"§ 101111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose and establishment of Foundation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To encourage private gifts of real and personal property, or any income from, or other interest in, the property, for the benefit of, or in connection with, the Service, its activities, or its services, and thereby to further the conservation of natural, scenic, historic, scientific, educational, inspirational, or recreational resources for future generations of Americans, there is established a charitable and nonprofit corporation to be known as the National Park Foundation to accept and administer those gifts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef82c96e-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3120"},"text":"128 Stat. 3120","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef82c96f-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef82c970-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef82c971-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"