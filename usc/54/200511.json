{"tag":"section","attrib":{"id":"idef9a9783-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200511"},"text":null,"children":[{"tag":"num","attrib":{"value":"200511"},"text":"§ 200511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9a9784-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of grants made under this chapter for projects in any one State for any fiscal year shall not be more than 15 percent of the amount made available for grants to all of the States for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9a9785-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recovery Action Program Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not more than 3 percent of the amount made available for grants under this chapter for a fiscal year shall be used for recovery action program grants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9a9786-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Innovation Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not more than 10 percent of the amount made available for grants under this chapter for a fiscal year shall be used for innovation grants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9a9787-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200511/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not more than 25 percent of the amount made available under this chapter to any local government shall be used for program support.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9a9788-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200511/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Land Acquisition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No funds made available under this chapter shall be used for the acquisition of land or an interest in land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9a9789-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3187"},"text":"128 Stat. 3187","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9a978a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9a978b-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9a978c-3a70-11f1