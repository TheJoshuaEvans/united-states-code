{"tag":"section","attrib":{"id":"idefab6188-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308901"},"text":null,"children":[{"tag":"num","attrib":{"value":"308901"},"text":"§ 308901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab6189-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “collection” means a collection of intellectual and cultural artifacts, including documents, sculpture, and works of art.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab618a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible entity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “eligible entity” means a Federal entity, State, local, or tribal government, educational institution, or nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab618b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Historic property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “historic property” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s300308"},"text":"section 300308 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab618c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308901/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nationally significant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “nationally significant”, in reference to a collection or historic property, means a collection or historic property that meets the applicable criteria for national significance, in accordance with regulations promulgated by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302103"},"text":"section 302103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab618d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308901/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “program” means the Save America’s Treasures Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s308902/a"},"text":"section 308902(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab618e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308901/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Secre