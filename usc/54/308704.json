{"tag":"section","attrib":{"id":"idefab6146-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704"},"text":null,"children":[{"tag":"num","attrib":{"value":"308704"},"text":"§ 308704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefab6147-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Funds From Sale and Scrapping of Obsolete Vessels.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab6148-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the amount of funds credited in a fiscal year to the Vessel Operations Revolving Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50301/a"},"text":"section 50301(a) of title 46","children":[],"tail":" that is attributable to the sale of obsolete vessels in the National Defense Reserve Fleet that are scrapped or sold under section 57102, 57103, or 57104 of title 46 shall be available until expended as follows:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefab6149-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fifty percent shall be available to the Administrator of the Maritime Administration for such acquisition, maintenance, repair, reconditioning, or improvement of vessels in the National Defense Reserve Fleet as is authorized under other Federal law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab614a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Twenty five percent shall be available to the Administrator of the Maritime Administration for the payment or reimbursement of expenses incurred by or on behalf of State maritime academies or the United States Merchant Marine Academy for facility and training ship maintenance, repair, and modernization, and for the purchase of simulators and fuel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab614b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The remainder shall be available to the Secretary to carry out the Program, as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab614c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) does not apply to amounts credited to the Vessel Operations Revolving Fund before ","children":[{"tag":"date","attrib":{"date":"1994-07-01"},"text":"July 1, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab614d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Amounts for Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab614e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefab614f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B) and paragraph (2), of the amounts available each fiscal year for the Program under subsection (a)(1)(C)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefab6150-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent shall be used for grants under section 308703(b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefab6151-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent shall be used for grants under section 308703(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6152-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Set aside.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idefab6153-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less than 25 percent of the amounts available each fiscal year for the Program under subsection (a)(1)(C) shall be used for the preservation and presentation to the public of the maritime heritage property of the Maritime Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefab6154-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Direct transfers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide amounts used for the preservation and presentation to the public of the maritime heritage property of the Maritime Administration through direct transfers to the Maritime Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefab6155-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administrator may waive the application of clause (i) for any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab6156-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative expenses.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefab6157-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not more than 15 percent or $500,000, whichever is less, of the amount available for the Program under subsection (a)(1)(C) for a fiscal year may be used for expenses of administering the Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6158-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amount available under subparagraph (A) for a fiscal year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefab6159-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one half shall be allocated to the National Trust for expenses incurred in administering grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s308703/b"},"text":"section 308703(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefab615a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one half shall be allocated as appropriate by the Secretary to the Service and participating State Historic Preservation Officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab615b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disposal of Vessels.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab615c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall dispose (by sale or by purchase of disposal services) of all vessels described in paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefab615d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with a priority system for disposing of vessels, as determined by the Secretary, that shall include provisions requiring the Maritime Administration to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefab615e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dispose of all deteriorated high priority ships that are available for disposal within 12 months of their designation as available for disposal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefab615f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give priority to the disposition of those vessels that pose the most significant danger to the environment or cost the most to maintain;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6160-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the manner that provides the best value to the Federal Government, except in any case in which obtaining the best value would require towing a vessel and the towing poses a serious threat to the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6161-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the plan of the Department of Transportation for disposal of those vessels and requirements under sections 57102 to 57104 of title 46.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab6162-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description of vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The vessels referred to in paragraph (1) are the vessels in the National Defense Reserve Fleet after ","children":[{"tag":"date","attrib":{"date":"1994-07-01"},"text":"July 1, 1994","children":[],"tail":", that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefab6163-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not assigned to the Ready Reserve Force component of the National Defense Reserve Fleet; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6164-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not specifically authorized or required by statute to be used for a particular purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab6165-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Available Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts available under this section shall not be considered in any determination of the amounts available to the Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefab6166-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3241"},"text":"128 Stat. 3241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3507/a"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3507(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2777"},"text":"130 Stat. 2777","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefab6167-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefab6168-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefab6169-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"308704","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s5405"},"text":"16 U.S.C. 5405","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/103/451/s6"},"text":"Pub. L. 103–451, § 6","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/4776"},"text":"108 Stat. 4776","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/85/dA/tX/s1026/c"},"text":"Pub. L. 105–85, div. A, title X, § 1026(c)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/111/1878"},"text":"111 Stat. 1878","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXV/s3502/a"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXV, § 3502(a)]","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–490; "},{"tag":"html:a","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3514"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3514","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/122/594"},"text":"122 Stat. 594","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/111/84/dC/tXXXV/s3509"},"text":"Pub. L. 111–84, div. C, title XXXV, § 3509","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/123/2721"},"text":"123 Stat. 2721","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/n"},"text":"Pub. L. 111–383, div. A, title X, § 1075(n)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/124/4378"},"text":"124 Stat. 4378","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5405/b/2"},"text":"16 U.S.C. 5405(b)(2)","children":[],"tail":" is omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1)(C), before subparagraph (i), the words “whether collected before or after ","children":[{"tag":"date","attrib":{"date":"2009-10-28"},"text":"October 28, 2009","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefab616a-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefab616b-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3507/a/1"},"text":"Pub. L. 114–328, § 3507(a)(1)","children":[],"tail":", amended subpar. (C) generally. Prior to amendment, subpar. (C) related to availability of remainder of funds."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3507/a/2"},"text":"Pub. L. 114–328, § 3507(a)(2)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) related to use of amounts for certain projects under the National Maritime Heritage Grants Program."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefab616c-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefab616d-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program on Export of Obsolete Vessels for Dismantlement and Recycling","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dC/tXXXV/s3504/c"},"text":"Pub. L. 107–314, div. C, title XXXV, § 3504(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2755"},"text":"116 Stat. 2755","children":[],"tail":", 2756, provided that the Secretary of Transportation, Secretary of State, and Administrator of the Environmental Protection Agency would jointly carry out, during fiscal year 2003, one or more pilot programs through the Maritime Administration to explore the feasibility and advisability of various alternatives for exporting obsolete vessels in the National Defense Reserve Fleet for purposes of the dismantlement and recycling of such vessels and the Secretary of Transportation shall submit to Congress a report on the pilot programs including a description of their activities and recommendations for further legislative or administrative action as the Secretary considers appropriate."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefab616e-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Scrapping of National Defense Reserve Fleet Vessels","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXV/s3502/b"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXV, § 3502(b)–(f)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–490 to 1654A–492, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3505/a"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3505(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3551"},"text":"119 Stat. 3551","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dC/tXXXV/s3504"},"text":"Pub. L. 112–81, div. C, title XXXV, § 3504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1717"},"text":"125 Stat. 1717","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dC/tXXXV/s3502"},"text":"Pub. L. 112–239, div. C, title XXXV, § 3502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2222"},"text":"126 Stat. 2222","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dC/tXXXV/s3502"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection of Scrapping Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may scrap obsolete vessels pursuant to section 6(c)(1) of the National Maritime Heritage Act of 1994 ([former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5405/c/1"},"text":"16 U.S.C. 5405(c)(1)","children":[],"tail":") [see "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s308704/c/1"},"text":"54 U.S.C. 308704(c)(1)","children":[],"tail":"] through qualified scrapping facilities, using the most expeditious scrapping methodology and location practicable. Scrapping facilities shall be selected under that section on a best value basis consistent with the Federal Acquisition Regulation, as in effect on the date of contract award, without any predisposition toward foreign or domestic facilities taking into consideration, among other things, the ability of facilities to scrap vessels—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least cost to the Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a timely manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" giving consideration to worker safety and the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that minimizes the geographic distance that a vessel must be towed when towing a vessel poses a serious threat to the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comprehensive Management Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement to develop plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall prepare, publish, and submit to the Congress by not later than 180 days after the date of the enactment of this Act [probably should be “this subsection”, ","children":[{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":"] a comprehensive plan for management of the vessel disposal program of the Maritime Administration in accordance with the recommendations made in the Government Accountability Office in report number GAO–05–264, dated March 2005."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a strategy and implementation plan for disposal of obsolete National Defense Reserve Fleet vessels (including vessels added to the fleet after the enactment of this paragraph) in a timely manner, maximizing the use of all available disposal methods, including dismantling, use for artificial reefs, donation, and Navy training exercises;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and describe the funding and other resources necessary to implement the plan, and specific milestones for disposal of vessels under the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish performance measures to track progress toward achieving the goals of the program, including the expeditious disposal of ships commencing upon the date of the enactment of this paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a formal decisionmaking framework for the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify external factors that could impede successful implementation of the plan, and describe steps to be taken to mitigate the effects of such factors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation of Management Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement to implement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Secretary shall implement the vessel disposal program of the Maritime Administration in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management plan submitted under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements set forth in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Utilization of domestic sources","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the procurement of services under the vessel disposal program of the Maritime Administration, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use full and open competition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize domestic sources to the maximum extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure to Submit Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Private management contract for disposal of maritime administration vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation, subject to the availability of appropriations, shall promptly award a contract using full and open competition to expeditiously implement all aspects of disposal of obsolete National Defense Reserve Fleet vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection shall apply beginning 180 days after the date of the enactment of this subsection [","children":[{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":"], unless the Secretary of Transportation has submitted to the Congress the comprehensive plan required under subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administrator shall, upon request, provide briefings to the Committee on Transportation and Infrastructure, the Committee on Natural Resources, and the Committee on Armed Services of the House of Representatives, and the Committee on Commerce, Science, and Transportation and the Committee on Armed Services of the Senate, on the progress made in recycling vessels, problems encountered with recycling vessels, issues relating to vessel recycling, and other issues relating to vessel recycling and disposal.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
