{"tag":"section","attrib":{"id":"idefadab1e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312104"},"text":null,"children":[{"tag":"num","attrib":{"value":"312104"},"text":"§ 312104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of trustees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefadab1f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The affairs of the National Trust shall be under the general direction of a board of trustees composed as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadab20-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General, the Secretary, and the Director of the National Gallery of Art, ex officio.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab21-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not fewer than 6 general trustees who shall be citizens of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadab22-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Another Officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General and the Secretary, when it appears desirable in the interest of the conduct of the business of the Board and to such extent as they consider it advisable, may, by written notice to the National Trust, designate any officer of their respective departments to act for them in the discharge of their duties as a member of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadab23-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Trustees.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadab24-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Number and selection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The number of general trustees shall be fixed by the Board and shall be chosen by the members of the National Trust from its members at any regular meeting of the National Trust.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab25-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term of office","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The respective terms of office of the general trustees shall be as prescribed by the Board but in no case shall exceed a period of 5 years from the date of election.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab26-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312104/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Successor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A successor to a general trustee shall be chosen in the same manner and shall have a term expiring 5 years from the date of the expiration of the term for which the predecessor was chosen, except that a successor chosen to fill a vacancy occurring prior to the expiration of a term shall be chosen only for the remainder of that term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadab27-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The chairman of the Board shall be elected by a majority vote of the members of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadab28-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation and Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No compensation shall be paid to the members of the Board for their services as such members, but they shall be reimbursed for travel and actual expenses necessarily incurred by them in attending board meetings and performing other official duties on behalf of the National Trust at the direction of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefadab29-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3249"},"text":"128 Stat. 3249","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefadab2a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefadab2b-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefadab2c-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"312104","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s468b"},"text":"16 U.S.C. 468b","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-26/ch735/s3"},"text":"Oct. 26, 1949, ch. 735, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/928"},"text":"63 Stat. 928","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-07-28/ch255"},"text":"July 28, 1953, ch. 255","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/228"},"text":"67 Stat. 228","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
