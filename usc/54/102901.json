t":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"102901(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s460"},"text":"16 U.S.C. 460","children":[],"tail":null},{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":"–22(d)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/90/401/s5/d"},"text":"Pub. L. 90–401, § 5(d)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 15, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/82/356"},"text":"82 Stat. 356","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/98/506/s2"},"text":"Pub. L. 98–506, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/2338"},"text":"98 Stat. 2338","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
