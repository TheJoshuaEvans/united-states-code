{"tag":"section","attrib":{"id":"idef9d098a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302302"},"text":null,"children":[{"tag":"num","attrib":{"value":"302302"},"text":"§ 302302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9d098b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When Evaluation Should Occcur ","children":[],"tail":null},{"tag":"ref","attrib":{"idref":"fn002018"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002018"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “"},{"tag":"inline","attrib":{},"text":"Occur","children":[],"tail":"”."}],"tail":null},{"tag":"inline","attrib":{},"text":null,"children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Periodically, but not less than every 4 years after the approval of any State program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302301"},"text":"section 302301 of this title","children":[],"tail":", the Secretary, in consultation with the Council on the appropriate provisions of this division, and in cooperation with the State Historic Preservation Officer, shall evaluate the program to determine whether it is consistent with this division."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9d098c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disapproval of Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, at any time, the Secretary determines that a major aspect of a State program is not consistent with this division, the Secretary shall disapprove the program and suspend in whole or in part any contracts or cooperative agreements with the State and the State Historic Preservation Officer under this division, until the program is consistent with this division, unless the Secretary determines that the program will be made consistent with this division within a reasonable period of time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9d098d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oversight","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in consultation with State Historic Preservation Officers, shall establish oversight methods to ensure State program consistency and quality without imposing undue review burdens on State Historic Preservation Officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9d098e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Fiscal Audit and Management System.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9d098f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302302/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Substitution for comparable federal systems","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the discretion of the Secretary, a State system of fiscal audit and management may be substituted for comparable Federal systems so long as the State system—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9d0990-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302302/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes and maintains substantially similar accountability standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9d0991-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302302/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for independent professional peer review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d0992-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302302/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fiscal audits and review by secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9d0993-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302302/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may conduct periodic fiscal audits of State programs approved under this subdivision as needed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9d0994-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302302/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall ensure that the programs meet applicable accountability standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9d0995-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3195"},"text":"128 Stat. 3195","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9d0996-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9d0997-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9d0998-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Se