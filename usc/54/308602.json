{"tag":"section","attrib":{"id":"idefab60cd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308602"},"text":null,"children":[{"tag":"num","attrib":{"value":"308602"},"text":"§ 308602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States African-American Burial Grounds Preservation Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefab60ce-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish within the Service, in accordance with this chapter, a program to be known as the “United States African-American Burial Grounds Preservation Program”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab60cf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties of Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the Program, the Secretary, in consultation with the National Trust for Historic Preservation and members of the African-American heritage community, shall develop a program for the provision of grants in accordance with section 308603(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab60d0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308602/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Donations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may accept monetary donations to further the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab60d1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308602/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consent of Private Property Owner Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Burial grounds shall only be considered for a grant under the Program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab60d2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308602/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the consent of the property owner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab60d3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308602/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of an individual, landowner, private or nonprofit organization, State, Tribal, or local government, or other entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefab60d4-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tVI/s643/a"},"text":"Pub. L. 117–328, div. DD, title VI, § 643(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5613"},"text":"136 Stat. 5613","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
