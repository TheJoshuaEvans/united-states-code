{"tag":"section","attrib":{"id":"idef9f79dd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302504"},"text":null,"children":[{"tag":"num","attrib":{"value":"302504"},"text":"§ 302504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of certified local governments in National Register nominations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9f79de-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before a property within the jurisdiction of a certified local government may be considered by a State to be nominated to the Secretary for inclusion on the National Register, the State Historic Preservation Officer shall notify the owner, the applicable chief local elected official, and the local historic preservation commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9f79df-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The local historic preservation commission, after reasonable opportunity for public comment, shall prepare a report as to whether the property, in the Commission’s opinion, meets the criteria of the National Register. Within 60 days of notice from the State Historic Preservation Officer, the chief local elected official shall transmit the report of the commission and the recommendation of the local official to the State Historic Preservation Officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9f79e0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9f79e1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Property nominated to national register","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), after receipt of the report and recommendation, or if no report and recommendation are received within 60 days, the State shall make the nomination pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302104"},"text":"section 302104 of this title","children":[],"tail":". The State may expedite the process with the concurrence of the certified local government."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9f79e2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Property not nominated to national register","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If both the commission and the chief local elected official recommend that a property not be nominated to the National Register, the State Historic Preservation Officer shall take no further action, unless, within 30 days of the receipt of the recommendation by the State Historic Preservation Officer, an appeal is filed with the State. If an appeal is filed, the State shall follow the procedures for making a nomination pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302104"},"text":"section 302104 of this title","children":[],"tail":". Any report and recommendations made under this section shall be included with any nomination submitted by the State to the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9f79e3-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3198"},"text":"128 Stat. 3198","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9f79e4-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9f79e5-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9f79e6-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"302504","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470a/c/2"},"text":"16 U.S.C. 470a(c)(2)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/665/tI/s101/c/2"},"text":"Pub. L. 89–665, title I, § 101(c)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/915"},"text":"80 Stat. 915","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/91/383/s11"},"text":"Pub. L. 91–383, § 11","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/94/458/s2"},"text":"Pub. L. 94–458, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 7, 1976","children":[],"tail":", "},{"tag":"ht