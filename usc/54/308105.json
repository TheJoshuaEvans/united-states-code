{"tag":"section","attrib":{"id":"idefa8f03b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308105"},"text":null,"children":[{"tag":"num","attrib":{"value":"308105"},"text":"§ 308105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Battlefield restoration grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa8f03c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a battlefield restoration grant program (referred to in this section as the “program”) under which the Secretary may provide grants to States, Tribes, local governments, and nonprofit organizations for projects that restore day-of-battle conditions on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa8f03d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land preserved and protected under the battlefield acquisition grant program established under section 308103(b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa8f03e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" battlefield land that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa8f03f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308105/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by a State, Tribe, local government, or nonprofit organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa8f040-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308105/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referred to in the Battlefield Reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f041-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Sites","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make grants under this section for Revolutionary War, War of 1812, and Civil War battlefield sites—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa8f042-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible for assistance under the battlefield acquisition grant program established under section 308103(b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa8f043-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on battlefield land that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa8f044-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308105/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by a State, Tribe, local government, or nonprofit organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa8f045-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308105/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referred to in battlefield reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f046-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of a restoration project funded through a grant provided under the program shall be not more than 50 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f047-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restoration Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All restoration work carried out through a grant awarded under the program shall be performed in accordance with the Secretary of the Interior’s Standards for the Treatment of Historic Properties under part 68 of title 36, Code of Federal Regulations (or successor regulations).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f048-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308105/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Secretary to provide grants under this section $1,000,000 for each of fiscal years 2020 through 2028.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa8f049-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tVII/s703/a"},"text":"Pub. L. 116–94, div. P, title VII, § 703(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3196"},"text":"133 Stat. 3196","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s157/d"},"text":"Pub. L. 118–234, title I, § 157(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2879"},"text":"138 Stat. 2879","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa8f04a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa8f04b-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefa8f04c-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s157/d/1"},"text":"Pub. L. 118–234, § 157(d)(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “The Secretary shall establish a battlefield restoration grant program (referred to in this section as the “program”) under which the Secretary may provide grants to States, Tribes, local governments, and nonprofit organizations for projects that restore day-of-battle conditions on land preserved under the battlefield acquisition grant program established under section 308103(b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s157/d/2"},"text":"Pub. L. 118–234, § 157(d)(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “The Secretary may make grants under this section for Revolutionary War, War of 1812, and Civil War battlefield sites eligible for assistance under the battlefield acquisition grant program established under section 308103(b).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
