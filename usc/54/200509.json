{"tag":"section","attrib":{"id":"idef9a9773-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200509"},"text":null,"children":[{"tag":"num","attrib":{"value":"200509"},"text":"§ 200509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9a9774-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recipient of assistance under this chapter shall keep such records as the Secretary shall prescribe, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9a9775-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200509/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" records that disclose—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9a9776-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200509/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and disposition of project undertakings in connection with which assistance under this chapter is given or used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9a9777-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200509/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and nature of the portion of the cost of the project or undertaking that is supplied by other sources; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9a9778-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200509/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other records as will facilitate an effective audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9a9779-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary and the Comptroller General shall have access for the purpose of audit and examination to any records of the recipient that are pertinent to assistance received under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9a977a-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3186"},"text":"128 Stat. 3186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9a977b-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9a977c-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9a977d-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":