{"tag":"section","attrib":{"id":"idef9121df-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103503"},"text":null,"children":[{"tag":"num","attrib":{"value":"103503"},"text":"§ 103503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summary to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide with the submission of the President’s annual budget a summary of the status and funding of signature projects and programs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef9121e0-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/tI/s101/a"},"text":"Pub. L. 114–289, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1484"},"text":"130 Stat. 1484","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
