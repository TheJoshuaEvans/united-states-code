{"tag":"section","attrib":{"id":"idefab60c8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308601"},"text":null,"children":[{"tag":"num","attrib":{"value":"308601"},"text":"§ 308601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab60c9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308601/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Burial ground","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “burial ground” means any natural or prepared physical location, whether originally below, on, or above the surface of the earth, into which human remains are deposited as a part of the death rite or ceremony of a culture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab60ca-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308601/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Historic","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “historic”, with respect to a property, means a property that can reasonably be considered to date back at least 50 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab60cb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308601/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Program” means the United States African-American Burial Grounds Preservation Program established under section 308602(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefab60cc-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tVI/s643/a"},"text":"Pub. L. 117–328, div. DD, title VI, § 643(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5613"},"text":"136 Stat. 5613","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
