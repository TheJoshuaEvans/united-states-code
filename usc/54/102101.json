{"tag":"section","attrib":{"id":"idef8c6691-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102101"},"text":null,"children":[{"tag":"num","attrib":{"value":"102101"},"text":"§ 102101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8c6692-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8c6693-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No lease or grant of a privilege that interferes with free access","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No natural curiosity, wonder, or object of interest shall be leased or granted to anyone on such terms as to interfere with free access by the public to any System unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c6694-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for grazing livestock","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, under such regulations and on such terms as the Secretary may prescribe, may grant the privilege to graze livestock within a System unit when, in the Secretary’s judgment, the use is not detrimental to the primary purpose for which the System unit was created. This paragraph does not apply to Yellowstone National Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c6695-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advertising and Competitive Bids Not Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may grant privileges and enter into leases described in subsection (a), and enter into related contracts with responsible persons, firms, or corporations, without advertising and without securing competitive bids.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c6696-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assignment or Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No contract, lease, or privilege described in subsection (a) or (b) that is entered into or granted shall be assigned or transferred by the grantee, lessee, or licensee without the prior written approval of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8c6697-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3152"},"text":"128 Stat. 3152","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8c6698-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef8c6699-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef8c669a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"102101","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s3"},"text":"16 U.S.C. 3","children":[],"tail":" (last sentence)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-08-25/ch408/s3"},"text":"Aug. 25, 1916, ch. 408, § 3","children":[],"tail":" (last sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1928-03-07/ch137/s1"},"text":"Mar. 7, 1928, ch. 137, § 1","children":[],"tail":" (matter relating to "},{"tag":"html:a","attrib":{"href":"/us/act/1916-08-25/s3"},"text":"section 3 of the Act of August 25, 1916","children":[],"tail":", in 12th undesignated par. under heading “"},{"tag":"html:span","attrib":{},"text":"NATIONAL PARK SERVICE","children":[],"tail":"”), "},{"tag":"html:a","attrib":{"href":"/us/stat/45/235"},"text":"45 Stat. 235","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/85/434"},"text":"Pub. L. 85–434","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"May 29, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/152"},"text":"72 Stat. 152","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/391/tIV/s415/b/1"},"text":"Pub. L. 105–391, title IV, § 415(b)(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/3515"},"text":"112 Stat. 3515","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the word “rented” is omitted as included in “leases”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (c), the word “permit” is omitted for consistency because a permit is not mentioned earlier in the source provision.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “lessee” is substituted for “permittees” for consistency in the section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
