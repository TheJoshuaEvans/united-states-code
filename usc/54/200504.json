{"tag":"section","attrib":{"id":"idef9a9739-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504"},"text":null,"children":[{"tag":"num","attrib":{"value":"200504"},"text":"§ 200504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery action programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9a973a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evidence of Local Commitment to Ongoing Programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a requirement for project approval, local governments applying for assistance under this chapter shall submit to the Secretary evidence of their commitments to ongoing planning, rehabilitation, service, operation, and maintenance programs for their park and recreation systems. These commitments will be expressed in local park and recreation recovery action programs that maximize coordination of all community resources, including other federally supported urban development and recreation programs. During an initial interim period to be established by regulations under this chapter, this requirement may be satisfied by local government submissions of preliminary action programs that briefly define objectives, priorities, and implementation strategies for overall system recovery and maintenance and commit the applicant to a scheduled program development process. Following this interim period, all local applicants shall submit to the Secretary, as a condition of eligibility, a 5-year action program for park and recreation recovery that satisfactorily demonstrates—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9a973b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" systematic identification of recovery objectives, priorities, and implementation strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9a973c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate planning for rehabilitation of specific recreation areas and facilities, including projections of the cost of proposed projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9a973d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity and commitment to ensure that facilities provided or improved under this chapter shall continue to be adequately maintained, protected, staffed, and supervised;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9a973e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intention to maintain total local public outlays for park and recreation purposes at levels at least equal to those in the year preceding that in which grant assistance is sought except in any case where a reduction in park and recreation outlays is proportionate to a reduction in overall spending by the applicant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9a973f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relationship of the park and recreation recovery program to overall community development and urban revitalization efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9a9740-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuing Planning Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Where appropriate, the Secretary may encourage local governments to meet action program requirements through a continuing planning process that includes periodic improvements and updates in action program submissions to eliminate identified gaps in program information and policy development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9a9741-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Action programs shall address, but are not limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9a9742-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" rehabilitation of existing recreational areas and facilities, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9a9743-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general systemwide renovation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9a9744-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special rehabilitation requirements for recreational areas and facilities in areas of high population concentration and economic distress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9a9745-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restoration of outstanding or unique structures, landscaping, or similar features in parks of historical or architectural significance; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9a9746-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" local commitments to innovative and cost-effective programs and projects at the neighborhood level to augment recovery of park and recreation systems, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9a9747-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recycling of abandoned schools and other public buildings for recreational purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9a9748-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiple use of operating educational and other public buildings, purchase of recreation services on a contractual basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9a9749-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of mobile facilities and recreational, cultural, and educational programs or other innovative approaches to improving access for neighborhood residents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9a974a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integration of recovery program with federally assisted projects to maximize recreational opportunities through conversion of abandoned railroad and highway rights of way, waterfront, and other redevelopment efforts and such other federally assisted projects as may be appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9a974b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conversion of recreation use of street space, derelict land, and other public land not now designated for neighborhood recreational use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9a974c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of various forms of compensated and uncompensated land regulation, tax inducements, or other means to encourage the private sector to provide neighborhood park and recreation facilities and programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9a974d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication in Federal Register","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish and publish in the Federal Register requirements for preparation, submission, and updating of local park and recreation recovery action programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9a974e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility for At-Risk Youth Recreation Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be eligible to receive at-risk youth recreation grants a local government shall amend its 5-year action program to incorporate the goal of reducing crime and juvenile delinquency and to provide a description of the implementation strategies to achieve this goal. The plan shall also address how the local government is coordinating its recreation programs with crime prevention efforts of law enforcement, juvenile corrections, and youth social service agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9a974f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200504/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matching Recovery Action Program Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide up to 50 percent matching recovery action program grants to eligible local governments for program development and planning specifically to meet the objectives of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9a9750-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3183"},"text":"128 Stat. 3183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9a9751-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9a9752-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9a9753-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"200504","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s2506"},"text":"16 U.S.C. 2506","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/625/tX/s1007"},"text":"Pub. L. 95–625, title X, § 1007","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/3541"},"text":"92 Stat. 3541","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/322/tIII"},"text":"Pub. L. 103–322, title III","children":[],"tail":", §§ 31504, "},{"tag":"html:span","attrib":{},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/1889"},"text":"108 Stat. 1889","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the word “areas” is substituted for “sites” for consistency with the defined term and with the new chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
