{"tag":"section","attrib":{"id":"idef984e3f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200503"},"text":null,"children":[{"tag":"num","attrib":{"value":"200503"},"text":"§ 200503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rehabilitation grants and innovation grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef984e40-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matching Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide 70 percent matching rehabilitation grants and innovation grants directly to eligible general purpose local governments on the Secretary’s approval of applications for the grants by the chief executive officials of those governments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984e41-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An innovation grant should be closely tied to goals, priorities, and implementation strategies expressed in local park and recreation recovery action programs, with particular regard to the special considerations listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s200504/c/2"},"text":"section 200504(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984e42-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If consistent with an approved application, a grant recipient may transfer a rehabilitation grant or innovation grant in whole or in part to an independent special purpose local government, private nonprofit agency, or county or regional park authority if the assisted recreation area or facility owned or managed by the transferree ","children":[{"tag":"ref","attrib":{"idref":"fn002017"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002017"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “transferee”."}],"tail":" offers recreation opportunities to the general population within the jurisdictional boundaries of the grant recipient."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984e43-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Payments may be made only for a rehabilitation project or innovation project that has been approved by the Secretary. Payments may be made from time to time in keeping with the rate of progress toward the satisfactory completion of the project, except that the Secretary, when appropriate, may make advance payments on an approved rehabilitation project or innovation project in an amount not to exceed 20 percent of the total project cost.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984e44-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200503/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modification of Project","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may authorize modification of an approved project only when a grant recipient adequately demonstrates that the modification is necessary because of circumstances not foreseeable at the time at which the project was proposed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef984e45-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3183"},"text":"128 Stat. 3183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9a9736-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9a9737-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9a9738-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"200503","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s2505"},"text":"16 U.S.C. 2505","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/625/tX/s1006"},"text":"Pub. L. 95–625, title X, § 1006","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/3541"},"text":"92 Stat. 3541","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “chief executive officials” are substituted for “chief executives” for consistency in the new title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “At the discretion of such applicants” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
