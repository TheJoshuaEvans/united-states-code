{"tag":"section","attrib":{"id":"idefa1c3cd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101"},"text":null,"children":[{"tag":"num","attrib":{"value":"304101"},"text":"§ 304101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; vacancies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa1c3ce-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established as an independent agency of the United States Government an Advisory Council on Historic Preservation, which shall be composed of the following members:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa1c3cf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Chairman appointed by the President selected from the general public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3d0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3d1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Architect of the Capitol.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3d2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture and the heads of 7 other agencies of the United States (other than the Department of the Interior), the activities of which affect historic preservation, designated by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3d3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One Governor appointed by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3d4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One mayor appointed by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3d5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President of the National Conference of State Historic Preservation Officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3d6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The General Chairman of the National Association of Tribal Historic Preservation Officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3d7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman of the National Trust.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3d8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four experts in the field of historic preservation appointed by the President from architecture, history, archeology, and other appropriate disciplines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3d9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members from the general public, appointed by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3da-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member of an Indian tribe or Native Hawaiian organization who represents the interests of the Indian tribe or Native Hawaiian organization of which he or she is a member, appointed by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa1c3db-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Substitutes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Council specified in paragraphs (2) to (5) and (7) through (9) of subsection (a) may designate another officer of the department, agency, or organization to serve on the Council instead of the member, except that, in the case of paragraphs (2) and (4), no officer other than an Assistant Secretary or an officer having major department-wide or agency-wide responsibilities may be designated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa1c3dc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term of Office","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Council appointed under paragraphs (10) through (12) of subsection (a) shall serve for a term of 4 years from the expiration of the term of the member’s predecessor. The members appointed under paragraphs (5) and (6) shall serve for the term of their elected office but not in excess of 4 years. An appointed member, other than the Chairman of the Council, may not serve more than 2 terms. An appointed member whose term has expired shall serve until that member’s successor has been appointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa1c3dd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vacancy in the Council shall not affect its powers, but shall be filled, not later than 60 days after the vacancy commences, in the same manner as the original appointment (and for the balance of the unexpired term).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa1c3de-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa1c3df-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After ","children":[{"tag":"date","attrib":{"date":"2017-01-20"},"text":"January 20, 2017","children":[],"tail":", the Chairman shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa1c3e0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed by the President, by and with the advice and consent of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa1c3e1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve at the will of the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa1c3e2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve full time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa1c3e3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be compensated at the rate provided for Level V of the Executive Schedule Pay Rates under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3e4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman shall serve for a term of 4 years and may be reappointed once, for a total of not more than 8 years of service as Chairman, except that a Chairman whose appointment has expired under this paragraph shall serve until his or her successor has been appointed. The term of a Chairman shall start (regardless of actual appointment date) on January 20 after each general Presidential election. The first Chairman appointed after the date of enactment of this paragraph shall have a first term commencing on ","children":[{"tag":"date","attrib":{"date":"2017-01-20"},"text":"January 20, 2017","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2021-01-19"},"text":"January 19, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3e5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairmen before the first appointment of a Chairman in accordance with paragraph (1) of this subsection shall receive $100 per diem when engaged in the performance of the duties of the Council, and shall receive reimbursement for necessary traveling and subsistence expenses incurred by them in the performance of the duties of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa1c3e6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Vice Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall designate a Vice Chairman from the members appointed under paragraph (5), (6), (10), or (11) of subsection (a). The Vice Chairman shall perform the functions of the Chairman during the absence or disability of the Chairman or when the office is vacant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa1c3e7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304101/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quorum","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Thirteen members of the Council shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa1c3e8-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3209"},"text":"128 Stat. 3209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/289/tV/s501/a"},"text":"Pub. L. 114–289, title V, § 501(a)","children":[],"tail":"–(c)(1), "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1489"},"text":"130 Stat. 1489","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa1c3e9-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa1c3ea-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa1c3eb-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"304101","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470i"},"text":"16 U.S.C. 470i","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/665/tII/s201"},"text":"Pub. L. 89–665, title II, § 201","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/917"},"text":"80 Stat. 917","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/91/243/s1/b"},"text":"Pub. L. 91–243, § 1(b)","children":[],"tail":" through (e), "},{"tag":"html:span","attrib":{},"text":"May 9, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/204"},"text":"84 Stat. 204","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/93/54/s1/c"},"text":"Pub. L. 93–54, § 1(c)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 1, 1973","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/87/139"},"text":"87 Stat. 139","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/94/422/tII/s201/5"},"text":"Pub. L. 94–422, title II, § 201(5)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 28, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/1320"},"text":"90 Stat. 1320","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/515/tIII/s301/a"},"text":"Pub. L. 96–515, title III, § 301(a)","children":[],"tail":" through (f), "},{"tag":"html:span","attrib":{},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/2998"},"text":"94 Stat. 2998","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/102/575/tXL"},"text":"Pub. L. 102–575, title XL","children":[],"tail":", §§ 4016, 4019(b), "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/4763"},"text":"106 Stat. 4763","children":[],"tail":", 4765; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/333/dI/tV/s509/c/1"},"text":"Pub. L. 104–333, div. I, title V, § 509(c)(1)","children":[],"tail":", (2), "},{"tag":"html:span","attrib":{},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/4157"},"text":"110 Stat. 4157","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/109/453/s1/d"},"text":"Pub. L. 109–453, § 1(d)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/120/3367"},"text":"120 Stat. 3367","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(9), the words “the disciplines of” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa1c3ec-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefa1c3ed-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this paragraph, referred to in subsec. (e)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289"},"text":"Pub. L. 114–289","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefa1c3ee-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(8) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/s501/a"},"text":"Pub. L. 114–289, § 501(a)","children":[],"tail":", added par. (8) and redesignated former pars. (8) to (11) as (9) to (12), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/s501/c/1/A"},"text":"Pub. L. 114–289, § 501(c)(1)(A)","children":[],"tail":", substituted “and (7) through (9)” for “, (7), and (8)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/s501/c/1/B"},"text":"Pub. L. 114–289, § 501(c)(1)(B)","children":[],"tail":", substituted “under paragraphs (10) through (12)” for “under paragraphs (1) and (9) to (11)” and “An appointed member, other than the Chairman of the Council, may not serve more than 2 terms.” for “An appointed member may not serve more than 2 terms.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/s501/b/2"},"text":"Pub. L. 114–289, § 501(b)(2)","children":[],"tail":", added subsec. (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/s501/b/1"},"text":"Pub. L. 114–289, § 501(b)(1)","children":[],"tail":", (3), (c)(1)(C), redesignated subsec. (e) as (f) and substituted “paragraph (5), (6), (10), or (11)” for “paragraph (5), (6), (9), or (10)” and “shall perform the functions” for “may act in place”. Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/s501/b/1"},"text":"Pub. L. 114–289, § 501(b)(1)","children":[],"tail":", (c)(1)(D), redesignated subsec. (f) as (g) and substituted “Thirteen members” for “Twelve members”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
