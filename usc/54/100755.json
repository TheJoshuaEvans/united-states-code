{"tag":"section","attrib":{"id":"idef7e0e6b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100755"},"text":null,"children":[{"tag":"num","attrib":{"value":"100755"},"text":"§ 100755.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7e0e6c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100755/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section and sections 100501, 100901(d) to (h), 101302(b)(2), 101901(c), and 102711 of this title, and the various authorities relating to the administration and protection of System units, including the provisions of law listed in subsection (b), shall, to the extent that those provisions are not in conflict with any such specific provision, be applicable to System units, and any reference in any of these provisions to a System unit does not limit those provisions to that System unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7e0e6d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100755/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicable Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of law referred to in subsection (a) are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7e0e6e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100755/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 100101(a), chapter 1003, sections 100751(a), 100752, 100753, 101101, 101102, 101511, 102101, 102712, 102901, 104905, and 104906, and chapter 2003 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0e6f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100755/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1911-03-04"},"text":"March 4, 1911","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s961"},"text":"43 U.S.C. 961","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0e70-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100755/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 3201 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7e0e71-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3112"},"text":"128 Stat. 3112","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7e0e72-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef7e0e73-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef7e0e74-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"ta