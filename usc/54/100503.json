{"tag":"section","attrib":{"id":"idef76e346-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100503"},"text":null,"children":[{"tag":"num","attrib":{"value":"100503"},"text":"§ 100503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Five-year strategic plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef76e347-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Strategic and Performance Plans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each System unit shall prepare and make available to the public a 5-year strategic plan and an annual performance plan. The plans shall reflect the Service policies, goals, and outcomes represented in the Service-wide strategic plan prepared pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef76e348-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Budget.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef76e349-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As a part of the annual performance plan for a System unit prepared pursuant to subsection (a), following receipt of the appropriation for the unit from the Operations of the National Park System account (but not later than January 1 of each year), the superintendent of the System unit shall develop and make available to the public the budget for the current fiscal year for that System unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef76e34a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The budget shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef76e34b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100503/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding allocations for resource preservation (including resource management), visitor services (including maintenance, interpretation, law enforcement, and search and rescue), and administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef76e34c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100503/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocations into each of the categories in subparagraph (A) of all funds retained from fees collected for that year, including special use permits, concession franchise fees, and recreation use and entrance fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef76e34d-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[