{"tag":"section","attrib":{"id":"idef9d0941-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302103"},"text":null,"children":[{"tag":"num","attrib":{"value":"302103"},"text":"§ 302103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria and regulations relating to National Register, National Historic Landmarks, and World Heritage List","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with national historical and archeological associations, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9d0942-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish criteria for properties to be included on the National Register and criteria for National Historic Landmarks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d0943-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promulgate regulations for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9d0944-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302103/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nominating properties for inclusion on, and removal from, the National Register and the recommendation of properties by certified local governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9d0945-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302103/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designating properties as National Historic Landmarks and removing that designation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9d0946-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302103/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considering appeals from recommendations, nominations, removals, and designations (or any failure or refusal by a nominating authority to nominate or designate);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9d0947-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302103/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nominating historic property for inclusion in the World Heritage List in accordance with the World Heritage Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9d0948-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302103/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making determinations of eligibility of properties for inclusion on the National Register; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9d0949-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302103/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifying the owner of a property, any appropriate local governments, and the general public, when the property is being considered for inclusion on the National Register, for designation as a National Historic Landmark, or for nomination to the World Heritage List.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ide