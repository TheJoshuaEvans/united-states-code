":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/665/s1/a"},"text":"Pub. L. 89–665, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/915"},"text":"80 Stat. 915","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/515/tI/s101/a"},"text":"Pub. L. 96–515, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2987"},"text":"94 Stat. 2987","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/515/tI/s101/a"},"text":"“This Act [see Tables for classification] may be cited as the ‘National Historic Preservation Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef76e30d-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1964 Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/578/tI/s1/a"},"text":"Pub. L. 88–578, title I, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-03"},"text":"Sept. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/897"},"text":"78 Stat. 897","children":[],"tail":", provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/88/578/tI/s1/a"},"text":"“This Act [see Tables for classification] may be cited as the ‘Land and Water Conservation Fund Act of 1965’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef76e30e-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1916 Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-25/ch408/s5"},"text":"Act Aug. 25, 1916, ch. 408, § 5","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/108/352/s10/a"},"text":"Pub. L. 108–352, § 10(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-21"},"text":"Oct. 21, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1397"},"text":"118 Stat. 1397","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/352/s10/a"},"text":"“This Act [see Tables for classification] may be cited as the ‘National Park Service Organic Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef76e30f-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Special Events at National Mall","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/108/tI/s145"},"text":"Pub. L. 108–108, title I, § 145","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-10"},"text":"Nov. 10, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1280"},"text":"117 Stat. 1280","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/108/tI/s145"},"text":"“None of the funds appropriated or otherwise made available by this or any other Act, hereafter enacted, may be used to permit the use of the National Mall for a special event, unless the permit expressly prohibits the erection, placement, or use of structures and signs bearing commercial advertising. The Secretary may allow for recognition of sponsors of special events: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the size and form of the recognition shall be consistent with the special nature and sanctity of the Mall and any lettering or design identifying the sponsor shall be no larger than one-third the size of the lettering or design identifying the special event. In approving special events, the Secretary shall ensure, to the maximum extent practicable, that public use of, and access to the Mall is not restricted. For purposes of this section, the term ‘special event’ shall have the meaning given to it by section 7.96(g)(1)(ii) of title 36, Code of Federal Regulations.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef76e310-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Park Police Drug Enforcement Supplemental Authority Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tV"},"text":"Pub. L. 99–570, title V","children":[],"tail":", subtitle B (§§ 5051, 5052), "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-156"},"text":"100 Stat. 3207–156","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6254/d/2"},"text":"Pub. L. 100–690, title VI, § 6254(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4365"},"text":"102 Stat. 4365","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/690/tVI/s6254/d/2"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5051"},"text":"“SEC. 5051.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This subtitle may be cited as the ‘National Park Police Drug Enforcement Supplemental Authority Act’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5052"},"text":"“SEC. 5052.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NATIONAL PARK AUTHORIZATION.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“In order to improve Federal law enforcement activities relating to the use and production of narcotics and controlled substances in National Park System units, from amounts appropriated there shall be made available to the Secretary of the Interior, in addition to sums made available under other authority of law, $3,000,000 for fiscal year 1989, and for each fiscal year thereafter, to be used for the employment and training of officers or employees of the Department of the Interior designated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/act/1970-08-18/s10/b"},"text":"section 10(b) of the Act of August 18, 1970","children":[],"tail":" ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1a–6"},"text":"16 U.S.C. 1a–6","children":[],"tail":" [see "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s102701"},"text":"54 U.S.C. 102701","children":[],"tail":"]), for equipment and facilities to be used by such personnel, and for expenses related to such employment, training, equipment, and facilities.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef76e311-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/578"},"text":"Pub. L. 88–578","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/578/tI/s1/b"},"text":"Pub. L. 88–578, title I, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-03"},"text":"Sept. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/897"},"text":"78 Stat. 897","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/88/578/tI/s1/b"},"text":"“The purposes of this Act [see Tables for classification] are to assist in preserving, developing, and assuring accessibility to all citizens of the United States of America of present and future generations and visitors who are lawfully present within the boundaries of the United States of America such quality and quantity of outdoor recreation resources as may be available and are necessary and desirable for individual active participation in such recreation and to strengthen the health and vitality of the citizens of the United States by (1) providing funds for and authorizing Federal assistance to the States in planning, acquisition, and development of needed land and water areas and facilities and (2) providing funds for the Federal acquisition and development of certain lands and other areas.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
