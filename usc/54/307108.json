{"tag":"section","attrib":{"id":"idefa8eff3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307108"},"text":null,"children":[{"tag":"num","attrib":{"value":"307108"},"text":"§ 307108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privately donated funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa8eff4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Projects for Which Funds May Be Used","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In furtherance of the purposes of this division, the Secretary may accept the donation of funds that may be expended by the Secretary for projects to acquire, restore, preserve, or recover data from any property included on the National Register, as long as the project is owned by a State, any unit of local government, or any nonprofit entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8eff5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration of Factors Respecting Expenditure of Funds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa8eff6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307108/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In expending the funds, the Secretary shall give due consideration to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa8eff7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307108/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national significance of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa8eff8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307108/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its historical value to the community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa8eff9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307108/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the imminence of its destruction or loss; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa8effa-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307108/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expressed intentions of the donor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa8effb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307108/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funds available without regard to matching requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds expended under this subsection shall be made available without regard to the matching requirements established by sections 302901 and 302902(b) of this title, but the recipient of the funds shall be permitted to utilize them to match any grants from the Historic Preservation Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8effc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Unobligated Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may transfer unobligated funds previously donated to the Secretary for the purposes of the Service, with the consent of the donor, and any funds so transferred shall be used or expended in accordance with this division.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa8effd-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3232"},"text":"128 Stat. 3232","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa8effe-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa8efff-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa8f000-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{}