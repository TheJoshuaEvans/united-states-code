":"Pub. L. 96–244, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"May 19, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/346"},"text":"94 Stat. 346","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “included” is substituted for “listed” for consistency in the revised subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
