{"tag":"section","attrib":{"id":"idef8c6674-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101934"},"text":null,"children":[{"tag":"num","attrib":{"value":"101934"},"text":"§ 101934.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital improvements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A person or entity awarded a contract under this subchapter shall receive no leasehold surrender interest, as defined in section 101915, in capital improvements constructed under the terms of the contract.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef8c6675-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/tVII/s701"},"text":"Pub. L. 114–289, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1493"},"text":"130 Stat. 1493","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
