{"tag":"section","attrib":{"id":"idef936b4b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103"},"text":null,"children":[{"tag":"num","attrib":{"value":"120103"},"text":"§ 120103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Heritage Area studies and designation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef936b4c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Studies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef936b4d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the availability of appropriations, the Secretary may carry out or review a study to assess the suitability and feasibility of each proposed National Heritage Area for designation as a National Heritage Area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936b4e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preparation.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef936b4f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A study under paragraph (1) may be carried out—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef936b50-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Secretary, in consultation with State and local historic preservation officers, State and local historical societies, State and local tourism offices, and other appropriate organizations and governmental agencies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef936b51-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by interested individuals or entities, if the Secretary certifies that the completed study meets the requirements of paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936b52-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after receiving a study carried out by interested individuals or entities under subparagraph (A)(ii), the Secretary shall review and certify whether the study meets the requirements of paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936b53-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A study under paragraph (1) shall include analysis, documentation, and determinations on whether the proposed National Heritage Area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef936b54-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has an assemblage of natural, historic, and cultural resources that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef936b55-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent distinctive aspects of the heritage of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef936b56-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are worthy of recognition, conservation, interpretation, and continuing use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef936b57-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" would be best managed—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef936b58-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through partnerships among public and private entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef936b59-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by linking diverse and sometimes noncontiguous resources and active communities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936b5a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflects traditions, customs, beliefs, and folklife that are a valuable part of the story of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936b5b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides outstanding opportunities—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef936b5c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conserve natural, historic, cultural, or scenic features; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef936b5d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for recreation and education;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936b5e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains resources that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef936b5f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are important to any identified themes of the proposed National Heritage Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef936b60-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain a degree of integrity capable of supporting interpretation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936b61-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes a diverse group of residents, business interests, nonprofit organizations, and State and local governments that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef936b62-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are involved in the planning of the proposed National Heritage Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef936b63-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have developed a conceptual financial plan that outlines the roles of all participants in the proposed National Heritage Area, including the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef936b64-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have demonstrated significant support for the designation of the proposed National Heritage Area;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936b65-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a potential management entity to work in partnership with the individuals and entities described in subparagraph (E) to develop the proposed National Heritage Area while encouraging State and local economic activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936b66-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a conceptual boundary map that is supported by the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936b67-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef936b68-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each study carried out under paragraph (1), the Secretary shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives a report that describes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef936b69-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any correspondence received by the Secretary demonstrating support for, or opposition to, the establishment of the National Heritage Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef936b6a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings of the study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef936b6b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any conclusions and recommendations of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936b6c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idef936b6d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Studies carried out by the secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to a study carried out by the Secretary in accordance with paragraph (2)(A)(i), the Secretary shall submit a report under subparagraph (A) not later than 3 years after the date on which funds are first made available to carry out the study.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef936b6e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Studies carried out by other interested parties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to a study carried out by interested individuals or entities in accordance with paragraph (2)(A)(ii), the Secretary shall submit a report under subparagraph (A) not later than 180 days after the date on which the Secretary certifies under paragraph (2)(B) that the study meets the requirements of paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef936b6f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An area shall be designated as a National Heritage Area only by an Act of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef936b70-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/339/s2/a"},"text":"Pub. L. 117–339, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6159"},"text":"136 Stat. 6159","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
