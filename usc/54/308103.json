{"tag":"section","attrib":{"id":"idefa8f023-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308103"},"text":null,"children":[{"tag":"num","attrib":{"value":"308103"},"text":"§ 308103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Battlefield acquisition grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa8f024-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Site Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible site”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa8f025-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a site that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa8f026-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308103/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not within the exterior boundaries of a unit of the National Park System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa8f027-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308103/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is identified in the Battlefield Reports as a battlefield; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa8f028-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" excludes sites identified in the Battlefield Reports as associated historic sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f029-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish a battlefield acquisition grant program under which the Secretary may provide grants to States, Tribes, local governments, and nonprofit organizations to pay the Federal share of the cost of acquiring interests in eligible sites for the preservation and protection of those eligible sites.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f02a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonprofit Partners","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State, Tribe, or local government may acquire an interest in an eligible site using a grant under this section in partnership with a nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f02b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The non-Federal share of the total cost of acquiring an interest in an eligible site under this section shall be not less than 50 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f02c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Land Use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An interest in an eligible site acquired under this section, including by States, Tribes, local governments, and nonprofit organizations, shall be subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s200305/f/3"},"text":"section 200305(f)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f02d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308103/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Secretary to provide grants under this section $18,000,000 for each of fiscal years 2020 through 2028.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa8f02e-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3234"},"text":"128 Stat. 3234","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/76/dG/tIV/s429"},"text":"Pub. L. 113–76, div. G, title IV, § 429","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/345"},"text":"128 Stat. 345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dF/tIV/s421"},"text":"Pub. L. 113–235, div. F, title IV, § 421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2449"},"text":"128 Stat. 2449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXX/s3050"},"text":"Pub. L. 113–291, div. B, title XXX, § 3050","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3799"},"text":"128 Stat. 3799","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tVII/s702"},"text":"Pub. L. 116–94, div. P, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3195"},"text":"133 Stat. 3195","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s157/c"},"text":"Pub. L. 118–234, title I, § 157(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2879"},"text":"138 Stat. 2879","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa8f02f-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idefa8f030-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment Not Shown in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section was derived from section 469k–1(c)(1)(A) to (C), (2) to (6) of Title 16, Conservation, which was amended by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/dG/tIV/s429"},"text":"Pub. L. 113–76, div. G, title IV, § 429","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/345"},"text":"128 Stat. 345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dF/tIV/s421"},"text":"Pub. L. 113–235, div. F, title IV, § 421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2449"},"text":"128 Stat. 2449","children":[],"tail":"; and "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXX/s3050"},"text":"Pub. L. 113–291, div. B, title XXX, § 3050","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3799"},"text":"128 Stat. 3799","children":[],"tail":". For applicability of those amendments to this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/b"},"text":"section 6(b) of Pub. L. 113–287","children":[],"tail":", set out as a Transitional and Savings Provisions note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6) of former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s469k–1"},"text":"section 469k–1 of Title 16","children":[],"tail":" [restated in subsec. (f) of this section] was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/76"},"text":"Pub. L. 113–76","children":[],"tail":" by striking “2013” and inserting “2014” and by "},{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" by striking “2014” and inserting “2021”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c) of former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s469k–1"},"text":"section 469k–1 of Title 16","children":[],"tail":" was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) In paragraph (1)—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(A) by striking subparagraph (A) [restated in subsec. (a)(2) of this section] and inserting the following:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"“(A) Battlefield report","children":[],"tail":null},{"tag":"i","attrib":{},"text":".—The term ‘battlefield report’ means, collectively—","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"“(i) the report entitled ‘Report on the Nation’s Civil War Battlefields’, prepared by the Civil War Sites Advisory Commission, and dated July 1993; and","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"“(ii) the report entitled ‘Report to Congress on the Historic Preservation of Revolutionary War and War of 1812 Sites in the United States’, prepared by the National Park Service, and dated September 2007.”; and","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(B) in subparagraph (C)(ii) [restated in subsec. (a)(2) of this section], by striking “Battlefield Report” and inserting “battlefield report”;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) In paragraph (2) [restated in subsec. (b) of this section], by inserting “eligible sites or” after “acquiring”;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(3) In paragraph (3) [restated in subsec. (c) of this section], by inserting “an eligible site or” after “acquire”;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(4) In paragraph (4) [restated as subsec. (d) of this section], by inserting “an eligible site or” after “acquiring”;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(5) In paragraph (5) [restated as subsec. (e) of this section], by striking “An” and inserting “An eligible site or an”;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(6) By redesignating paragraph (6) [restated as subsec. (f) of this section] as paragraph (9);","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(7) By inserting after paragraph (5) [restated as subsec. (e) of this section] the following new paragraphs:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"“(6) Willing sellers","children":[],"tail":null},{"tag":"i","attrib":{},"text":".—Acquisition of land or interests in land under this subsection shall be from willing sellers only.","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"“(7) Report","children":[],"tail":null},{"tag":"i","attrib":{},"text":".—Not later than 5 years after the date of the enactment of this paragraph, the Secretary shall submit to Congress a report on the activities carried out under this subsection, including a description of—","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"“(A) preservation activities carried out at the battlefields and associated sites identified in the battlefield report during the period between publication of the battlefield report and the report required under this paragraph;","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"“(B) changes in the condition of the battlefields and associated sites during that period; and","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"“(C) any other relevant developments relating to the battlefields and associated sites during that period.","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"“(8) Prohibition on lobbying","children":[],"tail":null},{"tag":"i","attrib":{},"text":".—None of the funds provided pursuant to this section shall be used in any way, directly or indirectly, to influence congressional action on any legislation or appropriation matters pending before Congress.”; and","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(8) In paragraph (9) [restated as subsec. (f) of this section] (as redesignated), by striking “2014” and inserting “2021”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa8f031-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa8f032-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"308103(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s469k–1/c/1/A"},"text":"16 U.S.C. 469k–1(c)(1)(A)","children":[],"tail":", (C)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/111/11/tVII"},"text":"Pub. L. 111–11, title VII","children":[],"tail":", subtitle D, § 7301(c)(1)(A) through (C), (2) through (6), "},{"tag":"html:span","attrib":{},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/123/1213"},"text":"123 Stat. 1213","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"308103(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s469k–1/c/1/B"},"text":"16 U.S.C. 469k–1(c)(1)(B)","children":[],"tail":", (2)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"308103(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s469k–1/c/1/B"},"text":"16 U.S.C. 469k–1(c)(1)(B)","children":[],"tail":", (3)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"308103(d) through (f)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s469k–1/c/4"},"text":"16 U.S.C. 469k–1(c)(4)","children":[],"tail":" through (6)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), reference to fiscal years 2009 to 2011 is omitted as obsolete.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa8f033-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefa8f034-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s157/c/1"},"text":"Pub. L. 118–234, § 157(c)(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) defined “eligible site”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s157/c/2"},"text":"Pub. L. 118–234, § 157(c)(2)","children":[],"tail":", substituted “States, Tribes, local governments, and nonprofit organizations” for “State and local governments”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s157/c/3"},"text":"Pub. L. 118–234, § 157(c)(3)","children":[],"tail":", substituted “State, Tribe, or local government” for “State or local government”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s157/c/4"},"text":"Pub. L. 118–234, § 157(c)(4)","children":[],"tail":", substituted “under this section, including by States, Tribes, local governments, and nonprofit organizations,” for “under this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “$18,000,000 for each of fiscal years 2020 through 2028” for “$10,000,000 for each of fiscal years 2012 and 2013”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
