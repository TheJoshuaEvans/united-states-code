{"tag":"section","attrib":{"id":"idefadab0e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312102"},"text":null,"children":[{"tag":"num","attrib":{"value":"312102"},"text":"§ 312102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefadab0f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To further the policy enunciated in chapter 3201 of this title, and to facilitate public participation in the preservation of sites, buildings, and objects of national significance or interest, there is established a charitable, educational, and nonprofit corporation to be known as the National Trust for Historic Preservation in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadab10-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the National Trust shall be to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadab11-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive donations of sites, buildings, and objects significant in American history and culture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab12-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserve and administer the sites, buildings, and objects for public benefit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab13-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312102/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept, hold, and administer gifts of money, securities, or other property of any character for the purpose of carrying out the preservation program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab14-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312102/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute other functions vested in the National Trust by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefadab15-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3249"},"text":"128 Stat. 3249","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefadab16-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefadab17-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefadab18-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":