{"tag":"section","attrib":{"id":"idefb01bf0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s320103"},"text":null,"children":[{"tag":"num","attrib":{"value":"320103"},"text":"§ 320103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with governmental and private agencies and individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefb01bf1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s320103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may cooperate with and may seek and accept the assistance of any Federal, State, or local agency, educational or scientific institution, patriotic association, or individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb01bf2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s320103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical Advisory Committees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the Secretary considers it necessary, the Secretary may establish technical advisory committees to act in an advisory capacity in connection with the restoration or reconstruction of any historic or prehistoric building or other structure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb01bf3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s320103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employment of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may employ professional and technical assistance and establish service as may be required to accomplish the purposes of this chapter and for which money may be appropriated by Congress or made available by gifts for those purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb01bf4-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3259"},"text":"128 Stat. 3259","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefb01bf5-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefb01bf6-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefb01bf7-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"