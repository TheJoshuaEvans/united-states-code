{"tag":"section","attrib":{"id":"idef808059-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100906"},"text":null,"children":[{"tag":"num","attrib":{"value":"100906"},"text":"§ 100906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef80805a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To facilitate the administration of the System, the Secretary, under such terms and conditions as the Secretary may consider advisable, may appoint and establish advisory committees in regard to the functions of the Service as the Secretary considers advisable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef80805b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Charter Exception On Renewal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/b"},"text":"Section 1013(b) of title 5","children":[],"tail":" is waived with respect to any advisory commission or advisory committee established by law in connection with any System unit during the period for which the commission or committee is authorized by law."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef80805c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service of Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any member of any advisory commission or advisory committee established in connection with any System unit may serve after the expiration of the member’s term until a successor is appointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef80805d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100906/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation and Travel Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members of an advisory committee established under subsection (a) shall receive no compensation for their services as such but shall be allowed necessary travel expenses as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef80805e-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3118"},"text":"128 Stat. 3118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/328"},"text":"Pub. L. 117–286, § 4(a)(328)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4342"},"text":"136 Stat. 4342","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef80805f-3a70-11f1-83cd-8a39f388f6db"},"text":"\n