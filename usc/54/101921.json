{"tag":"section","attrib":{"id":"idef89f622-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101921"},"text":null,"children":[{"tag":"num","attrib":{"value":"101921"},"text":"§ 101921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple contracts within a System unit","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If multiple concession contracts are awarded to authorize concessioners to provide the same or similar outfitting, guiding, river running, or other similar services at the same approximate location or resource within a System unit, the Secretary shall establish a comparable franchise fee structure for those contracts or similar contracts, except that the terms and conditions of any existing concession contract shall not be subject to modification or open to renegotiation by the Secretary because of an award of a new contract at the same approximate location or resource.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef89f623-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3149"},"text":"128 Stat. 3149","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef89f624-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef89f625-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef89f626-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"