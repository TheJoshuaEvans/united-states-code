{"tag":"section","attrib":{"id":"idef82c98e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101114"},"text":null,"children":[{"tag":"num","attrib":{"value":"101114"},"text":"§ 101114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of property or income","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef82c98f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Dispose or Deal With Property or Income","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise required by the instrument of transfer, the National Park Foundation may sell, lease, invest, reinvest, retain, or otherwise dispose of or deal with any property or income from the property as the Board may determine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef82c990-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Park Foundation shall not engage in any business or make any investment that may not lawfully be made by a trust company in the District of Columbia, except that the Foundation may make any investment authorized by the instrument of transfer, and may retain any property accepted by the Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef82c991-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Services and Facilities of the Departments of the Interior and Justice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Park Foundation may utilize the services and facilities of the Department of the Interior and the Department of Justice, and the services and facilities may be made available on request to the extent practicable with or without reimbursement. Amounts reimbursed to either Department shall be returned by the Department to the account from which the funds for which the reimbursement is made were drawn and may, without further appropriation, be expended for any purpose for which the account is authorized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef82c992-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3121"},"text":"128 Stat. 3121","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef82c993-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef82c994-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef82c995-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colsp