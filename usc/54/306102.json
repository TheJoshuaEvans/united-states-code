{"tag":"section","attrib":{"id":"idefa6a53b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306102"},"text":null,"children":[{"tag":"num","attrib":{"value":"306102"},"text":"§ 306102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa6a53c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Federal agency shall establish (except for programs or undertakings exempted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s304108/c"},"text":"section 304108(c) of this title","children":[],"tail":"), in consultation with the Secretary, a preservation program for the identification, evaluation, and nomination to the National Register, and protection, of historic property."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa6a53d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa6a53e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" historic property under the jurisdiction or control of the agency is identified, evaluated, and nominated to the National Register;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa6a53f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" historic property under the jurisdiction or control of the agency is managed and maintained in a way that considers the preservation of their historic, archeological, architectural, and cultural values in compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s306108"},"text":"section 306108 of this title","children":[],"tail":" and gives special consideration to the preservation of those values in the case of property designated as having national significance;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa6a540-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306102/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preservation of property not under the jurisdiction or control of the agency but potentially affected by agency actions is given full consideration in planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa6a541-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306102/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency’s preservation-related activities are carried out in consultation with other Federal, State, and local agencies, Indian tribes, Native Hawaiian organizations carrying out historic preservation planning activities, and the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa6a542-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306102/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the agency’s procedures for compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s306108"},"text":"section 306108 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa6a543-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306102/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with regulations promulgated by the Council pursuant to section 304108(a) and (b) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa6a544-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306102/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a process for the identification and evaluation of historic property for listing on the National Register and the development and implementation of agreements, in consultation with State Historic Preservation Officers, local governments, Indian tribes, Native Hawaiian organizations, and the interested public, as appropriate, regarding the means by which adverse effects on historic property will be considered; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa6a545-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306102/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the disposition of Native American cultural items from Federal or tribal land in a manner consistent with section 3(c) of the Native American Graves Protection and Repatriation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3002/c"},"text":"25 U.S.C. 3002(c)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa6a546-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3225"},"text":"128 Stat. 3225","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa6a547-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa6a548-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa6a549-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":n