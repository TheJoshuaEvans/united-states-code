children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3117"},"text":"128 Stat. 3117","children":[],"tail":", related to commercial filming, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s125/a/1"},"text":"Pub. L. 118–234, title I, § 125(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2847"},"text":"138 Stat. 2847","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
