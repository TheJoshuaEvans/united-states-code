{"tag":"section","attrib":{"id":"idef807fff-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905"},"text":null,"children":[{"tag":"num","attrib":{"value":"100905"},"text":"§ 100905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filming and still photography in System units","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef808000-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filming and Still Photography.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef808001-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that a filming or still photography activity or similar project in a System unit (referred to in this section as a “filming or still photography activity”) and the authorizing or permitting of a filming or still photography activity are carried out consistent with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef808002-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the laws and policies applicable to the Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef808003-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicable general management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef808004-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No permits required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not require an authorization or a permit or assess a fee, if a fee for a filming or still photography activity is not otherwise required by law, for a filming or still photography activity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef808005-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef808006-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves fewer than 6 individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef808007-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets each of the requirements described in paragraph (5); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef808008-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is merely incidental to, or documenting, an activity or event that is allowed or authorized at the System unit, regardless of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef808009-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals participating in the allowed or authorized activity or event; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef80800a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether any individual receives compensation for any products of the filming or still photography activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef80800b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filming and still photography authorizations for de minimis use.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef80800c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish a de minimis use authorization for certain filming or still photography activities that meets the requirements described in subparagraph (F).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef80800d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a filming or still photography activity that meets the requirements described in subparagraph (F), the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef80800e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may require a de minimis use authorization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef80800f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not require a permit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef808010-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No fee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall not charge a fee for a de minimis use authorization under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef808011-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall enable members of the public to apply for and obtain a de minimis use authorization under this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef808012-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through the website of the Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef808013-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in person at the field office of the applicable System unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef808014-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuances","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef808015-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a procedure—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef808016-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/E/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to automate the approval of an application submitted through the website of the Service under subparagraph (D)(i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef808017-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/E/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to issue a de minimis use authorization under this paragraph immediately on receipt of an application that is submitted in person at the field office of the applicable System unit under subparagraph (D)(ii); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef808018-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if an application submitted under subparagraph (D) meets the requirements of this paragraph, immediately on receipt of the application issue a de minimis use authorization for the filming or still photography activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef808019-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall only issue a de minimis use authorization under this paragraph if the filming or still photography activity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef80801a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves a group of not fewer than 6 individuals and not more than 8 individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef80801b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets each of the requirements described in paragraph (5); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef80801c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef80801d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A de minimis use authorization issued under this paragraph shall list the requirements described in subparagraph (F).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef80801e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required permits.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef80801f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2)(B), the Secretary may require a permit application and, if a permit is issued, assess a reasonable fee, as described in subsection (b)(1), for a filming or still photography activity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef808020-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves more than 8 individuals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef808021-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not meet each of the requirements described in paragraph (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef808022-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Wilderness act clarification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No provision of this subsection is intended to or shall be construed to conflict with the provisions of the Wilderness Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef808023-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for filming or still photography activity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements referred to in paragraphs (2)(A)(ii), (3)(F)(ii), (4)(B),","children":[{"tag":"ref","attrib":{"idref":"fn002004"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002004"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should refer to par. (4)(A)(ii)."}],"tail":" and (7)(C) "},{"tag":"ref","attrib":{"idref":"fn002005"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002005"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Par. (7)(C) does not refer to the requirements in par. (5)."}],"tail":" are as follows:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef808024-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person conducts the filming or still photography activity in a manner that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef808025-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not impede or intrude on the experience of other visitors to the applicable System unit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef808026-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as otherwise authorized, does not disturb or negatively impact—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef808027-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/5/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a natural or cultural resource; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef808028-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/5/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an environmental or scenic value; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef808029-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allows for equitable allocation or use of facilities of the applicable System unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef80802a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person conducts the filming or still photography activity at a location in which the public is allowed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef80802b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person conducting the filming or still photography activity does not require the exclusive use of a site or area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef80802c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person does not conduct the filming or still photography activity in a localized area that receives a very high volume of visitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef80802d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person conducting the filming or still photography activity does not use a set or staging equipment, subject to the limitation that handheld equipment (such as a tripod, monopod, and handheld lighting equipment) shall not be considered staging equipment for the purposes of this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef80802e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person conducting the filming or still photography activity complies with and adheres to visitor use policies, practices, and regulations applicable to the applicable System unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef80802f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The filming or still photography activity is not likely to result in additional administrative costs being incurred by the Secretary with respect to the filming or still photography activity, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef808030-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person conducting the filming or still photography activity complies with other applicable Federal, State (as such term is defined in section 3 ","children":[{"tag":"ref","attrib":{"idref":"fn002006"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002006"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See References in Text note below."}],"tail":" of the EXPLORE Act), and local laws (including regulations), including laws relating to the use of unmanned aerial equipment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef808031-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content creation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Regardless of distribution platform, any video, still photograph, or audio recording for commercial or noncommercial content creation in a System unit shall be considered to be a filming or still photography activity under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef808032-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef808033-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Permits requested though not required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On the request of a person intending to carry out a filming or still photography activity, the Secretary may issue a permit for the filming or still photography activity, even if a permit for the filming or still photography activity is not required under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef808034-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No additional permits, commercial use authorizations, or fees for filming and still photography at authorized events","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A filming or still photography activity at an activity or event that is allowed or authorized, including a wedding, engagement party, family reunion, or celebration of a graduate, shall be considered merely incidental for the purposes of paragraph (2)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef808035-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monetary compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The receipt of monetary compensation by the person conducting the filming or still photography activity shall not affect the permissibility of the filming or still photography activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef808036-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees and Recovery Costs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef808037-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The reasonable fees referred to in subsection (a)(4) shall meet each of the following criteria:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef808038-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The reasonable fee shall provide a fair return to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef808039-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The reasonable fee shall be based on the following criteria:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef80803a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of days of the filming or still photography activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef80803b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The size of the film or still photography crew present in the System unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef80803c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The quantity and type of film or still photography equipment present in the System unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef80803d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other factors that the Secretary determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef80803e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recovery of costs.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef80803f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall collect from the applicant for the applicable permit any costs incurred by the Secretary related to a filming or still photography activity subject to a permit under subsection (a)(4), including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef808040-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the review or issuance of the permit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef808041-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related administrative and personnel costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef808042-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on fees collected","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All costs recovered under subparagraph (A) shall be in addition to the fee described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef808043-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of proceeds.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef808044-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"All fees collected under this section shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef808045-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be available for expenditure by the Secretary, without further appropriation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef808046-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef808047-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"All costs recovered under paragraph (2)(A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef808048-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be available for expenditure by the Secretary, without further appropriation, at the System unit at which the costs are collected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef808049-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef80804a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection of Resources","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not allow a person to undertake a filming or still photography activity if the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef80804b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a likelihood that the person would cause resource damage at the System unit, except as otherwise authorized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef80804c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person would create an unreasonable disruption of the use and enjoyment by the public of the System unit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef80804d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the filming or still photography activity poses a health or safety risk to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef80804e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Processing of Permit Applications.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef80804f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish a process to ensure that the Secretary responds in a timely manner to an application for a permit for a filming or still photography activity required under subsection (a)(4).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef808050-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a permit is required under this section for 2 or more Federal agencies or System units, the Secretary and the head of any other applicable Federal agency, as applicable, shall, to the maximum extent practicable, coordinate permit processing procedures, including through the use of identifying a lead agency or lead System unit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef808051-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to review the application for the permit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef808052-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to issue the permit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef808053-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100905/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collect any required fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef808054-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s125/a/1"},"text":"Pub. L. 118–234, title I, § 125(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2847"},"text":"138 Stat. 2847","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef808055-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef808056-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef808057-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","childr