{"tag":"section","attrib":{"id":"idefa8efd2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307103"},"text":null,"children":[{"tag":"num","attrib":{"value":"307103"},"text":"§ 307103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa8efd3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Withhold From Disclosure","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of a Federal agency, or other public official receiving grant assistance pursuant to this division, after consultation with the Secretary, shall withhold from disclosure to the public information about the location, character, or ownership of a historic property if the Secretary and the agency determine that disclosure may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa8efd4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cause a significant invasion of privacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa8efd5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" risk harm to the historic property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa8efd6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impede the use of a traditional religious site by practitioners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8efd7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access Determination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the head of a Federal agency or other public official determines that information should be withheld from the public pursuant to subsection (a), the Secretary, in consultation with the Federal agency head or official, shall determine who may have access to the information for the purpose of carrying out this division.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8efd8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation With Council","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When information described in subsection (a) has been developed in the course of an agency’s compliance with section 306107 or 306108 of this title, the Secretary shall consult with the Council in reaching determinations under subsections (a) and (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa8efd9-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3231"},"text":"128 Stat. 3231","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa8efda-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa8efdb-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa8efdc-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"307103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470w–3"},"text":"16 U.S.C. 470w–3","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/665/tIII/s304"},"text":"Pub. L. 89–665, title III, § 304","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/96/515/tV/s501"},"text":"Pub. L. 96–515, title V, § 501","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/3002"},"text":"94 Stat. 3002","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/102/575/tXL/s4020"},"text":"Pub. L. 102–575, title XL, § 4020","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/4765"},"text":"106 Stat. 4765","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
