{"tag":"section","attrib":{"id":"idef9121cc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103501"},"text":null,"children":[{"tag":"num","attrib":{"value":"103501"},"text":"§ 103501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9121cd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Treasury an account to be known as the National Park Centennial Challenge Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9121ce-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All amounts received by the United States each fiscal year from sales by the National Park Service of National Parks and Federal Recreational Lands Passes under section 805(b)(1) of the Federal Lands Recreation Enhancement Act that are in excess of $10,000,000 shall be deposited into the National Park Centennial Challenge Fund as offsetting collections and shall remain available to the Secretary until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9121cf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds collected and deposited into the National Park Centennial Challenge Fund—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9121d0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103501/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be used for projects or programs approved by the Secretary to further the mission of the Service and to enhance the visitor experience in System units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9121d1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103501/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be used to acquire lands or interest in lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9121d2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103501/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may only be used if matched, on at least a 1-to-1 basis, by non-Federal donations (including funds and fairly valued durable goods and materials) to the Service for signature projects or programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9121d3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Source of Funds for Matching","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts derived from the Second Century Endowment for the National Park Service shall not be treated as non-Federal donations for purposes of subsection (c)(3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9121d4-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/tI/s101/a"},"text":"Pub. L. 114–289, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1483"},"text":"130 Stat. 1483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9121d5-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef9121d6-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef9121d7-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 805(b)(1) of the Federal Lands Recreation Enhancement Act, referred to in subsec. (b), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6804/b/1"},"text":"section 6804(b)(1) of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
