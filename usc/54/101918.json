{"tag":"section","attrib":{"id":"idef89f5e2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101918"},"text":null,"children":[{"tag":"num","attrib":{"value":"101918"},"text":"§ 101918.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer or conveyance of concession contracts or leasehold surrender interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef89f5e3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101918/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval of Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No concession contract or leasehold surrender interest may be transferred, assigned, sold, or otherwise conveyed or pledged by a concessioner without prior written notification to, and approval by, the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef89f5e4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101918/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall approve a transfer or conveyance described in subsection (a) unless the Secretary finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef89f5e5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101918/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual, corporation, or other entity seeking to acquire a concession contract is not qualified or able to satisfy the terms and conditions of the concession contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef89f5e6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101918/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the transfer or conveyance would have an adverse impact on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef89f5e7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101918/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection, conservation, or preservation of the resources of the System unit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef89f5e8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101918/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of necessary and appropriate facilities and services to visitors at reasonable rates and charges; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef89f5e9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101918/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the terms of the transfer or conveyance are likely, directly or indirectly, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef89f5ea-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101918/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the concessioner’s opportunity for a reasonable profit over the remaining term of the concession contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef89f5eb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101918/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adversely affect the quality of facilities and services provided by the concessioner; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef89f5ec-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101918/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in a need for increased rates and charges to the public to maintain the quality of the facilities and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef89f5ed-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101918/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modification or Renegotiation of Terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms and conditions of any concession contract under this section shall not be subject to modification or open to renegotiation by the Secretary because of a transfer or conveyance described in subsection (a) unless the transfer or conveyance would have an adverse impact as described in subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef89f5ee-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3147"},"text":"128 Stat. 3147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef89f5ef-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef89f5f0-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef89f5f1-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101918","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s5957"},"text":"16 U.S.C. 5957","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/105/391/tIV/s408"},"text":"Pub. L. 105–391, title IV, § 408","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/3512"},"text":"112 Stat. 3512","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the word “other” is added for consistency in the subchapter. See section 101926 of the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
