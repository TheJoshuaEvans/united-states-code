{"tag":"section","attrib":{"id":"idef7e0ecd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100903"},"text":null,"children":[{"tag":"num","attrib":{"value":"100903"},"text":"§ 100903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solid waste disposal operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7e0ece-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002003"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002003"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. A period probably should appear."}],"tail":" —"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To protect the air, land, water, and natural and cultural values of the System and the property of the United States in the System, no solid waste disposal site (including any site for the disposal of domestic or industrial solid waste) may be operated within the boundary of any System unit, other than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7e0ecf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100903/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a site that was operating as of ","children":[{"tag":"date","attrib":{"date":"1984-09-01"},"text":"September 1, 1984","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0ed0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100903/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a site used only for disposal of waste generated within that System unit so long as the site will not degrade any of the natural or cultural resources of the System unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7e0ed1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations to carry out this section, including reasonable regulations to mitigate the adverse effects of solid waste disposal sites in operation as of ","children":[{"tag":"date","attrib":{"date":"1984-09-01"},"text":"September 1, 1984","children":[],"tail":", on property of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7e0ed2-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3115"},"text":"128 Stat. 3115","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7e0ed3-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef7e0ed4-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef7e0ed5-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":nu