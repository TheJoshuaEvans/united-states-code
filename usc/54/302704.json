{"tag":"section","attrib":{"id":"idef9f7a0e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302704"},"text":null,"children":[{"tag":"num","attrib":{"value":"302704"},"text":"§ 302704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and cooperative agreements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"At the request of an Indian tribe whose preservation program has been approved to assume functions and responsibilities pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302702"},"text":"section 302702 of this title","children":[],"tail":", the Secretary shall enter into a contract or cooperative agreement with the Indian tribe permitting the assumption by the Indian tribe of any part of the responsibilities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s302304/b"},"text":"section 302304(b) of this title","children":[],"tail":" on tribal land, if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9f7a0f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302704/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary and the Indian tribe agree on additional financial assistance, if any, to the Indian tribe for the costs of carrying out those authorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9f7a10-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302704/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary finds that the tribal historic preservation program has been demonstrated to be sufficient to carry out the contract or cooperative agreement and this division; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9f7a11-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302704/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the contract or cooperative agreement specifies the continuing responsibilities of the Secretary or of the appropriate State Historic Preservation Officers and provides for appropriate participation by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9f7a12-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302704/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian tribe’s traditional cultural authorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9f7a13-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302704/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of other Indian tribes whose traditional land is under the jurisdiction of the Indian tribe assuming responsibilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9f7a14-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302704/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interested public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9f7a15-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3200"},"text":"128 Stat. 3200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9f7a16-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9f7a17-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9f7a18-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html: