{"tag":"section","attrib":{"id":"idefa6a56f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306110"},"text":null,"children":[{"tag":"num","attrib":{"value":"306110"},"text":"§ 306110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual preservation awards program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an annual preservation awards program under which the Secretary may make monetary awards in amounts of not to exceed $1,000 and provide citations for special achievement to officers and employees of Federal, State, and certified local governments in recognition of their outstanding contributions to the preservation of historic property. The program may include the issuance of annual awards by the President to any citizen of the United States recommended for the award by the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefa6a570-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3227"},"text":"128 Stat. 3227","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa6a571-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa6a572-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa6a573-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tai