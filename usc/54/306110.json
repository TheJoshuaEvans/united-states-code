65, title I, § 110(h)","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/96/515/tII/s206"},"text":"Pub. L. 96–515, title II, § 206","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/2997"},"text":"94 Stat. 2997","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “historic property” are substituted for “historic resources” for consistency because the defined term in the new division is “historic property”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
