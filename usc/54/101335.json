{"tag":"section","attrib":{"id":"idef853b56-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335"},"text":null,"children":[{"tag":"num","attrib":{"value":"101335"},"text":"§ 101335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef853b57-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Joint Public-Private Sector Housing Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef853b58-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lease-to-build program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the appropriation of necessary funds in advance, the Secretary may lease—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef853b59-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal land and interests in land to qualified persons for the construction of field employee quarters for any period not to exceed 50 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef853b5a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developed and undeveloped non-Federal land for providing field employee quarters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef853b5b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Competitive leasing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each lease under paragraph (1)(A) shall be awarded through the use of publicly advertised, competitively bid, or competitively negotiated contracting procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef853b5c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each lease under paragraph (1)(A)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef853b5d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall stipulate whether operation and maintenance of field employee quarters is to be provided by the lessee, field employees, or the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef853b5e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall require that the construction and rehabilitation of field employee quarters be done in accordance with the requirements of the Service and local applicable building codes and industry standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef853b5f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall contain additional terms and conditions as may be appropriate to protect the Federal interest, including limits on rents that the lessee may charge field employees for the occupancy of quarters, conditions on maintenance and repairs, and agreements on the provision of charges for utilities and other infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef853b60-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be granted at less than fair market value if the Secretary determines that the lease will improve the quality and availability of field employee quarters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef853b61-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contributions by federal government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make payments, subject to appropriations, or contributions in kind, in advance or on a continuing basis, to reduce the costs of planning, construction, or rehabilitation of quarters on or off Federal land under a lease under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef853b62-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rental Guarantee Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef853b63-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the appropriation of necessary funds in advance, the Secretary may enter into a lease-to-build arrangement as set forth in subsection (a) with further agreement to guarantee the occupancy of field employee quarters constructed or rehabilitated under the lease. A guarantee made under this paragraph shall be in writing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef853b64-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on guarantees.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef853b65-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specific guarantees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not guarantee—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef853b66-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the occupancy of more than 75 percent of the units constructed or rehabilitated under the lease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef853b67-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a rental rate that exceeds the rate based on the reasonable value of the housing in accordance with requirements applicable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5911"},"text":"section 5911 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef853b68-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Total of outstanding guarantees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Outstanding guarantees shall not be in excess of $3,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef853b69-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement to rent to federal government employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A guarantee may be made under this subsection only if the lessee agrees to permit the Secretary to utilize for housing purposes any units for which the guarantee is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef853b6a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101335/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation and maintenance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A lease shall be void if the lessee fails to maintain a satisfactory level of operation and maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef853b6b-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3127"},"text":"128 Stat. 3127","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef853b6c-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef853b6d-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef853b6e-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101335(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s17"},"text":"16 U.S.C. 17","children":[],"tail":null},{"tag":"html:i","attrib":{},"text":"o","children":[],"tail":"(7)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/104/333/dI/tVIII/s814/a/7"},"text":"Pub. L. 104–333, div. I, title VIII, § 814(a)(7)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/4190"},"text":"110 Stat. 4190","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/106/1