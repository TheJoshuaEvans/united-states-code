{"tag":"section","attrib":{"id":"idef9d090c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300318"},"text":null,"children":[{"tag":"num","attrib":{"value":"300318"},"text":"§ 300318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State historic preservation review board","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this division, the term “State historic preservation review board” means a board, council, commission, or other similar collegial body established as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302301/2"},"text":"section 302301(2) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9d090d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300318/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the members of which are appointed by the State Historic Preservation Officer (unless otherwise provided for by State law);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d090e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300318/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a majority of the members of which are professionals qualified in history, prehistoric and historic archeology, architectural history, architecture, folklore, cultural anthropology, curation, conservation, landscape architecture, and related disciplines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d090f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300318/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that has the authority to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9d0910-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300318/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review National Register nominations and appeals from nominations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9d0911-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300318/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review appropriate documentation submitted in conjunction with the Historic Preservation Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9d0912-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300318/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide general advice and guidance to the State Historic Preservation Officer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9d0913-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300318/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other duties as may be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9d0914-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3190"},"text":"128 Stat. 3190","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9d0915-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"not