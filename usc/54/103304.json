{"tag":"section","attrib":{"id":"idef8eb1b5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103304"},"text":null,"children":[{"tag":"num","attrib":{"value":"103304"},"text":"§ 103304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of land withheld","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8eb1b6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The United States may bring a civil action in the courts of the United States against a person to whom land lying within a national military park has been leased that refuses to give up possession of the land to the United States after the termination of the lease, and after possession has been demanded for the United States by the park superintendent, or against a person retaining possession of land lying within the boundary of a national military park that the person has sold to the United States for park purposes and received payment therefor, after possession of the land has been demanded for the United States by the park superintendent, to recover possession of the land withheld. The civil action shall be brought according to the statutes of the State in which the national military park is situated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8eb1b7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Trespass","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person described in subsection (a) shall be guilty of trespass.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8eb1b8-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3166"},"text":"128 Stat. 3166","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8eb1b9-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef8eb1ba-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef8eb1bb-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"103304","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s416"},"text":"16 U.S.C. 416","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1897-03-03/ch372"},"text":"Mar. 3, 1897, ch. 372","children":[],"tail":", §§ 4, 5, "},{"tag":"html:a","attrib":{"href":"/us/stat/29/622"},"text":"29 Stat. 622","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “any park commissioner” are omitted as obsolete. See section 103303 of the new title. The words “or code of practice” are omitted as obsolete because of the Federal Rules of Civil Procedure (28 U.S.C. App.).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
