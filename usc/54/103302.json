{"tag":"section","attrib":{"id":"idef8eb1a9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103302"},"text":null,"children":[{"tag":"num","attrib":{"value":"103302"},"text":"§ 103302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Camps for military instruction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8eb1aa-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assembling of Forces and Detailing of Instructors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army or Secretary of the Air Force, within the limits of appropriations that may be available for that purpose, may assemble in camp at such season of the year and for such period as the Secretary of the Army or Secretary of the Air Force may designate, at the field of military maneuvers, such portions of the military forces of the United States as the Secretary of the Army or Secretary of the Air Force may think best, to receive military instruction there. The Secretary of the Army of Secretary of the Air Force may detail instructors from the Regular Army or Regular Air Force, respectively, for those forces during their exercises.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8eb1ab-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army or Secretary of the Air Force may prescribe regulations governing the assembling of the National Guard or militia of the States on the maneuvering grounds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8eb1ac-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3165"},"text":"128 Stat. 3165","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8eb1ad-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef8eb1ae-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef8eb1af-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"103302","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s412"},"text":"16 U.S.C. 412","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1896-05-15/ch182/s2"},"text":"May 15, 1896, ch. 182, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/29/121"},"text":"29 Stat. 121","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title II, § 205(a), "},{"tag":"html:a","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “or Secretary of the Air Force” and “or Regular Air Force” are added because certain functions, personnel, and property, insofar as they pertain to the Air Force, were transferred from the Secretary of the Army and Department of the Army to the Secretary of the Air Force and Department of the Air Force by Secretary of Defense Transfer Order Nos. 1, ","children":[{"tag":"date","attrib":{"date":"1947-09-26"},"text":"September 26, 1947","children":[],"tail":"; 10, "},{"tag":"date","attrib":{"date":"1948-04-27"},"text":"April 27, 1948","children":[],"tail":"; and 40 [App. B(65)], "},{"tag":"date","attrib":{"date":"1949-07-22"},"text":"July 22, 1949","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “and publish” are omitted because of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s1505"},"text":"44 U.S.C. 1505","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
