{"tag":"section","attrib":{"id":"idef7b9e4f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100751"},"text":null,"children":[{"tag":"num","attrib":{"value":"100751"},"text":"§ 100751.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7b9e50-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100751/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe such regulations as the Secretary considers necessary or proper for the use and management of System units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7b9e51-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100751/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Boating and Other Activities on or Relating to Water","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, under such terms and conditions as the Secretary considers advisable, may prescribe regulations under subsection (a) concerning boating and other activities on or relating to water located within System units, including water subject to the jurisdiction of the United States. Any regulation under this subsection shall be complementary to, and not in derogation of, the authority of the Coast Guard to regulate the use of water subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7b9e52-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100751/c"},"text":null,"children":[{"tag":"num","attrib":{