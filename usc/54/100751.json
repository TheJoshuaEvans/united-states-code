"text":"114 Stat. 28","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"100751(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"no source.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “In order to facilitate the administration of the national park system” and “and enforce” are omitted as unnecessary. The words “under subsection (a)” are added for clarity to show that a regulation under subsection (b) is a special type of regulation under subsection (a) so that a violation of a regulation under subsection (b) is subject to a criminal penalty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1865"},"text":"18 U.S.C. 1865","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) is added for informational purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
