{"tag":"section","attrib":{"id":"idefb01bb2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312507"},"text":null,"children":[{"tag":"num","attrib":{"value":"312507"},"text":"§ 312507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to Secretary by Federal agencies responsible for construction projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefb01bb3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance of Federal Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To carry out this chapter, any Federal agency responsible for a construction project may assist the Secretary or may transfer to the Secretary funds as may be agreed on, but not more than 1 percent of the total amount authorized to be appropriated for the project, except that the 1 percent limitation under this section shall not apply if the cost of the project is $50,000 or less. The costs of the survey, recovery, analysis, and publication shall be deemed nonreimbursable project costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb01bb4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts appropriated for purposes of this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb01bb5-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3256"},"text":"128 Stat. 3256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefb01bb6-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefb01bb7-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefb01bb8-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"ta