{"tag":"section","attrib":{"id":"idef89f5f2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919"},"text":null,"children":[{"tag":"num","attrib":{"value":"101919"},"text":"§ 101919.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Park Service Concessions Management Advisory Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef89f5f3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is a National Park Service Concessions Management Advisory Board whose purpose shall be to advise the Secretary and Service on matters relating to management of concessions in the System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef89f5f4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef89f5f5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advice","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Board shall advise on each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef89f5f6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Policies and procedures intended to ensure that services and facilities provided by concessioners—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef89f5f7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are necessary and appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef89f5f8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet acceptable standards at reasonable rates with a minimum of impact on System unit resources and values; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef89f5f9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the concessioners with a reasonable opportunity to make a profit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef89f5fa-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ways to make Service concession programs and procedures more cost effective, more process efficient, less burdensome, and timelier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef89f5fb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Board shall make recommendations to the Secretary regarding each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef89f5fc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Service contracting with the private sector to conduct appropriate elements of concession management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef89f5fd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ways to make the review or approval of concessioner rates and charges to the public more efficient, less burdensome, and timelier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef89f5fe-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The nature and scope of products that qualify as Indian, Alaska Native, and Native Hawaiian handicrafts within the meaning of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef89f5ff-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The allocation of concession fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef89f600-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Board shall provide an annual report on its activities to the Committee on Natural Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef89f601-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory Board Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the Advisory Board shall be appointed on a staggered basis by the Secretary for a term not to exceed 4 years and shall serve at the pleasure of the Secretary. The Advisory Board shall be comprised of not more than 7 individuals appointed from among citizens of the United States not in the employment of the Federal Government and not in the employment of or having an interest in a Service concession. Of the 7 members of the Advisory Board—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef89f602-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member shall be privately employed in the hospitality industry and have both broad knowledge of hotel or food service management and experience in the parks and recreation concession business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef89f603-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member shall be privately employed in the tourism industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef89f604-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member shall be privately employed in the accounting industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef89f605-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member shall be privately employed in the outfitting and guide industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef89f606-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member shall be a State government employee with expertise in park concession management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef89f607-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member shall be active in promotion of traditional arts and crafts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef89f608-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member shall be active in a nonprofit conservation organization involved in parks and recreation programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef89f609-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service on Advisory Board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Service of an individual as a member of the Advisory Board shall not be deemed to be service or employment bringing the individual within the provisions of any Federal law relating to conflicts of interest or otherwise imposing restrictions, requirements, or penalties in relation to the employment of individuals, the performance of services, or the payment or receipt of compensation in connection with claims, proceedings, or matters involving the United States. Service as a member of the Advisory Board shall not be deemed service in an appointive or elective position in the Federal Government for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8344"},"text":"section 8344 of title 5","children":[],"tail":" or other comparable provisions of Federal law."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef89f60a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101919/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Board shall continue to exist until ","children":[{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":". In all other respects, it shall be subject to chapter 10 of title 5."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef89f60b-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3147"},"text":"128 Stat. 3147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/329"},"text":"Pub. L. 117–286, § 4(a)(329)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4342"},"text":"136 Stat. 4342","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef89f60c-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef89f60d-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef89f60e-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"101919(a) through (c)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s5958/a"},"text":"16 U.S.C. 5958(a)","children":[],"tail":" through (c)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/105/391/tIV/s409"},"text":"Pub. L. 105–391, title IV, § 409","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/3512"},"text":"112 Stat. 3512","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":", subtitle VII, subtitle E, § 7403, "},{"tag":"html:a","attrib":{"href":"/us/stat/123/1219"},"text":"123 Stat. 1219","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101919(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s5958/e"},"text":"16 U.S.C. 5958(e)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101919(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s5958/d"},"text":"16 U.S.C. 5958(d)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5958/b/2"},"text":"16 U.S.C. 5958(b)(2)","children":[],"tail":" (last sentence) is omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the words “commencing with the first anniversary of its initial meeting” are omitted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the word “deemed” is substituted for “considered as” for consistency in this title and with other titles of the United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef89f60f-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef89f610-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5.” for “the Federal Advisory Committee Act (5 U.S.C. App.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
