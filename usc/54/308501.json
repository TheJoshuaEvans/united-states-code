{"tag":"section","attrib":{"id":"idefab60ad-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308501"},"text":null,"children":[{"tag":"num","attrib":{"value":"308501"},"text":"§ 308501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National women’s rights history project national registry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefab60ae-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make annual grants to State historic preservation offices for not more than 5 years to assist the State historic preservation offices in surveying, evaluating, and nominating to the National Register of Historic Places women’s rights history properties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab60af-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In making grants under subsection (a), the Secretary shall give priority to grants relating to properties associated with the multiple facets of the women’s rights movement, such as politics, economics, education, religion, and social and family rights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab60b0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that the National Register travel itinerary website entitled “Places Where Women Made History” is updated to contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab60b1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308501/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the inventory conducted under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab60b2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308501/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any links to websites related to places on the inventory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab60b3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost-Sharing Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of any activity carried out using any assistance made available under this section shall be 50 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab60b4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308501/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"conten