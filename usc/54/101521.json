{"tag":"section","attrib":{"id":"idef853bcc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101521"},"text":null,"children":[{"tag":"num","attrib":{"value":"101521"},"text":"§ 101521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation service and facility programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef853bcd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101521/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Formulation of Plans and Implementation of Projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may formulate transportation plans and implement transportation projects where feasible pursuant to those plans for System units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef853bce-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101521/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracts, Operations, and Acquisitions for Improvement of Access to System Units.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef853bcf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101521/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out subsection (a), the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef853bd0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101521/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contract with public or private agencies or carriers to provide transportation services, capital equipment, or facilities to improve access to System units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef853bd1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101521/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate those services directly in the absence of suitable and adequate agencies or carriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef853bd2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101521/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, by purchase, lease, or agreement, capital equipment for those services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef853bd3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101521/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where necessary to carry out this subchapter, acquire, by lease, purchase, donation, exchange, or transfer, land, water, or an interest in land or water that is situated outside the boundary of a System unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef853bd4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101521/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specific provisions related to property acquisition.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef853bd5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101521/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The acquired property shall be administered as part of the System unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef853bd6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101521/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquistion ","children":[],"tail":null},{"tag":"ref","attrib":{"idref":"fn002008"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002008"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “"},{"tag":"inline","attrib":{},"text":"Acquisition","children":[],"tail":"”."}],"tail":null},{"tag":"inline","attrib":{},"text":" ","children":[],"tail":null},{"tag":"inline","attrib":{},"text":"of land or interests in land owned by state or political subdivision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any land or interests in land owned by a State or any of its political subdivisions may be acquired only by donation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef853bd7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101521/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition subject to statutory limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any land acquisition shall be subject to any statutory limitations on methods of acquisition and appropriations as may be specifically applicable to the area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef853bd8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101521/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Information Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish information programs to inform the public of available System unit access opportunities and to promote the use of transportation modes other than personal motor vehicles for access to and travel within the System units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef853bd9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101521/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Undertaking Transportation Facilities and Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Transportation facilities and services provided pursuant to this subchapter may be undertaken by the Secretary directly or by contract without regard to any requirement of Federal, State, or local law respecting determinations of public convenience and necessity or other similar matters. The Secretary or contractor shall consult with the appropriate State or local public service commission or other body having authority to issue certificates of convenience and necessity. A contractor shall be subject to applicable requirements of that body unless the Secretary determines that the requirements would not be consistent with the purposes and provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8784ca-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101521/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction of Grant of Authority Respecting Operation of Motor Vehicles Excepted From Statutory Coverage","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No grant of authority in this subchapter shall be deemed to expand the exemption of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s13506/a/9"},"text":"section 13506(a)(9) of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8784cb-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3132"},"text":"128 Stat. 3132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8784cc-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef8784cd-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef8784ce-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101521","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s2302"},"text":"16 U.S.C. 2302","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/344/tIII/s302"},"text":"Pub. L. 95–344, title III, § 302","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 15, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/478"},"text":"92 Stat. 478","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/437/s6/d/18"},"text":"Pub. L. 103–437, § 6(d)(18)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/4584"},"text":"108 Stat. 4584","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/333/dI/tVIII/s814/d/1/A"},"text":"Pub. L. 104–333, div. I, title VIII, § 814(d)(1)(A)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/4195"},"text":"110 Stat. 4195","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2302/d"},"text":"16 U.S.C. 2302(d)","children":[],"tail":" is omitted as superseded by "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s5981"},"text":"16 U.S.C. 5981","children":[],"tail":", restated as section 101531 of the new title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “shall not be considered as concession facilities or services within the meaning of the Act of ","children":[{"tag":"date","attrib":{"date":"1965-10-09"},"text":"October 9, 1965","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/79/969"},"text":"79 Stat. 969","children":[],"tail":")” are omitted as obsolete because that Act was repealed by section 415(a) of the National Parks Omnibus Management Act of 1998 ("},{"tag":"ref","attrib":{"href":"/us/pl/105/391"},"text":"Public Law 105–391","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3515"},"text":"112 Stat. 3515","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “section 13506(a)(9)” are substituted for “section 10526(a)(9)” because of the general amendment of subtitle IV of title 49 by the ICC Termination Act of 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Public Law 104–88","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/802"},"text":"109 Stat. 802","children":[],"tail":"), in which provisions comparable to section 10526(a)(9) were enacted as section 13506(a)(9) ("},{"tag":"ref","attrib":{"href":"/us/stat/109/862"},"text":"109 Stat. 862","children":[],"tail":"). The words “section 10526(a)(9)” previously had been substituted for “section 203(b)(4) of the Interstate Commerce Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t49/s303/b/4"},"text":"49 U.S.C. 303(b)(4)","children":[],"tail":")” because of "},{"tag":"ref","attrib":{"href":"/us/act/1978-10-17/s3/b"},"text":"section 3(b) of the Act of October 17, 1978","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Public Law 95–473","children":[],"tail":", 92 Stat, 1466), the 1st section of which enacted subtitle IV of title 49."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef8784cf-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef8784d0-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Statement of Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/344/tIII/s301/b"},"text":"Pub. L. 95–344, title III, § 301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-15"},"text":"Aug. 15, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/478"},"text":"92 Stat. 478","children":[],"tail":", provided that “The purpose of this title [see Tables for classification] is to make the National Park System more accessible in a manner consistent with the preservation of parks and the conservation of energy by encouraging the use of transportation modes other than personal motor vehicles for access to and within units of the National Park System with minimum disruption to nearby communities through authorization of a pilot transportation program.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
