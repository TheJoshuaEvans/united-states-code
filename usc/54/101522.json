{"tag":"section","attrib":{"id":"idef8784d1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101522"},"text":null,"children":[{"tag":"num","attrib":{"value":"101522"},"text":"§ 101522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8784d2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101522/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance of Heads of Other Federal Departments and Agencies in Formulation and Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To carry out this subchapter, the Secretary of Transportation, the Secretary of Housing and Urban Development, the Secretary of Health and Human Services, the Secretary of Commerce, and the heads of other Federal departments or agencies that the Secretary considers necessary shall assist the Secretary in the formulation and implementation of transportation projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8784d3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101522/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compilation of Statutes and Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall maintain a compilation of Federal statutes and programs providing authority for the planning, funding, or operation of transportation projects that might be utilized by the Secretary to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8784d4-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":