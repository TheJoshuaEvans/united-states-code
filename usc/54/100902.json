{"tag":"section","attrib":{"id":"idef7e0ead-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902"},"text":null,"children":[{"tag":"num","attrib":{"value":"100902"},"text":"§ 100902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of way for public utilities and power and communication facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7e0eae-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Utilities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7e0eaf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations the Secretary prescribes, the Secretary may grant a right of way through a System unit to a citizen, association, or corporation of the United States that intends to use the right of way for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7e0eb0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electrical plants, poles, and lines for the generation and distribution of electrical power;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7e0eb1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" telephone and telegraph purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7e0eb2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" canals, ditches, pipes and pipe lines, flumes, tunnels, or other water conduits and water plants, dams, and reservoirs used to promote irrigation or mining or quarrying, or the manufacturing or cutting of timber or lumber, or the supplying of water for domestic, public, or any other beneficial uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0eb3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extent of right of way","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A right of way under this subsection shall be for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7e0eb4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ground occupied by the canals, ditches, flumes, tunnels, reservoirs, or other water conduits or water plants, or electrical or other works permitted under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7e0eb5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not more than 50 feet—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef7e0eb6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on each side of the marginal limits of the ground; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef7e0eb7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on each side of the center line of the pipes and pipe lines, electrical, telegraph, and telephone lines and poles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0eb8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A right of way under this subsection shall be allowed within or through a System unit only on the approval of the Secretary and on a finding that the right of way is not incompatible with the public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0eb9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revocation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may revoke a right of way under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0eba-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Right, easement, or interest not conferred","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A right of way under this subsection does not confer any right, easement, or interest in, to, or over a System unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7e0ebb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Power and Communication Facilities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7e0ebc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations the Secretary prescribes, the Secretary may grant a right of way over, across, and on through a System unit to a citizen, association, or corporation of the United States that intends to use the right of way for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7e0ebd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electrical poles and lines for the transmission and distribution of electrical power;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7e0ebe-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" poles and lines for communication purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7e0ebf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" radio, television, and other forms of communication transmitting, relay, and receiving structures and facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0ec0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extent of right of way","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A right of way under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7e0ec1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be for not more than 50 years from the date the right of way is granted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7e0ec2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef7e0ec3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lines and poles shall be for 200 feet on each side of the center line of the lines and poles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef7e0ec4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" radio, television, and other forms of communication transmitting, relay, and receiving structures and facilities shall be for not more than 400 feet by 400 feet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0ec5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A right of way under this subsection shall be allowed within or through a System unit only on the approval of the Secretary and on a finding that the right of way is not incompatible with the public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0ec6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forfeiture and annulment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may forfeit and annul any part of a right of way under this subsection for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7e0ec7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonuse for a period of 2 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7e0ec8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100902/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" abandonment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7e0ec9-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3113"},"text":"128 Stat. 3113","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7e0eca-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef7e0ecb-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef7e0ecc-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"htm