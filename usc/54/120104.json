{"tag":"section","attrib":{"id":"idef936b71-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120104"},"text":null,"children":[{"tag":"num","attrib":{"value":"120104"},"text":"§ 120104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef936b72-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At reasonable and appropriate intervals, as determined by the Secretary, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef936b73-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an evaluation of the accomplishments of a National Heritage Area in accordance with subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936b74-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives a report that includes recommendations for the continued role of the Service with respect to each National Heritage Area in accordance with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef936b75-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Components","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An evaluation under subsection (a)(1) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef936b76-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assess the progress of the applicable local coordinating entity of a National Heritage Area with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef936b77-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120104/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accomplishing the purposes of the applicable National Heritage Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936b78-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120104/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieving the goals and objectives of the management plan;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936b79-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze Federal, State, local, Tribal government, and private investments in the National Heritage Area to determine the leverage and impact of the investments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936b7a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the management structure, partnership relationships, and funding of the National Heritage Area for purposes of identifying the critical components for sustainability of the National Heritage Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef936b7b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a)(2) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef936b7c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the report contains a recommendation of the Secretary that Federal funding for the applicable National Heritage Area should be continued, an analysis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef936b7d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120104/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any means by which that Federal funding may be reduced or eliminated over time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936b7e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120104/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate time period necessary to achieve the recommended reduction or elimination of Federal funding; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936b7f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s120104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the report contains a recommendation of the Secretary that Federal funding for the applicable National Heritage Area should be eliminated, a description of potential impacts on conservation, interpretation, and sustainability in the applicable National Heritage Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef936b80-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/339/s2/a"},"text":"Pub. L. 117–339, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6161"},"text":"136 Stat. 6161","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
