{"tag":"section","attrib":{"id":"idefadaae9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311103"},"text":null,"children":[{"tag":"num","attrib":{"value":"311103"},"text":"§ 311103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of Preserve America Communities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefadaaea-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be considered for designation as a Preserve America Community, a community, tribal area, or neighborhood shall submit to the Council an application containing such information as the Council may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadaaeb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be designated as a Preserve America Community under the program, a community, tribal area, or neighborhood that submits an application under subsection (a) shall, as determined by the Chairman of the Council, in consultation with the Secretary, meet criteria required by the Chairman of the Council and, in addition, consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadaaec-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection and celebration of the heritage of the community, tribal area, or neighborhood;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadaaed-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of the historic assets of the community, tribal area, or neighborhood for economic development and community revitalization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadaaee-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouragement of people to experience and appreciate local historic resources through education and heritage tourism programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadaaef-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Local Governments Previously Certified for Historic Preservation Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall establish an expedited process for Preserve America Community designation for local governments previously certified for historic preservation activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302502"},"text":"section 302502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadaaf0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s311103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chairman of the Council, in consultation with the Secretary, shall establish any guidelines that are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefadaaf1-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3248"},"text":"128 Stat. 3248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/289/tV/s501/d"},"text":"Pub. L. 114–289, title V, § 501(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1490"},"text":"130 Stat. 1490","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefadaaf2-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefadaaf3-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefadaaf4-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical a