{"tag":"section","attrib":{"id":"idef9d0982-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302301"},"text":null,"children":[{"tag":"num","attrib":{"value":"302301"},"text":"§ 302301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the National Conference of State Historic Preservation Officers and the National Trust, shall promulgate regulations for State Historic Preservation Programs. The regulations shall provide that a State program submitted to the Secretary under this chapter shall be approved by the Secretary if the Secretary determines that the program provides for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9d0983-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the designation and appointment by the chief elected official of the State of a State Historic Preservation Officer to administer the program in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302303"},"text":"section 302303 of this title","children":[],"tail":" and for the employment or appointment by the officer of such professionally qualified staff as may be necessary for those purposes;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d0984-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an adequate and qualified State historic preservation review board designated by the State Historic Preservation Officer unless otherwise provided for by State law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d0985-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate public participation in the State Historic Preservation Program, including the process of recommending properties for nomination to the National Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9d0986-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3194"},"text":"128 Stat. 3194","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9d0987-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9d0988-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9d0989-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"302301","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470a/b/1"},"text":"16 U.S.C. 470a(b)(1)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/665/tI/s101/b/1"},"text":"Pub. L. 89–665, title I, § 101(b)(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/915"},"text":"80 Stat. 915","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/91/383/s11"},"text":"Pub. L. 91–383, § 11","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/94/458/s2"},"text":"Pub. L. 94–458, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 7, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/1942"},"text":"90 Stat. 1942","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/93/54/s1/d"},"text":"Pub. L. 93–54, § 1(d)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 1, 1973","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/87/139"},"text":"87 Stat. 139","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/205/tVI/s608/a/1"},"text":"Pub. L. 96–205, title VI, § 608(a)(1)","children":[],"tail":", (2), "},{"tag":"html:span","attrib":{},"text":"Mar. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/92"},"text":"94 Stat. 92","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/515/tII/s201/a"},"text":"Pub. L. 96–515, title II, § 201(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/2990"},"text":"94 Stat. 2990","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Before paragraph (1), the words “or revise” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1), the words “chief elected official” are substituted for “Governor” for clarity because the definition of “State” in section 300316 of the new title includes entities in which the chief elected official is not the Governor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
