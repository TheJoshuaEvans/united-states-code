{"tag":"section","attrib":{"id":"idef984d6a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306"},"text":null,"children":[{"tag":"num","attrib":{"value":"200306"},"text":"§ 200306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of Fund amounts for Federal purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef984d6b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allowable Purposes and Subpurposes.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef984d6c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts appropriated from the Fund for Federal purposes shall, unless otherwise allotted in the appropriation Act making them available, be allotted by the President for the purposes and subpurposes stated in this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984d6d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition of land, water, or an interest in land or water.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef984d6e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"System units and recreation areas administered for recreation purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts shall be allotted for the acquisition of land, water, or an interest in land or water within the exterior boundary of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef984d6f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a System unit authorized or established; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef984d70-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an area authorized to be administered by the Secretary for outdoor recreation purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984d71-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National forest system.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idef984d72-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts shall be allotted for the acquisition of land, water, or an interest in land or water within inholdings within—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef984d73-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wilderness areas of the National Forest System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef984d74-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other areas of national forests as the boundaries of those forests existed on ","children":[{"tag":"date","attrib":{"date":"1965-01-01"},"text":"January 1, 1965","children":[],"tail":", or purchase units approved by the National Forest Reservation Commission subsequent to "},{"tag":"date","attrib":{"date":"1965-01-01"},"text":"January 1, 1965","children":[],"tail":", all of which other areas are primarily of value for outdoor recreation purposes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef984d75-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjacent land","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Land outside but adjacent to an existing national forest boundary, not to exceed 3,000 acres in the case of any one forest, that would comprise an integral part of a forest recreational management area may also be acquired with amounts appropriated from the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984d76-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Endangered species and threatened species; fish and wildlife refuge areas; national wildlife refuge system","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts shall be allotted for the acquisition of land, water, or an interest in land or water for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef984d77-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" endangered species and threatened species authorized under section 5(a) of the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1534/a"},"text":"16 U.S.C. 1534(a)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef984d78-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas authorized by section 2 of the Refuge Recreation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460k–1"},"text":"16 U.S.C. 460k–1","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef984d79-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national wildlife refuge areas under section 7(a)(4) of the Fish and Wildlife Act of 1956 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s742f/a/4"},"text":"16 U.S.C. 742f(a)(4)","children":[],"tail":") and wetlands acquired under section 304 of the Emergency Wetlands Resources Act of 1986 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3922"},"text":"16 U.S.C. 3922","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef984d7a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any area authorized for the National Wildlife Refuge System by specific Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984d7b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment as offset of capital costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts shall be allotted for payment into miscellaneous receipts of the Treasury as a partial offset for capital costs, if any, of Federal water development projects authorized to be constructed by or pursuant to an Act of Congress that are allocated to public recreation and the enhancement of fish and wildlife values and financed through appropriations to water resource agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984d7c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Appropriations allotted for the acquisition of land, water, or an interest in land or water as set forth under subparagraphs (A) and (B) of paragraph (2) shall be available for those acquisitions notwithstanding any statutory ceiling on the appropriations contained in any other provision of law enacted prior to ","children":[{"tag":"date","attrib":{"date":"1977-01-04"},"text":"January 4, 1977","children":[],"tail":", or, in the case of national recreation areas, prior to "},{"tag":"date","attrib":{"date":"1979-01-15"},"text":"January 15, 1979","children":[],"tail":", except that for any such area expenditures shall not exceed a statutory ceiling during any one fiscal year by 10 percent of the ceiling or $1,000,000, whichever is greater."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984d7d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition Restrictions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Appropriations from the Fund pursuant to this section shall not be used for acquisition unless the acquisition is otherwise authorized by law. Appropriations from the Fund may be used for preacquisition work where authorization is imminent and where substantial monetary savings could be realized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984d7e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recreational Public Access.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef984d7f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts made available for expenditure in any fiscal year under section 200303, there shall be made available for recreational public access projects identified on the priority list developed under paragraph (2) not less than the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef984d80-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 3 percent of those amounts; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984d81-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984d82-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority list","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary and the Secretary of Agriculture, in consultation with the head of each affected Federal agency, shall annually develop a priority list for projects that, through acquisition of land (or an interest in land), secure recreational public access to Federal land under the jurisdiction of the applicable Secretary for hunting, fishing, recreational shooting, or other outdoor recreational purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984d83-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether to acquire land (or an interest in land) under this section, the Secretary and the Secretary of Agriculture shall take into account—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef984d84-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the significance of the acquisition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984d85-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the urgency of the acquisition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984d86-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management efficiencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984d87-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management cost savings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984d88-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geographic distribution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984d89-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" threats to the integrity of the land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984d8a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200306/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recreational value of the land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef984d8b-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3177"},"text":"128 Stat. 3177","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tIII/s3001/d"},"text":"Pub. L. 116–9, title III, § 3001(d)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/755"},"text":"133 Stat. 755","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/152/s3/b/2"},"text":"Pub. L. 116–152, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-08-04"},"text":"Aug. 4, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/687"},"text":"134 Stat. 687","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef984d8c-3a70-11f1-83cd-8a39