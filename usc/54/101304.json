{"tag":"section","attrib":{"id":"idef853b16-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101304"},"text":null,"children":[{"tag":"num","attrib":{"value":"101304"},"text":"§ 101304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal equipment and property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef853b17-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purchase of Personal Equipment and Supplies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may purchase personal equipment and supplies for employees of the Service and make deductions for the equipment and supplies from amounts appropriated for salary payments or otherwise due the employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef853b18-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lost, Damaged, or Destroyed Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in the administration of the Service, may reimburse employees and other owners of horses, vehicles, and other equipment lost, damaged, or destroyed while in the custody of the employee or the Department of the Interior, under authorization, contract, or loan, for necessary firefighting, trail, or other official business. Reimbursement shall be made from any available funds in the appropriation to which the hire of the equipment would be properly chargeable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef853b19-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Equipment Required To Be Furnished by Field Employees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef853b1a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require field employees of the Service to furnish horses, motor and other vehicles, and miscellaneous equipment necessary for the performance of their official work; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef853b1b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, at Federal Government expense, forage, care, and housing for animals, and housing or storage and fuel for vehicles and other equipment required to be furnished.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef853b1c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hire, Rental, and Purchase of Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, under regulations the Secretary may prescribe, may authorize the hire, rental, or purchase of property from employees of the Service whenever it would promote the public interest to do so.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef853b1d-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3124"},"text":"128 Stat. 3124","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef853b1e-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef853b1f-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef853b20-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.