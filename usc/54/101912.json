{"tag":"section","attrib":{"id":"idef878551-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101912"},"text":null,"children":[{"tag":"num","attrib":{"value":"101912"},"text":"§ 101912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and declaration of policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef878552-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In furtherance of section 100101(a), Congress finds that the preservation and conservation of System unit resources and values requires that public accommodations, facilities, and services that have to be provided within those System units should be provided only under carefully controlled safeguards against unregulated and indiscriminate use, so that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef878553-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101912/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" visitation will not unduly impair those resources and values; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef878554-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101912/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of public accommodations, facilities, and services within System units can best be limited to locations that are consistent to the highest practicable degree with the preservation and conservation of the resources and values of the System units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef878555-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Declaration of Policy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the policy of Congress that the development of public accommodations, facilities, and services in System units shall be limited to accommodations, facilities, and services that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef878556-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101912/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are necessary and appropriate for public use and enjoyment of the System unit in which they are located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef878557-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101912/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent to the highest practicable degree with the preservation and conservation of the resources and values of the System unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef878558-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3138"},"text":"128 Stat. 3138","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef878559-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef87855a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef87855b-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101912","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s5951"},"text":"16 U.S.C. 5951","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/105/391/tIV/s402"},"text":"Pub. L. 105–391, title IV, § 402","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/3503"},"text":"112 Stat. 3503","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “section 100101(a)” are substituted for “sections 1, 2, 3, and 4 of this title, which directs the Secretary to administer units of the National Park System in accordance with the fundamental purpose of conserving their scenery, wildlife, and natural and historic objects, and providing for their enjoyment in a manner that will leave them unimpaired for the enjoyment of future generations” to give a more precise cross reference because section 100101(a) of the new title is where that direction to the Secretary is restated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef87855c-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef87855d-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of National Park Service Concessions Policy Act; Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/391/tIV/s415/a"},"text":"Pub. L. 105–391, title IV, § 415(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3515"},"text":"112 Stat. 3515","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/391/tIV/s415/a"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/249"},"text":"Public Law 89–249","children":[],"tail":" (commonly known as the National Park Service Concessions Policy Act; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s20"},"text":"16 U.S.C. 20","children":[],"tail":" et seq.) is repealed. The repeal of such Act shall not affect the validity of any concessions contract or permit entered into under such Act, but the provisions of this title [enacting former sections 5951 to 5966 of Title 16, Conservation, which were repealed and restated in sections 101911 et seq. and 101524 of this title, amending former sections 1a–7 and 3 of Title 16, repealing section 17b–1 and subchapter IV of chapter 1 of Title 16, and enacting provisions set out as notes under this section and sections 100101 and 101911 of this title] shall apply to any such contract or permit except to the extent such provisions are inconsistent with the terms and conditions of any such contract or permit. References in this title to concessions contracts awarded under authority of such Act also apply to concessions permits awarded under such authority.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
