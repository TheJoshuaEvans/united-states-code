l:a","attrib":{"href":"/us/stat/114/28"},"text":"114 Stat. 28","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"100901(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s1a–2/f"},"text":"16 U.S.C. 1a–2(f)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/91/383/s3/f"},"text":"Pub. L. 91–383, § 3(f)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 18, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/827"},"text":"84 Stat. 827","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/106/176/tI/s118/2"},"text":"Pub. L. 106–176, title I, § 118(2)","children":[],"tail":", (3), "},{"tag":"html:span","attrib":{},"text":"Mar. 10, 2000","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/114/28"},"text":"114 Stat. 28","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"100901(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s1b/2"},"text":"16 U.S.C. 1b(2)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"100901(e) through (h)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s1b/5"},"text":"16 U.S.C. 1b(5)","children":[],"tail":" through (8)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “and he may use applicable appropriations for the aforesaid system for the following purposes” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1b"},"text":"16 U.S.C. 1b","children":[],"tail":" (matter before (1)) are omitted as unnecessary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
