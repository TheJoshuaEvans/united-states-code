{"tag":"section","attrib":{"id":"idef7e0e93-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901"},"text":null,"children":[{"tag":"num","attrib":{"value":"100901"},"text":"§ 100901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary to carry out certain activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7e0e94-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To facilitate the administration of the System, the Secretary, under such terms and conditions as the Secretary may consider advisable, may carry out the activities described in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7e0e95-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Services, Resources, or Water Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enter into contracts that provide for the sale or lease to persons, States, or political subdivisions of States, of services, resources, or water available within a System unit, as long as the activity does not jeopardize or unduly interfere with the primary natural or historic resource of the System unit, if the person, State, or political subdivision—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7e0e96-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides public accommodations or services within the immediate vicinity of the System unit to individuals visiting the System unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0e97-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates to the Secretary that there are no reasonable alternatives by which to acquire or perform the necessary services, resources, or water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7e0e98-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vehicular Air Conditioning","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may acquire, and have installed, air conditioning units for any Government-owned passenger motor vehicles used by the Service, where assigned duties necessitate long periods in automobiles or in regions of the United States where high temperatures and humidity are common and prolonged.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7e0e99-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Utility Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may erect and maintain fire protection facilities, water lines, telephone lines, electric lines, and other utility facilities adjacent to any System unit, where necessary, to provide service in the System unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7e0e9a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supplies and Rental of Equipment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may furnish, on a reimbursement of appropriation basis, supplies, and rent equipment, to persons and agencies that, in cooperation with and subject to the approval of the Secretary, render services or perform functions that facilitate or supplement the activities of the Department of the Interior in the administration of the System. The reimbursements may be credited to the appropriation current at the time reimbursements are received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7e0e9b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracts for Utility Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may contract, under terms and conditions that the Secretary considers to be in the interest of the Federal Government, for the sale, operation, maintenance, repair, or relocation of Government-owned electric and telephone lines and other utility facilities used for the administration and protection of the System, regardless of whether the lines and facilities are located within or outside the System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7e0e9c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rights of Way Necessary To Construct, Improve, and Maintain Roads","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may acquire—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7e0e9d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rights of way necessary to construct, improve, and maintain roads within the authorized boundaries of any System unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0e9e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" land and interests in land adjacent to the rights of way, when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7e0e9f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" considered necessary by the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef7e0ea0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/g/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide adequate protection of natural features; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef7e0ea1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/g/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to avoid traffic and other hazards resulting from private road access connections; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7e0ea2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of adjacent residual tracts, which otherwise would remain after acquiring the rights of way, would be in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7e0ea3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation and Maintenance of Motor and Other Equipment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7e0ea4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may operate, repair, maintain, and replace motor and other equipment on a reimbursable basis when the equipment is used on Federal projects of the System, chargeable to other appropriations, or on work of other Federal agencies, when requested by the agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0ea5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Reimbursement shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7e0ea6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made from appropriations applicable to the work on which the equipment is used at rental rates established by the Secretary, based on actual or estimated cost of operation, repair, maintenance, depreciation, and equipment management control; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7e0ea7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credited to appropriations currently available at the time adjustment is effected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0ea8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100901/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rental of equipment for fire control purposes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may rent equipment for fire control purposes to State, county, private, or other non-Federal agencies that cooperate with the Secretary in the administration of the System and other areas in fire control. The rental shall be under the terms of written cooperative agreements. The amount collected for the rentals shall be credited to appropriations currently available at the time payment is received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7e0ea9-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3112"},"text":"128 Stat. 3112","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7e0eaa-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef7e0eab-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef7e0eac-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"100901(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s1a–2"},"text":"16 U.S.C. 1a–2","children":[],"tail":" (matter before (a))."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/91/383/s3"},"text":"Pub. L. 91–383, § 3","children":[],"tail":" (matter before (a)), "},{"tag":"html:span","attrib":{},"text":"Aug. 18, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/826"},"text":"84 Stat. 826","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s1b"},"text":"16 U.S.C. 1b","children":[],"tail":" (matter before (1))."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/19