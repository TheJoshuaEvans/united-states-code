{"tag":"section","attrib":{"id":"idef9d0939-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302102"},"text":null,"children":[{"tag":"num","attrib":{"value":"302102"},"text":"§ 302102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of properties on National Register","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9d093a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A property that meets the criteria for National Historic Landmarks established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302103"},"text":"section 302103 of this title","children":[],"tail":" shall be designated as a National Historic Landmark and included on the National Register, subject to the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s302107"},"text":"section 302107 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9d093b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Historic Property on National Register on December ","children":[],"tail":"12, 1980.—"}],"tail":null},{"tag":"content","attrib":{},"text":"All historic property included on the National Register on ","children":[{"tag":"date","attrib":{"date":"1980-12-12"},"text":"December 12, 1980","children":[],"tail":", shall be deemed to be included on the National Register as of their initial listing for purposes of this division."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9d093c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Historic Property Listed in Federal Register of February ","children":[],"tail":"6, 1979, "},{"tag":"inline","attrib":{},"text":"or Prior to December ","children":[],"tail":"12, 1980, "},{"tag":"inline","attrib":{},"text":"as National Historic Landmarks","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All historic property listed in the Federal Register of ","children":[{"tag":"date","attrib":{"date":"1979-02-06"},"text":"February 6, 1979","children":[],"tail":", or prior to "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"December 12, 1980","children":[],"tail":", as National Historic Landmarks are declared by Congress to be National Historic Landmarks of national historic significance as of their initial listing in the Federal Register for purposes of this division and chapter 3201 of this title, except that in the case of a National Historic Landmark district for which no boundaries had been established as of "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"December 12, 1980","children":[],"tail":", boundaries shall first be published in the Federal Register."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9d093d-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3191"},"text":"128 Stat. 3191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9d093e-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalA