{"tag":"section","attrib":{"id":"idefa8f035-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308104"},"text":null,"children":[{"tag":"num","attrib":{"value":"308104"},"text":"§ 308104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Battlefield interpretation modernization grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa8f036-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish a battlefield interpretation modernization grant program under which the Secretary may provide competitive grants to States, Tribes, local governments, and nonprofit organizations for projects and programs that deploy technology to modernize battlefield interpretation and education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f037-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Sites","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make grants under this section for Revolutionary War, War of 1812, and Civil War battlefield sites eligible for assistance under the battlefield acquisition grant program established under section 308103(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f038-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of a project or program funded through a grant provided under the program established under subsection (a) shall be not more than 50 percent of the total cost of the applicable project or program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f039-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Secretary to provide grants under this section $1,000,000 for each of fiscal years 2020 through 2028.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa8f03a-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tVII/s703/a"},"text":"Pub. L. 116–94, div. P, title VII, § 703(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3195"},"text":"133 Stat. 3195","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
