{"tag":"section","attrib":{"id":"idef912229-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s104909"},"text":null,"children":[{"tag":"num","attrib":{"value":"104909"},"text":"§ 104909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildlife management in parks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef91222a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s104909/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Qualified Volunteers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary determines it is necessary to reduce the size of a wildlife population on System land in accordance with applicable law (including regulations), the Secretary may use qualified volunteers to assist in carrying out wildlife management on System land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef91222b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s104909/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Qualified Volunteers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Qualified volunteers providing assistance under subsection (a) shall be subject to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef91222c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s104909/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any training requirements or qualifications established by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef91222d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s104909/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other terms and conditions that the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef91222e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s104909/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Donations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may authorize the donation and distribution of meat and any other part of an animal removed pursuant to wildlife management activities carried out under this section, including the donation and distribution to Indian Tribes, qualified volunteers, food banks, and other organizations that work to address hunger, in accordance with applicable health guidelines and such terms and conditions as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef91222f-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2410/a"},"text":"Pub. L. 116–9, title II, § 2410(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/752"},"text":"133 Stat. 752","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s126"},"text":"Pub. L. 118–234, title I, § 126","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2855"},"text":"138 Stat. 2855","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef912230-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef912231-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef912232-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234"},"text":"Pub. L. 118–234","children":[],"tail":" substituted “meat and any other part of an animal removed pursuant to” for “meat from”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
