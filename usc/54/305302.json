{"tag":"section","attrib":{"id":"idefa434c5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305302"},"text":null,"children":[{"tag":"num","attrib":{"value":"305302"},"text":"§ 305302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Center for Preservation Technology and Training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa434c6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established within the Department of the Interior a National Center for Preservation Technology and Training. The Center shall be located at Northwestern State University of Louisiana in Natchitoches, Louisiana.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa434c7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Center shall be to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa434c8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and distribute preservation and conservation skills and technologies for the identification, evaluation, conservation, and interpretation of historic property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa434c9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and facilitate training for Federal, State, and local resource preservation professionals, cultural resource managers, maintenance personnel, and others working in the preservation field;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa434ca-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305302/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take steps to apply preservation technology benefits from ongoing research by other agencies and institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa434cb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305302/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the transfer of preservation technology among Federal agencies, State and local governments, universities, international organizations, and the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa434cc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305302/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with related international organizations including the International Council on Monuments and Sites, the International Center for the Study of Preservation and Restoration of Cultural Property, and the International Council on Museums.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa434cd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purposes shall be carried out through research, professional training, technical assistance, and programs for public awareness, and through a program of grants established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s305304"},"text":"section 305304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa434ce-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Center shall be headed by an Executive Director with demonstrated expertise in historic preservation appointed by the Secretary with advice of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa434cf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305302/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance From Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide the Center assistance in obtaining such personnel, equipment, and facilities as may be needed by the Center to carry out its activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa434d0-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3221"},"text":"128 Stat. 3221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa434d1-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa434d2-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa434d3-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","childre