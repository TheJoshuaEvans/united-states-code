{"tag":"section","attrib":{"id":"idef853b85-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101339"},"text":null,"children":[{"tag":"num","attrib":{"value":"101339"},"text":"§ 101339.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment and priority listing","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef853b86-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101339/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete a condition assessment for all field employee housing, including the physical condition of the housing and the necessity and suitability of the housing for carrying out the mission of the Service, using existing information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef853b87-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101339/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a Service-wide priority listing, by structure, identifying the units in greatest need for repair, rehabilitation, replacement, or initial construction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef853b88-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3129"},"text":"128 Stat. 3129","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef853b89-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef853b8a-3a70-