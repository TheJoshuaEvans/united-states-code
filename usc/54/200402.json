{"tag":"section","attrib":{"id":"idef984dc1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402"},"text":null,"children":[{"tag":"num","attrib":{"value":"200402"},"text":"§ 200402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Parks and Public Land Legacy Restoration Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef984dc2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Treasury of the United States a fund to be known as the “National Parks and Public Land Legacy Restoration Fund”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984dc3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposits.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef984dc4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), for each of fiscal years 2021 through 2025, there shall be deposited in the Fund an amount equal to 50 percent of all energy development revenues due and payable to the United States from oil, gas, coal, or alternative or renewable energy development on Federal land and water credited, covered, or deposited as miscellaneous receipts under Federal law in the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984dc5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount deposited in the Fund under paragraph (1) shall not exceed $1,900,000,000 for any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984dc6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on other revenues","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section affects the disposition of revenues that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef984dc7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are due to the United States, special funds, trust funds, or States from mineral and energy development on Federal land and water; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984dc8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have been otherwise appropriated—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef984dc9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under Federal law, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef984dca-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/b/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Gulf of Mexico Energy Security Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"43 U.S.C. 1331","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Public Law 109–432","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef984dcb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/b/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Mineral Leasing Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s181"},"text":"30 U.S.C. 181","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef984dcc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" from—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef984dcd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/b/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Land and Water Conservation Fund established under chapter 2003; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef984dce-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/b/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Historic Preservation Fund established under chapter 3031.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984dcf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts deposited in the Fund shall be available to the Secretary and the Secretary of Agriculture, as provided in subsection (e), without further appropriation or fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984dd0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investment of Amounts.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef984dd1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may request the Secretary of the Treasury to invest any portion of the Fund that is not, as determined by the Secretary, in consultation with the Secretary of Agriculture, required to meet the current needs of the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984dd2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An investment requested under paragraph (1) shall be made by the Secretary of the Treasury in a public debt security—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef984dd3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with a maturity suitable to the needs of the Fund, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984dd4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bearing interest at a rate determined by the Secretary of the Treasury, taking into consideration current market yields on outstanding marketable obligations of the United States of comparable maturity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984dd5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credits to fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The income on investments of the Fund under this subsection shall be credited to, and form a part of, the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984dd6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef984dd7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts deposited in the Fund for each fiscal year shall be used for priority deferred maintenance projects in the System, in the National Wildlife Refuge System, on public land administered by the Bureau of Land Management, for the Bureau of Indian Education schools, and in the National Forest System, as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef984dd8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 70 percent of the amounts deposited in the Fund for each fiscal year shall be allocated to the Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984dd9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 15 percent of the amounts deposited in the Fund for each fiscal year shall be allocated to the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984dda-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 percent of the amounts deposited in the Fund for each fiscal year shall be allocated to the United States Fish and Wildlife Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984ddb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 percent of the amounts deposited in the Fund for each fiscal year shall be allocated to the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984ddc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 percent of the amounts deposited in the Fund for each fiscal year shall be allocated to the Bureau of Indian Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984ddd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef984dde-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-transportation projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Over the term of the Fund, within each covered agency, not less than 65 percent of amounts from the Fund shall be allocated for non-transportation projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984ddf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amounts remaining in the Fund after the allocations required under subparagraph (A) may be allocated for transportation projects of the covered agencies, including paved and unpaved roads, bridges, tunnels, and paved parking areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984de0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any priority deferred maintenance project funded under this section shall be consistent with an applicable transportation, deferred maintenance, or capital improvement plan developed by the applicable covered agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984de1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No amounts in the Fund shall be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef984de2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for land acquisition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984de3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to supplant discretionary funding made available for annually recurring facility operations, maintenance, and construction needs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984de4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for bonuses for employees of the Federal Government that are carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984de5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Priority List of Projects to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date of enactment of this section, the Secretary and the Secretary of Agriculture shall submit to the Committees on Energy and Natural Resources and Appropriations of the Senate and the Committees on Natural Resources and Appropriations of the House of Representatives a list of projects to be funded for fiscal year 2021 that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef984de6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are identified by the Secretary and the Secretary of Agriculture as priority deferred maintenance projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984de7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of the date of the submission of the list, are ready to be implemented.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984de8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Annual List of Projects to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Until the date on which all of the amounts in the Fund are expended, the President shall annually submit to Congress, together with the annual budget of the United States, a list of projects to be funded from the Fund that includes a detailed description of each project, including the estimated expenditures from the Fund for the project for the applicable fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984de9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternate Allocation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef984dea-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Appropriations Acts may provide for alternate allocation of amounts made available under this section, consistent with the allocations to covered agencies under subsection (e)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984deb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation by president.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef984dec-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No alternate allocations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If Congress has not enacted legislation establishing alternate allocations by the date on which the Act making full-year appropriations for the Department of the Interior, Environment, and Related Agencies for the applicable fiscal year is enacted into law, amounts made available under subsection (c) shall be allocated by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984ded-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Insufficient alternate allocation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If Congress enacts legislation establishing alternate allocations for amounts made available under subsection (c) that are less than the full amount appropriated under that subsection, the difference between the amount appropriated and the alternate allocation shall be allocated by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984dee-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Donations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef984def-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary and the Secretary of Agriculture may accept public cash or in-kind donations that advance efforts—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef984df0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the deferred maintenance backlog; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984df1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage relevant public-private partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984df2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credits to fund","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any cash donations accepted under paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef984df3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credited to, and form a part of, the Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984df4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocated to the covered agency for which the donation was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984df5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other allocations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any donations allocated to a covered agency under paragraph (2)(B) shall be allocated to the applicable covered agency independently of the allocations under subsection (e)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef984df6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200402/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Consideration for Accessibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In expending amounts from the Fund, the Secretary and the Secretary of Agriculture shall incorporate measures to improve the accessibility of assets and accommodate visitors and employees with disabilities in accordance with applicable law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef984df7-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/152/s2/a"},"text":"Pub. L. 116–152, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-08-04"},"text":"Aug. 4, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/683"},"text":"134 Stat. 683","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef984df8-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef984df9-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef984dfa-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Gulf of Mexico Energy Security Act of 2006, referred to in subsec. (b)(3)(B)(i)(I), is title I of div. C of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3000"},"text":"120 Stat. 3000","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Mineral Leasing Act, referred to in subsec. (b)(3)(B)(i)(II), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-02-25/ch85"},"text":"act Feb. 25, 1920, ch. 85","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/437"},"text":"41 Stat. 437","children":[],"tail":", which is classified generally to chapter 3A (§ 181 et seq.) of Title 30, Mineral Lands and Mining. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s181"},"text":"section 181 of Title 30","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (g), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/152"},"text":"Pub. L. 116–152","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2020-08-04"},"text":"Aug. 4, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef984dfb-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef984dfc-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Allocation of Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For certain requirements regarding allocation of funds pursuant to subsec. (c) of this section and as provided in subsec. (e) of this section, see section 430(a)–(c) of div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42"},"text":"Pub. L. 118–42","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s200303"},"text":"section 200303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
