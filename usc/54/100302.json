ll}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-08-25/ch408/s1"},"text":"Aug. 25, 1916, ch. 408, § 1","children":[],"tail":" (5th sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “of the Hot Springs Reservation in the State of Arkansas” [changed to “Hot Springs National Park” because of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-03-04/s1"},"text":"section 1 of the Act of March 4, 1921","children":[],"tail":" (ch. 161, "},{"tag":"ref","attrib":{"href":"/us/stat/41/1407"},"text":"41 Stat. 1407","children":[],"tail":")] in "},{"tag":"ref","attrib":{"href":"/us/act/1916-08-25/s2"},"text":"section 2 of the Act of August 25, 1916","children":[],"tail":" (known as the National Park Service Organic Act) (ch. 408, "},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":") are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) is substituted for the 5th sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-25/s1"},"text":"section 1 of the Act of August 25, 1916","children":[],"tail":" (known as the National Park Service Organic Act) (ch. 408, "},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":"), to eliminate unnecessary words and because the pay of employees is fixed pursuant to chapter 51 and subchapter III of chapter 53 of title 5."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
