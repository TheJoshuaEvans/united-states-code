{"tag":"section","attrib":{"id":"idef984db4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200401"},"text":null,"children":[{"tag":"num","attrib":{"value":"200401"},"text":"§ 200401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef984db5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Asset","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “asset” means any real property, including any physical structure or grouping of structures, landscape, trail, or other tangible property, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef984db6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200401/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a specific service or function; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984db7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200401/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is tracked and managed as a distinct, identifiable entity by the applicable covered agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984db8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered agency","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef984db9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200401/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984dba-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200401/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Fish and Wildlife Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984dbb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200401/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Forest Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984dbc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200401/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Land Management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef984dbd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200401/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Indian Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984dbe-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Fund” means the National Parks and Public Land Legacy Restoration Fund established by section 200402(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef984dbf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200401/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “project” means any activity to reduce or eliminate deferred maintenance of an asset, which may include resolving directly related infrastructure deficiencies of the asset that would not by itself be classified as deferred maintenance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef984dc0-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/152/s2/a"},"text":"Pub. L. 116–152, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-08-04"},"text":"Aug. 4, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/682"},"text":"134 Stat. 682","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
