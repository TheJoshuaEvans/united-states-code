{"tag":"section","attrib":{"id":"idef8784d8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101523"},"text":null,"children":[{"tag":"num","attrib":{"value":"101523"},"text":"§ 101523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures applicable to transportation plans and projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8784d9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101523/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"During Formulation of Plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, during the formulation of any transportation plan authorized pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s101521"},"text":"section 101521 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8784da-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101523/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give public notice of intention to formulate the plan by publication in the Federal Register and in a newspaper or periodical having general circulation in the vicinity of the affected System unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8784db-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101523/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" following the notice, hold a public meeting at a location convenient to the affected System unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8784dc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101523/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prior to Implementation of Project","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to the implementation of any project developed pursuant to the transportation plan formulated pursuant to subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8784dd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101523/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures, including public meetings, to give State and local governments and the public adequate notice and an opportunity to comment on the proposed transportation project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8784de-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101523/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the proposed project would involve an expenditure in excess of $100,000 in any fiscal year, submit a detailed report to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8784df-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101523/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiting Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When a report on a project is required under subsection (b)(2), the Secretary may proceed with the implementation of the project only after 60 days (not counting days on which the Senate or House of Representatives has adjourned for more than 3 consecutive days) have elapsed following submission of the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8784e0-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3133"},"text":"128 Stat. 3133","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8784e1-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef8784e2-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef8784e3-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101523","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s2304"},"text":"16 U.S.C. 2304","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/344/tIII/s304"},"text":"Pub. L. 95–344, title III, § 304","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 15, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/479"},"text":"92 Stat. 479","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/437/s6/d/18"},"text":"Pub. L. 103–437, § 6(d)(18)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/4584"},"text":"108 Stat. 4584","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “When a report on a project is required under subsection (b)(2)” are added for clarity. The words “implementation of the project” are substituted for “implementation of such plan”, and the words “submission of the report” are substituted for “submission of the plan”, for consistency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
