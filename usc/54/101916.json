{"tag":"section","attrib":{"id":"idef89f5c5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101916"},"text":null,"children":[{"tag":"num","attrib":{"value":"101916"},"text":"§ 101916.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonableness of rates and charges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef89f5c6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101916/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A concession contract shall permit the concessioner to set reasonable and appropriate rates and charges for facilities, goods, and services provided to the public, subject to approval under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef89f5c7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101916/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval by Secretary Required.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef89f5c8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101916/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors to consider","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A concessioner’s rates and charges to the public shall be subject to approval by the Secretary. The approval process utilized by the Secretary shall be as prompt and as unburdensome to the concessioner as possible and shall rely on market forces to establish reasonableness of rates and charges to the maximum extent practicable. The Secretary shall approve rates and charges that the Secretary determines to be reasonable and appropriate. Unless otherwise provided in the concession contract, the reasonableness and appropriateness of rates and charges shall be determined primarily by comparison with those rates and charges for facilities, goods, and services of comparable character under similar conditions, with due consideration to the following factors and other factors deemed relevant by the Secretary:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef89f5c9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101916/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Length of season.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef89f5ca-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101916/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Peakloads.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef89f5cb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101916/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Average percentage of occupancy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef89f5cc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101916/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Accessibility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef89f5cd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101916/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Availability and costs of labor and materials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef89f5ce-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101916/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Type of patronage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef89f5cf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101916/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rates and charges not to exceed market rates and charges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Rates and charges may not exceed the market rates and charges for comparable facilities, goods, and services, after taking into account the factors referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef89f5d0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101916/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation of Recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 6 months after receiving recommendations from the Advisory Board regarding concessioner rates and charges to the public, the Secretary shall implement the recommendations or report to Congress the reasons for not implementing the recommendations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef89f5d1-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3145"},"text":"128 Stat. 3145","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef89f5d2-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef89f5d3-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef89f5d4-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text"