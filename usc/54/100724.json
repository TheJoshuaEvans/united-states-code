{"tag":"section","attrib":{"id":"idef7b9e0b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100724"},"text":null,"children":[{"tag":"num","attrib":{"value":"100724"},"text":"§ 100724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of recovered amounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7b9e0c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Use","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Response costs and damages recovered by the Secretary under this subchapter or amounts recovered by the Federal Government under any Federal, State, or local law or regulation or otherwise as a result of destruction, loss of, or injury to any System unit resource shall be available to the Secretary and without further Congressional action may be used only as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7b9e0d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100724/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To reimburse response costs and damage assessments by the Secretary or other Federal agencies as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7b9e0e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100724/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restoration and replacement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To restore, replace, or acquire the equivalent of System unit resources that were the subject of the action and to monitor and study those System unit resources. The funds may not be used to acquire any land or water, interest in land or water, or right to land or water unless the acquisition is specifically approved in advance in appropriations Acts. The acquisition shall be subject to any limitations contained in the legislation establishing the System unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7b9e0f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Excess Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amounts remaining after expenditures pursuant to paragraphs (1) and (2) of subsection (a) shall be deposited in the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7b9e10-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3108"},"text":"128 Stat. 3108","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7b9e11-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef7b9e12-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef7b9e13-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"100724","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s19jj–3"},"text":"16 U.S.C. 19jj–3","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/101/337/s4"},"text":"Pub. L. 101–337, § 4","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 27, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/380"},"text":"104 Stat. 380","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/437/s6/d/3"},"text":"Pub. L. 103–437, § 6(d)(3)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 12, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/4583"},"text":"108 Stat. 4583","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1990-07-27/s4/d"},"text":"Section 4(d) of the Act of July 27, 1990","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/101/337"},"text":"Public Law 101–337","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/380"},"text":"104 Stat. 380","children":[],"tail":"), is omitted as obsolete. See section 3003 of the Federal Reports Elimination and Sunset Act of 1995 (Public Land 104–66, "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"31 U.S.C. 1113","children":[],"tail":" note) and page 111 of House Document No. 103–7."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before paragraph (1), the words “destruction, loss, or injury to” are substituted for “damage to” for consistency in the new chapter and to distinguish destruction, loss, or injury from damages recovered in a civil action.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “the General Fund of the United States” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
