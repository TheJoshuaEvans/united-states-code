{"tag":"section","attrib":{"id":"idef853bae-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101511"},"text":null,"children":[{"tag":"num","attrib":{"value":"101511"},"text":"§ 101511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef853baf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Roads and Trails in System Units","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may construct, reconstruct, and improve roads and trails, including bridges, in System units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef853bb0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approach Roads.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef853bb1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101511/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef853bb2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101511/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the Secretary determines it to be in the public interest, the Secretary may designate, as System unit approach roads, roads whose primary value is to carry System unit travel and that lead across land at least 90 percent owned by the Federal Government and that will connect the highways within a System unit with a convenient point on or leading to the National Highway System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef853bb3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101511/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limit on length of approach roads.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idef853bb4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101511/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A designated approach road shall not exceed—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef853bb5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101511/b/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 miles in length between a System unit gateway and a point on or leading to the nearest convenient National Highway System road; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef853bb6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101511/b/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 miles in length if the approach road is on the National Highway System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef853bb7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101511/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"County limit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not to exceed 40 miles of any one approach road shall be designated in any one county.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef853bb8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101511/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supplementary part of system unit highway system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An approach road designated for a System unit shall be treated as a supplementary part of the highway system of the System unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef853bb9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101511/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction, reconstruction, and improvement.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef853bba-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101511/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may construct, reconstruct, and improve approach roads designated under paragraph (1) (including bridges) and enter into agreements for the maintenance of the approach roads by State or county authorities or to maintain the approach roads when otherwise necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef853bbb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101511/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual allocation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not more than $1,500,000 shall be allocated annually for the construction, reconstruction, and improvement of System unit approach roads.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef853bbc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101511/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval of secretary of agriculture required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When an approach road is proposed under this section across or within any national forest, the Secretary shall secure the approval of the Secretary of Agriculture before construction begins.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef853bbd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement With Secretary of Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under agreement with the Secretary, the Secretary of Transportation may carry out any provision of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef853bbe-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3130"},"text":"128 Stat. 3130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef853bbf-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef853bc0-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef853bc1-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":