ll,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1924-04-09/ch86/s5"},"text":"Apr. 9, 1924, ch. 86, § 5","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/act/1931-01-31/ch79"},"text":"Jan. 31, 1931, ch. 79","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/46/1053"},"text":"46 Stat. 1053","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101511(b)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s8a"},"text":"16 U.S.C. 8a","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1924-04-09/ch86"},"text":"Apr. 9, 1924, ch. 86","children":[],"tail":", §§ 4, 6, as added "},{"tag":"html:a","attrib":{"href":"/us/act/1931-01-31/ch79"},"text":"Jan. 31, 1931, ch. 79","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/46/1053"},"text":"46 Stat. 1053","children":[],"tail":", 1054."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"101511(b) (2)(A)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s8b"},"text":"16 U.S.C. 8b","children":[],"tail":" (words before 6th comma, words after semicolon and before 1st proviso)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"101511(b) (2)(B)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s8b"},"text":"16 U.S.C. 8b","children":[],"tail":" (2d proviso)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101511(b)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s8c"},"text":"16 U.S.C. 8c","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101511(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s8b"},"text":"16 U.S.C. 8b","children":[],"tail":" (1st proviso)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8b"},"text":"16 U.S.C. 8b","children":[],"tail":" (last proviso) and the words “in the administration of the National Park Service” in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s8"},"text":"16 U.S.C. 8","children":[],"tail":" are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1)(A), the words “at least 90 percent” are substituted for “wholly or to the extent of 90 per centum” to eliminate unnecessary words. The words “National Highway System” are substituted for “Federal 7 per centum highway system” to reflect the current name of the system. See 23:101(a)(16).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2)(A), the words “during the fiscal years 1950 and 1951” and the text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8b"},"text":"16 U.S.C. 8b","children":[],"tail":" (words after semicolon and before 1st proviso) are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “Secretary of Transportation” are substituted for “Secretary of Commerce” because the functions of the Secretary of Agriculture relating to Public Roads Administration were transferred to the Federal Works Administrator by Reorganization Plan No. 1 of 1939 (5 App. U.S.C.) and subsequently to the Administrator of General Services by section 103 of the Federal Property and Administrative Services Act of 1949 (ch. 288, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/63/380"},"text":"63 Stat. 380","children":[],"tail":") and the Secretary of Commerce and Secretary of Transportation by Reorganization Plan No. 7 of 1949 (5 App. U.S.C.), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/97/449/s2/b"},"text":"section 2(b) of Public Law 97–449","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/96/2439"},"text":"96 Stat. 2439","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
