{"tag":"section","attrib":{"id":"idef7b9e3c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100737"},"text":null,"children":[{"tag":"num","attrib":{"value":"100737"},"text":"§ 100737.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial disclosure by officer or employee of Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7b9e3d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100737/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Statements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each officer or employee of the Secretary who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7b9e3e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100737/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs any function or duty under this subchapter, or any Act amended by the Mining in the Parks Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/429"},"text":"Public Law 94–429","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1342"},"text":"90 Stat. 1342","children":[],"tail":") concerning the regulation of mining in the System; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7b9e3f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100737/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has any known financial interest—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7b9e40-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100737/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any person subject to this subchapter or any Act amended by the Mining in the Parks Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/429"},"text":"Public Law 94–429","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1342"},"text":"90 Stat. 1342","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7b9e41-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100737/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any person who holds a mining claim within the boundary of any System unit;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall annually file with the Secretary a written statement concerning all such interests held by the officer or employee during the preceding calendar year. The statement shall be available to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7b9e42-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100737/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monitoring and Enforcement Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7b9e43-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100737/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" define the term “known financial interest” for purposes of subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7b9e44-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100737/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the methods by which the requirement to file written statements specified in subsection (a) will be monitored and enforced, including appropriate provisions for the filing by the officers and employees of the statements and the review by the Secretary of the statements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7b9e45-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100737/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress on June 1 of each year a report with respect to the disclosures and the actions taken in regard to the disclosures during the preceding calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7b9e46-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100737/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the rules prescribed under subsection (b), the Secretary may identify specific positions within the Department of the Interior that are of a nonregulatory or nonpolicymaking nature and provide that officers or employees occupying those positions shall be exempt from the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7b9e47-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100737/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Criminal penalties for a violation of this section are provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1865"},"text":"section 1865 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7b9e48-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3110"},"text":"128 Stat. 3110","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7b9e49-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef7b9e4a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef7b9e4b-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"100737(a) through (c)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s1912/a"},"text":"16 U.S.C. 1912(a)","children":[],"tail":" through (c)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/94/429/s13/a"},"text":"Pub. L. 94–429, § 13(a)","children":[],"tail":" through (c), "},{"tag":"html:span","attrib":{},"text":"Sept. 28, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/1344"},"text":"90 Stat. 1344","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"100737(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"no source.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “beginning on ","children":[{"tag":"date","attrib":{"date":"1977-02-01"},"text":"February 1, 1977","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “act within ninety days after ","children":[{"tag":"date","attrib":{"date":"1976-09-28"},"text":"September 28, 1976","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “the Department of the Interior” are substituted for “such agency” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) is added for informational purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7b9e4c-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef7b9e4d-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Mining in the Parks Act, referred to in subsec. (a)(1), (2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/429"},"text":"Pub. L. 94–429","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-28"},"text":"Sept. 28, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1342"},"text":"90 Stat. 1342","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
