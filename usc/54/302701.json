{"tag":"section","attrib":{"id":"idef9f79f0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302701"},"text":null,"children":[{"tag":"num","attrib":{"value":"302701"},"text":"§ 302701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program to assist Indian tribes in preserving historic property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9f79f1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish a program and promulgate regulations to assist Indian tribes in preserving their historic property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9f79f2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Communication and Cooperation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall foster communication and cooperation between Indian tribes and State Historic Preservation Officers in the administration of the national historic preservation program to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9f79f3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that all types of historic property and all public interests in historic property are given due consideration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9f79f4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage coordination among Indian tribes, State Historic Preservation Officers, and Federal agencies in historic preservation planning and in the identification, evaluation, protection, and interpretation of historic property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9f79f5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tribal Values","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The program under subsection (a) shall be developed in a manner to ensure that tribal values are taken into account to the extent feasible. The Secretary may waive or modify requirements of this subdivision to conform to the cultural setting of tribal heritage preservation goals and objectives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9f79f6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302701/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of Tribal Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The tribal programs implemented by specific tribal organizations may vary in scope, as determined by each Indian tribe’s chief governing authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9f79f7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302701/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall consult with Indian tribes, other Federal agencies, State Historic Preservations ","children":[{"tag":"ref","attrib":{"idref":"fn002019"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002019"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Preservation”."}],"tail":" Officers, and other interested parties concerning the program under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9f79f8-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3199"},"text":"128 Stat. 3199","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9f79f9-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9f79fa-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9f79fb-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"302701","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470a/d/1"},"text":"16 U.S.C. 470a(d)(1)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/665/tI/s101/d/1"},"text":"Pub. L. 89–665, title I, § 101(d)(1)","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/102/575/tXL/s4006/a/2"},"text":"Pub. L. 102–575, title XL, § 4006(a)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/4755"},"text":"106 Stat. 4755","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “and initiate the program under subparagraph (A) by not later than ","children":[{"tag":"date","attrib":{"date":"1994-10-01"},"text":"October 1, 1994","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
