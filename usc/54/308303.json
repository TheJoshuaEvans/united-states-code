{"tag":"section","attrib":{"id":"idefa8f06e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308303"},"text":null,"children":[{"tag":"num","attrib":{"value":"308303"},"text":"§ 308303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation and interpretation of Underground Railroad history, historic sites, and structures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa8f06f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Make Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make grants in accordance with this section for the preservation and restoration of historic buildings or structures associated with the Underground Railroad, and for related research and documentation to sites, programs, or facilities that have been included in the national network.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f070-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any grant made under this section shall provide that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa8f071-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no change or alteration may be made in property for which the grant is used except with the agreement of the property owner and the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa8f072-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall have the right of access at reasonable times to the public portions of the property for interpretive and other purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa8f073-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308303/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conversion, use, or disposal of the property for purposes contrary to the purposes of this chapter, as determined by the Secretary, shall result in a right of the United States to compensation equal to all Federal funds made available to the grantee under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8f074-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matching Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may obligate funds made available for a grant under this section only if the grantee agrees to match, from funds derived from non-Federal sources, the amount of the grant with an amount that is equal to or greater than the grant. The Secretary may waive the requirement if the Secretary determines that an extreme emergency exists or that a waiver is in the public interest to ensure the preservation of historically significant resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa8f075-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3235"},"text":"128 Stat. 3235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa8f076-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa8f077-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa8f078-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"308303","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s469"},"text":"16 U.S.C. 469","children":[],"tail":null},{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":"–2."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/105/203/s4"},"text":"Pub. L. 105–203, § 4","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/106/291/tI/s150/h"},"text":"Pub. L. 106–291, title I, § 150(h)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 11, 2000","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/114/959"},"text":"114 Stat. 959","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/110/229/tIII"},"text":"Pub. L. 110–229, title III","children":[],"tail":", subtitle G, § 361(a)(2), "},{"tag":"html:span","attrib":{},"text":"May 8, 2008","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/122/801"},"text":"122 Stat. 801","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefa8f079-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefa8f07a-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Underground Railroad Freedom Center","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/291/tI/s150/b"},"text":"Pub. L. 106–291, title I, § 150(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-11"},"text":"Oct. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/956"},"text":"114 Stat. 956","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/291/tI/s150/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Underground Railroad Freedom Center (hereinafter ‘Freedom Center’) is a nonprofit organization incorporated under the laws of the State of Ohio in 1995;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the objectives of the Freedom Center are to interpret the history of the Underground Railroad through development of a national cultural institution in Cincinnati, Ohio, that will house an interpretive center, including museum, educational, and research facilities, all dedicated to communicating to the public the importance of the quest for human freedom which provided the foundation for the historic and inspiring story of the Underground Railroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the city of Cincinnati has granted exclusive development rights for a prime riverfront location to the Freedom Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Freedom Center will be a national center linked through state-of-the-art technology to Underground Railroad sites and facilities throughout the United States and to a constituency that reaches across the United States, Canada, Mexico, the Caribbean and beyond; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Freedom Center has reached an agreement with the National Park Service to pursue a range of historical and educational cooperative activities related to the Underground Railroad, including but not limited to assisting the National Park Service in the implementation of the National Underground Railroad Network to Freedom Act [see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s308301"},"text":"54 U.S.C. 308301","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote preservation and public awareness of the history of the Underground Railroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the Freedom Center in the development of its programs and facilities in Cincinnati, Ohio; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the National Park Service in the implementation of the National Underground Railroad Network to Freedom Act (","children":[{"tag":"ref","attrib":{"href":"/us/stat/112/679"},"text":"112 Stat. 679","children":[],"tail":"; [former] "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s469"},"text":"16 U.S.C. 469","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" and following) [see "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s308301"},"text":"54 U.S.C. 308301","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
