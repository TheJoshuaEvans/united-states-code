{"tag":"section","attrib":{"id":"idefa8efbc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307101"},"text":null,"children":[{"tag":"num","attrib":{"value":"307101"},"text":"§ 307101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" World Heritage Convention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa8efbd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this section, the Secretary of the Interior may act directly or through an appropriate officer in the Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8efbe-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation by United States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall direct and coordinate participation by the United States in the World Heritage Convention in cooperation with the Secretary of State, the Smithsonian Institution, and the Council. Whenever possible, expenditures incurred in carrying out activities in cooperation with other nations and international organizations shall be paid for in such excess currency of the country or area where the expense is incurred as may be available to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8efbf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nomination of Property to World Heritage Committee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall periodically nominate property that the Secretary determines is of international significance to the World Heritage Committee on behalf of the United States. No property may be nominated unless it has previously been determined to be of national significance. Each nomination shall include evidence of such legal protections as may be necessary to ensure preservation of the property and its environment (including restrictive covenants, easements, or other forms of protection). Before making any nomination, the Secretary shall notify the Committee on Natural Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8efc0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nomination of Non-Federal Property to World Heritage Committee Requires Written Concurrence of Owner","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No non-Federal property may be nominated by the Secretary to the World Heritage Committee for inclusion on the World Heritage List unless the owner of the property concurs in the nomination in writing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa8efc1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s307101/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration of Undertaking on Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Prior to the approval of any undertaking outside the United States that may directly and adversely affect a property that is on the World Heritage List or on the applicable country’s equivalent of the National Register, the head of a Federal agency having direct or indirect jurisdiction over the undertaking shall take into account the effect of the undertaking on the property for purposes of avoiding or mitigating any adverse effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa8efc2-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3230"},"text":"128 Stat. 3230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa8efc3-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa8efc4-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa8efc5-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"307101(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"no source.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"307101(b) through (d)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470a–1"},"text":"16 U.S.C. 470a–1","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Pub. 96–515, title IV, § 401, ","children":[{"tag":"html:span","attrib":{},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/3000"},"text":"94 Stat. 3000","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/437/s6/d/28"},"text":"Pub. L. 103–437, § 6(d)(28)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/4584"},"text":"108 Stat. 4584","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"307101(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470a–2"},"text":"16 U.S.C. 470a–2","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/96/515/tIV/s402"},"text":"Pub. L. 96–515, title IV, § 402","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/3000"},"text":"94 Stat. 3000","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) is added for clarity because of the definition of “Secretary” in section 300316 of the new title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
