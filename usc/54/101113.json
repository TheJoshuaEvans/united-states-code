{"tag":"section","attrib":{"id":"idef82c981-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101113"},"text":null,"children":[{"tag":"num","attrib":{"value":"101113"},"text":"§ 101113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts, devises, or bequests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef82c982-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Accept Gifts, Devises, or Bequests.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef82c983-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101113/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Park Foundation may accept, receive, solicit, hold, administer, and use any gifts, devises, or bequests, either absolutely or in trust of real or personal property, or any income from, or other interest in, the gift, devise, or bequest, for the benefit of, or in connection with, the Service, its activities, or its services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef82c984-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101113/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination with service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Activities of the National Park Foundation under paragraph (1) shall be undertaken after consultation with the Director to ensure that those activities are consistent with the programs and policies of the Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef82c985-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101113/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gift, devise, or bequest that is encumbered, restricted, or subject to beneficial interests","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A gift, devise, or bequest may be accepted by the National Park Foundation even though it is encumbered, restricted, or subject to beneficial interests of private persons if any current or future interest in the gift, devise, or bequest is for the benefit of the Service, its activities, or its services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef82c986-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When Gift, Devise, or Bequest May Not Be Accepted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Park Foundation may not accept any gift, devise, or bequest that entails any expenditure other than from the resources of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef82c987-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interest in Real Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, an interest in real property includes easements or other rights for preservation, conservation, protection, or enhancement by and for the public of natural, scenic, historic, scientific, educational, inspirational, or recreational resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef82c988-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3120"},"text":"128 Stat. 3120","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/289/tIV/s401/2"},"text":"Pub. L. 114–289, title IV, § 401(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1488"},"text":"130 Stat. 1488","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef82c989-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef82c98a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef82c98b-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision 