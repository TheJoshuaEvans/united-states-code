{"tag":"section","attrib":{"id":"idef7e0e81-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100802"},"text":null,"children":[{"tag":"num","attrib":{"value":"100802"},"text":"§ 100802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpretation and education authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that management of System units and related areas is enhanced by the availability and use of a broad program of the highest quality interpretation and education.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef7e0e82-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/tIII/s301/a"},"text":"Pub. L. 114–289, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1487"},"text":"130 Stat. 1487","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
