{"tag":"section","attrib":{"id":"idef9d094e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302104"},"text":null,"children":[{"tag":"num","attrib":{"value":"302104"},"text":"§ 302104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominations for inclusion on National Register","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9d094f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nomination by State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302107"},"text":"section 302107 of this title","children":[],"tail":", any State that is carrying out a program approved under chapter 3023 shall nominate to the Secretary property that meets the criteria promulgated under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s302103"},"text":"section 302103 of this title","children":[],"tail":" for inclusion on the National Register. Subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s302107"},"text":"section 302107 of this title","children":[],"tail":", any property nominated under this subsection or under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s306102"},"text":"section 306102 of this title","children":[],"tail":" shall be included on the National Register on the date that is 45 days after receipt by the Secretary of the nomination and the necessary documentation, unless the Secretary disapproves the nomination within the 45-day period or unless an appeal is filed under subsection (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9d0950-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nomination by Person or Local Government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302107"},"text":"section 302107 of this title","children":[],"tail":", the Secretary may accept a nomination directly from any person or local government for inclusion of a property on the National Register only if the property is located in a State where there is no program approved under chapter 3023 of this title. The Secretary may include on the National Register any property for which such a nomination is made if the Secretary determines that the property is eligible in accordance with the regulations promulgated under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s302103"},"text":"section 302103 of this title","children":[],"tail":". The determination shall be made within 90 days from the date of the nomination unless the nomination is appealed under subsection (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9d0951-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nomination by Federal Agency","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302107"},"text":"section 302107 of this title","children":[],"tail":", the regulations promulgated under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s302103"},"text":"section 302103 of this title","children":[],"tail":", and appeal under subsection (d) of this section, the Secretary may accept a nomination directly by a Federal agency for inclusion of property on the National Register only if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9d0952-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completed nominations are sent to the State Historic Preservation Officer for review and comment regarding the adequacy of the nomination, the significance of the property and its eligibility for the National Register;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d0953-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 45 days of receiving the completed nomination, the State Historic Preservation Officer has made a recommendation regarding the nomination to the Federal Preservation Officer, except that failure to meet this deadline shall constitute a recommendation to not support the nomination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d0954-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302104/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chief elected officials of the county (or equivalent governmental unit) and municipal political jurisdiction in which the property is located are notified and given 45 days in which to comment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d0955-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302104/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Preservation Officer forwards it to the Keeper of the National Register of Historic Places after determining that all procedural requirements have been met, including those in paragraphs (1) through (3) above; the nomination is adequately documented; the nomination is technically and professionally correct and sufficient; and may include an opinion as to whether the property meets the National Register criteria for evaluation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d0956-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302104/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice is provided in the Federal Register that the nominated property is being considered for listing on the National Register that includes any comments and the recommendation of the State Historic Preservation Officer and a declaration whether the State Historic Preservation Officer has responded within the 45 day-period of review provided in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d0957-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302104/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary addresses in the Federal Register any comments from the State Historic Preservation Officer that do not support the nomination of the property on the National Register before the property is included in the National Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9d0958-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appeal","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person or local government may appeal to the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9d0959-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302104/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nomination of any property for inclusion on the National Register; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d095a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302104/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of a nominating authority to nominate a property in accordance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9d095b-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3192"},"text":"128 Stat. 3192","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/289/tVIII/s802/b"},"text":"Pub. L. 114–289, title VIII, § 802(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1494"},"text":"130 Stat. 1494","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9d095c-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9d095d-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9d095e-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"302104","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470a/a/3"},"text":"16 U.S.C. 470a(a)(3)","children":[],"tail":" through (5)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/665/tI/s101/a/3"},"text":"Pub. L. 89–665, title I, § 101(a)(3)","children":[],"tail":" through (5), "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/915"},"text":"80 Stat. 915","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/91/383/s11"},"text":"Pub. L. 91–383, § 11","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/94/458/s2"},"text":"Pub. L. 94–458, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 7, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/1942"},"text":"90 Stat. 1942","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/93/54/s1/d"},"text":"Pub. L. 93–54, § 1(d)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 1, 1973","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/87/139"},"text":"87 Stat. 139","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/205/tVI/s608/a/1"},"text":"Pub. L. 96–205, title VI, § 608(a)(1)","children":[],"tail":", (2), "},{"tag":"html:span","attrib":{},"text":"Mar. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/92"},"text":"94 Stat. 92","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/515/tII/s201/a"},"text":"Pub. L. 96–515, title II, § 201(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/2989"},"text":"94 Stat. 2989","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the word “historic” is omitted because a historic property already is eligible for inclusion on the National Register and would not have to be nominated for inclusion.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “or refusal” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef9d095f-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef9d0960-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/s802/b/1"},"text":"Pub. L. 114–289, § 802(b)(1)","children":[],"tail":", substituted “subsection (d)” for “subsection (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/s802/b/2"},"text":"Pub. L. 114–289, § 802(b)(2)","children":[],"tail":", (3), added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
