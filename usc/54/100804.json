{"tag":"section","attrib":{"id":"idef7e0e89-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100804"},"text":null,"children":[{"tag":"num","attrib":{"value":"100804"},"text":"§ 100804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improved use of partners and volunteers in interpretation and education","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7e0e8a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100804/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with park partners and volunteers in the delivery of quality programs and services to supplement those provided by the Service as part of a park’s Long Range Interpretive Plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0e8b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100804/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support interpretive partners by providing opportunities to participate in interpretive training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7e0e8c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100804/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with other Federal and non-Federal public or private agencies, organizations, or institutions for the purposes of developing, promoting, and making available educational opportunities related to resources of the System and programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7e0e8d-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/tIII/s301/a"},"text":"Pub. L. 114–289, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1487"},"text":"130 Stat. 1487","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
