{"tag":"section","attrib":{"id":"idef9d08ee-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300314"},"text":null,"children":[{"tag":"num","attrib":{"value":"300314"},"text":"§ 300314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native Hawaiian organization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9d08ef-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this division, the term “Native Hawaiian organization” means any organization that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9d08f0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300314/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves and represents the interests of Native Hawaiians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d08f1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300314/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has as a primary and stated purpose the provision of services to Native Hawaiians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d08f2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s300314/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has demonstrated expertise in aspects of historic preservation that are culturally significant to Native Hawaiians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection"