,"text":"Purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/203"},"text":"Pub. L. 105–203","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/203/s2/b"},"text":"Pub. L. 105–203, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-21"},"text":"July 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/679"},"text":"112 Stat. 679","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/203/s2/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The purposes of this Act [see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s308301"},"text":"54 U.S.C. 308301","children":[],"tail":" et seq.] are the following:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To recognize the importance of the Underground Railroad, the sacrifices made by those who used the Underground Railroad in search of freedom from tyranny and oppression, and the sacrifices made by the people who helped them.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To authorize the National Park Service to coordinate and facilitate Federal and non-Federal activities to commemorate, honor, and interpret the history of the Underground Railroad, its significance as a crucial element in the evolution of the national civil rights movement, and its relevance in fostering the spirit of racial harmony and national reconciliation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
