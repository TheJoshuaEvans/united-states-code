{"tag":"section","attrib":{"id":"idef7b9df4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100722"},"text":null,"children":[{"tag":"num","attrib":{"value":"100722"},"text":"§ 100722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7b9df5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (c), any person that destroys, causes the loss of, or injures any System unit resource is liable to the United States for response costs and damages resulting from the destruction, loss, or injury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7b9df6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability In Rem","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any instrumentality, including a vessel, vehicle, aircraft, or other equipment, that destroys, causes the loss of, or injures any System unit resource shall be liable in rem to the United States for response costs and damages resulting from the destruction, loss, or injury to the same extent as a person is liable under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7b9df7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100722/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person is not liable under this section if the person establishes that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7b9df8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100722/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the destruction, loss of, or injury to the System unit resource was caused solely by an act of God or an act of war;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7b9df9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100722/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person acted with due care, and the destruction, loss of, or injury to the System unit resource was caused solely by an act or omission of a 3d party, other than an employee or agent of the person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7b9dfa-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100722/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the destruction, loss, or injury to the System unit resource was caused by an activity authorized by Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7b9dfb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100722/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Liability under this section is in addition to any other liability that may arise under Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7b9dfc-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3107"},"text":"128 Stat. 3107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7b9dfd-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef7b9dfe-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef7b9dff-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{}