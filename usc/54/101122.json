{"tag":"section","attrib":{"id":"idef82c9e2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101122"},"text":null,"children":[{"tag":"num","attrib":{"value":"101122"},"text":"§ 101122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; use of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef82c9e3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated to carry out this subchapter $15,000,000 for each of fiscal years 2017 through 2030.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef82c9e4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds made available under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef82c9e5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101122/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be advanced each fiscal year to the National Park Foundation in a lump sum without regard to when expenses are incurred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef82c9e6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101122/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be provided to the National Park Foundation for use to match contributions (whether in currency, services, or property) made to the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef82c9e7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101122/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be used by the National Park Foundation for administrative expenses of the Foundation, including for salaries, travel and transportation expenses, and other overhead expenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef82c9e8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101122/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be deposited by the National Park Foundation into any fund that will be invested or earn interest in any way.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef82c9e9-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/tIV/s402/a"},"text":"Pub. L. 114–289, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1488"},"text":"130 Stat. 1488","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tVI/s646"},"text":"Pub. L. 117–328, div. DD, title VI, § 646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5616"},"text":"136 Stat. 5616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef82c9ea-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef82c9eb-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef82c9ec-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “$15,000,000” for “$5,000,000” and “2030” for “2023”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
