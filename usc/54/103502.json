{"tag":"section","attrib":{"id":"idef9121d8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103502"},"text":null,"children":[{"tag":"num","attrib":{"value":"103502"},"text":"§ 103502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Signature projects and programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9121d9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"List","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9121da-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a list of signature projects and programs eligible for funding from the National Park Centennial Challenge Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9121db-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the list developed pursuant to paragraph (1) to the Committees on Appropriations and Energy and Natural Resources in the United States Senate, and to the Committees on Appropriations and Natural Resources in the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9121dc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize deferred maintenance projects, physical improvements to visitor services facilities and trail maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9121dd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s103502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may, from time to time, as the Secretary finds appropriate, add any signature project or program to the list and provide notice of such addition as required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9121de-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289/tI/s101/a"},"text":"Pub. L. 114–289, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1484"},"text":"130 Stat. 1484","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
