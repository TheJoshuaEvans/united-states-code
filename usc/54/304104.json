{"tag":"section","attrib":{"id":"idefa1c404-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304104"},"text":null,"children":[{"tag":"num","attrib":{"value":"304104"},"text":"§ 304104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of members of Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The members of the Council specified in paragraphs (2), (3), and (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s304101/a"},"text":"section 304101(a) of this title","children":[],"tail":" shall serve without additional compensation. The Chairman of the Council shall be compensated as provided in subsection (e) of section 304101. The other members of the Council shall receive $100 per diem when engaged in the performance of the duties of the Council. All members of the Council shall receive reimbursement for necessary traveling and subsistence expenses incurred by them in the performance of the duties of the Council."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefa1c405-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3211"},"text":"128 Stat. 3211","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/289/tV/s501/c/2"},"text":"Pub. L. 114–289, title V, § 501(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1490"},"text":"130 Stat. 1490","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa1c406-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id