{"tag":"section","attrib":{"id":"idef912202-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s104905"},"text":null,"children":[{"tag":"num","attrib":{"value":"104905"},"text":"§ 104905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation of mats for reproduction of photographs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall prepare mats that may be used for the reproduction in magazines and newspapers of photographs of scenery in a System unit that, in the opinion of the Secretary, would be of interest to the people of the United States and foreign nations. The mats may be furnished, without charge and under regulations the Secretary may prescribe, to the publishers of magazines, newspapers, and any other publications that may carry photographic reproductions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef912203-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3168"},"text":"128 Stat. 3168","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef912204-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef912205-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef912206-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:th