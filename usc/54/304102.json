{"tag":"section","attrib":{"id":"idefa1c3ef-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304102"},"text":null,"children":[{"tag":"num","attrib":{"value":"304102"},"text":"§ 304102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa1c3f0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa1c3f1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the President and Congress on matters relating to historic preservation, recommend measures to coordinate activities of Federal, State, and local agencies and private institutions and individuals relating to historic preservation, and advise on the dissemination of information pertaining to those activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3f2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage, in cooperation with the National Trust and appropriate private agencies, public interest and participation in historic preservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3f3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommend the conduct of studies in such areas as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa1c3f4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304102/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of legislative and administrative statutes and regulations pertaining to historic preservation activities of State and local governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa1c3f5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304102/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects of tax policies at all levels of government on historic preservation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3f6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304102/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise as to guidelines for the assistance of State and local governments in drafting legislation relating to historic preservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3f7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304102/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage, in cooperation with appropriate public and private agencies and institutions, training and education in the field of historic preservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3f8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304102/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the policies and programs of Federal agencies and recommend to Federal agencies methods to improve the effectiveness, coordination, and consistency of those policies and programs with the policies and programs carried out under this division; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3f9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304102/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform and educate Federal agencies, State and local governments, Indian tribes, other nations and international organizations and private groups and individuals as to the Council’s authorized activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa1c3fa-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council annually shall submit to the President a comprehensive report of its activities and the results of its studies and shall from time to time submit additional and special reports as it deems advisable. Each report shall propose legislative enactments and other actions as, in the judgment of the Council, are necessary and appropriate to carry out its recommendations and shall provide the Council’s assessment of current and emerging problems in the field of historic preservation and an evaluation of the effectiveness of the programs of Federal agencies, State and local governments, and the private sector in carrying out this division.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa1c3fb-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3210"},"text":"128 Stat. 3210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa1c3fc-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa1c3fd-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa1c3fe-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"304102","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470j"},"text":"16 U.S.C. 470j","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/665/tII/s202"},"text":"Pub. L. 89–665, title II, § 202","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/918"},"text":"80 Stat. 918","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/515/tIII/s301/g"},"text":"Pub. L. 96–515, title III, § 301(g)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/2999"},"text":"94 Stat. 2999","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
