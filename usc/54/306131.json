{"tag":"section","attrib":{"id":"idefa6a59e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306131"},"text":null,"children":[{"tag":"num","attrib":{"value":"306131"},"text":"§ 306131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and guidelines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa6a59f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa6a5a0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306131/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Federal agency that is responsible for the protection of historic property (including archeological property) pursuant to this division or any other law shall ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa6a5a1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306131/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all actions taken by employees or contractors of the agency meet professional standards under regulations developed by the Secretary in consultation with the Council, other affected agencies, and the appropriate professional societies of archeology, architecture, conservation, history, landscape architecture, and planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa6a5a2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306131/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agency personnel or contractors responsible for historic property meet qualification standards established by the Office of Personnel Management in consultation with the Secretary and appropriate professional societies of archeology, architecture, conservation, curation, history, landscape architecture, and planning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa6a5a3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306131/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" records and other data, including data produced by historical research and archeological surveys and excavations, are permanently maintained in appropriate databases and made available to potential users pursuant to such regulations as the Secretary shall promulgate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa6a5a4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306131/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The standards referred to in paragraph (1)(B) shall consider the particular skills and expertise needed for the preservation of historic property and shall be equivalent requirements for the disciplines involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa6a5a5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306131/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office of Personnel Management shall revise qualification standards for the disciplines involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa6a5a6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To promote the preservation of historic property eligible for listing on the National Register, the Secretary shall, in consultation with the Council, promulgate guidelines to ensure that Federal, State, and tribal historic preservation programs subject to this division include plans to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa6a5a7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306131/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information to the owners of historic property (including architectural, curatorial, and archeological property) with demonstrated or likely research significance, about the need for protection of the historic property, and the available means of protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa6a5a8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306131/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage owners to preserve historic property intact and in place and offer the owners of historic property information on the tax and grant assistance available for the donation of the historic property or of a preservation easement of the historic property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa6a5a9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306131/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the protection of Native American cultural items (within the meaning of section 2 of the Native American Graves Protection and Repatriation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"25 U.S.C. 3001","children":[],"tail":")) and of property of religious or cultural importance to Indian tribes, Native Hawaiian organizations, or other Native American groups; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa6a5aa-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306131/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" encourage owners that are undertaking archeological excavations to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa6a5ab-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306131/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct excavations and analyses that meet standards for federally-sponsored excavations established by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa6a5ac-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306131/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donate or lend artifacts of research significance to an appropriate research institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa6a5ad-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306131/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow access to artifacts for research purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa6a5ae-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306131/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to excavating or disposing of a Native American cultural item in which an Indian tribe or Native Hawaiian organization may have an interest under subparagraph (B) or (C) of section 3(a)(2) of the Native American Graves Protection and Repatriation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3002/a/2/B"},"text":"25 U.S.C. 3002(a)(2)(B)","children":[],"tail":", (C)), give notice to and consult with the Indian tribe or Native Hawaiian organization."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa6a5af-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3229"},"text":"128 Stat. 3229","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/289/tVI/s601/f"},"text":"Pub. L. 114–289, title VI, § 601(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1491"},"text":"130 Stat. 1491","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa6a5b0-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa6a5b1-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa6a5b2-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"306131","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470h–4"},"text":"16 U.S.C. 470h–4","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/665/tI/s112"},"text":"Pub. L. 89–665, title I, § 112","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/102/575/tXL/s4014"},"text":"Pub. L. 102–575, title XL, § 4014","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/4761"},"text":"106 Stat. 4761","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/106/208/s5/a/9"},"text":"Pub. L. 106–208, § 5(a)(9)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/114/319"},"text":"114 Stat. 319","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subparagraphs (A) and (B) of subsection (a)(1), the words “the disciplines involved, specifically” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “within 2 years after ","children":[{"tag":"date","attrib":{"date":"1992-10-20"},"text":"October 20, 1992","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the word “property” is substituted for “resources” for consistency because the defined term in the new division is “property”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa6a5b3-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefa6a5b4-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289"},"text":"Pub. L. 114–289","children":[],"tail":" substituted “Office of Personnel Management” for “Office of Management and Budget”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
