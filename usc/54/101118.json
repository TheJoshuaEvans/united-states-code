{"tag":"section","attrib":{"id":"idef82c9aa-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101118"},"text":null,"children":[{"tag":"num","attrib":{"value":"101118"},"text":"§ 101118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax exemptions; contributions toward costs of local government; contributions, gifts, or transfers to or for use of United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef82c9ab-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101118/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tax Exemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Park Foundation and any income or property received or owned by it, and all transactions relating to that income or property, shall be exempt from all Federal, State, and local taxation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef82c9ac-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101118/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contributions In Lieu of Taxes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Park Foundation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef82c9ad-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101118/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute toward the costs of local government in amounts not in excess of those which it would be obligated to pay that government if it were not exempt from taxation by virtue of subsection (a) or by virtue of its being a charitable and nonprofit corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef82c9ae-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101118/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to contribute with respect to property transferred to it and the income derived from the property if the agreement is a condition of the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef82c9af-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101118/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfers Deemed To Be to or for the Use of United States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Contributions, gifts, and other transfers made to or for the use of the Foundation shall be deemed to be contributions, gifts, or transfers to or for the use of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef82c9b0-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3122"},"text":"128 Stat. 3122","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef82c9b1-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef82c9b2-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef82c9b3-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html