en":[],"tail":null},{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/90/209/s8"},"text":"Pub. L. 90–209, § 8","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 18, 1967","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/81/657"},"text":"81 Stat. 657","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “in the discretion of its directors” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
