{"tag":"section","attrib":{"id":"idef8c669b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102"},"text":null,"children":[{"tag":"num","attrib":{"value":"102102"},"text":"§ 102102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary to enter into lease for buildings and associated property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8c669c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To facilitate the administration of the System, the Secretary, under such terms and conditions as the Secretary may consider advisable, and except as provided in subsection (b) and subject to subsection (c), may enter into a lease with any person or government entity for the use of buildings and associated property administered by the Secretary as part of the System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c669d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not use a lease under subsection (a) to authorize the lessee to engage in activities that are subject to authorization by the Secretary through a concession contract, commercial use authorization, or similar instrument.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c669e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Buildings and associated property leased under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8c669f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be used for an activity that is consistent with the purposes established by law for the System unit in which the building is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c66a0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not result in degradation of the purposes and values of the System unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c66a1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be compatible with Service programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c66a2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rental Amounts.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8c66a3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a lease under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8c66a4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of fair market value rental shall be required; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8c66a5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s1302"},"text":"section 1302 of title 40","children":[],"tail":" shall not apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c66a6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may adjust the rental amount as appropriate to take into account any amounts to be expended by the lessee for preservation, maintenance, restoration, improvement, or repair and related expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c66a7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Account.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8c66a8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Rental payments under a lease under subsection (a) shall be deposited in a special account in the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c66a9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts in the special account shall be available until expended, without further appropriation, for infrastructure needs at System units, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8c66aa-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facility refurbishment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8c66ab-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repair and replacement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8c66ac-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" infrastructure projects associated with System unit resource protection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8c66ad-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct maintenance of the leased buildings and associated property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c66ae-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accountability and results","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall develop procedures for the use of the special account that ensure accountability and demonstrated results consistent with this section and sections 100101(b), 100502, 100507, 100751(b), 100754, 100901(b) and (c), 100906(a) and (d), 101302(b)(1) and (c) to (e), 101306, 101702(b) and (c), 101901, 102701, and 102702 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c66af-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102102/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations implementing this section that include provisions to encourage and facilitate competition in the leasing process and provide for timely and adequate public comment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8c66b0-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3152"},"text":"128 Stat. 3152","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8c66b1-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef8c66b2-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef8c66b3-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"