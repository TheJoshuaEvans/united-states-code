{"tag":"section","attrib":{"id":"idef76e351-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100504"},"text":null,"children":[{"tag":"num","attrib":{"value":"100504"},"text":"§ 100504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and planning of park, parkway, and recreational-area facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef76e352-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef76e353-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “State” means a State, the District of Columbia, Puerto Rico, Guam, and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef76e354-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall cause the Service to make a comprehensive study, other than on land under the jurisdiction of the Secretary of Agriculture, of the public park, parkway, and recreational area programs of the United States, States, and political subdivisions of States and of areas of land throughout the United States that are or may be chiefly valuable as public park, parkway, or recreational areas. A study shall not be made in any State without the consent and approval of the State officials, boards, or departments having jurisdiction over the land. The study shall be such as, in the judgment of the Secretary, will provide data helpful in developing a plan for coordinated and adequate public park, parkway, and recreational-area facilities for the people of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef76e355-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100504/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation and agreements with other entities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making the study and to accomplish the purposes of this section, the Secretary, acting through the Director—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef76e356-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100504/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall seek and accept the cooperation and assistance of Federal departments or agencies having jurisdiction of land belonging to the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef76e357-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100504/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may cooperate and make agreements with and seek and accept the assistance of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef76e358-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100504/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal agencies and instrumentalities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef76e359-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100504/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States, political subdivisions of States, and agencies and instrumentalities of either of them.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef76e35a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100504/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State planning","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purpose of developing coordinated and adequate public park, parkway, and recreational-area facilities for the people of the United States, the Secretary may aid States and political subdivisions of States in planning public park, parkway, and recreational areas and in cooperating with one another to accomplish these ends. Aid shall be made available through the Service acting in cooperation with such State agencies or agencies of political subdivisions of States as the Secretary considers best.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef76e35b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consent of Congress to Agreements Between States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The consent of Congress is given to any 2 or more States to negotiate and enter into compacts or agreements with one another with reference to planning, establishing, developing, improving, and maintaining any park, parkway, or recreational area. No compact or agreement shall be effective until approved by the legislatures of the States that are parties to the compact or agreement and by Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef76e35c-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3099"},"text":"128 Stat. 3099","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef76e35d-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef76e35e-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef76e35f-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"childre