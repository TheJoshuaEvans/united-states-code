{"tag":"section","attrib":{"id":"idef936b9e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200103"},"text":null,"children":[{"tag":"num","attrib":{"value":"200103"},"text":"§ 200103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary to carry out certain functions and activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef936b9f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To carry out this chapter, the Secretary may perform the functions and activities described in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef936ba0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inventory and Evaluation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may prepare and maintain a continuing inventory and evaluation of outdoor recreation needs and resources of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef936ba1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Classification System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may prepare a system for classification of outdoor recreation resources to assist in the effective and beneficial use and management of such resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef936ba2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical Assistance and Advice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide technical assistance and advice to and cooperate with States, political subdivisions, and private interests, including nonprofit organizations, with respect to outdoor recreation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef936ba3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interstate and Regional Cooperation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may encourage interstate and regional cooperation in the planning, acquisition, and development of outdoor recreation resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef936ba4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200103/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research, Information, and Education Programs and Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef936ba5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200103/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sponsor, engage in, and assist in research relating to outdoor recreation, directly or by contract or cooperative agreements, and make payments for such purposes without regard to the limitations of section 3324(a) and (b) of title 31 concerning advances of funds when the Secretary considers such action to be in the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936ba6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200103/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake studies and assemble information concerning outdoor recreation, directly or by contract or cooperative agreement, and disseminate the information without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3204"},"text":"section 3204 of title 39","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936ba7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200103/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with educational institutions and others to assist in establishing education programs and activities and to encourage public use and benefits from outdoor recreation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef936ba8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200103/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation and Coordination with Federal Agencies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef936ba9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200103/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef936baa-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200103/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with and provide technical assistance to Federal agencies and obtain from them information, data, reports, advice, and assistance that are needed and can reasonably be furnished in carrying out the purposes of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bab-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200103/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote coordination of Federal plans and activities generally relating to outdoor recreation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936bac-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200103/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An agency furnishing advice or assistance under this paragraph may expend its own funds for those purposes, with or without reimbursement, as may be agreed to by that agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef936bad-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200103/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Donations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may accept and use donations of money, property, personal services, or facilities for the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef936bae-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3170"},"text":"128 Stat. 3170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s112/c"},"text":"Pub. L. 118–234, title I, § 112(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2839"},"text":"138 Stat. 2839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef936baf-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef936bb0-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef936bb1-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"200103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s460"},"text":"16 U.S.C. 460","children":[],"tail":null},{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":"–1."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/88/29/s2"},"text":"Pub. L. 88–29, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"May 28, 1963","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/77/49"},"text":"77 Stat. 49","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/91/375/s6/h"},"text":"Pub. L. 91–375, § 6(h)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/776"},"text":"84 Stat. 776","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “which shall be prepared as soon as practicable within 5 years on and after ","children":[{"tag":"date","attrib":{"date":"1963-05-28"},"text":"May 28, 1963","children":[],"tail":"” and “Future” are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (h), the word “department” is omitted as being included in “agency”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef936bb2-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef936bb3-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsecs. (d) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234"},"text":"Pub. L. 118–234","children":[],"tail":" redesignated subsecs. (e) to (i) as (d) to (h), respectively, and struck out former subsec. (d) which related to formulation and maintenance of a comprehensive nationwide outdoor recreation plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
