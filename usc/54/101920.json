{"tag":"section","attrib":{"id":"idef89f611-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101920"},"text":null,"children":[{"tag":"num","attrib":{"value":"101920"},"text":"§ 101920.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting for services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef89f612-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101920/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracting Authorized.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef89f613-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101920/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management elements for which contract required to maximum extent practicable","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the Secretary shall contract with private entities to conduct or assist in elements of the management of the Service concession program considered by the Secretary to be suitable for non-Federal performance. Those management elements shall include each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef89f614-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101920/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health and safety inspections.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef89f615-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101920/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Quality control of concession operations and facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef89f616-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101920/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategic capital planning for concession facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef89f617-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101920/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Analysis of rates and charges to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef89f618-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101920/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management elements for which contract allowed","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may also contract with private entities to assist the Secretary with each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef89f619-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101920/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Preparation of the financial aspects of prospectuses for Service concession contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef89f61a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101920/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development of guidelines for a System capital improvement and maintenance program for all concession occupied facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef89f61b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101920/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Making recommendations to the Director regarding the conduct of annual audits of concession fee expenditures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef89f61c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101920/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Management Elements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall consider, taking into account the recommendations of the Advisory Board, contracting out other elements of the concessions management program, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef89f61d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101920/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Secretary Not Diminished","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall diminish the governmental responsibilities and authority of the Secretary to administer concession contracts and activities pursuant to this subchapter and section 100101(a), chapter 1003, and sections 100751(a), 100752, 100753, and 102101 of this title. The Secretary reserves the right to make the final decision or contract approval on contracting services dealing with the management of the Service concessions program under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef89f61e-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3149"},"text":"128 Stat. 3149","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef89f61f-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef89f620-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef89f621-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text"