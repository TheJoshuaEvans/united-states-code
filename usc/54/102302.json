{"tag":"section","attrib":{"id":"idef8c66c8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302"},"text":null,"children":[{"tag":"num","attrib":{"value":"102302"},"text":"§ 102302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Capital region arts and cultural affairs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8c66c9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is under the direction of the Service a program to support and enhance artistic and cultural activities in the National Capital region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c66ca-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Eligibility.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8c66cb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible organizations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Eligibility for grants shall be limited to organizations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8c66cc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are of demonstrated national significance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8c66cd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that meet at least 2 of the criteria stated in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c66ce-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The criteria referred to in paragraph (1) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8c66cf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The organization has an annual operating budget in excess of $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8c66d0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The organization has an annual audience or visitation of at least 200,000 people.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8c66d1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The organization has a paid staff of at least 100 individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8c66d2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The organization is eligible under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s320102/f"},"text":"section 320102(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c66d3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Organizations not eligible","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Public or private colleges and universities are not eligible for grants under the program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c66d4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Grants awarded under this section may be used to support general operations and maintenance, security, or special projects. No organization may receive a grant in excess of $500,000 in a single year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c66d5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsbilities ","children":[],"tail":null},{"tag":"ref","attrib":{"idref":"fn002012"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002012"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “"},{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":"”."}],"tail":null},{"tag":"inline","attrib":{},"text":" of Director","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8c66d6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish an application process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c66d7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint a review panel of 5 qualified individuals, at least a majority of whom reside in the National Capital region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8c66d8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop other program guidelines and definitions as required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8c66d9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s102302/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ford’s Theater and Wolf Trap National Park for the Performing Arts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The contractual amounts required for the support of Ford’s Theater and Wolf Trap National Park for the Performing Arts shall be available within the amount provided in this section without regard to any other provision of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8c66da-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3154"},"text":"128 Stat. 3154","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8c66db-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef8c66dc-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef8c66dd-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attri