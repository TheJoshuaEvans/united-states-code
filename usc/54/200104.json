{"tag":"section","attrib":{"id":"idef936bb4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104"},"text":null,"children":[{"tag":"num","attrib":{"value":"200104"},"text":"§ 200104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal interagency council on outdoor recreation ","children":[{"tag":"ref","attrib":{"idref":"fn002016"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002016"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized as “Federal Interagency Council on Outdoor Recreation”."}],"tail":null}],"tail":null},{"tag":"subsection","attrib":{"id":"idef936bb5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish an interagency council, to be known as the “Federal Interagency Council on Outdoor Recreation”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef936bb6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef936bb7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be composed of representatives of each of the following agencies, to be appointed by the head of the respective agency:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef936bb8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Park Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bb9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bba-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Fish and Wildlife Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bbb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Bureau of Indian Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bbc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Bureau of Reclamation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bbd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Forest Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bbe-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Army Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bbf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936bc0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional participants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the members of the Council appointed under paragraph (1), the Secretary may invite participation in the Council’s meetings or other activities from representatives of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef936bc1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Council on Environmental Quality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bc2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Natural Resources Conservation Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bc3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rural development programs of the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bc4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Center for Chronic Disease Prevention and Health Promotion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bc5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bc6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Transportation, including the Federal Highway Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bc7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Tennessee Valley Authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bc8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Department of Commerce, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef936bc9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/2/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Economic Analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef936bca-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/2/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Travel and Tourism Office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef936bcb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/2/H/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Economic Development Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bcc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Energy Regulatory Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bcd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An applicable State agency or office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bce-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An applicable agency or office of a local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bcf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other organizations or interests, as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936bd0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In determining additional participants under this subsection, the Secretary shall seek to ensure that States are invited and represented in the Council’s meetings or other activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936bd1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Leadership","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The leadership of the Council shall rotate every 2 years among the Council members appointed under paragraph (1), or as otherwise determined by the Secretary in consultation with the Secretaries of Agriculture, Defense, and Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936bd2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 708 of title VII of division E of the Consolidated Appropriations Act, 2023 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Public Law 117–328","children":[],"tail":"), the Council members appointed under paragraph (1) may enter into agreements to share the management and operational costs of the Council."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef936bd3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall meet as frequently as appropriate for the purposes of coordinating on issues related to outdoor recreation, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef936bd4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recreation programs and management policies across Federal land and water management agencies, including activities associated with the implementation of the Federal Lands Recreation Enhancement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6801"},"text":"16 U.S.C. 6801","children":[],"tail":" et seq.), as appropriate;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936bd5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the response by Federal land and water management agencies to public health emergencies or other emergencies, including those that result in disruptions to, or closures of, Federal recreational lands and waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936bd6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investments relating to outdoor recreation on Federal recreational lands and waters, including funds made available under section 40804(b)(7) of the Infrastructure Investment and Jobs Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6592a/b/7"},"text":"16 U.S.C. 6592a(b)(7)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936bd7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management of emerging technologies on Federal recreational lands and waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936bd8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research activities, including quantifying the economic impacts of recreation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936bd9-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dissemination to the public of recreation-related information, in a manner that ensures the recreation-related information is easily accessible with modern communication devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936bda-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the improvement of access to Federal recreational lands and waters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936bdb-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the identification and engagement of partners outside the Federal Government—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef936bdc-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/c/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote outdoor recreation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bdd-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/c/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate collaborative management of outdoor recreation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef936bde-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/c/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide additional resources relating to enhancing outdoor recreation opportunities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef936bdf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other outdoor recreation-related issues that the Council determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef936be0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s200104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section affects the authorities, regulations, or policies of any Federal agency described in paragraph (1) or (2) of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef936be1-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3171"},"text":"128 Stat. 3171","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s113/b"},"text":"Pub. L. 118–234, title I, § 113(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2840"},"text":"138 Stat. 2840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef936be2-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historic