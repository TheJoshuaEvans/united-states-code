{"tag":"section","attrib":{"id":"idefab608e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308402"},"text":null,"children":[{"tag":"num","attrib":{"value":"308402"},"text":"§ 308402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" African American Civil Rights Network","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefab608f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish, within the Service, a program to be known as the “African American Civil Rights Network”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab6090-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties of Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Network, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab6091-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308402/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review studies and reports to complement and not duplicate studies of the historical importance of the African American civil rights movement that may be underway or completed, such as the Civil Rights Framework Study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab6092-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308402/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce and disseminate appropriate educational materials relating to the African American civil rights movement, such as handbooks, maps, interpretive guides, or electronic information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab6093-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308402/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into appropriate cooperative agreements and memoranda of understanding to provide technical assistance under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab6094-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308402/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefab6095-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308402/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create and adopt an official, uniform symbol or device for the Network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab6096-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308402/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue regulations for the use of the symbol or device adopted under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab6097-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308402/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Network shall encompass the following elements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab6098-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308402/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All units and programs of the Service that are determined by the Secretary to relate to the African American civil rights movement during the period from 1939 through 1968.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab6099-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308402/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With the consent of the property owner, other Federal, State, local, and privately owned properties that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefab609a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308402/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relate to the African American civil rights movement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab609b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308402/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a verifiable connection to the African American civil rights movement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefab609c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308402/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are included in, or determined by the Secretary to be eligible for inclusion in, the National Register of Historic Places.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab609d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308402/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other governmental and nongovernmental facilities and programs of an educational, research, or interpretive nature that are directly related to the African American civil rights movement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefab609e-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/104/s3/a"},"text":"Pub. L. 115–104, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-01-08"},"text":"Jan. 8, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2261"},"text":"131 Stat. 2261","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2407/a"},"text":"Pub. L. 116–9, title II, § 2407(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/750"},"text":"133 Stat. 750","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefab609f-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefab60a0-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefab60a1-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9"},"text":"Pub. L. 116–9","children":[],"tail":" substituted “African American Civil Rights Network” for “U.S. Civil Rights Network” in section catchline and subsec. (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefab60a2-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefab60a3-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2407/c"},"text":"Pub. L. 116–9, title II, § 2407(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/750"},"text":"133 Stat. 750","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/9/tII/s2407/c"},"text":"“Any reference in any law (other than in this section [amending this section and analyses preceding section 100101 and preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s308401"},"text":"section 308401 of this title","children":[],"tail":"]), regulation, document, record, map, or other paper of the United States to the ‘U.S. Civil Rights Network’ shall be considered to be a reference to the ‘African American Civil Rights Network’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
