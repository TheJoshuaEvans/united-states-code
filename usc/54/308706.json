{"tag":"section","attrib":{"id":"idefab617c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308706"},"text":null,"children":[{"tag":"num","attrib":{"value":"308706"},"text":"§ 308706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, after consultation with the National Trust, the National Conference of State Historic Preservation Officers, and appropriate members of the maritime heritage community, shall prescribe appropriate guidelines, procedures, and regulations to carry out the chapter, including direct grant and subgrant priorities, the method of solicitation and review of direct grant and subgrant proposals, criteria for review of direct grant and subgrant proposals, administrative requirements, reporting and recordkeeping requirements, and any other requirements the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefab617d-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3243"},"text":"128 Stat. 3243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefab617e-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefab617f-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefab6180-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"ta