{"tag":"section","attrib":{"id":"idefa4344c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304112"},"text":null,"children":[{"tag":"num","attrib":{"value":"304112"},"text":"§ 304112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectiveness of Federal grant and assistance programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa4344d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council may enter into a cooperative agreement with any Federal agency that administers a grant or assistance program for the purpose of improving the effectiveness of the administration of the program in meeting the purposes and policies of this division. The cooperative agreement may include provisions that modify the selection criteria for a grant or assistance program to further the purposes of this division or that allow the Council to participate in the selection of recipients, if those provisions are not inconsistent with the grant or assistance program’s statutory authorization and purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa4344e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Grant and Assistance Programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa4344f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the operation of any Federal grant or assistance program to evaluate the effectiveness of the program in meeting the purposes and policies of this division;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa43450-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the head of any Federal agency that administers the program to further the consistency of the program with the purposes and policies of this division and to improve its effectiveness in carrying out those purposes and policies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa43451-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s304112/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the President and Congress regarding the effectiveness of Federal grant and assistance programs in meeting the purposes and policies of this division, including recommendations with regard to appropriate funding levels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa43452-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3214"},"text":"128 Stat. 3214","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa43453-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa43454-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa43455-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"304112","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s470v–2"},"text":"16 U.S.C. 470v–2","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/665/tII/s216"},"text":"Pub. L. 89–665, title II, § 216","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/109/453/s1/g"},"text":"Pub. L. 109–453, § 1(g)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/120/3368"},"text":"120 Stat. 3368","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
