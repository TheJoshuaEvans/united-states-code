{"tag":"section","attrib":{"id":"idef8784f1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101701"},"text":null,"children":[{"tag":"num","attrib":{"value":"101701"},"text":"§ 101701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Challenge cost-share agreement authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8784f2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8784f3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Challenge cost-share agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “challenge cost-share agreement” means any agreement entered into between the Secretary and any cooperator for the purpose of sharing costs or services in carrying out authorized functions and responsibilities of the Secretary with respect to any System unit or System program, any affiliated area, or any designated national scenic trail or national historic trail.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8784f4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “cooperator” means any State or local government, public or private agency, organization, institution, corporation, individual, or other entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8784f5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Enter Into Challenge Cost-Share Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may negotiate and enter into challenge cost-share agreements with cooperators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8784f6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s101701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Source of Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out challenge cost-share agreements, the Secretary may provide the Federal funding share from any funds available to the Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8784f7-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3134"},"text":"128 Stat. 3134","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/40/s10/c"},"text":"Pub. L. 113–40, § 10(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/546"},"text":"127 Stat. 546","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8784f8-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idef8784f9-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment Not Shown in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section was derived from ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1f"},"text":"section 1f of Title 16","children":[],"tail":", Conservation, which was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/40/s10/c"},"text":"Pub. L. 113–40, § 10(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/546"},"text":"127 Stat. 546","children":[],"tail":". For applicability of that amendment to this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/b"},"text":"section 6(b) of Pub. L. 113–287","children":[],"tail":", set out as a Transitional and Savings Provisions note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of this title","children":[],"tail":". Former "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1f"},"text":"section 1f of Title 16","children":[],"tail":", which consisted of pars. (1) to (3) [restated in this section as subsecs. (a) to (c)], was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/40"},"text":"Pub. L. 113–40","children":[],"tail":" by adding at the end the following new paragraphs:"},{"tag":"quotedContent","attrib":{},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":" Available funds","children":[],"tail":null},{"tag":"i","attrib":{},"text":".—","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Out of any amounts in the Treasury not otherwise appropriated, $20,000,000 shall be made available to the Secretary of the Interior for fiscal year 2018, and $30,000,000 shall be made available to the Secretary of the Interior for fiscal year 2019, without further appropriation and to remain available until expended, to pay the Federal funding share of challenge cost-share agreements for deferred maintenance projects and to correct deficiencies in National Park Service infrastructure.","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":" Cost-share requirement","children":[],"tail":null},{"tag":"i","attrib":{},"text":".—","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Not less than 50 percent of the total cost of project for funds made available under paragraph (4) to pay the Federal funding share shall be derived from non-Federal sources, including in-kind contribution of goods and services fairly valued.”","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef8784fa-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef8784fb-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html: