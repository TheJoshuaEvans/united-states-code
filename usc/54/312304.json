{"tag":"section","attrib":{"id":"idefadab5e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312304"},"text":null,"children":[{"tag":"num","attrib":{"value":"312304"},"text":"§ 312304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and powers; administrative support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefadab5f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadab60-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and publish a list of cemeteries, monuments, and historic buildings located abroad that are associated with the foreign heritage of United States citizens from eastern and central Europe, particularly cemeteries, monuments, and buildings that are in danger of deterioration or destruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab61-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the preservation and protection of those cemeteries, monuments, and historic buildings by obtaining, in cooperation with the Secretary of State, assurances from foreign governments that the cemeteries, monuments, and buildings will be preserved and protected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab62-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312304/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and disseminate reports on the condition of, and the progress toward preserving and protecting, those cemeteries, monuments, and historic buildings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadab63-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Powers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadab64-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hold hearings, request attendance, take testimony, and receive evidence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission or any member it authorizes may, for the purposes of carrying out this chapter, hold such hearings, sit and act at such times and places, request such attendance, take such testimony, and receive such evidence, as the Commission considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab65-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appoint personnel and fix pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may appoint such personnel (subject to the provisions of title 5 governing appointments in the competitive service) and may fix the pay of such personnel (subject to the provisions of chapter 51 and subchapter III of chapter 53 of title 5), as the Commission considers desirable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab66-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312304/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procure temporary and intermittent services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may procure temporary and intermittent services to the same extent as is authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":", but at rates for individuals not to exceed the daily equivalent of the maximum annual rate of basic pay then in effect under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab67-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312304/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detail personnel to commisison ","children":[],"tail":null},{"tag":"ref","attrib":{"idref":"fn002032"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002032"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “"},{"tag":"inline","attrib":{},"text":"commission","children":[],"tail":"”."}],"tail":null},{"tag":"inline","attrib":{},"text":null,"children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On request of the Commission, the head of any Federal department or agency, including the Secretary of State, may detail, on a reimbursable basis, any of the personnel of that department or agency to the Commission to assist it in carrying out its duties under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab68-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312304/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secure information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may secure directly from any department or agency of the United States, including the Department of State, any information necessary to enable it to carry out this chapter. On the request of the Chairman of the Commission, the head of the department or agency shall furnish the information to the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab69-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312304/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gifts or donations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may accept, use, and dispose of gifts or donations of money or property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab6a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312304/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of mails","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may use the United States mails in the same manner and on the same conditions as other departments and agencies of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadab6b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services shall provide to the Commission on a reimbursable basis administrative support services as the Commission may request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefadab6c-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3252"},"text":"128 Stat. 3252","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefadab6d-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefadab6e-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefadab6f-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag"