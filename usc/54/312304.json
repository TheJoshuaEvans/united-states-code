},{"tag":"html:a","attrib":{"href":"/us/stat/99/280"},"text":"99 Stat. 280","children":[],"tail":", 281."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"312304(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s469j/g"},"text":"16 U.S.C. 469j(g)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the word “Secretary” is substituted for “Department” because of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"22 U.S.C. 2651","children":[],"tail":" and 2651a(a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the words “under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":"” are substituted for “for grade GS–18 of the General Schedule ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332/a"},"text":"5 U.S.C. 5332(a)","children":[],"tail":")” because of section 529 [title I, § 101(c)(1)] of the Treasury, Postal Service and General Government Appropriations Act, 1991 ("},{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Public Law 101–509","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"5 U.S.C. 5376","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
