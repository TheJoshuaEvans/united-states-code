{"tag":"section","attrib":{"id":"idef9d0999-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302303"},"text":null,"children":[{"tag":"num","attrib":{"value":"302303"},"text":"§ 302303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of State Historic Preservation Officer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9d099a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall be the responsibility of the State Historic Preservation Officer to administer the State Historic Preservation Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9d099b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Particular Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be the responsibility of the State Historic Preservation Officer to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9d099c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with Federal and State agencies, local governments, and private organizations and individuals, direct and conduct a comprehensive statewide survey of historic property and maintain inventories of the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d099d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and nominate eligible property to the National Register and otherwise administer applications for listing historic property on the National Register;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d099e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302303/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and implement a comprehensive statewide historic preservation plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d099f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302303/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer the State program of Federal assistance for historic preservation within the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d09a0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302303/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise and assist, as appropriate, Federal and State agencies and local governments in carrying out their historic preservation responsibilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d09a1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302303/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with the Secretary, the Council, other Federal and State agencies, local governments, and private organizations and individuals to ensure that historic property is taken into consideration at all levels of planning and development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d09a2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302303/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide public information, education, and training and technical assistance in historic preservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d09a3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302303/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with local governments in the development of local historic preservation programs and assist local governments in becoming certified pursuant to chapter 3025;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d09a4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302303/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consult with appropriate Federal agencies in accordance with this division on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9d09a5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302303/b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal undertakings that may affect historic property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9d09a6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302303/b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the content and sufficiency of any plans developed to protect, manage, or reduce or mitigate harm to that property; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d09a7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302303/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise and assist in the evaluation of proposals for rehabilitation projects that may qualify for Federal assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9d09a8-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3195"},"text":"128 Stat. 3195","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9d09a9-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9d09aa-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9d09ab-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}