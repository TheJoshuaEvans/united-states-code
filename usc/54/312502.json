{"tag":"section","attrib":{"id":"idefadab7e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312502"},"text":null,"children":[{"tag":"num","attrib":{"value":"312502"},"text":"§ 312502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Threat of irreparable loss or destruction of significant scientific, prehistorical, historical, or archeological data by Federal construction projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefadab7f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activity of Federal Agency.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadab80-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When any Federal agency finds, or is notified, in writing, by an appropriate historical or archeological authority, that its activities in connection with any Federal construction project or federally licensed project, activity, or program may cause irreparable loss or destruction of significant scientific, prehistorical, historical, or archeological data, the agency shall notify the Secretary, in writing, and shall provide the Secretary with appropriate information concerning the project, program, or activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab81-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recovery, protection, and preservation of data","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefadab82-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312502/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may request the Secretary to undertake the recovery, protection, and preservation of the data (including preliminary survey, or other investigation as needed, and analysis and publication of the reports resulting from the investigation); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefadab83-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312502/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, with funds appropriated for the project, program, or activity, undertake those activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab84-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Copies of reports of any investigations made pursuant to this section shall be submitted to the Secretary, who shall make them available to the public for inspection and review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefadab85-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activity of Private Person, Association, or Public Entity.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefadab86-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recovery by secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"When any Federal agency provides financial assistance by loan, grant, or otherwise to any private person, association, or public entity, the Secretary, if the Secretary determines that significant scientific, prehistorical, historical, or archeological data might be irrevocably lost or destroyed, may, with funds appropriated expressly for this purpose—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefadab87-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312502/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct, with the consent of all persons, associations, or public entities having a legal interest in the property, a survey of the affected site; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefadab88-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312502/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake the recovery, protection, and preservation of the data (including analysis and publication).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefadab89-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall, unless otherwise agreed to in writing, compensate any person, association, or public entity damaged as a result of delays in construction or as a result of the temporary loss of the use of private or any nonfederally owned land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefadab8a-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3254"},"text":"128 Stat. 3254","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefadab8b-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefadab8c-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefadab8d-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"312502","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s469a–1"},"text":"16 U.S.C. 469a–1","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/86/523/s3"},"text":"Pub. L. 86–523, § 3","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/93/291/s1/3"},"text":"Pub. L. 93–291, § 1(3)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"May 24, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/174"},"text":"88 Stat. 174","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
