{"tag":"section","attrib":{"id":"idef912220-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s104908"},"text":null,"children":[{"tag":"num","attrib":{"value":"104908"},"text":"§ 104908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bows in parks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef912221-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s104908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Not Ready for Immediate Use","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “not ready for immediate use” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef912222-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s104908/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bow or crossbow, the arrows of which are secured or stowed in a quiver or other arrow transport case; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef912223-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s104908/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a crossbow, uncocked.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef912224-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s104908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vehicular Transportation Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall not promulgate or enforce any regulation that prohibits an individual from transporting bows and crossbows that are not ready for immediate use across any System unit in the vehicle of the individual if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef912225-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s104908/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual is not otherwise prohibited by law from possessing the bows and crossbows;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef912226-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s104908/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bows or crossbows that are not ready for immediate use remain inside the vehicle of the individual throughout the period during which the bows or crossbows are transported across System land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef912227-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s104908/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the possession of the bows and crossbows is in compliance with the law of the State in which the System unit is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef912228-3a70-11f1-83cd-8a39f388f6db"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2409/a"},"text":"Pub. L. 116–9, title II, § 2409(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/751"},"text":"133 Stat. 751","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
