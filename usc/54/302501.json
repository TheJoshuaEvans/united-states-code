{"tag":"section","attrib":{"id":"idef9f79c5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302501"},"text":null,"children":[{"tag":"num","attrib":{"value":"302501"},"text":"§ 302501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9f79c6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “designation” means the identification and registration of property for protection that meets criteria established by a State or locality for significant historic property within the jurisdiction of a local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9f79c7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “protection” means protection by means of a local review process under State or local law for proposed demolition of, changes to, or other action that may affect historic property designated pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9f79c8-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":