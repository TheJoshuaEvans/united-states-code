{"tag":"section","attrib":{"id":"idefb01ba3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312505"},"text":null,"children":[{"tag":"num","attrib":{"value":"312505"},"text":"§ 312505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of dam construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefb01ba4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before any Federal agency undertakes the construction of a dam, or issues a license to any private individual or corporation for the construction of a dam, it shall give written notice to the Secretary setting forth the site of the proposed dam and the approximate area to be flooded and otherwise changed if construction is undertaken.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb01ba5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s312505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dams With Certain Detention Capacity or Reservoir","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to any flood water retarding dam that provides fewer than 5,000 acre-feet of detention capacity, and with respect to any other type of dam that creates a reservoir of fewer than 40 surface acres, this section shall apply only when the constructing agency, in its preliminary surveys, finds or is presented with evidence that historical or archeological materials exist or may be present in the proposed reservoir area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb01ba6-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3256"},"text":"128 Stat. 3256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefb01ba7-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefb01ba8-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefb01ba9-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tai