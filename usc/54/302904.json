{"tag":"section","attrib":{"id":"idef9f7a54-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302904"},"text":null,"children":[{"tag":"num","attrib":{"value":"302904"},"text":"§ 302904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct grants for the preservation of properties included on National Register","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9f7a55-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration of Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall administer a program of direct grants for the preservation of properties included on the National Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9f7a56-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Available Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds to support the program annually shall not exceed 10 percent of the amount appropriated annually for the Historic Preservation Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9f7a57-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Uses of Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9f7a58-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302904/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under this section may be made by the Secretary, in consultation with the appropriate State Historic Preservation Officer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9f7a59-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302904/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the preservation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef9f7a5a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302904/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Historic Landmarks that are threatened with demolition or impairment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef9f7a5b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302904/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" historic property of World Heritage significance;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9f7a5c-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302904/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for demonstration projects that will provide information concerning professional methods and techniques having application to historic property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9f7a5d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302904/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the training and development of skilled labor in trades and crafts, and in analysis and curation, relating to historic preservation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9f7a5e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302904/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist individuals or small businesses within any historic district included on the National Register to remain within the district.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9f7a5f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302904/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limit on certain grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grant may be made under subparagraph (A) or (D) of paragraph (1) only to the extent that the project cannot be carried out in as effective a manner through the use of an insured loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s303901"},"text":"section 303901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9f7a60-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3204"},"text":"128 Stat. 3204","children":[],"tail":".)"}],"