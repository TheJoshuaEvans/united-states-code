{"tag":"section","attrib":{"id":"idef7b9e00-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100723"},"text":null,"children":[{"tag":"num","attrib":{"value":"100723"},"text":"§ 100723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7b9e01-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Action for Response Costs and Damages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General, on request of the Secretary after a finding by the Secretary of destruction, loss, or injury to a System unit resource or a finding that absent the undertaking of a response action, destruction, loss, or injury to a System unit resource would have occurred, may bring a civil action in United States district court against any person or instrumentality that may be liable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100722"},"text":"section 100722 of this title","children":[],"tail":" for response costs and damages. The Secretary shall submit a request for the civil action to the Attorney General whenever a person may be liable or an instrumentality may be liable in rem for those costs and damages under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100722"},"text":"section 100722 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7b9e02-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Response Actions and Assessment of Destruction, Loss, or Injury.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7b9e03-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100723/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions to prevent or minimize destruction, loss, or injury","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall undertake all necessary actions to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7b9e04-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100723/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent or minimize the destruction, loss of, or injury to System unit resources; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7b9e05-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100723/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the imminent risk of destruction, loss, or injury to System unit resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7b9e06-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100723/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment and monitoring","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall assess and monitor destruction, loss, or injury to System unit resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7b9e07-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3107"},"text":"128 Stat. 3107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7b9e08-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef7b9e09-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef7b9e0a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"100723","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s19jj–2"},"text":"16 U.S.C. 19jj–2","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/101/337/s3"},"text":"Pub. L. 101–337, § 3","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 27, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/380"},"text":"104 Stat. 380","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “destruction, loss, or injury” are substituted for “damage” in subsection (a) and for “damages” in subsection (b) for consistency in the new chapter and to distinguish destruction, loss, or injury from damages recovered in a civil action.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “response action” are substituted for “response costs” the 1st time the words appear for clarity and consistency in the new chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
