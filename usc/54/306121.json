ing","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefa6a597-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historic Lease Process Simplification","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/391/tVIII/s802/b"},"text":"Pub. L. 105–391, title VIII, § 802(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3523"},"text":"112 Stat. 3523","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/391/tVIII/s802/b"},"text":"“The Secretary is directed to simplify, to the maximum extent possible, the leasing process for historic properties with the goal of leasing available structures in a timely manner.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For “Secretary” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/391/s802/b"},"text":"section 802(b) of Pub. L. 105–391","children":[],"tail":", set out above, as meaning the Secretary of the Interior, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/391/s2"},"text":"section 2 of Pub. L. 105–391","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3498"},"text":"112 Stat. 3498","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s5901"},"text":"section 5901 of Title 16","children":[],"tail":", Conservation, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
