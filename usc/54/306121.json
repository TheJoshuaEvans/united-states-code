{"tag":"section","attrib":{"id":"idefa6a58d-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306121"},"text":null,"children":[{"tag":"num","attrib":{"value":"306121"},"text":"§ 306121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease or exchange","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa6a58e-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Lease or Exchange","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, each Federal agency, after consultation with the Council—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa6a58f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306121/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, to the extent practicable, establish and implement alternatives (including adaptive use) for historic property that is not needed for current or projected agency purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa6a590-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306121/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may lease historic property owned by the agency to any person or organization, or exchange any property owned by the agency with comparable historic property, if the agency head determines that the lease or exchange will adequately ensure the preservation of the historic property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa6a591-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s306121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proceeds of Lease","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, the proceeds of a lease under subsection (a) may be retained by the agency entering into the lease and used to defray the costs of administration, maintenance, repair, and related expenses incurred by the agency with respect to that property or other property that is on the National Register that is owned by, or are under the jurisdiction or control of, the agency. Any surplus proceeds from the leases shall be deposited in the Treasury at the end of the 2d fiscal year following the fiscal year in which the proceeds are received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa6a592-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3228"},"text":"128 Stat. 3228","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa6a593-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa6a594-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa6a595-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"h