{"tag":"section","attrib":{"id":"idef9d0978-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302108"},"text":null,"children":[{"tag":"num","attrib":{"value":"302108"},"text":"§ 302108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of threats to historic property","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"At least once every 4 years, the Secretary, in consultation with the Council and with State Historic Preservation Officers, shall review significant threats to historic property to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9d0979-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302108/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the kinds of historic property that may be threatened;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d097a-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302108/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ascertain the causes of the threats; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9d097b-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302108/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and submit to the President and Congress recommendations for appropriate action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9d097c-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3194"