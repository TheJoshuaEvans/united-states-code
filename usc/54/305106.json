{"tag":"section","attrib":{"id":"idefa434aa-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305106"},"text":null,"children":[{"tag":"num","attrib":{"value":"305106"},"text":"§ 305106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historic light station sales","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa434ab-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa434ac-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When sale may occur","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If no applicant is approved for the conveyance of a historic light station pursuant to sections 305101 through 305105 of this title, the historic light station shall be offered for sale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa434ad-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms of sale","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Terms of the sales—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa434ae-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305106/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be developed by the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa434af-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305106/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be consistent with the requirements of paragraphs (1) to (4) and (8) of subsection (a), and subsection (b), of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s305104"},"text":"section 305104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa434b0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305106/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covenants to be included in conveyance documents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Conveyance documents shall include all necessary covenants to protect the historical integrity of the historic light station and ensure that any Federal aid to navigation located at the historic light station is operated and maintained by the United States for as long as needed for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa434b1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Net Sale Proceeds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa434b2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disposition and use of funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Net sale proceeds from the disposal of a historic light station—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa434b3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305106/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located on public domain land shall be transferred to the National Maritime Heritage Grants Program established under chapter 3087 in the Department of the Interior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa434b4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305106/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under the administrative control of the Secretary of Homeland Security—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefa434b5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305106/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be credited to the Coast Guard’s Operating Expenses appropriation account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefa434b6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305106/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be available for obligation and expenditure for the maintenance of light stations remaining under the administrative control of the Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa434b7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s305106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The funds referred to in paragraph (1)(B) shall remain available until expended and shall be available in addition to funds available in the Coast Guard’s Operating Expense appropriation for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa434b8-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3220"},"text":"128 Stat. 3220","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa434b9-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa434ba-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa434bb-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and 