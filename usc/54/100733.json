{"tag":"section","attrib":{"id":"idef7b9e26-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s100733"},"text":null,"children":[{"tag":"num","attrib":{"value":"100733"},"text":"§ 100733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordation of mining claims; publication of notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All mining claims under the Mining Law of 1872 (30 U.S.C. chapter 2, sections 161 and 162, and chapters 12A and 16) that lie within the boundaries of System units in existence on ","children":[{"tag":"date","attrib":{"date":"1976-09-28"},"text":"September 28, 1976","children":[],"tail":", that were not recorded with the Secretary within one year after "},{"tag":"date","attrib":{"date":"1976-09-28"},"text":"September 28, 1976","children":[],"tail":", shall be conclusively presumed to be abandoned and shall be void. The recordation does not render valid any claim that was not valid on "},{"tag":"date","attrib":{"date":"1976-09-28"},"text":"September 28, 1976","children":[],"tail":", or that becomes invalid after that date."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef7b9e27-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3109"},"text":"128 Stat. 3109","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7b9e28-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef7b9e29-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef7b9e2a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"100733","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s1907"},"text":"16 U.S.C. 1907","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/94/429/s8"},"text":"Pub. L. 94–429, § 8","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 28, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/1343"},"text":"90 Stat. 1343","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The section is substituted for the source provision to eliminate obsolete words. The words “in existence on ","children":[{"tag":"date","attrib":{"date":"1976-09-28"},"text":"September 28, 1976","children":[],"tail":"” are added for clarity to show that the provision applies only to System units that were part of the System on that date."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7b9e2b-3a70-11f1-83cd-8a39f388f6db"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef7b9e2c-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Mining Law of 1872, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1872-05-10/ch152"},"text":"act May 10, 1872, ch. 152","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/91"},"text":"17 Stat. 91","children":[],"tail":", which was incorporated into the Revised Statutes of 1878 as R.S. §§ 2319 to 2328, 2331, 2333 to 2337, and 2344, which are classified to sections 22 to 24, 26 to 28, 29, 30, 33 to 35, 37, 39 to 42, and 47 of Title 30, Mineral Lands and Mining. For complete classification of such Revised Statutes sections to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
