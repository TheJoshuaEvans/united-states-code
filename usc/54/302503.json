,"attrib":{},"text":"Mar. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/92"},"text":"94 Stat. 92","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/515/tII/s201/a"},"text":"Pub. L. 96–515, title II, § 201(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/2991"},"text":"94 Stat. 2991","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “State program approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302302"},"text":"section 302302 of this title","children":[],"tail":"” are substituted for “approved State program” for clarity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
