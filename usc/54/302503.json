{"tag":"section","attrib":{"id":"idef9f79d1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302503"},"text":null,"children":[{"tag":"num","attrib":{"value":"302503"},"text":"§ 302503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for certification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9f79d2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approved State Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any local government shall be certified to participate under this section if the applicable State Historic Preservation Officer, and the Secretary, certify that the local government—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9f79d3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforces appropriate State or local legislation for the designation and protection of historic property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9f79d4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has established an adequate and qualified historic preservation review commission by State or local legislation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9f79d5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302503/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains a system for the survey and inventory of historic property that furthers the purposes of chapter 3023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9f79d6-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302503/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for adequate public participation in the local historic preservation program, including the process of recommending properties for nomination to the National Register; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9f79d7-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302503/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfactorily performs the responsibilities delegated to it under this division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9f79d8-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s302503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Approved State Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Where there is no State program approved under sections 302301 and 302302 of this title, a local government may be certified by the Secretary if the Secretary determines that the local government meets the requirements of subsection (a). The Secretary may make grants to the local government certified under this subsection for purposes of this subdivision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9f79d9-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3197"},"text":"128 Stat. 3197","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9f79da-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idef9f79db-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idef9f79dc-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Sou