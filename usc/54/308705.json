{"tag":"section","attrib":{"id":"idefab616f-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308705"},"text":null,"children":[{"tag":"num","attrib":{"value":"308705"},"text":"§ 308705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of America’s National Maritime Museum","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefab6170-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"America’s National Maritime Museum shall be composed of the museums designated by law to be museums of America’s National Maritime Museum on the basis that the museums—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab6171-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308705/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" house a collection of maritime artifacts clearly representing the Nation’s maritime heritage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab6172-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308705/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide outreach programs to educate the public about the Nation’s maritime heritage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab6173-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial Designation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following museums (meeting the criteria specified in subsection (a)) are designated as museums of America’s National Maritime Museum:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefab6174-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308705/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Mariners’ Museum, located at 100 Museum Drive, Newport News, Virginia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefab6175-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308705/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The South Street Seaport Museum, located at 207 Front Street, New York, New York.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab6176-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Future Designation of Other Museums Not Precluded","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The designation of the museums referred to in subsection (b) as museums of America’s National Maritime Museum does not preclude the designation by law of any other museum that meets the criteria specified in subsection (a) as a museum of America’s National Maritime Museum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefab6177-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s308705/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reference to Museums","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reference in any law, map, regulation, document, paper, or other record of the United States to a museum designated by law to be a museum of America’s National Maritime Museum shall be deemed to be a reference to that museum as a museum of America’s National Maritime Museum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefab6178-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3242"},"text":"128 Stat. 3242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefab6179-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefab617a-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefab617b-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html: