{"tag":"section","attrib":{"id":"idefa1c3be-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s303903"},"text":null,"children":[{"tag":"num","attrib":{"value":"303903"},"text":"§ 303903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation education and training program","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Council and other appropriate Federal, tribal, Native Hawaiian, and non-Federal organizations, shall develop and implement a comprehensive preservation education and training program. The program shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa1c3bf-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s303903/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards and increased preservation training opportunities for Federal workers involved in preservation-related functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3c0-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s303903/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preservation training opportunities for other Federal, State, tribal and local government workers, and students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3c1-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s303903/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical or financial assistance, or both, to historically black colleges and universities, to tribal colleges, and to colleges with a high enrollment of Native Americans or Native Hawaiians, to establish preservation training and degree programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa1c3c2-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s303903/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" where appropriate, coordination with the National Center for Preservation Technology and Training of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa1c3c3-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s303903/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distribution of information on preservation technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa1c3c4-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s303903/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of training and skill development in trades, crafts, and disciplines related to historic preservation in Federal training and development programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa1c3c5-3a70-11f1-83cd-8a39f388f6db","identifier":"/us/usc/t54/s303903/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support for research, analysis, conservation, curation, interpretation, and display related to preservation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa1c3c6-3a70-11f1-83cd-8a39f388f6db"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s3"},"text":"Pub. L. 113–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3208"},"text":"128 Stat. 3208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa1c3c7-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idefa1c3c8-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idefa1c3c9-3a70-11f1-83cd-8a39f388f6db"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib"