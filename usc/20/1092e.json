{"tag":"section","attrib":{"id":"id0d59c0ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1092e"},"text":"§ 1092e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" College access initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d59c0ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State-by-State information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall direct each guaranty agency with which the Secretary has an agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078/c"},"text":"section 1078(c) of this title","children":[],"tail":" to provide to the Secretary the information necessary for the development of Internet web links and access for students and families to a comprehensive listing of the postsecondary education opportunities, programs, publications, Internet web sites, and other services available in the States for which such agency serves as the designated guarantor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d59c0f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guaranty agency activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d59c0f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan and activity required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each guaranty agency with which the Secretary has an agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078/c"},"text":"section 1078(c) of this title","children":[],"tail":" shall develop a plan, and undertake the activity necessary, to gather the information required under subsection (a) and to make such information available to the public and to the Secretary in a form and manner as prescribed by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c0f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each guaranty agency shall undertake such activities as are necessary to promote access to postsecondary education for students through providing information on college planning, career preparation, and paying for college. The guaranty agency shall publicize such information and coordinate such activities with other entities that either provide or distribute such information in the States for which such guaranty agency serves as the designated guarantor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c0f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The activities required by this section may be funded from the guaranty agency’s Operating Fund established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1072b"},"text":"section 1072b of this title","children":[],"tail":" and, to the extent funds remain, from earnings on the restricted account established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1072/h/4"},"text":"section 1072(h)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c0f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to require a guaranty agency to duplicate any efforts under way on ","children":[{"tag":"date","attrib":{"date":"2006-02-08"},"text":"February 8, 2006","children":[],"tail":", that meet the requirements of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d59c0f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d59c0f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary’s responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure the availability of the information provided, by the guaranty agencies in accordance with this section, to students, parents, and other interested individuals, through Internet web links or other methods prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c0f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guaranty agency responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The guaranty agencies shall ensure that the information required by this section is available without charge in printed format for students and parents requesting such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c0f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publicity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 270 days after ","children":[{"tag":"date","attrib":{"date":"2006-02-08"},"text":"February 8, 2006","children":[],"tail":", the Secretary and guaranty agencies shall publicize the availability of the information required by this section, with special emphasis on ensuring that populations that are traditionally underrepresented in postsecondary education are made aware of the availability of such information."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d59c0f9-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s485D"},"text":"Pub. L. 89–329, title IV, § 485D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tVIII/s8023"},"text":"Pub. L. 109–171, title VIII, § 8023","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/179"},"text":"120 Stat. 179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d59c0fa-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d59c0fb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d59c0fc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2006-07-01"},"text":"July 1, 2006","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8001/c"},"text":"section 8001(c) of Pub. L. 109–171","children":[],"tail":", set out as an Effective Date of 2006 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
