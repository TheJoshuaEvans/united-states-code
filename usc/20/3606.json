{"tag":"section","attrib":{"id":"id0ddcd4c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3606"},"text":null,"children":[{"tag":"num","attrib":{"value":"3606"},"text":"§ 3606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and safety procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ddcd4c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3606/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and distribution to designated State agency or unit; establishment of criteria for loan program eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ddcd4c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3606/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Within 120 days after the first meeting of the Task Force, and after consultation with the Task Force, the Secretary shall establish and distribute to the State agency or unit designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3603/a/4"},"text":"section 3603(a)(4) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ddcd4ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3606/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for testing the level of asbestos fibers in schools, including safety measures to be followed in conducting such tests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ddcd4cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3606/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for evaluating (on the basis of such tests) the likelihood of the leakage of asbestos fibers into the school environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ddcd4cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3606/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for determining which contractors are qualified to carry out the testing and evaluation described in this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddcd4cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3606/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After consulting with the Task Force, the Secretary shall establish criteria to be used for determining eligibility for loans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3605"},"text":"section 3605 of this title","children":[],"tail":". The criteria shall be based on the assessment of the extent of the health hazards posed by the presence of asbestos fibers in schools, as determined in accordance with standards under paragraph (1)(B) of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddcd4ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3606/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After reviewing recommendations submitted to the Secretary by the Task Force under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3602/e/5"},"text":"section 3602(e)(5) of this title","children":[],"tail":", the Secretary, with the concurrence of the Task Force, shall by regulation establish—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ddcd4cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3606/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" procedures to be used by local educational agencies, in programs for which loans are made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3605"},"text":"section 3605 of this title","children":[],"tail":", for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ddcd4d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3606/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containing and removing asbestos materials in school buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ddcd4d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3606/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" replacing the asbestos materials removed from school buildings with other appropriate building materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ddcd4d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3606/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restoring such school buildings to conditions comparable to those existing before asbestos containment or removal activities were undertaken; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddcd4d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3606/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for determining which contractors are qualified to carry out the activities referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ddcd4d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3606/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Avoidance of duplication of similar activities of Environmental Protection Agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out his duties under this section, the Secretary shall avoid, to the maximum extent practicable, duplicating similar activities undertaken by the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ddcd4d5-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/270/s7"},"text":"Pub. L. 96–270, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-14"},"text":"June 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/494"},"text":"94 Stat. 494","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
