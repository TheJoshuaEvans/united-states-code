{"tag":"section","attrib":{"id":"id0cddb33d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1067h"},"text":"§ 1067h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cddb33e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission and contents of applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible applicant (as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067g"},"text":"section 1067g of this title","children":[],"tail":") that desires to receive a grant under this part shall submit to the Secretary an application therefor at such time or times, in such manner, and containing such information as the Secretary may prescribe by regulation. Such application shall set forth—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cddb33f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program of activities for carrying out one or more of the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067a/b"},"text":"section 1067a(b) of this title","children":[],"tail":" in such detail as will enable the Secretary to determine the degree to which such program will accomplish such purpose or purposes; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cddb340-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other policies, procedures, and assurances as the Secretary may require by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cddb341-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval based on likelihood of progress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall approve an application only if the Secretary determines that the application sets forth a program of activities which are likely to make substantial progress toward achieving the purposes of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cddb342-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s362"},"text":"Pub. L. 89–329, title III, § 362","children":[],"tail":", formerly title X, § 1042, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tX/s1002"},"text":"Pub. L. 99–498, title X, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1564"},"text":"100 Stat. 1564","children":[],"tail":"; renumbered title III, § 362, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIII/s301/a/5"},"text":"Pub. L. 105–244, title III, § 301(a)(5)","children":[],"tail":", (7), (c)(10), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1636"},"text":"112 Stat. 1636","children":[],"tail":", 1637.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cddb343-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cddb3