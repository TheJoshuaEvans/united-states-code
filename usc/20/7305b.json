1"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3710"},"text":"108 Stat. 3710","children":[],"tail":", related to State applications."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e32bc54-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5002/5/A/i"},"text":"Pub. L. 114–95, § 5002(5)(A)(i)","children":[],"tail":", substituted “all, or any lesser amount, of State funds” for “not more than 50 percent of the nonadministrative State funds” in introductory provisions, added subpars. (A) to (C), and struck out former subpars. (A) to (D) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6613/a/3"},"text":"Section 6613(a)(3) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6762/a/1"},"text":"Section 6762(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) Subsections (a)(1) (with the agreement of the Governor) and (c)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7112"},"text":"section 7112 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7172/c/3"},"text":"section 7172(c)(3) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7211a/b"},"text":"Section 7211a(b) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5002/3"},"text":"Pub. L. 114–95, § 5002(3)","children":[],"tail":", substituted “part” for “subpart” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5002/5/A/ii"},"text":"Pub. L. 114–95, § 5002(5)(A)(ii)","children":[],"tail":", added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “In accordance with this subpart and subject to the 50 percent limitation described in paragraph (1), a State may transfer any funds allotted to the State under a provision listed in paragraph (1) to its allotment under subchapter I of this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5002/3"},"text":"Pub. L. 114–95, § 5002(3)","children":[],"tail":", (5)(B)(i)(I), substituted “part” for “subpart” and “may transfer all, or any lesser amount, of the funds allocated to it” for “(except a local educational agency identified for improvement under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6316/c"},"text":"section 6316(c) of this title","children":[],"tail":" or subject to corrective action under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6316/c/9"},"text":"section 6316(c)(9) of this title","children":[],"tail":") may transfer not more than 50 percent of the funds allocated to it (including funds transferred under subparagraph (C))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5002/5/B/i/II"},"text":"Pub. L. 114–95, § 5002(5)(B)(i)(II)","children":[],"tail":", added subpar. (B) and struck out former subpars. (B) and (C) which permitted transfers of allocated funds for agencies identified for improvement and for additional funds for subchapter I."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5002/5/B/ii"},