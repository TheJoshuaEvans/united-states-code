{"tag":"section","attrib":{"id":"id0e32bc26-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b"},"text":null,"children":[{"tag":"num","attrib":{"value":"7305b"},"text":"§ 7305b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferability of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e32bc27-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers by States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e32bc28-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with this part, a State may transfer all, or any lesser amount, of State funds (including funds transferred under paragraph (2)) allotted to the State for use for State-level activities under the following provisions for a fiscal year to one or more of the State’s allotments for such fiscal year under any other of such provisions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e32bc29-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A of subchapter II.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc2a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A of subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc2b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7172/c/3"},"text":"Section 7172(c)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e32bc2c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with this part, a State may transfer any funds allotted to the State under a provision listed in paragraph (1) for a fiscal year to its allotment under any other of the following provisions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e32bc2d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A of subchapter I.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc2e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part C of subchapter I.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc2f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part D of subchapter I.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc30-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A of subchapter III.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc31-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e32bc32-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers by local educational agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e32bc33-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to transfer funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e32bc34-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with this part, a local educational agency may transfer all, or any lesser amount, of the funds allocated to it under each of the provisions listed in paragraph (2) for a fiscal year to one or more of its allocations for such fiscal year under any other provision listed in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc35-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with this part, a local educational agency may transfer any funds allotted to such agency under a provision listed in paragraph (2) for a fiscal year to its allotment under any other of the following provisions:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e32bc36-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A of subchapter I.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e32bc37-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part C of subchapter I.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e32bc38-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part D of subchapter I.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e32bc39-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A of subchapter III.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e32bc3a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/b/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e32bc3b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A local educational agency may transfer funds under subparagraph (A) or (B) of paragraph (1) from allocations made under each of the following provisions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e32bc3c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A of subchapter II.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc3d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A of subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e32bc3e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No transfer of certain funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State or local educational agency may not transfer under this part to any other program any funds allotted or allocated to it for the following provisions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e32bc3f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A of subchapter I.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e32bc40-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part C of subchapter I.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e32bc41-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part D of subchapter I.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e32bc42-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part A of subchapter III.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e32bc43-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e32bc44-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of plans and applications; notification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e32bc45-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State transfers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State that makes a transfer of funds under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e32bc46-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modify, to account for such transfer, each State plan, or application submitted by the State, to which such funds relate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc47-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 30 days after the date of such transfer, submit a copy of such modified plan or application to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc48-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 30 days before the effective date of such transfer, notify the Secretary of such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e32bc49-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local transfers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each local educational agency that makes a transfer of funds under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e32bc4a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modify, to account for such transfer, each local plan, or application submitted by the agency, to which such funds relate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc4b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 30 days after the date of such transfer, submit a copy of such modified plan or application to the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e32bc4c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 30 days before the effective date of such transfer, notify the State of such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e32bc4d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e32bc4e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this part, funds transferred under this section are subject to each of the rules and requirements applicable to the funds under the provision to which the transferred funds are transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e32bc4f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7305b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State educational agency or local educational agency that transfers funds under this section shall conduct consultations in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7881"},"text":"section 7881 of this title","children":[],"tail":", if such transfer transfers funds from a program that provides for the participation of students, teachers, or other educational personnel, from private schools."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e32bc50-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5103"},"text":"Pub. L. 89–10, title V, § 5103","children":[],"tail":", formerly title VI, § 6123, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVI/s601"},"text":"Pub. L. 107–110, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1876"},"text":"115 Stat. 1876","children":[],"tail":"; renumbered title V, § 5103, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tV"},"text":"Pub. L. 114–95, title V","children":[],"tail":", §§ 5001(a)(1), 5002(3), (5), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2039"},"text":"129 Stat. 2039","children":