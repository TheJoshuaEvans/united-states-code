{"tag":"section","attrib":{"id":"id0d339bcb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1087h"},"text":"§ 1087h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds for administrative expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d339bcc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d339bcd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional mandatory funds for servicing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be available to the Secretary (in addition to any other amounts appropriated under any appropriations Act for administrative costs under this part and part B and out of any money in the Treasury not otherwise appropriated) $1,000,000,000 to be obligated for administrative costs under this part and part B, including the costs of servicing the direct student loan programs under this part, which shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d339bce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/67/dA/tV/s502/2"},"text":"Pub. L. 113–67, div. A, title V, § 502(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1187"},"text":"127 Stat. 1187","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d339bcf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087h/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for administrative costs beginning in fiscal years 2007 through 2014","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of the fiscal years 2007 through 2014, there are authorized to be appropriated such sums as may be necessary for administrative costs under this part and part B, including the costs of the direct student loan programs under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d339bd0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087h/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing mandatory funds for account maintenance fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of the fiscal years 2007 through 2021,","children":[{"tag":"ref","attrib":{"idref":"fn002085"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002085"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Funds for Account Maintenance Fees note below."}],"tail":" there shall be available to the Secretary, from funds not otherwise appropriated, funds to be obligated for account maintenance fees payable to guaranty agencies under part B and calculated in accordance with subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d339bd1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087h/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Account maintenance fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Account maintenance fees under paragraph (3) ","children":[{"tag":"ref","attrib":{"idref":"fn002086"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002086"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" shall be paid quarterly and deposited in the Agency Operating Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1072b"},"text":"section 1072b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d339bd2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087h/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance to institutions of higher education","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d339bd3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087h/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide institutions of higher education participating, or seeking to participate, in the loan programs under this part with technical assistance in establishing and administering such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d339bd4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087h/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated, and there are appropriated, to carry out this paragraph (in addition to any other amounts appropriated to carry out this paragraph and out of any money in the Treasury not otherwise appropriated), $50,000,000 for fiscal year 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d339bd5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087h/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “assistance” means the provision of technical support, training, materials, technical assistance, and financial assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d339bd6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087h/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d339bd7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087h/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide payments to loan servicers for retaining jobs at locations in the United States where such servicers were operating under part B on ","children":[{"tag":"date","attrib":{"date":"2010-01-01"},"text":"January 1, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d339bd8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087h/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated, and there are appropriated, to carry out this paragraph (in addition to any other amounts appropriated to carry out this paragraph and out of any money in the Treasury not otherwise appropriated), $25,000,000 for each of the fiscal years 2010 and 2011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d339bd9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087h/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may carry over funds made available under this section to a subsequent fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d339bda-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Account maintenance fees payable to guaranty agencies under subsection (a)(4) shall be calculated on the basis of 0.06 percent of the original principal amount of outstanding loans on which insurance was issued under part B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d339bdb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget justification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds may be expended under this section unless the Secretary includes in the Department of Education’s annual budget justification to Congress a detailed description of the specific activities for which the funds made available by this section have been used in the prior and current years (if applicable), the activities and costs planned for the budget year, and the projection of activities and costs for each remaining year for which administrative expenses under this section are made available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d339bdc-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s458"},"text":"Pub. L. 89–329, title IV, § 458","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s451"},"text":"Pub. L. 102–325, title IV, § 451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/573"},"text":"106 Stat. 573","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tIV/s4021"},"text":"Pub. L. 103–66, title IV, § 4021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/