,"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dH/tIII/s309"},"text":"Pub. L. 115–141, div. H, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/750"},"text":"132 Stat. 750","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/245/dB/tIII/s307"},"text":"Pub. L. 115–245, div. B, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3105"},"text":"132 Stat. 3105","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dA/tIII/s306"},"text":"Pub. L. 116–94, div. A, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2595"},"text":"133 Stat. 2595","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dH/tIII/s306"},"text":"Pub. L. 116–260, div. H, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1608"},"text":"134 Stat. 1608","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVIII/s82005"},"text":"Pub. L. 119–21, title VIII, § 82005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/349"},"text":"139 Stat. 349","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d339bdd-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d339bde-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d339bdf-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Paragraph (3), referred to in subsec. (a)(5), was redesignated par. (4) by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s2212/b/1/B"},"text":"Pub. L. 111–152, § 2212(b)(1)(B)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d339be0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" amended par. (1) generally. Prior to amendment, text read as follows: “For fiscal year 2006, there shall be available to the Secretary, from funds not otherwise appropriated, funds to be obligated for—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) administrative costs under this part and part B, including the costs of the direct student loan programs under this part; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) account maintenance fees payable to guaranty agencies under part B and calculated in accordance with subsections (b) and (c),","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"not to exceed (from such funds not otherwise appropriated) $820,000,000 in fiscal year 2006.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “2021” for “2020”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “2020” for “2019”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/245"},"text":"Pub. L. 115–245","children":[],"tail":" substituted “2019” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “2018” for “2017”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31"},"text":"Pub. L. 115–31","children":[],"tail":" substituted “2017” for “2016”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" substituted “2016” for “2014”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/67"},"text":"Pub. L. 113–67","children":[],"tail":" struck out par. (2). Text read as follows: “For fiscal years 2010 through 2019, there shall be available to the Secretary, in addition to any other amounts appropriated to carry out this paragraph and out of any money in the Treasury not otherwise appropriated, funds to be obligated for administrative costs of servicing contracts with eligible not-for-profit servicers as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087f"},"text":"section 1087f of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s2212/b/1"},"text":"Pub. L. 111–152, § 2212(b)(1)","children":[],"tail":", added pars. (2), (6), and (7) and redesignated former pars. (2), (3), (4), and (5) as (3), (4), (5), and (8), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s2212/b/2"},"text":"Pub. L. 111–152, § 2212(b)(2)","children":[],"tail":", substituted “subsection (a)(4)” for “subsection (a)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s452/1"},"text":"Pub. L. 110–315, § 452(1)","children":[],"tail":", substituted “2014” for “2011” in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s452/2"},"text":"Pub. L. 110–315, § 452(2)","children":[],"tail":", substituted “2014” for “2011”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/84"},"text":"Pub. L. 110–84","children":[],"tail":" substituted “0.06 percent” for “0.10 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171"},"text":"Pub. L. 109–171","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text consisted of subsecs. (a) to (d) relating to administrative expenses, calculation basis for account maintenance fees payable to guaranty agencies, special rules relating to caps on account maintenance fees and insufficient funding, and budget justification for funds expended, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/292"},"text":"Pub. L. 109–292","children":[],"tail":" substituted “shall be calculated on” for “shall not exceed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s454/1"},"text":"Pub. L. 105–244, § 454(1)","children":[],"tail":", amended heading and text of subsec. (a) generally. Prior to amendment, subsec. (a) related to availability of funds for administrative costs and cost allowances."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s454/2"},"text":"Pub. L. 105–244, § 454(2)","children":[],"tail":", amended heading and text of subsec. (b) generally. Prior to amendment, text read as follows: “Funds made available under subsection (a) of this section shall remain available until expended.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s454/5"},"text":"Pub. L. 105–244, § 454(5)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s454/4"},"text":"Pub. L. 105–244, § 454(4)","children":[],"tail":", redesignated subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s454/3"},"text":"Pub. L. 105–244, § 454(3)","children":[],"tail":", struck out heading and text of subsec. (d). Text read as follows: “In the event the Secretary finds it necessary to use the authority provided to the Secretary under subsection (a) of this section to draw funds for administrative expenses from a future year’s funds, no funds may be expended under this section unless the Secretary immediately notifies the Committees on Appropriations of the Senate and of the House of Representatives, and the Labor and Human Resources Committee of the Senate and the Education and Labor Committee of the House of Representatives, of such action and explain the reasons for such action.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" amended heading and text of subsec. (a) generally. Prior to amendment, text read as follows: “Each fiscal year, there shall be available to the Secretary of Education from funds available pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1072/g"},"text":"section 1072(g) of this title","children":[],"tail":" and from funds not otherwise appropriated, funds to be obligated for administrative costs under this part, including the costs of the transition from the loan programs under part B of this subchapter to the direct student loan programs under this part (including the costs of annually assessing the program under this part and the progress of the transition) and transition support (including administrative costs) for the expenses of guaranty agencies in servicing outstanding loans in their portfolios and in guaranteeing new loans, not to exceed (from such funds not otherwise appropriated) $260,000,000 in fiscal year 1994, $284,000,000 in fiscal year 1995, $550,000,000 in fiscal year 1996, $595,000,000 in fiscal year 1997, and $750,000,000 in fiscal year 1998. If in any fiscal year the Secretary determines that additional funds for administrative expenses are needed as a result of such transition or the expansion of the direct student loan programs under this part, the Secretary is authorized to use funds available under this section for a subsequent fiscal year for such expenses, except that the total expenditures by the Secretary (from such funds not otherwise appropriated) shall not exceed $2,439,000,000 in fiscal years 1994 through 1998. The Secretary is also authorized to carry over funds available under this section to a subsequent fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/78"},"text":"Pub. L. 105–78","children":[],"tail":" substituted “$507,000,000” for “$532,000,000” in closing provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/19"},"text":"Pub. L. 104–19","children":[],"tail":" substituted “$284,000,000 in fiscal year 1995” for “$345,000,000 in fiscal year 1995” and “$2,439,000,000 in fiscal years 1994 through 1998” for “$2,500,000,000 in fiscal years 1994 through 1998”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" amended section generally, substituting provisions relating to funds for administrative expenses for former provisions relating to reports."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d339be1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d339be2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/84"},"text":"Pub. L. 110–84","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2007-10-01"},"text":"Oct. 1, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/84/s1/c"},"text":"section 1(c) of Pub. L. 110–84","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"section 1070a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d339be3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171"},"text":"Pub. L. 109–171","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2006-07-01"},"text":"July 1, 2006","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8001/c"},"text":"section 8001(c) of Pub. L. 109–171","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d339be4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d339be5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/s2"},"text":"section 2 of Pub. L. 102–325","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0d339be6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/78/tVI/s609/m"},"text":"Pub. L. 105–78, title VI, § 609(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-13"},"text":"Nov. 13, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1524"},"text":"111 Stat. 1524","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/78/tVI/s609/m"},"text":"“Nothing in this Act [see Tables for classification] or an amendment made by this Act shall be construed to prohibit the Secretary of Education from using funds that are returned or otherwise recovered by the Secretary under section 422(g) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1072/g"},"text":"20 U.S.C. 1072(g)","children":[],"tail":") including the balances of returned reserve funds, formerly held by the Higher Education Assistance Foundation, that are currently held in Higher Education Assistance Foundation Claims Reserves, Treasury account number 91X6192, for expenditure for expenses pursuant to section 458 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087h"},"text":"20 U.S.C. 1087h","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0d339be7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Funds for Account Maintenance Fees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/dB/tIII/s306"},"text":"Pub. L. 119–75, div. B, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/305"},"text":"140 Stat. 305","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/75/dB/tIII/s306"},"text":"“Section 458(a)(4) of the HEA [Higher Education Act of 1965] (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087h/a"},"text":"20 U.S.C. 1087h(a)","children":[],"tail":"[4]) shall be applied by substituting ‘2027’ for ‘2021’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47/dD/tIII/s306"},"text":"Pub. L. 118–47, div. D, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-23"},"text":"Mar. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/692"},"text":"138 Stat. 692","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/4/dA/tIX/s1909"},"text":"Pub. L. 119–4, div. A, title IX, § 1909","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-03-15"},"text":"Mar. 15, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/33"},"text":"139 Stat. 33","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dH/tIII/s306"},"text":"Pub. L. 117–328, div. H, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4897"},"text":"136 Stat. 4897","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dH/tIII/s306"},"text":"Pub. L. 117–103, div. H, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/484"},"text":"136 Stat. 484","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0d339be8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Use of Funds for Administrative Expenses of William D. Ford Direct Loan Program Prohibited","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/e/tIII/s304"},"text":"Pub. L. 104–208, div. A, title I, § 101(e) [title III, § 304]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-233"},"text":"110 Stat. 3009–233","children":[],"tail":", 3009–261, provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/208/dA/tI/s101/e/tIII/s304"},"text":"“Notwithstanding section 458 of the Higher Education Act [of 1965] [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087h"},"text":"20 U.S.C. 1087h","children":[],"tail":"], the Secretary may not use funds available under that section or any other section for subsequent fiscal years for administrative expenses of the William D. Ford Direct Loan Program.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101/d/tIII/s305"},"text":"Pub. L. 104–134, title I, § 101(d) [title III, § 305]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-211"},"text":"110 Stat. 1321–211","children":[],"tail":", 1321–236; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
