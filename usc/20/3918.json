{"tag":"section","attrib":{"id":"id0de18ee7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3918"},"text":null,"children":[{"tag":"num","attrib":{"value":"3918"},"text":"§ 3918.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Foundation shall adopt approval procedures designed to assure that awards are made on the basis of the scientific and educational merit as determined by the peer review process. To the maximum extent possible, the Foundation shall assure that there is an equitable distribution of resources with respect to institutions and geographical areas.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0de18ee8-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tI/s108"},"text":"Pub. L. 98–377, title I, § 108","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tII/s201"},"text":"Pub. L. 99–159, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/896"},"text":"99 Stat. 896","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
