{"tag":"section","attrib":{"id":"id0dfbcd79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5983"},"text":null,"children":[{"tag":"num","attrib":{"value":"5983"},"text":"§ 5983.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dfbcd7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5983/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dfbcd7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5983/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make grants to eligible entities for the development and implementation of seminars in American government and civics for elementary and secondary school teachers and other educators who work with minority and Native American students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dfbcd7c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5983/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this subchapter, the Secretary shall ensure that there is wide geographic distribution of such grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dfbcd7d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5983/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $5,000,000 for fiscal 1995, and such sums as may be necessary for each of the fiscal years 1996, 1997, and 1998, to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dfbcd7e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227/tVIII/s803"},"text":"Pub. L. 103–227, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/210"},"text":"108 Stat. 210","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
