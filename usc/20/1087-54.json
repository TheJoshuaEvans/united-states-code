{"tag":"section","attrib":{"id":"id0d29ff47-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087–54"},"text":null,"children":[{"tag":"num","attrib":{"value":"1087–54"},"text":"§ 1087–54.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sources of matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall be construed as restricting the source (other than this part) from which the institution may pay its share of the compensation of a student employed under a work-study program covered by an agreement under this part, and such share may be paid to such student in the form of services and equipment (including tuition, room, board, and books) furnished by such institution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d29ff48-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s444"},"text":"Pub. L. 89–329, title IV, § 444","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s403/a"},"text":"Pub. L. 99–498, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1435"},"text":"100 Stat. 1435","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d29ff49-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d29ff4a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d29ff4b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","chi