{"tag":"section","attrib":{"id":"id0df7126a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b"},"text":null,"children":[{"tag":"num","attrib":{"value":"5607b"},"text":"§ 5607b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of the National Center by Federal agency or other entity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0df7126b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal agency may use the Foundation and the National Center to provide assessment, mediation, collaboration, or other related services in connection with a dispute or conflict related to the environment, public lands, or natural resources, or with a Federal, State, or tribal process or procedure that may result in a dispute or conflict.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df7126c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df7126d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal agency may enter into a contract and expend funds to obtain the services of the National Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df7126e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment into Environmental Dispute Resolution Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A payment from an executive agency on a contract entered into under paragraph (1) shall be paid into the Environmental Dispute Resolution Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5607a"},"text":"section 5607a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df7126f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification and concurrence","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df71270-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An agency or instrumentality of the Federal Government shall notify the chairperson of the President’s Council on Environmental Quality when using the Foundation or the National Center to provide the services described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df71271-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification descriptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a matter involving two or more agencies or instrumentalities of the Federal Government, notification under paragraph (1) shall include a written description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0df71272-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issues and parties involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df71273-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior efforts, if any, undertaken by the agency to resolve or address the issue or issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df71274-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all Federal agencies or instrumentalities with a direct interest or involvement in the matter and a statement that all Federal agencies or instrumentalities agree to mediation, collaboration, and dispute resolution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df71275-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df71276-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concurrence","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0df71277-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In a matter that involves two or more agencies or instrumentalities of the Federal Government (including branches or divisions of a single agency or instrumentality), the agencies or instrumentalities of the Federal Government shall obtain the concurrence of the chairperson of the President’s Council on Environmental Quality before using the Foundation or National Center to provide the services described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df71278-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indication of concurrence or nonconcurrence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chairperson of the President’s Council on Environmental Quality shall indicate concurrence or nonconcurrence under subparagraph (A) not later than 20 days after receiving notice under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df71279-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df7127a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal issues and enforcement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0df7127b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A dispute or conflict involving agencies or instrumentalities of the Federal Government (including branches or divisions of a single agency or instrumentality) that concern purely legal issues or matters, interpretation or determination of law, or enforcement of law by one agency against another agency shall not be submitted to the Foundation or National Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df7127c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) does not apply to a dispute or conflict concerning—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0df7127d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agency implementation of a program or project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0df7127e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a matter involving two or more agencies with parallel authority requiring facilitation and coordination of the various Government agencies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0df7127f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonlegal policy or decisionmaking matter that involves two or more agencies that are jointly operating a project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df71280-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other mandated mechanisms or avenues","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A dispute or conflict involving agencies or instrumentalities of the Federal Government (including branches or divisions of a single agency or instrumentality) for which Congress by law has mandated another dispute resolution mechanism or avenue to address or resolve shall not be submitted to the Foundation or National Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df71281-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df71282-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Non-Federal entities, including state ","children":[{"tag":"ref","attrib":{"idref":"fn002189"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002189"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" and local governments, Native American tribal governments, nongovernmental organizations and persons, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t1/s1"},"text":"section 1 of title 1","children":[],"tail":", may use the Foundation and the National Center to provide assessment, mediation, or other related services in connection with a dispute or conflict involving the Federal government "},{"tag":"ref","attrib":{"idref":"fn002189"},"text":"1","children":[],"tail":" related to the environment, public lands, or natural resources."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df71283-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment into the environmental dispute resolution fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Entities utilizing services pursuant to this subsection shall reimburse the National Center for the costs of services provided. Such amounts shall be deposited into the Environmental Dispute Resolution Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5607a"},"text":"section 5607a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df71284-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency management or control","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Use of the Foundation or National Center to provide independent and impartial assessment, mediation, or other dispute or conflict resolution under this section shall not be considered to be the establishment or use of an advisory committee within the meaning of chapter 10 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0df71285-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/259/s11"},"text":"Pub. L. 102–259, § 11","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/156/s7"},"text":"Pub. L. 105–156, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-02-11"},"text":"Feb. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/10"},"text":"112 Stat. 10","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/h/tV/s517/a"},"text":"Pub. L. 105–277, div. A, § 101(h) [title V, § 517(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-480"},"text":"112 Stat. 2681–480","children":[],"tail":", 2681–512; "},{"tag":"ref","attrib":{"href":"/us/pl/111/90/s9"},"text":"Pub. L. 111–90, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-03"},"text":"Nov. 3, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2978"},"text":"123 Stat. 2978","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tIII/s307"},"text":"Pub. L. 116–94, div. P, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3190"},"text":"133 Stat. 3190","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/151"},"text":"Pub. L. 117–286, § 4(a)(151)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4322"},"text":"136 Stat. 4322","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0df71286-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0df71287-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0df71288-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/259/s11"},"text":"section 11 of Pub. L. 102–259","children":[],"tail":" was renumbered section 13 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s5609"},"text":"section 5609 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0df71289-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5.” for “the Federal Advisory Committee Act (5 U.S.C. App.).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s307/1"},"text":"Pub. L. 116–94, § 307(1)","children":[],"tail":", substituted “the National Center” for “the Institute” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s307/2"},"text":"Pub. L. 116–94, § 307(2)","children":[],"tail":", substituted “National Center” for “Institute” and “resources, or with a Federal, State, or tribal process or procedure that may result in a dispute or conflict.” for “resources.” and inserted “collaboration,” after “mediation,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s307/3"},"text":"Pub. L. 116–94, § 307(3)","children":[],"tail":", substituted “National Center” for “Institute”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s307/4/A"},"text":"Pub. L. 116–94, § 307(4)(A)","children":[],"tail":", substituted “National Center” for “Institute”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s307/4/B"},"text":"Pub. L. 116–94, § 307(4)(B)","children":[],"tail":", inserted “mediation, collaboration, and” after “agree to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s307/4/C"},"text":"Pub. L. 116–94, § 307(4)(C)","children":[],"tail":", substituted “National Center” for “Institute”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s307/5"},"text":"Pub. L. 116–94, § 307(5)","children":[],"tail":", substituted “National Center” for “Institute”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s307/6"},"text":"Pub. L. 116–94, § 307(6)","children":[],"tail":", substituted “National Center” for “Institute” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s307/7"},"text":"Pub. L. 116–94, § 307(7)","children":[],"tail":", substituted “National Center” for “Institute”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/90"},"text":"Pub. L. 111–90","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/h/tV/s517/a/1"},"text":"Pub. L. 105–277, § 101(h) [title V, § 517(a)(1)]","children":[],"tail":", inserted “or other entity” after “Federal agency” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/h/tV/s517/a/2"},"text":"Pub. L. 105–277, § 101(h) [title V, § 517(a)(2)]","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
