:"Pub. L. 94–482, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2091"},"text":"90 Stat. 2091","children":[],"tail":", related to eligibility for special assistance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1053, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s303"},"text":"Pub. L. 89–329, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1230"},"text":"79 Stat. 1230","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/230/tIV/s401/h/4"},"text":"Pub. L. 91–230, title IV, § 401(h)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/174"},"text":"84 Stat. 174","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tI/s121/a"},"text":"Pub. L. 92–318, title I, § 121(a)","children":[],"tail":", title III, § 301(a)(1), "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/242"},"text":"86 Stat. 242","children":[],"tail":", 326, provided for the establishment of an Advisory Council on Developing Institutions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1054, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s304"},"text":"Pub. L. 89–329, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1230"},"text":"79 Stat. 1230","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tI/s121/a"},"text":"Pub. L. 92–318, title I, § 121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/243"},"text":"86 Stat. 243","children":[],"tail":", authorized the Commissioner of Education to make grants and awards."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1055, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s305"},"text":"Pub. L. 89–329, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1231"},"text":"79 Stat. 1231","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tI/s121/a"},"text":"Pub. L. 92–318, title I, § 121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/244"},"text":"86 Stat. 244","children":[],"tail":", related to assistance to developing institutions under other programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1056, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s306"},"text":"Pub. L. 89–329, title III, § 306","children":[],"tail":", as added Pub L. 90–575, title II, § 223(a), "},{"tag":"date","attrib":{"date":"1968-10-16"},"text":"Oct. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1038"},"text":"82 Stat. 1038","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tI/s121/a"},"text":"Pub. L. 92–318, title I, § 121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/245"},"text":"86 Stat. 245","children":[],"tail":", prohibited the use of funds for religious activities."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cd1cc4f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Pars. (3) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" added par. (3) and redesignated former pars. (3) to (7) as (4) to (8), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" struck out the comma after “planning”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s301/1"},"text":"Pub. L. 102–325, § 301(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “many institutions of higher education in this era of declining enrollments and scarce resources face problems which threaten their ability to survive;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s301/2"},"text":"Pub. L. 102–325, § 301(2)","children":[],"tail":", struck out “recruitment activities,” after “long-range planning,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s301/3"},"text":"Pub. L. 102–325, § 301(3)","children":[],"tail":", amended par. (5) generally. Prior to amendment, par. (5) read as follows: “providing a minimum level of assistance to all categories of eligible institutions will assure the continued participation of the institutions in the program established in this subchapter and enhance their role in providing access and quality education to low-income and minority students;”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cd1cc50-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","at