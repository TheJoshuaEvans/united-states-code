:{},"text":"Except as otherwise provided therein or in subsection (b) of this section, the amendments made by section 2 of this Act [see Tables for classification] shall be effective as if such amendments were included in the Higher Education Amendments of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Public Law 102–325","children":[],"tail":"), except that section 492 of the Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1098a"},"text":"section 1098a of this title","children":[],"tail":"] shall not apply to the amendments made by this Act [see Tables for classification]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective on October","children":[],"tail":" 1, 1993.—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by the following subsections of section 2 of this Act shall be effective on and after ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":": (b)(29), (j)(28), (j)(36), and (j)(40) [amending sections 1070d–34, 1134e, 1134j, and 1134q of this title]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective on date of enactment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by the following subsections of section 2 of this 