{"tag":"section","attrib":{"id":"id0de8bb86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4359a"},"text":"§ 4359a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International students","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de8bb87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de8bb88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), effective with new admissions for academic year 1993–1994 and each succeeding academic year, the University (including undergraduate and graduate students) and NTID shall limit the enrollment of international students to approximately 15 percent of the total postsecondary student population enrolled respectively at the University or NTID, except that in any school year no United States citizen who is qualified to be admitted to the University or NTID and applies for admission to the University or NTID shall be denied admission because of the admission of an international student.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de8bb89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distance learning","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"International students who participate in distance learning courses that are at the University or the NTID, who are residing outside of the United States, and are not enrolled in a degree program at the University or the NTID shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de8bb8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be counted as international students for purposes of the cap on international students under paragraph (1), except that in any school year no United States citizen who applies to participate in distance learning courses that are at the University or NTID shall be denied participation in such courses because of the participation of an international student in such courses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de8bb8b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be charged a tuition surcharge, as described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de8bb8c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tuition surcharge","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsections (a)(2)(B) and (c), the tuition for postsecondary international students enrolled in the University (including undergraduate and graduate students) or NTID shall include, for academic year 2009–2010 and any succeeding academic year, a surcharge of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de8bb8d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent for a postsecondary international student from a non-developing country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de8bb8e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent for a postsecondary international student from a developing country, or a country that was a developing country for any academic year during the student’s period of uninterrupted enrollment in a degree program at the University or NTID, except that such a surcharge shall not be adjusted retroactively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de8bb8f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of surcharge","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de8bb90-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning with the academic year 2009–2010, the University or NTID may reduce the surcharge—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de8bb91-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under subsection (b)(1) from 100 percent to not less than 50 percent if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0de8bb92-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a student described under subsection (b)(1) demonstrates need; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de8bb93-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such student has made a good-faith effort to secure aid through such student’s government or other sources; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de8bb94-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under subsection (b)(2) from 50 percent to not less than 25 percent if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0de8bb95-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a student described under subsection (b)(2) demonstrates need; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de8bb96-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such student has made a good faith effort to secure aid through such student’s government or other sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de8bb97-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of sliding scale","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The University and NTID shall develop a sliding scale model that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de8bb98-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be used to determine the amount of a tuition surcharge reduction pursuant to paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de8bb99-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de8bb9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4359a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “developing country” means a country with a per-capita income of not more than $5,345, measured in 2005 United States dollars, as adjusted by the Secretary to reflect inflation since 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de8bb9b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/371/tII/s209"},"text":"Pub. L. 99–371, title II, § 209","children":[],"tail":", formerly § 210, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/421/tI/s139"},"text":"Pub. L. 102–421, title I, § 139","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2163"},"text":"106 Stat. 2163","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/73/tII/s204/h"},"text":"Pub. L. 103–73, title II, § 204(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/735"},"text":"107 Stat. 735","children":[],"tail":"; renumbered § 209 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s922"},"text":"Pub. L. 105–244, title IX, § 922","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1832"},"text":"112 Stat. 1832","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s911"},"text":"Pub. L. 110–315, title IX, § 911","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3454"},"text":"122 Stat. 3454","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de8bb9c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de8bb9d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0de8bb9e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/371/s209"},"text":"section 209 of Pub. L. 99–371","children":[],"tail":" was renumbered section 208 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4359"},"text":"section 4359 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0de8bb9f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s911/1"},"text":"Pub. L. 110–315, § 911(1)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, substituted “Except as provided in paragraph (2), effective with” for “Effective with” and “undergraduate” for “preparatory, undergraduate,”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s911/2"},"text":"Pub. L. 110–315, § 911(2)","children":[],"tail":", added subsecs. (b) to (d) and struck out former subsecs. (b) to (d), which related to tuition surcharge, reduction of surcharge, and definition of “developing country”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s922/a/1"},"text":"Pub. L. 105–244, § 922(a)(1)","children":[],"tail":", substituted “15 percent” for “10 percent” and inserted before period “, except that in any school year no United States citizen who is qualified to be admitted to the University or NTID and applies for admission to the University or NTID shall be denied admission because of the admission of an international student”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s922/a/2"},"text":"Pub. L. 105–244, § 922(a)(2)","children":[],"tail":", substituted “surcharge of 100 percent for the academic year 1999–2000 and any succeeding academic year” for “surcharge of 75 percent for the academic year 1993–1994 and 90 percent beginning with the academic year 1994–1995”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/73/s204/h/1"},"text":"Pub. L. 103–73, § 204(h)(1)","children":[],"tail":", substituted “75 percent for the academic year 1993–1994 and 90 percent beginning with the academic year 1994–1995” for “75 percent beginning the academic year 1993–1994, and 90 percent beginning the academic year 1994–1995”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/73/s204/h/2"},"text":"Pub. L. 103–73, § 204(h)(2)","children":[],"tail":", substituted “Beginning with the academic year 1993–1994” for “Beginning the academic year 1993–1994 and thereafter” in introductory provisions and redesignated subpars. (A) to (C) as pars. (1) to (3), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0de8bba0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0de8bba1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0de8bba2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/421/s161"},"text":"section 161 of Pub. L. 102–421","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
