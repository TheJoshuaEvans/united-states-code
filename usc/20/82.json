{"tag":"section","attrib":{"id":"id0c8cadd4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s82"},"text":null,"children":[{"tag":"num","attrib":{"value":"82"},"text":"§ 82.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aid in acquisition of collections","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The heads of executive departments of the Government are authorized and directed to cause to be rendered all necessary and practicable aid to the said Regents in the acquisition of collections for the Zoological Park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c8cadd5-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-04-30/ch173/s3"},"text":"Apr. 30, 1890, ch. 173, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/78"},"text":"26 Stat. 78","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
