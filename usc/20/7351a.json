":null},{"tag":"content","attrib":{},"text":" Activities authorized under part A of subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3505bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7351a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Parental involvement activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3505be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7351a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State educational agency receiving a grant under this subpart may not use more than 5 percent of the amount of the grant for State administrative costs and to provide technical assistance to eligible local educational agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e3505bf-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5222"},"text":"Pub. L. 89–10, title V, § 5222","children":[],"tail":", formerly title VI, § 6222, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVI/s601"},"text":"Pub. L. 107–110, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1895"},"text":"115 Stat. 1895","children":[],"tail":"; renumbered title V, § 5222, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tV"},"text":"Pub. L. 114–95, title V","children":[],"tail":", §§ 5001(a)(4), 5003(5), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", 