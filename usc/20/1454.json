":{},"text":"Subsec. (a)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9215/ss/8/A/ii"},"text":"Pub. L. 114–95, § 9215(ss)(8)(A)(ii)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9214/d/4/B/i"},"text":"Pub. L. 114–95, § 9214(d)(4)(B)(i)","children":[],"tail":", substituted “certification of special education teachers for individuals with a baccalaureate or master’s degree who meet the qualifications described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1412/a/14/C"},"text":"section 1412(a)(14)(C) of this title","children":[],"tail":"” for “certification of special education teachers for highly qualified individuals with a baccalaureate or master’s degree”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9214/d/4/B/ii"},"text":"Pub. L. 114–95, § 9214(d)(4)(B)(ii)","children":[],"tail":", substituted “special education teachers who meet the qualifications described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1412/a/14/C"},"text":"section 1412(a)(14)(C) of this title","children":[],"tail":"” for “highly qualified special education teachers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9215/ss/8/B"},"text":"Pub. L. 114–95, § 9215(ss)(8)(B)","children":[],"tail":", inserted “(as such section was in effect on the day before "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":")” after “of this title”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dad3973-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0dad3974-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
