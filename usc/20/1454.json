 6613 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/134"},"text":"Public Law 95–134","children":[],"tail":", referred to in subsec. (e), is "},{"tag":"ref","attrib":{"href":"/us/pl/95/134"},"text":"Pub. L. 95–134","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-15"},"text":"Oct. 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1159"},"text":"91 Stat. 1159","children":[],"tail":". Provisions relating to consolidation of grants to the outlying areas are contained in "},{"tag":"ref","attrib":{"href":"/us/pl/95/134/s501"},"text":"section 501 of Pub. L. 95–134","children":[],"tail":" which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1469a"},"text":"section 1469a of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0dad3971-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1454, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s654"},"text":"Pub. L. 91–230, title VI, § 654","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tI/s101"},"text":"Pub. L. 105–17, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June 4, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/128"},"text":"111 Stat. 128","children":[],"tail":", related to use of funds, prior to the general amendment of subchapters I to IV of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/108/446"},"text":"Pub. L. 108–446","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1454, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s653"},"tex