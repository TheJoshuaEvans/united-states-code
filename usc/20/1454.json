{"tag":"section","attrib":{"id":"id0dad392e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454"},"text":null,"children":[{"tag":"num","attrib":{"value":"1454"},"text":"§ 1454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dad392f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional development activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State educational agency that receives a grant under this part shall use the grant funds to support activities in accordance with the State’s plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1453"},"text":"section 1453 of this title","children":[],"tail":", including 1 or more of the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dad3930-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Carrying out programs that provide support to both special education and regular education teachers of children with disabilities and principals, such as programs that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad3931-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide teacher mentoring, team teaching, reduced class schedules and case loads, and intensive professional development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3932-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use standards or assessments for guiding beginning teachers that are consistent with challenging State academic achievement standards and with the requirements for professional development, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3933-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage collaborative and consultative models of providing early intervention, special education, and related services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3934-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Encouraging and supporting the training of special education and regular education teachers and administrators to effectively use and integrate technology—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad3935-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" into curricula and instruction, including training to improve the ability to collect, manage, and analyze data to improve teaching, decisionmaking, school improvement efforts, and accountability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3936-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance learning by children with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3937-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to effectively communicate with parents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3938-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Providing professional development activities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad3939-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improve the knowledge of special education and regular education teachers concerning—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0dad393a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the academic and developmental or functional needs of students with disabilities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dad393b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective instructional strategies, methods, and skills, and the use of State academic content standards and student academic achievement and functional standards, and State assessments, to improve teaching practices and student academic achievement;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad393c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improve the knowledge of special education and regular education teachers and principals and, in appropriate cases, paraprofessionals, concerning effective instructional practices, and that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0dad393d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training in how to teach and address the needs of children with different learning styles and children who are limited English proficient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dad393e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve collaborative groups of teachers, administrators, and, in appropriate cases, related services personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dad393f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide training in methods of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0dad3940-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" positive behavioral interventions and supports to improve student behavior in the classroom;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0dad3941-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientifically based reading instruction, including early literacy instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0dad3942-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early and appropriate interventions to identify and help children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0dad3943-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/B/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective instruction for children with low incidence disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0dad3944-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/B/iii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successful transitioning to postsecondary opportunities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0dad3945-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/B/iii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using classroom-based techniques to assist children prior to referral for special education;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dad3946-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training to enable personnel to work with and involve parents in their child’s education, including parents of low income and limited English proficient children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dad3947-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training for special education personnel and regular education personnel in planning, developing, and implementing effective and appropriate IEPs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dad3948-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training to meet the needs of students with significant health, mobility, or behavioral needs prior to serving such students;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3949-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train administrators, principals, and other relevant school personnel in conducting effective IEP meetings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad394a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train early intervention, preschool, and related services providers, and other relevant school personnel, in conducting effective individualized family service plan (IFSP) meetings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad394b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Developing and implementing initiatives to promote the recruitment and retention of special education teachers who meet the qualifications described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1412/a/14/C"},"text":"section 1412(a)(14)(C) of this title","children":[],"tail":", particularly initiatives that have been proven effective in recruiting and retaining teachers, including programs that provide—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad394c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teacher mentoring from exemplary special education teachers, principals, or superintendents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad394d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" induction and support for special education teachers during their first 3 years of employment as teachers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad394e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incentives, including financial incentives, to retain special education teachers who have a record of success in helping students with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad394f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Carrying out programs and activities that are designed to improve the quality of personnel who serve children with disabilities, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad3950-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative professional development programs (which may be provided through partnerships that include institutions of higher education), including programs that train teachers and principals to integrate technology into curricula and instruction to improve teaching, learning, and technology literacy, which professional development shall be consistent with the definition of professional development in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3951-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and use of proven, cost effective strategies for the implementation of professional development activities, such as through the use of technology and distance learning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3952-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Carrying out programs and activities that are designed to improve the quality of early intervention personnel, including paraprofessionals and primary referral sources, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad3953-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional development programs to improve the delivery of early intervention services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3954-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiatives to promote the recruitment and retention of early intervention personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad3955-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interagency activities to ensure that early intervention personnel are adequately prepared and trained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dad3956-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State educational agency that receives a grant under this part shall use the grant funds to support activities in accordance with the State’s plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1453"},"text":"section 1453 of this title","children":[],"tail":", including 1 or more of the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dad3957-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Reforming special education and regular education teacher certification (including recertification) or licensing requirements to ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dad3958-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" special education and regular education teachers have—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0dad3959-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training and information necessary to address the full range of needs of children with disabilities across disability categories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dad395a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the necessary subject matter knowledge and teaching skills in the academic subjects that the teachers teach;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad395b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special education and regular education teacher certification (including recertification) or licensing requirements are aligned with challenging State academic content standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dad395c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special education and regular education teachers have the subject matter knowledge and teaching skills, including technology literacy, necessary to help students with disabilities meet challenging State student academic achievement and functional standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad395d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs that establish, expand, or improve alternative routes for State certification of special education teachers for individuals with a baccalaureate or master’s degree who meet the qualifications described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1412/a/14/C"},"text":"section 1412(a)(14)(C) of this title","children":[],"tail":", including mid-career professionals from other occupations, paraprofessionals, and recent college or university graduates with records of academic distinction who demonstrate the potential to become highly effective special education teachers."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad395e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Teacher advancement initiatives for special education teachers that promote professional growth and emphasize multiple career paths (such as paths to becoming a career teacher, mentor teacher, or exemplary teacher) and pay differentiation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad395f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing and implementing mechanisms to assist local educational agencies and schools in effectively recruiting and retaining special education teachers who meet the qualifications described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1412/a/14/C"},"text":"section 1412(a)(14)(C) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3960-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reforming tenure systems, implementing teacher testing for subject matter knowledge, and implementing teacher testing for State certification or licensing, consistent with title II of the Higher Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1021"},"text":"20 U.S.C. 1021","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3961-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funding projects to promote reciprocity of teacher certification or licensing between or among States for special education teachers, except that no reciprocity agreement developed under this paragraph or developed using funds provided under this part may lead to the weakening of any State teaching certification or licensing requirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3962-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assisting local educational agencies to serve children with disabilities through the development and use of proven, innovative strategies to deliver intensive professional development programs that are both cost effective and easily accessible, such as strategies that involve delivery through the use of technology, peer networks, and distance learning.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3963-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing, or assisting local educational agencies in developing, merit based performance systems, and strategies that provide differential and bonus pay for special education teachers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3964-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supporting activities that ensure that teachers are able to use challenging State academic content standards and student academic achievement and functional standards, and State assessments for all children with disabilities, to improve instructional practices and improve the academic achievement of children with disabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3965-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When applicable, coordinating with, and expanding centers established under, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6613/c/18"},"text":"section 6613(c)(18) of this title","children":[],"tail":" (as such section was in effect on the day before "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":") to benefit special education teachers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dad3966-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and subgrants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State educational agency that receives a grant under this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dad3967-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall award contracts or subgrants to local educational agencies, institutions of higher education, parent training and information centers, or community parent resource centers, as appropriate, to carry out its State plan under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad3968-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may award contracts and subgrants to other public and private entities, including the lead agency under subchapter III, to carry out the State plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dad3969-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds for professional development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State educational agency that receives a grant under this part shall use—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dad396a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 90 percent of the funds the State educational agency receives under the grant for any fiscal year for activities under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dad396b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 10 percent of the funds the State educational agency receives under the grant for any fiscal year for activities under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dad396c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1454/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to outlying areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/134"},"text":"Public Law 95–134","children":[],"tail":", permitting the consolidation of grants to the outlying areas, shall not apply to funds received under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dad396d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s654"},"text":"Pub. L. 91–230, title VI, § 654","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2770"},"text":"118 Stat. 2770","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX"},"text":"Pub. L. 114–95, title IX","children":[],"tail":", §§ 9214(d)(4)(A), (B), 9215(ss)(8), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2165"},"text":"129 Stat. 2165","children":[],"tail":", 2183.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dad396e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dad396f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0dad3970-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"Section 7801 of this title","children":[],"tail":", refer