{"tag":"section","attrib":{"id":"id0e26d67d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174"},"text":null,"children":[{"tag":"num","attrib":{"value":"7174"},"text":"§ 7174.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local competitive subgrant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e26d67e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e26d67f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community learning centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives funds under this part for a fiscal year shall provide the amount made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7172/c/1"},"text":"section 7172(c)(1) of this title","children":[],"tail":" to award subgrants to eligible entities for community learning centers in accordance with this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d680-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanded learning program activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State that receives funds under this part for a fiscal year may use funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7172/c/1"},"text":"section 7172(c)(1) of this title","children":[],"tail":" to support those enrichment and engaging academic activities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7175/a"},"text":"section 7175(a) of this title","children":[],"tail":" that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d681-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are included as part of an expanded learning program that provides students at least 300 additional program hours before, during, or after the traditional school day;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d682-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplement but do not supplant regular school day requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d683-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are carried out by entities that meet the requirements of subsection (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d684-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e26d685-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a subgrant under this part, an eligible entity shall submit an application to the State educational agency at such time, in such manner, and including such information as the State educational agency may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d686-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d687-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the activities to be funded, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e26d688-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the program will take place in a safe and easily accessible facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e26d689-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how students participating in the program carried out by the community learning center will travel safely to and from the center and home, if applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e26d68a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the eligible entity will disseminate information about the community learning center (including its location) to the community in a manner that is understandable and accessible;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d68b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how such activities are expected to improve student academic achievement as well as overall student success;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d68c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a demonstration of how the proposed program will coordinate Federal, State, and local programs and make the most effective use of public resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d68d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assurance that the proposed program was developed and will be carried out—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e26d68e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in active collaboration with the schools that participating students attend (including through the sharing of relevant data among the schools), all participants of the eligible entity, and any partnership entities described in subparagraph (H), in compliance with applicable laws relating to privacy and confidentiality; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e26d68f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in alignment with the challenging State academic standards and any local academic standards;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d690-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the activities will meet the measures of effectiveness described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7175/b"},"text":"section 7175(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d691-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the program will target students who primarily attend schools eligible for schoolwide programs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6314"},"text":"section 6314 of this title","children":[],"tail":" and the families of such students;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d692-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that subgrant funds under this part will be used to increase the level of State, local, and other non-Federal funds that would, in the absence of funds under this part, be made available for programs and activities authorized under this part, and in no case supplant Federal, State, local, or non-Federal funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d693-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the partnership between a local educational agency, a community-based organization, and another public entity or private entity, if appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d694-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the community needs and available resources for the community learning center, and a description of how the program proposed to be carried out in the center will address those needs (including the needs of working families);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d695-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a demonstration that the eligible entity will use best practices, including research or evidence-based practices, to provide educational and related activities that will complement and enhance academic performance, achievement, postsecondary and workforce preparation, and positive youth development of the students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d696-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of a preliminary plan for how the community learning center will continue after funding under this part ends;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d697-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the community will be given notice of an intent to submit an application and that the application and any waiver request will be available for public review after submission of the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d698-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the eligible entity plans to use volunteers in activities carried out through the community learning center, a description of how the eligible entity will encourage and use appropriately qualified persons to serve as the volunteers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d699-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/b/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information and assurances as the State educational agency may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d69a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of certain applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State educational agency may approve an application under this part for a program to be located in a facility other than an elementary school or secondary school only if the program will be at least as available and accessible to the students to be served as if the program were located in an elementary school or secondary school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d69b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissive local match","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e26d69c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State educational agency may require an eligible entity to match subgrant funds awarded under this part, except that such match may not exceed the amount of the subgrant and may not be derived from other Federal or State funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d69d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sliding scale","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a match under paragraph (1) shall be established based on a sliding scale that takes into account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d69e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative poverty of the population to be targeted by the eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d69f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the eligible entity to obtain such matching funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d6a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In-kind contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State educational agency that requires an eligible entity to match funds under this subsection shall permit the eligible entity to provide all or any portion of such match in the form of in-kind contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d6a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding this subsection, a State educational agency shall not consider an eligible entity’s ability to match funds when determining which eligible entities will receive subgrants under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d6a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In reviewing local applications under this part, a State educational agency shall use a rigorous peer-review process or other methods to ensure the quality of funded projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d6a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic diversity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, a State educational agency shall distribute subgrant funds under this part equitably among geographic areas within the State, including urban and rural communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d6a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A subgrant awarded under this part shall be awarded for a period of not less than 3 years and not more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d6a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A subgrant awarded under this part may not be made in an amount that is less than $50,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d6a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e26d6a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding subgrants under this part, a State educational agency shall give priority to applications—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e26d6a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" proposing to target services to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e26d6a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/i/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" students who primarily attend schools that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e26d6aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/i/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are implementing comprehensive support and improvement activities or targeted support and improvement activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d"},"text":"section 6311(d) of this title","children":[],"tail":" or other schools determined by the local educational agency to be in need of intervention and support to improve student academic achievement and other outcomes; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e26d6ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/i/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enroll students who may be at risk for academic failure, dropping out of school, involvement in criminal or delinquent activities, or who lack strong positive role models; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e26d6ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/i/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the families of students described in clause (i);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d6ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submitted jointly by eligible entities consisting of not less than 1—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e26d6ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/i/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local educational agency receiving funds under part A of subchapter I; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e26d6af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/i/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e26d6b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demonstrating that the activities proposed in the application—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e26d6b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/i/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are, as of the date of the submission of the application, not accessible to students who would be served; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e26d6b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/i/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would expand accessibility to high-quality services that may be available in the community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d6b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State educational agency shall provide the same priority under paragraph (1) to an application submitted by a local educational agency if the local educational agency demonstrates that it is unable to partner with a community-based organization in reasonable geographic proximity and of sufficient quality to meet the requirements of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e26d6b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State educational agency may not give a priority or a preference to eligible entities that seek to use funds made available under this part to extend the regular school day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e26d6b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7174/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewability of awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State educational agency may renew a subgrant provided under this part to an eligible entity, based on the eligible entity’s performance during the preceding subgrant period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e26d6b6-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4204"},"text":"Pub. L. 89–10, title IV, § 4204","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIV/s401"},"text":"Pub. L. 107–110, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1769"},"text":"115 Stat. 1769","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4201/a"},"text":"Pub. L. 114–95, title IV, § 4201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1988"},"text":"129 Stat. 1988","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e26d6b7-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e26d6b8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e26d6b9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" amended section generally. Prior to amendment, section related to local competitive grant program, consisting of subsecs. (a) to (i)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e26d6ba-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e26d6bb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
