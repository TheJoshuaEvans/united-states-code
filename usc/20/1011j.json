{"tag":"section","attrib":{"id":"id0cbeba16-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1011j"},"text":"§ 1011j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior rights and obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cbeba17-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cbeba18-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pre-1987 parts C and D of subchapter VII","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for fiscal year 2009 and for each succeeding fiscal year to pay obligations incurred prior to 1987 under parts C and D of subchapter VII, as such parts were in effect before the effective date of the Higher Education Amendments of 1992.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeba19-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-1992 and pre-1998 part C of subchapter VII","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for fiscal year 2009 and for each succeeding fiscal year to pay obligations incurred prior to ","children":[{"tag":"date","attrib":{"date":"1998-10-07"},"text":"October 7, 1998","children":[],"tail":", under part C of subchapter VII, as such part was in effect during the period—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cbeba1a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011j/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the effective date of the Higher Education Amendments of 1992; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbeba1b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011j/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to ","children":[{"tag":"date","attrib":{"date":"1998-10-07"},"text":"October 7, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cbeba1c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal responsibilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cbeba1d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pre-1987 subchapter VII","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All entities with continuing obligations incurred under parts A, B, C, and D of subchapter VII, as such parts were in effect before the effective date of the Higher Education Amendments of 1992, shall be subject to the requirements of such part as in effect before the effective date of the Higher Education Amendments of 1992.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeba1e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-1992 and pre-1998 part C of subchapter VII","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All entities with continuing obligations incurred under part C of subchapter VII, as such part was in effect during the period—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cbeba1f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011j/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the effective date of the Higher Education Amendments of 1992; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cbeba20-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011j/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to ","children":[{"tag":"date","attrib":{"date":"1998-10-07"},"text":"October 7, 1998","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be subject to the requirements of such part as such part was in effect during such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cbeba21-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s121"},"text":"Pub. L. 89–329, title I, § 121","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tI/s101/a"},"text":"Pub. L. 105–244, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1601"},"text":"112 Stat. 1601","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tI/s108"},"text":"Pub. L. 110–315, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3094"},"text":"122 Stat. 3094","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cbeba22-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cbeba23-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0cbeba24-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Parts A, B, C, and D of subchapter VII, as such parts were in effect before the effective date of the Higher Education Amendments of 1992, referred to in subsecs. (a)(1) and (b)(1), means parts A (§ 1132b et seq.), B (§ 1132c et seq.), C (§ 1132d et seq.), and D (§ 1132e et seq.) of subchapter VII of this chapter, as in effect before the effective date of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":". For effective date of "},{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/s2"},"text":"section 2 of Pub. L. 102–325","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tVII"},"text":"Pub. L. 102–325, title VII","children":[],"tail":", §§ 703–707(a), "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/738-753"},"text":"106 Stat. 738–753","children":[],"tail":", amended subchapter VII of this chapter effective "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", by amending parts A to C generally, repealing part D, and redesignating former part E as D."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Part C of subchapter VII, as such part was in effect during the period after the effective date of the Higher Education Amendments of 1992 and prior to ","children":[{"tag":"date","attrib":{"date":"1998-10-07"},"text":"October 7, 1998","children":[],"tail":", referred to in subsecs. (a)(2) and (b)(2), probably means part C (§ 1132d et seq.) of subchapter VII of this chapter, as in effect during the period after the effective date of "},{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" and before it was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":". For effective date of "},{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/s2"},"text":"section 2 of Pub. L. 102–325","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVII/s701"},"text":"Pub. L. 105–244, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1786"},"text":"112 Stat. 1786","children":[],"tail":", amended subchapter VII of this chapter generally, effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", omitting part C which related to loans for construction, reconstruction, and renovation of academic housing, and other educational facilities and adding a new part C (§ 1139 et seq.) relating to urban community service."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cbeba25-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1132a–1"},"text":"section 1132a–1 of this title","children":[],"tail":" prior to the general amendment of subchapter VII of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s121"},"text":"section 121 of Pub. L. 89–329","children":[],"tail":", title I, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tI/s101"},"text":"Pub. L. 99–498, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1285"},"text":"100 Stat. 1285","children":[],"tail":", related to adult learning research and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1016"},"text":"section 1016 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cbeba26-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" substituted “2009 and for each succeeding fiscal year” for “1999 and for each of the 4 succeeding fiscal years” in pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
