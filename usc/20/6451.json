{"tag":"section","attrib":{"id":"id0e13c30c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6451"},"text":null,"children":[{"tag":"num","attrib":{"value":"6451"},"text":"§ 6451.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this subpart is to support the operation of local educational agency programs that involve collaboration with locally operated correctional facilities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e13c30d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6451/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out high quality education programs to prepare children and youth for secondary school completion, training, employment, or further education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e13c30e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6451/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide activities to facilitate the transition of such children and youth from the correctional program to further education or employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e13c30f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6451/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to operate programs in local schools, including schools operated or funded by the Bureau of Indian Education, for children and youth returning from correctional facilities, and programs which may serve at-risk children and youth.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e13c310-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1421"},"text":"Pub. L. 89–10, title I, § 1421","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1587"},"text":"115 Stat. 1587","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1401/8"},"text":"Pub. L. 114–95, title I, § 1401(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1903"},"text":"129 Stat. 1903","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e13c311-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e13c312-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e13c313-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6451, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1421"},"text":"Pub. L. 89–10, title I, § 1421","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3597"},"text":"108 Stat. 3597","children":[],"tail":", related to purpose of subpart, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e13c314-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" inserted “, including schools operated or funded by the Bureau of Indian Education,” after “local schools”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e13c315-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e13c316-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
