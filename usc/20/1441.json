{"tag":"section","attrib":{"id":"id0daac84e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441"},"text":null,"children":[{"tag":"num","attrib":{"value":"1441"},"text":"§ 1441.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State interagency coordinating council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0daac84f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daac850-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that desires to receive financial assistance under this subchapter shall establish a State interagency coordinating council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daac851-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The council shall be appointed by the Governor. In making appointments to the council, the Governor shall ensure that the membership of the council reasonably represents the population of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daac852-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor shall designate a member of the council to serve as the chairperson of the council, or shall require the council to so designate such a member. Any member of the council who is a representative of the lead agency designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1435/a/10"},"text":"section 1435(a)(10) of this title","children":[],"tail":" may not serve as the chairperson of the council."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daac853-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daac854-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The council shall be composed as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daac855-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 20 percent of the members shall be parents of infants or toddlers with disabilities or children with disabilities aged 12 or younger, with knowledge of, or experience with, programs for infants and toddlers with disabilities. Not less than 1 such member shall be a parent of an infant or toddler with a disability or a child with a disability aged 6 or younger.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac856-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 20 percent of the members shall be public or private providers of early intervention services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac857-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State legislature","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 1 member shall be from the State legislature.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac858-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel preparation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 1 member shall be involved in personnel preparation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac859-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency for early intervention services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 1 member shall be from each of the State agencies involved in the provision of, or payment for, early intervention services to infants and toddlers with disabilities and their families and shall have sufficient authority to engage in policy planning and implementation on behalf of such agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac85a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency for preschool services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 1 member shall be from the State educational agency responsible for preschool services to children with disabilities and shall have sufficient authority to engage in policy planning and implementation on behalf of such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac85b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State medicaid agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 1 member shall be from the agency responsible for the State medicaid program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac85c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Head Start agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 1 member shall be a representative from a Head Start agency or program in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac85d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child care agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 1 member shall be a representative from a State agency responsible for child care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac85e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency for health insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 1 member shall be from the agency responsible for the State regulation of health insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac85f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of the Coordinator of Education of Homeless Children and Youth","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 1 member shall be a representative designated by the Office of Coordinator for Education of Homeless Children and Youths.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac860-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/b/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State foster care representative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 1 member shall be a representative from the State child welfare agency responsible for foster care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac861-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/b/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mental health agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 1 member shall be a representative from the State agency responsible for children’s mental health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daac862-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The council may include other members selected by the Governor, including a representative from the Bureau of Indian Affairs (BIA), or where there is no BIA-operated or BIA-funded school, from the Indian Health Service or the tribe or tribal council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daac863-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The council shall meet, at a minimum, on a quarterly basis, and in such places as the council determines necessary. The meetings shall be publicly announced, and, to the extent appropriate, open and accessible to the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daac864-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the approval of the Governor, the council may prepare and approve a budget using funds under this subchapter to conduct hearings and forums, to reimburse members of the council for reasonable and necessary expenses for attending council meetings and performing council duties (including child care for parent representatives), to pay compensation to a member of the council if the member is not employed or must forfeit wages from other employment when performing official council business, to hire staff, and to obtain the services of such professional, technical, and clerical personnel as may be necessary to carry out its functions under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daac865-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daac866-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The council shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daac867-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise and assist the lead agency designated or established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1435/a/10"},"text":"section 1435(a)(10) of this title","children":[],"tail":" in the performance of the responsibilities set forth in such section, particularly the identification of the sources of fiscal and other support for services for early intervention programs, assignment of financial responsibility to the appropriate agency, and the promotion of the interagency agreements;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac868-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise and assist the lead agency in the preparation of applications and amendments thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac869-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise and assist the State educational agency regarding the transition of toddlers with disabilities to preschool and other appropriate services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac86a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit an annual report to the Governor and to the Secretary on the status of early intervention programs for infants and toddlers with disabilities and their families operated within the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daac86b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The council may advise and assist the lead agency and the State educational agency regarding the provision of appropriate services for children from birth through age 5. The council may advise appropriate agencies in the State with respect to the integration of services for infants and toddlers with disabilities and at-risk infants and toddlers and their families, regardless of whether at-risk infants and toddlers are eligible for early intervention services in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daac86c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1441/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No member of the council shall cast a vote on any matter that is likely to provide a direct financial benefit to that member or otherwise give the appearance of a conflict of interest under State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0daac86d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s641"},"text":"Pub. L. 91–230, title VI, § 641","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2758"},"text":"118 Stat. 2758","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0daac86e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0daac86f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0daac870-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1441, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s641"},"text":"Pub. L. 91–230, title VI, § 641","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tI/s101"},"text":"Pub. L. 105–17, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June 4, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/116"},"text":"111 Stat. 116","children":[],"tail":", related to State interagency coordinating councils, prior to the general amendment of subchapters I to IV of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/108/446"},"text":"Pub. L. 108–446","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1441, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s641"},"text":"Pub. L. 91–230, title VI, § 641","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/185"},"text":"84 Stat. 185","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/49/s4"},"text":"Pub. L. 95–49, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-06-17"},"text":"June 17, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/230"},"text":"91 Stat. 230","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/199"},"text":"Pub. L. 98–199","children":[],"tail":", §§ 3(b), 12, "},{"tag":"date","attrib":{"date":"1983-12-02"},"text":"Dec. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1358"},"text":"97 Stat. 1358","children":[],"tail":", 1372; "},{"tag":"ref","attrib":{"href":"/us/pl/99/457/tIII/s312"},"text":"Pub. L. 99–457, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-08"},"text":"Oct. 8, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1169"},"text":"100 Stat. 1169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/630/tI/s105/b"},"text":"Pub. L. 100–630, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3299"},"text":"102 Stat. 3299","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/476/tV/s501"},"text":"Pub. L. 101–476, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-30"},"text":"Oct. 30, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1135"},"text":"104 Stat. 1135","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/421/tII/s203"},"text":"Pub. L. 102–421, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2165"},"text":"106 Stat. 2165","children":[],"tail":", related to grants, contracts, and cooperative agreements for research and related activities, attention deficit disorder centers, and model demonstration programs, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tII/s203/c"},"text":"Pub. L. 105–17, title II, § 203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June 4, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/157"},"text":"111 Stat. 157","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
