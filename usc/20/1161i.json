{"tag":"section","attrib":{"id":"id0d84a23a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161i"},"text":"§ 1161i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this part are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a23b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the quality of the early childhood education workforce by creating a statewide early childhood education professional development and career task force for early childhood education program staff, directors, administrators, and faculty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a23c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to create—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a23d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a coherent system of core competencies, pathways to qualifications, credentials, degrees, quality assurances, access, and outreach, for early childhood education program staff, directors, administrators, and faculty that is linked to compensation commensurate with experience and qualifications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a23e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" articulation agreements that enable early childhood education professionals to transition easily among degrees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a23f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation initiatives for individuals working in an early childhood education program that reflect the individuals’ credentials, degrees, and experience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d84a240-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s811"},"text":"Pub. L. 89–329, title VIII, § 811","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3397"},"text":"122 Stat. 3397","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
