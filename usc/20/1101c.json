{"tag":"section","attrib":{"id":"id0d6a62ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1101c"},"text":"§ 1101c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of grant","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6a62ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award a grant to a Hispanic-serving institution under this subchapter for 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a62ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a), the Secretary may award a grant to a Hispanic-serving institution under this subchapter for a period of 1 year for the purpose of preparation of plans and applications for a grant under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6a62f0-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s504"},"text":"Pub. L. 89–329, title V, § 504","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tV/s501"},"text":"Pub. L. 105–244, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1769"},"text":"112 Stat. 1769","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/292/s4/b"},"text":"Pub. L. 109–292, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-30"},"text":"Sept. 30, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1341"},"text":"120 Stat. 1341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6a62f1-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6a62f2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d6a62f3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s504"},"text":"section 504 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1102c"},"text":"section 1102c of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s504"},"text":"section 504 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1091c"},"text":"section 1091c of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/482"},"text":"Pub. L. 94–482","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d6a62f4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/292"},"text":"Pub. L. 109–292","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—The Secretary may award a grant to a Hispanic-serving institution under this subchapter for 5 years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Waitout period","children":[],"tail":".—A Hispanic-serving institution shall not be eligible to secure a subsequent 5-year grant award under this subchapter until 2 years have elapsed since the expiration of the institution’s most recent 5-year grant award under this subchapter, except that for the purpose of this subsection a grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1103c/a"},"text":"section 1103c(a) of this title","children":[],"tail":" shall not be considered a grant under this subchapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
