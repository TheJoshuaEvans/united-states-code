{"tag":"section","attrib":{"id":"id0ce99a87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–17"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070a–17"},"text":"§ 1070a–17.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff development activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ce99a88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–17/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary’s authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of improving the operation of the programs and projects authorized by this division, the Secretary is authorized to make grants to institutions of higher education and other public and private nonprofit institutions and organizations to provide training for staff and leadership personnel employed in, participating in, or preparing for employment in, such programs and projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce99a89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–17/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of training programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such training shall include conferences, internships, seminars, workshops, and the publication of manuals designed to improve the operation of such programs and projects and shall be carried out in the various regions of the Nation in order to ensure that the training opportunities are appropriate to meet the needs in the local areas being served by such programs and projects. Such training shall be offered annually for new directors of projects funded under this division as well as annually on the following topics and other topics chosen by the Secretary:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce99a8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–17/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legislative and regulatory requirements for the operation of programs funded under this division.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a8b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–17/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assisting students in receiving adequate financial aid from programs assisted under this subchapter and other programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a8c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–17/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The design and operation of model programs for projects funded under this division.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a8d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–17/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of appropriate educational technology in the operation of projects assisted under this division.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99a8e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–17/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategies for recruiting and serving hard to reach populations, including students who are limited English proficient, students from groups that are traditionally underrepresented in postsecondary education, students with disabilities, students who are homeless children and youths (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11434a"},"text":"section 11434a of title 42","children":[],"tail":"), students who are in foster care or are aging out of the foster care system, or other disconnected students."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce99a8f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–17/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants for the purposes of this section shall be made only after consultation with regional and State professional associations of persons having special knowledge with respect to the needs and problems of such programs and projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ce99a90-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s402G"},"text":"Pub. L. 89–329, title IV, § 402G","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s402/a/4"},"text":"Pub. L. 102–325, title IV, § 402(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/491"},"text":"106 Stat. 491","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s402/f"},"text":"Pub. L. 105–244, title IV, § 402(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1655"},"text":"112 Stat. 1655","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s403/g"},"text":"Pub. L. 110–315, title IV, § 403(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3204"},"text":"122 Stat. 3204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ce99a91-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ce99a92-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ce99a93-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s402/f/1"},"text":"Pub. L. 105–244, § 402(f)(1)","children":[],"tail":", inserted “participating in,” after “leadership personnel employed in,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s402/f/2"},"text":"Pub. L. 105–244, § 402(f)(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ce99a94-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0ce99a95-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
