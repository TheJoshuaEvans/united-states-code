{"tag":"section","attrib":{"id":"id0cd43d6c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1059f"},"text":"§ 1059f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American-serving, nontribal institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cd43d6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide grants and related assistance to Native American-serving, nontribal institutions to enable such institutions to improve and expand their capacity to serve Native Americans and low-income individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd43d6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd43d6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Native American” means an individual who is of a tribe, people, or culture that is indigenous to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd43d70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American-serving, nontribal institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Native American-serving, nontribal institution” means an institution of higher education, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"section 1001(a) of this title","children":[],"tail":", that, at the time of application—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd43d71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an eligible institution under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1058/b"},"text":"section 1058(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an enrollment of undergraduate students that is not less than 10 percent Native American students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a Tribal College or University (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c"},"text":"section 1059c of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd43d74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd43d75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of activities authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded under this section shall be used by Native American-serving, nontribal institutions to assist such institutions to plan, develop, undertake, and carry out activities to improve and expand such institutions’ capacity to serve Native Americans and low-income individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd43d76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examples of authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such programs may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd43d77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase, rental, or lease of scientific or laboratory equipment for educational purposes, including instructional and research purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d78-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renovation and improvement in classroom, library, laboratory, and other instructional facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support of faculty exchanges, and faculty development and faculty fellowships to assist faculty in attaining advanced degrees in the faculty’s field of instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" curriculum development and academic instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of library books, periodicals, microfilm, and other educational materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d7c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds and administrative management, and acquisition of equipment for use in strengthening funds management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d7d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the joint use of facilities such as laboratories and libraries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d7e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic tutoring and counseling programs and student support services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d7f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education or counseling services designed to improve the financial and economic literacy of students or the students’ families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd43d80-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cd43d81-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Native American-serving, nontribal institution desiring to receive assistance under this section shall submit to the Secretary such enrollment data as may be necessary to demonstrate that the institution is a Native American-serving, nontribal institution, along with such other information and data as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd43d82-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd43d83-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to submit applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any institution that is determined by the Secretary to be a Native American-serving, nontribal institution may submit an application for assistance under this section to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d84-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simplified and streamlined format","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, to the extent possible, continue to prescribe a simplified and streamlined format for applications under this section that takes into account the limited number of institutions that are eligible for assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d85-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application submitted under subparagraph (A) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cd43d86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a five-year plan for improving the assistance provided by the Native American-serving, nontribal institution to Native Americans and low-income individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cd43d87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information and assurances as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cd43d88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cd43d89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No Native American-serving, nontribal institution that receives funds under this section shall concurrently receive funds under any other provision of this part, part B, or part A of subchapter V.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059/d"},"text":"Section 1059(d) of this title","children":[],"tail":" shall not apply to institutions that are eligible to receive funds under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d8b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall, to the extent possible and consistent with the competitive process under which such grants are awarded, ensure maximum and equitable distribution among all eligible institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cd43d8c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059f/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum grant amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The minimum amount of a grant under this section shall be $200,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cd43d8d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s319"},"text":"Pub. L. 89–329, title III, § 319","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIII/s306"},"text":"Pub. L. 110–315, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3173"},"text":"122 Stat. 3173","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
