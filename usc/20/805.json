{"tag":"section","attrib":{"id":"id0c9fc017-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s805"},"text":null,"children":[{"tag":"num","attrib":{"value":"805"},"text":"§ 805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance, studies, and publication of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to carry out the purpose of this chapter, the Secretary is authorized to provide technical assistance to State and local governmental or public bodies and to undertake such studies and publish and distribute such information, either directly or by contract, as he shall determine to be desirable. Nothing contained in this chapter shall limit any authority of the Secretary under any other provision of law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c9fc018-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/560/tVIII/s806"},"text":"Pub. L. 88–560, title VIII, § 806","children":[],"tail":", formerly § 805, "},{"tag":"date","attrib":{"date":"1964-09-02"},"text":"Sept. 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/803"},"text":"78 Stat. 803","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/19/s21/e"},"text":"Pub. L. 90–19, § 21(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-05-25"},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/26"},"text":"81 Stat. 26","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/448/tXVII/s1707/b"},"text":"Pub. L. 90–448, title XVII, § 1707(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/606"},"text":"82 Stat. 606","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/152/tIII/s307"},"text":"Pub. L. 91–152, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-24"},"text":"Dec. 24, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/394"},"text":"83 Stat. 394","children":[],"tail":"; renumbered § 806, "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/tIV/s402/c/1"},"text":"Pub. L. 93–383, title IV, § 402(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/692"},"text":"88 Stat. 692","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c9fc019-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c9fc01a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c9fc01b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/152"},"text":"Pub. L. 91–152","children":[],"tail":" substituted provisions authorizing the Secretary to provide technical assistance, etc., to State and local bodies to carry out the purposes of this chapter for provisions defining “State” and “Secretary” and authorizing to be appropriated such sums as may be necessary for administrative and other expenses. The former provisions of this section are now set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s807"},"text":"section 807 of this title","children":[],"tail":" with minor amendments."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448"},"text":"Pub. L. 90–448","children":[],"tail":" inserted “Guam, American Samoa, the Trust Territory of the Pacific Islands,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/19"},"text":"Pub. L. 90–19","children":[],"tail":" substituted definition of “Secretary” meaning the Secretary of Housing and Urban Development for “Administrator” meaning the Housing and Home Finance Administrator."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
