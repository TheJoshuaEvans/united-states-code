{"tag":"section","attrib":{"id":"id0dc9c102-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2566"},"text":null,"children":[{"tag":"num","attrib":{"value":"2566"},"text":"§ 2566.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hubert H. Humphrey Institute of Public Affairs; grants for development","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In recognition of the public service of Senator Hubert H. Humphrey, the Secretary of Education (hereafter in sections 2566 to 2569 of this title referred to as the “Secretary”) is authorized to make grants in accordance with the provisions of sections 2566 to 2569 of this title to assist in the development of the Hubert H. Humphrey Institute of Public Affairs, located at the University of Minnesota, Minneapolis-Saint Paul.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0dc9c103-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/270/s2/a"},"text":"Pub. L. 95–270, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-04-27"},"text":"Apr. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/220"},"text":"92 Stat. 220","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIII/s301/a/1"},"text":"Pub. L. 96–88, title III, § 301(a)(1)","children":[],"tail":", title V, § 507, "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/677"},"text":"93 Stat. 677","children":[],"tail":", 692.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dc9c104-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dc9c105-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0dc9c106-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/270/s4/d"},"text":"Pub. L. 95–270, § 4(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-04-27"},"text":"Apr. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/220"},"text":"92 Stat. 220","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/270/s4/d"},"text":"“This Act [enacting this section, sections 2567 to 2569 of this title, and provisions set out as a note below] shall take effect ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0dc9c107-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/270/s1"},"text":"Pub. L. 95–270, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-04-27"},"text":"Apr. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/220"},"text":"92 Stat. 220","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/270/s1"},"text":"“That this Act [enacting this section, sections 2567 to 2569 of this title, and provisions set out as a note above] may be cited as the ‘Hubert H. Humphrey Institute of Public Affairs and the Everett McKinley Dirksen Congressional Leadership Research Center Assistance Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0dc9c108-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” substituted in text for “Commissioner” pursuant to sections 301(a)(1) and 507 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88"},"text":"Pub. L. 96–88","children":[],"tail":", which are classified to sections 3441(a)(1) and 3507 of this title and which transferred functions of Commissioner of Education to Secretary of Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
