{"tag":"section","attrib":{"id":"id0d92f939-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1231d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1231d"},"text":"§ 1231d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parental involvement and dissemination","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In the case of any applicable program in which the Secretary determines that parental participation at the State or local level would increase the effectiveness of the program in achieving its purposes, the Secretary shall promulgate regulations with respect to such program setting forth criteria designed to encourage such participation. If the program for which such determination is made provides for payments to local educational agencies, applications for such payments shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d92f93a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1231d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth such policies and procedures as will ensure that programs and projects assisted under the application have been planned and developed, and will be operated, in consultation with, and with the involvement of, parents of the children to be served by such programs and projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d92f93b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1231d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be submitted with assurance that such parents have had an opportunity to present their views with respect to the application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d92f93c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1231d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth policies and procedures for adequate dissemination of program plans and evaluations to such parents and the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d92f93d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s434"},"text":"Pub. L. 90–247, title IV, § 434","children":[],"tail":", formerly § 415, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/230/tIV/s401/a/10"},"text":"Pub. L. 91–230, title IV, § 401(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/168"},"text":"84 Stat. 168","children":[],"tail":"; renumbered § 425, "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tIII/s301/a/1"},"text":"Pub. L. 92–318, title III, § 301(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/326"},"text":"86 Stat. 326","children":[],"tail":"; renumbered § 427, "},{"tag":"ref","attrib":{"href":"/us/pl/93/380/tV/s508/a"},"text":"Pub. L. 93–380, title V, § 508(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/565"},"text":"88 Stat. 565","children":[],"tail":"; renumbered § 434 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII"},"text":"Pub. L. 103–382, title II","children":[],"tail":", §§ 212(b)(1), 244, "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3913"},"text":"108 Stat. 3913","children":[],"tail":", 3922.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d92f93e-3a70-11f1