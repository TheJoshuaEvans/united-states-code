{"tag":"section","attrib":{"id":"id0d8713d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161n"},"text":"§ 1161n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purpose; definition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d8713d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this part to award grants to institutions of higher education or consortia of such institutions to encourage such institutions to develop and make available to their students work experience that will aid such students in future careers and will enable such students to support themselves financially while in school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8713d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this part the term “cooperative education” means the provision of alternating or parallel periods of academic study and public or private employment to give students work experiences related to their academic or occupational objectives and an opportunity to earn the funds necessary for continuing and completing their education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d8713d5-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s831"},"text":"Pub. L. 89–329, title VIII, § 831","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3415"},"text":"122 Stat. 3415","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
