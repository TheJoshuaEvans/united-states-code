{"tag":"section","attrib":{"id":"id0dda8a86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3476"},"text":null,"children":[{"tag":"num","attrib":{"value":"3476"},"text":"§ 3476.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional and field offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish, alter, discontinue, or maintain such regional or other field offices as the Secretary may find necessary or appropriate to perform functions of the Secretary or the Department.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0dda8a87-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIV/s416"},"text":"Pub. L. 96–88, title IV, § 416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/685"},"text":"93 Stat. 685","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
