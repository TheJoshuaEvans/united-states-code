{"tag":"section","attrib":{"id":"id0e37774a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441"},"text":null,"children":[{"tag":"num","attrib":{"value":"7441"},"text":"§ 7441.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvement of educational opportunities for Indian children and youth","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e37774b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e37774c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this section to support projects to develop, test, and demonstrate the effectiveness of services and programs to improve educational opportunities and achievement of Indian children and youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e37774d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall take the necessary actions to achieve the coordination of activities assisted under this subpart with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e37774e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other programs funded under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e37774f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal programs operated for the benefit of Indian children and youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e377750-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “eligible entity” means a State educational agency, local educational agency, Indian tribe, Indian organization, federally supported elementary school or secondary school for Indian students, a Tribal College or University (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c/b"},"text":"section 1059c(b) of this title","children":[],"tail":"), or a consortium of such entities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e377751-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award grants to eligible entities to enable such entities to carry out activities that meet the purpose of this section, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e377752-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative programs related to the educational needs of educationally disadvantaged Indian children and youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e377753-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational services that are not available to such children and youth in sufficient quantity or quality, including remedial instruction, to raise the achievement of Indian children in one or more of the subjects of English, mathematics, science, foreign languages, art, history, and geography;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e377754-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bilingual and bicultural programs and projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e377755-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special health and nutrition services, and other related activities, that address the special health, social, and psychological problems of Indian children and youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e377756-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special compensatory and other programs and projects designed to assist and encourage Indian children and youth to enter, remain in, or reenter school, and to increase the rate of high school graduation for Indian children and youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e377757-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprehensive guidance, counseling, and testing services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e377758-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early childhood education programs that are effective in preparing young children to make sufficient academic growth by the end of grade 3, including kindergarten and pre-kindergarten programs, family-based preschool programs that emphasize school readiness, screening and referral, and the provision of services to Indian children and youth with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e377759-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partnership projects between local educational agencies and institutions of higher education that allow secondary school students to enroll in courses at the postsecondary level to aid such students in the transition from secondary to postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e37775a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partnership projects between schools and local businesses for career preparation programs designed to provide Indian youth with the knowledge and skills such youth need to make an effective transition from school to a high-skill career;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e37775b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs designed to encourage and assist Indian students to work toward, and gain entrance into, institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e37775c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family literacy services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e37775d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities that recognize and support the unique cultural and educational needs of Indian children and youth, and incorporate traditional leaders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e37775e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-quality professional development of teaching professionals and paraprofessionals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e37775f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other services that meet the purpose described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e377760-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant requirements and applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e377761-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e377762-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make multiyear grants under subsection (c) for the planning, development, pilot operation, or demonstration of any activity described in subsection (c) for a period not to exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e377763-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making multiyear grants described in this paragraph, the Secretary shall give priority to entities submitting applications that present a plan for combining two or more of the activities described in subsection (c) over a period of more than 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e377764-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Progress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants for an initial period of not more than 3 years and may renew such grants for not more than an additional 2 years if the Secretary determines that the eligible entity has made substantial progress in carrying out the activities assisted under the grant in accordance with the application submitted under paragraph (3) and any subsequent modifications to such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e377765-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e377766-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to awarding the multiyear grants described in paragraph (1), the Secretary may award grants under subsection (c) to eligible entities for the dissemination of exemplary materials or programs assisted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e377767-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award a dissemination grant described in this paragraph if, prior to awarding the grant, the Secretary determines that the material or program to be disseminated—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e377768-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been adequately reviewed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e377769-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has demonstrated educational merit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e37776a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can be replicated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e37776b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e37776c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any eligible entity that desires to receive a grant under this section shall submit an application to the Secretary at such time and in such manner as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e37776d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted to the Secretary under subparagraph (A), other than an application for a dissemination grant under paragraph (2), shall contain—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e37776e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how parents and family of Indian children and representatives of Indian tribes have been, and will be, involved in developing and implementing the activities for which assistance is sought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e37776f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances that the applicant will participate, at the request of the Secretary, in any national evaluation of activities assisted under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e377770-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information demonstrating that the proposed program is an evidence-based program, where applicable, which may include a program that has been modified to be culturally appropriate for students who will be served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e377771-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the applicant will incorporate the proposed activities into the ongoing school program involved once the grant period is over; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e377772-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/d/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other assurances and information as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e377773-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7441/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 percent of the funds provided to a grantee under this subpart for any fiscal year may be used for administrative purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e377774-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6121"},"text":"Pub. L. 89–10, title VI, § 6121","children":[],"tail":", formerly title VII, § 7121, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1919"},"text":"115 Stat. 1919","children":[],"tail":"; renumbered title VI, § 6121, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI"},"text":"Pub. L. 114–95, title VI","children":[],"tail":", §§ 6001(a), (b)(1), 6002(k), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":", 2054.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e377775-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e377776-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e377777-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s6121"},"text":"section 6121 of Pub. L. 89–10","children":[],"tail":" was renumbered section 5101 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7305"},"text":"section 7305 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e377778-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/k/1"},"text":"Pub. L. 114–95, § 6002(k)(1)","children":[],"tail":", substituted “Improvement of educational opportunities for Indian children and youth” for “Improvement of educational opportunities for Indian children” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/k/2/A"},"text":"Pub. L. 114–95, § 6002(k)(2)(A)","children":[],"tail":", inserted “and youth” after “Indian children”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/k/2/B"},"text":"Pub. L. 114–95, § 6002(k)(2)(B)","children":[],"tail":", substituted “Indian children and youth” for “American Indian and Alaska Native children”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/k/3"},"text":"Pub. L. 114–95, § 6002(k)(3)","children":[],"tail":", substituted “a Tribal College or University (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c/b"},"text":"section 1059c(b) of this title","children":[],"tail":")” for “Indian institution (including an Indian institution of higher education)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/k/4"},"text":"Pub. L. 114–95, § 6002(k)(4)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which related to grants authorized, consisting of pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/k/5/A"},"text":"Pub. L. 114–95, § 6002(k)(5)(A)","children":[],"tail":", substituted “award grants for an initial period of not more than 3 years and may renew such grants for not more 