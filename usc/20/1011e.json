{"tag":"section","attrib":{"id":"id0cbeb9af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1011e"},"text":"§ 1011e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial responsibility of foreign students","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter or any other Federal law shall be construed to prohibit any institution of higher education from requiring a student who is a foreign national (and not admitted to permanent residence in the United States) to guarantee the future payment of tuition and fees to such institution by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cbeb9b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making advance payment of such tuition and fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeb9b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making deposits in an escrow account administered by such institution for such payments; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cbeb9b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1011e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining a bond or other insurance that such payments will be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cbeb9b3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s116"},"text":"Pub. L. 89–329, title I, § 116","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tI/s101/a"},"text":"Pub. L. 105–244, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1593"},"text":"112 Stat. 1593","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cbeb9b4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cbeb9b5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cbeb9b6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1145c"},"text":"section 1145c of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 1011e, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s126"},"text":"Pub. L. 89–329, title I, § 126","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tI/s101"},"text":"Pub. L. 102–325, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/464"},"text":"106 Stat. 464","children":[],"tail":", related to State administrative costs, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","