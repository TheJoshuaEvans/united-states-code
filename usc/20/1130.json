{"tag":"section","attrib":{"id":"id0d6f1e8d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130"},"text":null,"children":[{"tag":"num","attrib":{"value":"1130"},"text":"§ 1130.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6f1e8e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6f1e8f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the future economic welfare of the United States will depend substantially on increasing international skills in the business and educational community and creating an awareness among the American public of the internationalization of our economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e90-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concerted efforts are necessary to engage business schools, language and area study programs, professional international affairs education programs, public and private sector organizations, and United States business in a mutually productive relationship which benefits the Nation’s future economic interests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e91-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" few linkages presently exist between the manpower and information needs of United States business and the international education, language training and research capacities of institutions of higher education in the United States, and public and private organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e92-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations such as world trade councils, world trade clubs, chambers of commerce and State departments of commerce are not adequately used to link universities and business for joint venture exploration and program development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6f1e93-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6f1e94-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the broad objective of this chapter by increasing and promoting the Nation’s capacity for international understanding and economic enterprise through the provision of suitable international education and training for business personnel in various stages of professional development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e95-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1130/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote institutional and noninstitutional educational and training activities that will contribute to the ability of United States business to prosper in an international economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6f1e96-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s611"},"text":"Pub. L. 89–329, title VI, § 611","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tVI/s601/a"},"text":"Pub. L. 96–374, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1467"},"text":"94 Stat. 1467","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tVI/s610"},"text":"Pub. L. 99–498, title VI, § 610","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1519"},"text":"100 Stat. 1519","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tVI/s601"},"text":"Pub. L. 102–325, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/728"},"text":"106 Stat. 728","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVI/s602/a"},"text":"Pub. L. 105–244, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1783"},"text":"112 Stat. 1783","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6f1e97-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6f1e98-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d6f1e99-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" amended section catchline generally."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" amended section generally, inserting subsec. headings and reenacting text without substantial change."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":" inserted “and educational” after “skills in the business”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d6f1e9a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d6f1e9b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"