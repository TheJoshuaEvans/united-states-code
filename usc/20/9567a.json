{"tag":"section","attrib":{"id":"id0e64c8ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9567a"},"text":null,"children":[{"tag":"num","attrib":{"value":"9567a"},"text":"§ 9567a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner for Special Education Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Special Education Research Center shall be headed by a Commissioner for Special Education Research (in this part referred to as the “Special Education Research Commissioner”) who shall have substantial knowledge of the Special Education Research Center’s activities, including a high level of expertise in the fields of research, research management, and the education of children with disabilities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e64c8ae-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s176"},"text":"Pub. L. 107–279, title I, § 176","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tII/s201/a/2"},"text":"Pub. L. 108–446, title II, § 201(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2799"},"text":"118 Stat. 2799","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
