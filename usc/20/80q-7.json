{"tag":"section","attrib":{"id":"id0c87f250-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"80q–7"},"text":"§ 80q–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audubon Terrace","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c87f251-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Regents shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c87f252-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–7/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assure that, on the date on which a qualified successor to the Heye Foundation at Audubon Terrace first takes possession of Audubon Terrace, an area of at least 2,000 square feet at that facility is accessible to the public and physically suitable for exhibition of museum objects and for related exhibition activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f253-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–7/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon written agreement between the Board and any qualified successor, lend objects from the collections of the Smithsonian Institution to the successor for exhibition at Audubon Terrace; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f254-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–7/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon written agreement between the Board and any qualified successor, provide training, scholarship, technical, and other assistance (other than operating funds) with respect to the area referred to in paragraph (1) for the purposes described in that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c87f255-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of charges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any charge by the Board of Regents for activities pursuant to agreements under paragraph (2) or (3) of subsection (a) shall be determined according to the ability of the successor to pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c87f256-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section, the terms “qualified successor to the Heye Foundation at Audubon Terrace”, “qualified successor”, and,","children":[{"tag":"ref","attrib":{"idref":"fn002005"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002005"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" “successor” mean an organization described in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":", and exempt from tax under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/a"},"text":"section 501(a) of title 26","children":[],"tail":", that, as determined by the Board of Regents—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c87f257-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–7/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a successor occupant to the Heye Foundation at Audubon Terrace, 3753 Broadway, New York, New York;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f258-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–7/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is qualified to operate the area referred to in paragraph (1) for the purposes described in that paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f259-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–7/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is committed to making a good faith effort to respond to community cultural interests in such operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c87f25a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/185/s9"},"text":"Pub. L. 101–185, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1342"},"text":"103 Stat. 1342","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
