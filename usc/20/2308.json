{"tag":"section","attrib":{"id":"id0dbb695a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2308"},"text":null,"children":[{"tag":"num","attrib":{"value":"2308"},"text":"§ 2308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interdepartmental Task Force on Vocational Education and Related Programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dbb695b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Interdepartmental Task Force on Vocational Education and Related Programs (in this section referred to as the “Task Force”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dbb695c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force shall consist of the Secretary of Education, the Secretary of Labor, the Secretary of Health and Human Services, and such other personnel of the Department of Education, the Department of Labor, and the Department of Health and Human Services as the Secretaries consider appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dbb695d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2308/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dbb695e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2308/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine principal data required for programs under the Adult Education Act, the Carl D. Perkins Vocational and Applied Technology Education Act, the Job Training Partnership Act, the Rehabilitation Act of 1973 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq.], and the Wagner-Peyser Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s49"},"text":"29 U.S.C. 49","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dbb695f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2308/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine possible common objectives, definitions, measures, and standards for such programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dbb6960-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2308/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider integration of research and development conducted with Federal assistance in the area of vocational education and related areas, including areas of emerging technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dbb6961-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/392/s4"},"text":"Pub. L. 101–392, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-09-25"},"text":"Sept. 25, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/758"},"text":"104 Stat. 758","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1041/f"},"text":"Pub. L. 104–66, title I, § 1041(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/715"},"text":"109 Stat. 715","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dbb6962-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dbb6963-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0dbb6964-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Adult Education Act, referred to in subsec. (c)(1), was title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/750"},"text":"Pub. L. 89–750","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1216"},"text":"80 Stat. 1216","children":[],"tail":", which was classified generally to chapter 30 (§ 1201 et seq.) of this title, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tII/s251/a/1"},"text":"Pub. L. 105–220, title II, § 251(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1079"},"text":"112 Stat. 1079","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Carl D. Perkins Vocational and Applied Technology Education Act, referred to in subsec. (c)(1), was ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210"},"text":"Pub. L. 88–210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-12-18"},"text":"Dec. 18, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/403"},"text":"77 Stat. 403","children":[],"tail":", which was classified generally to this chapter, prior to being amended generally and renamed the Carl D. Perkins Vocational and Technical Education Act of 1998 by "},{"tag":"ref","attrib":{"href":"/us/pl/105/332/s1/b"},"text":"Pub. L. 105–332, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3076"},"text":"112 Stat. 3076","children":[],"tail":", and amended generally and renamed the Carl D. Perkins Career and Technical Education Act of 2006 by "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/683"},"text":"120 Stat. 683","children":[],"tail":". For complete classification of "},{"tag":"ref","attrib":{"href":"/us/pl/88/210"},"text":"Pub. L. 88–210","children":[],"tail":" to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2301"},"text":"section 2301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Job Training Partnership Act, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/300"},"text":"Pub. L. 97–300","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-13"},"text":"Oct. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1322"},"text":"96 Stat. 1322","children":[],"tail":", which was classified genera