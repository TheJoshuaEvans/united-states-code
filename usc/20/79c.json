{"tag":"section","attrib":{"id":"id0c83103f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s79c"},"text":null,"children":[{"tag":"num","attrib":{"value":"79c"},"text":"§ 79c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resident manager; powers and duties; compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Smithsonian Institution may select and designate a resident manager to assist in carrying out the policy, conditions, and regulations approved by it in compliance with the purposes of this subchapter. The resident manager shall receive such compensation for his services as may be allowed by the Smithsonian Institution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c831040-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-07-02/ch516/s5"},"text":"July 2, 1940, ch. 516, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/725"},"text":"54 Stat. 725","children":[],"tail":"; 1946 Reorg. Plan No. 3, § 801, eff. "},{"tag":"date","attrib":{"date":"1946-07-16"},"text":"July 16, 1946","children":[],"tail":", 11 F.R. 7877, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1101"},"text":"60 Stat. 1101","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c831041-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c831042-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c831043-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1385"},"text":"section 1385 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id0c831044-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0c831045-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"References to the “Board of Directors of the Canal Zone Biological Area” and its “executive officer” changed to “Smithsonian Institution” and provisions for the appointment and compensation of said executive officer were superseded by Reorg. Plan No. 3 of 1946, set out in the Appendix to Title 5, Government Organization and Employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
