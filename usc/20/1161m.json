{"tag":"section","attrib":{"id":"id0d8713a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161m"},"text":"§ 1161m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentives and rewards for low tuition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d8713a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rewards for low tuition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8713aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From funds made available under subsection (e), the Secretary shall award grants to institutions of higher education that, for academic year 2009–2010 or any succeeding academic year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8713ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have an annual tuition and fee increase, expressed as a percentage change, for the most recent academic year for which satisfactory data is available, that is in the lowest 20 percent of such increases for each category described in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8713ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are public institutions of higher education that have tuition and fees that are in the lowest quartile of institutions in each category described in subsection (b)(1), (b)(4), or (b)(7); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8713ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are public institutions of higher education that have a tuition and fee increase of less than $600 for a first-time, full-time undergraduate student.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds awarded to an institution of higher education under paragraph (1) shall be distributed by the institution in the form of need-based grant aid to students who are eligible for Federal Pell Grants, except that no student shall receive an amount under this section that would cause the amount of total financial aid received by such student to exceed the cost of attendance of the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8713af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Categories of institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The categories of institutions described in subsection (a) shall be the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8713b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four-year public institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four-year private, nonprofit institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four-year private, for-profit institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two-year public institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two-year private, nonprofit institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two-year private, for-profit institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than two-year public institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than two-year private, nonprofit institutions of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than two-year private, for-profit institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8713b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rewards for guaranteed tuition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8713ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bonus","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each institution of higher education that the Secretary determines complies with the requirements of paragraph (2) or (3) of this subsection, the Secretary shall provide to such institution a bonus amount. Such institution shall award the bonus amount in the form of need-based aid first to students who are eligible for Federal Pell Grants who were in attendance at the institution during the award year that such institution satisfied the eligibility criteria for maintaining low tuition and fees, then to students who are eligible for Federal Pell Grants who were not in attendance at the institution during such award year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Four-year institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education that provides a program of instruction for which it awards a bachelor’s degree complies with the requirements of this paragraph if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8713bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a public institution of higher education, such institution’s tuition and fees are in the lowest quartile of institutions in the same category as described under subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8713bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for any institution of higher education, such institution guarantees that for any academic year (or the equivalent) beginning on or after ","children":[{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", and for each of the four succeeding continuous academic years, the tuition and fees charged to an undergraduate student will not exceed—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0d8713be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a public institution of higher education, $600 per year for a full-time undergraduate student; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8713bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for any other institution of higher education—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d8713c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/c/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount that the student was charged for an academic year at the time the student first enrolled in the institution of higher education, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d8713c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/c/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage change in tuition and fees at the institution for the three most recent academic years for which data is available, multiplied by the amount determined under subclause (I).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Less-than four-year institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education that does not provide a program of instruction for which it awards a bachelor’s degree complies with the requirements of this paragraph if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8713c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a public institution of higher education, such institution’s tuition is in the lowest quartile of institutions in the same category as described under subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8713c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for any institution of higher education, such institution guarantees that for any academic year (or the equivalent) beginning on or after ","children":[{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", and for each of the 1.5 succeeding continuous academic years, the tuition and fees charged to an undergraduate student will not exceed—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0d8713c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a public institution of higher education, $600 per year for a full-time undergraduate student; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8713c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for any other institution of higher education—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d8713c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/c/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount that the student was charged for an academic year at the time the student first enrolled in the institution of higher education, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d8713c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/c/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage change in tuition and fees at the institution for the three most recent academic years for which data is available, multiplied by the amount determined under subclause (I).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8713c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the terms “tuition and fees” and “net price” have the meaning given to such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1015a"},"text":"section 1015a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8713ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161m/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d8713cb-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s830"},"text":"Pub. L. 89–329, title VIII, § 830","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3413"},"text":"122 Stat. 3413","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tVIII/s801/10"},"text":"Pub. L. 111–39, title VIII, § 801(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1956"},"text":"123 Stat. 1956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d8713cc-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d8713cd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d8713ce-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" substituted “of institutions” for “of for institutions”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d8713cf-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d8713d0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/s3"},"text":"section 3 of Pub. L. 111–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
