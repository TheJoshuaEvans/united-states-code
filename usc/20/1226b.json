{"tag":"section","attrib":{"id":"id0d908948-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1226b"},"text":"§ 1226b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility of States to furnish information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d908949-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial reports; contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State educational agency shall submit to the Secretary a report on or before March 15 of every second year. Each such report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d90894a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information with respect to the uses of Federal funds in such State in the two preceding fiscal years under any applicable program under the jurisdiction of the State educational agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d90894b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information with respect to the uses of Federal funds in such State in the two preceding fiscal years under any Federal program administered by the State that provided grants or contracts to a local educational agency in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d90894c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d90894d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" list, with respect to each program for which information is provided, all grants made to and contracts entered into with local educational agencies and other public and private agencies and institutions within the State during each fiscal year concerned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d90894e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze the information included in the report by local educational agency and by program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d90894f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the total amount of funds available to the State under each such program for each fiscal year concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d908950-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made readily available by the State to local educational agencies and institutions within the State and to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d908951-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delinquent or incomplete reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary does not receive a report by the date required under subsection (a), or receives an incomplete report, the Secretary, not later than 30 days after such report is required to be submitted, shall take all reasonable measures to obtain the delinquent or incomplete information from the State educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d908952-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When the Secretary receives a report required under subsection (a), the Secretary shall provide such information to the National Center for Education Statistics, and shall make such information available, at a reasonable cost, to any individual who requests such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d908953-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional telecommunications network","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Speaker and Minority Leader of the House of Representatives and the Majority and Minority Leaders of the Senate regarding the costs and feasibility of making the information described in subsection (a) available as part of a telecommunications network that is readily accessible to every member of Congress and other interested parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d908954-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On or before August 15 of each year in which reports are submitted under subsection (a), the Secretary shall submit a report to the Committee on Education and Labor of the House of Representatives and the Committee on Labor and Human Resources of the Senate. Such report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d908955-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the content and data quality of such reports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d908956-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a compilation of statistical data derived from such reports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d908957-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information obtained by the Secretary with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d908958-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct grants made to local educational agencies by the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d908959-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1226b/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contracts entered into between such agencies and the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d90895a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s424"},"text":"Pub. L. 90–247, title IV, § 424","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII/s234"},"text":"Pub. L. 103–382, title II, § 234","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3915"},"text":"108 Stat. 3915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d90895b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d90895c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d90895d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in subsecs. (a), (b), and (f) of this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221e–1a"},"text":"section 1221e–1a of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 1226b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s416"},"text":"Pub. L. 90–247, title IV, § 416","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/380/tV/s506/a/3/C"},"text":"Pub. L. 93–380, title V, § 506(a)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/563"},"text":"88 Stat. 563","children":[],"tail":", related to program planning and evaluation, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII/s212/a/1"},"text":"Pub. L. 103–382, title II, § 212(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3913"},"text":"108 Stat. 3913","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s424"},"text":"section 424 of Pub. L. 90–247","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1231b–1"},"text":"section 1231b–1 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s424"},"text":"section 424 of Pub. L. 90–247","children":[],"tail":" was renumbered section 433, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1231c"},"text":"section 1231c of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s424"},"text":"section 424 of Pub. L. 90–247","children":[],"tail":" was renumbered section 434, and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232c"},"text":"section 1232c of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/95/561"},"text":"Pub. L. 95–561","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d90895e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id0d90895f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Labor and Human Resources of Senate changed to Committee on Health, Education, Labor, and Pensions of Senate by Senate Resolution No. 20, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-19"},"text":"Jan. 19, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
