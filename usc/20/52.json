{"tag":"section","attrib":{"id":"id0c77290f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s52"},"text":null,"children":[{"tag":"num","attrib":{"value":"52"},"text":"§ 52.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evidence of title to site and buildings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The site and lands selected for buildings for the Smithsonian Institution shall be deemed appropriated to the institution, and the record of the description of such site and lands, or a copy thereof, certified by the chancellor and Secretary of the Board of Regents, shall be received as evidence in all courts of the extent and boundaries of the lands appropriated to the institution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c772910-3a70-11f1-a648-bee82ed8a795"},"text":"(R.S. § 5588.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c772911-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c772912-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c772913-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5588 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1846-08-10/ch178/s4"},"text":"act Aug. 10, 1846, ch. 178, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/104"},"text":"9 Stat. 104","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
