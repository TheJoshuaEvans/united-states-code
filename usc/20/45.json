{"tag":"section","attrib":{"id":"id0c74dfe4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s45"},"text":null,"children":[{"tag":"num","attrib":{"value":"45"},"text":"§ 45.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special meetings of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The members of the institution may hold stated and special meetings, for the supervision of the affairs of the institution and the advice and instruction of the Board of Regents, to be called in the manner provided for in the by-laws of the institution, at which the President, and in his absence the Vice President, shall preside.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c74dfe5-3a70-11f1-a648-bee82ed8a795"},"text":"(R.S. § 5585.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c74dfe6-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c74dfe7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c74dfe8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5585 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1846-08-10/ch178/s8"},"text":"act Aug. 10, 1846, ch. 178, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/103"},"text":"9 Stat. 103","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
