{"tag":"section","attrib":{"id":"id0e6e66d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9905"},"text":null,"children":[{"tag":"num","attrib":{"value":"9905"},"text":"§ 9905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6e66d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9905/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Field-based course","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “field-based course” means a course of instruction offered by an institution of higher education that includes a requirement that students teach a minimum of 3 lessons or sequences of lessons to elementary or secondary students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6e66d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9905/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given that term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6e66d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9905/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Master teacher","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “master teacher” means an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6e66d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9905/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has been awarded a master’s or doctoral degree by an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6e66d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9905/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose graduate coursework included courses in mathematics, science, computer science, or engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6e66da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9905/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has at least 3 years teaching experience in K–12 settings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6e66db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9905/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose teaching has been recognized for exceptional accomplishments in educating students, or is demonstrated to have resulted in improved student achievement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6e66dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9905/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mentor teacher","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “mentor teacher” means an elementary or secondary school classroom teacher who assists with the training of students participating in a field-based course.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6e66dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9905/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e6e66de-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/tV/s555"},"text":"Pub. L. 111–358, title V, § 555","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4025"},"text":"124 Stat. 4025","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
