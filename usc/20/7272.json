{"tag":"section","attrib":{"id":"id0e2e01d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272"},"text":null,"children":[{"tag":"num","attrib":{"value":"7272"},"text":"§ 7272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subpart:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2e01d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2e01d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to a grant for activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7273/a/1/A"},"text":"section 7273(a)(1)(A) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0e2e01da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2e01db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe or tribal organization, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2e01dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" one or more nonprofit entities working in formal partnership with not less than 1 of the following entities:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e2e01dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A high-need local educational agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e2e01de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An institution of higher education, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e2e01df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/1/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The office of a chief elected official of a unit of local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e2e01e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/1/A/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Indian tribe or tribal organization, as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to a grant for activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7273/a/1/B"},"text":"section 7273(a)(1)(B) of this title","children":[],"tail":", a consortium of—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0e2e01e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e2e01e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more local educational agencies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e2e01e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Indian Education; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2e01e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more community-based organizations, nonprofit organizations, or other public or private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e01e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full-service community school","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “full-service community school” means a public elementary school or secondary school that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2e01e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participates in a community-based effort to coordinate and integrate educational, developmental, family, health, and other comprehensive services through community-based organizations and public and private partnerships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides access to such services in school to students, families, and the community, such as access during the school year (including before- and after-school hours and weekends), as well as during the summer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e01e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pipeline services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “pipeline services” means a continuum of coordinated supports, services, and opportunities for children from birth through entry into and success in postsecondary education, and career attainment. Such services shall include, at a minimum, strategies to address through services or programs (including integrated student supports) the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2e01ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" High-quality early childhood education programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" High-quality school and out-of-school-time programs and strategies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support for a child’s transition to elementary school, from elementary school to middle school, from middle school to high school, and from high school into and through postsecondary education and into the workforce, including any comprehensive readiness assessment determined necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Family and community engagement and supports, which may include engaging or supporting families at school or at home.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Activities that support postsecondary and workforce readiness, which may include job training, internship opportunities, and career counseling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Community-based support for students who have attended the schools in the area served by the pipeline, or students who are members of the community, facilitating their continued connection to the community and success in postsecondary education and the workforce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Social, health, nutrition, and mental health services and supports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e01f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7272/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Juvenile crime prevention and rehabilitation programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e2e01f2-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4622"},"text":"Pub. L. 89–10, title IV, § 4622","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4601"},"text":"Pub. L. 114–95, title IV, § 4601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2023"},"text":"129 Stat. 2023","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e2e01f3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e2e01f4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e2e01f5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
