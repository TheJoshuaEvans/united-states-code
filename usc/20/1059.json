{"tag":"section","attrib":{"id":"id0cd1cca8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059"},"text":null,"children":[{"tag":"num","attrib":{"value":"1059"},"text":"§ 1059.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of grant","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cd1cca9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award a grant to an eligible institution under this part for 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd1ccaa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this part the Secretary shall give priority to applicants who are not already receiving a grant under this part, except that for the purpose of this subsection a grant under subsection (c) and a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1068c/a/1"},"text":"section 1068c(a)(1) of this title","children":[],"tail":" shall not be considered a grant under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd1ccab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a), the Secretary may award a grant to an eligible institution under this part for a period of one year for the purpose of preparation of plans and applications for a grant under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cd1ccac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1059/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wait-out-period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible institution that received a grant under this part for a 5-year period shall not be eligible to receive an additional grant under this part until 2 years after the date on which the 5-year grant period terminates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cd1ccad-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s313"},"text":"Pub. L. 89–329, title III, § 313","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIII/s301/a"},"text":"Pub. L. 99–498, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1294"},"text":"100 Stat. 1294","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIII/s302/c"},"text":"Pub. L. 102–325, title III, § 302(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/472"},"text":"106 Stat. 472","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/a/6"},"text":"Pub. L. 103–208, § 2(a)(6)","children":[],"tail":", "},{"tag":"date","a