{"tag":"section","attrib":{"id":"id0dd8199e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3426"},"text":null,"children":[{"tag":"num","attrib":{"value":"3426"},"text":"§ 3426.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liaison for Proprietary Institutions of Higher Education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dd8199f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3426/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Department a Liaison for Proprietary Institutions of Higher Education, who shall be an officer of the Department appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd819a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3426/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall appoint, not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"1998-10-07"},"text":"October 7, 1998","children":[],"tail":", a Liaison for Proprietary Institutions of Higher Education who shall be a person who—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dd819a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3426/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has attained a certificate or degree from a proprietary institution of higher education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd819a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3426/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been employed in a proprietary institution setting for not less than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd819a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3426/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Liaison for Proprietary Institutions of Higher Education shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dd819a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3426/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the principal advisor to the Secretary on matters affecting proprietary institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd819a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3426/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guidance to programs within the Department that involve functions affecting proprietary institutions of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd819a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3426/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" work with the Federal Interagency Committee on Education to improve the coordination of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dd819a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3426/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the outreach programs in the numerous Federal departments and agencies that administer education and job training programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dd819a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3426/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborative business and education partnerships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dd819a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3426/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education programs located in, and involving, rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dd819aa-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tII/s219"},"text":"Pub. L. 96–88, title II, § 219","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s961"},"text":"Pub. L. 105–244, title IX, § 961","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1836"},"text":"112 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dd819ab-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dd819ac-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0dd819ad-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
