{"tag":"section","attrib":{"id":"id0c7be419-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i"},"text":null,"children":[{"tag":"num","attrib":{"value":"76i"},"text":"§ 76i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" John F. Kennedy Center for the Performing Arts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c7be41a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall construct for the Smithsonian Institution, with funds raised by voluntary contributions, a building to be designated as the John F. Kennedy Center for the Performing Arts on a site in the District of Columbia bounded by the Inner Loop Freeway on the east, the Theodore Roosevelt Bridge approaches on the south, Rock Creek Parkway on the west, New Hampshire Avenue and F Street on the north, which shall be selected for such purpose by the National Capital Planning Commission. The National Capital Planning Commission shall acquire by purchase, condemnation, or otherwise, lands necessary to provide for the John F. Kennedy Center for the Performing Arts and related facilities. Such building shall be in accordance with plans and specifications approved by the Commission of Fine Arts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c7be41b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parking garage additions and site improvements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c7be41c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Substantially in accordance with the plan entitled “Site Master Plan—Drawing Number 1997–2 ","children":[{"tag":"date","attrib":{"date":"1997-04-29"},"text":"April 29, 1997","children":[],"tail":",” and map number NCR 844/82571, the Board may design and construct—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c7be41d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an addition to the parking garage at each of the north and south ends of the John F. Kennedy Center for the Performing Arts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be41e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" site improvements and modifications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c7be41f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan shall be on file and available for public inspection in the office of the Secretary of the Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c7be420-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of appropriated funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No appropriated funds may be used to pay the costs (including the repayment of obligations incurred to finance costs) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c7be421-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the design and construction of an addition to the parking garage authorized under paragraph (1)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be422-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the design and construction of site improvements and modifications authorized under paragraph (1)(B) that the Board specifically designates will be financed using sources other than appropriated funds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be423-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any project to acquire large screen format equipment for an interpretive theater, or to produce an interpretive film, that the Board specifically designates will be financed using sources other than appropriated funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c7be424-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion project","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c7be425-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to construct","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c7be426-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the requirements of this subsection, the Board may undertake such activities as may be necessary to construct the expansion project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be427-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may construct the expansion project, and shall be responsible for the planning, design, engineering, and construction of the expansion project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be428-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0c7be429-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All activities carried out under this paragraph shall be within the mission of the John F. Kennedy Center for the Performing Arts to serve as the national center for the performing arts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c7be42a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The costs of planning, design, engineering, and construction of the expansion project shall be paid for using nonappropriated funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c7be42b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual operations and maintenance costs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c7be42c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estimates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before awarding a contract for construction of the expansion project, the Board shall estimate any additional annual operations and maintenance costs (or savings) associated with the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be42d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget requests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall account for any additional costs identified under subparagraph (A) in making a budget request for fiscal year 2014 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be42e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget priorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall base a final determination on whether to proceed with the expansion project on the ability of the Board to accommodate any additional costs identified under subparagraph (A) within the other budget priorities of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c7be42f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acknowledgments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may acknowledge private contributions used in carrying out the expansion project in the interior of the project, but may not acknowledge such private contributions on the exterior of the project. Any acknowledgment of private contributions under this paragraph shall be consistent with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s76j/b"},"text":"section 76j(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c7be430-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion project defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “expansion project” means an addition to the south end of the building of the John F. Kennedy Center for the Performing Arts that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c7be431-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is less than 100,000 square feet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be432-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will improve the existing (as of ","children":[{"tag":"date","attrib":{"date":"2012-06-08"},"text":"June 8, 2012","children":[],"tail":") accessibility and education functions of the Center; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c7be433-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76i/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will become part of the existing (as of ","children":[{"tag":"date","attrib":{"date":"2012-06-08"},"text":"June 8, 2012","children":[],"tail":") structure of the Center."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c7be434-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/874/s3"},"text":"Pub. L. 85–874, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1699"},"text":"72 Stat. 1699","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/260/s1/2"},"text":"Pub. L. 88–260, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-01-23"},"text":"Jan. 23, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/4"},"text":"78 Stat. 4","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/95/s2"},"text":"Pub. L. 105–95, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-19"},"text":"Nov. 19, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2148"},"text":"111 Stat. 2148","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/131/s2"},"text":"Pub. L. 112–131, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-06-08"},"text":"June 8, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/377"},"text":"126 Stat. 377","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c7be435-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c7be436-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c7be437-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/131"},"text":"Pub. L. 112–131","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/95"},"text":"Pub. L. 105–95","children":[],"tail":" substituted section catchline for former section catchline, designated existing provisions as subsec. (a) and inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/260"},"text":"Pub. L. 88–260","children":[],"tail":" substituted “John F. Kennedy Center for the Performing Arts” for “National Cultural Center” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
