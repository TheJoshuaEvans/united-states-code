{"tag":"section","attrib":{"id":"id0de18fbd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3998"},"text":null,"children":[{"tag":"num","attrib":{"value":"3998"},"text":"§ 3998.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of grant amounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de18fbe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3998/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to grantees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18fbf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3998/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment by State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State shall pay to the extent of amounts received by it from the Secretary under this part, to each applicant having an application approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3997"},"text":"section 3997 of this title","children":[],"tail":", the Federal share of the cost of the program described in the application."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18fc0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3998/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de18fc1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3998/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), the Federal share for each fiscal year shall be 75 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18fc2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3998/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an applicant that receives a waiver under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3995/c"},"text":"section 3995(c) of this title","children":[],"tail":", the Federal share for each fiscal year may be as much as 100 percent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18fc3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3998/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of payments under this part may be in cash or in kind, fairly evaluated, including plant, equipment, or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18fc4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3998/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), each State shall receive under this part the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18fc5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3998/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to its share of funds appropriated under chapter 1 of the Education Consolidation and Improvement Act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18fc6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3998/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $225,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18fc7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3998/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction for insufficient funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If sums appropriated to carry out this part are not sufficient to permit the Secretary to pay in full the grants which States may receive under subsection (b), the amount of such grants shall be ratably reduced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de18fc8-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tIII/s328"},"text":"Pub. L. 98–377, title III, § 328","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6031/a/2"},"text":"Pub. L. 100–418, title VI, § 6031(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1482"},"text":"102 Stat. 1482","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de18fc9-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de18fca-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0de18fcb-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Education Consolidation and Improvement Act, referred to in subsec. (b)(1), probably means the Education Consolidation and Improvement Act of 1981, which is subtitle D [§§ 551 to 596] of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/463"},"text":"95 Stat. 463","children":[],"tail":". Chapter 1 of the Act was classified generally to subchapter I (§ 3801 et seq.) of chapter 51 of this title, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/tI/s1003/a"},"text":"Pub. L. 100–297, title I, § 1003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/293"},"text":"102 Stat. 293","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
