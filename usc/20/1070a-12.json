{"tag":"section","attrib":{"id":"id0ce74fce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070a–12"},"text":"§ 1070a–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Talent search","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ce74fcf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a program to be known as talent search which shall be designed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce74fd0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify qualified youths with potential for education at the postsecondary level and to encourage such youths to complete secondary school and to undertake a program of postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74fd1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to publicize the availability of, and facilitate the application for, student financial assistance available to persons who pursue a program of postsecondary education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74fd2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage persons who have not completed programs of education at the secondary or postsecondary level to enter or reenter, and complete such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce74fd3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any project assisted under this section shall provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce74fd4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" connections to high quality academic tutoring services, to enable students to complete secondary or postsecondary courses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74fd5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advice and assistance in secondary course selection and, if applicable, initial postsecondary course selection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74fd6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in preparing for college entrance examinations and completing college admission applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74fd7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce74fd8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the full range of Federal student financial aid programs and benefits (including Federal Pell Grant awards and loan forgiveness) and resources for locating public and private scholarships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce74fd9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in completing financial aid applications, including the Free Application for Federal Student Aid described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1090/a"},"text":"section 1090(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74fda-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" guidance on and assistance in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce74fdb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secondary school reentry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce74fdc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative education programs for secondary school dropouts that lead to the receipt of a regular secondary school diploma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce74fdd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entry into general educational development (GED) programs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce74fde-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" postsecondary education; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74fdf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" connections to education or counseling services designed to improve the financial literacy and economic literacy of students or the students’ parents, including financial planning for postsecondary education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce74fe0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any project assisted under this section may provide services such as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce74fe1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic tutoring, which may include instruction in reading, writing, study skills, mathematics, science, and other subjects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74fe2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal and career counseling or activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74fe3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and activities designed to acquaint youth with the range of career options available to the youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74fe4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exposure to the campuses of institutions of higher education, as well as cultural events, academic programs, and other sites or activities not usually available to disadvantaged youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74fe5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" workshops and counseling for families of students served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74fe6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mentoring programs involving elementary or secondary school teachers or counselors, faculty members at institutions of higher education, students, or any combination of such persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74fe7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs and activities as described in subsection (b) or paragraphs (1) through (6) of this subsection that are specially designed for students who are limited English proficient, students from groups that are traditionally underrepresented in postsecondary education, students with disabilities, students who are homeless children and youths (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11434a"},"text":"section 11434a of title 42","children":[],"tail":"), students who are in foster care or are aging out of the foster care system, or other disconnected students."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce74fe8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for approval of applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In approving applications for projects under this section for any fiscal year the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce74fe9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require an assurance that not less than two-thirds of the individuals participating in the project proposed to be carried out under any application be low-income individuals who are first generation college students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74fea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that such participants be persons who either have completed 5 years of elementary education or are at least 11 years of age but not more than 27 years of age, unless the imposition of any such limitation with respect to any person would defeat the purposes of this section or the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–16"},"text":"section 1070a–16 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74feb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require an assurance that individuals participating in the project proposed in the application do not have access to services from another project funded under this section or under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–16"},"text":"section 1070a–16 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce74fec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–12/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require an assurance that the project will be located in a setting accessible to the persons proposed to be served by the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ce74fed-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s402B"},"text":"Pub. L. 89–329, title IV, § 402B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s402/a/4"},"text":"Pub. L. 102–325, title IV, § 402(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/486"},"text":"106 Stat. 486","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s402/b"},"text":"Pub. L. 105–244, title IV, § 402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1654"},"text":"112 Stat. 1654","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s403/b"},"text":"Pub. L. 110–315, title IV, § 403(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3198"},"text":"122 Stat. 3198","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ce74fee-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ce74fef-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ce74ff0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/b/1/A"},"text":"Pub. L. 110–315, § 403(b)(1)(A)","children":[],"tail":", inserted “, and facilitate the application for,” after “the availability of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/b/1/B"},"text":"Pub. L. 110–315, § 403(b)(1)(B)","children":[],"tail":", substituted “to enter or reenter, and complete” for “, but who have the ability to complete such programs, to reenter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/b/3"},"text":"Pub. L. 110–315, § 403(b)(3)","children":[],"tail":", added subsecs. (b) and (c) and struck out former subsec. (b) which related to permissible services. Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/b/2"},"text":"Pub. L. 110–315, § 403(b)(2)","children":[],"tail":", (4), redesignated subsec. (c) as (d) and substituted “projects under this section” for “talent search projects under this division” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s402/b/1"},"text":"Pub. L. 105–244, § 402(b)(1)","children":[],"tail":", added par. (4) and struck out former par. (4) which read as follows: “guidance on secondary school reentry or entry to general educational development (GED) programs or other alternative education programs for secondary school dropouts;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s402/b/2"},"text":"Pub. L. 105–244, § 402(b)(2)","children":[],"tail":", inserted before semicolon “, or activities designed to acquaint individuals from disadvantaged backgrounds with careers in which the individuals are particularly underrepresented”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s402/b/3"},"text":"Pub. L. 105–244, § 402(b)(3)","children":[],"tail":", substituted “families” for “parents”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s402/b/4"},"text":"Pub. L. 105–244, § 402(b)(4)","children":[],"tail":", inserted “or counselors” after “teachers”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ce74ff1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0ce74ff2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
