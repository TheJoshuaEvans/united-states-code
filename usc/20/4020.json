{"tag":"section","attrib":{"id":"id0de4007a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020"},"text":null,"children":[{"tag":"num","attrib":{"value":"4020"},"text":"§ 4020.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de4007b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “asbestos” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de4007c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chrysotile, amosite, or crocidolite; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de4007d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in fibrous form, tremolite, anthophyllite, or actinolite.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de4007e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Attorney General” means the Attorney General of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de4007f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “threat” or “hazard” means that an asbestos material is friable or easily damaged, or within reach of students or employees or otherwise susceptible to damage (including damage from water, vibration, or air circulation) which could result in the dispersal of asbestos fibers into the school environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de40080-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “local educational agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de40081-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any local educational agency as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de40082-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the governing authority of any nonprofit elementary or secondary school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de40083-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “nonprofit elementary or secondary school” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de40084-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any elementary school or secondary school as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":" owned and operated by one or more nonprofit corporations or associations no part of the net earnings of which inures, or may lawfully inure, to the benefit of any private shareholder or individual; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de40085-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any school of any agency of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de40086-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “school buildings” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de40087-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" structures suitable for use as classrooms, laboratories, libraries, school eating facilities, or facilities used for the preparation of food;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de40088-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any gymnasium or other facility which is specially designed for athletic or recreational activities for an academic course in physical education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de40089-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other facilities used for the instruction of students, for research, or for the administration of educational or research programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de4008a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance, storage, or utility facilities essential to the operation of the facilities described in subparagraphs (A) through (C) of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de4008b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Administrator” means the Administrator of the Environmental Protection Agency, or the Administrator’s designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de4008c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means each of the several States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, American Samoa, the Virgin Islands, the Northern Mariana Islands, the Trust Territory of the Pacific Islands, and the Bureau of Indian Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de4008d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4020/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “response action” has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2642/11"},"text":"section 2642(11) of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de4008e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tV/s511"},"text":"Pub. L. 98–377, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1294"},"text":"98 Stat. 1294","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/637"},"text":"Pub. L. 101–637","children":[],"tail":", §§ 10, 14(a)(11), (c)(6), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4592"},"text":"104 Stat. 4592","children":[],"tail":", 4594, 4596; "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s394/c"},"text":"Pub. L. 103–382, title III, § 394(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4027"},"text":"108 Stat. 4027","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1076"},"text":"Pub. L. 107–110, title X, § 1076","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2092"},"text":"115 Stat. 2092","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/dd/2"},"text":"Pub. L. 114–95, title IX, § 9215(dd)(2)","children":