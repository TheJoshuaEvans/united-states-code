 the introductory provisions to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/c/6/B"},"text":"Pub. L. 101–637, § 14(c)(6)(B)","children":[],"tail":", (C), substituted “The” for “the” at beginning and a period for semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/c/6/B"},"text":"Pub. L. 101–637, § 14(c)(6)(B)","children":[],"tail":", (C), substituted “The” for “the” at beginning and a period for semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/c/6/B"},"text":"Pub. L. 101–637, § 14(c)(6)(B)","children":[],"tail":", substituted “The” for “the” at beginning."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s10/2"},"text":"Pub. L. 101–637, § 10(2)","children":[],"tail":", added par. (9)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0de40092-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0de40093-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib"