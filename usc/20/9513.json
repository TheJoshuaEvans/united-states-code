{"tag":"section","attrib":{"id":"id0e600eb5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9513"},"text":null,"children":[{"tag":"num","attrib":{"value":"9513"},"text":"§ 9513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e600eb6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3472"},"text":"section 3472 of this title","children":[],"tail":", the Secretary shall delegate to the Director all functions for carrying out this subchapter (other than administrative and support functions), except that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e600eb7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9513/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nothing in this subchapter or in subchapter III of this chapter (except ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9621/e/1/J"},"text":"section 9621(e)(1)(J) of this title","children":[],"tail":") shall be construed to alter or diminish the role, responsibilities, or authority of the National Assessment Governing Board with respect to the National Assessment of Educational Progress (including with respect to the methodologies of the National Assessment of Educational Progress described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9621/e/1/E"},"text":"section 9621(e)(1)(E) of this title","children":[],"tail":") from those authorized by the National Education Statistics Act of 1994 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9001"},"text":"20 U.S.C. 9001","children":[],"tail":" et seq.) on the day before "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"November 5, 2002","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600eb8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9513/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the National Assessment Governing Board shall continue to be appointed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600eb9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9513/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9621/f/1"},"text":"section 9621(f)(1) of this title","children":[],"tail":" shall apply to the National Assessment Governing Board in the exercise of its responsibilities under this Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600eba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9513/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 9515 and 9516 of this title shall not apply to the National Assessment of Educational Progress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600ebb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9513/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 9515 and 9516 of this title shall not apply to the National Assessment Governing Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e600ebc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may assign the Institute responsibility for administering other activities, if those activities are consistent with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e600ebd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9513/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Institute’s priorities, as approved by the National Board for Education Sciences under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9516"},"text":"section 9516 of this title","children":[],"tail":", and the Institute’s mission, as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9511/b"},"text":"section 9511(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600ebe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9513/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Institute’s mission, but only if those activities do not divert the Institute from its priorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e600ebf-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s113"},"text":"Pub. L. 107–279, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1945"},"text":"116 Stat. 1945","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e600ec0-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e600ec1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e600ec2-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Education Statistics Act of 1994, referred to in subsec. (a)(1), is title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4029"},"text":"108 Stat. 4029","children":[],"tail":", which was classified generally to chapter 71 (§ 9001 et seq.) of this title, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/279/tIV/s403/1"},"text":"Pub. L. 107–279, title IV, § 403(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1985"},"text":"116 Stat. 1985","children":[],"tail":". Provisions relating to education statistics are now contained in part C (§ 9541 et seq.) of this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a)(3), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279"},"text":"Pub. L. 107–279","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1940"},"text":"116 Stat. 1940","children":[],"tail":", which enacted this chapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3419"},"text":"section 3419 of this title","children":[],"tail":", amended sections 1232j, 3412, 3461, 6194, 6311, 6312, 7013, 7451, 7703, 7909, 9007, 9010, 9011, 9573, 9623, and 9624 and former sections 6317, 6491, 6932, 7253c, 7283b, and 7283d of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of Title 5","children":[],"tail":", Government Organization and Employees, transferred sections 9010 and 9011 of this title to sections 9621 and 9622 of this title, respectively, repealed sections 3419, 6011, 6021, 6031, 6041, 6051, 6053 to 6053e, 6054 to 6054b, 6055 to 6055h, 6056, 6056a, 9001 to 9009, and 9012 of this title, enacted provisions set out as notes under section 7703 and 9501 of this title, and repealed provisions set out as notes under sections 1221e and 9001 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
