{"tag":"section","attrib":{"id":"id0e246536-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117"},"text":null,"children":[{"tag":"num","attrib":{"value":"7117"},"text":"§ 7117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities to support well-rounded educational opportunities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e246537-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7116/f"},"text":"section 7116(f) of this title","children":[],"tail":", each local educational agency, or consortium of such agencies, that receives an allocation under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7115/a"},"text":"section 7115(a) of this title","children":[],"tail":" shall use a portion of such funds to develop and implement programs and activities that support access to a well-rounded education and that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e246538-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are coordinated with other schools and community-based services and programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e246539-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be conducted in partnership with an institution of higher education, business, nonprofit organization, community-based organization, or other public or private entity with a demonstrated record of success in implementing activities under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e24653a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include programs and activities, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e24653b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" college and career guidance and counseling programs, such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e24653c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" postsecondary education and career awareness and exploration activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e24653d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training counselors to effectively use labor market information in assisting students with postsecondary education and career planning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e24653e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial literacy and Federal financial aid awareness activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e24653f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs and activities that use music and the arts as tools to support student success through the promotion of constructive student engagement, problem solving, and conflict resolution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e246540-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" programming and activities to improve instruction and student engagement in science, technology, engineering, and mathematics, including computer science, (referred to in this section as “STEM subjects”) such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e246541-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing access for students through grade 12 who are members of groups underrepresented in such subject fields, such as female students, minority students, English learners, children with disabilities, and economically disadvantaged students, to high-quality courses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e246542-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the participation of low-income students in nonprofit competitions related to STEM subjects (such as robotics, science research, invention, mathematics, computer science, and technology competitions);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e246543-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing hands-on learning and exposure to science, technology, engineering, and mathematics and supporting the use of field-based or service learning to enhance the students’ understanding of the STEM subjects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e246544-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the creation and enhancement of STEM-focused specialty schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e246545-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating collaboration among school, after-school program, and informal program personnel to improve the integration of programming and instruction in the identified subjects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e246546-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrating other academic subjects, including the arts, into STEM subject programs to increase participation in STEM subjects, improve attainment of skills related to STEM subjects, and promote well-rounded education;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e246547-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" efforts to raise student academic achievement through accelerated learning programs described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7114/b/3/A/i/IV"},"text":"section 7114(b)(3)(A)(i)(IV) of this title","children":[],"tail":", such as—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0e246548-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimbursing low-income students to cover part or all of the costs of accelerated learning examination fees, if the low-income students are enrolled in accelerated learning courses and plan to take accelerated learning examinations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e246549-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the availability of, and enrollment in, accelerated learning courses, accelerated learning examinations, dual or concurrent enrollment programs, and early college high school courses;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e24654a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities to promote the development, implementation, and strengthening of programs to teach traditional American history, civics, economics, geography, or government education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e24654b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign language instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e24654c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e24654d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs and activities that promote volunteerism and community involvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e24654e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs and activities that support educational programs that integrate multiple disciplines, such as programs that combine arts and mathematics; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e24654f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/a/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities and programs to support student access to, and success in, a variety of well-rounded education experiences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e246550-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7117/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency, or consortium of such agencies, that receives a subgrant under this subpart for fiscal year 2017 may use such funds to cover part or all of the fees for accelerated learning examinations taken by low-income students during the 2016-2017 school year, in accordance with subsection (a)(3)(D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e246551-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4107"},"text":"Pub. L. 89–10, title IV, § 4107","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4101"},"text":"Pub. L. 114–95, title IV, § 4101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1977"},"text":"129 Stat. 1977","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e246552-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e246553-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e246554-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7117, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4117"},"text":"Pub. L. 89–10, title IV, § 4117","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIV/s401"},"text":"Pub. L. 107–110, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1750"},"text":"115 Stat. 1750","children":[],"tail":", related to programs for Native Hawaiians, prior to the general amendment of this subpart by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 7117, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4117"},"text":"Pub. L. 89–10, title IV, § 4117","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3685"},"text":"108 Stat. 3685","children":[],"tail":", related to evaluation and reporting, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s4107"},"text":"section 4107 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3067"},"text":"section 3067 of this title","children":[],"tail":", prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e246555-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e246556-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
