{"tag":"section","attrib":{"id":"id0dd81938-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3423a"},"text":"§ 3423a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Correctional Education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dd81939-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds and declares that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dd8193a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education is important to, and makes a significant contribution to, the readjustment of incarcerated individuals to society; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd8193b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a growing need for immediate action by the Federal Government to assist State and local educational programs for criminal offenders in correctional institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd8193c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this subchapter to encourage and support educational programs for criminal offenders in correctional institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd8193d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Education shall establish within the Department of Education an Office of Correctional Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd8193e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, through the Office of Correctional Education established under subsection (c) of this section, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dd8193f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate all correctional education programs within the Department of Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd81940-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical support to State and local educational agencies and schools funded by the Bureau of Indian Affairs on correctional education programs and curricula;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd81941-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an annual report to the Congress on the progress of the Office of Correctional Education and the status of correctional education in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd81942-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with other Federal agencies carrying out correctional education programs to ensure coordination of such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd81943-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with, and provide outreach to, State directors of correctional education and correctional educators; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd81944-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect from States a sample of information on the number of individuals who complete a vocational education sequence, earn a high school degree or general equivalency diploma, or earn a postsecondary degree while incarcerated and the correlation with job placement, job retention, and recidivism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd81945-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dd81946-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “criminal offender” means any individual who is charged with or convicted of any criminal offense, including a youth offender or a juvenile offender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd81947-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “correctional institution” means any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dd81948-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prison,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dd81949-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jail,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dd8194a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reformatory,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dd8194b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work farm,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dd8194c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detention center, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dd8194d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" halfway house, community-based rehabilitation center, or any other similar institution designed for the confinement or rehabilitation of criminal offenders; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd8194e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3423a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State educational agency” means the State board of education or other agency or officer primarily responsible for the State supervision of public elementary and secondary schools, or, if there is no such officer or agency, an officer or agency designated by the Governor or by State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dd8194f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tII/s212"},"text":"Pub. L. 96–88, title II, § 212","children":[],"tail":", formerly § 214, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/392/tVI/s602/a/3"},"text":"Pub. L. 101–392, title VI, § 602(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-09-25"},"text":"Sept. 25, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/840"},"text":"104 Stat. 840","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tII/s20408/a"},"text":"Pub. L. 103–322, title II, § 20408(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1827"},"text":"108 Stat. 1827","children":[],"tail":"; renumbered § 212, "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII/s271/a/2"},"text":"Pub. L. 103–382, title II, § 271(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3929"},"text":"108 Stat. 3929","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dd81950-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dd81951-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0dd81952-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s212"},"text":"section 212 of Pub. L. 96–88","children":[],"tail":" was renumbered section 211 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3422"},"text":"section 3422 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0dd81953-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “under subsection (c)” for “under subsection (a)” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dd81954-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0dd81955-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/392/tVII/s702"},"text":"Pub. L. 101–392, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-09-25"},"text":"Sept. 25, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/843"},"text":"104 Stat. 843","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/392/tVII/s702"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), the amendments made by this Act [enacting subchapter II of chapter 44 of this title, this section, sections 2311a, 2327, 2328, 2394 to 2394e, 2395 to 2395e, 2396 to 2396m, 2411 to 2420a, 2424, 2466b to 2466e, 2468, 2468b to 2468e, and 3423a of this title, and subchapter III of chapter 20 of Title 25, Indians, amending sections 2301, 2311 to 2313, 2321 to 2324, 2352, 2361 to 2363, 2382, 2391, 2392, 2401 to 2404, 2421 to 2423, 2451, 2463, and 2471 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1812"},"text":"section 1812 of Title 25","children":[],"tail":", and sections 49f, 1533, 1604, and 1661c of Title 29, Labor, repealing sections 1131, 2371 to 2373, 2376 to 2378, 2431, 2462, 2464, 2465, and 3423 of this title, and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2301"},"text":"section 2301 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1991-07-01"},"text":"July 1, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 3, 115, 116, 504, and 512 and part H of title III of the Carl D. Perkins Vocational and Applied Technology Education Act [former sections 2302, 2325, 2326, 2466a, and 2468a of this title and former part H (§ 2397 et seq.) of subchapter III of chapter 44 of this title] (as amended by this Act) shall take effect upon the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-09-25"},"text":"Sept. 25, 1990","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
