{"tag":"section","attrib":{"id":"id0c87f2a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"80q–12"},"text":"§ 80q–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants by Secretary of the Interior to assist Indian tribes with respect to agreements for return of Indian human remains and Indian funerary objects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c87f2aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–12/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior may make grants to Indian tribes to assist such tribes in reaching and carrying out agreements with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c87f2ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–12/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board of Regents for the return of Indian human remains and Indian funerary objects under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80q–9"},"text":"section 80q–9 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f2ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–12/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal and non-Federal entities for additional returns of Indian human remains and Indian funerary objects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c87f2ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–12/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $1,000,000 for fiscal year 1991 and such sums as may be necessary for succeeding fiscal years for grants under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c87f2ae-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/185/s14"},"text":"Pub. L. 101–185, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1345"},"text":"103 Stat. 1345","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
