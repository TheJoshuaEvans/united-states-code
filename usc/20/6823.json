{"tag":"section","attrib":{"id":"id0e1fa9e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823"},"text":null,"children":[{"tag":"num","attrib":{"value":"6823"},"text":"§ 6823.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and specially qualified agency plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e1fa9e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State educational agency and specially qualified agency desiring a grant under this subpart shall submit a plan to the Secretary at such time and in such manner as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1fa9e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each plan submitted under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1fa9e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the process that the agency will use in awarding subgrants to eligible entities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6824/d/1"},"text":"section 6824(d)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa9e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how the agency will establish and implement, with timely and meaningful consultation with local educational agencies representing the geographic diversity of the State, standardized, statewide entrance and exit procedures, including an assurance that all students who may be English learners are assessed for such status within 30 days of enrollment in a school in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa9e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide an assurance that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1fa9ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency will ensure that eligible entities receiving a subgrant under this subpart comply with the requirement in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2/B/ix"},"text":"section 6311(b)(2)(B)(ix) of this title","children":[],"tail":" regarding assessment of English learners in English;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa9eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency will ensure that eligible entities receiving a subgrant under this subpart annually assess the English proficiency of all English learners participating in a program funded under this subpart, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2/G"},"text":"section 6311(b)(2)(G) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa9ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in awarding subgrants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6824"},"text":"section 6824 of this title","children":[],"tail":", the agency will address the needs of school systems of all sizes and in all geographic areas, including school systems with rural and urban schools;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa9ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subgrants to eligible entities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6824/d/1"},"text":"section 6824(d)(1) of this title","children":[],"tail":" will be of sufficient size and scope to allow such entities to carry out effective language instruction educational programs for English learners;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa9ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency will require an eligible entity receiving a subgrant under this subpart to use the subgrant in ways that will build such recipient’s capacity to continue to offer effective language instruction educational programs that assist English learners in meeting challenging State academic standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa9ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency will monitor each eligible entity receiving a subgrant under this subpart for compliance with applicable Federal fiscal requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa9f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan has been developed in consultation with local educational agencies, teachers, administrators of programs implemented under this subpart, parents of English learners, and other relevant stakeholders;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa9f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how the agency will coordinate its programs and activities under this subpart with other programs and activities under this chapter and other Acts, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa9f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe how each eligible entity will be given the flexibility to teach English learners—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1fa9f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using a high-quality, effective language instruction curriculum for teaching English learners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa9f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the manner the eligible entity determines to be the most effective;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa9f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe how the agency will assist eligible entities in meeting—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1fa9f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State-designed long-term goals established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/c/4/A/ii"},"text":"section 6311(c)(4)(A)(ii) of this title","children":[],"tail":", including measurements of interim progress towards meeting such goals, based on the State’s English language proficiency assessment under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2/G"},"text":"section 6311(b)(2)(G) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa9f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the challenging State academic standards;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa9f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how the agency will meet the unique needs of children and youth in the State being served through the reservation of funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6824/d"},"text":"section 6824(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa9f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1fa9fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the agency will monitor the progress of each eligible entity receiving a subgrant under this subpart in helping English learners achieve English proficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa9fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the steps the agency will take to further assist eligible entities if the strategies funded under this subpart are not effective, such as providing technical assistance and modifying such strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1fa9fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, after using a peer review process, shall approve a plan submitted under subsection (a) if the plan meets the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1fa9fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1fa9fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each plan submitted by a State educational agency or specially qualified agency and approved under subsection (c) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1fa9ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain in effect for the duration of the agency’s participation under this subpart; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1faa00-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be periodically reviewed and revised by the agency, as necessary, to reflect changes to the agency’s strategies and programs carried out under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1faa01-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1faa02-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the State educational agency or specially qualified agency amends the plan, the agency shall submit such amendment to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1faa03-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall approve such amendment to an approved plan, unless the Secretary determines that the amendment will result in the agency not meeting the requirements, or fulfilling the purposes, of this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1faa04-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidated plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A plan submitted under subsection (a) may be submitted as part of a consolidated plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7842"},"text":"section 7842 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1faa05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6823/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide technical assistance, if requested by the State, in the development of English proficiency standards and assessments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1faa06-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIII/s3113"},"text":"Pub. L. 89–10, title III, § 3113","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIII/s301"},"text":"Pub. L. 107–110, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1694"},"text":"115 Stat. 1694","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIII/s3003/d"},"text":"Pub. L. 114–95, title III, § 3003(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1956"},"text":"129 Stat. 1956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e1faa07-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e1faa08-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e1faa09-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s3113"},"text":"section 3113 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6813"},"text":"section 6813 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e1faa0a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s3003/d/1"},"text":"Pub. L. 114–95, § 3003(d)(1)","children":[],"tail":", substituted “and in such manner” for “, in such manner, and containing such information”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s3003/d/2/A"},"text":"Pub. L. 114–95, § 3003(d)(2)(A)","children":[],"tail":", substituted “awarding” for “making”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s3003/d/2/B"},"text":"Pub. L. 114–95, § 3003(d)(2)(B)","children":[],"tail":", added pars. (2) to (8) and struck out former pars. (2) to (6) which related to establishing standards and objectives for raising the level of English proficiency, assurances by the agency, coordination of programs and activities under this subpart with other programs and activities, accountability, and flexibility in teaching limited English proficient children, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s3003/d/3"},"text":"Pub. L. 114–95, § 3003(d)(3)","children":[],"tail":", substituted “this subpart” for “this part” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s3003/d/4"},"text":"Pub. L. 114–95, § 3003(d)(4)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7842"},"text":"section 7842 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s3003/d/5"},"text":"Pub. L. 114–95, § 3003(d)(5)","children":[],"tail":", inserted “by the State” after “if requested” and struck out “, objectives,” after “proficiency standards”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e1faa0b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e1faa0c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
