{"tag":"section","attrib":{"id":"id0e64c8e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9572"},"text":null,"children":[{"tag":"num","attrib":{"value":"9572"},"text":"§ 9572.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e64c8e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9572/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National database","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter may be construed to authorize the establishment of a nationwide database of individually identifiable information on individuals involved in studies or other collections of data under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e64c8e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9572/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Government and use of Federal funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter may be construed to authorize an officer or employee of the Federal Government to mandate, direct, or control the curriculum, program of instruction, or allocation of State or local resources of a State, local educational agency, or school, or to mandate a State, or any subdivision thereof, to spend any funds or incur any costs not provided for under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e64c8e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9572/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endorsement of curriculum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of Federal law, no funds provided under this subchapter to the Institute, including any office, board, committee, or center of the Institute, may be used by the Institute to endorse, approve, or sanction any curriculum designed to be used in an elementary school or secondary school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e64c8e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9572/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally sponsored testing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e64c8e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9572/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), no funds provided under this subchapter to the Secretary or to the recipient of any award may be used to develop, pilot test, field test, implement, administer, or distribute any federally sponsored national test in reading, mathematics, or any other subject, unless specifically and explicitly authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c8e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9572/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to international comparative assessments developed under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9543/a/6"},"text":"section 9543(a)(6) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9003/a/6"},"text":"section 9003(a)(6) of this title","children":[],"tail":" (as such section was in effect on the day before "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"November 5, 2002","children":[],"tail":") and administered to only a representative sample of pupils in the United States and in foreign nations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e64c8ea-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s182"},"text":"Pub. L. 107–279, title I, § 182","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1971"},"text":"116 Stat. 1971","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e64c8eb-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e64c8ec-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e64c8ed-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9003"},"text":"Section 9003 of this title","children":[],"tail":", referred to in subsec. (d)(2), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/279/tIV/s403/1"},"text":"Pub. L. 107–279, title IV, § 403(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1985"},"text":"116 Stat. 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
