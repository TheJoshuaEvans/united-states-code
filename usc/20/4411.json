{"tag":"section","attrib":{"id":"id0deb2c07-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4411"},"text":null,"children":[{"tag":"num","attrib":{"value":"4411"},"text":"§ 4411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Institute","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0deb2c08-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established a corporation to be known as the “Institute of American Indian and Alaska Native Culture and Arts Development”, which shall be under the direction and control of a Board of Trustees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4412"},"text":"section 4412 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0deb2c09-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Succession and amendment of charter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The corporation established under subsection (a) shall have succession until dissolved by Act of Congress. Only the Congress shall have the authority to revise or amend the charter of such corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0deb2c0a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXV/s1504"},"text":"Pub. L. 99–498, title XV, § 1504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1601"},"text":"100 Stat. 1601","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0deb2c0b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0deb2c0c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0deb2c0d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Fiscal Year 1988 Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/g/tI/s100"},"text":"Pub. L. 100–202, § 101(g) [title I, § 100]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-213"},"text":"101 Stat. 1329–213","children":[],"tail":", 1329–228, provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/202/s101/g/tI/s100"},"text":"“That notwithstanding any provision of the American Indian, Alaska Native, and Native Hawaiian Culture and Art Development Act [this chapter], the amounts appropriated for fiscal year 1988 for the Bureau of Indian Affairs for the Institute of American Indian Arts shall be available to operate the Institute until the Board of Regents and President of the Institute have been named and had an opportunity to organize, and for use under part A of that Act [this subchapter].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0deb2c0e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Appropriations; Implementation of Chapter; Interim Authority of Secretary","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/h/tI/s100"},"text":"Pub. L. 99–500, § 101(h) [title I, § 100]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-242"},"text":"100 Stat. 1783–242","children":[],"tail":", 1783–255, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/h/tI/s100"},"text":"Pub. L. 99–591, § 101(h) [title I, § 100]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-242"},"text":"100 Stat. 3341–242","children":[],"tail":", 3341–255, provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/591/s101/h/tI/s100"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“That notwithstanding any provision of the American Indian, Alaska Native, and Native Hawaiian Culture and Art Development Act [this chapter], the amounts appropriated for fiscal year 1987 for the Bureau of Indian Affairs for the Institute of American Indian Arts shall be available for use under part A of that Act [this subchapter] and—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that Act shall be implemented in a reasonable period of time and shall be fully implemented by no later than ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" until the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appointment and confirmation of a majority of the members of the Board of Trustees of the Institute of American Indian and Alaska Native Culture and Arts Development under section 1505(a)(1)(A) of that Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4412/a/1/A"},"text":"20 U.S.C. 4412(a)(1)(A)","children":[],"tail":"],"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary of the Interior shall have the authority conferred upon such members under that Act, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" until the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appointment of a President of such Institute under section 1508 of that Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4415"},"text":"20 U.S.C. 4415","children":[],"tail":"],"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary of the Interior shall have the authority conferred upon such members under that Act, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3) [(4)]","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" until the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appointment of a President of such Institute under section 1508 of that Act,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary of the Interior shall have the authority conferred upon the President of such Institute under this [that] Act”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
