d0c7e5586-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0c7e5587-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s76r"},"text":"Section 76r of this title","children":[],"tail":", referred to in subsec. (d), was in the original a reference to "},{"tag":"ref","attrib":{"href":"/us/pl/85/874/s12"},"text":"section 12 of Pub. L. 85–874","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/85/874/s12"},"text":"Section 12 of Pub. L. 85–874","children":[],"tail":" was renumbered as section 13, and a new section 12 was added, by "},{"tag":"ref","attrib":{"href":"/us/pl/107/224/s2"},"text":"Pub. L. 107–224, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-18"},"text":"Sept. 18, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1340"},"text":"116 Stat. 1340","children":[],"tail":". Sections 12 and 13 are classified to sections 76q–1 and 76r, respectively, of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c7e5588-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 4 of title 5.” for “the Inspector General Act of 1978 (5 U.S.C. App.).” and “such chapter” for “such Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/226"},"text":"Pub. L. 105–226","children":[],"tail":" redesignated subsecs. (e) and (f) as (d) and (e), respectively, and struck out heading and text of former subsec. (d). Text read as follows: “Not less than once every 3 years, the Comptroller General shall review and audit the accounts of the John F. Kennedy Center for the Performing Arts for the purpose of examining expenditures of funds appropriated under the authority provided by this subchapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/279/s5/1"},"text":"Pub. L. 103–279, § 5(1)","children":[],"tail":", substituted “the operations of the Board” for “its operations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/279/s5/2"},"text":"Pub. L. 103–279, § 5(2)","children":[],"tail":", added subsecs. (d) to (f) and struck out former subsec. (e) which related to maintenance, repair, alteration, security, information, and other services and former subsec. (f) which related to audits."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/500"},"text":"Pub. L. 102–500","children":[],"tail":" amended par. (3) generally. Prior to amendment, par. (3) read as follows: “There is authorized to be appropriated to the Secretary of the Interior to carry out this subsection—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) for fiscal year 1991, not more than—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) $6,750,000 for annual maintenance, repairs, alterations, and operating services; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) $15,000,000 for deferred maintenance, repairs, and alterations; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) for fiscal year 1992, not more than—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) $9,850,000 for annual maintenance, repairs, alterations, and operating services; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) $15,512,000 for deferred maintenance, repairs, and alterations.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/449/s3"},"text":"Pub. L. 101–449, § 3","children":[],"tail":", struck out subsec. (d) which read as follows: “The Board shall transmit to Congress a detailed report of any memorial which it proposes to provide within the John F. Kennedy Center for the Performing Arts under authority of paragraph (5) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s76j"},"text":"section 76j of this title","children":[],"tail":", and no such memorial shall be provided until the Board of Regents of the Smithsonian Institution shall have approved such memorial.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/449/s1"},"text":"Pub. L. 101–449, § 1","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, subsec. (e) read as follows: “The Secretary of the Interior, acting through the National Park Service, shall provide maintenance, security, information, interpretation, janitorial and all other services necessary to the nonperforming arts functions of the John F. Kennedy Center for the Performing Arts. There is authorized to be appropriated to carry out this subsection not to exceed $2,800,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", $741,000 for the transition period ending "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"September 30, 1976","children":[],"tail":", $3,100,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1977-09-30"},"text":"September 30, 1977","children":[],"tail":", and $4,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"September 30, 1978","children":[],"tail":". There is authorized to be appropriated to carry out this subsection not to exceed $4,200,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":". There is authorized to be appropriated to carry out this subsection not to exceed $4,287,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":", and not to exceed $4,400,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":", and not to exceed $4,544,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":", and not to exceed $4,247,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1983-09-30"},"text":"September 30, 1983","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/449/s2"},"text":"Pub. L. 101–449, § 2","children":[],"tail":", amended subsec. (f) generally. Prior to amendment, subsec. (f) read as follows: “The General Accounting Office is authorized and directed to review and audit, regularly, the accounts of the Kennedy Center for the Performing Arts, for the purpose of determining the continuing ability of the Center to pay its share of future operating costs, and for the purpose of assuring that the cost-of-living formula fairly and accurately reflects the use of the building.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/202"},"text":"Pub. L. 97–202","children":[],"tail":" inserted provisions authorizing an appropriation of not to exceed $4,247,000 for fiscal year ending "},{"tag":"date","attrib":{"date":"1983-09-30"},"text":"Sept. 30, 1983","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"tex