{"tag":"section","attrib":{"id":"id0df9842a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5963"},"text":null,"children":[{"tag":"num","attrib":{"value":"5963"},"text":"§ 5963.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible applicants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0df9842b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5963/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this subchapter, a local educational agency shall demonstrate in the application submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5964/a"},"text":"section 5964(a) of this title","children":[],"tail":" that such agency—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df9842c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5963/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" serves an area in which there is a high rate of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0df9842d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5963/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" homicides committed by persons between the ages 5 to 18, inclusive;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df9842e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5963/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referrals of youth to juvenile court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df9842f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5963/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" youth under the supervision of the courts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df98430-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5963/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expulsions and suspensions of students from school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df98431-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5963/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referrals of youth, for disciplinary reasons, to alternative schools; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df98432-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5963/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" victimization of youth by violence, crime, or other forms of abuse; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df98433-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5963/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has serious school crime, violence, and discipline problems, as indicated by other appropriate data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df98434-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5963/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this subchapter, the Secretary shall give priority to a local educational agency that submits an application that assures a strong local commitment to the projects or activities assisted under this subchapter, such as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df98435-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5963/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the formation of partnerships among the local educational agency, a community-based organization, a nonprofit organization with a demonstrated commitment to or expertise in developing education programs or providing educational services to students or the public, a local law enforcement agency, or any combination thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df98436-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5963/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a high level of youth participation in such projects or activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dfbcd27-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227/tVII/s703"},"text":"Pub. L. 103–227, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/205"},"text":"108 Stat. 205","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
