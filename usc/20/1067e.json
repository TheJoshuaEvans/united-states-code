{"tag":"section","attrib":{"id":"id0cdb42f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1067e"},"text":"§ 1067e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" YES partnerships grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cdb42f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations to carry out this subpart, the Secretary shall make grants to eligible partnerships (as described in subsection (f)) to support the engagement of underrepresented minority youth and youth who are low-income individuals (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1058"},"text":"section 1058 of this title","children":[],"tail":") in science, technology, engineering, and mathematics through outreach and hands-on, experiential-based learning projects that encourage students in kindergarten through grade 12 who are underrepresented minority youth or low-income individuals to pursue careers in science, technology, engineering, and mathematics."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cdb42f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum grant amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded to a partnership under this subpart shall be for an amount that is not less than $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cdb42fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this subpart shall be for a period of five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cdb42fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal matching share required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A partnership receiving a grant under this subpart shall provide, from non-Federal sources, in cash or in-kind, an amount equal to 50 percent of the costs of the project supported by such grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cdb42fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this subpart, the Secretary shall ensure that, to the maximum extent practicable, the projects funded under this subpart are located in diverse geographic regions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cdb42fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the general eligibility provision in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067g"},"text":"section 1067g of this title","children":[],"tail":", eligibility to receive grants under this subpart is limited to partnerships described in paragraph (5) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cdb42fe-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s355"},"text":"Pub. L. 89–329, title III, § 355","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIII/s315/a/2"},"text":"Pub. L. 110–315, title III, § 315(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3182"},"text":"122 Stat. 3182","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tIII/s301/6"},"text":"Pub. L. 111–39, title III, § 301(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1937"},"text":"123 Stat. 1937","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cdb42ff-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cdb4300-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cdb4301-3a70-11f1-a648-bee82ed8a795"},"text":null,"