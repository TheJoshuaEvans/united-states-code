{"tag":"section","attrib":{"id":"id0c8a3c5f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"80r–9"},"text":"§ 80r–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c8a3c60-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Smithsonian Institution to carry out this subchapter, other than sections 80r–5(b) and 80r–6 of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c8a3c61-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–9/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $17,000,000 for fiscal year 2004; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8a3c62-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–9/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8a3c63-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available under subsection (a) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8a3c64-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–9/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds for fundraising","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated pursuant to the authorization under this section may be used to conduct fundraising in support of the Museum from private sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c8a3c65-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/184/s11"},"text":"Pub. L. 108–184, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2682"},"text":"117 Stat. 2682","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
