{"tag":"section","attrib":{"id":"id0e1fa9d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6822"},"text":null,"children":[{"tag":"num","attrib":{"value":"6822"},"text":"§ 6822.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American and Alaska Native children in school","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e1fa9d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6822/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of carrying out programs under this part for individuals served by elementary schools, secondary schools, and postsecondary schools operated predominately for Native American children (including Alaska Native children), the following shall be considered to be an eligible entity:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1fa9d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6822/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa9d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6822/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A tribally sanctioned educational authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa9d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6822/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Native Hawaiian or Native American Pacific Islander native language educational organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa9d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6822/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An elementary school or secondary school that is operated or funded by the Bureau of Indian Education, or a consortium of such schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa9d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6822/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An elementary school or secondary school operated under a contract with or grant from the Bureau of Indian Education, in consortium with another such school or a tribal or community organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa9da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6822/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An elementary school or secondary school operated by the Bureau of Indian Education and an institution of higher education, in consortium with an elementary school or secondary school operated under a contract with or grant from the Bureau of Indian Education or a tribal or community organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1fa9db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6822/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of applications for assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this part, an entity that is considered to be an eligible entity under subsection (a), and that desires to receive Federal financial assistance under this subpart, shall submit an application to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1fa9dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6822/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity described in subsection (a) that receives Federal financial assistance pursuant to this section shall not be eligible to receive a subgrant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6824"},"text":"section 6824 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1fa9dd-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIII/s3112"},"text":"Pub. L. 89–10, title III, § 3112","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIII/s301"},"text":"Pub. L. 107–110, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1694"},"text":"115 Stat. 1694","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIII/s3003/c"},"text":"Pub. L. 114–95, title III, § 3003(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1956"},"text":"129 Stat. 1956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e1fa9de-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e1fa9df-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e1fa9e0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s3112"},"text":"section 3112 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6812"},"text":"section 6812 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e1fa9e1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" substituted “Bureau of Indian Education” for “Bureau of Indian Affairs” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e1fa9e2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e1fa9e3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
