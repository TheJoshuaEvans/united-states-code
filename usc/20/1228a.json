{"tag":"section","attrib":{"id":"id0d908989-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1228a"},"text":"§ 1228a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equity for students, teachers, and other program beneficiaries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d90898a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this section is to assist the Department in implementing the Department’s mission to ensure equal access to education and to promote educational excellence throughout the Nation, by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d90898b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring equal opportunities to participate for all eligible students, teachers, and other program beneficiaries in any project or activity carried out under an applicable program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d90898c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the ability of such students, teachers, and beneficiaries to meet high standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d90898d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to develop steps to ensure equity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require each applicant for assistance under an applicable program (other than an individual) to develop and describe in such applicant’s application the steps such applicant proposes to take to ensure equitable access to, and equitable participation in, the project or activity to be conducted with such assistance, by addressing the special needs of students, teachers, and other program beneficiaries in order to overcome barriers to equitable participation, including barriers based on gender, race, color, national origin, disability, and age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d90898e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish criteria and provide technical assistance for meeting the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d90898f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1228a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to alter in any way the rights or responsibilities established under the laws cited in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221/d"},"text":"section 1221(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d908990-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s427"},"text":"Pub. L. 90–247, title IV, § 427","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII/s236"},"text":"Pub. L. 103–382, title II, § 236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3917"},"text":"108 Stat. 3917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d908991-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d908992-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d908993-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s427"},"text":"section 427 of Pub. L. 90–247","children":[],"tail":" was renumbered section 434, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1231d"},"text":"section 1231d of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s427"},"text":"section 427 of Pub. L. 90–247","children":[],"tail":" was renumbered section 429, and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1231f"},"text":"section 1231f of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d908994-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d908995-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1995-07-01"},"text":"July 1, 1995","children":[],"tail":", for noncompetitive programs in which funds are allocated on the basis of a formula and for programs that are conducted on a competitive basis, with respect to appropriations for use under such programs in fiscal year 1995 and in subsequent fiscal years, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/s3/a/2"},"text":"section 3(a)(2) of Pub. L. 103–382","children":[],"tail":", set out as an Effective Date of 1994 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221"},"text":"section 1221 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
