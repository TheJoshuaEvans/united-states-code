{"tag":"section","attrib":{"id":"id0cec0bd9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070b"},"text":"§ 1070b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose; appropriations authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cec0bda-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of subpart","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this subpart to provide, through institutions of higher education, supplemental grants to assist in making available the benefits of postsecondary education to qualified students who demonstrate financial need in accordance with the provisions of part F of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0bdb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cec0bdc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of enabling the Secretary to make payments to institutions of higher education which have made agreements with the Secretary in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070b–2/a"},"text":"section 1070b–2(a) of this title","children":[],"tail":", for use by such institutions for payments to undergraduate students of supplemental grants awarded to them under this subpart, there are authorized to be appropriated such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0bdd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sums appropriated pursuant to this subsection for any fiscal year shall be available for payments to institutions until the end of the second fiscal year succeeding the fiscal year for which such sums were appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cec0bde-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s413A"},"text":"Pub. L. 89–329, title IV, § 413A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s401/a"},"text":"Pub. L. 99–498, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1328"},"text":"100 Stat. 1328","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s403/b"},"text":"Pub. L. 102–325, title IV, § 403(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/505"},"text":"106 Stat. 505","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s406/a"},"text":"Pub. L. 105–244, title IV, § 406(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1664"},"text":"112 Stat. 1664","children":[],"tail":".; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s406/a"},"text":"Pub. L. 110–315, title IV, § 406(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3215"},"text":"122 Stat. 3215","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cec0bdf-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cec0be0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cec0be1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1070b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s413A"},"text":"Pub. L. 89–329, title IV, § 413A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tI/s131/b/1"},"text":"Pub. L. 92–318, title I, § 131(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/251"},"text":"86 Stat. 251","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/482/tI/s122/a"},"text":"Pub. L. 94–482, title I, § 122(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2094"},"text":"90 Stat. 2094","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/49/s5/a/3"},"text":"Pub. L. 96–49, § 5(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-13"},"text":"Aug. 13, 1979","children":[],"tail":", "},{"tag":"ref","attrib