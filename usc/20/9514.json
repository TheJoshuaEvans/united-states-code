{"tag":"section","attrib":{"id":"id0e600ec3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514"},"text":null,"children":[{"tag":"num","attrib":{"value":"9514"},"text":"§ 9514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of the Director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e600ec4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b)(2), the President, by and with the advice and consent of the Senate, shall appoint the Director of the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e600ec5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e600ec6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall serve for a term of 6 years, beginning on the date of appointment of the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600ec7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, without the advice and consent of the Senate, may appoint the Assistant Secretary for the Office of Educational Research and Improvement (as such office existed on the day before ","children":[{"tag":"date","attrib":{"date":"2002-11-05"},"text":"November 5, 2002","children":[],"tail":") to serve as the first Director of the Institute."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600ec8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent Directors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may make recommendations to the President with respect to the appointment of a Director under subsection (a), other than a Director appointed under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e600ec9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall receive the rate of basic pay for level II of the Executive Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e600eca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall be selected from individuals who are highly qualified authorities in the fields of scientifically valid research, statistics, or evaluation in education, as well as management within such areas, and have a demonstrated capacity for sustained productivity and leadership in these areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e600ecb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e600ecc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer, oversee, and coordinate the activities carried out under the Institute, including the activities of the National Education Centers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600ecd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and approve budgets and operating plans for each of the National Education Centers for submission to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e600ece-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the Director shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e600ecf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To propose to the Board priorities for the Institute, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9515/a"},"text":"section 9515(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600ed0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure the methodology applied in conducting research, development, evaluation, and statistical analysis is consistent with the standards for such activities under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600ed1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To coordinate education research and related activities carried out by the Institute with such research and activities carried out by other agencies within the Department and the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600ed2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To advise the Secretary on research, evaluation, and statistics activities relevant to the activities of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600ed3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To establish necessary procedures for technical and scientific peer review of the activities of the Institute, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9516/b/3"},"text":"section 9516(b)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600ed4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure that all participants in research conducted or supported by the Institute are afforded their privacy rights and other relevant protections as research subjects, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9573"},"text":"section 9573 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":", and sections 1232g and 1232h of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600ed5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure that activities conducted or supported by the Institute are objective, secular, neutral, and nonideological and are free of partisan political influence and racial, cultural, gender, or regional bias.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600ed6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/f/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To undertake initiatives and programs to increase the participation of researchers and institutions that have been historically underutilized in Federal education research activities of the Institute, including historically Black colleges or universities or other institutions of higher education with large numbers of minority students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600ed7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/f/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To coordinate with the Secretary to promote and provide for the coordination of research and development activities and technical assistance activities between the Institute and comprehensive centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600ed8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/f/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To solicit and consider the recommendations of education stakeholders, in order to ensure that there is broad and regular public and professional input from the educational field in the planning and carrying out of the Institute’s activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6257c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/f/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To coordinate the wide dissemination of information on scientifically valid research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6257ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/f/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out and support other activities consistent with the priorities and mission of the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6257cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expert guidance and assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may establish technical and scientific peer-review groups and scientific program advisory committees for research and evaluations that the Director determines are necessary to carry out the requirements of this subchapter. The Director shall appoint such personnel, except that officers and employees of the United States shall comprise no more than ¼ of the members of any such group or committee and shall not receive additional compensation for their service as members of such a group or committee. The Director shall ensure that reviewers are highly qualified and capable to appraise education research and development projects. Chapter 10 of title 5 shall not apply to a peer-review group or an advisory committee established under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6257cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9514/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may, when requested by other officers of the Department, and shall, when directed by the Secretary, review the products and publications of other offices of the Department to certify that evidence-based claims about those products and publications are scientifically valid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e6257cd-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s114"},"text":"Pub. L. 107–279, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1946"},"text":"116 Stat. 1946","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/153"},"text":"Pub. L. 117–286, § 4(a)(153)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4322"},"text":"136 Stat. 4322","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e6257ce-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e6257cf-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e6257d0-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Level II of the Executive Schedule, referred to in subsec. (c), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e6257d1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
