{"tag":"section","attrib":{"id":"id0de40047-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4015"},"text":null,"children":[{"tag":"num","attrib":{"value":"4015"},"text":"§ 4015.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de40048-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4015/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall promulgate rules and regulations as necessary to implement the authorities and requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de40049-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4015/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator also shall establish procedures to be used by local educational agencies, in programs for which financial assistance is made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4014"},"text":"section 4014 of this title","children":[],"tail":", for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de4004a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4015/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" abating asbestos materials in school buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de4004b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4015/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" replacing the asbestos materials removed from school buildings with other appropriate building materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de4004c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4015/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restoring such school buildings to conditions comparable to those existing before asbestos containment or removal activities were undertaken.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de4004d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4015/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing contained in this subchapter shall be construed, interpreted, or applied to diminish in any way the level of protection required under any other State or Federal worker protection or other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de4004e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4015/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to effectuate the purposes of this subchapter, the Administrator may also adopt such other procedures, standards, and regulations as the Administrator deems necessary, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de4004f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4015/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for testing the level of asbestos fibers in schools, including safety measures to be followed in conducting such tests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de40050-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4015/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for evaluating (on the basis of such tests) the likelihood of the leakage of asbestos fibers into the school environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de40051-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4015/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodic reporting with respect to the activities that have taken place using funds loaned or granted under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de40052-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tV/s506"},"text":"Pub. L. 98–377, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1292"},"text":"98 Stat. 1292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/637"},"text":"Pub. L. 101–637","children":[],"tail":", §§ 7, 14(a)(6), (b)(8), (9), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4592"},"text":"104 Stat. 4592","children":[],"tail":", 4594, 4595.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de40053-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de40054-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0de40055-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637"},"text":"Pub. L. 101–637","children":[],"tail":" inserted section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/b/8"},"text":"Pub. L. 101–637, § 14(b)(8)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s7/2"},"text":"Pub. L. 101–637, § 7(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which read as follows: “The Administrator shall also establish—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) procedures to be used by local educational agencies, in programs for which financial assistance is made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4014"},"text":"section 4014 of this title","children":[],"tail":" for—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) abating asbestos materials in school buildings;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) replacing the asbestos materials removed from school buildings with other appropriate building materials; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) restoring such school buildings to conditions comparable to those existing before asbestos containment or removal activities were undertaken; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) within ninety days, standards for determining—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) which contractors are qualified to carry out the activities referred to in paragraph (1), and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) what training, equipment, protective clothing and other information and material must be supplied to adequately advise and protect school employees utilized to carry out the activities in paragraph (1).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) nothing contained in this subchapter shall be construed, interpreted or applied to diminish in any way the level of protection required under State or Federal worker protection laws.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s7/2"},"text":"Pub. L. 101–637, § 7(2)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637"},"text":"Pub. L. 101–637","children":[],"tail":", §§ 7(1), 14(b)(9), redesignated subsec. (c) as (d), inserted heading, and inserted a comma after “standards” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
