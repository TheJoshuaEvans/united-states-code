{"tag":"section","attrib":{"id":"id0d823189-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161e"},"text":"§ 1161e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" American history for freedom","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d82318a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amounts appropriated under subsection (f), the Secretary is authorized to award three-year grants, on a competitive basis, to eligible institutions to establish or strengthen postsecondary academic programs or centers that promote and impart knowledge of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d82318b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" traditional American history;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d82318c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the history and nature of, and threats to, free institutions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d82318d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the history and achievements of Western civilization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d82318e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d82318f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible institution” means an institution of higher education as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823190-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Free institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “free institution” means an institution that emerged out of Western civilization, such as democracy, constitutional government, individual rights, market economics, religious freedom and religious tolerance, and freedom of thought and inquiry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823191-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Traditional American history","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “traditional American history” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d823192-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the significant constitutional, political, intellectual, economic, and foreign policy trends and issues that have shaped the course of American history; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d823193-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the key episodes, turning points, and leading figures involved in the constitutional, political, intellectual, diplomatic, and economic history of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d823194-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d823195-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible institution that desires a grant under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823196-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted under paragraph (1) shall include a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d823197-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how funds made available under this section will be used for the activities set forth under subsection (e), including how such activities will increase knowledge with respect to traditional American history, free institutions, or Western civilization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d823198-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the eligible institution will ensure that information about the activities funded under this section is widely disseminated pursuant to subsection (e)(1)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d823199-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activities to be undertaken pursuant to subsection (e)(2)(A), including identification of entities intended to participate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d82319a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how funds made available under this section shall be used to supplement and not supplant non-Federal funds available for the activities described in subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d82319b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such fiscal controls and accounting procedures as may be necessary to ensure proper disbursement of and accounting for funding made available to the eligible institution under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d82319c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award basis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary shall take into consideration the capability of the eligible institution to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d82319d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase access to quality programming that expands knowledge of traditional American history, free institutions, or Western civilization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d82319e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve personnel with strong expertise in traditional American history, free institutions, or Western civilization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d82319f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sustain the activities funded under this section after the grant has expired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8231a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8231a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds provided under this section shall be used to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8231a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish or strengthen academic programs or centers focused on traditional American history, free institutions, or Western civilization, which may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d8231a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design and implementation of programs of study, courses, lecture series, seminars, and symposia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8231a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development, publication, and dissemination of instructional materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8231a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8231a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support for faculty teaching in undergraduate and, if applicable, graduate programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8231a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support for graduate and postgraduate fellowships, if applicable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8231a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teacher preparation initiatives that stress content mastery regarding traditional American history, free institutions, or Western civilization; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8231a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct outreach activities to ensure that information about the activities funded under this section is widely disseminated—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d8231aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to undergraduate students (including students enrolled in teacher education programs, if applicable);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a1ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to graduate students (including students enrolled in teacher education programs, if applicable);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a1ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to faculty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a1ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to local educational agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a1ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the local community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a1af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowable uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds provided under this section may be used to support—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a1b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collaboration with entities such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d84a1b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local educational agencies, for the purpose of providing elementary and secondary school teachers an opportunity to enhance their knowledge of traditional American history, free institutions, or Western civilization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a1b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit organizations whose mission is consistent with the purpose of this section, such as academic organizations, museums, and libraries, for assistance in carrying out activities described under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a1b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities that meet the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a1b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d84a1b5-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s805"},"text":"Pub. L. 89–329, title VIII, § 805","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3388"},"text":"122 Stat. 3388","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
