{"tag":"section","attrib":{"id":"id0dd8198f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3425"},"text":null,"children":[{"tag":"num","attrib":{"value":"3425"},"text":"§ 3425.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Educational Technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dd81990-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3425/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Department of Education an Office of Educational Technology (hereafter in this section referred to as the “Office”), to be administered by the Director of Educational Technology. The Director of Educational Technology shall report directly to the Secretary and shall perform such additional functions as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd81991-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3425/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Office of Educational Technology (hereafter in this section referred to as the “Director”), through the Office, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dd81992-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3425/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in support of the overall national technology policy and in consultation with other Federal departments or agencies which the Director determines appropriate, provide leadership to the Nation in the use of technology to promote achievement of the National Education Goals and to increase opportunities for all students to achieve State content and challenging State student performance standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd81993-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3425/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review all programs and training functions administered by the Department and recommend policies in order to promote increased use of technology and technology planning throughout all such programs and functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd81994-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3425/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review all relevant programs supported by the Department to ensure that such programs are coordinated with and support the national long-range technology plan developed pursuant to section 5862(b) ","children":[{"tag":"ref","attrib":{"idref":"fn002147"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002147"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd81995-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3425/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such additional functions as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd81996-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3425/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers and employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director is authorized to select, appoint, and employ such officers and employees as may be necessary to carry out the functions of the Office, subject to the provisions of title 5 (governing appointments in the competitive service), and the provisions of chapter 51 and subchapter III of chapter 53 of such title (relating to classification and General Schedule pay rates).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd81997-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3425/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Experts and consultants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may obtain the services of experts and consultants in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dd81998-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tII/s218"},"text":"Pub. L. 96–88, title II, § 218","children":[],"tail":", formerly § 216, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/227/tII/s233/a"},"text":"Pub. L. 103–227, title II, § 233(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/154"},"text":"108 Stat. 154","children":[],"tail":"; renumbered § 218, "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1072/e/3"},"text":"Pub. L. 107–110, title X, § 1072(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2090"},"text":"115 Stat. 2090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dd81999-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dd8199a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0dd8199b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5862"},"text":"Section 5862 of this title","children":[],"tail":", referred to in subsec. (b)(3), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s361/a"},"text":"Pub. L. 103–382, title III, § 361(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3974"},"text":"108 Stat. 3974","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dd8199c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0dd8199d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Office of Training Technology Transfer","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227/tII/s236/a/1"},"text":"Pub. L. 103–227, title II, § 236(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/156"},"text":"108 Stat. 156","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/227/tII/s236/a/1"},"text":"“The Office of Training Technology Transfer as established under section 6103 of the Training Technology Transfer Act of 1988 ([former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5093"},"text":"20 U.S.C. 5093","children":[],"tail":") is transferred to and established in the Office of Educational Technology.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
