{"tag":"section","attrib":{"id":"id0df2584e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5201"},"text":null,"children":[{"tag":"num","attrib":{"value":"5201"},"text":"§ 5201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df2584f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5201/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a permanent endowment for the Eisenhower Exchange Fellowship Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df25850-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5201/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to honor Dwight D. Eisenhower for his character, courage, and patriotism, and for his leadership based on moral integrity and trust;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df25851-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5201/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay tribute to President Eisenhower’s leadership in war and peace, through his diverse understanding of history, practical affairs, and the hearts of humankind;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df25852-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5201/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address America’s need for the best possible higher education of its young talent for a competitive world which shares a common and endangered environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df25853-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5201/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advance the network of friendship and trust already established in President Eisenhower’s name, so that it may continue to grow to the imminent challenges of the 21st century;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df25854-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5201/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to complete Dwight David Eisenhower’s crusade to liberate the people’s of Europe from oppression;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df25855-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5201/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to deepen and expand relationships with European nations developing democracy and self-determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df25856-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5201/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to honor President Dwight D. Eisenhower on the occasion of the centennial of his birth through permanent endowment of an established fellowship program, the Eisenhower Exchange Fellowships, to increase educational opportunities for young leaders in preparation for and enhancement of their professional careers, and advancement of peace through international understanding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0df25857-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/454/s2"},"text":"Pub. L. 101–454, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-24"},"text":"Oct. 24, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1063"},"text":"104 Stat. 1063","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0df25858-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0df25859-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0df2585a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/454"},"text":"Pub. L. 101–454","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-24"},"text":"Oct. 24, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1063"},"text":"104 Stat. 1063","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0df2585b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0df2585c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/454/s1"},"text":"Pub. L. 101–454, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-24"},"text":"Oct. 24, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1063"},"text":"104 Stat. 1063","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/454/s1"},"text":"“This Act [enacting this chapter, amending sections 4901, 4902, and 4904 of Title 22, Foreign Relations and Intercourse, and enacting provisions set out as notes under sections 4901 and 4902 of Title 22] may be cited as the ‘Eisenhower Exchange Fellowship Act of 1990’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
