{"tag":"section","attrib":{"id":"id0c8cace4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"80t–3"},"text":"§ 80t–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director and staff of the Museum","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c8cace5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c8cace6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Museum shall have a Director who shall be appointed by the Secretary, taking into consideration individuals recommended by the council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80t–2"},"text":"section 80t–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8cace7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall manage the Museum subject to the policies of the Board of Regents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8cace8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may appoint 2 additional employees to serve under the Director, except that such additional employees may be appointed without regard to the provisions of title 5 governing appointments in the competitive service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8cace9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The employees appointed by the Secretary under subsection (b) may be paid without regard to the provisions of chapter 51 and subchapter III of chapter 53 of title 5 relating to classification of positions and General Schedule pay rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c8cacea-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dT/tI/s105"},"text":"Pub. L. 116–260, div. T, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2275"},"text":"134 Stat. 2275","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
