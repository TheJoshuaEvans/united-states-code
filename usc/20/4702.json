{"tag":"section","attrib":{"id":"id0defe749-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4702"},"text":null,"children":[{"tag":"num","attrib":{"value":"4702"},"text":"§ 4702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0defe74a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Foundation” means the Barry Goldwater Scholarship and Excellence in Education Foundation established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4703/a"},"text":"section 4703(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe74b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Board” means the Board of Trustees of the Barry Goldwater Scholarship and Excellence in Education Foundation established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4703/b"},"text":"section 4703(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe74c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “fund” means the Barry Goldwater Scholarship and Excellence in Education Fund provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4707"},"text":"section 4707 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe74d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “institution of higher education” means any such institution as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe74e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4702/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means each of the 50 States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, the United States Virgin Islands, American Samoa, the Commonwealth of the Northern Mariana Islands, the Republic of the Marshall Islands, the Federated States of Micronesia, the Republic of Palau, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe74f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4702/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “eligible person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0defe750-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4702/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a permanent resident alien of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0defe751-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4702/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a citizen or national of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0defe752-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4702/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a citizen of the Republic of the Marshall Islands, the Federal States of Micronesia, or the Republic of Palau; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0defe753-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4702/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who may be admitted to lawfully engage in occupations and establish residence as a nonimmigrant in the United States as permitted under the Compact of Free Association agreements with the Republic of the Marshall Islands, the Federal States of Micronesia, or the Republic of Palau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0defe754-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIV/s1403"},"text":"Pub. L. 99–661, div. A, title XIV, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4008"},"text":"100 Stat. 4008","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tI/s102/a/6/H"},"text":"Pub. L. 105–244, title I, § 102(a)(6)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1618"},"text":"112 Stat. 1618","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXIII/s6302"},"text":"Pub. L. 117–81, div. F, title LXIII, § 6302"