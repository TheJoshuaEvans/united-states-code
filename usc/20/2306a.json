{"tag":"section","attrib":{"id":"id0dbb692a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2306a"},"text":"§ 2306a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dbb692b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local control","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall be construed to authorize an officer or employee of the Federal Government—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dbb692c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to condition or incentivize the receipt of any grant, contract, or cooperative agreement, or the receipt of any priority or preference under such grant, contract, or cooperative agreement, upon a State, local educational agency, eligible agency, eligible recipient, eligible entity, or school’s adoption or implementation of specific instructional content, academic standards and assessments, curricula, or program of instruction (including any condition, priority, or preference to adopt the Common Core State Standards developed under the Common Core State Standards Initiative, any other academic standards common to a significant number of States, or any assessment, instructional content, or curriculum aligned to such standards);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dbb692d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through grants, contracts, or other cooperative agreements, to mandate, direct, or control a State, local educational agency, eligible agency, eligible recipient, eligible entity, or school’s specific instructional content, academic standards and assessments, curricula, or program of instruction (including any requirement, direction, or mandate to adopt the Common Core State Standards developed under the Common Core State Standards Initiative, any other academic standards common to a significant number of States, or any assessment, instructional content, or curriculum aligned to such standards); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dbb692e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as required under sections 2322(b), 2391(b), and 2413 of this title—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dbb692f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to mandate, direct, or control the allocation of State or local resources; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb6930-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to mandate that a State or a political subdivision of a State spend any funds or incur any costs not paid for under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dbb6931-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No preclusion of other assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State that declines to submit an application to the Secretary for assistance under this chapter shall not be precluded from applying for assistance under any other program administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dbb6932-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on requiring Federal approval or certification of standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of Federal law, no State shall be required to have academic and career and technical content standards or student academic and career and technical achievement standards approved or certified by the Federal Government, in order to receive assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dbb6933-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section affects the applicability of subchapter II of chapter 5, and chapter 7, of title 5 (commonly known as the “Administrative Procedure Act”) or chapter 8 of title 5, commonly ","children":[{"tag":"ref","attrib":{"idref":"fn002136"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002136"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “title 5 (commonly”."}],"tail":" known as the “Congressional Review Act”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dbb6934-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coherent and rigorous content","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this chapter, coherent and rigorous content shall be determined by the State consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/1"},"text":"section 6311(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dbb6935-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notice and comment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dbb6936-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less than 15 business days prior to issuing a notice of proposed rulemaking related to this chapter in the Federal Register, the Secretary shall provide to the Committee on Health, Education, Labor, and Pensions of the Senate, the Committee on Education and the Workforce of the House of Representatives, and other relevant congressional committees, notice of the Secretary’s intent to issue a notice of proposed rulemaking that shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dbb6937-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the proposed regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb6938-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need to issue the regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb6939-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the regulation is consistent with the scope of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb693a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated burden (including the time, cost, and paperwork burden) the regulation will impose on an eligible agency, institution, or recipient that may be impacted by the regulation, including the potential impact on rural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb693b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated benefits to an eligible agency, institution, or recipient that may be impacted by the regulation, including in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb693c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/f/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any regulations that will be repealed when the new regulation is issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dbb693d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comment period for Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dbb693e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before issuing any notice of proposed rulemaking under this subsection, provide Congress with a comment period of 15 business days to make comments on the proposed regulation, beginning on the date that the Secretary provides the notice of intent to the appropriate committees of Congress under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb693f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include and seek to address all comments submitted by members of Congress in the public rulemaking record for the regulation published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dbb6940-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comment and review period; emergency situations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The comment and review period for any proposed regulation shall be not less than 60 days unless an emergency requires a shorter period, in which case the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dbb6941-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate the proposed regulation as an emergency with an explanation of the emergency in the notice to Congress under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb6942-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the length of the comment and review period in such notice and in the Federal Register; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb6943-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2306a/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct immediately thereafter regional meetings to review such proposed regulation before issuing any final regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dbb6944-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/s8"},"text":"Pub. L. 88–210, § 8","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/690"},"text":"120 Stat. 690","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/n/2"},"text":"Pub. L. 114–95, title IX, § 9215(n)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2169"},"text":"129 Stat. 2169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/s9"},"text":"Pub. L. 115–224, § 9","children":[],"tail":", title II, § 201(b), "},{"tag":"date","attrib":{"date":"2018-07-31"},"text":"July 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1574"},"text":"132 Stat. 1574","children":[],"tail":", 1622.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dbb6945-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dbb6946-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0dbb6947-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/s8"},"text":"section 8 of Pub. L. 88–210","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2307"},"text":"section 2307 of this title","children":[],"tail":" prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/270"},"text":"Pub. L. 109–270","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0dbb6948-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/224/s201/b"},"text":"Pub. L. 115–224, § 201(b)","children":[],"tail":", which made technical amendment to references in original Act which appeared in text as references to sections 2391(b) and 2413 of this title, could not be executed because of the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/s9/1"},"text":"Pub. L. 115–224, § 9(1)","children":[],"tail":", which had already amended those references. See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/224/s9/1"},"text":"Pub. L. 115–224, § 9(1)","children":[],"tail":", substituted “Federal Government—” for “Federal Government to mandate, direct, or control a State, local educational agency, or school’s curriculum, program of instruction, or allocation of State or local resources, or mandate a State or any subdivision thereof to spend any funds or incur any costs not paid for under this chapter, except as required under sections 2322(b), 2391(b), and 2413 of this title.” and added pars. (1) to (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/224/s9/2"},"text":"Pub. L. 115–224, § 9(2)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, text read as follows: “Nothing in this section shall be construed to affect the requirements under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2323"},"text":"section 2323 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/224/s9/3"},"text":"Pub. L. 115–224, § 9(3)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/1"},"text":"section 6311(b)(1) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/1/D"},"text":"section 6311(b)(1)(D) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dbb6949-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0dbb694a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/224"},"text":"Pub. L. 115–224","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/s4"},"text":"section 4 of Pub. L. 115–224","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2301"},"text":"section 2301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0dbb694b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
