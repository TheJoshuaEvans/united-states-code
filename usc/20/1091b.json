{"tag":"section","attrib":{"id":"id0d4dda6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1091b"},"text":"§ 1091b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional refunds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d4dda6c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of subchapter IV funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d4dda6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a recipient of assistance under this subchapter withdraws from an institution during a payment period or period of enrollment in which the recipient began attendance, the amount of grant or loan assistance (other than assistance received under part C) to be returned to the subchapter IV programs is calculated according to paragraph (3) and returned in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d4dda6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leave of absence","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d4dda6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leave not treated as withdrawal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a student who takes 1 or more leaves of absence from an institution for not more than a total of 180 days in any 12-month period, the institution may consider the student as not having withdrawn from the institution during the leave of absence, and not calculate the amount of grant and loan assistance provided under this subchapter that is to be returned in accordance with this section if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d4dda70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution has a formal policy regarding leaves of absence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4dda71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the student followed the institution’s policy in requesting a leave of absence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4dda72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution approved the student’s request in accordance with the institution’s policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d4dda73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consequences of failure to return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a student does not return to the institution at the expiration of an approved leave of absence that meets the requirements of subparagraph (A), the institution shall calculate the amount of grant and loan assistance provided under this subchapter that is to be returned in accordance with this section based on the day the student withdrew (as determined under subsection (c)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d4dda74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of amount of subchapter IV assistance earned","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d4dda75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of grant or loan assistance under this subchapter that is earned by the recipient for purposes of this section is calculated by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d4dda76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the percentage of grant and loan assistance under this subchapter that has been earned by the student, as described in subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4dda77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applying such percentage to the total amount of such grant and loan assistance that was disbursed (and that could have been disbursed) to the student, or on the student’s behalf, for the payment period or period of enrollment for which the assistance was awarded, as of the day the student withdrew.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d4dda78-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Percentage earned","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A)(i), the percentage of grant or loan assistance under this subchapter that has been earned by the student is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d4dda79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equal to the percentage of the payment period or period of enrollment for which assistance was awarded that was completed (as determined in accordance with subsection (d)) as of the day the student withdrew, provided that such date occurs on or before the completion of 60 percent of the payment period or period of enrollment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4dda7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent, if the day the student withdrew occurs after the student has completed (as determined in accordance with subsection (d)) 60 percent of the payment period or period of enrollment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d4dda7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Percentage and amount not earned","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (b), the amount of grant and loan assistance awarded under this subchapter that has not been earned by the student shall be calculated by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d4dda7c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the complement of the percentage of grant assistance under subparts 1 and 3 of part A, or loan assistance under parts B, D, and E, that has been earned by the student described in subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4dda7d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applying the percentage determined under clause (i) to the total amount of such grant and loan assistance that was disbursed (and that could have been disbursed) to the student, or on the student’s behalf, for the payment period or period of enrollment, as of the day the student withdrew.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d4dda7e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Differences between amounts earned and amounts received","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d4dda7f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After determining the eligibility of the student for a late disbursement or post-withdrawal disbursement (as required in regulations prescribed by the Secretary), the institution of higher education shall contact the borrower and obtain confirmation that the loan funds are still required by the borrower. In making such contact, the institution shall explain to the borrower the borrower’s obligation to repay the funds following any such disbursement. The institution shall document in the borrower’s file the result of such contact and the final determination made concerning such disbursement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d4dda80-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the student has received more grant or loan assistance than the amount earned as calculated under paragraph (3)(A), the unearned funds shall be returned by the institution or the student, or both, as may be required under paragraphs (1) and (2) of subsection (b), to the programs under this subchapter in the order specified in subsection (b)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d4dda81-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of subchapter IV program funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d4dda82-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility of the institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The institution shall return not later than 45 days from the determination of withdrawal, in the order specified in paragraph (3), the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d4dda83-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of grant and loan assistance awarded under this subchapter that has not been earned by the student, as calculated under subsection (a)(3)(C); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d4dda84-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an amount equal to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d4dda85-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total institutional charges incurred by the student for the payment period or period of enrollment for which such assistance was awarded; multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4dda86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of grant and loan assistance awarded under this subchapter that has not been earned by the student, as described in subsection (a)(3)(C)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d4dda87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility of the student","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d4dda88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The student shall return assistance that has not been earned by the student as described in subsection (a)(3)(C)(ii) in the order specified in paragraph (3) minus the amount the institution is required to return under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d4dda89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The student (or parent in the case of funds due to a loan borrowed by a parent under part B or D) shall return or repay, as appropriate, the amount determined under subparagraph (A) to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d4dda8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan program under this subchapter in accordance with the terms of the loan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4dda8b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a grant program under this subchapter, as an overpayment of such grant and shall be subject to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d4dda8c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repayment arrangements satisfactory to the institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d4dda8d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overpayment collection procedures prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d4dda8e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant overpayment requirements","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d4dda8f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subparagraphs (A) and (B), a student shall only be required to return grant assistance in the amount (if any) by which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d4dda90-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount to be returned by the student (as determined under subparagraphs (A) and (B)), exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d4dda91-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the total grant assistance received by the student under this subchapter for the payment period or period of enrollment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4dda92-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A student shall not be required to return amounts of $50 or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d4dda93-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers of Federal Pell Grant repayment by students affected by disasters","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive the amounts that students are required to return under this section with respect to Federal Pell Grants if the withdrawals on which the returns are based are withdrawals by students—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d4dda94-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who were residing in, employed in, or attending an institution of higher education that is located in an area in which the President has declared that a major disaster exists, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"section 5170 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4dda95-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose attendance was interrupted because of the impact of the disaster on the student or the institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4dda96-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose withdrawal ended within the academic year during which the designation occurred or during the next succeeding academic year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d4dda97-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers of grant assistance repayment by students affected by disasters","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the waivers authorized by subparagraph (D), the Secretary may waive the amounts that students are required to return under this section with respect to any other grant assistance under this subchapter if the withdrawals on which the returns are based are withdrawals by students—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d4dda98-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who were residing in, employed in, or attending an institution of higher education that is located in an area in which the President has declared that a major disaster exists, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"section 5170 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4dda99-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose attendance was interrupted because of the impact of the disaster on the student or the institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4dda9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose withdrawal ended within the academic year during which the designation occurred or during the next succeeding academic year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d4dda9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order of return of subchapter IV funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d4dda9c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Excess funds returned by the institution or the student, as appropriate, in accordance with paragraph (1) or (2), respectively, shall be credited to outstanding balances on loans made under this subchapter to the student or on behalf of the student for the payment period or period of enrollment for which a return of funds is required. Such excess funds shall be credited in the following order:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d4dda9d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To outstanding balances on loans made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078–8"},"text":"section 1078–8 of this title","children":[],"tail":" for the payment period or period of enrollment for which a return of funds is required."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4dda9e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To outstanding balances on loans made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078"},"text":"section 1078 of this title","children":[],"tail":" for the payment period or period of enrollment for which a return of funds is required."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4dda9f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To outstanding balances on unsubsidized loans (other than parent loans) made under part D for the payment period or period of enrollment for which a return of funds is required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4ddaa0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To outstanding balances on subsidized loans made under part D for the payment period or period of enrollment for which a return of funds is required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4ddaa1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To outstanding balances on loans made under part E for the payment period or period of enrollment for which a return of funds is required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4ddaa2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To outstanding balances on loans made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078–2"},"text":"section 1078–2 of this title","children":[],"tail":" for the payment period or period of enrollment for which a return of funds is required."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4ddaa3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/3/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To outstanding balances on parent loans made under part D for the payment period or period of enrollment for which a return of funds is required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d4ddaa4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remaining excesses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If excess funds remain after repaying all outstanding loan amounts, the remaining excess shall be credited in the following order:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d4ddaa5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To awards under subpart 1 of part A for the payment period or period of enrollment for which a return of funds is required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4ddaa6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To awards under subpart 3 of part A for the payment period or period of enrollment for which a return of funds is required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4ddaa7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To other assistance awarded under this subchapter for which a return of funds is required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d4ddaa8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal date","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d4ddaa9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “day the student withdrew”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d4ddaaa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is the date that the institution determines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d4ddaab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the student began the withdrawal process prescribed by the institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4ddaac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the student otherwise provided official notification to the institution of the intent to withdraw; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d4ddaad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a student who does not begin the withdrawal process or otherwise notify the institution of the intent to withdraw, the date that is the mid-point of the payment period for which assistance under this subchapter was disbursed or a later date documented by the institution; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d4ddaae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for institutions required to take attendance, is determined by the institution from such attendance records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d4ddaaf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), if the institution determines that a student did not begin the withdrawal process, or otherwise notify the institution of the intent to withdraw, due to illness, accident, grievous personal loss, or other such circumstances beyond the student’s control, the institution may determine the appropriate withdrawal date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d4ddab0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Percentage of the payment period or period of enrollment completed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(3)(B), the percentage of the payment period or period of enrollment for which assistance was awarded that was completed, is determined—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d4ddab1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a program that is measured in credit hours, by dividing the total number of calendar days comprising the payment period or period of enrollment for which assistance is awarded into the number of calendar days completed in that period as of the day the student withdrew; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d4ddab2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a program that is measured in clock hours, by dividing the total number of clock hours comprising the payment period or period of enrollment for which assistance is awarded into the number of clock hours scheduled to be completed by the student in that period as of the day the student withdrew.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d4ddab3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1091b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall take effect 2 years after ","children":[{"tag":"date","attrib":{"date":"1998-10-07"},"text":"October 7, 1998","children":[],"tail":". An institution of higher education may choose to implement such provisions prior to that date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d4ddab4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s484B"},"text":"Pub. L. 89–329, title IV, § 484B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s485/a"},"text":"Pub. L. 102–325, title IV, § 485(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/619"},"text":"106 Stat. 619","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/h/26"},"text":"Pub. L. 103–208, § 2(h)(26)","children":[],"tail":", (27), "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2477"},"text":"107 Stat. 2477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s485"},"text":"Pub. L. 105–244, title IV, § 485","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1737"},"text":"112 Stat. 1737","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/66/s2"},"text":"Pub. L. 109–66, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-09-21"},"text":"Sept. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1999"},"text":"119 Stat. 1999","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/67/s2"},"text":"Pub. L. 109–67, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-09-21"},"text":"Sept. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2001"},"text":"119 Stat. 2001","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tVIII/s8022"},"text":"Pub. L. 109–171, title VIII, § 8022","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/178"},"text":"120 Stat. 178","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d4ddab5-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d4ddab6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d4ddab7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1091b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s503"},"text":"Pub. L. 89–329, title V, § 503","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/35/s2/c"},"text":"Pub. L. 90–35, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-06-29"},"text":"June 29, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/83"},"text":"81 Stat. 83","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tIV/s451/a"},"text":"Pub. L. 92–318, title IV, § 451(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/344"},"text":"86 Stat. 344","children":[],"tail":", authorized the Commissioner to appraise and annually report on existing and future education personnel needs, prior to repeal, effective "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/94/482/tI/s151/a/2"},"text":"Pub. L. 94–482, title I, § 151(a)(2)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2151"},"text":"90 Stat. 2151","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d4ddab8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8022/1"},"text":"Pub. L. 109–171, § 8022(1)","children":[],"tail":", substituted “1 or more leaves of” for “a leave of” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8022/2"},"text":"Pub. L. 109–171, § 8022(2)","children":[],"tail":", inserted “(as determined in accordance with subsection (d))” after “student has completed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8022/3"},"text":"Pub. L. 109–171, § 8022(3)","children":[],"tail":", substituted “grant assistance under subparts 1 and 3 of part A, or loan assistance under parts B, D, and E,” for “grant or loan assistance under this subchapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8022/4"},"text":"Pub. L. 109–171, § 8022(4)","children":[],"tail":", amended heading and text of subpar. (A) generally. Prior to amendment, text read as follows: “If the student has received less grant or loan assistance than the amount earned as calculated under subparagraph (A) of paragraph (3), the institution of higher education shall comply with the procedures for late disbursement specified by the Secretary in regulations.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8022/5"},"text":"Pub. L. 109–171, § 8022(5)","children":[],"tail":", inserted “not later than 45 days from the determination of withdrawal” after “return” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8022/6"},"text":"Pub. L. 109–171, § 8022(6)","children":[],"tail":", amended heading and text of subpar. (C) generally. Prior to amendment, text read as follows: “Notwithstanding subparagraphs (A) and (B), a student shall not be required to return 50 percent of the grant assistance received by the student under this subchapter, for a payment period or period of enrollment, that is the responsibility of the student to repay under this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8022/7"},"text":"Pub. L. 109–171, § 8022(7)","children":[],"tail":", (8), in introductory provisions, substituted “(a)(3)(B)” for “(a)(3)(B)(i)” and, in par. (2), substituted “clock hours scheduled to be completed by the student in that period as of the day the student withdrew.” for “clock hours—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) completed by the student in that period as of the day the student withdrew; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) scheduled to be completed as of the day the student withdrew, if the clock hours completed in the period are not less than a percentage, to be determined by the Secretary in regulations, of the hours that were scheduled to be completed by the student in the period.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/66"},"text":"Pub. L. 109–66","children":[],"tail":" added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/67"},"text":"Pub. L. 109–67","children":[],"tail":" added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" amended section catchline and text generally. Prior to amendment, section consisted of subsecs. (a) to (c) requiring each institution of higher education participating in a program under this subchapter to have in effect a fair and equitable refund policy for refunding unearned tuition, fees, room and board, and other charges to students or parents who received grant or loan assistance under this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/h/26"},"text":"Pub. L. 103–208, § 2(h)(26)","children":[],"tail":", substituted “grant or loan assistance” for “grant, loan, or work assistance” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/h/27"},"text":"Pub. L. 103–208, § 2(h)(27)","children":[],"tail":", substituted “subsection (c) of this section” for “subsection (d) of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d4ddab9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d4ddaba-3a70-11f1-a648-bee82ed8a795"},"text":null,"chil