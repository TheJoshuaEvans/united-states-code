{"tag":"section","attrib":{"id":"id0d718f22-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1131a"},"text":"§ 1131a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study abroad program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d718f23-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute shall conduct, by grant or contract, a junior year abroad program. The junior year abroad program shall be open to eligible students at institutions of higher education, including historically Black colleges and universities, tribally controlled colleges or universities, Alaska Native-serving, Native Hawaiian-serving, and Hispanic-serving institutions, and other institutions of higher education with significant minority student populations. Eligible student expenses shall be shared by the Institute and the institution at which the student is in attendance. Each student may spend not more than 9 months abroad in a program of academic study, as well as social, familial and political interactions designed to foster an understanding of and familiarity with the language, culture, economics and governance of the host country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d718f24-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Eligible student” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this section, the term “eligible student” means a student that is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d718f25-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrolled full-time in a baccalaureate degree program at an institution of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718f26-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entering the third year of study, or completing the third year of study in the case of a summer abroad program, at an institution of higher education which nominates such student for participation in the study abroad program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d718f27-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education desiring to send a student on the study abroad program shall enter into a Memorandum of Understanding with the Institute under which such institution of higher education agrees to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d718f28-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the requisite academic preparation for students participating in the study abroad or internship programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718f29-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay one-third the cost of each student it nominates for participation in the study abroad program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718f2a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet such other requirements as the Secretary may from time to time, by regulation, reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d718f2b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s623"},"text":"Pub. L. 89–329, title VI, § 623","children":[],"tail":", formerly § 622, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tVI/s601"},"text":"Pub. L. 102–325, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/734"},"text":"106 Stat. 734","children":[],"tail":"; renumbered § 623 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVI/s603/b/1"},"text":"Pub. L. 105–244, title VI, § 603(b)(1)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1783"},"text":"112 Stat. 1783","children":[],"tail":", 1784; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVI/s614"},"text":"Pub. L. 110–315, title VI, § 614","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3340"},"text":"122 Stat. 3340","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d718f2c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d718f2d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d718f2e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s623"},"text":"section 623 of Pub. L. 89–329","children":[],"tail":" was renumbered section 624 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1131b"},"text":"section 1131b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d718f2f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" struck out “as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061"},"text":"section 1061 of this title","children":[],"tail":"” after “Black colleges and universities” and substituted “tribally controlled colleges or universities, Alaska Native-serving, Native Hawaiian-serving, and Hispanic-serving institutions” for “tribally controlled Indian community colleges as defined in the Tribally Controlled Community College Assistance Act of 1978”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s603/c/1"},"text":"Pub. L. 105–244, § 603(c)(1)","children":[],"tail":", substituted “Study” for “Junior year” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s603/c/2"},"text":"Pub. L. 105–244, § 603(c)(2)","children":[],"tail":", inserted “, or completing the third year of study in the case of a summer abroad program,” after “year of study” and substituted “study abroad” for “junior year abroad”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s603/c/3/A"},"text":"Pub. L. 105–244, § 603(c)(3)(A)","children":[],"tail":", substituted “study abroad” for “junior year abroad” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s603/c/3/B"},"text":"Pub. L. 105–244, § 603(c)(3)(B)","children":[],"tail":", substituted “study abroad” for “junior year abroad”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s603/c/3/C"},"text":"Pub. L. 105–244, § 603(c)(3)(C)","children":[],"tail":", substituted “one-third” for “one-half” and “study abroad” for “junior year abroad”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d718f30-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d718f31-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{