{"tag":"section","attrib":{"id":"id0d6a636e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1103d"},"text":"§ 1103d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to institutions under other programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6a636f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Hispanic-serving institution that the Secretary determines to be an institution eligible under this subchapter may be eligible for waivers in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a6370-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver applicability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6a6371-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to, and in accordance with, regulations promulgated for the purpose of this section, in the case of any application by a Hispanic-serving institution referred to in subsection (a) for assistance under any programs specified in paragraph (2), the Secretary is authorized, if such application is otherwise approvable, to waive any requirement for a non-Federal share of the cost of the program or project, or, to the extent not inconsistent with other law, to give, or require to be given, priority consideration of the application in relation to applications from other institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6a6372-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall apply to any program authorized by subchapter IV or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1124"},"text":"section 1124 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a6373-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not waive, under subsection (b), the non-Federal share requirement for any program for applications which, if approved, would require the expenditure of more than 10 percent of the appropriations for the program for any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6a6374-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s525"},"text":"Pub. L. 89–329, title V, § 525","children":[],"tail":", formerly § 515, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tV/s501"},"text":"Pub. L. 105–244, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"