{"tag":"section","attrib":{"id":"id0df7129c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5609"},"text":null,"children":[{"tag":"num","attrib":{"value":"5609"},"text":"§ 5609.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0df7129d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5609/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Trust Fund $2,000,000 for each of fiscal years 2020 through 2029 to carry out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df7129e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5609/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental Dispute Resolution Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated to the Environmental Dispute Resolution Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5607a"},"text":"section 5607a of this title","children":[],"tail":" $4,000,000 for each of fiscal years 2020 through 2029, of which—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df7129f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5609/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000,000 shall be used to pay operations costs (including not more than $1,000 for official reception and representation expenses); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df712a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5609/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 shall be used for grants or other appropriate arrangements to pay the costs of services provided in a neutral manner relating to, and to support the participation of non-Federal entities (such as State and local governments, tribal governments, nongovernmental organizations, and individuals) in, environmental conflict resolution proceedings involving Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df712a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5609/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training of professionals in health care and public policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5604/7"},"text":"section 5604(7) of this title","children":[],"tail":" $12,300,000 for the 5-fiscal year period beginning with fiscal year 2025."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0df712a2-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/259/s13"},"text":"Pub. L. 102–259, § 13","children":[],"tail":", formerly § 11, "},{"tag":"date","attrib":{"date":"1992-03-19"},"text":"Mar. 19, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/84"},"text":"106 Stat. 84","children":[],"tail":"; renumbered § 13 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/156"},"text":"Pub. L. 105–156","children":[],"tail":", §§ 6(a), 8, "},{"tag":"date","attrib":{"date":"1998-02-11"},"text":"Feb. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/9"},"text":"112 Stat. 9","children":[],"tail":", 12; "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tVIII/s817/c"},"text":"Pub. L. 106–568, title VIII, § 817(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2918"},"text":"114 Stat. 2918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/160/s2"},"text":"Pub. L. 108–160, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2013"},"text":"117 Stat. 2013","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tIII/s309"},"text":"Pub. L. 116–94, div. P, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3191"},"text":"133 Stat. 3191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/47/dG/tII/s203"},"text":"Pub. L. 118–47, div. G, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-23"},"text":"Mar. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/858"},"text":"138 Stat. 858","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0df712a3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0df712a4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0df712a5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47/s203/1"},"text":"Pub. L. 118–47, § 203(1)","children":[],"tail":", substituted “2029” for “2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47/s203/2"},"text":"Pub. L. 118–47, § 203(2)","children":[],"tail":", substituted “2029” for “2023” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47/s203/3"},"text":"Pub. L. 118–47, § 203(3)","children":[],"tail":", substituted “5-fiscal year period beginning with fiscal year 2025.” for “5-fiscal year period beginning with the fiscal year in which this subsection is enacted.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s309/1"},"text":"Pub. L. 116–94, § 309(1)","children":[],"tail":", substituted “$2,000,000 for each of fiscal years 2020 through 2023” for “$40,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s309/2"},"text":"Pub. L. 116–94, § 309(2)","children":[],"tail":", substituted “fiscal years 2020 through 2023” for “fiscal years 2004 through 2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/160"},"text":"Pub. L. 108–160","children":[],"tail":" added subsec. (b) and struck out former subsec. (b) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“There are authorized to be appropriated to the Environmental Dispute Resolution Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5607a"},"text":"section 5607a of this title","children":[],"tail":"—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) $4,250,000 for fiscal year 1998, of which—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) $3,000,000 shall be for capitalization; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) $1,250,000 shall be for operation costs; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) $1,250,000 for each of the fiscal years 1999 through 2002 for operation costs.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568"},"text":"Pub. L. 106–568","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/156/s8"},"text":"Pub. L. 105–156, § 8","children":[],"tail":", designated existing provisions as subsec. (a), inserted heading, substituted “There is authorized to be appropriated to the Trust Fund” for “There are authorized to be appropriated to the Fund”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
