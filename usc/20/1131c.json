{"tag":"section","attrib":{"id":"id0d718f38-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1131c"},"text":"§ 1131c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d718f39-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute shall enter into agreements with historically Black colleges and universities, tribally controlled colleges or universities, Alaska Native-serving, Native Hawaiian-serving, and Hispanic-serving institutions, other institutions of higher education with significant numbers of minority students, and institutions of higher education with programs in training foreign service professionals, to provide academic year internships during the junior and senior year and summer internships following the sophomore and junior academic years, by work placements with international, voluntary or government organizations or agencies, including the Agency for International Development, the Department of State,","children":[{"tag":"ref","attrib":{"idref":"fn002113"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002113"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. “Department of State” appears twice."}],"tail":" the International Monetary Fund, the National Security Council, the Organization of American States, the Export-Import Bank, the United States International Development Finance Corporation, the Department of State,"},{"tag":"ref","attrib":{"idref":"fn002113"},"text":"1","children":[],"tail":" Office of the United States Trade Representative, the World Bank, and the United Nations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d718f3a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postbaccalaureate internships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Institute shall enter into agreements with institutions of higher education described in the first sentence of subsection (a) to conduct internships for students who have completed study for a baccalaureate degree. The internship program authorized by this subsection shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d718f3b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the students to prepare for a master’s degree program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718f3c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be carried out with the assistance of the Woodrow Wilson International Center for Scholars; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718f3d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain work experience for the students designed to contribute to the students’ preparation for a master’s degree program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d718f3e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Committee on Minority Careers in International Affairs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d718f3f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established in the executive branch of the Federal Government an Interagency Committee on Minority Careers in International Affairs composed of not less than 7 members, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d718f40-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary of Agriculture for Trade and Foreign Agricultural Affairs, or the designee of that Under Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718f41-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary and Director General, of the United States and Foreign Commercial Service of the Department of Commerce, or the Assistant Secretary and Director General’s designee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718f42-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary of Defense for Personnel and Readiness of the Department of Defense, or the Under Secretary’s designee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718f43-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary for Postsecondary Education in the Department of Education, or the Assistant Secretary’s designee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718f44-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director General of the Foreign Service of the Department of State, or the Director General’s designee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718f45-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the General Counsel of the Agency for International Development, or the General Counsel’s designee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d718f46-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Interagency Committee established by this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d718f47-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on an annual basis inform the Secretary and the Institute regarding ways to advise students participating in the internship program assisted under this section with respect to goals for careers in international affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718f48-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" locate for students potential internship opportunities in the Federal Government related to international affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d718f49-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote policies in each department and agency participating in the Committee that are designed to carry out the objectives of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d718f4a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s625"},"text":"Pub. L. 89–329, title VI, § 625","children":[],"tail":", formerly § 624, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tVI/s601"},"text":"Pub. L. 102–325, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/735"},"text":"106 Stat. 735","children":[],"tail":"; renumbered § 625, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVI/s603/b/1"},"text":"Pub. L. 105–244, title VI, § 603(b)(1)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1783"},"text":"112 Stat. 1783","children":[],"tail":", 1784; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIII, § 1335(j), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-788"},"text":"112 Stat. 2681–788","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVI/s616"},"text":"Pub. L. 110–315, title VI, § 616","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3341"},"text":"122 Stat. 3341","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tVI/s1470/i"},"text":"Pub. L. 115–254, div. F, title VI, § 1470(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3516"},"text":"132 Stat. 3516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12405/d"},"text":"Pub. L. 115–334, title XII, § 12405(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4975"},"text":"132 Stat. 4975","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d718f4b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d718f4c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d718f4d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s625"},"text":"section 625 of Pub. L. 89–329","children":[],"tail":" was renumbered section 626 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1131d"},"text":"section 1131d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d718f4e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" substituted “United States International Development Finance Corporation” for “Overseas Private Investment Corporation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “Under Secretary of Agriculture for Trade and Foreign Agricultural Affairs, or the designee of that Under Secretary” for “Under Secretary for Farm and Foreign Agricultural Services of the Department of Agriculture, or the Under Secretary’s designee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s616/1"},"text":"Pub. L. 110–315, § 616(1)","children":[],"tail":", struck out “as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061"},"text":"section 1061 of this title","children":[],"tail":"” after “Black colleges and universities” and substituted “tribally controlled colleges or universities, Alaska Native-serving, Native Hawaiian-serving, and Hispanic-serving institutions” for “tribally controlled Indian community colleges as defined in the Tribally Controlled Community College Assistance Act of 1978”, “international,” for “an international”, and “the Department of State” for “the United States Information Agency” after “Development,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s616/2"},"text":"Pub. L. 110–315, § 616(2)","children":[],"tail":", inserted “and” after semicolon at end of par. (2), substituted a period for “; and” at end of par. (3), and struck out par. (4) which read as follows: “be assisted by the Interagency Committee on Minority Careers in International Affairs established under subsection (c) of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(E) to (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s616/3"},"text":"Pub. L. 110–315, § 616(3)","children":[],"tail":", inserted “and” after semicolon at end of subpar. (E), substituted a period for “; and” at end of subpar. (F), and struck out subpar. (G) which read as follows: “the Associate Director for Educational and Cultural Affairs of the United States Information Agency, or the Associate Director’s designee.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s603/d"},"text":"Pub. L. 105–244, § 603(d)","children":[],"tail":", designated existing provisions as subsec. (a), inserted heading, and added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", which directed the amendment of “"},{"tag":"ref","attrib":{"href":"/us/pl/89/329/s624"},"text":"section 624 of Pub. L. 89–329","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1131c"},"text":"20 U.S.C. 1131c","children":[],"tail":")” by striking “the United States Information Agency,” after “Agency for International Development,”, could not be executed because of the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" which renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/89/329/s624"},"text":"section 624 of Pub. L. 89–329","children":[],"tail":" as section 625."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d74004f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d740050-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" effective at the end of the transition period, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9681"},"text":"section 9681 of Title 22","children":[],"tail":", Foreign Relations and Intercourse, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1470/w"},"text":"section 1470(w) of Pub. L. 115–254","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s905"},"text":"section 905 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d740051-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1301"},"text":"section 1301 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6531"},"text":"section 6531 of Title 22","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
