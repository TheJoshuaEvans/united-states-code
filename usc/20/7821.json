{"tag":"section","attrib":{"id":"id0e4cfb22-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821"},"text":null,"children":[{"tag":"num","attrib":{"value":"7821"},"text":"§ 7821.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation of State administrative funds for elementary and secondary education programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e4cfb23-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation of administrative funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e4cfb24-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State educational agency may consolidate the amounts specifically made available to it for State administration under one or more of the programs under paragraph (2) if the State educational agency can demonstrate that the majority of its resources are derived from non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfb25-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section applies to any program under this chapter under which funds are authorized to be used for administration, and such other programs as the Secretary may designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4cfb26-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e4cfb27-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State educational agency shall use the amount available under this section for the administration of the programs included in the consolidation under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfb28-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State educational agency may also use funds available under this section for administrative activities designed to enhance the effective and coordinated use of funds under programs included in the consolidation under subsection (a), such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4cfb29-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination of those programs with other Federal and non-Federal programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4cfb2a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment and operation of peer-review mechanisms under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4cfb2b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administration of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4cfb2c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dissemination of information regarding model programs and practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4cfb2d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance under any program under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4cfb2e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State-level activities designed to carry out this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4cfb2f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training personnel engaged in audit and other monitoring activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4cfb30-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation of the Cooperative Audit Resolution and Oversight Initiative of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4cfb31-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation of fiscal support teams that provide technical fiscal support assistance, which shall include evaluating fiscal, administrative, and staffing functions, and any other key operational function.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4cfb32-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State educational agency that consolidates administrative funds under this section shall not be required to keep separate records, by individual program, to account for costs relating to the administration of programs included in the consolidation under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4cfb33-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To determine the effectiveness of State administration under this section, the Secretary may periodically review the performance of State educational agencies in using consolidated administrative funds under this section and take such steps as the Secretary finds appropriate to ensure the effectiveness of that administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4cfb34-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unused administrative funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State educational agency does not use all of the funds available to the agency under this section for administration, the agency may use those funds during the applicable period of availability as funds available under one or more programs included in the consolidation under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4cfb35-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7821/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation of funds for standards and assessment development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to develop challenging State academic standards and assessments, a State educational agency may consolidate the amounts described in subsection (a) for those purposes under subchapter I.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e4cfb36-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8201"},"text":"Pub. L. 89–10, title VIII, § 8201","children":[],"tail":", formerly title IX, § 9201, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1966"},"text":"115 Stat. 1966","children":[],"tail":"; renumbered title VIII, § 8201, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII"},"text":"Pub. L. 114–95, title VIII","children":[],"tail":", §§ 8001(a)(2), 8005, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089, 2100.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e4cfb37-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e4cfb38-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e4cfb39-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(2)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8005"},"text":"Pub. L. 114–95, § 8005","children":[],"tail":", added subpar. (I)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e4cfb3a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e4cfb3b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
