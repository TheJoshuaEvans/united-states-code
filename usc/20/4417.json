{"tag":"section","attrib":{"id":"id0deb2c98-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4417"},"text":null,"children":[{"tag":"num","attrib":{"value":"4417"},"text":"§ 4417.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Institute","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0deb2c99-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4417/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Primary functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The primary functions of the Institute shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0deb2c9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4417/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide scholarly study of, and instruction in, Indian art and culture, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4417/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish programs which culminate in the awarding of degrees in the various fields of Indian art and culture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0deb2c9c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4417/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0deb2c9d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4417/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall be responsible for establishing the policies and internal organization that relate to the control and monitoring of all subdivisions, administrative entities, and departments of the Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c9e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4417/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The specific responsibilities of each subdivision, entity, and department of the Institute are solely within the discretion of the Board, or its designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c9f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4417/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall establish, within the Institute, departments for the study of culture and arts and for research and exchange, and a museum. The Board shall establish the areas of competency for the departments created under this paragraph, which may include (but are not limited to) Departments of Arts and Sciences, Visual Arts, Performing Arts, Language, Literature and Museology and a learning resources center, programs of institutional support and development, research programs, fellowship programs, seminars, publications, scholar-in-residence programs and inter-institutional programs of cooperation at national and international levels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0deb2ca0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4417/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the centers and programs described in subsection (b), the Institute shall develop such programs and centers as the Board determines are necessary to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0deb2ca1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4417/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" foster research and scholarship in Indian art and culture through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0deb2ca2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4417/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resident programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0deb2ca3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4417/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperative programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0deb2ca4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4417/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2ca5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4417/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complement existing tribal programs for the advancement of Indian art and culture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2ca6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4417/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate efforts to preserve, support, revitalize, and develop evolving forms of Indian art and culture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0deb2ca7-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXV/s1510"},"text":"Pub. L. 99–498, title XV, § 1510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1606"},"text":"100 Stat. 1606","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/644/tV/s502"},"text":"Pub. L. 101–644, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4668"},"text":"104 Stat. 4668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tXIII/s1331/d"},"text":"Pub. L. 102–325, title XIII, § 1331(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/807"},"text":"106 Stat. 807","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0deb2ca8-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0deb2ca9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0deb2caa-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “There shall be established within the Institute—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) a Center for Culture and Art Studies to be administered by a director (appointed by the President of the Institute, with the approval of the Board), which shall include (but not be limited to) Departments of Arts and Sciences, Visual Arts, Performing Arts, Language, Literature, and Museology;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) a Center for Research and Cultural Exchange, administered by a director (appointed by the President of the Institute, with the approval of the Board), which shall include—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) a learning resources center;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) programs of institutional support and development;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) research programs;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) fellowship programs;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) seminars;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(F) publications;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(G) scholar-in-residence and artist-in-residence programs; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(H) inter-institutional programs of cooperation at national and international levels; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) a Museum of American Indian and Alaska Native Arts, which shall be under the direction of the President of the Institute.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/644/s502/1"},"text":"Pub. L. 101–644, § 502(1)","children":[],"tail":", redesignated subpars. (B) to (I) as (A) to (H), respectively, and struck out former subpar. (A) which related to a museum of Indian arts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/644/s502/2"},"text":"Pub. L. 101–644, § 502(2)","children":[],"tail":"–(4), added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0deb2cab-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0deb2cac-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/s2"},"text":"section 2 of Pub. L. 102–325","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
