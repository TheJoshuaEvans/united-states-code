{"tag":"section","attrib":{"id":"id0db46486-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1713"},"text":null,"children":[{"tag":"num","attrib":{"value":"1713"},"text":"§ 1713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority of remedies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In formulating a remedy for a denial of equal educational opportunity or a denial of the equal protection of the laws, which may involve directly or indirectly the transportation of students, a court, department, or agency of the United States shall consider and make specific findings on the efficacy in correcting such denial of the following remedies and shall require implementation of the first of the remedies set out below, or of the first combination thereof which would remedy such denial:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0db46487-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assigning students to the schools closest to their places of residence which provide the appropriate grade level and type of education for such students, taking into account school capacities and natural physical barriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db46488-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assigning students to the schools closest to their places of residence which provide the appropriate grade level and type of education for such students, taking into account only school capacities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db46489-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1713/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permitting students to transfer from a school in which a majority of the students are of their race, color, or national origin to a school in which a minority of the students are of their race, color, or national origin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db4648a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1713/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creation or revision of attendance zones or grade structures without requiring transportation beyond that described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1714"},"text":"section 1714 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db4648b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1713/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction of new schools or the closing of inferior schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db4648c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1713/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction or establishment of magnet schools; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db4648d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1713/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and implementation of any other plan which is educationally sound and administratively feasible, subject to the provisions of sections 1714 and 1715 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0db4648e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/380/tII/s214"},"text":"Pub. L. 93–380, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/517"},"text":"88 Stat. 517","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db4648f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0db46490-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0db46491-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on and after sixtieth day after ","children":[{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/380/s2/c"},"text":"section 2(c) of Pub. L. 93–380","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221–1"},"text":"section 1221–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
