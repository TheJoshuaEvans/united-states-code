{"tag":"section","attrib":{"id":"id0d59c0fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1092f"},"text":"§ 1092f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early awareness and outreach of financial aid eligibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d59c0fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall implement early outreach activities in order to provide prospective students and their families with information about financial aid and estimates of financial aid. Such early outreach activities shall include the activities described in subsections (b), (c), and (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d59c0ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pell Grant early awareness estimates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d59c100-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall produce a consumer-tested method of estimating student eligibility for Federal Pell Grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a/b"},"text":"section 1070a(b) of this title","children":[],"tail":" utilizing the variables of family size and adjusted gross income, presented in electronic format. There shall be a method for students to indicate whether they are, or will be in—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d59c101-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a single-parent household;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c102-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a household with two parents; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c103-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a household with no children or dependents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c104-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer testing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d59c105-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The method of estimating eligibility described in paragraph (1) shall be consumer tested with prospective first-generation students and families as well as low-income individuals and families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c106-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For award year 2024–2025 and each fourth succeeding award year thereafter, the design of the method of estimating eligibility shall be updated based on additional consumer testing with the populations described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c107-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The method of estimating eligibility described in paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d59c108-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made publicly and prominently available on the Department’s website; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c109-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" actively shared by the Secretary with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d59c10a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education participating in programs under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c10b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all middle and secondary schools eligible for funds under part A of title I of the Elementary and Secondary Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311"},"text":"20 U.S.C. 6311","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c10c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local educational agencies and middle schools and high schools that serve students not less than 25 percent of whom meet a measure of poverty as described in section 1113(a)(5) of the Elementary and Secondary Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6313/a/5"},"text":"20 U.S.C. 6313(a)(5)","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c10d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agencies responsible for administering means-tested Federal benefit programs, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087ss/b/4/H"},"text":"section 1087ss(b)(4)(H) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c10e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic estimator on FAFSA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with subsection (d)(5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1090"},"text":"section 1090 of this title","children":[],"tail":", the Secretary shall maintain an electronic method for applicants to enter income and family size, and level of education sought information to calculate a non-binding estimate (which may include a range, ceiling, or minimum) of the applicant’s Federal financial aid available under this subchapter and shall place such calculator on a prominent location on the FAFSA website and in a manner that encourages students to fill out the FAFSA."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d59c10f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early awareness plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish and implement early awareness and outreach plans to provide early information about the availability of Federal financial aid and estimates of prospective students’ eligibility for Federal financial aid as well as to promote the attainment of postsecondary education specifically among prospective first-generation students and families as well as low-income individuals and families, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d59c110-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach plans for low-income families","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d59c111-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop plans for each population described in this subparagraph to disseminate information about the availability of Federal financial aid under this subchapter, in addition to and in coordination with the distribution of the method of estimating eligibility under subsection (b), to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d59c112-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all middle schools and secondary schools eligible for funds under part A of title I of the Elementary and Secondary Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311"},"text":"20 U.S.C. 6311","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c113-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local educational agencies and middle schools and high schools that serve students not less than 25 percent of whom meet a measure of poverty as described in section 1113(a)(5) of the Elementary and Secondary Education Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6313/a/5"},"text":"20 U.S.C. 6313(a)(5)","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c114-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" households receiving assistance under the supplemental nutrition assistance program established under the Food and Nutrition Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"7 U.S.C. 2011","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c115-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agencies responsible for administering means-tested Federal benefit programs, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087ss/b/4/H"},"text":"section 1087ss(b)(4)(H) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c116-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plans described in paragraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d59c117-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide students and their families with information on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d59c118-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of the College Scorecard or any similar successor website;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d59c119-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the electronic estimates of financial aid available under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d59c11a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal financial aid available to students, including eligibility criteria for the Federal financial aid and an explanation of the Federal financial aid programs (including applicable Federal educational tax credits); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d59c11b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/1/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resources that can inform students of financial aid that may be available from state-based financial aid, state-based college savings programs, and scholarships and other non-governmental sources;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c11c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how the dissemination of information will be conducted by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c11d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting and updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall post the information about the plans under subparagraph (A) and associated goals publicly on the Department’s website. On an annual basis, the Secretary shall report qualitative and quantitative outcomes regarding the implementation of the plans under subparagraph (A). The Secretary shall review and update such plans not less often than every 4 award years with the goal of progressively increasing the impact of the activities under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c11e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may partner with States, State systems of higher education, institutions of higher education, or college access organizations to carry out this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c11f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency coordination plans","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d59c120-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop interagency coordination plans in order to inform more students and families, including low-income individuals or families and recipients of means-tested Federal benefits, about the availability of Federal financial aid under this subchapter through participation in existing Federal programs or tax benefits that serve low-income individuals or families, in coordination with the following Secretaries:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d59c121-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c122-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c123-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c124-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c125-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c126-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c127-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c128-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c129-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process, activities, and goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each interagency coordination plan under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d59c12a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify opportunities in which low-income individuals and families could be informed of the availability of Federal financial aid under this subchapter through access to other Federal programs that serve low-income individuals and families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c12b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify methods to effectively inform low-income individuals and families of the availability of Federal financial aid for postsecondary education under this subchapter and assist such individuals in completing the Free Application for Federal Student Aid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c12c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop early awareness and FAFSA completion activities that align with the opportunities and methods identified under clauses (i) and (ii);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c12d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish goals regarding the effects of the activities to be implemented under clause (iii); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c12e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information on how students and families can maintain access to Federal programs that serve low-income individuals and families operated by the agencies identified under subsection (A) while attending an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c12f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan with Secretary of the Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interagency coordination plan under subparagraph (A)(i) between the Secretary and the Secretary of the Treasury shall further include specific methods to increase the application for Federal financial aid under this subchapter from individuals who file Federal tax returns, including collaboration with tax preparation entities or other third parties, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c130-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting and updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall post the information about the interagency coordination plans under this paragraph and associated goals publicly on the Department’s website. The plans shall have the goal of progressively increasing the impact of the activities under this paragraph by increasing the number of low-income applicants for, and recipients of, Federal financial aid. The plans shall be updated not less than once every 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c131-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nationwide participation in early awareness plans","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d59c132-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall solicit voluntary public commitments from entities, such as States, State systems of higher education, institutions of higher education, and other interested organizations, to carry out early awareness plans, which shall include goals, to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d59c133-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify prospective and existing students who are low-income individuals and families about their eligibility for Federal aid under this subchapter, as well as State-based financial aid, if applicable, on an annual basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c134-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the number of prospective and current students who are low-income individuals and families filing the Free Application for Federal Student Aid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d59c135-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the number of prospective and current students who are low-income individuals and families enrolling in postsecondary education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c136-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting and updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each entity that makes a voluntary public commitment to carry out an early awareness plan may submit quantitative and qualitative data based on the entity’s progress toward the goals of the plan annually prior to a date selected by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d59c137-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early awareness champions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Based on data submitted by entities, the Secretary shall select and designate entities submitting public commitments, plans, and goals, as Early Awareness Champions on an annual basis. Those entities designated as Early Awareness Champions shall provide one or more case studies regarding the activities the entity undertook under this paragraph which shall be made public by the Secretary on the Department of Education website to promote best practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d59c138-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public awareness campaign","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d59c139-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and implement a public awareness campaign designed using current and relevant independent research regarding strategies and media platforms found to be most effective in communicating with low-income populations in order to increase national awareness regarding the availability of Federal Pell Grants and financial aid under this subchapter and, at the option of the Secretary, potential availability of state need-based financial aid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c13a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The public awareness campaign described in paragraph (1) shall leverage the activities in subsections (b) and (c) to highlight eligibility among low-income populations. In developing and implementing the campaign, the Secretary may work in coordination with States, institutions of higher education, early intervention and outreach programs under this subchapter, other Federal agencies, agencies responsible for administering means-tested Federal benefit programs (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087ss/b/4/H"},"text":"section 1087ss(b)(4)(H) of this title","children":[],"tail":"), organizations involved in college access and student financial aid, secondary schools, local educational agencies, public libraries, community centers, businesses, employers, workforce investment boards, and organizations that provide services to individuals who are or were homeless, in foster care, or are disconnected youth."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c13b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092f/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall report on the success of the public awareness campaign described in paragraph (1) annually regarding the extent to which the public and target populations were reached using data commonly used to evaluate advertising and outreach campaigns and data regarding whether the campaign produced any increase in applicants for Federal aid under this subchapter publicly on the Department of Education website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d59c13c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s485E"},"text":"Pub. L. 89–329, title IV, § 485E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s490"},"text":"Pub. L. 110–315, title IV, § 490","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3305"},"text":"122 Stat. 3305","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/152/tII/s2101/b/5"},"text":"Pub. L. 111–152, title II, § 2101(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-30"},"text":"Mar. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1073"},"text":"124 Stat. 1073","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tVII/s702"},"text":"Pub. L. 116–260, div. FF, title VII, § 702","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3186"},"text":"134 Stat. 3186","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dR/s102/b/5"},"text":"Pub. L. 117–103, div. R, § 102(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/819"},"text":"136 Stat. 819","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d59c13d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d59c13e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d59c13f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Elementary and Secondary Education Act of 1965, referred to in subsecs. (b)(3)(B)(ii) and (c)(1)(A)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-04-11"},"text":"Apr. 11, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/27"},"text":"79 Stat. 27","children":[],"tail":". Part A of title I of the Act is classified generally to part A (§ 6311 et seq.) of subchapter I of chapter 70 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Food and Nutrition Act of 2008, referred to in subsec. (c)(1)(A)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/525"},"text":"Pub. L. 88–525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-31"},"text":"Aug. 31, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/703"},"text":"78 Stat. 703","children":[],"tail":", which is classified generally to chapter 51 (§ 2011 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"section 2011 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d59c140-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" substituted “award year 2024–2025” for “award year 2023–2024”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" amended section generally. Prior to amendment, section related to early awareness of financial aid eligibility."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152"},"text":"Pub. L. 111–152","children":[],"tail":" substituted “of such students’ potential eligibility for the Federal Pell Grant amount, determined under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a/b/2/A"},"text":"section 1070a(b)(2)(A) of this title","children":[],"tail":", for which the student would be eligible” for “of such students’ potential eligibility for a maximum Federal Pell Grant under subpart 1 of part A”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d59c141-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d59c142-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2024-07-01"},"text":"July 1, 2024","children":[],"tail":", except as otherwise expressly provided, and applicable with respect to award year 2024–2025 and each subsequent award year, as determined under this chapter, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/s701/b"},"text":"section 701(b) of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d59c143-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152"},"text":"Pub. L. 111–152","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/152/s2101/c"},"text":"section 2101(c) of Pub. L. 111–152","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"section 1070a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
