ter "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", or made to cover the costs of instruction for periods of enrollment beginning on or after "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the changes in section 428(b)(1)(H) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078/b/1/H"},"text":"20 U.S.C. 1078(b)(1)(H)","children":[],"tail":"] shall apply with respect only to loans for which the borrower files an application on or after "},{"tag":"date","attrib":{"date":"1987-07-01"},"text":"July 1, 1987","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the changes in sections 435(d)(5) and 438(d) of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1085/d/5"},"text":"20 U.S.C. 1085(d)(5)","children":[],"tail":", 1087–1(d)] shall take effect 30 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the changes made in section 438(b) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087–1/b"},"text":"20 U.S.C. 1087–1(b)","children":[],"tail":"] shall take effect with respect to loans disbursed on or after 30 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":"] or made to cover the costs of instruction for periods of enrollment beginning on or after 30 days after the date of enactment of this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Changes Effective Without Regard to Regulations; Republication of Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The changes made in part B of title IV of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1071"},"text":"20 U.S.C. 1071","children":[],"tail":" et seq.] by the amendment made by subsection (a) of this section shall be effective in accordance with subsection (b) of this section without regard to whether such changes are reflected in the regulations prescribed by the Secretary of Education for the purpose of such part."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"New Borrowers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purpose of this section, the term ‘new borrower’ means, with respect to any date, an individual who on that date has no outstanding balance of principal or interest owing on any loan made, insured, or guaranteed under part B of title IV of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1071"},"text":"20 U.S.C. 1071","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0cf7f1bc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Role of Guaranty Agencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/tXIV/s1401"},"text":"Pub. L. 102–325, title XIV, § 1401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/816"},"text":"106 Stat. 816","children":[],"tail":", directed Secretary of Education to review role of guaranty agencies within Federal Family Education Loan Program by examining administrative and financial operations of such agencies and the relationships between guaranty agencies and State governments and report to Congress within 1 year of "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", on the review, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/332/s6/b/2"},"text":"Pub. L. 105–332, § 6(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3128"},"text":"112 Stat. 3128","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0cf7f1bd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"General Accounting Office Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXIII"},"text":"Pub. L. 99–498, title XIII","children":[],"tail":", §§ 1311–1314, "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1583"},"text":"100 Stat. 1583","children":[],"tail":", 1584, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s23/6"},"text":"Pub. L. 100–50, § 23(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-06-03"},"text":"June 3, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/362"},"text":"101 Stat. 362","children":[],"tail":", directed Comptroller General to conduct studies on practices of State guaranty agencies and multistate guarantors under the student loan program, on the feasibility and efficiency of permitting students to establish multiple year lines of credit with eligible lenders, on the impact of the multiple disbursement system on the ability of students and institutions of higher education to meet expenses, and on the cost, efficiency, and impact of the consolidation loan program established by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":", and directed Comptroller General to make and submit a report to Congress on each study not later than two years after "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/332/s6/a"},"text":"Pub. L. 105–332, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3127"},"text":"112 Stat. 3127","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
