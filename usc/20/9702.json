{"tag":"section","attrib":{"id":"id0e6bf4be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9702"},"text":null,"children":[{"tag":"num","attrib":{"value":"9702"},"text":"§ 9702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Financial Literacy and Education Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e6bf4bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a commission to be known as the “Financial Literacy and Education Commission”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6bf4c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall serve to improve the financial literacy and education of persons in the United States through development of a national strategy to promote financial literacy and education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6bf4c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6bf4c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6bf4c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9702/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6bf4c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9702/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the respective head of each of the Federal banking agencies (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of title 12","children":[],"tail":"), the National Credit Union Administration, the Securities and Exchange Commission, each of the Departments of Education, Agriculture, Defense, Health and Human Services, Housing and Urban Development, Labor, and Veterans Affairs, the Federal Trade Commission, the General Services Administration, the Small Business Administration, the Social Security Administration, the Commodity Futures Trading Commission, and the Office of Personnel Management;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6bf4c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9702/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Bureau of Consumer Financial Protection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6bf4c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9702/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the discretion of the President, not more than 5 individuals appointed by the President from among the administrative heads of any other Federal agencies, departments, or other Federal Government entities, whom the President determines to be engaged in a serious effort to improve financial literacy and education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6bf4c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Commission may designate an alternate if the member is unable to attend a meeting of the Commission. Such alternate shall be an individual who exercises significant decisionmaking authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6bf4c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall serve as the Chairperson. The Director of the Bureau of Consumer Financial Protection shall serve as the Vice Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6bf4c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9702/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall hold, at the call of the Chairperson, at least 1 meeting every 4 months. All such meetings shall be open to the public. The Commission may hold, at the call of the Chairperson, such other meetings as the Chairperson sees fit to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6bf4ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9702/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Commission shall constitute a quorum, but a lesser number of members may hold hearings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6bf4cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9702/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall hold its first meeting not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2003-12-04"},"text":"December 4, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e6bf4cc-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/159/tV/s513"},"text":"Pub. L. 108–159, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-04"},"text":"Dec. 4, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2003"},"text":"117 Stat. 2003","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1013/d/5"},"text":"Pub. L. 111–203, title X, § 1013(d)(5)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1971"},"text":"124 Stat. 1971","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e6bf4cd-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e6bf4ce-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e6bf4cf-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(1)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1013/d/5"},"text":"Pub. L. 111–203, § 1013(d)(5)","children":[],"tail":", added subpar. (C) and redesignated former subpar. (C) as (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1013/d/6"},"text":"Pub. L. 111–203, § 1013(d)(6)","children":[],"tail":", inserted at end “The Director of the Bureau of Consumer Financial Protection shall serve as the Vice Chairman.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e6bf4d0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e6bf4d1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section subject to joint regulations establishing effective dates as prescribed by Federal Reserve Board and Federal Trade Commission, except as otherwise provided, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/159/s3"},"text":"section 3 of Pub. L. 108–159","children":[],"tail":", set out as an Effective Date of 2003 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681"},"text":"section 1681 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
