{"tag":"section","attrib":{"id":"id0e3c329e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544"},"text":null,"children":[{"tag":"num","attrib":{"value":"7544"},"text":"§ 7544.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e3c329f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3c32a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and contracts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to make grants to, or enter into contracts with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e3c32a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Alaska Native organizations with experience operating programs that fulfill the purposes of this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c32a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Alaska Native organizations that do not have the experience described in subparagraph (A) but are in partnership with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e3c32a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State educational agency or a local educational agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c32a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Alaska Native organization that operates a program that fulfills the purposes of this part;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3c32a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an entity located in Alaska, and predominately governed by Alaska Natives, that does not meet the definition of an Alaska Native organization under this part but—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e3c32a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has experience operating programs that fulfill the purposes of this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3c32a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is granted an official charter or sanction, as described in the definition of a tribal organization under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":", from at least one Alaska Native tribe or Alaska Native organization to carry out programs that meet the purposes of this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3c32a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities provided through the programs carried out under this part shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e3c32a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development and implementation of plans, methods, strategies, and activities to improve the educational outcomes of Alaska Natives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3ea2aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The collection of data to assist in the evaluation of the programs carried out under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3ea2ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities provided through programs carried out under this part may include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e3ea2ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The development of curricula and programs that address the educational needs of Alaska Native students, including the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e3ea2ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Curriculum materials that are culturally informed and reflect the cultural diversity, languages, history, or the contributions of Alaska Native people, including curricula intended to preserve and promote Alaska Native culture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3ea2ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Instructional programs that make use of Alaska Native languages and cultures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3ea2af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Networks that develop, test, and disseminate best practices and introduce successful programs, materials, and techniques to meet the educational needs of Alaska Native students in urban and rural schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3ea2b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Training and professional development activities for educators, including the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e3ea2b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pre-service and in-service training and professional development programs to prepare teachers to develop appreciation for, and understanding of, Alaska Native history, cultures, values, and ways of knowing and learning in order to effectively address the cultural diversity and unique needs of Alaska Native students and improve the teaching methods of educators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3ea2b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recruitment and preparation of Alaska Native teachers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3ea2b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs that will lead to the certification and licensing of Alaska Native teachers, principals, other school leaders, and superintendents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3ea2b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Early childhood and parenting education activities designed to improve the school readiness of Alaska Native children, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e3ea2b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and operation of home visiting programs for Alaska Native preschool children, to ensure the active involvement of parents in their children’s education from the earliest ages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3ea2b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training, education, and support, including in-home visitation, for parents and caregivers of Alaska Native children to improve parenting and caregiving skills (including skills relating to discipline and cognitive development, reading readiness, observation, storytelling, and critical thinking);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3ea2b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family literacy services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3ea2b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities carried out under the Head Start Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9831"},"text":"42 U.S.C. 9831","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3ea2b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs for parents and their infants, from the prenatal period of the infant through age 3;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3ea2ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early childhood education programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3ea2bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" native language immersion within early childhood education programs, Head Start, or preschool programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3ea2bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The development and operation of student enrichment programs, including programs in science, technology, engineering, and mathematics that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e3ea2bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are designed to prepare Alaska Native students to excel in such subjects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3ea2be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide appropriate support services to enable such students to benefit from the programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3ea2bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include activities that recognize and support the unique cultural and educational needs of Alaska Native children and incorporate appropriately qualified Alaska Native elders and other tradition bearers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3ea2c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Research and data collection activities to determine the educational status and needs of Alaska Native children and adults and other such research and evaluation activities related to programs funded under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3ea2c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Activities designed to enable Alaska Native students served under this part to meet the challenging State academic standards or increase the graduation rates of Alaska Native students, such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e3ea2c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remedial and enrichment programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3ea2c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" culturally based education programs, such as—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e3ea2c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/F/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs of study and other instruction in Alaska Native history and ways of living to share the rich and diverse cultures of Alaska Natives among Alaska Native youth and elders, non-Native students and teachers, and the larger community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e3ea2c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/F/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instructing Alaska Native youth in leadership, communication, and Alaska Native culture, arts, history, and languages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e3ea2c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/F/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intergenerational learning and internship opportunities to Alaska Native youth and young adults;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e3ea2c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/F/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing cultural immersion activities aimed at Alaska Native cultural preservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e3ea2c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/F/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" native language instruction and immersion activities, including native language immersion nests or schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e3ea2c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/F/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" school-within-a-school model programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e3ea2ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/F/ii/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparation for postsecondary education and career planning; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3ea2cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" comprehensive school or community-based support services, including services that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e3ea2cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/F/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address family instability and trauma; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e3ea2cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/F/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve conditions for learning at home, in the community, and at school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3ea2ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Student and teacher exchange programs, cross-cultural immersion programs, and culture camps designed to build mutual respect and understanding among participants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3ea2cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Education programs for at-risk urban Alaska Native students that are designed to improve academic proficiency and graduation rates, use strategies otherwise permissible under this part, and incorporate a strong data collection and continuous evaluation component.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3ea2d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategies designed to increase the involvement of parents in their children’s education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3ea2d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Programs and strategies that increase connections between and among schools, families, and communities, including positive youth-adult relationships, to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e3ea2d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/J/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the academic progress and positive development of Alaska Native children and youth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e3ea2d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/J/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve conditions for learning at home, in the community, and at school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3ea2d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Career preparation activities to enable Alaska Native children and adults to prepare for meaningful employment, including programs providing mentoring, training, and apprenticeship activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3ea2d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support for the development and operational activities of regional vocational schools in rural areas of Alaska to provide students with necessary resources to prepare for skilled employment opportunities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3ea2d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regional leadership academies that demonstrate effectiveness in building respect and understanding, and fostering a sense of Alaska Native identity in Alaska Native students to promote their pursuit of and success in completing higher education or career training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e3ea2d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/a/3/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other activities, consistent with the purposes of this part, to meet the educational needs of Alaska Native children and adults.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3ea2d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7544/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $31,453,000 for each of fiscal years 2017 through 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e3ea2d9-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6304"},"text":"Pub. L. 89–10, title VI, § 6304","children":[],"tail":", formerly title VII, § 7304, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"t