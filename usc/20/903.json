{"tag":"section","attrib":{"id":"id0ca47af4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s903"},"text":null,"children":[{"tag":"num","attrib":{"value":"903"},"text":"§ 903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ca47af5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment and salary practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall conduct the employment and salary practices applicable to teachers and teaching positions in the Department of Defense in accordance with this chapter, other applicable law, and the regulations prescribed and issued by the Secretary of Defense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s902"},"text":"section 902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ca47af6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of exempt positions and individuals; establishment of annual salary rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5103"},"text":"section 5103 of title 5","children":[],"tail":", the Secretary of Defense—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ca47af7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall determine the applicability of paragraph (22) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5102/c"},"text":"section 5102(c) of title 5","children":[],"tail":" to positions and individuals in the Department of Defense; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca47af8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish the appropriate annual salary rate in accordance with this chapter for each such position and individual to which such paragraph (22) is determined to be applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ca47af9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates of basic compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall fix the basic compensation for teachers and teaching positions in the Department of Defense at rates equal to the average of the range of rates of basic compensation for similar positions of a comparable level of duties and responsibilities in urban school jurisdictions in the United States of 100,000 or more population.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ca47afa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of regulations by Secretary of Defense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense may prescribe and issue such regulations as he deems appropriate to carry out his functions under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ca47afb-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/91/s5"},"text":"Pub. L. 86–91, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-07-17"},"text":"July 17, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/214"},"text":"73 Stat. 214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/370/s6/b"},"text":"Pub. L. 86–370, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-23"},"text":"Sept. 23, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/652"},"text":"73 Stat. 652","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/391/s1/b"},"text":"Pub. L. 89–391, § 1(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1966-04-14"},"text":"Apr. 14, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/117"},"text":"80 Stat. 117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/470/tI/s104/b"},"text":"Pub. L. 96–470, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-19"},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2238"},"text":"94 Stat. 2238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1606/b"},"text":"Pub. L. 104–201, div. A, title XVI, § 1606(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2737"},"text":"110 Stat. 2737","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/c/9/B"},"text":"Pub. L. 105–85, div. A, title X, § 1073(c)(9)(B)","children":[],"tail":", (C), "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1904"},"text":"111 Stat. 1904","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ca47afc-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ca47afd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0ca47afe-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5103"},"text":"section 5103 of title 5","children":[],"tail":"” and “paragraph (22) of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5102/c"},"text":"section 5102(c) of title 5","children":[],"tail":"” substituted for “section 202 of the Classification Act of 1949” and “paragraph (33) of section 202 of such Act, added by section 3 of this Act” respectively, on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", the first section of which enacted Title 5, Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of section 1(b) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/391"},"text":"Pub. L. 89–391","children":[],"tail":" for amendment of subsec. (c) of this section and addition of other provisions as another subsec. (c), have been executed in the Code as an amendment of subsec. (c) of this section and addition of subsec. (e) of this section, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2353"},"text":"section 2353 of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ca47aff-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s1073/c/9/B"},"text":"Pub. L. 105–85, § 1073(c)(9)(B)","children":[],"tail":", made technical correction to "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1606/b/1/A"},"text":"Pub. L. 104–201, § 1606(b)(1)(A)","children":[],"tail":". See 1996 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s1073/c/9/C"},"text":"Pub. L. 105–85, § 1073(c)(9)(C)","children":[],"tail":", made technical correction to "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1606/b/2/B"},"text":"Pub. L. 104–201, § 1606(b)(2)(B)","children":[],"tail":". See 1996 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1606/b/1/B"},"text":"Pub. L. 104–201, § 1606(b)(1)(B)","children":[],"tail":", substituted “the Department of Defense” for “his military department”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1606/b/1/A"},"text":"Pub. L. 104–201, § 1606(b)(1)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/s1073/c/9/B"},"text":"Pub. L. 105–85, § 1073(c)(9)(B)","children":[],"tail":", substituted “Secretary of Defense shall” for “secretary of each military department in the Department of Defense shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1606/b/2/A"},"text":"Pub. L. 104–201, § 1606(b)(2)(A)","children":[],"tail":", substituted “Secretary of Defense—” for “secretary of each military department—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1606/b/2/B"},"text":"Pub. L. 104–201, § 1606(b)(2)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/s1073/c/9/C"},"text":"Pub. L. 105–85, § 1073(c)(9)(C)","children":[],"tail":", substituted “the Department of Defense;” for “his military department,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1606/b/3"},"text":"Pub. L. 104–201, § 1606(b)(3)","children":[],"tail":", substituted “Secretary of Defense” for “Secretary of each military department” and “the Department of Defense” for “his military department”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1606/b/4"},"text":"Pub. L. 104–201, § 1606(b)(4)","children":[],"tail":", substituted “Secretary of Defense” for “Secretary of each military department”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/470"},"text":"Pub. L. 96–470","children":[],"tail":" struck out subsec. (e) which required the Secretary of Defense, on or before the 15th day of January in each calendar year beginning after "},{"tag":"date","attrib":{"date":"1966-04-14"},"text":"Apr. 14, 1966","children":[],"tail":", to report to the respective Committees on Post Office and Civil Service of the Senate and House of Representatives information on teachers separated from teaching positions subsequent to the close of the immediately preceding full school year and the number of new teachers appointed to teaching positions at the beginning of the school year current at time of the report, including the number of such new teachers obtained through voluntary reciprocal interchange agreements with school jurisdictions in the United States."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/391/s1/b"},"text":"Pub. L. 89–391, § 1(b)","children":[],"tail":", substituted provisions for fixing the basic compensation for teachers and teaching positions at rates equal to the average of the range of rates of basic compensation for similar positions of a comparable level of duties and responsibilities in urban school jurisdictions in the United States of 100,000 or more population for former provisions fixing such rates in relation to the rates of basic compensation for similar positions in the United States but not exceeding the highest rate of basic compensation for similar positions of a comparable level of duties and responsibilities under the municipal government of the District of Columbia."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/391/s1/c"},"text":"Pub. L. 89–391, § 1(c)","children":[],"tail":", inserted provisions designated as subsec. (c) to "},{"tag":"ref","attrib":{"href":"/us/pl/86/91/s5"},"text":"section 5 of Pub. L. 86–91","children":[],"tail":", but codified as subsec. (e) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/370"},"text":"Pub. L. 86–370","children":[],"tail":" substituted “(33)” for “(32)” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ca47b00-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0ca47b01-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/c"},"text":"Pub. L. 105–85, div. A, title X, § 1073(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1904"},"text":"111 Stat. 1904","children":[],"tail":", provided that the amendment made by that section is effective as of "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", and as if included in the National Defense Authorization Act for Fiscal Year 1997, "},{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":", as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0ca47b02-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendments of this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/391"},"text":"Pub. L. 89–391","children":[],"tail":" effective on first day of first pay period beginning after "},{"tag":"date","attrib":{"date":"1966-04-14"},"text":"Apr. 14, 1966","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/391/s2"},"text":"section 2 of Pub. L. 89–391","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s902"},"text":"section 902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0ca47b03-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1959 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/370"},"text":"Pub. L. 86–370","children":[],"tail":" effective on first day of first pay period which begins after "},{"tag":"date","attrib":{"date":"1959-09-23"},"text":"Sept. 23, 1959","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/86/370/s7/b"},"text":"section 7(b) of Pub. L. 86–370","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s3"},"text":"section 3 of Title 35","children":[],"tail":", Patents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0ca47b04-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Teachers Employed by Canal Zone Government School System on ","children":[{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (c) of this section not to apply with respect to any teacher who was employed by the Canal Zone Government school system on ","children":[{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":", and who was transferred from such position to a teaching position which is under the Department of Defense Overseas Dependent School System and the permanent duty station of which is in the Republic of Panama, until the rates of basic compensation established under subsec. (c) of this section equal or exceed the rates of basic compensation then in effect for teachers who were so transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3671/c/1"},"text":"section 3671(c)(1) of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
