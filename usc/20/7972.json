{"tag":"section","attrib":{"id":"id0e5427a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7972"},"text":null,"children":[{"tag":"num","attrib":{"value":"7972"},"text":"§ 7972.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subpart: ","children":[{"tag":"ref","attrib":{"idref":"fn002237"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002237"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e5427a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7972/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Children","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “children” means individuals who have not attained the age of 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5427a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7972/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Children’s services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “children’s services” means the provision on a routine or regular basis of health, day care, education, or library services—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e5427a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7972/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that are funded, after ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", directly by the Federal Government or through State or local governments, by Federal grant, loan, loan guarantee, or contract programs—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0e5427a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7972/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administered by either the Secretary of Health and Human Services or the Secretary of Education (other than services provided and funded solely under titles XVIII and XIX of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq., 1396 et seq.]); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e5427a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7972/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administered by the Secretary of Agriculture in the case of a clinic (as defined in part 246.2 of title 7, Code of Federal Regulations (or any corresponding similar regulation or ruling)) under section 17(b)(6) of the Child Nutrition Act of 1966 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1786/b/6"},"text":"42 U.S.C. 1786(b)(6)","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e5427aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7972/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are provided in indoor facilities that are constructed, operated, or maintained with such Federal funds, as determined by the appropriate head of a Federal agency in any enforcement action carried out under this subpart,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that nothing in clause (ii) of subparagraph (A) is intended to include facilities (other than clinics) where coupons are redeemed under the Child Nutrition Act of 1966 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"42 U.S.C. 1771","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5427ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7972/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indoor facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “indoor facility” means a building that is enclosed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5427ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7972/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means any State or local subdivision of a State, agency of such State or subdivision, corporation, or partnership that owns or operates or otherwise controls and provides children’s services or any individual who owns or operates or otherwise controls and provides such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5427ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7972/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e5427ae-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8572"},"text":"Pub. L. 89–10, title VIII, § 8572","children":[],"tail":", formerly title IV, § 4302, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIV/s401"},"text":"Pub. L. 107–110, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1773"},"text":"115 Stat. 1773","children":[],"tail":"; renumbered title IX, § 9562, renumbered title VIII, § 8572, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4001/a/4/A"},"text":"Pub. L. 114–95, title IV, § 4001(a)(4)(A)","children":[],"tail":", (B), (C)(ii), title VIII, § 8001(a)(9), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1966"},"text":"129 Stat. 1966","children":[],"tail":", 2088, 2089.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e5427af-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e5427b0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e5427b1-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subpart, referred to in text, was in the original “this part”, and was translated as reading “this subpart”, to reflect the probable intent of Congress. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" redesignated part C of title IV of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" as subpart 5 of part F of title VIII of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", which is classified to this subpart."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Child Nutrition Act of 1966, referred to in par. (2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642"},"text":"Pub. L. 89–642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/885"},"text":"80 Stat. 885","children":[],"tail":", which is classified generally to chapter 13A (§ 1771 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"section 1771 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in par. (2)(A)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Titles XVIII and XIX of the Act are classified generally to subchapters XVIII (§ 1395 et seq.) and XIX (§ 1396 et seq.), respectively, of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0e5427b2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7182"},"text":"section 7182 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
