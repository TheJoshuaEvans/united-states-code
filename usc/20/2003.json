{"tag":"section","attrib":{"id":"id0db6ae51-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2003"},"text":null,"children":[{"tag":"num","attrib":{"value":"2003"},"text":"§ 2003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Federal memorials prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Harry S Truman Scholarship Program as authorized by this chapter shall be the sole Federal memorial to President Harry S Truman.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0db6ae52-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/642/s4"},"text":"Pub. L. 93–642, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2277"},"text":"88 Stat. 2277","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
