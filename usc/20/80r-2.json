{"tag":"section","attrib":{"id":"id0c8a3bd7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"80r–2"},"text":"§ 80r–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Museum","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c8a3bd8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Smithsonian Institution a museum to be known as the “National Museum of African American History and Culture”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8a3bd9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the Museum shall be to provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c8a3bda-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the collection, study, and establishment of programs relating to African American life, art, history, and culture that encompass—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c8a3bdb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–2/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of slavery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8a3bdc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–2/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the era of Reconstruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8a3bdd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–2/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Harlem renaissance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8a3bde-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–2/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the civil rights movement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8a3bdf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–2/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other periods of the African American diaspora;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8a3be0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creation and maintenance of permanent and temporary exhibits documenting the history of slavery in America and African American life, art, history, and culture during the periods referred to in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8a3be1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection and study of artifacts and documents relating to African American life, art, history, and culture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8a3be2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collaboration between the Museum and other museums, historically black colleges and universities, historical societies, educational institutions, and other organizations that promote the study or appreciation of African American life, art, history, or culture, including collaboration concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c8a3be3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–2/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of cooperative programs and exhibitions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8a3be4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–2/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification, management, and care of collections; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8a3be5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–2/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training of museum professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c8a3be6-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/184/s4"},"text":"Pub. L. 108–184, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2677"},"text":"117 Stat. 2677","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
