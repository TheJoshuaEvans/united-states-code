{"tag":"section","attrib":{"id":"id0e187d05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573"},"text":null,"children":[{"tag":"num","attrib":{"value":"6573"},"text":"§ 6573.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e187d06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e187d07-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State that receives funds under this subchapter shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e187d08-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that any State rules, regulations, and policies relating to this subchapter conform to the purposes of this subchapter and provide any such proposed rules, regulations, and policies to the committee of practitioners created under subsection (b) for review and comment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e187d09-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize such rules, regulations, and policies to which the State’s local educational agencies and schools are subject;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e187d0a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminate or modify State and local fiscal accounting requirements in order to facilitate the ability of schools to consolidate funds under schoolwide programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e187d0b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any such rule, regulation, or policy as a State-imposed requirement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e187d0c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e187d0d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/a/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any duplicative or contrasting requirements between the State and Federal rules or regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e187d0e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/a/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminate the State rules and regulations that are duplicative of Federal requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e187d0f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support and facilitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"State rules, regulations, and policies under this subchapter shall support and facilitate local educational agency and school-level systemic reform designed to enable all children to meet the challenging State academic standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e187d10-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee of practitioners","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e187d11-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State educational agency that receives funds under this subchapter shall create a State committee of practitioners to advise the State in carrying out its responsibilities under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e187d12-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each such committee shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e187d13-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a majority of its members, representatives from local educational agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e187d14-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrators, including the administrators of programs described in other parts of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e187d15-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teachers from traditional public schools and charter schools (if there are charter schools in the State) and career and technical educators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e187d16-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" principals and other school leaders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e187d17-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e187d18-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of local school boards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e187d19-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of private school children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e187d1a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specialized instructional support personnel and paraprofessionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e187d1b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of authorized public chartering agencies (if there are charter schools in the State); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e187d1c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charter school leaders (if there are charter schools in the State).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e187d1d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6573/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The duties of such committee shall include a review, before publication, of any proposed or final State rule or regulation pursuant to this subchapter. In an emergency situation where such rule or regulation must be issued within a very limited time to assist local educational agencies with the operation of the program under this subchapter, the State educational agency may issue a regulation without prior consultation, but shall immediately thereafter convene the State committee of practitioners to review the emergency regulation before issuance in final form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e187d1e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1603"},"text":"Pub. L. 89–10, title I, § 1603","children":[],"tail":", formerly § 1903, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1618"},"text":"115 Stat. 1618","children":[],"tail":"; renumbered § 1603 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI"},"text":"Pub. L. 114–95, title I","children":[],"tail":", §§ 1501(a)(4), 1601(c), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1906"},"text":"129 Stat. 1906","children":[],"tail":", 1912.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e187d1f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e187d20-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e187d21-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s1603"},"text":"section 1603 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6513"},"text":"section 6513 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s1603"},"text":"section 1603 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6513"},"text":"section 6513 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e187d22-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1601/c/1/A"},"text":"Pub. L. 114–95, § 1601(c)(1)(A)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1601/c/1/B"},"text":"Pub. L. 114–95, § 1601(c)(1)(B)","children":[],"tail":", substituted “the challenging State academic standards” for “the challenging State student academic achievement standards”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C) to (J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1601/c/2"},"text":"Pub. L. 114–95, § 1601(c)(2)","children":[],"tail":", added subpars. (C) to (J) and struck out former subpars. (C) to (G) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) teachers, including vocational educators;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) parents;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) members of local school boards;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(F) representatives of private school children; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(G) pupil services personnel.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e187d23-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e187d24-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
