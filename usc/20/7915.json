{"tag":"section","attrib":{"id":"id0e51b65e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7915"},"text":null,"children":[{"tag":"num","attrib":{"value":"7915"},"text":"§ 7915.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue regulations under this chapter only to the extent that such regulations are necessary to ensure that there is compliance with the specific requirements and assurances required by this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e51b65f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8535"},"text":"Pub. L. 89–10, title VIII, § 8535","children":[],"tail":", formerly title IX, § 9535, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1985"},"text":"115 Stat. 1985","children":[],"tail":"; renumbered title VIII, § 8535, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII/s8001/a/6"},"text":"Pub. L. 114–95, title VIII, § 8001(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089.)"}],"tail":"\n"}],"tail":null}
