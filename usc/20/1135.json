{"tag":"section","attrib":{"id":"id0d764a01-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135"},"text":null,"children":[{"tag":"num","attrib":{"value":"1135"},"text":"§ 1135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to academic departments and programs of institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d764a02-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d764a03-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants to academic departments, programs and other academic units of institutions of higher education that provide courses of study leading to a graduate degree, including a master’s or doctoral degree, in order to enable such institutions to provide assistance to graduate students in accordance with this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d764a04-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may also make grants to such departments, programs and other academic units of institutions of higher education granting graduate degrees which submit joint proposals involving nondegree granting institutions which have formal arrangements for the support of doctoral dissertation research with degree-granting institutions. Nondegree granting institutions eligible for awards as part of such joint proposals include any organization which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d764a05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":", and is exempt from tax under section 501(a) of such title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d764a06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is organized and operated substantially to conduct scientific and cultural research and graduate training programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d764a07-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a private foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d764a08-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has academic personnel for instruction and counseling who meet the standards of the institution of higher education in which the students are enrolled; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d764a09-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has necessary research resources not otherwise readily available in such institutions to such students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d764a0a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award and duration of grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d764a0b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The principal criterion for the award of grants shall be the relative quality of the graduate programs presented in competing applications. Consistent with an allocation of awards based on quality of competing applications, the Secretary shall, in awarding such grants, promote an equitable geographic distribution among eligible public and private institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d764a0c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration and amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d764a0d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award a grant under this subpart for a period of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d764a0e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award a grant to an academic department, program or unit of an institution of higher education under this subpart for a fiscal year in an amount that is not less than $100,000 and not greater than $750,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d764a0f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Secretary determines that an academic department, program or unit of an institution of higher education is unable to use all of the amounts available to the department, program or unit under this subpart, the Secretary shall, on such dates during each fiscal year as the Secretary may fix, reallot the amounts not needed to academic departments, programs and units of institutions which can use the grants authorized by this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d764a10-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference to continuing grant recipients","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d764a11-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make new grant awards under this subpart only to the extent that each previous grant recipient under this subpart has received continued funding in accordance with subsection (b)(2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d764a12-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratable reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that appropriations under this subpart are insufficient to comply with paragraph (1), available funds shall be distributed by ratably reducing the amounts required to be awarded under subsection (b)(2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d764a13-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s711"},"text":"Pub. L. 89–329, title VII, § 711","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVII/s701"},"text":"Pub. L. 105–244, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1790"},"text":"112 Stat. 1790","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s703/e/1"},"text":"Pub. L. 110–315, title VII, § 703(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3347"},"text":"122 Stat. 3347","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d764a14-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d764a15-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d764a16-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1134m"},"text":"section 1134m of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 1135, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tX/s1001"},"text":"Pub. L. 89–329, title X, § 1001","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tX/s1001/a"},"text":"Pub. L. 96–374, title X, § 1001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1489"},"text":"94 Stat. 1489","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tX/s1001"},"text":"Pub. L. 102–325, title X, § 1001","children":[],"tail":", "},{"tag":"d