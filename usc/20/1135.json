t":"90 Stat. 2165","children":[],"tail":", 2236; "},{"tag":"ref","attrib":{"href":"/us/pl/95/180/s1/c"},"text":"Pub. L. 95–180, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-15"},"text":"Nov. 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1372"},"text":"91 Stat. 1372","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/49/s53/a"},"text":"Pub. L. 96–49, § 53(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-13"},"text":"Aug. 13, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/354"},"text":"93 Stat. 354","children":[],"tail":", related to development plans for expansion or improvement of postsecondary education programs in community colleges, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/s1001/a"},"text":"section 1001(a) of Pub. L. 96–374","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1135, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tX/s1001"},"text":"Pub. L. 89–329, title X, § 1001","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/575/tII/s271"},"text":"Pub. L. 90–575, title II, § 271","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-16"},"text":"Oct. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1047"},"text":"82 Stat. 1047","children":[],"tail":", contained Congressional statement of purpose respecting improvement of graduate programs, prior to the general amendment of subchapter X of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/92/318"},"text":"Pub. L. 92–318","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s711"},"text":"section 711 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1132b"},"text":"section 1132b of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s711"},"text":"section 711 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1132b"},"text":"section 1132b of this title","children":[],"tail":", prior to the general amendment of part A of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s711"},"text":"section 711 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1132b"},"text":"section 1132b of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d764a17-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" inserted “, including a master’s or doctoral degree,” after “leading to a graduate degree”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
