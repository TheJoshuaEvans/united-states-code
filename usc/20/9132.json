{"tag":"section","attrib":{"id":"id0e5b2c44-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9132"},"text":null,"children":[{"tag":"num","attrib":{"value":"9132"},"text":"§ 9132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e5b2c45-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 4 percent of the total amount of funds received under this subchapter for any fiscal year by a State may be used for administrative costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e5b2c46-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to limit spending for evaluation costs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9134/c"},"text":"section 9134(c) of this title","children":[],"tail":" from sources other than this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e5b2c47-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/tII/s222"},"text":"Pub. L. 94–462, title II, § 222","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/e/tVII/s702"},"text":"Pub. L. 104–208, div. A, title I, § 101(e) [title VII, § 702]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30