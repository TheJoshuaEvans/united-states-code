{"tag":"section","attrib":{"id":"id0d8230b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161a"},"text":"§ 1161a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project GRAD","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d8230b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8230b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide support and assistance to programs implementing integrated education reform services in order to improve secondary school graduation, postsecondary program attendance, and postsecondary completion rates for low-income students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8230b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the establishment of new programs to implement such integrated education reform services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8230ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8230bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income student","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “low-income student” means a student who is determined by a local educational agency to be from a low-income family using the measures described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6313/a/5"},"text":"section 6313(a)(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8230bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feeder pattern","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “feeder pattern” means a secondary school and the elementary schools and middle schools that channel students into that secondary school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8230bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount appropriated to carry out this section, the Secretary is authorized to award a five-year contract to Project GRAD USA (referred to in this section as the “contractor”), a nonprofit education organization that has as its primary purpose the improvement of secondary school graduation and postsecondary attendance and completion rates for low-income students. Such contract shall be used to carry out the requirements of subsection (d) and to implement and sustain integrated education reform services through subcontractor activities described in subsection (e)(3) at existing Project GRAD program sites and to promote the expansion to new sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8230be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements of contract","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall enter into an agreement with the contractor that requires that the contractor shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8230bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into subcontracts with nonprofit educational organizations that serve a substantial number or percentage of low-income students (referred to in this subsection as “subcontractors”), under which the subcontractors agree to implement the Project GRAD programs described in subsection (e) and provide matching funds for such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8230c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" directly carry out—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8230c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities to implement and sustain the literacy, mathematics, classroom management, social service, and postsecondary access programs further described in subsection (e)(3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities to build the organizational and management capacity of the subcontractors to effectively implement and sustain the programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" activities for the purpose of improving and expanding the programs, including activities—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d8230c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to further articulate a program for one or more grade levels and across grade levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8230c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to tailor a program for a particular target audience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8230c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/d/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide tighter integration across programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities for the purpose of implementing new Project GRAD program sites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities for the purpose of promoting greater public awareness of integrated education reform services to improve secondary school graduation and postsecondary attendance rates for low-income students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities directly related to improving secondary school graduation and postsecondary attendance and completion rates for low-income students; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8230ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" use contract funds available under this section to pay—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8230cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under subsection (f); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs associated with carrying out the activities and providing the services, as provided in paragraph (2) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8230cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supported programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8230ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The subcontractor programs referred to in this subsection shall be known as Project GRAD programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8230cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feeder patterns","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each subcontractor shall implement a Project GRAD program and shall, with the agreement of the contractor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8230d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify or establish not less than one feeder pattern of public schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the integrated educational reform services described in paragraph (3) at each identified feeder pattern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8230d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated education reform services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The services provided through a Project GRAD program may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8230d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research-based programs in reading, mathematics, and classroom management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" campus-based social services programs, including a systematic approach to increase family and community involvement in the schools served by the Project GRAD program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a postsecondary access program that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d8230d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/e/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing postsecondary scholarships for students who meet established criteria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8230d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/e/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proven approaches for increasing student and family postsecondary awareness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8230d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/e/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance for students in applying for higher education financial aid; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other services identified by the contractor as necessary to increase secondary school graduation and postsecondary attendance and completion rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8230da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds made available to carry out this section, not more than five percent of such funds, or $4,000,000, whichever is less, shall be used by the contractor to pay for administration of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8230db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contribution and matching requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8230dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The contractor shall provide to each subcontractor an average of $200 for each student served by the subcontractor in the Project GRAD program, adjusted to take into consideration—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8230dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resources or funds available in the area where the subcontractor will implement the Project GRAD program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for the Project GRAD program in such area to improve student outcomes, including reading and mathematics achievement, secondary school graduation, and postsecondary attendance and completion rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8230df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each subcontractor shall provide funds for the Project GRAD program in an amount that is equal to the amount received by the subcontractor from the contractor. Such matching funds may be provided in cash or in kind, fairly evaluated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8230e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The contractor may waive, in whole or in part, the requirement of paragraph (2) for a subcontractor, if the subcontractor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8230e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates that the subcontractor would not otherwise be able to participate in the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enters into an agreement with the contractor with respect to the amount to which the waiver will apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8230e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8230e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation by the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall select an independent entity to evaluate, every three years, the performance of students who participate in a Project GRAD program under this section. The evaluation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8230e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be conducted using a rigorous research design for determining the effectiveness of the Project GRAD programs funded under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compare reading and mathematics achievement, secondary school graduation, and postsecondary attendance and completion rates of students who participate in a Project GRAD program funded under this section with those indicators for students of similar backgrounds who do not participate in such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8230e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation by contractor and subcontractors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The contractor shall require each subcontractor to prepare an in-depth report of the results and the use of funds of each Project GRAD program funded under this section that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8230e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data on the reading and mathematics achievement of students involved in the Project GRAD program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data on secondary school graduation and postsecondary attendance and completion rates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such financial reporting as required by the Secretary to review the effectiveness and efficiency of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8230eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of evaluations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Copies of any evaluation or report prepared under this subsection shall be made available to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8230ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authorizing committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8230ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d8230ef-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s801"},"text":"Pub. L. 89–329, title VIII, § 801","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3378"},"text":"122 Stat. 3378","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
