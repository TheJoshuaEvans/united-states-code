{"tag":"section","attrib":{"id":"id0d6819a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101"},"text":null,"children":[{"tag":"num","attrib":{"value":"1101"},"text":"§ 1101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings; purpose; and program authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6819a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6819a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hispanic Americans are at high risk of not enrolling or graduating from institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6819a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disparities between the enrollment of non-Hispanic white students and Hispanic students in postsecondary education are increasing. Between 1973 and 1994, enrollment of white secondary school graduates in 4-year institutions of higher education increased at a rate two times higher than that of Hispanic secondary school graduates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6819a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Despite significant limitations in resources, Hispanic-serving institutions provide a significant proportion of postsecondary opportunities for Hispanic students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6819a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Relative to other institutions of higher education, Hispanic-serving institutions are underfunded. Such institutions receive significantly less in State and local funding, per full-time equivalent student, than other institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6819a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Hispanic-serving institutions are succeeding in educating Hispanic students despite significant resource problems that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d6819aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the ability of such institutions to expand and improve the academic programs of such institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d6819ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could imperil the financial and administrative stability of such institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6819ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a national interest in remedying the disparities described in paragraphs (2) and (4) and ensuring that Hispanic students have an equal opportunity to pursue postsecondary opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6819ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this subchapter is to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6819ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand educational opportunities for, and improve the academic attainment of, Hispanic students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6819af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand and enhance the academic offerings, program quality, and institutional stability of colleges and universities that are educating the majority of Hispanic college students and helping large numbers of Hispanic students and other low-income individuals complete postsecondary degrees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6819b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide grants and related assistance to Hispanic-serving institutions to enable such institutions to improve and expand their capacity to serve Hispanic students and other low-income individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6819b1-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s501"},"text":"Pub. L. 89–329, title V, § 501","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tV/s501"},"text":"Pub. L. 105–244, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1765"},"text":"112 Stat. 1765","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6819b2-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6819b3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d6819b4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1101, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s500"},"text":"Pub. L. 89–329, title V, § 500","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tV/s501/a"},"text":"Pub. L. 102–325, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"