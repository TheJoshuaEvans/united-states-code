{"tag":"section","attrib":{"id":"id0d740052-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1131c–1"},"text":"§ 1131c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d740053-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute may provide financial assistance, in the form of summer stipends described in subsection (b) and Ralph Bunche scholarship assistance described in subsection (c), to low-income students to facilitate the participation of the students in the Institute’s programs under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d740054-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summer stipends","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d740055-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A student receiving a summer stipend under this section shall use such stipend to defray the student’s cost of participation in a summer institute program funded under this part, including the costs of travel, living, and educational expenses necessary for the student’s participation in such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d740056-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A summer stipend awarded to a student under this section shall not exceed $3,000 per summer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d740057-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ralph Bunche scholarship","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d740058-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A student receiving a Ralph Bunche scholarship under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d740059-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be a full-time student at an institution of higher education who is accepted into a program funded under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d74005a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall use such scholarship to pay costs related to the cost of attendance, as defined in section 1087","children":[{"tag":"i","attrib":{},"text":"ll","children":[],"tail":" of this title, at the institution of higher education in which the student is enrolled."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d74005b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1131c–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount and duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Ralph Bunche scholarship awarded to a student under this section shall not exceed $5,000 per academic year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d74005c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s626"},"text":"Pub. L. 89–329, title VI, § 626","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVI/s617/2"},"text":"Pub. L. 110–315, title VI, § 617(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3341"},"text":"122 Stat. 3341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d74005d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d74005e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d74005f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s626"},"text":"section 626 of Pub. L. 89–329","children":[],"tail":" was renumbered section 627, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1131d"},"text":"section 1131d of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s626"},"text":"section 626 of Pub. L. 89–329","children":[],"tail":" was renumbered section 628, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1131e"},"text":"section 1131e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
