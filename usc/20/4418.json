{"tag":"section","attrib":{"id":"id0deb2cad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4418"},"text":null,"children":[{"tag":"num","attrib":{"value":"4418"},"text":"§ 4418.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian preference","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0deb2cae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4418/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of Federal or State law, the Institute is authorized to develop a policy or policies for the Institute to extend preference to Indians in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0deb2caf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4418/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" admissions to, and enrollment in, programs conducted by the Institute,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2cb0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4418/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employment by the Institute, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2cb1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4418/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contracts, fellowships, and grants awarded by the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0deb2cb2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4418/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hiring preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4416/b/1"},"text":"section 4416(b)(1) of this title","children":[],"tail":", the President of the Institute shall, to the maximum extent practicable, give preference in hiring to Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0deb2cb3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXV/s1511"},"text":"Pub. L. 99–498, title XV, § 1511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1607"},"text":"100 Stat. 1607","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tXIII/s1331/e"},"text":"Pub. L. 102–325, title XIII, § 1331(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/807"},"text":"106 Stat. 807","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0deb2cb4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0deb2cb5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0deb2cb6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","chi