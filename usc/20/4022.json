{"tag":"section","attrib":{"id":"id0de400ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022"},"text":null,"children":[{"tag":"num","attrib":{"value":"4022"},"text":"§ 4022.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asbestos Trust Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de400ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of Trust Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a trust fund to be known as the “Asbestos Trust Fund”, consisting of such amounts as may be transferred or credited to such Trust Fund as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de400ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers to Trust Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de400af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are hereby transferred to the Asbestos Trust Fund amounts equivalent to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de400b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts received in the Treasury on or after ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", as repayments of loans made under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4014"},"text":"section 4014 of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de400b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts received as deposits from local educational agencies under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2647/a"},"text":"section 2647(a) of title 15","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de400b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts received as proceeds from any judgment recovered in any suit brought pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4017/a/1"},"text":"section 4017(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de400b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monthly transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts transferred by paragraph (1) shall be transferred at least monthly from the general fund of the Treasury to the Asbestos Trust Fund on the basis of estimates made by the Secretary of the Treasury of the amounts referred to in such paragraph. Adjustments shall be made in the amounts subsequently transferred to the extent prior estimates were more or less than the amounts required to be transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de400b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of Trust Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de400b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de400b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall invest such portion of the Asbestos Trust Fund as is not, in his judgment, required to meet current withdrawals. Such investments may be made only in interest-bearing obligations of the United States and may be acquired—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0de400b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on original issue at the issue price, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de400b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by purchase of outstanding obligations at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de400b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any obligation acquired by the Asbestos Trust Fund may be sold by the Secretary of the Treasury at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de400ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest on certain proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest on, and the proceeds from the sale or redemption of, any obligations held in the Asbestos Trust Fund shall be credited to and form a part of the Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de400bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1131/c"},"text":"Pub. L. 104–66, title I, § 1131(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/725"},"text":"109 Stat. 725","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de400bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures from Asbestos Trust Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Asbestos Trust Fund shall be available, as provided by appropriation Acts, only for purposes of carrying out the Asbestos Hazards Abatement Assistance Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4014"},"text":"section 4014 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de400bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to borrow","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de400be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Asbestos Trust Fund, as repayable advances, $25,000,000 for each of fiscal years 1987, 1988, 1989, and 1990.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de400bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of advances","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de400c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Advances made under this subsection shall be repaid, and interest on such advances shall be paid, to the general fund of the Treasury when the Secretary determines that moneys are available for such purposes in the Asbestos Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de400c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Interest on advances made under this subsection shall be at a rate determined by the Secretary (as of the close of the calendar month preceding the month in which the advance is made) to be equal to the current average market yield on outstanding marketable obligations of the United States with remaining periods to maturity comparable to the anticipated period during which the advance will be outstanding and shall be compounded annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de400c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4022/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amendments made by this section shall take effect on ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"January 1, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de400c3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/519/s5"},"text":"Pub. L. 99–519, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2990"},"text":"100 Stat. 2990","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/637/s12"},"text":"Pub. L. 101–637, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4593"},"text":"104 Stat. 4593","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1131/c"},"text":"Pub. L. 104–66, title I, § 1131(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/725"},"text":"109 Stat. 725","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de400c4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de400c5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0de400c6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Asbestos Hazard Emergency Response Act of 1986, and not as part of the Asbestos School Hazard Abatement Act of 1984 which comprises this subchapter nor as part of the Education for Economic Security Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0de400c7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" struck out heading and text of par. (2). Text read as follows: “It shall be the duty of the Secretary of the Treasury to hold the Asbestos Trust Fund and to report to the Congress each year on the financial condition and the results of the operations of the Trust Fund during the preceding fiscal year and on its expected condition and operations during the next 5 fiscal years.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s12/a"},"text":"Pub. L. 101–637, § 12(a)","children":[],"tail":", substituted a comma for “as in effect on "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":", and” in subpar. (A) and “, and” for period at end of subpar. (B), and added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s12/b"},"text":"Pub. L. 101–637, § 12(b)","children":[],"tail":", struck out before period at end “as in effect on "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
