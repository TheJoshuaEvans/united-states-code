{"tag":"section","attrib":{"id":"id0d8713df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161n–2"},"text":"§ 1161n–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for cooperative education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d8713e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8713e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized, from the amount available to carry out this section under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1161n–4"},"text":"section 1161n–4 of this title","children":[],"tail":" in each fiscal year and in accordance with the provisions of this part—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8713e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to award grants to institutions of higher education or consortia of such institutions that have not received a grant under this paragraph in the ten-year period preceding the date for which a grant under this section is requested to pay the Federal share of the cost of planning, establishing, expanding, or carrying out programs of cooperative education by such institutions or consortia of institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8713e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to award grants to institutions of higher education that are operating an existing cooperative education program as determined by the Secretary to pay the Federal share of the cost of planning, establishing, expanding, or carrying out programs of cooperative education by such institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Cooperative education programs assisted under this section shall provide alternating or parallel periods of academic study and of public or private employment, giving students work experience related to their academic or occupational objectives and the opportunity to earn the funds necessary for continuing and completing their education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8713e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of each grant awarded pursuant to paragraph (1)(A) to any institution of higher education or consortia of such institutions in any fiscal year shall not exceed $500,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8713e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d8713e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in clauses (ii) and (iii), the Secretary shall award grants in each fiscal year to each institution of higher education described in paragraph (1)(B) that has an application approved under subsection (b) in an amount that bears the same ratio to the amount reserved pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1161n–1/a/2"},"text":"section 1161n–1(a)(2) of this title","children":[],"tail":" for such fiscal year as the number of unduplicated students placed in cooperative education jobs during the preceding fiscal year by such institution of higher education (other than cooperative education jobs under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1161n–3"},"text":"section 1161n–3 of this title","children":[],"tail":" and as determined by the Secretary) bears to the total number of all such students placed in such jobs during the preceding fiscal year by all such institutions."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8713e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No institution of higher education shall receive a grant pursuant to paragraph (1)(B) in any fiscal year in an amount that exceeds 25 percent of such institution’s cooperative education program’s personnel and operating budget for the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8713ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The minimum annual grant amount that an institution of higher education is eligible to receive under paragraph (1)(B) is $1,000 and the maximum annual grant amount is $75,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not award grants pursuant to subparagraphs (A) and (B) of paragraph (1) to the same institution of higher education or consortia of such institution in any one fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under paragraph (1)(B) shall be used exclusively—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8713ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand the quality of and participation in a cooperative education program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8713ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for outreach to potential participants in new curricular areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8713ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for outreach to potential participants including underrepresented and nontraditional populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8713f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each institution of higher education or consortium of such institutions desiring to receive a grant under this section shall submit an application to the Secretary at such time and in such manner as the Secretary shall prescribe. Each such application shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8713f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the program or activities for which a grant is authorized under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify each portion of such program or activities which will be performed by a nonprofit organization or institution other than the applicant, and the amount of grant funds to be used for such program or activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the applicant will expend, during the fiscal year for which the grant is awarded for the purpose of such program or activities, not less than the amount expended for such purpose during the previous fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the plans which the applicant will carry out to assure, and contain a formal statement of the institution’s commitment that assures, that the applicant will continue the cooperative education program beyond the five-year period of Federal assistance described in subsection (c)(1) at a level that is not less than the total amount expended for such program during the first year such program was assisted under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that, in the case of an institution of higher education that provides a two-year program that is acceptable for full credit toward a bachelor’s degree, the cooperative education program will be available to students who are certificate or associate degree candidates and who carry at least one-half of the normal full-time academic workload;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide that the applicant will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8713f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make such reports as may be necessary to ensure that the applicant is complying with the provisions of this section, including reports for the second and each succeeding fiscal year for which the applicant receives a grant with respect to the impact of the cooperative education program in the previous fiscal year, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d8713f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of unduplicated student applicants in the cooperative education program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8713f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of unduplicated students placed in cooperative education jobs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8713fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employers who have hired cooperative education students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8713fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the income for students derived from working in cooperative education jobs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8713fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/6/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increase or decrease in the number of unduplicated students placed in cooperative education jobs in each fiscal year compared to the previous fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8713fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" keep such records as may be necessary to ensure that the applicant is complying with the provisions of this part, including the notation of cooperative education employment on the student’s transcript;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the extent to which programs in the academic disciplines for which the application is made have satisfactorily met the needs of public and private sector employers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8713ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the extent to which the institution is committed to extending cooperative education on an institution-wide basis for all students who can benefit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871400-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the plans that the applicant will carry out to evaluate the applicant’s cooperative education program at the end of the grant period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871401-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for such fiscal control and fund accounting procedures as may be necessary to ensure proper disbursement of, and accounting for, Federal funds paid to the applicant under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871402-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate a commitment to serving underserved populations at the institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871403-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include such other information as may be necessary to carry out the provisions of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d871404-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of grants; Federal share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d871405-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No individual institution of higher education may receive, individually or as a participant in a consortium of such institutions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d871406-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a grant pursuant to subsection (a)(1)(A) for more than five fiscal years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d871407-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a grant pursuant to subsection (a)(1)(B) for more than five fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871408-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal share of a grant under subsection (a)(1)(A) may not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895cf9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 85 percent of the cost of carrying out the program or activities described in the application in the first year the applicant receives a grant under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895cfa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 70 percent of such cost in the second such year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895cfb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 55 percent of such cost in the third such year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895cfc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40 percent of such cost in the fourth such year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895cfd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent of such cost in the fifth such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895cfe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary may not waive the provisions of paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895cff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that a recipient of funds under this section has failed to maintain the fiscal effort described in subsection (b)(3), then the Secretary may elect not to make grant payments under this section to such recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895d00-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors for special consideration of applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895d01-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In approving applications under this section, the Secretary shall give special consideration to applications from institutions of higher education or consortia of such institutions for programs that show the greatest promise of success based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895d02-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which programs in the academic discipline with respect to which the application is made have satisfactorily met the needs of public and private sector employers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d03-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strength of the commitment of the institution of higher education or consortium of such institutions to cooperative education as demonstrated by the plans and formalized institutional commitment statement which such institution or consortium has made to continue the program after the termination of Federal financial assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d04-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the institution or consortium of institutions is committed to extending cooperative education for students who can benefit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as are consistent with the purpose of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161n–2/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional special consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall also give special consideration to applications from institutions of higher education or consortia of such institutions that demonstrate a commitment to serving underserved populations attending such institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d895d07-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s833"},"text":"Pub. L. 89–329, title VIII, § 833","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3415"},"text":"122 Stat. 3415","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tVIII/s801/11"},"text":"Pub. L. 111–39, title VIII, § 801(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1956"},"text":"123 Stat. 1956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d895d08-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d895d09-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d895d0a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s801/11/A"},"text":"Pub. L. 111–39, § 801(11)(A)","children":[],"tail":", substituted “based on” for “because of” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s801/11/B"},"text":"Pub. L. 111–39, § 801(11)(B)","children":[],"tail":", substituted “purpose of this part” for “purposes of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d895d0b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d895d0c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/s3"},"text":"section 3 of Pub. L. 111–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
