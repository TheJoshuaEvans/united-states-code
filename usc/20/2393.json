{"tag":"section","attrib":{"id":"id0dc77703-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2393"},"text":null,"children":[{"tag":"num","attrib":{"value":"2393"},"text":"§ 2393.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to permit, allow, encourage, or authorize any Federal control over any aspect of a private, religious, or home school, regardless of whether a home school is treated as a private school or home school under State law. This section shall not be construed to bar students attending private, religious, or home schools from participation in programs or services under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0dc77704-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tII/s213"},"text":"Pub. L. 88–210, title II, § 213","children":[],"tail":", formerly title III, § 313, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/743"},"text":"120 Stat. 743","children":[],"tail":"; renumbered title II, § 213, "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/tII/s201/a/5"},"text":"Pub. L. 115–224, title II, § 201(a)(5)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"2018-07-31"},"text":"July 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1621"},"text":"132 Stat. 1621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dc77705-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dc77706-3a70-11f