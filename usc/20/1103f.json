{"tag":"section","attrib":{"id":"id0d6a6382-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1103f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1103f"},"text":"§ 1103f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being an officer, director, agent, or employee of, or connected in any capacity with, any recipient of Federal financial assistance or grant pursuant to this subchapter embezzles, willfully misapplies, steals, or obtains by fraud any of the funds that are the subject of such grant or assistance, shall be fined not more than $10,000 or imprisoned for not more than 2 years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d6a6383-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s527"},"text":"Pub. L. 89–329, title V, § 527","children":[],"tail":", formerly § 517, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tV/s501"},"text":"Pub. L. 105–244, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1774"},"text":"112 Stat. 1774","children":[],"tail":"; renumbered § 527, "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tV/s502/a/2"},"text":"Pub. L. 110–315, title V, § 502(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3331"},"text":"122 Stat. 3331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6a6384-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6a6385-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{