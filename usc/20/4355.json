{"tag":"section","attrib":{"id":"id0de8bb2e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4355"},"text":null,"children":[{"tag":"num","attrib":{"value":"4355"},"text":"§ 4355.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring, evaluation, and reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de8bb2f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4355/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct monitoring and evaluation activities of the education programs and activities and the administrative operations of the University (including the elementary, secondary, undergraduate, and graduate programs) and of NTID. The Secretary may also conduct studies related to the provision of preschool, elementary, secondary, and postsecondary education and other related services to individuals who are deaf or hard of hearing. In carrying out the responsibilities described in this section, the Secretary is authorized to employ such consultants as may be necessary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de8bb30-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4355/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall annually transmit information to Congress on the monitoring and evaluation activities pursuant to subsection (a), together with such recommendations, including recommendations for legislation, as the Secretary may consider necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de8bb31-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4355/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2009 through 2014 to carry out the monitoring and evaluation activities authorized under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de8bb32-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/371/tII/s205"},"text":"Pub. L. 99–371, title II, § 205","children":[],"tail":", formerly title IV, § 405, "},{"tag":"date","attrib":{"date":"1986-08-04"},"text":"Aug. 4, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/790"},"text":"100 Stat. 790","children":[],"tail":"; renumbered title II, § 205, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/421/tI"},"text":"Pub. L. 102–421, title I","children":[],"tail":", §§ 101(b)(5), (6), 135(a), "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2151"},"text":"106 Stat. 2151","children":[],"tail":", 2158; "},{"tag":"ref","attrib":{"href":"/us/pl/103/73/tII/s204/d"},"text":"Pub. L. 103–73, title II, § 204(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/735"},"text":"107 Stat. 735","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s918"},"text":"Pub. L. 105–244, title IX, § 918","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1831"},"text":"112 Stat. 1831","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s907"},"text":"Pub. L. 110–315, title IX, § 907","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3453"},"text":"122 Stat. 3453","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de8bb33-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de8bb34-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0de8bb35-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s907/1"},"text":"Pub. L. 110–315, § 907(1)","children":[],"tail":", struck out “preparatory,” before “undergraduate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s907/2"},"text":"Pub. L. 110–315, § 907(2)","children":[],"tail":", substituted “The Secretary shall annually transmit information to Congress on” for “The Secretary, as part of the annual report required under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3486"},"text":"section 3486 of this title","children":[],"tail":", shall include a description of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attr