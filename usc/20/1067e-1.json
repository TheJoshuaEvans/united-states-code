{"tag":"section","attrib":{"id":"id0cdb4305-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1067e–1"},"text":"§ 1067e–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of entry into STEM fields","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cdb4306-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to contract, subject to appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to enter into a contract with a firm with a demonstrated record of success in advertising to implement a campaign to expand the population of qualified individuals in science, technology, engineering, and mathematics fields (referred to in this section as “STEM fields”) by encouraging young Americans to enter such fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cdb4307-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design of campaign","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The campaign under this section shall be designed to enhance the image of education and professions in the STEM fields and promote participation in the STEM fields, and may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cdb4308-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring trends in youths’ attitudes toward pursuing education and professions in the STEM fields and their propensity toward entering the STEM fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb4309-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining what factors contribute to encouraging and discouraging Americans from pursuing study in STEM fields and entering the STEM fields professionally;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb430a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining what specific factors limit the participation of groups currently underrepresented in STEM fields, including Latinos, African-Americans, and women; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb430b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drawing from the market research performed under this section and implementing an advertising campaign to encourage young Americans to take up studies in STEM fields, beginning at an early age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cdb430c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The campaign under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cdb430d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include components that focus tailored messages on appropriate age groups, starting with elementary school students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb430e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" link participation in the STEM fields to the concept of service to one’s country, so that young people will be encouraged to enter the STEM fields in order fulfill the obligation to be of service to their country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cdb430f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The campaign under this section shall hold as a high priority making specific appeals to Hispanic Americans, African Americans, Native Americans, students with disabilities, and women, who are currently underrepresented in the STEM fields, in order to increase their numbers in the STEM fields, and shall tailor recruitment efforts to each specific group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cdb4310-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of variety of media","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The campaign under this section shall make use of a variety of media, with an emphasis on television advertising, to reach its intended audience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cddb311-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Teaching","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The campaign under this section shall include a narrowly focused effort to attract current professionals in the STEM fields, through advertising in mediums likely to reach that specific group, into teaching in a STEM field in elementary schools and secondary schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cddb312-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s356"},"text":"Pub. L. 89–329, title III, § 356","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIII/s315/a/2"},"text":"Pub. L. 110–315, title III, § 315(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3183"},"text":"122 Stat. 3183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cddb313-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cddb314-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cddb315-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s356"},"text":"section 356 of Pub. L. 89–329","children":[],"tail":" was renumbered section 395 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1068d"},"text":"section 1068d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
