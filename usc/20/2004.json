{"tag":"section","attrib":{"id":"id0db6ae53-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2004"},"text":null,"children":[{"tag":"num","attrib":{"value":"2004"},"text":"§ 2004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harry S Truman Scholarship Foundation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0db6ae54-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established, as an independent establishment of the executive branch of the United States Government, the Harry S Truman Scholarship Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db6ae55-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Trustees; membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db6ae56-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2004/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002132"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002132"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" The Foundation shall be subject to the supervision and direction of a Board of Trustees. The Board shall be composed of thirteen members, as follows:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db6ae57-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2004/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two Members of the Senate, one from each political party, to be appointed by the President of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db6ae58-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2004/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two Members of the House of Representatives, one from each political party, to be appointed by the Speaker;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db6ae59-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2004/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eight members, not more than four of whom shall be of the same political party, to be appointed by the President with the advice and consent of the Senate, of whom one shall be a chief executive officer of a State, one a chief executive officer of a city or county, one a member of a Federal court, one a member of a State court, one a person active in postsecondary education, and three representatives of the general public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db6ae5a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2004/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Education or his designate, who shall serve ex officio as a member of the Board, but shall not be eligible to serve as Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db6ae5b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2004/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of office of each member of the Board shall be six years; except that (1) the members first taking office shall serve as designated by the President, four for terms of two years, five for terms of four years, and four for terms of six years, and (2) any member appointed to fill a vacancy shall serve for the remainder of the term for which his predecessor was appointed, and shall be appointed in the same manner as the original appointment for that vacancy was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db6ae5c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2004/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board shall serve without pay, but shall be entitled to reimbursement for travel, subsistence, and other necessary expenses incurred in the performance of their duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0db6ae5d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/642/s5"},"text":"Pub. L. 93–642, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2277"},"text":"88 Stat. 2277","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIII/s301/a/1"},"text":"Pub. L. 96–88, title III, § 301(a)(1)","children":[],"tail":", title V, § 507, "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/677"},"text":"93 Stat. 677","children":[],"tail":", 692.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db6ae5e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0db6ae5f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0db6ae60-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Education” substituted for “Commissioner of Education” in subsec. (b)(1)(D) pursuant to sections 301(a)(1) and 507 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88"},"text":"Pub. L. 96–88","children":[],"tail":", which are classified to sections 3441(a)(1) and 3507 of this title and which transferred functions of Commissioner of Education to Secretary of Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
