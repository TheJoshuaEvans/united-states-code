{"tag":"section","attrib":{"id":"id0df4c919-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5604"},"text":null,"children":[{"tag":"num","attrib":{"value":"5604"},"text":"§ 5604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of Foundation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of the Foundation to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df4c91a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5604/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase awareness of the importance of and promote the benefit and enjoyment of the Nation’s natural resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c91b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5604/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster among the American population greater recognition and understanding of the role of the environment, public lands and resources in the development of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c91c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5604/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify critical environmental issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c91d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5604/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a program for environmental policy research at the Center and a program for environmental conflict resolution and training at the National Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c91e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5604/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop resources to properly train professionals in the environmental, natural resource, conflict resolution, and related fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c91f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5604/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide educational outreach regarding environmental policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c920-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5604/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop resources at the Native Nations Institute to properly train Native American and Alaska Native professionals in health care and public policy, by providing education to and conducting management and leadership training of Native Americans, Alaska Natives, and others involved in tribal leadership, providing assistance and resources for policy analysis, and carrying out other appropriate activities.; ","children":[{"tag":"ref","attrib":{"idref":"fn002187"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002187"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c921-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5604/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish as part of the Foundation the John S. McCain III National Center for Environmental Conflict Resolution to assist the Federal Government in implementing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4331"},"text":"section 4331 of title 42","children":[],"tail":" by providing assessment, mediation, and other related services to resolve environmental issues, conflicts, and disputes involving agencies and instrumentalities of the United States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c922-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5604/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complement the direction established by the President in Executive Order No. 12988 (61 Fed. Reg. 4729; relating to civil justice reform).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0df4c923-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/259/s6"},"text":"Pub. L. 102–259, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-19"},"text":"Mar. 19, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/80"},"text":"106 Stat. 80","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/156/s4"},"text":"Pub. L. 105–156, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-02-11"},"text":"Feb. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/9"},"text":"112 Stat. 9","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/568/tVIII/s817/a"},"text":"Pub. L. 106–568, title VIII, § 817(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2918"},"text":"114 Stat. 2918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tIII/s304"},"text":"Pub. L. 116–94, div. P, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3187"},"text":"133 Stat. 3187","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0df4c924-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0df4c925-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0df4c926-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order No. 12988, referred to in par. (9), is set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s519"},"text":"section 519 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0df4c927-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s304/1"},"text":"Pub. L. 116–94, § 304(1)","children":[],"tail":", substituted “establish a program for environmental policy research at the Center and a program for environmental conflict resolution and training at the National Center” for “establish a Program for Environmental Policy Research and Environmental Conflict Resolution and Training at the Center”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s304/2"},"text":"Pub. L. 116–94, § 304(2)","children":[],"tail":", inserted “, natural resource, conflict resolution,” after “environmental”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s304/3"},"text":"Pub. L. 116–94, § 304(3)","children":[],"tail":", inserted “at the Native Nations Institute” after “develop resources” and “providing education to and” after “policy, by”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s304/4"},"text":"Pub. L. 116–94, § 304(4)","children":[],"tail":", substituted “John S. McCain III National Center for Environmental Conflict Resolution” for “United States Institute for Environmental Conflict Resolution” and “resolve environmental issues, conflicts, and” for “resolve environmental”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/568"},"text":"Pub. L. 106–568","children":[],"tail":" inserted before semicolon at end “, by conducting management and leadership training of Native Americans, Alaska Natives, and others involved in tribal leadership, providing assistance and resources for policy analysis, and carrying out other appropriate activities.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/156/s4/1"},"text":"Pub. L. 105–156, § 4(1)","children":[],"tail":", substituted “Environmental Conflict Resolution and Training” for “an Environmental Conflict Resolution”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (8), (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/156/s4/2"},"text":"Pub. L. 105–156, § 4(2)","children":[],"tail":"–(4), added pars. (8) and (9)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
