{"tag":"section","attrib":{"id":"id0e350624-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7402"},"text":null,"children":[{"tag":"num","attrib":{"value":"7402"},"text":"§ 7402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this part to support the efforts of local educational agencies, Indian tribes and organizations, postsecondary institutions, and other entities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e350625-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7402/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet the unique educational and culturally related academic needs of Indian students, so that such students can meet the challenging State academic standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e350626-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7402/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that Indian students gain knowledge and understanding of Native communities, languages, tribal histories, traditions, and cultures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e350627-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7402/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that teachers, principals, other school leaders, and other staff who serve Indian students have the ability to provide culturally appropriate and effective instruction and supports to such students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e350628-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6102"},"text":"Pub. L. 89–10, title VI, § 6102","children":[],"tail":", formerly title VII, § 7102, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1907"},"text":"115 Stat. 1907","children":[],"tail":"; renumbered title VI, § 6102, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI"},"text":"Pub. L. 114–95, title VI","children":[],"tail":", §§ 6001(a), (b)(1), 6002(b), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":", 2047.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e350629-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e35062a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e35062b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7402, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVII/s7102"},"text":"Pub. L. 89–10, title VII, § 7102","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3716"},"text":"108 Stat. 3716","children":[],"tail":", set forth findings, policy, and purpose of Bilingual Education Act, prior to the general amendment of former subchapter VII of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s6102"},"text":"section 6102 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7312"},"text":"section 7312 of this title","children":[],"tail":", prior to the general amendment of former subchapter VI of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s6102"},"text":"section 6102 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3262"},"text":"section 3262 of this title","children":[],"tail":", prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 7403 to 7405 were omitted in the general amendment of former subchapter VII of this chapter by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7403, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVII/s7103"},"text":"Pub. L. 89–10, title VII, § 7103","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3718"},"text":"108 Stat. 3718","children":[],"tail":", authorized appropriations for bilingual education."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7404, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVII/s7104"},"text":"Pub. L. 89–10, title VII, § 7104","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3718"},"text":"108 Stat. 3718","children":[],"tail":", related to Native American and Alaska Native children in school."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7405, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVII/s7105"},"text":"Pub. L. 89–10, title VII, § 7105","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3719"},"text":"108 Stat. 3719","children":[],"tail":", related to residents of territories and freely associated nations."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e35062c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/b"},"text":"Pub. L. 114–95, § 6002(b)","children":[],"tail":", amended section generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—It is the purpose of this part to support the efforts of local educational agencies, Indian tribes and organizations, postsecondary institutions, and other entities to meet the unique educational and culturally related academic needs of American Indian and Alaska Native students, so that such students can meet the same challenging State student academic achievement standards as all other students are expected to meet."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Programs","children":[],"tail":".—This part carries out the purpose described in subsection (a) of this section by authorizing programs of direct assistance for—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) meeting the unique educational and culturally related academic needs of American Indians and Alaska Natives;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the education of Indian children and adults;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) the training of Indian persons as educators and counselors, and in other professions serving Indian people; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) research, evaluation, data collection, and technical assistance.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e35062d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e35062e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
