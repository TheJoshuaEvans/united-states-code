{"tag":"section","attrib":{"id":"id0ca6ebc3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s927"},"text":null,"children":[{"tag":"num","attrib":{"value":"927"},"text":"§ 927.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment formula","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ca6ebc4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s927/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment by regulation of minimum allotment formula; criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall by regulation establish a formula for determining the minimum allotment of funds necessary for the operation of each school in the defense dependents’ education system. In establishing such formula, the Director shall take into consideration—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ca6ebc5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s927/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of students served by a school and the size of the school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6ebc6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s927/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" special cost factors for a school, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ca6ebc7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s927/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geographic isolation of the school,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ca6ebc8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s927/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a need for special staffing, transportation, or educational programs at the school, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ca6ebc9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s927/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unusual food and housing costs,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6ebca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s927/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of providing academic services of a high quality as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s921/b/1"},"text":"section 921(b)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6ebcb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s927/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as the Director considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ca6ebcc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s927/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance, etc., of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any regulation under subsection (a) shall be issued, and shall become effective, in accordance with the procedures applicable to regulations required to be issued by the Secretary of Education in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232"},"text":"section 1232 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ca6ebcd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s927/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ca6ebce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s927/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Children with disabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s921/b/3"},"text":"section 921(b)(3) of this title","children":[],"tail":", the provisions of part B of the Individuals with Disabilities Education Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1411"},"text":"20 U.S.C. 1411","children":[],"tail":" et seq.], other than the funding and reporting provisions, shall apply to all schools operated by the Department of Defense under this chapter, including the requirement that children with disabilities, aged 3 to 5, inclusive, receive a free appropriate public education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6ebcf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s927/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Infants and toddlers with disabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responsibility to provide comparable early intervention services to infants and toddlers with disabilities and their families in accordance with individualized family service plans described in section 636 of the Individuals with Disabilities Education Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1436"},"text":"20 U.S.C. 1436","children":[],"tail":"] and to comply with the procedural safeguards set forth in part C of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1431"},"text":"20 U.S.C. 1431","children":[],"tail":" et seq.] shall apply with respect to all eligible dependents overseas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6ebd0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s927/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (2), the Secretary shall have in effect a comprehensive, coordinated, multidisciplinary program of early intervention services for infants and toddlers with disabilities among Department of Defense entities involved in the provision of such services to such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ca6ebd1-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXIV/s1409"},"text":"Pub. L. 95–561, title XIV, § 1409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2369"},"text":"92 Stat. 2369","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/119/s24"},"text":"Pub. L. 102–119, § 24","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-07"},"text":"Oct. 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/605"},"text":"105 Stat. 605","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIII/s354/3"},"text":"Pub. L. 106–65, div. A, title III, § 354(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/573"},"text":"113 Stat. 573","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tIII/s305/b"},"text":"Pub. L. 108–446, title III, § 305(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2804"},"text":"118 Stat. 2804","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ca6ebd2-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ca6ebd3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0ca6ebd4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in subsec. (c)(1), (2), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":". Parts B and C of the Act are classified generally to subchapters II (§ 1411 et seq.) and III (§ 1431 et seq.), respectively, of chapter 33 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ca6ebd5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/446"},"text":"Pub. L. 108–446","children":[],"tail":" substituted “section 636” for “section 677” and “part C” for “part H”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s354/3/A"},"text":"Pub. L. 106–65, § 354(3)(A)","children":[],"tail":", substituted “Secretary of Education” for “Department of Health, Education, and Welfare” and made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232"},"text":"section 1232 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s354/3/B"},"text":"Pub. L. 106–65, § 354(3)(B)","children":[],"tail":", struck out “by academic year 1993–1994” after “public education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s354/3/C"},"text":"Pub. L. 106–65, § 354(3)(C)","children":[],"tail":", substituted “Implementation” for “Implementation timelines” in heading, substituted “In carrying out paragraph (2), the Secretary shall have in effect a comprehensive” for “In carrying out the provisions of paragraph (2), the Secretary shall—”, struck out the subpar. (A) designation and “in academic year 1991–1992 and the 2 succeeding academic years, plan and develop a comprehensive” before “, coordinated”, substituted a period for the semicolon after “such individuals”, and struck out subpars. (B) and (C) which related to implementation in academic years 1994–1995, 1995–1996, and succeeding academic years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/119"},"text":"Pub. L. 102–119","children":[],"tail":" amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “The provisions of the Education for All Handicapped Children Act of 1975 shall apply with respect to all schools operated by the Department of Defense under this chapter.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ca6ebd6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0ca6ebd7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/119/s27"},"text":"Pub. L. 102–119, § 27","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-07"},"text":"Oct. 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/608"},"text":"105 Stat. 608","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/119/s27"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sections","children":[],"tail":" 8, 9, "},{"tag":"inline","attrib":{},"text":"and","children":[],"tail":" 10.—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by sections 8, 9, and 10 [amending sections 1423, 1431, 1434, and 1435 of this title] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":", or on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1991-10-07"},"text":"Oct. 7, 1991","children":[],"tail":"], whichever is later."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sections","children":[],"tail":" 5, 12, 13, 14, 15, 17, "},{"tag":"inline","attrib":{},"text":"and","children":[],"tail":" 18.—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by sections 5, 12, 13, 14, 15, 17, and 18 [amending sections 1413, 1472, 1476, 1477, 1478, 1480, and 1482 of this title] shall take effect ","children":[{"tag":"date","attrib":{"date":"1992-07-01"},"text":"July 1, 1992","children":[],"tail":", except that each State shall have the option to have any of the amendments apply earlier than such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remaining Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The remaining sections of this Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1484a"},"text":"section 1484a of this title","children":[],"tail":", amending this section, sections 241, 1087ee, 1400 to 1402, 1404, 1405, 1407, 1411 to 1417, 1419, 1421 to 1425, 1431 to 1433, 1435, 1442, 1443, 1451, 1452, 1461, 1471 to 1473, and 1475 to 1485 of this title, sections 2503 and 2504 of Title 25, Indians, sections 721, [former] 774, 777a, 795m, and 796d of Title 29, Labor, and sections 1396b, 1396n, 6022, 6024, 9835, 9855d, 9862, and 9886 of Title 42, The Public Health and Welfare, and enacting provisions set out as notes under this section and sections 1400 and 1484 of this title] and the amendments made by such sections shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1991-10-07"},"text":"Oct. 7, 1991","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
