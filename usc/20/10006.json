{"tag":"section","attrib":{"id":"id0e70af2b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10006"},"text":null,"children":[{"tag":"num","attrib":{"value":"10006"},"text":"§ 10006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State incentive grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e70af2c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e70af2d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10006/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the total amount reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s10001/c"},"text":"section 10001(c) of this title","children":[],"tail":" that is not used for "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s10007"},"text":"section 10007 of this title","children":[],"tail":", the Secretary may reserve up to 1 percent for technical assistance to States to assist them in meeting the objectives of paragraphs (2), (3), (4), and (5) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s10005/d"},"text":"section 10005(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e70af2e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10006/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remainder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the remaining funds, the Secretary shall, in fiscal year 2010, make grants to States that have made significant progress in meeting the objectives of paragraphs (2), (3), (4), and (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s10005/d"},"text":"section 10005(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e70af2f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis for grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine which States receive grants under this section, and the amount of those grants, on the basis of information provided in State applications under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s10005"},"text":"section 10005 of this title","children":[],"tail":" and such other criteria as the Secretary determines appropriate, which may include a State’s need for assistance to help meet the objective of paragraphs "},{"tag":"ref","attrib":{"idref":"fn002261"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002261"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “paragraph”."}],"tail":" (2), (3), (4), (5), or (6) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s10005/d"},"text":"section 10005(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e70af30-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10006/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subgrants to local educational agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e70af31-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10006/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State receiving a grant under this section shall use at least 50 percent of the grant to provide local educational agencies in the State with subgrants based on their relative shares of funding under part A of title I of the ESEA (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311"},"text":"20 U.S.C. 6311","children":[],"tail":" et seq.) for the most recent year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e70af32-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10006/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) does not apply to grants made by the Secretary to consortia of States to develop academic assessments that are aligned with academic standards, or to a State or States for improving early childhood care and education except that such a State may use its grant funds to make subgrants to public or private agencies and organizations for activities consistent with the purposes of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e70af33-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIV/s14006"},"text":"Pub. L. 111–5, div. A, title XIV, § 14006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/283"},"text":"123 Stat. 283","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/117/dD/tIII/s310"},"text":"Pub. L. 111–117, div. D, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-12-16"},"text":"Dec. 16, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3272"},"text":"123 Stat. 3272","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/10/dB/tVIII/s1832/b/2"},"text":"Pub. L. 112–10, div. B, title VIII, § 1832(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-04-15"},"text":"Apr. 15, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/164"},"text":"125 Stat. 164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dF/tIII/s308"},"text":"Pub. L. 112–74, div. F, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1100"},"text":"125 Stat. 1100","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e70af34-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e70af35-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e70af36-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"ESEA, referred to in subsec. (c)(1), is the Elementary and Secondary Education Act of 1965, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-04-11"},"text":"Apr. 11, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/27"},"text":"79 Stat. 27","children":[],"tail":". Part A of title I of the Act is classified generally to part A (§ 6311 et seq.) of subchapter I of chapter 70 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e70af37-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/10/s1832/b/2/A"},"text":"Pub. L. 112–10, § 1832(b)(2)(A)","children":[],"tail":", substituted “(5), or (6)” for “and (5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74"},"text":"Pub. L. 112–74","children":[],"tail":" inserted before period at end “except that such a State may use its grant funds to make subgrants to public or private agencies and organizations for activities consistent with the purposes of the grant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/10/s1832/b/2/B"},"text":"Pub. L. 112–10, § 1832(b)(2)(B)","children":[],"tail":", inserted before period at end “, or to a State or States for improving early childhood care and education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/117"},"text":"Pub. L. 111–117","children":[],"tail":" designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
