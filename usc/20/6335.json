 county who constitute not more than 15.00 percent, inclusive, of the county’s total population aged 5 to 17, inclusive, multiplied by 1.0;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0c96cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such children who constitute more than 15.00 percent, but not more than 19.00 percent, of such population, multiplied by 1.75;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0c96cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such children who constitute more than 19.00 percent, but not more than 24.20 percent, of such population, multiplied by 2.5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0c96ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such children who constitute more than 24.20 percent, but not more than 29.20 percent, of such population, multiplied by 3.25; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0c96cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such children who constitute more than 29.20 percent of such population, multiplied by 4.0.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c96d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/