, inclusive, of the agency’s total population aged 5 to 17, inclusive, multiplied by 1.0;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0c96e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such children between 692 and 2,262, inclusive, in such population, multiplied by 1.5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0c96e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such children between 2,263 and 7,851, inclusive, in such population, multiplied by 2.0;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0c96e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/c/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such children between 7,852 and 35,514, inclusive, in such population, multiplied by 2.5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0c96e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/c/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such children in excess of 35,514 in such population, multiplied by 3.0.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c96e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Puerto Rico","children"