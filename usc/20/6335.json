{"tag":"section","attrib":{"id":"id0e0c96bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335"},"text":null,"children":[{"tag":"num","attrib":{"value":"6335"},"text":"§ 6335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Targeted grants to local educational agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e0c96bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of local educational agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0c96be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A local educational agency in a State is eligible to receive a targeted grant under this section for any fiscal year if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0c96bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of children in the local educational agency counted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/c"},"text":"section 6333(c) of this title","children":[],"tail":", before application of the weighted child count described in subsection (c), is at least 10; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c96c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the number of children counted for grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/c"},"text":"section 6333(c) of this title","children":[],"tail":", before application of the weighted child count described in subsection (c), is at least 5 percent of the total number of children aged 5 to 17 years, inclusive, in the school district of the local educational agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c96c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any fiscal year for which the Secretary allocates funds under this section on the basis of counties, funds made available as a result of applying this subsection shall be reallocated by the State educational agency to other eligible local educational agencies in the State in proportion to the distribution of other funds under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0c96c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for local educational agencies, the District of Columbia, and the Commonwealth of Puerto Rico","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0c96c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the grant that a local educational agency in a State (other than the Commonwealth of Puerto Rico) is eligible to receive under this section for any fiscal year shall be the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0c96c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the weighted child count determined under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c96c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/a/1/B"},"text":"section 6333(a)(1)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c96c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Puerto Rico","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, the amount of the grant the Commonwealth of Puerto Rico is eligible to receive under this section shall be equal to the number of children counted under subsection (c) for the Commonwealth of Puerto Rico, multiplied by the amount determined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/a/4"},"text":"section 6333(a)(4) of this title","children":[],"tail":" for the Commonwealth of Puerto Rico."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0c96c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6335/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"tex