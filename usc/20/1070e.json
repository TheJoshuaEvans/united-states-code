{"tag":"section","attrib":{"id":"id0cf337ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070e"},"text":"§ 1070e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child care access means parents in school","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cf337eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to support the participation of low-income parents in postsecondary education through the provision of campus-based child care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cf337ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cf337ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants to institutions of higher education to assist the institutions in providing campus-based child care services to low-income students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf337ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cf337ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant awarded to an institution of higher education under this section for a fiscal year shall not exceed 1 percent of the total amount of all Federal Pell Grant funds awarded to students enrolled at the institution of higher education for the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cf337f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cf337f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), a grant under this section shall be awarded in an amount that is not less than $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cf337f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase trigger","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any fiscal year for which the amount appropriated under the authority of subsection (g) is equal to or greater than $20,000,000, a grant under this section shall be awarded in an amount that is not less than $30,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf337f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration; renewal; and payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cf337f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award a grant under this section for a period of 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cf337f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (e)(2), the Secretary shall make annual grant payments under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf337f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of higher education shall be eligible to receive a grant under this section for a fiscal year if the total amount of all Federal Pell Grant funds awarded to students enrolled at the institution of higher education for the preceding fiscal year equals or exceeds $350,000, except that for any fiscal year for which the amount appropriated to carry out this section is equal to or greater than $20,000,000, this sentence shall be applied by substituting “$250,000” for “$350,000”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf337f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grant funds under this section shall be used by an institution of higher education to support or establish a campus-based child care program primarily serving the needs of low-income students enrolled at the institution of higher education. Grant funds under this section may be used to provide before and after school services to the extent necessary to enable low-income students enrolled at the institution of higher education to pursue postsecondary education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf337f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prohibit an institution of higher education that receives grant funds under this section from serving the child care needs of the community served by the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf337f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of low-income student","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this section, the term “low-income student” means a student—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cf337fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is eligible to receive a Federal Pell Grant for the award year for which the determination is made; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cf337fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who would otherwise be eligible to receive a Federal Pell Grant for the award year for which the determination is made, except that the student fails to meet the requirements of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cf337fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a/c/1"},"text":"section 1070a(c)(1) of this title","children":[],"tail":" because the student is enrolled in a graduate or first professional course of study; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cf337fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1091/a/5"},"text":"section 1091(a)(5) of this title","children":[],"tail":" because the student is in the United States for a temporary purpose."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf337fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publicity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publicize the availability of grants under this section in appropriate periodicals, in addition to publication in the Federal Register, and shall inform appropriate educational organizations of such availability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cf337ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education desiring a grant under this section shall submit an application to the Secretary at such time, in such manner, and accompanied by such information as the Secretary may require. Each application shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cf33800-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate that the institution is an eligible institution described in subsection (b)(4);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf33801-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the amount of funds requested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf33802-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demonstrate the need of low-income students at the institution for campus-based child care services by including in the application—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cf33803-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding student demographics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cf33804-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of child care capacity on or near campus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cf33805-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding the existence of waiting lists for existing child care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cf33806-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding additional needs created by concentrations of poverty or by geographic isolation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cf33807-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant data;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf33808-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain a description of the activities to be assisted, including whether the grant funds will support an existing child care program or a new child care program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf33809-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the resources, including technical expertise and financial support, the institution will draw upon to support the child care program and the participation of low-income students in the program, such as accessing social services funding, using student activity fees to help pay the costs of child care, using resources obtained by meeting the needs of parents who are not low-income students, and accessing foundation, corporate or other institutional support, and demonstrate that the use of the resources will not result in increases in student tuition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf3380a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain an assurance that the institution will meet the child care needs of low-income students through the provision of services, or through a contract for the provision of services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf3380b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the extent to which the child care program will coordinate with the institution’s early childhood education curriculum, to the extent the curriculum is available, to meet the needs of the students in the early childhood education program at the institution, and the needs of the parents and children participating in the child care program assisted under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf3380c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an institution seeking assistance for a new child care program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cf3380d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a timeline, covering the period from receipt of the grant through the provision of the child care services, delineating the specific steps the institution will take to achieve the goal of providing low-income students with child care services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cf3380e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify any measures the institution will take to assist low-income students with child care during the period before the institution provides child care services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cf3380f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a plan for identifying resources needed for the child care services, including space in which to provide child care services, and technical assistance if necessary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf33810-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain an assurance that any child care facility assisted under this section will meet the applicable State or local government licensing, certification, approval, or registration requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf33811-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain a plan for any child care facility assisted under this section to become accredited within 3 years of the date the institution first receives assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cf33812-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall give priority in awarding grants under this section to institutions of higher education that submit applications describing programs that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cf33813-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage significant local or institutional resources, including in-kind contributions, to support the activities assisted under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf33814-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize a sliding fee scale for child care services provided under this section in order to support a high number of low-income parents pursuing postsecondary education at the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cf33815-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements; continuing eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cf33816-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cf33817-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each institution of higher education receiving a grant under this section shall report to the Secretary annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cf33818-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cf33819-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data on the population served under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cf3381a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on campus and community resources and funding used to help low-income students access child care services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cf3381b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on progress made toward accreditation of any child care facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cf3381c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/e/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the impact of the grant on the quality, availability, and affordability of campus-based child care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cf3381d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make continuation awards under this section to an institution of higher education only if the Secretary determines, on the basis of the reports submitted under paragraph (1), that the institution is making a good faith effort to ensure that low-income students at the institution have access to affordable, quality child care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cf3381e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds provided under this section shall be used for construction, except for minor renovation or repair to meet applicable State or local health or safety requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cf3381f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070e/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cf33820-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s419N"},"text":"Pub. L. 89–329, title IV, § 419N","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s410"},"text":"Pub. L. 105–244, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1668"},"text":"112 Stat. 1668","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s410"},"text":"Pub. L. 110–315, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3225"},"text":"122 Stat. 3225","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cf33821-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cf33822-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","chil