ail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/49/s5/a/7"},"text":"Pub. L. 96–49, § 5(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-13"},"text":"Aug. 13, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/352"},"text":"93 Stat. 352","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tIV/s407"},"text":"Pub. L. 96–374, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1412"},"text":"94 Stat. 1412","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/300/tI/s183"},"text":"Pub. L. 97–300, title I, § 183","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-13"},"text":"Oct. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1357"},"text":"96 Stat. 1357","children":[],"tail":"; renumbered § 420A, "},{"tag":"ref","attrib":{"href":"/us/pl/98/558/tVIII/s801/b/2"},"text":"Pub. L. 98–558, title VIII, § 801(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2902"},"text":"98 Stat. 2902","children":[],"tail":", related to veterans’ cost-of-instruction payments to institutions of higher education, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cf33824-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s410/a"},"text":"Pub. L. 110–315, § 410(a)","children":[],"tail":", designated existing provisions as cl. (i), inserted heading, substituted “Except as provided in clause (ii), a grant” for “A grant”, and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s410/b"},"text":"Pub. L. 110–315, § 410(b)","children":[],"tail":", inserted “, except that for any fiscal year for which the amount appropriated to carry out this section is equal to or greater than $20,000,000, this sentence shall be applied by substituting ‘$250,000’ for ‘$350,000’ ” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s410/c"},"text":"Pub. L. 110–315, § 410(c)","children":[],"tail":", amended par. (7) generally. Prior to amendment, text read as follows: “For the purpose of this section, the term ‘low-income student’ means a student who is eligible to receive a Federal Pell Grant for the fiscal year for which the determination is made.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s410/d"},"text":"Pub. L. 110–315, § 410(d)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s410/e/1"},"text":"Pub. L. 110–315, § 410(e)(1)","children":[],"tail":", substituted “annually” for “18 months, and 36 months, after receiving the first grant payment under this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s410/e/2"},"text":"Pub. L. 110–315, § 410(e)(2)","children":[],"tail":", substituted “continuation awards” for “the third annual grant payment” and “the reports” for “the 18-month report”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s410/f"},"text":"Pub. L. 110–315, § 410(f)","children":[],"tail":", substituted “such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years” for “$45,000,000 for fiscal year 1999 and such sums as may be necessary for each of the 4 succeeding fiscal years”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cf33825-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0cf33826-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
