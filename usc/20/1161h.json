{"tag":"section","attrib":{"id":"id0d84a222-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161h"},"text":"§ 1161h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving college enrollment by secondary schools","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d84a223-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amounts appropriated under subsection (c), the Secretary shall award a grant to one nonprofit organization described in subsection (b) to enable the nonprofit organization—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a224-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make publicly available the year-to-year postsecondary education enrollment rate trends of secondary school students, disaggregated by secondary school, in compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232g"},"text":"section 1232g of this title","children":[],"tail":" (commonly known as the “Family Educational Rights and Privacy Act of 1974”);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a225-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to identify not less than 50 urban local educational agencies and five States with significant rural populations, each serving a significant population of low-income students, and to carry out a comprehensive assessment in the agencies and States of the factors known to contribute to improved postsecondary education enrollment rates, which factors shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a226-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161h/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local educational agency’s and State’s leadership strategies and capacities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a227-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161h/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the secondary school curriculum and class offerings of the local educational agency and State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a228-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161h/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the professional development used by the local educational agency and the State to assist teachers, guidance counselors, and administrators in supporting the transition of secondary students to postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a229-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161h/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secondary school student attendance and other factors demonstrated to be associated with enrollment into postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a22a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161h/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of data systems by the local educational agency and the State to measure postsecondary education enrollment rates and the incentives in place to motivate the efforts of faculty and students to improve student and schoolwide outcomes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a22b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161h/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategies to mobilize student leaders to build a college-bound culture; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a22c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161h/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide comprehensive services to improve the schoolwide postsecondary education enrollment rates of each of not less than ten local educational agencies and States, with the federally funded portion of each project declining by not less than 20 percent each year beginning in the second year of the comprehensive services, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a22d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161h/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participated in the needs assessment described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a22e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161h/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrated a willingness and commitment to improving the postsecondary education enrollment rates of the local educational agency or State, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a22f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant recipient criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The recipient of the grant awarded under subsection (a) shall be a nonprofit organization with demonstrated expertise—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a230-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in increasing schoolwide postsecondary enrollment rates in low-income communities nationwide by providing curriculum, training, and technical assistance to secondary school staff and student peer influencers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a231-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a postsecondary education transition data management system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a232-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d84a233-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s808"},"text":"Pub. L. 89–329, title VIII, § 808","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3396"},"text":"122 Stat. 3396","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tVIII/s801/3"},"text":"Pub. L. 111–39, title VIII, § 801(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1955"},"text":"123 Stat. 1955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d84a234-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d84a235-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d84a236-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232g"},"text":"section 1232g of this title","children":[],"tail":" (commonly known as the ‘Family Educational Rights and Privacy Act of 1974’)” for “the Family Education Rights and Privacy Act of 1974”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d84a237-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d84a238-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/s3"},"text":"section 3 of Pub. L. 111–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
