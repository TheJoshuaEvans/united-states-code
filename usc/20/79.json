{"tag":"section","attrib":{"id":"id0c831028-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s79"},"text":null,"children":[{"tag":"num","attrib":{"value":"79"},"text":"§ 79.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Barro Colorado Island in Gatun Lake to be set aside","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized and directed to set aside within the Canal Zone an area in Gatun Lake known as Barro Colorado Island in which the natural features shall, except in event of declared national emergency, be left in their natural state for scientific observation and investigation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c831029-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-07-02/ch516/s1"},"text":"July 2, 1940, ch. 516, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/724"},"text":"54 Stat. 724","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c83102a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c83102b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0c83102c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of Canal Zone, referred to in text, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3602/b"},"text":"section 3602(b) of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":