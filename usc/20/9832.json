{"tag":"section","attrib":{"id":"id0e6bf599-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832"},"text":null,"children":[{"tag":"num","attrib":{"value":"9832"},"text":"§ 9832.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6bf59a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced Placement or International Baccalaureate course","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Advanced Placement or International Baccalaureate course” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6bf59b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a course of college-level instruction provided to secondary school students, terminating in an examination administered by the College Board or the International Baccalaureate Organization, or another such examination approved by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6bf59c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another highly rigorous, evidence-based, postsecondary preparatory program terminating in an examination administered by another nationally recognized educational organization that has a demonstrated record of effectiveness in assessing secondary school students, or another such examination approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6bf59d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6bf59e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State educational agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6bf59f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6bf5a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a partnership consisting of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e6bf5a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national, regional, or statewide nonprofit organization, with expertise and experience in providing Advanced Placement or International Baccalaureate services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e6bf5a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State educational agency or local educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6bf5a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income student","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “low-income student” means an individual who is determined by a State educational agency or local educational agency to be a child ages 5 through 19, from a low-income family, on the basis of data used by the Secretary to determine allocations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333"},"text":"section 6333 of this title","children":[],"tail":", data on children eligible for free or reduced-price lunches under the Richard B. Russell National School Lunch Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.], data on children in families receiving assistance under part A of title IV of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq.], or data on children eligible to receive medical assistance under the Medicaid program under title XIX of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.], or through an alternate method that combines or extrapolates from those data."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6bf5a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High concentration of low-income students","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high concentration of low-income students”, used with respect to a school, means a school that serves a student population 40 percent or more of who are low-income students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6bf5a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-need local educational agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high-need local educational agency” means a local educational agency or educational service agency described in 9812(3)(A) ","children":[{"tag":"ref","attrib":{"idref":"fn002254"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002254"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “section”."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6bf5a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-need school","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “high-need school” means a secondary school—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6bf5a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with a pervasive need for Advanced Placement or International Baccalaureate courses in mathematics, science, or critical foreign languages, or for additional Advanced Placement or International Baccalaureate courses in such a subject; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6bf5a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e6bf5a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with a high concentration of low-income students; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e6bf5aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9832/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designated with a school locale code of 41, 42, or 43, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e6bf5ab-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69/tVI/s6122"},"text":"Pub. L. 110–69, title VI, § 6122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/635"},"text":"121 Stat. 635","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/i/2"},"text":"Pub. L. 114–95, title IX, § 9215(i)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2167"},"text":"129 Stat. 2167","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e6bf5ac-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e6bf5ad-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e6bf5ae-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Richard B. Russell National School Lunch Act, referred to in par. (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281"},"text":"act June 4, 1946, ch. 281","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/230"},"text":"60 Stat. 230","children":[],"tail":", which is classified generally to chapter 13 (§ 1751 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in par. (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Part A of title IV of the Act is classified generally to part A (§ 601 et seq.) of subchapter IV of chapter 7 of Title 42, The Public Health and Welfare. Title XIX of the Act is classified generally to subchapter XIX (§ 1396 et seq.) of chapter 7 of Title 42. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e6e65af-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9215/i/2/A"},"text":"Pub. L. 114–95, § 9215(i)(2)(A)","children":[],"tail":", substituted “The term ‘low-income student’ means an individual who is determined by a State educational agency or local educational agency to be a child ages 5 through 19, from a low-income family, on the basis of data used by the Secretary to determine allocations under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333"},"text":"section 6333 of this title","children":[],"tail":", data on children eligible for free or reduced-price lunches under the Richard B. Russell National School Lunch Act, data on children in families receiving assistance under part A of title IV of the Social Security Act, or data on children eligible to receive medical assistance under the Medicaid program under title XIX of the Social Security Act, or through an alternate method that combines or extrapolates from those data.” for “The term ‘low-income student’ has the meaning given the term ‘low-income individual’ in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6537/3"},"text":"section 6537(3) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9215/i/2/B"},"text":"Pub. L. 114–95, § 9215(i)(2)(B)","children":[],"tail":", substituted “The term ‘high concentration of low-income students’, used with respect to a school, means a school that serves a student population 40 percent or more of who are low-income students.” for “The term ‘high concentration of low-income students’ has the meaning given the term in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6537/2"},"text":"section 6537(2) of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e6e65b0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e6e65b1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
