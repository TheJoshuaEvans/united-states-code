{"tag":"section","attrib":{"id":"id0e24650d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116"},"text":null,"children":[{"tag":"num","attrib":{"value":"7116"},"text":"§ 7116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local educational agency applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e24650e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive an allocation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7115/a"},"text":"section 7115(a) of this title","children":[],"tail":", a local educational agency shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e24650f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit an application, which shall contain, at a minimum, the information described in subsection (e), to the State educational agency at such time, in such manner, and containing such information as the State educational agency may reasonably require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e246510-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete a needs assessment in accordance with subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e246511-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consortium","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a local educational agency desires to carry out the activities described in this subpart in consortium with one or more surrounding local educational agencies as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7115/a/3"},"text":"section 7115(a)(3) of this title","children":[],"tail":", such local educational agencies shall submit a single application as required under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e246512-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e246513-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency, or consortium of such agencies, shall develop its application through consultation with parents, teachers, principals, other school leaders, specialized instructional support personnel, students, community-based organizations, local government representatives (which may include a local law enforcement agency, local juvenile court, local child welfare agency, or local public housing agency), Indian tribes or tribal organizations that may be located in the region served by the local educational agency (where applicable), charter school teachers, principals, and other school leaders (if such agency or consortium of such agencies supports charter schools), and others with relevant and demonstrated expertise in programs and activities designed to meet the purpose of this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e246514-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The local educational agency, or consortium of such agencies, shall engage in continued consultation with the entities described in paragraph (1) in order to improve the local activities in order to meet the purpose of this subpart and to coordinate such implementation with other related strategies, programs, and activities being conducted in the community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e246515-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Needs assessment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e246516-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2) and prior to receiving an allocation under this subpart, a local educational agency or consortium of such agencies shall conduct a comprehensive needs assessment of the local educational agency or agencies proposed to be served under this subpart in order to examine needs for improvement of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e246517-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to, and opportunities for, a well-rounded education for all students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e246518-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" school conditions for student learning in order to create a healthy and safe school environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e246519-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to personalized learning experiences supported by technology and professional development for the effective use of data and technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e24651a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency receiving an allocation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7115/a"},"text":"section 7115(a) of this title","children":[],"tail":" in an amount that is less than $30,000 shall not be required to conduct a comprehensive needs assessment under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e24651b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency of needs assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each local educational agency, or consortium of local educational agencies, shall conduct the needs assessment described in paragraph (1) once every 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e24651c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of local application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted under this section by a local educational agency, or a consortium of such agencies, shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e24651d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Descriptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A description of the activities and programming that the local educational agency, or consortium of such agencies, will carry out under this subpart, including a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e24651e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any partnership with an institution of higher education, business, nonprofit organization, community-based organization, or other public or private entity with a demonstrated record of success in implementing activities under this subpart;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e24651f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, how funds will be used for activities related to supporting well-rounded education under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7117"},"text":"section 7117 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e246520-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, how funds will be used for activities related to supporting safe and healthy students under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7118"},"text":"section 7118 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e246521-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, how funds will be used for activities related to supporting the effective use of technology in schools under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7119"},"text":"section 7119 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e246522-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program objectives and intended outcomes for activities under this subpart, and how the local educational agency, or consortium of such agencies, will periodically evaluate the effectiveness of the activities carried out under this section based on such objectives and outcomes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e246523-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assurances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application shall include assurances that the local educational agency, or consortium of such agencies, will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e246524-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prioritize the distribution of funds to schools served by the local educational agency, or consortium of such agencies, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e246525-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are among the schools with the greatest needs, as determined by such local educational agency, or consortium;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e246526-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the highest percentages or numbers of children counted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/c"},"text":"section 6333(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e246527-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are identified for comprehensive support and improvement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/c/4/D/i"},"text":"section 6311(c)(4)(D)(i) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e246528-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are implementing targeted support and improvement plans as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d/2"},"text":"section 6311(d)(2) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e246529-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are identified as a persistently dangerous public elementary school or secondary school under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7912"},"text":"section 7912 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e24652a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7881"},"text":"section 7881 of this title","children":[],"tail":" (regarding equitable participation by private school children and teachers);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e24652b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use not less than 20 percent of funds received under this subpart to support one or more of the activities authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7117"},"text":"section 7117 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e24652c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use not less than 20 percent of funds received under this subpart to support one or more activities authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7118"},"text":"section 7118 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e24652d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use a portion of funds received under this subpart to support one or more activities authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7119/a"},"text":"section 7119(a) of this title","children":[],"tail":", including an assurance that the local educational agency, or consortium of local educational agencies, will comply with "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7119/b"},"text":"section 7119(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e24652e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually report to the State for inclusion in the report described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7114/a/2"},"text":"section 7114(a)(2) of this title","children":[],"tail":" how funds are being used under this subpart to meet the requirements of subparagraphs (C) through (E)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e24652f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7116/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any local educational agency receiving an allocation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7115/a/1"},"text":"section 7115(a)(1) of this title","children":[],"tail":" in an amount less than $30,000 shall be required to provide only one of the assurances described in subparagraphs (C), (D), and (E) of subsection (e)(2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e246530-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4106"},"text":"Pub. L. 89–10, title IV, § 4106","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4101"},"text":"Pub. L. 114–95, title IV, § 4101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1974"},"text":"129 Stat. 1974","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e246531-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e246532-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e246533-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7116, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4116"},"text":"Pub. L. 89–10, title IV, § 4116","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIV/s401"},"text":"Pub. L. 107–110, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1750"},"text":"115 Stat. 1750","children":[],"tail":", related to reporting by States and local educational agencies, prior to the general amendment of this subpart by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 7116, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4116"},"text":"Pub. L. 89–10, title IV, § 4116","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3682"},"text":"108 Stat. 3682","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/1/tIII/s314"},"text":"Pub. L. 106–554, § 1(a)(1) [title III, § 314]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–47, related to local drug and violence prevention programs, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s4106"},"text":"section 4106 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3066"},"text":"section 3066 of this title","children":[],"tail":", prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e246534-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e246535-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
