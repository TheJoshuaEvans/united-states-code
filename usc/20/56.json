{"tag":"section","attrib":{"id":"id0c772929-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s56"},"text":null,"children":[{"tag":"num","attrib":{"value":"56"},"text":"§ 56.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of unappropriated money","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Regents are authorized to make such disposal of any other moneys which have accrued, or shall hereafter accrue, as interest upon the Smithsonian fund, not herein appropriated, or not required for the purposes herein provided, as they shall deem best suited for the promotion of the purpose of the testator.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c77292a-3a70-11f1-a648-bee82ed8a795"},"text":"(R.S. § 5592.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c77292b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c77292c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c77292d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5592 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1846-08-10/ch178/s9"},"text":"act Aug. 10, 1846, ch. 178, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/105"},"text":"9 Stat. 105","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
