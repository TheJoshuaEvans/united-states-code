{"tag":"section","attrib":{"id":"id0e625853-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9531"},"text":null,"children":[{"tag":"num","attrib":{"value":"9531"},"text":"§ 9531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e625854-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9531/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Institute a National Center for Education Research (in this part referred to as the “Research Center”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e625855-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9531/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The mission of the Research Center is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e625856-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9531/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to sponsor sustained research that will lead to the accumulation of knowledge and understanding of education, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e625857-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9531/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that all children have access to a high-quality education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625858-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9531/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve student academic achievement, including through the use of educational technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e625859-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9531/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" close the achievement gap between high-performing and low-performing students through the improvement of teaching and learning of reading, writing, mathematics, science, and other academic subjects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e62585a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9531/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve access to, and opportunity for, postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e62585b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9531/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the synthesis and, as appropriate, the integration of education research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e62585c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9531/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote quality and integrity through the use of accepted practices of scientific inquiry to obtain knowledge and understanding of the validity of education theories, practices, or conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e62585d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9531/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote scientifically valid research findings that can provide the basis for improving academic instruction and lifelong learning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e62585e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s131"},"text":"Pub. L. 107–279, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1954"},"text":"116 Stat. 1954","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
