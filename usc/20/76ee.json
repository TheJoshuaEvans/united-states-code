{"tag":"section","attrib":{"id":"id0c830ff5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"76ee"},"text":"§ 76ee.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated not to exceed $15,000,000 for the planning and construction of the Joseph H. Hirshhorn Museum and Sculpture Garden, and such additional sums as may be necessary for the maintenance and operation of such museum and sculpture garden.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c830ff6-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/788/s5"},"text":"Pub. L. 89–788, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-07"},"text":"Nov. 7, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1404"},"text":"80 Stat. 1404","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
