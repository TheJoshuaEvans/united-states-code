{"tag":"section","attrib":{"id":"id0d78bb87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1136a"},"text":"§ 1136a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Masters degree programs at historically Black colleges and universities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d78bb88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d78bb89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of funds appropriated to carry out this section, the Secretary shall award program grants to each of the institutions listed in subsection (b)(1) that is determined by the Secretary to be making a substantial contribution to graduate education opportunities at the masters level in mathematics, engineering, the physical or natural sciences, computer science, information technology, nursing, allied health, or other scientific disciplines for Black Americans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assurance of non-Federal matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant in excess of $1,000,000 may be made under this section unless the institution provides assurances that 50 percent of the cost of the purposes for which the grant is made will be paid from non-Federal sources, except that no institution shall be required to match any portion of the first $1,000,000 of the institution’s award from the Secretary. After funds are made available to each eligible institution under the funding rules described in subsection (f), the Secretary shall distribute, on a pro rata basis, any amounts which were not so made available (by reason of the failure of an institution to comply with the matching requirements of this paragraph) among the institutions that have complied with such matching requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb8b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsections (f) and (g), the amount awarded to each eligible institution listed in subsection (b)(1) for a fiscal year shall be not less than $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb8c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this section shall be for a period of not more than six years, but may be periodically renewed for a period to be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bb8d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d78bb8e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Institutions eligible for grants under subsection (a) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d78bb8f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Albany State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb90-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Alcorn State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb91-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Claflin University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb92-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coppin State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb93-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Elizabeth City State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb94-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fayetteville State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb95-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fisk University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb96-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fort Valley State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb97-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grambling State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb98-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Kentucky State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb99-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mississippi Valley State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Savannah State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" South Carolina State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb9c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" University of Arkansas, Pine Bluff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb9d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Virginia State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb9e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" West Virginia State University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bb9f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wilberforce University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bba0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/1/R"},"text":null,"children":[{"tag":"num","attrib":{"value":"R"},"text":"(R)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Winston-Salem State University.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bba1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified masters degree program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d78bba2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, the term “qualified masters degree program” means a masters degree program that provides a program of instruction in mathematics, engineering, the physical or natural sciences, computer science, information technology, nursing, allied health, or other scientific disciplines in which African Americans are underrepresented and has students enrolled in such program of instruction at the time of application for a grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bba3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the enrollment requirement contained in subparagraph (A), an institution may use an amount equal to not more than 10 percent of the institution’s grant under this section for the development of a new qualified masters degree program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bba4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional choice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The president or chancellor of the institution may decide which graduate school or qualified masters degree program will receive funds under the grant in any one fiscal year, if the allocation of funds among the schools or programs is delineated in the application for funds submitted to the Secretary under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bba5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" One grant per institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not award more than one grant under this section in any fiscal year to any institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bba6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible institution listed in subsection (b)(1) desiring a grant under this section shall submit an application at such time, in such manner, and containing such information as the Secretary may require. The application shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d78bba7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate how the grant funds under this section will be used to improve graduate educational opportunities for Black and low-income students, and lead to greater financial independence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bba8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, in the case of applications for grants in excess of $1,000,000, the assurances required under subsection (a)(2) and specify the manner in which the eligible institution is going to pay the non-Federal share of the cost of the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bba9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant under this section may be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d78bbaa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase, rental, or lease of scientific or laboratory equipment for educational purposes, including instructional and research purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bbab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction, maintenance, renovation, and improvement in classroom, library, laboratory, and other instructional facilities, including purchase or rental of telecommunications technology equipment or services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bbac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase of library books, periodicals, technical and other scientific journals, microfilm, microfiche, and other educational materials, including telecommunications program materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bbad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scholarships, fellowships, and other financial assistance for needy graduate students to permit the enrollment of the students in, and completion of, a masters degree in mathematics, engineering, the physical or natural sciences, computer science, information technology, nursing, allied health, or other scientific disciplines in which African Americans are underrepresented;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bbae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing or improving a development office to strengthen and increase contributions from alumni and the private sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bbaf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting in the establishment or maintenance of an institutional endowment to facilitate financial independence pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1065"},"text":"section 1065 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bbb0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds and administrative management, and the acquisition of equipment, including software, for use in strengthening funds management and management information systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bbb1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition of real property that is adjacent to the campus in connection with the construction, renovation, or improvement of, or an addition to, campus facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bbb2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education or financial information designed to improve the financial literacy and economic literacy of students or the students’ families, especially with regard to student indebtedness and student assistance programs under subchapter IV;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bbb3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tutoring, counseling, and student service programs designed to improve academic success;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bbb4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faculty professional development, faculty exchanges, and faculty participation in professional conferences and meetings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bbb5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/d/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other activities proposed in the application submitted under subsection (c) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d78bbb6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/d/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to carrying out the purposes of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bbb7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/d/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are approved by the Secretary as part of the review and acceptance of such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bbb8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interaction with other grant programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No institution that is eligible for and receives an award under section 1063b, 1102a, or 1136b of this title for a fiscal year shall be eligible to apply for a grant, or receive grant funds, under this section for the same fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bbb9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (g), of the amount appropriated to carry out this section for any fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d78bbba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first $9,000,000 (or any lesser amount appropriated) shall be available only for the purposes of making minimum grants under subsection (a)(3) to eligible institutions listed in subparagraphs (A) through (R) of subsection (b)(1), except that if the amount appropriated is not sufficient to pay the minimum grant awards to all such eligible institutions, the amount of the minimum award to each such eligible institution shall be ratably reduced;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bbbb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the application of paragraph (1), an amount shall be available for the purpose of making minimum grants under subsection (a)(3) to eligible institutions listed in subsection (b)(1) that do not receive a grant under paragraph (1), if any, except that if the amount appropriated is not sufficient to pay the minimum grant awards to all such eligible institutions, the amount of the minimum award to each such eligible institution shall be ratably reduced; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bbbc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any amount in excess of $9,000,000 shall be made available to each of the eligible institutions identified in subparagraphs (A) through (R) of subsection (b)(1), pursuant to a formula developed by the Secretary that uses the following elements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d78bbbd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ability of the institution to match Federal funds with non-Federal funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bbbe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of students enrolled in the qualified masters degree program at the eligible institution in the previous academic year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bbbf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average cost of attendance per student, for all full-time students enrolled in the qualified masters degree program at such institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bbc0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of students in the previous year who received a degree in the qualified masters degree program at such institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d78bbc1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/f/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The contribution, on a percent basis, of the programs for which the institution is eligible to receive funds under this section to the total number of African Americans receiving masters degrees in the disciplines related to the programs for the previous year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bbc2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hold harmless rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraphs (2) and (3) of subsection (f), no eligible institution identified in subsection (b)(1) that receives a grant under this section for fiscal year 2009 and that is eligible to receive a grant for a subsequent fiscal year shall receive a grant amount for any such subsequent fiscal year that is less than the grant amount received for fiscal year 2009, unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d78bbc3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount appropriated is not sufficient to provide such grant amounts to all such institutions and programs that received grants under this section for such fiscal year and that are eligible to receive a grant in such subsequent fiscal year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bbc4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1136a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution cannot provide sufficient matching funds to meet the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d78bbc5-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s723"},"text":"Pub. L. 89–329, title VII, § 723","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s706/b"},"text":"Pub. L. 110–315, title VII, § 706(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag"