{"tag":"section","attrib":{"id":"id0de18f99-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995"},"text":null,"children":[{"tag":"num","attrib":{"value":"3995"},"text":"§ 3995.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de18f9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An applicant that desires to receive a grant under this part shall submit an application to the State educational agency, at such time, and in such manner, as the State may require. Such application may take the form of an amendment to an assessment submitted by the local educational agency under section 210,","children":[{"tag":"ref","attrib":{"idref":"fn002160"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002160"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" if appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18f9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State shall require each application to include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18f9c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the activities for which assistance under this part is sought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f9d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances that not more than 5 percent of the amount received by the applicant in any fiscal year shall be expended on administrative expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f9e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the funds are to be used for improvement of elementary and secondary resources as described in subsection (b)(1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de18f9f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the amount to be spent on equipment, facilities improvement, library resources, and classroom instructional material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18fa0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the number of elementary and secondary students who will be aided by activities and expenditures under the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18fa1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assurances that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0de18fa2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subsection (c), a minimum of 25 percent of the funds for each project will be supplied by business concerns within the community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de18fa3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no stipend shall be paid directly to employees of a profitmaking business concern;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de18fa4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995/b/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision shall be made for the equitable participation in the project of children who are enrolled in private elementary and secondary schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de18fa5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995/b/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consideration will be given to programs and activities designed to meet the needs of educationally disadvantaged and other traditionally underserved populations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18fa6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the funds are to be used for advanced placement programs as described in subsection (b)(2), a commitment as to the percentage of funds received from the State on a per student basis that shall be used by the local educational agency to defray costs of the advanced placement program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18fa7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State may waive or reduce the amount of matching funds required under subsection (b)(3)(C)(i) if the State determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18fa8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantial need exists in the area served by the applicant for a grant under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18fa9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the required amount of matching funds cannot be made available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18faa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3995/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A regional consortium of applicants in 2 or more local school districts may file a joint application under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de18fab-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tIII/s325"},"text":"Pub. L. 98–377, title III, § 325","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6031/a/2"},"text":"Pub. L. 100–418, title VI, § 6031(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1481"},"text":"102 Stat. 1481","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de18fac-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de18fad-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0de18fae-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 210, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/s210"},"text":"section 210 of Pub. L. 98–377","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1280"},"text":"98 Stat. 1280","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3970"},"text":"section 3970 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/tII/s2303"},"text":"Pub. L. 100–297, title II, § 2303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/324"},"text":"102 Stat. 324","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
