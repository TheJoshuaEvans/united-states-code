{"tag":"section","attrib":{"id":"id0ded9cbe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4420"},"text":null,"children":[{"tag":"num","attrib":{"value":"4420"},"text":"§ 4420.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax status; tort liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ded9cbf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4420/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute and the franchise, capital, reserves, income, and property of the Institute shall be exempt from all taxation now or hereafter imposed by the United States, by any Indian tribe, or by any State or political subdivision thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ded9cc0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4420/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tort liability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ded9cc1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4420/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Institute shall be subject to liability relating to tort claims only to the extent a Federal agency is subject to such liability under chapter 171 of title 28.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9cc2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4420/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of chapter 171 of title 28, the Institute shall be treated as a Federal agency (within the meaning of section 2671 of such title).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ded9cc3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4420/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of chapter 171 of title 28, the President of the Institute shall be deemed the head of the Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ded9cc4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXV/s1513"},"text":"Pub. L. 99–498, title XV, § 1513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1608"},"text":"100 Stat. 1608","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/446/tII"},"text":"Pub. L. 100–446, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-27"},"text":"Sept. 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1818"},"text":"102 Stat. 1818","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ded9cc5-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ded9cc6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ded9cc7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/446"},"text":"Pub. L. 100–446","children":[],"tail":" inserted “; tort liability” in section catchline, designated existing provisions as subsec. (a) and inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
