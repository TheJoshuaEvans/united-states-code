{"tag":"section","attrib":{"id":"id0c8caceb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"80t–4"},"text":"§ 80t–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational and liaison programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c8cacec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Museum may carry out educational and liaison programs in support of the goals of the Museum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8caced-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80t–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration with schools","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Director shall carry out educational programs in collaboration with elementary schools, secondary schools, and postsecondary schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c8cacee-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dT/tI/s106"},"text":"Pub. L. 116–260, div. T, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2276"},"text":"134 Stat. 2276","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
