{"tag":"section","attrib":{"id":"id0df258e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5502"},"text":null,"children":[{"tag":"num","attrib":{"value":"5502"},"text":"§ 5502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df258e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5502/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Administrator” means the Administrator of the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df258e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5502/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Agency” means the United States Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df258e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5502/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Federal agency” or “agency of the United States” means any department, agency or other instrumentality of the Federal Government, any independent agency or establishment of the Federal Government including any Government corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df258e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5502/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of the Department of Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df258e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5502/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “local educational agency” means any education agency as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":" and shall include any tribal education agency;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df258e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5502/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “not-for-profit” organization ","children":[{"tag":"ref","attrib":{"idref":"fn002183"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002183"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “ ‘not-for-profit organization’ ”."}],"tail":" means an organization, association, or institution described in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":", which is exempt from taxation pursuant to the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/a"},"text":"section 501(a) of title 26","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df258e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5502/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “noncommercial education broadcasting entities” means any noncommercial educational broadcasting station (and/or its legal nonprofit affiliates) as defined and licensed by the Federal Communications Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df258e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5502/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “tribal education agency” means a school or community college which is controlled by an Indian tribe, band, or nation, including any Alaska Native village, which is recognized as eligible for special programs and services provided by the United States to Indians because of their status as Indians and which is not administered by the Bureau of Indian Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df258e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5502/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Federal natural resource management agencies” means the United States Forest Service, the Bureau of Land Management, the National Park Service, and the Fish and Wildlife Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df258ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5502/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “environmental engineering” means the discipline within engineering and science concerned with the development and application of scientific and technical solutions to protecting the aquatic and atmospheric environment, including, but not limited to, all phases of water resources planning, water supply, water treatment, air pollution characterization and control, remediation of hazardous substances, environmental transport of contaminants in surface and ground water and atmosphere, and methods for assessment and control of pollution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df258eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5502/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “environmental education” and “environmental education and training” mean educational activities and training activities involving elementary, secondary, and postsecondary students, as such terms are defined in the State in which they reside, and environmental education personnel, but does not include technical training activities directed toward environmental management professionals or activities primarily directed toward the support of noneducational research and development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df258ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5502/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Foundation” means the National Environmental Education and Training Foundation established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5509"},"text":"section 5509 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df258ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5502/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Board of Directors” means the Board of Directors of the National Environmental Education and Training Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0df258ee-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/619/s3"},"text":"Pub. L. 101–619, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3326"},"text":"104 Stat. 3326","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s391/m"},"text":"Pub. L. 103–382, title III, § 391(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4023"},"text":"108 Stat. 4023","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1076/n"},"text":"Pub. L. 107–110, title X, § 1076(n)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2092"},"text":"115 Stat. 2092","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/fff"},"text":"Pub. L. 114–95, title IX, § 9215(fff)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2186"},"text":"129 Stat. 2186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0df258ef-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0df258f0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0df258f1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":" substituted “7801” for “8801”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":" substituted “local educational agency” for “local education agency” and reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s8801"},"text":"section 8801 of this title","children":[],"tail":" for reference to section 198 of the Elementary and Secondary Education Act of 1965."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0df258f2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0df258f3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0df258f4-3a70-11f1-a64