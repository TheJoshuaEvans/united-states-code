{"tag":"section","attrib":{"id":"id0dc5064b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2353"},"text":null,"children":[{"tag":"num","attrib":{"value":"2353"},"text":"§ 2353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for career and technical education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dc5064c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2353/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for minimal allocation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc5064d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2353/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the provisions of sections 2351 and 2352 of this title and in order to make a more equitable distribution of funds for programs serving the areas of greatest economic need, for any program year for which a minimal amount is made available by an eligible agency for distribution under section 2351 or 2352 of this title, such eligible agency may distribute such minimal amount for such year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dc5064e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2353/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a competitive basis; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc5064f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2353/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through any alternative method determined by the eligible agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc50650-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2353/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimal amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “minimal amount” means not more than 15 percent of the total amount made available for distribution under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2322/a/1"},"text":"section 2322(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc50651-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2353/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redistribution","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc50652-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2353/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any academic year that an eligible recipient does not expend all of the amounts the eligible recipient is allocated for such year under section 2351 or 2352 of this title, such eligible recipient shall return any unexpended amounts to the eligible agency to be reallocated under section 2351 or 2352 of this title, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc50653-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2353/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redistribution of amounts returned late in an academic year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any academic year in which amounts are returned to the eligible agency under section 2351 or 2352 of this title and the eligible agency is unable to reallocate such amounts according to such sections in time for such amounts to be expended in such academic year, the eligible agency shall retain such amounts for distribution in combination with amounts provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2322/a/1"},"text":"section 2322(a)(1) of this title","children":[],"tail":" for the following academic year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc50654-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2353/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in section 2351 or 2352 of this title shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc50655-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2353/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prohibit a local educational agency or a consortium thereof that receives assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2351"},"text":"section 2351 of this title","children":[],"tail":", from working with an eligible institution or consortium thereof that receives assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2352"},"text":"section 2352 of this title","children":[],"tail":", to carry out career and technical education programs or programs of study at the secondary level in accordance with this subchapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc50656-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2353/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prohibit an eligible institution or consortium thereof that receives assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2352"},"text":"section 2352 of this title","children":[],"tail":", from working with a local educational agency or consortium thereof that receives assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2351"},"text":"section 2351 of this title","children":[],"tail":", to carry out postsecondary and adult career and technical education programs or programs of study in accordance with this subchapter; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc50657-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2353/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require a charter school, that provides career and technical education programs or programs of study and is considered a local educational agency under State law, to jointly establish the charter school’s eligibility for assistance under this subchapter unless the charter school is explicitly permitted to do so under the State’s charter school statute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc50658-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2353/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistent application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the eligible agency shall provide funds to charter schools offering career and technical education programs or programs of study in the same manner as the eligible agency provides those funds to other schools. Such career and technical education programs or programs of study within a charter school shall be of sufficient size, scope, and quality to be effective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dc50659-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tI/s133"},"text":"Pub. L. 88–210, title I, § 133","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/731"},"text":"120 Stat. 731","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/tI/s132"},"text":"Pub. L. 115–224, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-31"},"text":"July 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1612"},"text":"132 Stat. 1612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dc5065a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dc5065b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0dc5065c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2353, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tI/s133"},"text":"Pub. L. 88–210, title I, § 133","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/332/s1/b"},"text":"Pub. L. 105–332, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3113"},"text":"112 Stat. 3113","children":[],"tail":", related to special rules for vocational and technical education, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/270"},"text":"Pub. L. 109–270","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0dc5065d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/224"},"text":"Pub. L. 115–224","children":[],"tail":" inserted “or programs of study” after “career and technical education programs” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dc5065e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0dc5065f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/224"},"text":"Pub. L. 115–224","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/s4"},"text":"section 4 of Pub. L. 115–224","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2301"},"text":"section 2301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
