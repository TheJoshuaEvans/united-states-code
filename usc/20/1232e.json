{"tag":"section","attrib":{"id":"id0d92f9c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1232e"},"text":"§ 1232e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single local educational agency application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d92f9c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General application to State agency or board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each local educational agency which participates in an applicable program under which Federal funds are made available to such agency through a State agency or board shall submit to such agency or board a general application containing the assurances set forth in subsection (b). That application shall cover the participation by that local educational agency in all such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d92f9c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assurances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The general application submitted by a local educational agency under subsection (a) shall set forth assurances—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9543b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the local educational agency will administer each program covered by the application in accordance with all applicable statutes, regulations, program plans, and applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9543b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the control of funds provided to the local educational agency under each program, and title to property acquired with those funds, will be in a public agency and that a public agency will administer those funds and property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9543b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the local educational agency will use fiscal control and fund accounting procedures that will ensure proper disbursement of, and accounting for, Federal funds paid to that agency under each program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9543b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the local educational agency will make reports to the State agency or board and to the Secretary as may reasonably be necessary to enable the State agency or board and the Secretary to perform their duties and that the local educational agency will maintain such records, including the records required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232f"},"text":"section 1232f of this title","children":[],"tail":", and provide access to those records, as the State agency or board or the Secretary deem necessary to perform their duties;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9543ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232e/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the local educational agency will provide reasonable opportunities for the participation by teachers, parents, and other interested agencies, organizations, and individuals in the planning for and operation of each program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9543bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232e/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that any application, evaluation, periodic program plan or report relating to each program will be made readily available to parents and other members of the general public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9543bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232e/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that in the case of any project involving construction—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9543bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232e/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project is not inconsistent with overall State plans for the construction of school facilities, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9543be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232e/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in developing plans for construction, due consideration will be given to excellence of architecture and design and to compliance with standards prescribed by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"section 794 of title 29","children":[],"tail":" in order to ensure that facilities constructed with the use of Federal funds are accessible to and usable by individuals with disabilities;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9543bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232e/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the local educational agency has adopted effective procedures for acquiring and disseminating to teachers and administrators participating in each program significant information from educational research, demonstrations, and similar projects, and for adopting, where appropriate, promising educational practices developed through such projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9543c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232e/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that none of the funds expended under any applicable program will be used to acquire equipment (including computer software) in any instance in which such acquisition results in a direct financial benefit to any organization representing the interests of the purchasing entity or its employees or any affiliate of such an organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9543c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective term of general application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A general application submitted under this section shall remain in effect for the duration of the programs it covers. The State agencies or boards administering the programs covered by the application shall not require the submission or amendment of such application unless required by changes in Federal or State law or by other significant change in the circumstances affecting an assurance in such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9543c2-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s442"},"text":"Pub. L. 90–247, title IV, § 442","children":[],"tail":", formerly § 436, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXII/s1231/a/3"},"text":"Pub. L. 95–561, title XII, § 1231(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2345"},"text":"92 Stat. 2345","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/511/tVII/s706/b"},"text":"Pub. L. 98–511, title VII, § 706(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2407"},"text":"98 Stat. 2407","children":[],"tail":"; renumbered § 442 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII"},"text":"Pub. L. 103–382, title II","children":[],"tail":", §§ 212(b)(1), (3)(B), 261(g), "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3913"},"text":"108 Stat. 3913","children":[],"tail":", 3928.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9543c3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9543c4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d9543c5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1232e, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s436"},"text":"Pub. L. 90–247, title IV, § 436","children":[],"tail":", formerly § 426, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/230/tIV/s401/a/10"},"text":"Pub. L. 91–230, title IV, § 401(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/170"},"text":"84 Stat. 170","children":[],"tail":"; renumbered § 436, "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tIII/s301/a/1"},"text":"Pub. L. 92–318, title III, § 301(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/326"},"text":"86 Stat. 326","children":[],"tail":", related to authority of Commissioner to vest title in equipment, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/95/561/s1231/a/3"},"text":"section 1231(a)(3) of Pub. L. 95–561","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s442"},"text":"section 442 of Pub. L. 90–247","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1233a"},"text":"section 1233a of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d9543c6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s261/g/1"},"text":"Pub. L. 103–382, § 261(g)(1)","children":[],"tail":", substituted “that local educational agency” for “that local education agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s261/g/2/A"},"text":"Pub. L. 103–382, § 261(g)(2)(A)","children":[],"tail":", inserted comma after “program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s261/g/2/B"},"text":"Pub. L. 103–382, § 261(g)(2)(B)","children":[],"tail":", substituted “Secretary” for “Commissioner” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s212/b/3/B"},"text":"Pub. L. 103–382, § 212(b)(3)(B)","children":[],"tail":", made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232f"},"text":"section 1232f of this title","children":[],"tail":" to reflect renumbering of corresponding section of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s261/g/2/C"},"text":"Pub. L. 103–382, § 261(g)(2)(C)","children":[],"tail":", substituted “individuals with disabilities” for “handicapped individuals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/511"},"text":"Pub. L. 98–511","children":[],"tail":" added par. (9)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d9543c7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d9543c8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/511"},"text":"Pub. L. 98–511","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/511/s711/a"},"text":"section 711(a) of Pub. L. 98–511","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1226c"},"text":"section 1226c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d9543c9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective with respect to appropriations for fiscal year 1980 and subsequent fiscal years, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/s1261"},"text":"section 1261 of Pub. L. 95–561","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232c"},"text":"section 1232c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
