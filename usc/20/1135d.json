{"tag":"section","attrib":{"id":"id0d78bb47-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1135d"},"text":"§ 1135d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional assistance for cost of education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d78bb48-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d78bb49-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall (in addition to stipends paid to individuals under this subpart) pay to the institution of higher education, for each individual awarded a fellowship under this subpart at such institution, an institutional allowance. Except as provided in paragraph (2), such allowance shall be, for 2009–2010 and succeeding academic years, the same amount as the institutional payment made for 2008–2009 adjusted annually thereafter in accordance with inflation as determined by the Department of Labor’s Consumer Price Index for the previous calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d78bb4a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The institutional allowance paid under paragraph (1) shall be reduced by the amount the institution charges and collects from a fellowship recipient for tuition and other expenses as part of the recipient’s instructional program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d78bb4b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1135d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use for overhead prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available pursuant to this subpart may not be used for the general operational overhead of the academic department or program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d78bb4c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s715"},"text":"Pub. L. 89–329, title VII, § 715","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVII/s701"},"text":"Pub. L. 105–244, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1793"},"text":"112 Stat. 1793","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s703/c"},"text":"Pub. L. 110–315, title VII, § 703(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3346"},"text":"122 Stat. 3346","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d78bb4d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d78bb4e-3a70