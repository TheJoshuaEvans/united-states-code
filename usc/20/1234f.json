{"tag":"section","attrib":{"id":"id0d97b546-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1234f"},"text":"§ 1234f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d97b547-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary authority; purposes of agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234c"},"text":"section 1234c of this title","children":[],"tail":", the Secretary may enter into a compliance agreement with a recipient under an applicable program. The purpose of any compliance agreement under this section shall be to bring the recipient into full compliance with the applicable requirements of law as soon as feasible and not to excuse or remedy past violations of such requirements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b548-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures applicable","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d97b549-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before entering into a compliance agreement with a recipient, the Secretary shall hold a hearing at which the recipient, affected students and parents or their representatives, and other interested parties are invited to participate. The recipient shall have the burden of persuading the Secretary that full compliance with the applicable requirements of law is not feasible until a future date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b54a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary determines, on the basis of all the evidence presented, that full compliance is genuinely not feasible until a future date, the Secretary shall make written findings to that effect and shall publish those findings, along with the substance of any compliance agreement, in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b54b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A compliance agreement under this section shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d97b54c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an expiration date not later than 3 years from the date of the written findings under subsection (b)(2), by which the recipient shall be in full compliance with the applicable requirements of law, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9a254d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those terms and conditions with which the recipient must comply until it is in full compliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9a254e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure of recipient to comply with terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a recipient fails to comply with the terms and conditions of a compliance agreement under this section, the Secretary may consider that compliance agreement to be no longer in effect, and the Secretary may take any action authorized by law with respect to the recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9a254f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s457"},"text":"Pub. L. 90–247, title IV, § 457","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/tIII/s3501/a"},"text":"Pub. L. 100–297, title III, § 3501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/355"},"text":"102 Stat. 355","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9a2550-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d9a2551-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d9a2552-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", but not applicable to recipients receiving written notice to return funds prior to that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/s3501/b"},"text":"section 3501(b) of Pub. L. 100–297","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234"},"text":"section 1234 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
