{"tag":"section","attrib":{"id":"id0e1fa94e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683"},"text":null,"children":[{"tag":"num","attrib":{"value":"6683"},"text":"§ 6683.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition program established","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e1fa94f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Education shall establish a national recognition program to be known as the “Recognizing Inspiring School Employees Award Program” or the “award program”. The purpose of the award program shall be to recognize and promote the commitment and excellence exhibited by classified school employees who provide exemplary service to students in prekindergarten through high school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1fa950-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1fa951-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to May 31 of each year (beginning with the second calendar year that begins after ","children":[{"tag":"date","attrib":{"date":"2019-04-12"},"text":"April 12, 2019","children":[],"tail":"), the Secretary shall select a classified school employee to receive the Recognizing Inspiring School Employees Award for the year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa952-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-monetary value","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The award and recognition provided under this subpart shall have no monetary value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1fa953-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1fa954-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nomination process","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1fa955-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than November 1 of each year (beginning with the first calendar year that begins after ","children":[{"tag":"date","attrib":{"date":"2019-04-12"},"text":"April 12, 2019","children":[],"tail":"), the Secretary shall solicit nominations of classified school employees from the occupational specialties described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6682/1"},"text":"section 6682(1) of this title","children":[],"tail":" from the Governor of each State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa956-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nomination submissions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order for individuals in a State to be eligible to receive recognition under this section, the Governor of the State shall consider nominations submitted by the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e1fa957-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Local educational agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1fa958-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" School administrators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1fa959-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Professional associations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1fa95a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Labor organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1fa95b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Educational service agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1fa95c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nonprofit entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1fa95d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Parents and students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e1fa95e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/1/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other group determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa95f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Governor of a State who desires individuals in the State to receive recognition under this section shall submit the nominations described in paragraph (1) to the Secretary in such manner as may be required by the Secretary. Each such nomination shall contain, at a minimum, demonstrations of excellence in the following areas:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1fa960-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Work performance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa961-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" School and community involvement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa962-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leadership and commitment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa963-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Local support.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1fa964-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhancement of classified school employees’ image in the community and schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1fa965-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6683/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop uniform national guidelines for evaluating nominations submitted under paragraph (2) in order to select the most deserving nominees based on the demonstrations made in the areas described in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1fa966-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/13/s4"},"text":"Pub. L. 116–13, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-04-12"},"text":"Apr. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/848"},"text":"133 Stat. 848","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e1fa967-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e1fa968-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0e1fa969-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Recognizing Achievement in Classified School Employees Act, and not as part of the Elementary and Secondary Education Act of 1965 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
