{"tag":"section","attrib":{"id":"id0c8581f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"80q–3"},"text":"§ 80q–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Trustees of National Museum of the American Indian","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c8581fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Museum shall be under a Board of Trustees with the duties, powers, and authority specified in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8581fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General duties and powers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Trustees shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c8581fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend annual operating budgets for the National Museum to the Board of Regents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise and assist the Board of Regents on all matters relating to the administration, operation, maintenance, and preservation of the National Museum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt bylaws for the Board of Trustees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8581ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate a chairman and other officers from among the members of the Board of trustees; ","children":[{"tag":"ref","attrib":{"idref":"fn002003"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002003"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c858200-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report annually to the Board of Regents on the acquisition, disposition, and display of Native American objects and artifacts and on other appropriate matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c858201-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sole authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the general policies of the Board of Regents, the Board of Trustees shall have the sole authority to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c858202-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lend, exchange, sell, or otherwise dispose of any part of the collections of the National Museum, with the proceeds of such transactions to be used for additions to the collections of the National Museum or additions to the endowment of the National Museum, as the case may be;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c858203-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase, accept, borrow, or otherwise acquire artifacts and other objects for addition to the collections of the Natural Museum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c858204-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify criteria for use of the collections of the National Museum for appropriate purposes, including research, evaluation, education, and method of display.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c858205-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the general policies of the Board of Regents, the Board of Trustees shall have authority to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c858206-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for restoration, preservation, and maintenance of the collections of the National Museum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c858207-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit funds for the National Museum and determine the purposes to which such funds shall be applied; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c858208-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve expenditures from the endowment of the National Museum for any purpose of the Museum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c858209-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial appointments to Board of Trustees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c85820a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The initial membership of the Board of Trustees shall consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c85820b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Smithsonian Institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c85820c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Assistant Secretary of the Smithsonian Institution appointed by the Board of Regents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c85820d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 8 individuals appointed by the Board of Regents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c85820e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 15 individuals, each of whom shall be a member of the board of trustees of the Heye Museum, appointed by the Board of Regents from a list of nominees recommended by the board of trustees of the Heye Museum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c85820f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least 7 of the 23 members appointed under subparagraphs (C) and (D) of paragraph (1) shall be Indians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c858210-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The trustee appointed under paragraph (1)(B) shall serve at the pleasure of the Board of Regents. The terms of the trustees appointed under subparagraph (C) or (D) of paragraph (1) shall be 3 years, beginning on the date of the transfer of the Heye Foundation assets to the Smithsonian Institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c858211-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy shall be filled only for the remainder of the term involved. Any vacancy appointment under paragraph (1)(D) shall not be subject to the source and recommendation requirements of that paragraph, but shall be subject to paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c858212-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent appointments to Board of Trustees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c858213-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon the expiration of the terms under subsection (e), the Board of Trustees shall consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c858214-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Smithsonian Institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c858215-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a senior official of the Smithsonian Institution appointed by the Board of Regents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c858216-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 23 individuals appointed by the Board of Regents from a list of nominees recommended by the Board of Trustees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c858217-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A ","children":[{"tag":"ref","attrib":{"idref":"fn002004"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002004"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “At”."}],"tail":" least 12 of the 23 members appointed under paragraph (1)(C) shall be Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c858218-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The trustee appointed under paragraph (1)(B) shall serve at the pleasure of the Board of Regents. Except as otherwise provided in the next sentence, the terms of members appointed under paragraph (1)(C) shall be 3 years. Of the members first appointed under paragraph (1)(C)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c858219-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 7 members, 4 of whom shall be Indians, shall be appointed for a term of one year, as designated at the time of appointment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c85821a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 8 members, 4 of whom shall be Indians, shall be appointed for a term of 2 years, as designated at the time of appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c85821b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy shall be filled only for the remainder of the term involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c85821c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Board of Trustees then in office shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c85821d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–3/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board shall be entitled (to the same extent as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":" with respect to employees serving intermittently in the Government service) to per diem, travel, and transportation expenses for each day (including travel time) during which they are engaged in the performance of their duties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c85821e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/185/s5"},"text":"Pub. L. 101–185, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1337"},"text":"103 Stat. 1337","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/278/s2"},"text":"Pub. L. 104–278, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3355"},"text":"110 Stat. 3355","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c85821f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c858220-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c858221-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (f)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/278"},"text":"Pub. L. 104–278","children":[],"tail":" substituted “a senior official” for “an Assistant Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
