{"tag":"section","attrib":{"id":"id0cfa6388-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1073"},"text":null,"children":[{"tag":"num","attrib":{"value":"1073"},"text":"§ 1073.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effects of adequate non-Federal programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cfa6389-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1073/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal insurance barred to lenders with access to State or private insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), the Secretary shall not issue certificates of insurance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1079"},"text":"section 1079 of this title","children":[],"tail":" to lenders in a State if the Secretary determines that every eligible institution has reasonable access in that State to a State or private nonprofit student loan insurance program which is covered by an agreement under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078/b"},"text":"section 1078(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cfa638a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1073/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may issue certificates of insurance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1079"},"text":"section 1079 of this title","children":[],"tail":" to a lender in a State—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cfa638b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1073/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for insurance of a loan made to a student borrower who does not, by reason of the borrower’s residence, have access to loan insurance under the loan insurance program of such State (or under any private nonprofit loan insurance program which has received an advance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1072"},"text":"section 1072 of this title","children":[],"tail":" for the benefit of students in such State);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cfa638c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1073/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for insurance of all the loans made to student borrowers by a lender who satisfies the Secretary that, by reason of the residence of such borrowers, such lender will not have access to any single State or nonprofit private loan insurance program which will insure substantially all of the loans such lender intends to make to such student borrowers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cfa638d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1073/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under such circumstances as may be approved by the guaranty agency in such State, for the insurance of a loan to a borrower for whom such lender previously was issued such a certificate if the loan covered by such certificate is not yet repaid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cfa638e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s423"},"text":"Pub. L. 89–329, title IV, § 423","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s402/a"},"text":"Pub. L. 99–498, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1358"},"text":"100 Stat. 1358","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cfa638f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cfa6390-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cfa6391-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1073, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s423"},"text":"Pub. L. 89–329, title IV, § 423","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1237"},"text":"79 Stat. 1237","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/575/tI/s119/a"},"text":"Pub. L. 90–575, title I, § 119(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-16"},"text":"Oct. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1026"},"text":"82 Stat. 1026","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/482/tI/s127/a"},"text":"Pub. L. 94–482, title I, § 127(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2103"},"text":"90 Stat. 2103","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/43/s1/a/14"},"text":"Pub. L. 95–43, § 1(a)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-06-15"},"text":"June 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/214"},"text":"91 Stat. 214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tXIII/s1391/a/1"},"text":"Pub. L. 96–374, title XIII, § 1391(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1503"},"text":"94 Stat. 1503","children":[],"tail":", limited participation in Federal loan insurance programs, prior to the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
