{"tag":"section","attrib":{"id":"id0d41ccac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1087uu"},"text":null,"children":[{"tag":"num","attrib":{"value":"1087uu"},"text":"§ 1087uu.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disregard of student aid in other programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, student financial assistance received under this subchapter, Bureau of Indian Education student assistance programs, and employment and training programs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3174"},"text":"section 3174 of title 29","children":[],"tail":" shall not be taken into account in determining the need or eligibility of any person for benefits or assistance, or the amount of such benefits or assistance, under any Federal, State, or local program financed in whole or in part with Federal funds."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d41ccad-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s479B"},"text":"Pub. L. 89–329, title IV, § 479B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/50/s14/27"},"text":"Pub. L. 100–50, § 14(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-06-03"},"text":"June 3, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/353"},"text":"101 Stat. 353","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s471/a"},"text":"Pub. L. 102–325, title IV, § 471(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/606"},"text":"106 Stat. 606","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tVII/s702/j"},"text":"Pub. L. 116–260, div. FF, ti