{"tag":"section","attrib":{"id":"id0d7b2cba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1140b"},"text":"§ 1140b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants, contracts, and cooperative agreements authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d7d75ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants, contracts, and cooperative agreements authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7d75ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1140e"},"text":"section 1140e of this title","children":[],"tail":", the Secretary may award grants, contracts, and cooperative agreements, on a competitive basis, to institutions of higher education to enable the institutions to carry out the activities under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d75ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards for professional development and technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than two grants, contracts, cooperative agreements, or a combination of such awards shall be awarded to institutions of higher education that provide professional development and technical assistance in order for students with learning disabilities to receive a quality postsecondary education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7d75ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration; activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7d75af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant, contract, or cooperative agreement under this subpart shall be awarded for a period of three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d75b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant, contract, or cooperative agreement awarded under this subpart shall be used to carry out one or more of the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7d75b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Teaching methods and strategies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The development of innovative, effective, and efficient teaching methods and strategies, consistent with the principles of universal design for learning, to provide postsecondary faculty, staff, and administrators with the skills and supports necessary to teach and meet the academic and programmatic needs of students with disabilities, in order to improve the retention of such students in, and the completion by such students of, postsecondary education. Such methods and strategies may include in-service training, professional development, customized and general technical assistance, workshops, summer institutes, distance learning, and training in the use of assistive and educational technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d75b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective transition practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The development of innovative and effective teaching methods and strategies to provide postsecondary faculty, staff, and administrators with the skill and supports necessary to ensure the successful and smooth transition of students with disabilities from secondary school to postsecondary education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d75b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Synthesizing research and information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The synthesis of research and other information related to the provision of postsecondary educational services to students with disabilities, including data on the impact of a postsecondary education on subsequent employment of students with disabilities. Such research, information, and data shall be made publicly available and accessible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d75b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distance learning","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The development of innovative and effective teaching methods and strategies to provide postsecondary faculty, staff, and administrators with the ability to provide accessible distance education programs or classes that would enhance the access of students with disabilities to postsecondary education, including the use of accessible curricula and electronic communication for instruction and advising.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d75b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disability career pathways","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d7d75b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provision of information, training, and technical assistance to secondary and postsecondary faculty, staff, and administrators with respect to disability-related fields that would enable such faculty, staff, and administrators to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d7d75b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/2/E/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage interest and participation in such fields, among students with disabilities and other students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7d75b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/2/E/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance awareness and understanding of such fields among students with disabilities and other students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7d75b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/2/E/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide educational opportunities in such fields for students with disabilities and other students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7d75ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/2/E/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teach practical skills related to such fields to students with disabilities and other students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7d75bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/2/E/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer work-based opportunities in such fields to students with disabilities and other students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d75bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The training and support described in subclauses (I) through (V) of clause (i) may include offering students—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d7d75bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/2/E/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credit-bearing postsecondary-level coursework; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7d75be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/2/E/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" career and educational counseling.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d75bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional development and training sessions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The conduct of professional development and training sessions for postsecondary faculty, staff, and administrators from other institutions of higher education to enable such individuals to meet the educational needs of students with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d75c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accessibility of education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Making postsecondary education more accessible to students with disabilities through curriculum development, consistent with the principles of universal design for learning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d75c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory evaluation and dissemination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of higher education awarded a grant, contract, or cooperative agreement under this subpart shall evaluate and disseminate to other institutions of higher education, the information obtained through the activities described in subparagraphs (A) through (G) of paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7d75c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations in making awards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants, contracts, or cooperative agreements under this subpart, the Secretary shall consider the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7d75c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Providing an equitable geographic distribution of such awards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d75c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural and urban areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Distributing such awards to urban and rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d75c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Range and type of institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Ensuring that the activities to be assisted are developed for a range of types and sizes of institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d75c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior experience or exceptional programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Distributing the awards to institutions of higher education with demonstrated prior experience in, or exceptional programs for, meeting the postsecondary educational needs of students with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7d75c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7d75c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", the Secretary shall prepare and submit to the authorizing committees, and make available to the public, a report on all demonstration projects awarded grants under this part for any of fiscal years 1999 through 2008, including a review of the activities and program performance of such demonstration projects based on existing information as of the date of the report."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d75c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than three years after the date of the first award of a grant under this subpart after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", the Secretary shall prepare and submit to the authorizing committees, and make available to the public, a report that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7d75ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviews the activities and program performance of the demonstration projects authorized under this subpart; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d75cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides guidance and recommendations on how effective projects can be replicated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d7d75cc-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s762"},"text":"Pub. L. 89–329, title VII, § 762","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s709/2"},"text":"Pub. L. 110–315, title VII, § 709(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3362"},"text":"122 Stat. 3362","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d7d75cd-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d7d75ce-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d7d75cf-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1140b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s763"},"text":"Pub. L. 89–329, title VII, § 763","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVII/s701"},"text":"Pub. L. 105–244, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1802"},"text":"112 Stat. 1802","children":[],"tail":", related to applications, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s709/2"},"text":"Pub. L. 110–315, title VII, § 709(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3361"},"text":"122 Stat. 3361","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s762"},"text":"section 762 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1140a"},"text":"section 1140a of this title","children":[],"tail":", prior to repeal by Pub L. 110–315."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s762"},"text":"section 762 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1132g–1"},"text":"section 1132g–1 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s762"},"text":"section 762 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1132d–1"},"text":"section 1132d–1 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
