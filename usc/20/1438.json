{"tag":"section","attrib":{"id":"id0daac81a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1438"},"text":null,"children":[{"tag":"num","attrib":{"value":"1438"},"text":"§ 1438.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In addition to using funds provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1433"},"text":"section 1433 of this title","children":[],"tail":" to maintain and implement the statewide system required by such section, a State may use such funds—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daac81b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1438/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for direct early intervention services for infants and toddlers with disabilities, and their families, under this subchapter that are not otherwise funded through other public or private sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daac81c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1438/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand and improve on services for infants and toddlers and their families under this subchapter that are otherwise available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daac81d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1438/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a free appropriate public education, in accordance with subchapter II, to children with disabilities from their third birthday to the beginning of the following school year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daac81e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1438/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the written consent of the parents, to continue to provide early intervention services under this subchapter to children with disabilities from their 3rd birthday until such children enter, or are eligible under State law to enter, kindergarten, in lieu of a free appropriate public education provided in accordance with subchapter II; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daac81f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1438/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in any State that does not provide services for at-risk infants and toddlers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1437/a/4"},"text":"section 1437(a)(4) of this title","children":[],"tail":", to strengthen the statewide system by initiating, expanding, or improving collaborative efforts related to at-risk infants and toddlers, including establishing linkages with appropriate public or private community-based organizations, services, and personnel for the purposes of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daac820-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1438/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and evaluating at-risk infants and toddlers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac821-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1438/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making referrals of the infants and toddlers identified and evaluated under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daac822-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1438/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting periodic follow-up on each such referral to determine if the status of the infant or toddler involved has changed with respect to the eligibility of the infant or toddler for services under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0daac823-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s638"},"text":"Pub. L. 91–230, title VI, § 638","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2755"},"text":"118 Stat. 2755","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0daac824-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0daac825-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0daac826-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1438, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s638"},"text":"Pub. L. 91–230, title VI, § 638","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tI/s101"},"text":"Pub. L. 105–17, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June 4, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/114"},"text":"111 Stat. 114","children":[],"tail":", related to uses of funds, prior to the general amendment of subchapters I to IV of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/108/446"},"text":"Pub. L. 108–446","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
