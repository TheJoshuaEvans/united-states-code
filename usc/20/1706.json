{"tag":"section","attrib":{"id":"id0db46465-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1706"},"text":null,"children":[{"tag":"num","attrib":{"value":"1706"},"text":"§ 1706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions by individuals denied equal educational opportunities or by Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An individual denied an equal educational opportunity, as defined by this subchapter may institute a civil action in an appropriate district court of the United States against such parties, and for such relief, as may be appropriate. The Attorney General of the United States (hereinafter in this chapter referred to as the “Attorney General”), for or in the name of the United States, may also institute such a civil action on behalf of such an individual.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0db46466-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/380/tII/s207"},"text":"Pub. L. 93–380, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/516"},"text":"88 Stat. 516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db46467-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0db46468-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0db46469-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on and after sixtieth day after ","children":[{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/380/s2/c"},"text":"section 2(c) of Pub. L. 93–380","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221–1"},"text":"section 1221–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
