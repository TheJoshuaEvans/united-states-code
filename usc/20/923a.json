{"tag":"section","attrib":{"id":"id0ca6eb99-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923a"},"text":null,"children":[{"tag":"num","attrib":{"value":"923a"},"text":"§ 923a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment of certain additional children on tuition-free basis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ca6eb9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations to be prescribed by the Secretary of Defense, the Secretary may authorize the enrollment in schools of the defense dependents’ education system on a tuition-free basis of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ca6eb9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the children of full-time, locally-hired employees of the Department of Defense in an overseas area if such employees are citizens or nationals of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6eb9c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the children of foreign military members assigned to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ca6eb9d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Supreme Headquarters Allied Powers, Europe, but only in a school of the defense dependents’ education system in Mons, Belgium; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ca6eb9e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United Nations Command, but only in a school of the defense dependents’ education system in South Korea or Japan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ca6eb9f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use funds available for the defense dependents’ education system to provide for the education of children enrolled in the defense dependents’ education system under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ca6eba0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules regarding enrollment of dependents of foreign military members","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ca6eba1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the regulations required by subsection (a), the Secretary shall prescribe a methodology based on the estimated total number of dependents of sponsors under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s932/2"},"text":"section 932(2) of this title","children":[],"tail":" enrolled in schools of the defense dependents’ education system described in paragraph (2) of subsection (a) to determine the number of children described in that paragraph who will be authorized to enroll under such subsection. The Secretary shall prescribe such methodology with the advice and assistance of the commanders of the geographic combatant commands with jurisdiction over the locations described in paragraph (2) of subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6eba2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s923a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the number of children described in paragraph (2) of subsection (a) who seek enrollment in schools of the defense dependents’ education system exceeds the number authorized by the Secretary under paragraph (1), the Secretary may enroll the additional children on a space-available, tuition-free basis notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s923/d/2"},"text":"section 923(d)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ca6eba3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXIV/s1404A"},"text":"Pub. L. 95–561, title XIV, § 1404A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s571"},"text":"Pub. L. 109–163, div. A, title V, § 571","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3270"},"text":"119 Stat. 3270","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s571/a"},"text":"Pub. L. 109–364, div. A, title V, § 571(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2225"},"text":"120 Stat. 2225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1063/e/1"},"text":"Pub. L. 110–181, div. A, title X, § 1063(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/323"},"text":"122 Stat. 323","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s535"},"text":"Pub. L. 111–84, div. A, title V, § 535","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2292"},"text":"123 Stat. 2292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s597"},"text":"Pub. L. 118–159, div. A, title V, § 597","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1921"},"text":"138 Stat. 1921","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ca6eba4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ca6eba5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ca6eba6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s597/1"},"text":"Pub. L. 118–159, § 597(1)","children":[],"tail":", substituted “foreign military members assigned to—” for “a foreign military member assigned to”, designated remainder of existing provisions as subpar. (A), and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s597/2/A"},"text":"Pub. L. 118–159, § 597(2)(A)","children":[],"tail":", struck out “assigned to Supreme Headquarters Allied Powers, Europe” after “members” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s597/2/B"},"text":"Pub. L. 118–159, § 597(2)(B)","children":[],"tail":", substituted “described in paragraph (2) of subsection (a) to determine the number of children described in that paragraph” for “in Mons, Belgium, to determine the number of children described in paragraph (2) of subsection (a)” in first sentence and “the commanders of the geographic combatant commands with jurisdiction over the locations described in paragraph (2) of subsection (a)” for “the commander of the geographic combatant command with jurisdiction over Mons, Belgium” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s597/2/C"},"text":"Pub. L. 118–159, § 597(2)(C)","children":[],"tail":", struck out “in Mons, Belgium,” after “education system”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s535/a"},"text":"Pub. L. 111–84, § 535(a)","children":[],"tail":", struck out “, and only through the 2010–2011 school year” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s535/b"},"text":"Pub. L. 111–84, § 535(b)","children":[],"tail":", inserted at end “The Secretary shall prescribe such methodology with the advice and assistance of the commander of the geographic combatant command with jurisdiction over Mons, Belgium.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1063/e/1"},"text":"Pub. L. 110–181, § 1063(e)(1)","children":[],"tail":", made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s571"},"text":"Pub. L. 109–163, § 571","children":[],"tail":", which enacted this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s571/a/1"},"text":"Pub. L. 109–364, § 571(a)(1)","children":[],"tail":", substituted “basis of—” for “basis of”, designated part of existing provisions as par. (1), substituted “; and” for period at end, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s571/a/2"},"text":"Pub. L. 109–364, § 571(a)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ca6eba7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0ca6eba8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1063/e"},"text":"Pub. L. 110–181, div. A, title X, § 1063(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/323"},"text":"122 Stat. 323","children":[],"tail":", provided that the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1063/e"},"text":"section 1063(e) of Pub. L. 110–181","children":[],"tail":" is effective as of "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
