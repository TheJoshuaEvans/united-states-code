{"tag":"section","attrib":{"id":"id0dfbcd7f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5984"},"text":null,"children":[{"tag":"num","attrib":{"value":"5984"},"text":"§ 5984.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dfbcd80-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5984/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “eligible entity” means a State educational agency, an institution of higher education or a State higher education agency, or a public or private nonprofit organization, with experience in coordinating or conducting teacher training seminars in American government and civics education, or a consortium thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dfbcd81-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5984/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State higher education agency” means the officer or agency primarily responsible for the State supervision of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dfbcd82-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227/tVIII/s804"},"text":"Pub. L. 103–227, title VIII, § 804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/210"},"text":"108 Stat. 210","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
