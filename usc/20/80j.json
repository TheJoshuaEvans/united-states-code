{"tag":"section","attrib":{"id":"id0c8581b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80j"},"text":null,"children":[{"tag":"num","attrib":{"value":"80j"},"text":"§ 80j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit of accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The accounts of the Board shall be audited in accordance with the principles and procedures applicable to, and as part of, the audit of the other Federal and trust funds of the Smithsonian Institution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c8581b1-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/637/s8"},"text":"Pub. L. 90–637, § 8","children":[],"tail":", formerly § 7, "},{"tag":"date","attrib":{"date":"1968-10-24"},"text":"Oct. 24, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1359"},"text":"82 Stat. 1359","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/95/286/s1/1"},"text":"Pub. L. 95–286, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-05-26"},"text":"May 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/278"},"text":"92 Stat. 278","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
