{"tag":"section","attrib":{"id":"id0e4f457c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7882"},"text":null,"children":[{"tag":"num","attrib":{"value":"7882"},"text":"§ 7882.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for by-pass","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e4f457d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7882/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, by reason of any provision of law, a State educational agency, local educational agency, educational service agency, consortium of those agencies, or other entity is prohibited from providing for the participation in programs of children enrolled in, or teachers or other educational personnel from, private elementary schools and secondary schools, on an equitable basis, or if the Secretary determines that the agency, consortium, or entity has substantially failed or is unwilling to provide for that participation, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7881"},"text":"section 7881 of this title","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e4f457e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7882/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waive the requirements of that section for the agency, consortium, or entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4f457f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7882/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrange for the provision of equitable services to those children, teachers, or other educational personnel through arrangements that shall be subject to the requirements of this section and of sections 7881, 7883, and 7884 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4f4580-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7882/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making the determination under subsection (a), the Secretary shall consider one or more factors, including the quality, size, scope, and location of the program, and the opportunity of private school children, teachers, and other educational personnel to participate in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e4f4581-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8502"},"text":"Pub. L. 89–10, title VIII, § 8502","children":[],"tail":", formerly title IX, § 9502, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1977"},"text":"115 Stat. 1977","children":[],"tail":"; renumbered title VIII, § 8502, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII"},"text":"Pub. L. 114–95, title VIII","children":[],"tail":", §§ 8001(a)(5), (b)(4), 8016, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089, 2111.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e4f4582-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e4f4583-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e4f4584-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7882, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIX/s9162"},"text":"Pub. L. 89–10, title IX, § 9162","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3794"},"text":"108 Stat. 3794","children":[],"tail":", authorized appropriations, prior to the general amendment of former subchapter IX of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e4f4585-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8001/b/4"},"text":"Pub. L. 114–95, § 8001(b)(4)","children":[],"tail":", made technical amendment to reference in original act which appears in two places in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7881"},"text":"section 7881 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8016"},"text":"Pub. L. 114–95, § 8016","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to sections 7883 and 7884 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e4f4586-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e4f4587-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
