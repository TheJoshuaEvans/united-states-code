{"tag":"section","attrib":{"id":"id0e39e7ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452"},"text":null,"children":[{"tag":"num","attrib":{"value":"7452"},"text":"§ 7452.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to tribes for education administrative planning, development, and coordination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e39e7bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award grants under this section to eligible applicants to enable the eligible applicants to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e39e7bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote tribal self-determination in education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e7bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the academic achievement of Indian children and youth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e7be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the coordination and collaboration of tribal educational agencies with State educational agencies and local educational agencies to meet the unique educational and culturally related academic needs of Indian students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e39e7bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e39e7c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible applicant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible applicant” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e39e7c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe or tribal organization approved by an Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribal educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e7c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” means a federally recognized tribe or a State-recognized tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e7c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal educational agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tribal educational agency” means the agency, department, or instrumentality of an Indian tribe that is primarily responsible for supporting tribal students’ elementary and secondary education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e39e7c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award grants to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e39e7c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible applicants described under subsection (b)(1)(A) to plan and develop a tribal educational agency, if the tribe or organization has no current tribal educational agency, for a period of not more than 1 year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e7c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" eligible applicants described under subsection (b)(1)(B), for a period of not more than 3 years, in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e39e7c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly administer education programs, including formula grant programs under this chapter, consistent with State law and under a written agreement between the parties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" build capacity to administer and coordinate such education programs, and to improve the relationship and coordination between such applicants and the State educational agencies and local educational agencies that educate students from the tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive training and support from the State educational agency and local educational agency, in areas such as data collection and analysis, grants management and monitoring, fiscal accountability, and other areas as needed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train and support the State educational agency and local educational agency in areas related to tribal history, language, or culture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" build on existing activities or resources rather than replacing other funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out other activities, consistent with the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e39e7ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e39e7cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible applicant desiring a grant under this section shall submit an application to the Secretary at such time and in such manner as the Secretary may reasonably prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e7d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application described in paragraph (1) shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e39e7d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement describing the activities to be conducted, and the objectives to be achieved, under the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the method to be used for evaluating the effectiveness of the activities for which assistance is sought and for determining whether such objectives are achieved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for applications for activities under subsection (c)(2), evidence of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e39e7d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a preliminary agreement with the appropriate State educational agency, 1 or more local educational agencies, or both the State educational agency and a local educational agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e39e7d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing capacity as a tribal educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e7d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may approve an application submitted by an eligible applicant under this subsection if the application, including any documentation submitted with the application—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e39e7d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates that the eligible applicant has consulted with other education entities, if any, within the territorial jurisdiction of the applicant that will be affected by the activities to be conducted under the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for consultation with such other education entities in the operation and evaluation of the activities conducted under the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e39e7d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates that there will be adequate resources provided under this section or from other sources to complete the activities for which assistance is sought.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e39e7da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e39e7db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian tribe may not receive funds under this section if the tribe receives funds under section 1140 of the Education Amendments of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2020"},"text":"20 U.S.C. 2020","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn002226"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002226"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2020"},"text":"25 U.S.C. 2020","children":[],"tail":")”."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e7dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds under this section may be used to provide direct services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e39e7dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7452/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement, not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds under this section shall be used to supplement, and not supplant, other Federal, State, and local programs that meet the needs of tribal students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e39e7de-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6132"},"text":"Pub. L. 89–10, title VI, § 6132","children":[],"tail":", formerly title VII, § 7135, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1928"},"text":"115 Stat. 1928","children":[],"tail":"; renumbered title VI, § 6135, renumbered § 6132, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI"},"text":"Pub. L. 114–95, title VI","children":[],"tail":", §§ 6001(a), (b)(1), 6002(n)(2), (p), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":", 2057, 2060.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e39e7df-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e39e7e0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0e39e7e1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7455"},"text":"section 7455 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e39e7e2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7452, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6132"},"text":"Pub. L. 89–10, title VI, § 6132","children":[],"tail":", formerly title VII, § 7132, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1924"},"text":"115 Stat. 1924","children":[],"tail":"; renumbered title VI, § 6132, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI/s6001/a"},"text":"Pub. L. 114–95, title VI, § 6001(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":", related to in-service training for teachers of Indian children, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"Pub. L. 114–95, § 5","children":[],"tail":", title VI, § 6002(n)(1), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1806"},"text":"129 Stat. 1806","children":[],"tail":", 2057, effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 7452, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVII/s7132"},"text":"Pub. L. 89–10, title VII, § 7132","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3729"},"text":"108 Stat. 3729","children":[],"tail":", related to research activities, prior to the general amendment of former subchapter VII of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s6132"},"text":"section 6132 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7311a"},"text":"section 7311a of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e39e7e3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6001/p"},"text":"Pub. L. 114–95, § 6001(p)","children":[],"tail":", amended section generally. Prior to amendment, section related to grants to Indian tribes for education administrative planning and development."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e39e7e4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e39e7e5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
