{"tag":"section","attrib":{"id":"id0c858222-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"80q–4"},"text":"§ 80q–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director and staff of National Museum","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c858223-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Smithsonian Institution shall appoint—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c858224-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Director who, subject to the policies of the Board of Trustees, shall manage the National Museum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c858225-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other employees of the National Museum, to serve under the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c858226-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offer of employment to Heye Foundation employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each employee of the Heye Museum on the day before the date of the transfer of the Heye Foundation assets to the Smithsonian Institution shall be offered employment with the Smithsonian Institution—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c858227-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the usual terms of such employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c858228-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a rate of pay not less than the rate applicable to the employee on the day before the date of the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c858229-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain civil service laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c85822a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–4/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint the Director, 2 employees under subsection (a)(2), and the employees under subsection (b) without regard to the provisions of title 5, governing appointments in the competitive service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c85822b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–4/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fix the pay of the Director and such 2 employees without regard to the provisions of chapter 51 and subchapter III of chapter 53 of such title, relating to classification and General Schedule pay rates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c85822c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–4/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fix the pay of the employees under subsection (b) in accordance with the provisions of chapter 51 and subchapter III of chapter 53 of such title, relating to classification and General Schedule pay rates, subject to subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c85822d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/185/s6"},"text":"Pub. L. 101–185, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1339"},"text":"103 Stat. 1339","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
