{"tag":"section","attrib":{"id":"id0c831030-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s79a"},"text":null,"children":[{"tag":"num","attrib":{"value":"79a"},"text":"§ 79a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of natural features for scientific observation and investigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of setting aside such an area is to preserve and conserve its natural features, including existing flora and fauna, in as nearly a natural condition as possible, thus providing a place where duly qualified students can make observations and scientific investigations for increase of knowledge, under such conditions and regulations as may be prescribed by the Smithsonian Institution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c831031-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-07-02/ch516/s2"},"text":"July 2, 1940, ch. 516, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/724"},"text":"54 Stat. 724","children":[],"tail":"; 1946 Reorg. Plan No. 3, § 801, eff. "},{"tag":"date","attrib":{"date":"1946-07-16"},"text":"July 16, 1946","children":[],"tail":", 11 F.R. 7877, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1101"},"text":"60 Stat. 1101","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c831032-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c831033-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c831034-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1382"},"text":"section 1382 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id0c831035-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0c831036-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Smithsonian Institution” substituted in text for “Board of Directors of the Canal Zone Biological Area” by Reorg. Plan No. 3 of 1946, set out in the Appendix to Title 5, Government Organization and Employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
