{"tag":"section","attrib":{"id":"id0de40013-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014"},"text":null,"children":[{"tag":"num","attrib":{"value":"4014"},"text":"§ 4014.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de40014-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established within the Environmental Protection Agency an Asbestos Hazards Abatement Assistance Program (hereinafter in this chapter referred to as the “Assistance Program”), which shall be administered in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de40015-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application submission","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de40016-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Applications for financial assistance shall be submitted by a local educational agency to the Governor, or the Governor’s designee, who shall establish a priority list based on the criteria of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4013/b/2"},"text":"section 4013(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de40017-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4013"},"text":"section 4013 of this title","children":[],"tail":", the Governor shall submit applications, together with the Governor’s report and priority list, to the Administrator who shall review and rank such applications pursuant to subsection (c)(2) and propose financing pursuant to the criteria of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4013/b/4"},"text":"section 4013(b)(4) of this title","children":[],"tail":". The Administrator shall approve or disapprove applications for financial assistance no later than April 30 of each year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de40018-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de40019-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall provide financial assistance on a school-by-school basis to local educational agencies in accordance with other provisions of this section to carry out projects for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de4001a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" abating the threat posed by materials containing asbestos to the health and safety of children or employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de4001b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" replacing the asbestos materials removed from school buildings with other appropriate building materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de4001c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restoring school buildings to conditions comparable to those existing before abatement activities were undertaken pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de4001d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall review and list in priority order applications for financial assistance. In ranking applications, the Administrator shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de4001e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the priority assigned to the abatement program by the Governor pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4013/b/2"},"text":"section 4013(b)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de4001f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0de40020-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the likelihood of release of asbestos fibers into a school environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de40021-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other evidence of the risk caused by the presence of asbestos including, but not limited to, situations in which there is a substantial quantity of dry loose asbestos-containing material on horizontal surfaces or asbestos-containing material is substantially deteriorated or damaged, and there is asbestos-containing material in an air plenum or in a high traffic area, confined space, or within easy reach of a passerby;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de40022-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the corrective action proposed by the applicant will reduce the exposure of school children and school employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de40023-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the corrective action proposed by the applicant uses the least burdensome methods which protect human health and the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de40024-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In determining whether an applicant is eligible for assistance, and the nature and amount of financial assistance, the Administrator shall consider the financial resources available to the applicant as certified by the Governor pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4013/b/4"},"text":"section 4013(b)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de40025-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In no event shall financial assistance be provided under this subchapter to an applicant if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de40026-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator determines that such applicant has resources adequate to support an appropriate asbestos materials abatement program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de40027-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant is not in compliance with title II of the Toxic Substances Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2641"},"text":"15 U.S.C. 2641","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de40028-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of loan or grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de40029-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An applicant for financial assistance may be granted a loan of up to 100 percent of the costs of an abatement program or, if the Administrator determines the applicant is unable to undertake and complete an asbestos materials abatement program with a loan, such applicant may also receive a grant (alone or in combination with a loan) not to exceed 50 percent of the total costs of abatement, in the amount which the Administrator deems necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de4002a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In approving any grant, the Administrator shall state with particularity the reasons why the applicant is unable to undertake and complete the abatement program with loan funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de4002b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Loans under this section shall be made pursuant to agreements which shall provide for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de4002c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan shall not bear interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de4002d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan shall have a maturity period of not more than twenty years (as determined by the Administrator) and shall be repayable during such period at such times and in such amounts as the Administrator may specify in the loan agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de4002e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repayment shall be made to the Secretary of the Treasury for deposit in the Asbestos Trust Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4022"},"text":"section 4022 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de4002f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other terms and conditions that the Administrator determines necessary to protect the financial interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de40030-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de40031-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No financial assistance may be provided under this section unless an application has been submitted to the Administrator in accordance with such procedures as may be developed by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de40032-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall not approve an application unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de40033-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the application contains such information as the Administrator may require, including but not limited to information describing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0de40034-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/g/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and extent of the asbestos problem for which the assistance is sought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de40035-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/g/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the asbestos content of the material to be abated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de40036-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/g/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods which will be used to abate the asbestos materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de40037-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/g/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and type of financial assistance requested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de40038-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/g/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the financial resources of the local educational agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de40039-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/g/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a justification for the type and amount of the financial assistance requested.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de4003a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the application contains a certification that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0de4003b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local educational agency has prepared and is implementing an asbestos management plan, as required under title II of the Toxic Substances Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2641"},"text":"15 U.S.C. 2641","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de4003c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all activities to be conducted with the financial assistance will be performed by individuals trained and accredited in conformance with title II of the Toxic Substances Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2641"},"text":"15 U.S.C. 2641","children":[],"tail":" et seq.) and regulations promulgated under that title;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de4003d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application contains assurances that the local educational agency will furnish such information as is necessary for the Administrator to make the report required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4016"},"text":"section 4016 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de4003e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No financial assistance may be provided by the Administrator under this section for projects described in subsection (a)(2) on which abatement action was completed prior to ","children":[{"tag":"date","attrib":{"date":"1984-01-01"},"text":"January 1, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de4003f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4014/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4021/b/1"},"text":"section 4021(b)(1) of this title","children":[],"tail":", in approving applications the Administrator shall provide assistance to the local educational agencies having the highest priority among applications being considered in order of ranking until the appropriated funds are expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de40040-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tV/s505"},"text":"Pub. L. 98–377, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1290"},"text":"98 Stat. 1290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/519/s3/a"},"text":"Pub. L. 99–519, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2988"},"text":"100 Stat. 2988","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/368/s6/b"},"text":"Pub. L. 100–368, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-18"},"text":"July 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/833"},"text":"102 Stat. 833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/637"},"text":"Pub. L. 101–637","children":[],"tail":", §§ 6, 14(a)(5), (b)(7), (c)(1)–(4), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4591"},"text":"104 Stat. 4591","children":[],"tail":", 4594–4596.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de40041-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de40042-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0de40043-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Toxic Substances Control Act, referred to in subsecs. (d)(2) and (g)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469"},"text":"Pub. L. 94–469","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-11"},"text":"Oct. 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2003"},"text":"90 Stat. 2003","children":[],"tail":". Title II of the Act, as added by "},{"tag":"ref","attrib":{"href":"/us/pl/99/519/s2"},"text":"Pub. L. 99–519, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2970"},"text":"100 Stat. 2970","children":[],"tail":", is classified generally to subchapter II (§ 2641 et seq.) of chapter 53 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2601"},"text":"section 2601 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0de40044-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/a/5"},"text":"Pub. L. 101–637, § 14(a)(5)","children":[],"tail":", made technical amendment to section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/b/7/A"},"text":"Pub. L. 101–637, § 14(b)(7)(A)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/b/7/B"},"text":"Pub. L. 101–637, § 14(b)(7)(B)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/c/1"},"text":"Pub. L. 101–637, § 14(c)(1)","children":[],"tail":", struck out comma after “educational agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s6/a/1"},"text":"Pub. L. 101–637, § 6(a)(1)","children":[],"tail":", (2), substituted “the Governor shall submit applications,” for “applications shall be submitted,” and inserted “The Administrator shall approve or disapprove applications for financial assistance no later than April 30 of each year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s6/a/3"},"text":"Pub. L. 101–637, § 6(a)(3)","children":[],"tail":", struck out par. (3) which read as follows: “Within sixty days of receipt of the information described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4013/b/1"},"text":"section 4013(b)(1) of this title","children":[],"tail":", the Secretary of the Department of Education shall review such information and, in the Secretary’s discretion, provide to the Administrator comments and recommendations based upon the needs of local educational agencies for financial assistance. Within sixty days of receipt of the Secretary’s report, or expiration of the time allowed for such report, the Administrator shall approve or disapprove applications for financial assistance.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/b/7/C"},"text":"Pub. L. 101–637, § 14(b)(7)(C)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/c/2/A"},"text":"Pub. L. 101–637, § 14(c)(2)(A)","children":[],"tail":", inserted “and” after semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/c/2/B"},"text":"Pub. L. 101–637, § 14(c)(2)(B)","children":[],"tail":", inserted a comma after “confined space”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/c/2/B"},"text":"Pub. L. 101–637, § 14(c)(2)(B)","children":[],"tail":", which directed the insertion of a comma after “techniques”, could not be executed because of the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/101/637/s6/b"},"text":"Pub. L. 101–637, § 6(b)","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s6/b"},"text":"Pub. L. 101–637, § 6(b)","children":[],"tail":", substituted “uses the least burdensome methods which protect human health and the environment” for “is cost-effective compared to other techniques including management of material containing asbestos”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s6/c"},"text":"Pub. L. 101–637, § 6(c)","children":[],"tail":", substituted “shall consider the financial resources available to the applicant as certified by the Governor pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4013/b/4"},"text":"section 4013(b)(4) of this title","children":[],"tail":".” for “shall consider—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the financial resources available to the applicant as certified by the Governor pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4013/b/4"},"text":"section 4013(b)(4) of this title","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the report, if any, of the Secretary of Education pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4013/b/5"},"text":"section 4013(b)(5) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s6/d"},"text":"Pub. L. 101–637, § 6(d)","children":[],"tail":", inserted heading and amended text generally. Prior to amendment, text read as follows: “In no event shall financial assistance be provided under this subchapter to an applicant if the Administrator determines that such applicant has resources adequate to support an appropriate asbestos materials abatement program. In making such a determination, the Administrator may consult with the Secretary of Education.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/b/7/D"},"text":"Pub. L. 101–637, § 14(b)(7)(D)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/c/3"},"text":"Pub. L. 101–637, § 14(c)(3)","children":[],"tail":", substituted “percent” for “per centum” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/b/7/E"},"text":"Pub. L. 101–637, § 14(b)(7)(E)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s6/e"},"text":"Pub. L. 101–637, § 6(e)","children":[],"tail":", substituted “for deposit in the Asbestos Trust Fund established by "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4022"},"text":"section 4022 of this title","children":[],"tail":"” for “for deposit in the general fund”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/b/7/F"},"text":"Pub. L. 101–637, § 14(b)(7)(F)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s6/f/1"},"text":"Pub. L. 101–637, § 6(f)(1)","children":[],"tail":", substituted “in accordance with such procedures as may be developed by the Administrator” for “within the five-year period beginning on "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"August 11, 1984","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2)(B)(i), (ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s6/f/2"},"text":"Pub. L. 101–637, § 6(f)(2)","children":[],"tail":", amended cls. (i) and (ii) generally. Prior to amendment, cls. (i) and (ii) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) any employee engaged in an asbestos material abatement program will be trained and equipped pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4015/b/2/B"},"text":"section 4015(b)(2)(B) of this title","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) no child or inadequately informed or protected school employee will be permitted in the vicinity of any asbestos abatement activity;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637"},"text":"Pub. L. 101–637","children":[],"tail":", §§ 6(f)(3), 14(c)(4), redesignated subpar. (B) appearing after par. (3) as par. (4), inserted a comma after “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4021/b/1"},"text":"section 4021(b)(1) of this title","children":[],"tail":"”, and struck out former par. (4) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) No financial assistance may be provided under this section to any school—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) which uses any person who has not been accredited pursuant to section 2646(b) or (c) of title 15, to carry out activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2646/a"},"text":"section 2646(a) of title 15","children":[],"tail":", or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) which uses any laboratory which has not been accredited pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2646/d"},"text":"section 2646(d) of title 15","children":[],"tail":", to carry out activities described in such section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) This paragraph shall apply to any financial assistance provided under this section after ","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":", for activities performed after the following dates:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) In the case of activities performed by persons, after the date which is one year after ","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) In the case of activities performed by laboratories, after the date which is 180 days after the date on which a laboratory accreditation program is completed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2646/d"},"text":"section 2646(d) of title 15","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (g)(4)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/368/s6/b/1"},"text":"Pub. L. 100–368, § 6(b)(1)","children":[],"tail":", substituted reference to "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":", for reference to "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"August 11, 1984","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(4)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/368/s6/b/2"},"text":"Pub. L. 100–368, § 6(b)(2)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2646/d"},"text":"section 2646(d) of title 15","children":[],"tail":"” for “subsection (d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (g)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/519"},"text":"Pub. L. 99–519","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0de40045-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0de40046-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Financial Assistance To Carry Out Inspections for Asbestos-Containing Material","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/519/s4/b"},"text":"Pub. L. 99–519, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2989"},"text":"100 Stat. 2989","children":[],"tail":", provided that, notwithstanding subsec. (c) of this section, for fiscal years 1988 and 1989 the Administrator would provide financial assistance under this section in the form of grants to States or local educational agencies to carry out inspections for asbestos-containing material in school buildings and preparation of management plans for school buildings under title II of the Toxic Substances Control Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2641"},"text":"15 U.S.C. 2641","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
