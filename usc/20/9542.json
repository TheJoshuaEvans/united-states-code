{"tag":"section","attrib":{"id":"id0e6258ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9542"},"text":null,"children":[{"tag":"num","attrib":{"value":"9542"},"text":"§ 9542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner for Education Statistics","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Statistics Center shall be headed by a Commissioner for Education Statistics (in this part referred to as the “Statistics Commissioner”) who shall be highly qualified and have substantial knowledge of statistical methodologies and activities undertaken by the Statistics Center.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e6258af-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s152"},"text":"Pub. L. 107–279, title I, § 152","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1958"},"text":"116 Stat. 1958","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
