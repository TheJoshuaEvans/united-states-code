{"tag":"section","attrib":{"id":"id0e2e01f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273"},"text":null,"children":[{"tag":"num","attrib":{"value":"7273"},"text":"§ 7273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e2e01f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2e01f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall use not less than 95 percent of the amounts made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7251/b/2/B"},"text":"section 7251(b)(2)(B) of this title","children":[],"tail":" to award grants, on a competitive basis and subject to subsection (e), to eligible entities for the following activities:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e304ae9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promise neighborhoods","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The implementation of a comprehensive, effective continuum of coordinated services that meets the purpose described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7271/1"},"text":"section 7271(1) of this title","children":[],"tail":" by carrying out activities in neighborhoods with—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0e304aea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high concentrations of low-income individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e304aeb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiple signs of distress, which may include high rates of poverty, childhood obesity, academic failure, and juvenile delinquency, adjudication, or incarceration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e304aec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" schools implementing comprehensive support and improvement activities or targeted support and improvement activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d"},"text":"section 6311(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304aed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full-service community schools","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provision of assistance to public elementary schools or secondary schools to function as full-service community schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304aee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sufficient size and scope","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each grant awarded under this subpart shall be of sufficient size and scope to allow the eligible entity to carry out the applicable purposes of this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304aef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this subpart shall be for a period of not more than 5 years, and may be extended for an additional period of not more than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304af0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Continued funding of a grant under this subpart, including a grant extended under subsection (b), after the third year of the initial grant period shall be contingent on the eligible entity’s progress toward meeting—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e304af1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a grant for activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7274"},"text":"section 7274 of this title","children":[],"tail":", the performance metrics described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7274/h"},"text":"section 7274(h) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304af2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a grant for activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7275"},"text":"section 7275 of this title","children":[],"tail":", annual performance objectives and outcomes under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7275/a/4/C"},"text":"section 7275(a)(4)(C) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304af3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e304af4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promise neighborhood activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e304af5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity receiving a grant under this subpart for activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7274"},"text":"section 7274 of this title","children":[],"tail":" shall contribute matching funds in an amount equal to not less than 100 percent of the amount of the grant. Such matching funds shall come from Federal, State, local, and private sources."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304af6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private sources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require that a portion of the matching funds come from private sources, which may include in-kind contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304af7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may adjust the matching funds requirement under this paragraph for applicants that demonstrate high need, including applicants from rural areas and applicants that wish to provide services on tribal lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304af8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial hardship waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive or reduce, on a case-by-case basis, the matching requirement under this paragraph, including the requirement for funds from private sources, for a period of 1 year at a time, if the eligible entity demonstrates significant financial hardship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304af9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full-service community schools activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e304afa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity receiving a grant under this subpart for activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7275"},"text":"section 7275 of this title","children":[],"tail":" shall provide matching funds from non-Federal sources, which may be provided in part with in-kind contributions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304afb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau of Indian Education may meet the requirement of subparagraph (A) using funds from other Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304afc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e304afd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not require any eligible entity receiving a grant under this subpart to provide matching funds in an amount that exceeds the amount of the grant award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304afe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding this subsection, the Secretary shall not consider the ability of an eligible entity to match funds when determining which applicants will receive grants under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304aff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation for rural areas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e304b00-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amounts allocated under subsection (a) for grants to eligible entities, the Secretary shall use not less than 15 percent of such amounts to award grants to eligible entities that propose to carry out the activities described in such subsection in rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304b01-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reduce the amount described in paragraph (1) if the Secretary does not receive a sufficient number of applications of sufficient quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304b02-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7273/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum number of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, the Secretary shall award under this subpart not fewer than 3 grants for activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7274"},"text":"section 7274 of this title","children":[],"tail":" and not fewer than 10 grants for activities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7275"},"text":"section 7275 of this title","children":[],"tail":", subject to the availability of appropriations, the requirements of subsection (a)(2), and the number and quality of applications."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e304b03-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4623"},"text":"Pub. L. 89–10, title IV, § 4623","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4601"},"text":"Pub. L. 114–95, title IV, § 4601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2024"},"text":"129 Stat. 2024","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e304b04-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e304b05-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e304b06-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 7273 to 7273e were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"Pub. L. 114–95, § 5","children":[],"tail":", title IV, § 4001(b)(1)(C), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1806"},"text":"129 Stat. 1806","children":[],"tail":", 1967, effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7273, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5561"},"text":"Pub. L. 89–10, title V, § 5561","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1856"},"text":"115 Stat. 1856","children":[],"tail":", related to purposes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7273a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5562"},"text":"Pub. L. 89–10, title V, § 5562","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1857"},"text":"115 Stat. 1857","children":[],"tail":", authorized grants."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7273b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5563"},"text":"Pub. L. 89–10, title V, § 5563","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1857"},"text":"115 Stat. 1857","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tIII/s305/g/3"},"text":"Pub. L. 108–446, title III, § 305(g)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2805"},"text":"118 Stat. 2805","children":[],"tail":", related to applications."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7273c, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5564"},"text":"Pub. L. 89–10, title V, § 5564","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1858"},"text":"115 Stat. 1858","children":[],"tail":", related to uses of funds."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7273d, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5565"},"text":"Pub. L. 89–10, title V, § 5565","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1859"},"text":"115 Stat. 1859","children":[],"tail":", related to administrative provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7273e, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5566"},"text":"Pub. L. 89–10, title V, § 5566","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1861"},"text":"115 Stat. 1861","children":[],"tail":", related to local family information centers."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e304b07-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e304b08-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
