{"tag":"section","attrib":{"id":"id0d895d26-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161o"},"text":"§ 1161o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" College partnership grants authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d895d27-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount appropriated to carry out this section, the Secretary shall award grants to eligible partnerships for the purposes of developing and implementing articulation agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895d28-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, an eligible partnership shall include at least two institutions of higher education, or a system of institutions of higher education, and may include either or both of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895d29-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A consortia of institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d2a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State higher education agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895d2b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall give priority to eligible partnerships that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895d2c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are located in a State that has employed strategies described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1093a/b/1"},"text":"section 1093a(b)(1) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d2d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895d2e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more junior or community colleges (as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1058/f"},"text":"section 1058(f) of this title","children":[],"tail":") that award associate’s degrees; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d2f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more institutions of higher education that offer a baccalaureate or post-baccalaureate degree not awarded by the institutions described in subparagraph (A) with which it is partnered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895d30-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this part shall be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895d31-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of policies and programs to expand opportunities for students to earn bachelor’s degrees, by facilitating the transfer of academic credits between institutions and expanding articulation and guaranteed transfer agreements between institutions of higher education, including through common course numbering and general education core curriculum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d32-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic program enhancements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d33-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to identify and remove barriers that inhibit student transfers, including technological and informational programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895d34-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optional use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this part may be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895d35-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support services to students participating in the program, such as tutoring, mentoring, and academic and personal counseling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d36-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any service that facilitates the transition of students between the partner institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895d37-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds provided under this section shall be used to financially compensate an institution for the purposes of entering into an articulation agreement or for accepting students transferring into such institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895d38-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any eligible partnership that desires to obtain a grant under this section shall submit to the Secretary an application at such time, in such manner, and containing such information or assurances as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895d39-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “articulation agreement” means an agreement between institutions of higher education that specifies the acceptability of courses in transfer toward meeting specific degree requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895d3a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161o/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d895d3b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s841"},"text":"Pub. L. 89–329, title VIII, § 841","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3420"},"text":"122 Stat. 3420","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tVIII/s801/12"},"text":"Pub. L. 111–39, title VIII, § 801(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1956"},"text":"123 Stat. 1956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d895d3c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d895d3d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d895d3e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" substituted “1093a(b)(1)” for “1093a(d)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d895d3f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d895d40-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/s3"},"text":"section 3 of Pub. L. 111–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
