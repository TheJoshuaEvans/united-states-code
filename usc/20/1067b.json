{"tag":"section","attrib":{"id":"id0cdb42b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1067b"},"text":"§ 1067b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant recipient selection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cdb42b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under this subpart shall be awarded on the basis of criteria established by the Secretary by regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cdb42b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities to be given in criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing criteria under subsection (a), the Secretary shall give priority to applicants which have not previously received funding from the Minority Institutions Science Improvement Program and to previous grantees with a proven record of success, as well as to applications that contribute to achieving balance among projects with respect to geographic region, academic discipline, and project type.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cdb42b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing criteria under subsection (a), the Secretary may consider the following selection criteria in making grants:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cdb42ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan of operation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb42bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quality of key personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb42bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" budget and cost effectiveness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb42bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb42be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequacy of resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb42bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067b/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of need for the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb42c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067b/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential institutional impact of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb42c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067b/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutional commitment to the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb42c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067b/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expected outcomes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cdb42c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067b/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific and educational value of the proposed project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cdb42c4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s352"},"text":"Pub. L. 89–329, title III, § 352","children":[],"tail":", formerly title X, § 1022, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tX/s1002"},"text":"Pub. L. 99–498, title X, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib