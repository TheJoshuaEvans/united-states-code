{"tag":"section","attrib":{"id":"id0db91ef8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2105"},"text":null,"children":[{"tag":"num","attrib":{"value":"2105"},"text":"§ 2105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0db91ef9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No payment shall be made pursuant to this subchapter to carry out any research or training over a period in excess of two years, except that with the concurrence of at least two-thirds of the members of the Board of the Center such research or training may be carried out over a period of not to exceed five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db91efa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Items excluded","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance pursuant to this subchapter shall not cover the cost of land acquisition, construction, building acquisitions, or acquisition of major equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db91efb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Former Government employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No individual formerly in the employment of the Federal Government shall be eligible to receive any assistance pursuant to this subchapter, or to serve as a trustee of the Center in the two-year period following the termination of such employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0db91efc-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/201/s6"},"text":"Pub. L. 94–201, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-01-02"},"text":"Jan. 2, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1132"},"text":"89 Stat. 1132","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
