{"tag":"section","attrib":{"id":"id0c962343-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s130aa–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"130aa–4"},"text":"§ 130aa–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c962344-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s130aa–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After notice and an opportunity for a hearing, the Secretary is authorized to terminate and recover any grant awarded under this subchapter if the University—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c962345-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s130aa–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdraws or expends any endowment fund corpus, or any endowment fund income in excess of the amount authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s130aa–3"},"text":"section 130aa–3 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c962346-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s130aa–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to invest its endowment fund corpus or income in accordance with the investment standards set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s130aa–2"},"text":"section 130aa–2 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c962347-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s130aa–4/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to account properly to the Secretary concerning investments and expenditures of its endowment fund corpus or income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c962348-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s130aa–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary terminates a grant under subsection (a), the University shall return to the Treasury of the United States an amount equal to the sum of the original grant or grants under this subchapter ","children":[{"tag":"ref","attrib":{"idref":"fn002016"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002016"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Codification note below."}],"tail":" plus any income earned thereon. The Secretary may direct the University to take such other appropriate measures to remedy any violation of this subchapter and to protect the financial interest of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c962349-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/480/tII/s206"},"text":"Pub. L. 98–480, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-17"},"text":"Oct. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2247"},"text":"98 Stat. 2247","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c96234a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c96234b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c96234c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This subchapter, the first time it appears in subsec. (b), was in the original “this Act” which was translated as reading “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/480"},"text":"Pub. L. 98–480","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-17"},"text":"Oct. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2236"},"text":"98 Stat. 2236","children":[],"tail":", as the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
