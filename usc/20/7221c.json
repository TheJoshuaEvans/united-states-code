{"tag":"section","attrib":{"id":"id0e291fb1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c"},"text":null,"children":[{"tag":"num","attrib":{"value":"7221c"},"text":"§ 7221c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities financing assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e291fb2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to eligible entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e291fb3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7221a/b/1"},"text":"section 7221a(b)(1) of this title","children":[],"tail":", the Secretary shall use not less than 50 percent to award, on a competitive basis, not less than 3 grants to eligible entities that have the highest-quality applications approved under subsection (d), after considering the diversity of such applications, to demonstrate innovative methods of helping charter schools to address the cost of acquiring, constructing, and renovating facilities by enhancing the availability of loans or bond financing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291fb4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, the term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e291fb5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public entity, such as a State or local governmental entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e291fb6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private nonprofit entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e291fb7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of entities described in subparagraphs (A) and (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e291fb8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grantee selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall evaluate each application submitted under subsection (d), and shall determine whether the application is sufficient to merit approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e291fb9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant characteristics","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under subsection (a) shall be of sufficient size, scope, and quality so as to ensure an effective demonstration of an innovative means of enhancing credit for the financing of charter school acquisition, construction, or renovation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e291fba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e291fbb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity desiring to receive a grant under this section shall submit an application to the Secretary in such form as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291fbc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application submitted under paragraph (1) shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e291fbd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement identifying the activities that the eligible entity proposes to carry out with funds received under subsection (a), including how the eligible entity will determine which charter schools will receive assistance, and how much and what types of assistance charter schools will receive;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e291fbe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the involvement of charter schools in the application’s development and the design of the proposed activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e291fbf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the eligible entity’s expertise in capital market financing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e291fc0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the proposed activities will leverage the maximum amount of private-sector financing capital relative to the amount of government funding used and otherwise enhance credit available to charter schools, including how the eligible entity will offer a combination of rates and terms more favorable than the rates and terms that a charter school could receive without assistance from the eligible entity under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e291fc1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the eligible entity possesses sufficient expertise in education to evaluate the likelihood of success of a charter school program for which facilities financing is sought; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e291fc2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an application submitted by a State governmental entity, a description of the actions that the eligible entity has taken, or will take, to ensure that charter schools within the State receive the funding that charter schools need to have adequate facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e291fc3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charter school objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity receiving a grant under subsection (a) shall use the funds deposited in the reserve account established under subsection (f) to assist one or more charter schools to access private-sector capital to accomplish one or more of the following objectives:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e291fc4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The acquisition (by purchase, lease, donation, or otherwise) of an interest (including an interest held by a third party for the benefit of a charter school) in improved or unimproved real property that is necessary to commence or continue the operation of a charter school.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291fc5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The construction of new facilities, or the renovation, repair, or alteration of existing facilities, necessary to commence or continue the operation of a charter school.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e291fc6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The predevelopment costs required to assess sites for purposes of paragraph (1) or (2) and that are necessary to commence or continue the operation of a charter school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e291fc7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve account","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e291fc8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To assist charter schools in accomplishing the objectives described in subsection (e), an eligible entity receiving a grant under subsection (a) shall, in accordance with State and local law, directly or indirectly, alone or in collaboration with others, deposit the funds received under subsection (a) (other than funds used for administrative costs in accordance with subsection (g)) in a reserve account established and maintained by the eligible entity for this purpose. Amounts deposited in such account shall be used by the eligible entity for one or more of the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2b8fc9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guaranteeing, insuring, and reinsuring bonds, notes, evidences of debt, loans, and interests therein, the proceeds of which are used for an objective described in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b8fca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guaranteeing and insuring leases of personal and real property for an objective described in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b8fcb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Facilitating financing by identifying potential lending sources, encouraging private lending, and other similar activities that directly promote lending to, or for the benefit of, charter schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b8fcc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Facilitating the issuance of bonds by charter schools, or by other public entities for the benefit of charter schools, by providing technical, administrative, and other appropriate assistance (including the recruitment of bond counsel, underwriters, and potential investors and the consolidation of multiple charter school projects within a single bond issue).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b8fcd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds received under subsection (a) and deposited in the reserve account established under paragraph (1) shall be invested in obligations issued or guaranteed by the United States or a State, or in other similarly low-risk securities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b8fce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reinvestment of earnings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any earnings on funds received under subsection (a) shall be deposited in the reserve account established under paragraph (1) and used in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2b8fcf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity may use not more than 2.5 percent of the funds received under subsection (a) for the administrative costs of carrying out its responsibilities under this section (excluding subsection (k)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2b8fd0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits and reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2b8fd1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial record maintenance and audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The financial records of each eligible entity receiving a grant under subsection (a) shall be maintained in accordance with generally accepted accounting principles and shall be subject to an annual audit by an independent public accountant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b8fd2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2b8fd3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grantee annual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity receiving a grant under subsection (a) shall submit to the Secretary an annual report of the entity’s operations and activities under this section (excluding subsection (k)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b8fd4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each annual report submitted under subparagraph (A) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e2b8fd5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the most recent financial statements, and any accompanying opinion on such statements, prepared by the independent public accountant reviewing the financial records of the eligible entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b8fd6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of any report made on an audit of the financial records of the eligible entity that was conducted under paragraph (1) during the reporting period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b8fd7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/h/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation by the eligible entity of the effectiveness of its use of the Federal funds provided under subsection (a) in leveraging private funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b8fd8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/h/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a listing and description of the charter schools served during the reporting period, including the amount of funds used by each school, the type of project facilitated by the grant, and the type of assistance provided to the charter schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b8fd9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/h/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the activities carried out by the eligible entity to assist charter schools in meeting the objectives set forth in subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b8fda-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/h/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the characteristics of lenders and other financial institutions participating in the activities carried out by the eligible entity under this section (excluding subsection (k)) during the reporting period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b8fdb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review the reports submitted under subparagraph (A) and shall provide a comprehensive annual report to Congress on the activities conducted under this section (excluding subsection (k)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2b8fdc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No full faith and credit for grantee obligation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No financial obligation of an eligible entity entered into pursuant to this section (such as an obligation under a guarantee, bond, note, evidence of debt, or loan) shall be an obligation of, or guaranteed in any respect by, the United States. The full faith and credit of the United States is not pledged to the payment of funds that may be required to be paid under any obligation made by an eligible entity pursuant to any provision of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2b8fdd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2b8fde-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in accordance with chapter 37 of title 31, shall collect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2b8fdf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all of the funds in a reserve account established by an eligible entity under subsection (f)(1) if the Secretary determines, not earlier than 2 years after the date on which the eligible entity first received funds under subsection (a), that the eligible entity has failed to make substantial progress in carrying out the purposes described in subsection (f)(1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b8fe0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all or a portion of the funds in a reserve account established by an eligible entity under subsection (f)(1) if the Secretary determines that the eligible entity has permanently ceased to use all or a portion of the funds in such account to accomplish any purpose described in subsection (f)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b8fe1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exercise of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not exercise the authority provided in paragraph (1) to collect from any eligible entity any funds that are being properly used to achieve one or more of the purposes described in subsection (f)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b8fe2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of sections 451, 452, and 458 of the General Education Provisions Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234"},"text":"20 U.S.C. 1234","children":[],"tail":", 1234a, 1234g] shall apply to the recovery of funds under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b8fe3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not be construed to impair or affect the authority of the Secretary to recover funds under part D of the General Education Provisions Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234"},"text":"20 U.S.C. 1234","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2b8fe4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Per-pupil facilities aid program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2b8fe5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of per-pupil facilities aid program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “per-pupil facilities aid program” means a program in which a State makes payments, on a per-pupil basis, to charter schools to provide the schools with financing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2b8fe6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is dedicated solely to funding charter school facilities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b8fe7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a portion of which is dedicated for funding charter school facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b8fe8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2b8fe9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7221a/b/1"},"text":"section 7221a(b)(1) of this title","children":[],"tail":" and remaining after the Secretary makes grants under subsection (a), the Secretary shall make grants, on a competitive basis, to States to pay for the Federal share of the cost of establishing or enhancing, and administering, per-pupil facilities aid programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b8fea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants under this subsection for periods of not more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b8feb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal share of the cost described in subparagraph (A) for a per-pupil facilities aid program shall be not more than—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e2b8fec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent of the cost, for the first fiscal year for which the program receives assistance under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b8fed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent for the second such year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b8fee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 percent for the third such year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b8fef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40 percent for the fourth such year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b8ff0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 20 percent for the fifth such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b8ff1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State receiving a grant under this subsection may partner with 1 or more organizations, and such organizations may provide not more than 50 percent of the State share of the cost of establishing or enhancing, and administering, the per-pupil facilities aid program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b8ff2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may receive more than 1 grant under this subsection, so long as the amount of total funds provided to charter schools increases with each successive grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b8ff3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2b8ff4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives a grant under this subsection shall use the funds made available through the grant to establish or enhance, and administer, a per-pupil facilities aid program for charter schools in the State of the applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b8ff5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations; technical assistance; dissemination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount made available to a State through a grant under this subsection for a fiscal year, the State may reserve not more than 5 percent to carry out evaluations, to provide technical assistance, and to disseminate information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b8ff6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement, not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under this subsection shall be used to supplement, and not supplant, State and local public funds expended to provide per-pupil facilities aid programs, operations financing programs, or other programs, for charter schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b8ff7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2b8ff8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State may be required to participate in a program carried out under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2b8ff9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State law","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e2b8ffa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this subsection, a State shall establish or enhance, and administer, a per-pupil facilities aid program for charter schools in the State, that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e2b8ffb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is specified in State law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e2b8ffc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides annual financing, on a per-pupil basis, for charter school facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2b8ffd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that is required under State law to provide its charter schools with access to adequate facility space, but that does not have a per-pupil facilities aid program for charter schools specified in State law, is eligible to receive a grant under this subsection if the State agrees to use the funds to develop a per-pupil facilities aid program consistent with the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2b8ffe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221c/k/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this subsection, a State shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e2b8fff-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4304"},"text":"Pub. L. 89–10, title IV, § 4304","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4301/1"},"text":"Pub. L. 114–95, title IV, § 4301(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2004"},"text":"129 Stat. 2004","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e2b9000-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e2b9001-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e2b9002-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Education Provisions Act, referred to in subsec. (j)(4), is title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247"},"text":"Pub. L. 90–247","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/814"},"text":"81 Stat. 814","children":[],"tail":". Part D of the Act is classified generally to subchapter IV (§ 1234 et seq.) of chapter 31 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221"},"text":"section 1221 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e2b9003-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7221c, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4304"},"text":"Pub. L. 89–10, title IV, § 4304","children":[],"tail":", formerly title V, § 5204, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1792"},"text":"115 Stat. 1792","children":[],"tail":"; renumbered title IV, § 4304, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4001/b/2/A"},"text":"Pub. L. 114–95, title IV, § 4001(b)(2)(A)","children":[],"tail":", (B), (D)(iii), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1967"},"text":"129 Stat. 1967","children":[],"tail":", related to administration, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"Pub. L. 114–95, § 5","children":[],"tail":", title IV, § 4301(1), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1806"},"text":"129 Stat. 1806","children":[],"tail":", 1993, effective "},{"tag":"date","attrib":{"date":"2015-1