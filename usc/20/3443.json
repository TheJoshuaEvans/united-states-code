{"tag":"section","attrib":{"id":"id0dd819f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3443"},"text":null,"children":[{"tag":"num","attrib":{"value":"3443"},"text":"§ 3443.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers from Department of Labor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dd819f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3443/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions relating to programs for the education of migrant and seasonal farmworkers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of section 601 of this Act, there shall be transferred to the Secretary, at such time on or after ","children":[{"tag":"date","attrib":{"date":"1980-05-04"},"text":"May 4, 1980","children":[],"tail":", as the Secretary certifies that there has been established in the Department a single component responsible for the administration and the coordination of programs relating to the education of migrants, all functions of the Secretary of Labor or the Department of Labor relating to such education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dd819f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3443/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization to conduct functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to conduct the functions transferred by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dd819f3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"