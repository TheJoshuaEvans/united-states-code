":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d1230ce-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment; Transition Rule","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/409/s3/a/2"},"text":"Pub. L. 108–409, § 3(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2300"},"text":"118 Stat. 2300","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/409/s3/a/2"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by paragraph (1) of this subsection to sections 428J(b)(1) and 460(b)(1)(A) of the Higher Education Act of 1965 [sections 1078–10(b)(1) and 1087j(b)(1)(A) of this title] shall not be applied to disqualify any individual who, before the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":"], commenced service that met and continues to meet the requirements of such sections as such sections were in effect on the day before the date of enactment of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule not applicable to increased qualified loan amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subparagraph (A) of this paragraph s