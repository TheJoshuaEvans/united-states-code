{"tag":"section","attrib":{"id":"id0e51b63f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7910a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7910a"},"text":"§ 7910a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on requiring State participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any State that opts out of receiving funds, or that has not been awarded funds, under one or more programs under this chapter shall not be required to carry out any of the requirements of such program or programs, and nothing in this chapter shall be construed to require a State to participate in any program under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e51b640-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8530A"},"text":"Pub. L. 89–10, title VIII, § 8530A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII/s8028"},"text":"Pub. L. 114–95, title VIII, § 8028","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2116"},"text":"129 Stat. 2116","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e51b641-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e51b642-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e51b643-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
