{"tag":"section","attrib":{"id":"id0d7d7613-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1140i"},"text":"§ 1140i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations and reservation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d7d7614-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this subpart such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7d7615-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any fiscal year for which appropriations are made for this subpart, the Secretary shall reserve funds to enter into a cooperative agreement to establish the coordinating center under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1140q/b"},"text":"section 1140q(b) of this title","children":[],"tail":", in an amount that is—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7d7616-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $240,000 for any year in which the amount appropriated to carry out this subpart is $8,000,000 or less; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d7617-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equal to 3 percent of the amount appropriated to carry out this subpart for any year in which such amount appropriated is greater than $8,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d7d7618-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s769"},"text":"Pub. L. 89–329, title VII, § 769","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s709/2"},"text":"Pub. L. 110–315, title VII, § 709(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3367"},"text":"122 Stat. 3367","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
