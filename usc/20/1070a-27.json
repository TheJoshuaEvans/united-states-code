{"tag":"section","attrib":{"id":"id0cec0b8d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–27"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070a–27"},"text":"§ 1070a–27.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cec0b8e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–27/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity receiving a grant under this division shall biennially evaluate the activities assisted under this division in accordance with the standards described in subsection (b) and shall submit to the Secretary a copy of such evaluation. The evaluation shall permit service providers to track eligible student progress during the period such students are participating in the activities and shall be consistent with the standards developed by the Secretary pursuant to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0b8f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–27/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe standards for the evaluation described in subsection (a). Such standards shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cec0b90-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–27/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for input from eligible entities and service providers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b91-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–27/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that data protocols and procedures are consistent and uniform.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0b92-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–27/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to evaluate and improve the impact of the activities assisted under this division, the Secretary shall, from not more than 0.75 percent of the funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–28"},"text":"section 1070a–28 of this title","children":[],"tail":" for a fiscal year, award one or more grants, contracts, or cooperative agreements to or with public and private institutions and organizations, to enable the institutions and organizations to evaluate the effectiveness of the program and, as appropriate, disseminate the results of the evaluation. Such evaluation shall include a separate analysis of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cec0b93-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–27/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of the scholarship component described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–25"},"text":"section 1070a–25 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0b94-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–27/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of methods for complying with matching requirements described in paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–23/c"},"text":"section 1070a–23(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0b95-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–27/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall biennially report to Congress regarding the activities assisted under this division and the evaluations conducted pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cec0b96-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s404G"},"text":"Pub. L. 89–329, title IV, § 404G","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s403"},"text":"Pub. L. 105–244, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1662"},"text":"112 Stat. 1662","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s404/g"},"text":"Pub. L. 110–315, title IV, § 404(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3215"},"text":"122 Stat. 3215","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cec0b97-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cec0b98-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cec0b99-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1070a–27, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s404G"},"text":"Pub. L. 89–329, title IV, § 404G","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s402/a/4"},"text":"Pub. L. 102–325, title IV, § 402(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/496"},"text":"106 Stat. 496","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/b/23"},"text":"Pub. L. 103–208, § 2(b)(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2459"},"text":"107 Stat. 2459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s354"},"text":"Pub. L. 103–382, title III, § 354","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3967"},"text":"108 Stat. 3967","children":[],"tail":", authorized appropriations for grants under this division, prior to the general amendment of this division by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–28"},"text":"section 1070a–28 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cec0b9a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" inserted at end “Such evaluation shall include a separate analysis of—” and pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
