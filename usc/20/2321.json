{"tag":"section","attrib":{"id":"id0dbb696a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321"},"text":null,"children":[{"tag":"num","attrib":{"value":"2321"},"text":"§ 2321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservations and State allotment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dbb696b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservations and State allotment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dbb696c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2307"},"text":"section 2307 of this title","children":[],"tail":" for each fiscal year, the Secretary shall reserve—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dbb696d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.13 percent to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2325"},"text":"section 2325 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb696e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 1.50 percent to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2326"},"text":"section 2326 of this title","children":[],"tail":", of which—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0dbb696f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1.25 percent of the sum shall be available to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2326/b"},"text":"section 2326(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dbb6970-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.25 percent of the sum shall be available to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2326/h"},"text":"section 2326(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dbb6971-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foundational grant","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dbb6972-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the remainder of the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2307"},"text":"section 2307 of this title","children":[],"tail":" and not reserved under paragraph (1) for a fiscal year, the Secretary shall allot to a State for the fiscal year an amount equal to the amount the State received in fiscal year 2018."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb6973-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratable reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If for any fiscal year the amount appropriated for allotments under this section is insufficient to satisfy the provisions of subparagraph (A), the payments to all States under such subparagraph shall be ratably reduced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dbb6974-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (4), from the additional funds remaining from the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2307"},"text":"section 2307 of this title","children":[],"tail":" and not expended under paragraphs (1) and (2) for a fiscal year, the Secretary shall allot to a State for the fiscal year—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dbb6975-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount that bears the same ratio to 50 percent of the sum being allotted as the product of the population aged 15 to 19, inclusive, in the State in the fiscal year preceding the fiscal year for which the determination is made and the State’s allotment ratio bears to the sum of the corresponding products for all the States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb6976-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount that bears the same ratio to 20 percent of the sum being allotted as the product of the population aged 20 to 24, inclusive, in the State in the fiscal year preceding the fiscal year for which the determination is made and the State’s allotment ratio bears to the sum of the corresponding products for all the States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb6977-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount that bears the same ratio to 15 percent of the sum being allotted as the product of the population aged 25 to 65, inclusive, in the State in the fiscal year preceding the fiscal year for which the determination is made and the State’s allotment ratio bears to the sum of the corresponding products for all the States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb6978-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount that bears the same ratio to 15 percent of the sum being allotted as the amounts allotted to the State under subparagraphs (A), (B), and (C) for such years bears to the sum of the amounts allotted to all the States under subparagraphs (A), (B), and (C) for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dbb6979-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotment for years with additional funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dbb697a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), for a fiscal year for which there are additional funds described in paragraph (3), no State shall receive for such fiscal year under paragraph (3) less than 1/2 of 1 percent of the additional funds available for such fiscal year. Amounts necessary for increasing such payments to States to comply with the preceding sentence shall be obtained by ratably reducing the amounts to be paid to other States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb697b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a qualifying State, the minimum allotment under subparagraph (A) for a fiscal year for the qualifying State shall be the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0dbb697c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1/2 of 1 percent of the additional funds available for such fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dbb697d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0dbb697e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1/3 of the additional funds; multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0dbb697f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the quotient of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id0dbb6980-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/4/B/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the qualifying State’s ratio described in subparagraph (C) for the fiscal year for which the determination is made; divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id0dbb6981-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/4/B/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of all such ratios for all qualifying States for the fiscal year for which the determination is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb6982-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratio","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (B)(ii)(II)(aa), the ratio for a qualifying State for a fiscal year shall be 1.00 less the quotient of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0dbb6983-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount the qualifying State is allotted under paragraph (3) for the fiscal year; divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dbb6984-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1/2 of 1 percent of the amount appropriated under paragraph (3) for the fiscal year for which the determination is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb6985-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “qualifying State” means a State (except the United States Virgin Islands) that, for the fiscal year for which a determination under this paragraph is made, would receive, under the allotment formula under paragraph (3) (without the application of this paragraph), an amount that would be less than the amount the State would receive under subparagraph (A) for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dbb6986-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that any amount of any State’s allotment under subsection (a) for any fiscal year will not be required for such fiscal year for carrying out the activities for which such amount has been allotted, the Secretary shall make such amount available for reallotment. Any such reallotment among other States shall occur on such dates during the same year as the Secretary shall fix, and shall be made on the basis of criteria established by regulation. No funds may be reallotted for any use other than the use for which the funds were appropriated. Any amount reallotted to a State under this subsection for any fiscal year shall remain available for obligation during the succeeding fiscal year and shall be deemed to be part of the State’s allotment for the year in which the amount is obligated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dbb6987-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment ratio","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dbb6988-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The allotment ratio for any State shall be 1.00 less the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dbb6989-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.50; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dbb698a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the quotient obtained by dividing the per capita income for the State by the per capita income for all the States (exclusive of the Commonwealth of Puerto Rico and the United States Virgin Islands), except that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0dbb698b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allotment ratio in no case shall be more than 0.60 or less than 0.40; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dbb698c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allotment ratio for the Commonwealth of Puerto Rico and the United States Virgin Islands shall be 0.60.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dbb698d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The allotment ratios shall be promulgated by the Secretary for each fiscal year between October 1 and December 31 of the fiscal year preceding the fiscal year for which the determination is made. Allotment ratios shall be computed on the basis of the average of the appropriate per capita incomes for the 3 most recent consecutive fiscal years for which satisfactory data are available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dbb698e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of per capita income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this section, the term “per capita income” means, with respect to a fiscal year, the total personal income in the calendar year ending in such year, divided by the population of the area concerned in such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dbb698f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, population shall be determined by the Secretary on the basis of the latest estimates available to the Department of Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dbb6990-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2321/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this section, the term “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, and the United States Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dbdd991-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tI/s111"},"text":"Pub. L. 88–210, title I, § 111","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/691"},"text":"120 Stat. 691","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/tI/s110"},"text":"Pub. L. 115–224, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-31"},"text":"July 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1576"},"text":"132 Stat. 1576","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dbdd992-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dbdd993-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0dbdd994-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2321, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tI/s111"},"text":"Pub