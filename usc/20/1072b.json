{"tag":"section","attrib":{"id":"id0cfa636b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1072b"},"text":"§ 1072b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency Operating Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cfa636c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each guaranty agency shall, not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"1998-10-07"},"text":"October 7, 1998","children":[],"tail":", establish a fund designated as the Operating Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cfa636d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds deposited into the Operating Fund shall be invested at the discretion of the guaranty agency in accordance with prudent investor standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cfa636e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional deposits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After the establishment of the Operating Fund, the guaranty agency shall deposit into the Operating Fund—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cfa636f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan processing and issuance fee paid by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078/f"},"text":"section 1078(f) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cfa6370-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 percent of amounts received after ","children":[{"tag":"date","attrib":{"date":"1998-10-07"},"text":"October 7, 1998","children":[],"tail":", from the Secretary as payment for administrative cost allowances for loans upon which insurance was issued prior to "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"October 7, 1998","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cfa6371-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the account maintenance fee paid by the Secretary in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087h"},"text":"section 1087h of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cfa6372-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the default aversion fee paid in accordance with section 1078(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cfa6373-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts remaining pursuant to section 1078(c)(6)(B) ","children":[{"tag":"ref","attrib":{"idref":"fn002052"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002052"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title from collection on defaulted loans held by the agency, after payment of the Secretary’s equitable share, excluding amounts deposited in the Federal Fund pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1072a/c/2"},"text":"section 1072a(c)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cfa6374-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other receipts as specified in regulations of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cfa6375-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cfa6376-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds in the Operating Fund shall be used for application processing, loan disbursement, enrollment and repayment status management, default aversion activities (including those described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1072/h/8"},"text":"section 1072(h)(8) of this title","children":[],"tail":"), default collection activities, school and lender training, financial aid awareness and related outreach activities, compliance monitoring, and other student financial aid related activities, as selected by the guaranty agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cfa6377-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The guaranty agency may, in the agency’s discretion, transfer funds from the Operating Fund to the Federal Fund for use pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1072a"},"text":"section 1072a of this title","children":[],"tail":". Such transfer shall be irrevocable, and any funds so transferred shall become the sole property of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cfa6378-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cfa6379-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Default collection activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “default collection activities” means activities of a guaranty agency that are directly related to the collection of the loan on which a default claim has been paid to the participating lender, including the due diligence activities required pursuant to regulations of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cfa637a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Default aversion activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “default aversion activities” means activities of a guaranty agency that are directly related to providing collection assistance to the lender on a delinquent loan, prior to the loan’s being legally in a default status, including due diligence activities required pursuant to regulations of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cfa637b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment and repayment status management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “enrollment and repayment status management” means activities of a guaranty agency that are directly related to ascertaining the student’s enrollment status, including prompt notification to the lender of such status, an audit of the note or written agreement to determine if the provisions of that note or agreement are consistent with the records of the guaranty agency as to the principal amount of the loan guaranteed, and an examination of the note or agreement to assure that the repayment provisions are consistent with the provisions of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cfa637c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership and regulation of Operating Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cfa637d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Operating Fund, with the exception of funds transferred from the Federal Fund in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1072a/f"},"text":"section 1072a(f) of this title","children":[],"tail":", shall be considered to be the property of the guaranty agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cfa637e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), the Secretary may not regulate the uses or expenditure of moneys in the Operating Fund, but the Secretary may require such necessary reports and audits as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078/b/2"},"text":"section 1078(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cfa637f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraphs (1) and (2), during any period in which funds are owed to the Federal Fund as a result of transfer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1072a/f"},"text":"section 1072a(f) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cfa6380-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" moneys in the Operating Fund may only be used for expenses related to the student loan programs authorized under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cfa6381-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1072b/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may regulate the uses or expenditure of moneys in the Operating Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cfa6382-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s422B"},"text":"Pub. L. 89–329, title IV, § 422B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s413/b"},"text":"Pub. L. 105–244, title IV, § 413(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1677"},"text":"112 Stat. 1677","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cfa6383-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cfa6384-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0cfa6385-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078/c/6/B"},"text":"Section 1078(c)(6)(B) of this title","children":[],"tail":", referred to in subsec. (c)(5), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078/c/6/A/ii"},"text":"section 1078(c)(6)(A)(ii) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tVIII/s8014/d/3/A"},"text":"Pub. L. 109–171, title VIII, § 8014(d)(3)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/170"},"text":"120 Stat. 170","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cfa6386-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0cfa6387-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
