{"tag":"section","attrib":{"id":"id0e13c2ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6438"},"text":null,"children":[{"tag":"num","attrib":{"value":"6438"},"text":"§ 6438.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e13c2f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6438/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State agency shall reserve not less than 15 percent and not more than 30 percent of the amount such agency receives under this subpart for any fiscal year to support—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e13c2f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6438/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects that facilitate the transition of children and youth between State-operated institutions, or institutions in the State operated by the Secretary of the Interior, and schools served by local educational agencies or schools operated or funded by the Bureau of Indian Education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e13c2f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6438/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the successful reentry of youth offenders, who are age 20 or younger and have received a regular high school diploma or its recognized equivalent, into postsecondary education, or career and technical training programs, through strategies designed to expose the youth to, and prepare the youth for, postsecondary education, or career and technical training programs, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e13c2f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6438/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preplacement programs that allow adjudicated or incarcerated youth to audit or attend courses on college, university, or community college campuses, or through programs provided in institutional settings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e13c2f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6438/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" worksite schools, in which institutions of higher education and private or public employers partner to create programs to help students make a successful transition to postsecondary education and employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e13c2f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6438/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" essential support services to ensure the success of the youth, such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e13c2f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6438/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal, career and technical, and academic, counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e13c2f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6438/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" placement services designed to place the youth in a university, college, or junior college program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e13c2f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6438/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information concerning, and assistance in obtaining, available student financial aid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e13c2f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6438/a/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counseling services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e13c2fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6438/a/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" job placement services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e13c2fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6438/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project supported under this section may be conducted directly by the State agency, or through a contract or other arrangement with one or more local educational agencies, other public agencies, or private nonprofit organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e13c2fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6438/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prohibit a school that receives funds under subsection (a) from serving neglected and delinquent children and youth simultaneously with students with similar educational needs, in the same educational settings where appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e13c2fd-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1418"},"text":"Pub. L. 89–10, title I, § 1418","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1586"},"text":"115 Stat. 1586","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1401/6"},"text":"Pub. L. 114–95, title I, § 1401(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1903"},"text":"129 Stat. 1903","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e13c2fe-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e13c2ff-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e13c300-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6438, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1418"},"text":"Pub. L. 89–10, title I, § 1418","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3597"},"text":"108 Stat. 3597","children":[],"tail":", related to transition services, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e13c301-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/6/A"},"text":"Pub. L. 114–95, § 1401(6)(A)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “projects that facilitate the transition of children and youth from State-operated institutions to schools served by local educational agencies; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1401/6/B"},"text":"Pub. L. 114–95, § 1401(6)(B)","children":[],"tail":", substituted “regular high school diploma” for “secondary school diploma” in introductory provisions and substituted “career” for “vocational” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e13c302-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e13c303-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
