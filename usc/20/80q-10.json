{"tag":"section","attrib":{"id":"id0c87f288-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"80q–10"},"text":"§ 80q–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special committee to review inventory, identification, and return of Indian human remains and Indian funerary objects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c87f289-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"1989-11-28"},"text":"November 28, 1989","children":[],"tail":", the Secretary of the Smithsonian Institution shall appoint a special committee to monitor and review the inventory, identification, and return of Indian human remains and Indian funerary objects under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s80q–9"},"text":"section 80q–9 of this title","children":[],"tail":" and unassociated funerary objects, sacred objects, and objects of cultural patrimony under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s80q–9a"},"text":"section 80q–9a of this title","children":[],"tail":". In carrying out its duties, the committee shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c87f28a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the inventory and identification, ensure fair and objective consideration and assessment of all relevant evidence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f28b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon the request of any affected party or otherwise, review any finding relating to the origin or the return of such remains or objects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f28c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the resolution of any dispute that may arise between Indian tribes with respect to the return of such remains or objects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f28d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other related functions as the Secretary may assign.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c87f28e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The committee shall consist of 7 members, of whom—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c87f28f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 members shall be appointed from among nominations submitted by Indian tribes and organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f290-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 2 members shall be traditional Indian religious leaders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f291-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall designate one member as chairman.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary may not appoint to the committee any individual who is an officer or employee of the Government (including the Smithsonian Institution) or any individual who is otherwise affiliated with the Smithsonian Institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c87f292-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the members of the committee have full and free access to the Indian human remains and Indian funerary objects subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80q–9"},"text":"section 80q–9 of this title","children":[],"tail":" and to any related evidence, including scientific and historical documents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c87f293-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay and expenses of members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c87f294-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be paid the daily equivalent of the annual rate of basic pay payable for grade GS–18 of the General schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f295-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be entitled (to the same extent as provided in section 5703 of such title, with respect to employees serving intermittently in the Government service) to per diem, travel, and transportation expenses;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for each day (including travel time) during which they are engaged in the performance of their duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c87f296-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and administrative support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe regulations and provide administrative support for the committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c87f297-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report and termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the conclusion of the work of the committee, the Secretary shall be so ","children":[{"tag":"ref","attrib":{"idref":"fn002006"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002006"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “shall so”."}],"tail":" certify by report to the Congress. The committee shall cease to exist 120 days after the submission of the report."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c87f298-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to the committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c87f299-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–10/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $250,000 for fiscal year 1991 and such sums as may be necessary for succeeding fiscal years to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c87f29a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/185/s12"},"text":"Pub. L. 101–185, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1344"},"text":"103 Stat. 1344","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/278/s5"},"text":"Pub. L. 104–278, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3357"},"text":"110 Stat. 3357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/145"},"text":"Pub. L. 117–286, § 4(a)(145)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4321"},"text":"136 Stat. 4321","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c87f29b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c87f29c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c87f29d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “the Federal Advisory Committee Act” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/278/s5/1"},"text":"Pub. L. 104–278, § 5(1)","children":[],"tail":", in first sentence, inserted “and unassociated funerary objects, sacred objects, and objects of cultural patrimony under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s80q–9a"},"text":"section 80q–9a of this title","children":[],"tail":"” before period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/278/s5/2/A"},"text":"Pub. L. 104–278, § 5(2)(A)","children":[],"tail":", substituted “7 members” for “five members” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/278/s5/2/B"},"text":"Pub. L. 104–278, § 5(2)(B)","children":[],"tail":", substituted “4 members” for “three members” and struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/278/s5/2/C"},"text":"Pub. L. 104–278, § 5(2)(C)","children":[],"tail":", (D), added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c87f29e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0c87f29f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Other Laws to GS–16, 17, or 18 Pay Rates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References in laws to the rates of pay for GS–16, 17, or 18, or to maximum rates of pay under the General Schedule, to be considered references to rates payable under specified sections of Title 5, Government Organization and Employees, see section 529 [title I, § 101(c)(1)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
