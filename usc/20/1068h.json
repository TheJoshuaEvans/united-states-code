elated to authorizations for parts A to E for fiscal year 1999 and each of the 4 succeeding fiscal years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s308/h/1/A"},"text":"Pub. L. 105–244, § 308(h)(1)(A)","children":[],"tail":", substituted “1999” for “1993”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s308/h/1/B"},"text":"Pub. L. 105–244, § 308(h)(1)(B)","children":[],"tail":", redesignated cl. (i) as entire subpar., substituted “$10,000,000 for fiscal year 1999” for “$45,000,000 for fiscal year 1993”, and struck out cl. (ii) which read as follows: “No funds are authorized to be appropriated pursuant to clause (i) for any fiscal year unless the amount appropriated pursuant to paragraph (1)(A) for such fiscal year equals or exceeds $80,000,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s308/h/1/C"},"text":"Pub. L. 105–244, § 308(h)(1)(C)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s308/h/2/A"},"text":"Pub. L. 105–244, § 308(h)(2)(A)","children":[],"tail":", substituted “1999” for “1993”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s308/h/2/B"},"text":"Pub. L. 105–244, § 308(h)(2)(B)","children":[],"tail":", substituted “$35,000,000 for fiscal year 1999” for “$20,000,000 for fiscal year 1993”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s308/h/3"},"text":"Pub. L. 105–244, § 308(h)(3)","children":[],"tail":", substituted “$10,000,000 for fiscal year 1999” for “$50,000,000 for fiscal year 1993”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s308/h/4"},"text":"Pub. L. 105–244, § 308(h)(4)","children":[],"tail":", added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s308/h/5"},"text":"Pub. L. 105–244, § 308(h)(5)","children":[],"tail":", struck out heading and text of subsec. (c). Text read as follows: “If the amount appropriated under subsection (a)(1) of this section for part A of this subchapter for any fiscal year beginning after "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":", equals or exceeds the amount appropriated for such part for fiscal year 1986, the Secretary shall, for such fiscal year—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) allocate 25 percent of the excess (above the amount appropriated for part A of this subchapter for fiscal year 1986) among eligible institutions at which at least 60 percent of the students are African Americans, Hispanic Americans, Native Americans, Asian Americans, Native Hawaiians, or Pacific Islanders, or any combination thereof; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) allocate 75 percent of such excess among other eligible institutions.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s308/h/5"},"text":"Pub. L. 105–244, § 308(h)(5)","children":[],"tail":", struck out heading and text of subsec. (d). Text read as follows: “In any fiscal year in which the sums appropriated for part A of this subchapter are insufficient to make the reservations required by subsection (c) of this section, the Secretary shall ratably reduce the amount of the reservation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s308/h/5"},"text":"Pub. L. 105–244, § 308(h)(5)","children":[],"tail":", struck out heading and text of subsec. (e). Text read as follows: “In any fiscal year beginning after "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":", the Secretary shall award at least 25 percent of the amount appropriated pursuant to the authority of paragraph (3) of subsection (a) of this section in each fiscal year to historically black colleges and universities that meet the requirements of part C of this subchapter, unless there are an insufficient number of quality applications or an insufficient number of applications due to the provisions in subsection (b)(2)(C) or subsection (b)(4)(B) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1065"},"text":"section 1065 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s305/e"},"text":"Pub. L. 102–325, § 305(e)","children":[],"tail":", amended subsec. (a) generally, substituting present provisions for provisions authorizing appropriations for fiscal year 1987 and the four succeeding fiscal years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s305/f"},"text":"Pub. L. 102–325, § 305(f)","children":[],"tail":", substituted “1986, the Secretary shall, for such fiscal year—” for “1986—” in introductory provisions, added pars. (1) and (2), and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the Secretary shall, for such fiscal year, make available for use for the purposes of part A of this subchapter to institutions that are junior or community colleges not less than $51,400,000; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the Secretary shall, for such fiscal year—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) allocate 25 percent of the excess (above the amount appropriated for part A of this subchapter for fiscal year 1986) among eligible institutions with the highest percentages of students who are Black Americans, Hispanic Americans, Native Americans, Asian Americans, Native Hawaiians, or Pacific Islanders, or any combination thereof; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) allocate 75 percent of such excess among other eligible institutions.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s305/g"},"text":"Pub. L. 102–325, § 305(g)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ce02486-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0ce02487-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0ce02488-3a70-11f1-a648-bee82ed8a7