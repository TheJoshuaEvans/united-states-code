{"tag":"section","attrib":{"id":"id0c8581ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80i"},"text":null,"children":[{"tag":"num","attrib":{"value":"80i"},"text":"§ 80i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated to the Board such funds as may be necessary to carry out the purposes of this subchapter: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no more than $200,000 shall be authorized for appropriation through fiscal year 1970 and no part of that appropriation shall be available for construction purposes."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c8581af-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/637/s7"},"text":"Pub. L. 90–637, § 7","children":[],"tail":", formerly § 6, "},{"tag":"date","attrib":{"date":"1968-10-24"},"text":"Oct. 24, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1359"},"text":"82 Stat. 1359","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/95/286/s1/1"},"text":"Pub. L. 95–286, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-05-26"},"text":"May 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/278"},"text":"92 Stat. 278","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
