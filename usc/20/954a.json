{"tag":"section","attrib":{"id":"id0caba6c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s954a"},"text":null,"children":[{"tag":"num","attrib":{"value":"954a"},"text":"§ 954a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to the arts through support of education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0caba6c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s954a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0caba6c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s954a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase accessibility to the arts through providing education to all Americans, including diverse cultures, urban and rural populations by encouraging and developing quality education in the arts at all levels, in conjunction with programs of nonformal education for all age groups, with formal systems of elementary, secondary, and postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0caba6c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s954a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and stimulate research to teach quality education in the arts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0caba6c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s954a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage and facilitate the work of artists, arts institutions, and Federal, State, regional, and local agencies in the area of education in the arts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0caba6c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s954a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program of contracts or grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chairperson of the National Endowment for the Arts,","children":[{"tag":"ref","attrib":{"idref":"fn002019"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002019"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" is authorized to establish and carry out a program of contracts with, or grants to, any State or other public agency, individual, artist, any nonprofit society, performing and nonperforming arts and educational institution or organization, association, or museum in the United States, in order to foster and encourage exceptional talent, public knowledge, understanding, and appreciation of the arts, and to support the education, training, and development of this Nation’s artists, through such activities as projects that will—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0caba6c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s954a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote and improve the availability of arts instruction for American youth and life-long learning in the arts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0caba6ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s954a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the quality of arts instruction in programs of teacher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0caba6cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s954a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop arts faculty resources and talents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0caba6cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s954a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support and encourage the development of improved curriculum materials in the arts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0caba6cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s954a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve evaluation and assessment of education in the arts programs and instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0caba6ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s954a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster cooperative programs with the Department of Education and encourage partnerships between arts and education agencies at State and local levels, arts organizations, business colleges and universities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0caba6cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s954a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support apprenticeships, internships, and other career oriented work-study experiences for artists and arts teachers, and encourage residencies of artists at all educational levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0caba6d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s954a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the use of technology and improved facilities and resources in education in the arts programs at all levels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0caba6d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s954a/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster the development of demonstration projects, demonstration productions, demonstration workshops, and demonstration programs in arts education and collect, and make available to the public, information on their implementation and effectiveness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0caba6d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s954a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory council on arts education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to provide advice and counsel concerning arts education, the Chairperson shall appoint an advisory council on arts education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0caba6d3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/209/s5A"},"text":"Pub. L. 89–209, § 5A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/512/tIII/s318/tI/s105"},"text":"Pub. L. 101–512, title III, § 318 [title I, § 105]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1960"},"text":"104 Stat. 1960","children":[],"tail":", 1967.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0caba6d4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0caba6d5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0caba6d6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see section 318 [title IV, § 403(a)] of "},{"tag":"ref","attrib":{"href":"/us/pl/101/512"},"text":"Pub. L. 101–512","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s951"},"text":"section 951 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
