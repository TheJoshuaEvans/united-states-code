{"tag":"section","attrib":{"id":"id0e70aedd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002"},"text":null,"children":[{"tag":"num","attrib":{"value":"10002"},"text":"§ 10002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State uses of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e70aede-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e70aedf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, the Governor shall use 81.8 percent of the State’s allocation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s10001/d"},"text":"section 10001(d) of this title","children":[],"tail":" for the support of elementary, secondary, and postsecondary education and, as applicable, early childhood education programs and services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e70aee0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoring State support for education","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e70aee1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Governor shall first use the funds described in paragraph (1)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e70aee2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide the amount of funds, through the State’s primary elementary and secondary education funding formulae, that is needed—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e70aee3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002/a/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restore, in each of fiscal years 2009, 2010, and 2011, the level of State support provided through such formulae to the greater of the fiscal year 2008 or fiscal year 2009 level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e70aee4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002/a/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where applicable, to allow existing State formulae increases to support elementary and secondary education for fiscal years 2010 and 2011 to be implemented and allow funding for phasing in State equity and adequacy adjustments, if such increases were enacted pursuant to State law prior to ","children":[{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e70aee5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide, in each of fiscal years 2009, 2010, and 2011, the amount of funds to public institutions of higher education in the State that is needed to restore State support for such institutions (excluding tuition and fees paid by students) to the greater of the fiscal year 2008 or fiscal year 2009 level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e70aee6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shortfall","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Governor determines that the amount of funds available under paragraph (1) is insufficient to support, in each of fiscal years 2009, 2010, and 2011, public elementary, secondary, and higher education at the levels described in clauses (i) and (ii) of subparagraph (A), the Governor shall allocate those funds between those clauses in proportion to the relative shortfall in State support for the education sectors described in those clauses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e70aee7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the term “fiscal year” shall have the meaning given such term under State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e70aee8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subgrants to improve basic programs operated by local educational agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After carrying out paragraph (2), the Governor shall use any funds remaining under paragraph (1) to provide local educational agencies in the State with subgrants based on their relative shares of funding under part A of title I of the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311"},"text":"20 U.S.C. 6311","children":[],"tail":" et seq.) for the most recent year for which data are available."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e70aee9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other government services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e70aeea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor shall use 18.2 percent of the State’s allocation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s10001/d"},"text":"section 10001(d) of this title","children":[],"tail":" for public safety and other government services, which may include assistance for elementary and secondary education and public institutions of higher education, and for modernization, renovation, or repair of public school facilities and institutions of higher education facilities, including modernization, renovation, and repairs that are consistent with a recognized green building rating system."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e70aeeb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to all institutions of higher education","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Governor shall not consider the type or mission of an institution of higher education, and shall consider any institution for funding for modernization, renovation, and repairs within the State that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e70aeec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualifies as an institution of higher education, as defined in subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002258"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002258"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 10013(3) of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e70aeed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continues to be eligible to participate in the programs under title IV of the Higher Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070"},"text":"20 U.S.C. 1070","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e70aeee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10002/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall allow a local educational agency to engage in school modernization, renovation, or repair that is inconsistent with State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e70aeef-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIV/s14002"},"text":"Pub. L. 111–5, div. A, title XIV, § 14002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/279"},"text":"123 Stat. 279","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/8/dF/tV/s523/a"},"text":"Pub. L. 111–8, div. F, title V, § 523(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/806"},"text":"123 Stat. 806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e70aef0-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e70aef1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e70aef2-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Elementary and Secondary Education Act of 1965, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-04-11"},"text":"Apr. 11, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/27"},"text":"79 Stat. 27","children":[],"tail":". Part A of title I of the Act is classified generally to part A (§ 6311 et seq.) of subchapter I of chapter 70 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Higher Education Act of 1965, referred to in subsec. (b)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1219"},"text":"79 Stat. 1219","children":[],"tail":". Title IV of the Act is classified generally to subchapter IV (§ 1070 et seq.) of chapter 28 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e70aef3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8/s523/a"},"text":"Pub. L. 111–8, § 523(a)","children":[],"tail":", inserted “education” after “secondary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8/s523/b"},"text":"Pub. L. 111–8, § 523(b)","children":[],"tail":", substituted “10001(d)” for “10001”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
