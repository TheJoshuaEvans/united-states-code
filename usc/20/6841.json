{"tag":"section","attrib":{"id":"id0e21f35c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6841"},"text":null,"children":[{"tag":"num","attrib":{"value":"6841"},"text":"§ 6841.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e21f35d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6841/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each eligible entity that receives a subgrant from a State educational agency under subpart 1 shall provide such agency, at the conclusion of every second fiscal year during which the subgrant is received, with a report, in a form prescribed by the agency, on the activities conducted and children served under such subpart that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e21f35e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6841/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the programs and activities conducted by the entity with funds received under subpart 1 during the 2 immediately preceding fiscal years, which shall include a description of how such programs and activities supplemented programs funded primarily with State or local funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f35f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6841/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and percentage of English learners in the programs and activities who are making progress toward achieving English language proficiency, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/c/4/A/ii"},"text":"section 6311(c)(4)(A)(ii) of this title","children":[],"tail":", in the aggregate and disaggregated, at a minimum, by English learners with a disability;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f360-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6841/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and percentage of English learners in the programs and activities attaining English language proficiency based on State English language proficiency standards established under section 6311(b)(1)(G) ","children":[{"tag":"ref","attrib":{"idref":"fn002216"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002216"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “6311(b)(1)(F)”."}],"tail":" of this title by the end of each school year, as determined by the State’s English language proficiency assessment under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2/G"},"text":"section 6311(b)(2)(G) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f361-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6841/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and percentage of English learners who exit the language instruction educational programs based on their attainment of English language proficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f362-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6841/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and percentage of English learners meeting challenging State academic standards for each of the 4 years after such children are no longer receiving services under this part, in the aggregate and disaggregated, at a minimum, by English learners with a disability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f363-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6841/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and percentage of English learners who have not attained English language proficiency within 5 years of initial classification as an English learner and first enrollment in the local educational agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f364-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6841/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information that the State educational agency may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e21f365-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6841/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A report provided by an eligible entity under subsection (a) shall be used by the entity and the State educational agency for improvement of programs and activities under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e21f366-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6841/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for specially qualified agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each specially qualified agency receiving a grant under subpart 1 shall provide the reports described in subsection (a) to the Secretary subject to the same requirements as apply to eligible entities providing such evaluations to State educational agencies under such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e21f367-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIII/s3121"},"text":"Pub. L. 89–10, title III, § 3121","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIII/s301"},"text":"Pub. L. 107–110, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1701"},"text":"115 Stat. 1701","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIII/s3003/h"},"text":"Pub. L. 114–95, title III, § 3003(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1962"},"text":"129 Stat. 1962","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e21f368-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e21f369-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e21f36a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6841, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIII/s3131"},"text":"Pub. L. 89–10, title III, § 3131","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3644"},"text":"108 Stat. 3644","children":[],"tail":", related to allotment and reallotment of funds, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s3121"},"text":"section 3121 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6831"},"text":"section 6831 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e21f36b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (e) relating to evaluations."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e21f36c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"tex