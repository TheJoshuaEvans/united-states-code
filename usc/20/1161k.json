{"tag":"section","attrib":{"id":"id0d84a2bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161k"},"text":"§ 1161k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot programs to increase college persistence and success","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d84a2bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amounts appropriated under subsection (i), the Secretary is authorized to award grants in accordance with this section, on a competitive basis, to eligible institutions to enable the institutions to develop programs to increase the persistence and success of low-income college students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a2be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a2bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible institution seeking a grant under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require. An eligible institution may submit an application to receive a grant under subsection (c) or (d) or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a2c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation condition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible institution seeking a grant under this section shall agree to participate in the evaluation described in subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a2c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for replication of evidence-based policies and practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants for the program under subsection (d), the Secretary shall give priority to applications submitted by eligible institutions that propose to replicate policies and practices that have proven effective in increasing persistence and degree completion by low-income students or students in need of developmental education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a2c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program to increase persistence and success in community colleges","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a2c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a2c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible institution” means an institution of higher education, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":", that provides a one- or two-year program of study leading to a degree or certificate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a2c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible student","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible student” means a student who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d84a2c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible to receive assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"section 1070a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a2c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled at least half-time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a2c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not younger than age 19;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a2c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the parent of at least one dependent child, which dependent child is age 18 or younger;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a2ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a secondary school diploma or its recognized equivalent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a2cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not have a degree or certificate from an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a2cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a2cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants under this subsection to eligible institutions to enable such institutions to provide additional monetary and nonmonetary support to eligible students to enable the eligible students to maintain enrollment and complete degree or certificate programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a2ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each eligible institution receiving a grant under this subsection shall use the grant funds—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d84a2cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide scholarships in accordance with paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a2d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide counseling services in accordance with paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a2d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowable uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grant funds provided under this subsection may be used—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d84a2d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct outreach to make students aware of the scholarships and counseling services available under this subsection and to encourage the students to participate in the program assisted under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a2d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide incentives of $20 or less to applicants who complete the process of applying for assistance under this subsection, as compensation for the student’s time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a2d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarship requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a2d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each scholarship awarded under this subsection shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d84a2d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be awarded for one academic year consisting of two semesters or the equivalent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a2d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the student to maintain, during the scholarship period, at least half-time enrollment and at least a 2.0 grade point average or the equivalent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a2d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be awarded in the amount of $1,000 for each of two semesters (prorated for quarters or other equivalents), or $2,000 for an academic year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a2d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not exceed the student’s cost of attendance, as defined in section 1087","children":[{"tag":"i","attrib":{},"text":"ll","children":[],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a2da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be paid, for each of the two semesters, in increments of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d84a2db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/3/A/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250 upon enrollment (prorated for quarters or other equivalents);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d84a2dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/3/A/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250 upon passing midterm examinations or comparable assessments (prorated for quarters or other equivalents); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d84a2dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/3/A/v/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500 upon passing courses (prorated for quarters or other equivalents).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a2de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible institution may award an eligible student not more than two scholarships under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a2df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counseling services","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a2e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each eligible institution receiving a grant under this subsection shall use the grant funds to provide students at the institution with a counseling staff dedicated to students participating in the program under this subsection. Each such counselor shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d84a2e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a caseload of less than 125 students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a2e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use a proactive, team-oriented approach to counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a2e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold a minimum of two meetings with each student each semester; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d84a2e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide referrals to and follow-up with other student services staff, including financial aid and career services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a2e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counseling services availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The counseling services provided under this subsection shall be available to participating students during the daytime and evening hours.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a2e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student success grant pilot program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a2e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a2e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “eligible institution” means an institution of higher education in which, during the three-year period preceding the year in which the institution is applying for a grant under this subsection, an average of not less than 50 percent of the institution’s entering first-year students are assessed as needing developmental courses to bring reading, writing, or mathematics skills up to college level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8712e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible student","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “eligible student” means a student who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d8712ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible to receive assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"section 1070a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8712eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a first-year student at the time of entering the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8712ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is assessed as needing developmental education to bring reading, writing, or mathematics skills up to college level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8712ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is selected by an eligible institution to participate in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8712ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student success grant amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants under this subsection to eligible institutions in an amount equal to $1,500 multiplied by the number of students the institution selects to participate in the program in such year. An institution shall not select more than 200 students to participate in the program under this subsection during such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8712ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible institution that receives a grant under this subsection shall use the grant funds to assign a student success coach to each first-year student participating in the program to provide intensive career and academic advising, ongoing personal help in navigating college services (such as financial aid and registration), and assistance in connecting to community resources that can help students overcome family and personal challenges to success. Student success coaches—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8712f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall work with not more than 50 new students during any academic period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8712f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be employees of academic departments, student services offices, community-based organizations, or other entities as determined appropriate by the institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8712f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall meet with each eligible student selected for the program before registration for courses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8712f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowable uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible institution that receives a grant under this subsection may use the grant funds to provide services and program innovations for students participating in the program, including the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8712f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" College and career success courses provided at no charge to participating students. These courses may cover college success topics, including how to take notes, how to study, how to take tests, and how to budget time, and may also include a substantial career exploration component. Institutions may use such courses to help students develop a college and career success plan, so that by the end of the first semester the students have a clear sense of their career goals and what classes to take to achieve such goals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8712f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Work-study jobs with private employers in the students’ fields of study.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8712f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Learning communities that ensure that students participating in the program are clustered together for at least two courses beginning in the first semester after enrolling and have other opportunities to create and maintain bonds that allow them to provide academic and social support to each other.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8712f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Curricular redesign, which may include such innovations as blended or accelerated remediation classes that help student success grant recipients to attain college-level reading, writing, or math skills (or a combination thereof) more rapidly than traditional remediation formats allow, and intensive skills refresher classes, offered prior to each semester, to help students who have tested into remedial coursework to reach entry level assessment scores for the postsecondary programs they wish to enter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8712f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Instructional support, such as learning labs, supplemental instruction, and tutoring.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8712f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance with support services, such as child care and transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8712fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each institution participating in the program under this subsection shall provide a non-Federal share of 25 percent of the amount of the grant to carry out the activities of the program. The non-Federal share under this subsection may be provided in cash or in kind.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8712fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award a grant under subsection (c) or (d) of this section for a period of five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8712fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8712fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contractor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the funds appropriated under this section, the Secretary shall enter into a contract with one or more private, nonprofit entities to provide technical assistance to grantees and to conduct the evaluations required under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8712fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The evaluations required under paragraph (3) shall be conducted by entities that are capable of designing and carrying out independent evaluations that identify the impact of the activities carried out by eligible institutions under this section on improving persistence and success of student participants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8712ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of evaluations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct an evaluation of the impact of the persistence and success grant programs as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d871300-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program to increase persistence in community colleges","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The evaluation of the program under subsection (c) shall be conducted using a random assignment research design with the following requirements:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d871301-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/f/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When students are recruited for the program, all students will be told about the program and the evaluation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d871302-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/f/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Baseline data will be collected from all applicants for assistance under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d871303-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/f/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Students will be assigned randomly to two groups, which will consist of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d871304-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/f/3/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program group that will receive the scholarship and the additional counseling services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d871305-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/f/3/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a control group that will receive whatever regular financial aid and counseling services are available to all students at the institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d871306-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student success grant program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Eligible institutions receiving a grant to carry out the program under subsection (d) shall work with the evaluator to track persistence and completion outcomes for students in such program, specifically the proportion of these students who take and complete developmental education courses, the proportion who take and complete college-level coursework, and the proportion who complete certificates and degrees. The data shall be broken down by gender, race, ethnicity, and age and the evaluator shall assist institutions in analyzing these data to compare program participants to comparable nonparticipants, using statistical techniques to control for differences in the groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d871307-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d871308-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a report to the authorizing committees that includes the evaluation and information on best practices and lessons learned during the pilot programs described in this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871309-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate the report to the public by making the report available on the Department’s website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d87130a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under this section shall be used to supplement and not supplant other Federal, State, and local funds available to the institution to carrying out the activities described in subsections (c) and (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d87130b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161k/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years. The Secretary may use not more than two percent of the amounts appropriated to provide the technical assistance and conduct the evaluations required under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d87130c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s820"},"text":"Pub. L. 89–329, title VIII, § 820","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3404"},"text":"122 Stat. 3404","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tVIII/s801/5"},"text":"Pub. L. 111–39, title VIII, § 801(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1955"},"text":"123 Stat. 1955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d87130d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d87130e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d87130f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s801/5/A"},"text":"Pub. L. 111–39, § 801(5)(A)","children":[],"tail":", inserted “the” before “grant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s801/5/B"},"text":"Pub. L. 111–39, § 801(5)(B)","children":[],"tail":", substituted “section” for “subpart” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s801/5/C"},"text":"Pub. L. 111–39, § 801(5)(C)","children":[],"tail":", substituted “used” for “use”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d871310-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d871311-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/s3"},"text":"section 3 of Pub. L. 111–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
