{"tag":"section","attrib":{"id":"id0cddb31f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1067g"},"text":"§ 1067g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for grants","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Eligibility to receive grants under this part is limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cddb320-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" public and private nonprofit institutions of higher education that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cddb321-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award baccalaureate degrees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb322-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are minority institutions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cddb323-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" public or private nonprofit institutions of higher education that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cddb324-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award associate degrees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb325-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are minority institutions that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cddb326-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a curriculum that includes science or engineering subjects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cddb327-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into a partnership with public or private nonprofit institutions of higher education that award baccalaureate degrees in science and engineering;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cddb328-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" nonprofit science-oriented organizations, professional scientific societies, and institutions of higher education that award baccalaureate degrees, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cddb329-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a needed service to a group of minority institutions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb32a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide in-service training for project directors, scientists, and engineers from minority institutions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cddb32b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consortia of organizations, that provide needed services to one or more minority institutions, the membership of which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cddb32c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public and private nonprofit institutions of higher education which have a curriculum in science or engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb32d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education that have a graduate or professional program in science or engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb32e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research laboratories of, or under contract with, the Department of Energy, the Department of Defense, or the National Institutes of Health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb32f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant offices of the National Aeronautics and Space Administration, National Oceanic and Atmospheric Administration, National Science Foundation, and National Institute of Standards and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb330-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quasi-governmental entities that have a significant scientific or engineering mission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb331-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education that have State-sponsored centers for research in science, technology, engineering, and mathematics; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cddb332-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" only with respect to grants under subpart 2, partnerships of organizations, the membership of which shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cddb333-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one institution of higher education eligible for assistance under this subchapter or subchapter V;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb334-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one high-need local educational agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1021"},"text":"section 1021 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cddb335-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067g/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least two community organizations or entities, such as businesses, professional associations, community-based organizations, philanthropic organizations, or State agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cddb336-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s361"},"text":"Pub. L. 89–329, title III, § 361","children":[],"tail":", formerly title X, § 1041, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tX/s1002"},"text":"Pub. L. 99–498, title X, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1564"},"text":"100 Stat. 1564","children":[],"tail":"; renumbered title III, § 361, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIII"},"text":"Pub. L. 105–244, title III","children":[],"tail":", §§ 301(a)(5), (7), (b), (c)(9), 307(b), "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1636"},"text":"112 Stat. 1636","children":[],"tail":", 1637, 1648; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIII/s315/b"},"text":"Pub. L. 110–315, title III, § 315(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3184"},"text":"122 Stat. 3184","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cddb337-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cddb338-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0cddb339-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1135d"},"text":"section 1135d of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cddb33a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Par. (3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s315/b/1"},"text":"Pub. L. 110–315, § 315(b)(1)","children":[],"tail":", struck out “or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s315/b/2/A"},"text":"Pub. L. 110–315, § 315(b)(2)(A)","children":[],"tail":", substituted “public and private nonprofit institutions of higher education” for “institutions of higher education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s315/b/2/B"},"text":"Pub. L. 110–315, § 315(b)(2)(B)","children":[],"tail":", inserted “, the Department of Defense, or the National Institutes of Health” before the semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s315/b/2/C"},"text":"Pub. L. 110–315, § 315(b)(2)(C)","children":[],"tail":", added subpar. (D) and struck out former subpar. (D) which read as follows: “private organizations that have science or engineering facilities; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s315/b/2/D"},"text":"Pub. L. 110–315, § 315(b)(2)(D)","children":[],"tail":", (E), added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s315/b/3"},"text":"Pub. L. 110–315, § 315(b)(3)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s307/b"},"text":"Pub. L. 105–244, § 307(b)","children":[],"tail":", amended section catchline and text generally. Prior to amendment, text read as follows: “Eligibility to receive grants under this part is limited to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) public and private nonprofit institutions that are minority institutions (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067k/3"},"text":"section 1067k(3) of this title","children":[],"tail":"); and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) nonprofit science-oriented organizations, professional scientific societies, and all nonprofit, accredited colleges and universities which provide a needed service to a group of eligible minority institutions or which provide in-service training for project directors, scientists, and engineers from eligible minority institutions.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s301/c/9"},"text":"Pub. L. 105–244, § 301(c)(9)","children":[],"tail":", substituted “section 1067k(3)” for “section 1135d–5(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s301/b/1"},"text":"Pub. L. 105–244, § 301(b)(1)","children":[],"tail":", inserted “and” after the semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s301/b/2"},"text":"Pub. L. 105–244, § 301(b)(2)","children":[],"tail":", substituted a period for “; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/s301/b/3"},"text":"Pub. L. 105–244, § 301(b)(3)","children":[],"tail":", struck out par. (3) which read as follows: “for the purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1135c–1"},"text":"section 1135c–1 of this title","children":[],"tail":", public and private nonprofit institutions that have at least 10 percent minority enrollment.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cddb33b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cddb33c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
