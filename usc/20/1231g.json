{"tag":"section","attrib":{"id":"id0d92f951-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1231g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1231g"},"text":"§ 1231g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d92f952-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1231g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission and amendments of applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, unless expressly in limitation of the provisions of this section, the Secretary is authorized to provide for the submission of applications for assistance effective for more than one fiscal year under any applicable program with whatever amendments to such applications being required as the Secretary determines essential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d92f953-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1231g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform dates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, insofar as is practicable, establish uniform dates during the year for the submission of applications under all applicable programs and for the approval of such applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d92f954-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1231g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of common applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, insofar as is practicable, develop and require the use of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d92f955-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1231g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a common application for grants to local educational agencies in applicable programs administered by State educational agencies in which the funds are distributed to such local agencies pursuant to some objective formula, and such application shall be used as the single application for as many of these programs as is practicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d92f956-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1231g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a common application for grants to local educational agencies in applicable programs administered by State educational agencies in which the funds are distributed to such local agencies on a competitive or discretionary basis, and such application shall be used as the single application for as many of such programs as is practicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d92f957-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1231g/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a common application for grants to local educational agencies in applicable programs which are directly administered by the Secretary, and such application shall be used as the single application for as many of these programs as is practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d92f958-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s436"},"text":"Pub. L. 90–247, title IV, § 436","children":[],"tail":", formerly § 430, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXII/s1213"},"text":"Pub. L. 95–561, title XII, § 1213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2342"},"text":"92 Stat. 2342","children":[],"tail":"; renumbered § 436 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII"},"text":"Pub. L. 103–382, title II","children":[],"tail":", §§ 212(b)(1), 246, "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3913"},"text":"108 Stat. 3913","children":[],"tail":", 3923.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d92f959-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d92f95a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d92f95b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s436"},"text":"section 436 of Pub. L. 90–247","children":[],"tail":" was renumbered section 442, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232e"},"text":"section 1232e of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{