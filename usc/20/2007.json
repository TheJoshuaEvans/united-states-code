{"tag":"section","attrib":{"id":"id0db6ae6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2007"},"text":null,"children":[{"tag":"num","attrib":{"value":"2007"},"text":"§ 2007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stipends","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each student awarded a scholarship under this chapter shall receive a stipend which shall not exceed the cost to such student for tuition, fees, books, room and board, or $10,000 (adjusted annually to reflect increases, if any, in the Consumer Price Index for All Urban Consumers, published by the Bureau of Labor Statistics) whichever is less for each academic year of study.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0db6ae6c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/642/s8"},"text":"Pub. L. 93–642, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2278"},"text":"88 Stat. 2278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tV/s501"},"text":"Pub. L. 99–159, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/904"},"text":"99 Stat. 904","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db6ae6d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0db6ae6e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0db6ae6f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/159"},"text":"Pub. L. 99–159","children":[],"tail":" increased amount from $5,000 to $10,000 with provision for annual adjustments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
