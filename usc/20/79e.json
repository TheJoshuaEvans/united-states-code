{"tag":"section","attrib":{"id":"id0c83104d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s79e"},"text":null,"children":[{"tag":"num","attrib":{"value":"79e"},"text":"§ 79e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated annually, from money in the Treasury of the United States not otherwise appropriated, such sums as are necessary for the administration of this subchapter and for the maintenance of laboratory or other facilities provided for carrying out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c83104e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-07-02/ch516/s7"},"text":"July 2, 1940, ch. 516, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/725"},"text":"54 Stat. 725","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/280/s1"},"text":"Pub. L. 89–280, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-20"},"text":"Oct. 20, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1012"},"text":"79 Stat. 1012","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/89/s1"},"text":"Pub. L. 96–89, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-19"},"text":"Oct. 19, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/697"},"text":"93 Stat. 697","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/57/s1"},"text":"Pub. L. 98–57, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-07-22"},"text":"July 22, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/293"},"text":"97 Stat. 293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attr