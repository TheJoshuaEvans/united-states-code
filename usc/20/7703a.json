{"tag":"section","attrib":{"id":"id0e435e40-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7703a"},"text":"§ 7703a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impact aid for children with severe disabilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e435e41-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (f), the Secretary of Defense shall make a payment for fiscal years after fiscal year 2001, to each local educational agency eligible to receive a payment for a child described in subparagraph (A)(ii) or (B), or clause (i) or (ii) of subparagraph (D), of section 7703(a)(1) ","children":[{"tag":"ref","attrib":{"idref":"fn002228"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002228"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title that serves two or more such children with severe disabilities, for costs incurred in providing a free appropriate public education to each such child."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e435e42-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the payment under subsection (a) to a local educational agency for a fiscal year for each child referred to in such subsection with a severe disability shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e435e43-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment made on behalf of the child with a severe disability that is in excess of the average per pupil expenditure in the State in which the local educational agency is located; less","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e435e44-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of the funds received by the local educational agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e435e45-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the State in which the child resides to defray the educational and related services for such child;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e435e46-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the Individuals with Disabilities Education Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.) to defray the educational and related services for such child; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e435e47-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from any other source to defray the costs of providing educational and related services to the child which are received due to the presence of a severe disabling condition of such child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e435e48-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No payment shall be made under subsection (a) on behalf of a child with a severe disability whose individual cost of educational and related services does not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e435e49-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" five times the national or State average per pupil expenditure (whichever is lower), for a child who is provided educational and related services under a program that is located outside the boundaries of the school district of the local educational agency that pays for the free appropriate public education of the student; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e435e4a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three times the State average per pupil expenditure, for a child who is provided educational and related services under a program offered by the local educational agency, or within the boundaries of the school district served by the local educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e435e4b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratable reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount available for a fiscal year for payments under subsection (a) is insufficient to pay the full amount all local educational agencies are eligible to receive under such subsection, the Secretary of Defense shall ratably reduce the amounts of the payments made under such subsection to all local educational agencies by an equal percentage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e435e4c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each local educational agency desiring a payment under subsection (a) shall report to the Secretary of Defense—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e435e4d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of severely disabled children for which a payment may be made under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e435e4e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a breakdown of the average cost, by placement (inside or outside the boundaries of the school district of the local educational agency), of providing education and related services to such children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e435e4f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments subject to appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments shall be made for any period in a fiscal year under this section only to the extent that funds are appropriated specifically for making such payments for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e435e50-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7703a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local educational agency defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “local educational agency” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7713"},"text":"section 7713 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e435e51-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title III, § 363], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–77; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/kk"},"text":"Pub. L. 114–95, title IX, § 9215(kk)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2175"},"text":"129 Stat. 2175","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e435e52-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e435e53-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e435e54-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703/a/1"},"text":"Section 7703(a)(1) of this title","children":[],"tail":", referred to in subsec. (a), was in the original “section 7003(a)(1)” and was translated as meaning section 7003(a)(1) of the Elementary and Secondary Education Act of 1965, which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703/a/1"},"text":"section 7703(a)(1) of this title","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in subsec. (b)(2)(B), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":", which is classified generally to chapter 33 (§ 1400 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0e435e55-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Floyd D. Spence National Defense Authorization Act for Fiscal Year 2001, and not as part of the Elementary and Secondary Education Act of 1965 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e435e56-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9215/kk/1"},"text":"Pub. L. 114–95, § 9215(kk)(1)","children":[],"tail":", substituted “subparagraph (A)(ii) or (B), or clause (i) or (ii) of subparagraph (D), of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703/a/1"},"text":"section 7703(a)(1) of this title","children":[],"tail":"” for “subparagraph (A)(ii), (B), (D)(i) or (D)(ii) of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703/a/1"},"text":"section 7703(a)(1) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9215/kk/2"},"text":"Pub. L. 114–95, § 9215(kk)(2)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7713"},"text":"section 7713 of this title","children":[],"tail":".” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7713/9"},"text":"section 7713(9) of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e435e57-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e435e58-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
