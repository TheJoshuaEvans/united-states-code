{"tag":"section","attrib":{"id":"id0e350602-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7371"},"text":null,"children":[{"tag":"num","attrib":{"value":"7371"},"text":"§ 7371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against Federal mandates, direction, or control","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to authorize an officer or employee of the Federal Government to mandate, direct, or control a State, local educational agency, or school’s specific instructional content, academic standards and assessments, curriculum, or program of instruction, as a condition of eligibility to receive funds under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e350603-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5301"},"text":"Pub. L. 89–10, title V, § 5301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tV/s5004"},"text":"Pub. L. 114–95, title V, § 5004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2045"},"text":"129 Stat. 2045","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e350604-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e350605-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e350606-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail