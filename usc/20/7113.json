{"tag":"section","attrib":{"id":"id0e2464b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113"},"text":null,"children":[{"tag":"num","attrib":{"value":"7113"},"text":"§ 7113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula grants to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e2464ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the total amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7122"},"text":"section 7122 of this title","children":[],"tail":" for a fiscal year, the Secretary shall reserve—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2464bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-half of 1 percent for allotments for payments to the outlying areas, to be distributed among those outlying areas on the basis of their relative need, as determined by the Secretary, in accordance with the purpose of this subpart;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2464bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-half of 1 percent for the Secretary of the Interior for programs under this subpart in schools operated or funded by the Bureau of Indian Education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2464bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 percent for technical assistance and capacity building.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2464be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State allotments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2464bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2464c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraphs (B) and (C), from the amount appropriated to carry out this subpart that remains after the Secretary makes the reservations under subsection (a), the Secretary shall allot to each State having a plan approved under subsection (c), an amount that bears the same relationship to the remainder as the amount the State received under subpart 2 of part A of subchapter I for the preceding fiscal year bears to the amount all States received under that subpart for the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2464c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small State minimum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State receiving an allotment under this paragraph shall receive less than one-half of 1 percent of the total amount allotted under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2464c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Puerto Rico","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount allotted under this paragraph to the Commonwealth of Puerto Rico for a fiscal year may not exceed one-half of 1 percent of the total amount allotted under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2464c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State does not receive an allotment under this subpart for a fiscal year, the Secretary shall reallot the amount of the State’s allotment to the remaining States in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2464c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2464c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to receive an allotment under this section for any fiscal year, a State shall submit a plan to the Secretary, at such time and in such manner as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2464c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each plan submitted by a State under this section shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2464c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of how the State educational agency will use funds received under this subpart for State-level activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2464c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of how the State educational agency will ensure that awards made to local educational agencies under this subpart are in amounts that are consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7115/a/2"},"text":"section 7115(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2464c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Assurances that the State educational agency will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e2464ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review existing resources and programs across the State and will coordinate any new plans and resources under this subpart with such existing resources and programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2464cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the implementation of activities under this subpart and provide technical assistance to local educational agencies in carrying out such activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e2464cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7113/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for equitable access for all students to the activities supported under this subpart, including aligning those activities with the requirements of other Federal laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e2464cd-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4103"},"text":"Pub. L. 89–10, title IV, § 4103","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4101"},"text":"Pub. L. 114–95, title IV, § 4101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1970"},"text":"129 Stat. 1970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e2464ce-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e2464cf-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e2464d0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7113, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4113"},"text":"Pub. L. 89–10, title IV, § 4113","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIV/s401"},"text":"Pub. L. 107–110, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1739"},"text":"115 Stat. 1739","children":[],"tail":", related to State application to receive allotment, prior to the general amendment of this subpart by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 7113, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4113"},"text":"Pub. L. 89–10, title IV, § 4113","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3677"},"text":"108 Stat. 3677","children":[],"tail":", related to State and local educational agency programs, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s4103"},"text":"section 4103 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3063"},"text":"section 3063 of this title","children":[],"tail":", prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e2464d1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e2464d2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"ta