{"tag":"section","attrib":{"id":"id0e70af74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10013"},"text":null,"children":[{"tag":"num","attrib":{"value":"10013"},"text":"§ 10013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this chapter, as used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e70af75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10013/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “elementary education” and “secondary education” have the meaning given such terms under State law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e70af76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10013/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “high-need local educational agency” means a local educational agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e70af77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10013/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that serves not fewer than 10,000 children from families with incomes below the poverty line; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e70af78-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10013/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which not less than 20 percent of the children served by the agency are from families with incomes below the poverty line;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e70af79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10013/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “institution of higher education” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e70af7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10013/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e70af7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10013/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means each of the 50 States, the District of Columbia, and the Commonwealth of Puerto Rico; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e70af7c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s10013/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other term used that is defined in section 7801 ","children":[{"tag":"ref","attrib":{"idref":"fn002264"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002264"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title shall have the meaning given the term in such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e70af7d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIV/s14013"},"text":"Pub. L. 111–5, div. A, title XIV, § 14013","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/286"},"text":"123 Stat. 286","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e70af7e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e70af7f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e70af80-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"Section 7801 of this title","children":[],"tail":", referred to in par. (6), was in the original a reference to "},{"tag":"ref","attrib":{"href":"/us/pl/89/10/s9101"},"text":"section 9101 of Pub. L. 89–10","children":[],"tail":", which was renumbered section 8101 by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII/s8001/a/1"},"text":"Pub. L. 114–95, title VIII, § 8001(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2089"},"text":"129 Stat. 2089","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
