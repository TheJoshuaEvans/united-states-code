{"tag":"section","attrib":{"id":"id0ca93646-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s953"},"text":null,"children":[{"tag":"num","attrib":{"value":"953"},"text":"§ 953.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Foundation on the Arts and the Humanities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ca93647-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s953/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a National Foundation on the Arts and the Humanities (hereinafter referred to as the “Foundation”), which shall be composed of a National Endowment for the Arts, a National Endowment for the Humanities, a Federal Council on the Arts and the Humanities, and an Institute of Museum and Library Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ca93648-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s953/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the Foundation shall be to develop and promote a broadly conceived national policy of support for the humanities and the arts in the United States, and for institutions which preserve the cultural heritage of the United States pursuant to this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ca93649-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s953/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against Federal supervision over policy determination, personnel, or curriculum, or administration or operation of any school or other non-Federal body","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the administration of this subchapter no department, agency, officer, or employee of the United States shall exercise any direction, supervision, or control over the policy determination, personnel, or curriculum, or the administration or operation of any school or other non-Federal agency, institution, organization, or association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ca9364a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/209/s4"},"text":"Pub. L. 89–209, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-29"},"text":"Sept. 29, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/846"},"text":"79 Stat. 846","children":[],"tail":"; renumbered title I, § 4, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/306"},"text":"Pub. L. 98–306","children":[],"tail":", §§ 2, 4, "},{"tag":"date","attrib":{"date":"1984-05-31"},"text":"May 31, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/223"},"text":"98 Stat. 223","children":[],"tail":"; renumbered § 4 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/194/tI"},"text":"Pub. L. 99–194, title I","children":[],"tail":", §§ 101(1), 104, "},{"tag":"date","attrib":{"date":"1985-12-20"},"text":"Dec. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1332"},"text":"99 Stat. 1332","children":[],"tail":", 1333; "},{"tag":"ref","attrib":{"href":"/us/pl/111/340/tII/s208/1"},"text":"Pub. L. 111–340, title II, § 208(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3602"},"text":"124 Stat. 3602","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ca9364b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ca9364c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ca9364d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/340"},"text":"Pub. L. 111–340","children":[],"tail":" substituted “Institute of Museum and Library Services” for “Institute of Museum Services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/194/s104"},"text":"Pub. L. 99–194, § 104","children":[],"tail":", struck out a second comma after “a National Endowment for the Humanities” and “(hereinafter established)” after “Institute of Museum Services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/306/s4/a"},"text":"Pub. L. 98–306, § 4(a)","children":[],"tail":", substituted “, a Federal Council” for “and a Federal Council” and inserted “, and an Institute of Museum Services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/306/s4/b"},"text":"Pub. L. 98–306, § 4(b)","children":[],"tail":", inserted “, and for institutions which preserve the cultural heritage of the United States”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
