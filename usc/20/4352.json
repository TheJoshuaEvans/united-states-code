{"tag":"section","attrib":{"id":"id0de8bae8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4352"},"text":null,"children":[{"tag":"num","attrib":{"value":"4352"},"text":"§ 4352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The University and NTID are authorized to receive by gift, devise, bequest, purchase, or otherwise, property, both real and personal, for the use of the University or NTID, or for the use, as appropriate, for any programs, departments, or other units as may be designated in the conveyance or will, and to hold, invest, use, or dispose of such property for the purpose stated in the conveyance or will.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0de8bae9-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/371/tII/s202"},"text":"Pub. L. 99–371, title II, § 202","children":[],"tail":", formerly title IV, § 402, "},{"tag":"date","attrib":{"date":"1986-08-04"},"text":"Aug. 4, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/789"},"text":"100 Stat. 789","children":[],"tail":"; renumbered title II, § 202, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/421/tI"},"text":"Pub. L. 102–421, title I","children":[],"tail":", §§ 101(b)(5), (6), 132, "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2151"},"text":"106 Stat. 2151","children":[],"tail":", 2156.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de8baea-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de8baeb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0de8baec-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/371/s202"},"text":"section 202 of Pub. L. 99–371","children":[],"tail":" was renumbered section 112 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4332"},"text":"section 4332 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to subsec. (a) of this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s691c"},"text":"section 691c of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/371"},"text":"Pub. L. 99–371","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0de8baed-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/421/s132"},"text":"Pub. L. 102–421, § 132","children":[],"tail":", amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Gallaudet University","children":[],"tail":".—Gallaudet University is authorized to receive by gift, devise, bequest, purchase, or otherwise, property, both real and personal, for the use of Gallaudet University, or for the use of any of its departments or other units as may be designated in the conveyance or will, and to hold, invest, use, or dispose of such property for the purpose stated in the conveyance or will."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"National Technical Institute for the Deaf","children":[],"tail":".—The National Technical Institute for the Deaf is authorized to receive by gift, devise, bequest, purchase, or otherwise, property, both real and personal, for the use of the Institute, or for the use of any of its programs as may be designated in the conveyance or will, and to hold, invest, use, or dispose of such property for the purpose stated in the conveyance or will.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0de8baee-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0de8baef-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/421"},"text":"Pub. L. 102–421","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/421/s161"},"text":"section 161 of Pub. L. 102–421","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
