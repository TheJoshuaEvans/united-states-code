{"tag":"section","attrib":{"id":"id0e4cfb3e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7823"},"text":null,"children":[{"tag":"num","attrib":{"value":"7823"},"text":"§ 7823.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation of funds for local administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e4cfb3f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7823/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with regulations of the Secretary and for any fiscal year, a local educational agency, with the approval of its State educational agency, may consolidate and use for the administration of one or more programs under this chapter (or such other programs as the Secretary shall designate) not more than the percentage, established in each program, of the total available for the local educational agency under those programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4cfb40-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7823/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State educational agency shall, in collaboration with local educational agencies in the State, establish procedures for responding to requests from local educational agencies to consolidate administrative funds under subsection (a) and for establishing limitations on the amount of funds under those programs that may be used for administration on a consolidated basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4cfb41-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7823/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency that consolidates administrative funds under this section for any fiscal year shall not use any other funds under the programs included in the consolidation for administration for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4cfb42-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7823/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of administrative funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e4cfb43-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7823/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency that consolidates administrative funds under this section may use the consolidated funds for the administration of the programs and for uses, at the school district and school levels, comparable to those described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7821/b/2"},"text":"section 7821(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4cfb44-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7823/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal support teams","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency that uses funds as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7821/b/2/I"},"text":"section 7821(b)(2)(I) of this title","children":[],"tail":" may contribute State or local funds to expand the reach of such support without violating any supplement, not supplant requirement of any program contributing administrative funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4cfb45-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7823/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency that consolidates administrative funds under this section shall not be required to keep separate records, by individual program, to account for costs relating to the administration of the programs included in the consolidation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e4cfb46-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8203"},"text":"Pub. L. 89–10, title VIII, § 8203","children":[],"tail":", formerly title IX, § 9203, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1967"},"text":"115 Stat. 1967","children":[],"tail":"; renumbered title VIII, § 8203, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII"},"text":"Pub. L. 114–95, title VIII","children":[],"tail":", §§ 8001(a)(2), 8006, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089, 2100.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e4cfb47-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e4cfb48-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e4cfb49-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8006/1"},"text":"Pub. L. 114–95, § 8006(1)","children":[],"tail":", substituted “A State” for “Within 1 year after "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", a State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8006/2"},"text":"Pub. L. 114–95, § 8006(2)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d). Prior to amendment, text read as follows: “A local educational agency that consolidates administrative funds under this section may use the consolidated funds for the administration of the programs and for uses, at the school district and school levels, comparable to those described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7821/b/2"},"text":"section 7821(b)(2) of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e4cfb4a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e4cfb4b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
