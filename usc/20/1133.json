{"tag":"section","attrib":{"id":"id0d7400bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1133"},"text":null,"children":[{"tag":"num","attrib":{"value":"1133"},"text":"§ 1133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7400be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1133/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to authorize national graduate fellowship programs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7400bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1133/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in order to attract students of superior ability and achievement, exceptional promise, and demonstrated financial need, into high-quality graduate programs and provide the students with the financial support necessary to complete advanced degrees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7400c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1133/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that are designed to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d7649b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1133/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sustain and enhance the capacity for graduate education in areas of national need, including those areas critical to United States national and homeland security needs, such as science, technology, engineering, and mathematics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7649b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1133/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage talented students to pursue scholarly careers in the humanities, social sciences, and the arts; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7649b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1133/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote postsecondary programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d7649b4-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s700"},"text":"Pub. L. 89–329, title VII, § 700","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVII/s701"},"text":"Pub. L. 105–244, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1786"},"text":"112 Stat. 1786","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s701"},"text":"Pub. L. 110–315, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3345"},"text":"122 Stat. 3345","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d7649b5-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d7649b6-3a70-11f1-a648-bee82ed8a795"},"text"