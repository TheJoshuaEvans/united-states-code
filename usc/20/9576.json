{"tag":"section","attrib":{"id":"id0e67391d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9576"},"text":null,"children":[{"tag":"num","attrib":{"value":"9576"},"text":"§ 9576.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to publish","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e67391e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9576/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may prepare and publish (including through oral presentation) such research, statistics (consistent with part C), and evaluation information and reports from any office, board, committee, and center of the Institute, as needed to carry out the priorities and mission of the Institute without the approval of the Secretary or any other office of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e67391f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9576/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance copies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall provide the Secretary and other relevant offices with an advance copy of any information to be published under this section before publication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e673920-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9576/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All research, statistics, and evaluation reports conducted by, or supported through, the Institute shall be subjected to rigorous peer review before being published or otherwise made available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e673921-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9576/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Items not covered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in subsections ","children":[{"tag":"ref","attrib":{"idref":"fn002249"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002249"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":" (a), (b), or (c) shall be construed to apply to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e673922-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9576/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on current or proposed budgets, appropriations, or legislation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e673923-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9576/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information prohibited from disclosure by law or the Constitution, classified national security information, or information described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e673924-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9576/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review by officers of the United States in order to prevent the unauthorized disclosure of information described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e673925-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s186"},"text":"Pub. L. 107–279, title I, § 186","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1973"},"text":"116 Stat. 1973","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
