{"tag":"section","attrib":{"id":"id0ce7501e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070a–14"},"text":"§ 1070a–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student support services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ce7501f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a program to be known as student support services which shall be designed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce75020-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase college retention and graduation rates for eligible students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75021-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the transfer rates of eligible students from 2-year to 4-year institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75022-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to foster an institutional climate supportive of the success of students who are limited English proficient, students from groups that are traditionally underrepresented in postsecondary education, students with disabilities, students who are homeless children and youths (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11434a"},"text":"section 11434a of title 42","children":[],"tail":"), students who are in foster care or are aging out of the foster care system, or other disconnected students; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75023-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to improve the financial literacy and economic literacy of students, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce75024-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic personal income, household money management, and financial planning skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce75025-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic economic decisionmaking skills.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce75026-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project assisted under this section shall provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce75027-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic tutoring, directly or through other services provided by the institution, to enable students to complete postsecondary courses, which may include instruction in reading, writing, study skills, mathematics, science, and other subjects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75028-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advice and assistance in postsecondary course selection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75029-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce7502a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on both the full range of Federal student financial aid programs and benefits (including Federal Pell Grant awards and loan forgiveness) and resources for locating public and private scholarships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce7502b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in completing financial aid applications, including the Free Application for Federal Student Aid described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1090/a"},"text":"section 1090(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7502c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education or counseling services designed to improve the financial literacy and economic literacy of students, including financial planning for postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7502d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities designed to assist students participating in the project in applying for admission to, and obtaining financial assistance for enrollment in, graduate and professional programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7502e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities designed to assist students enrolled in two-year institutions of higher education in applying for admission to, and obtaining financial assistance for enrollment in, a four-year program of postsecondary education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce7502f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project assisted under this section may provide services such as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce75030-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individualized counseling for personal, career, and academic matters provided by assigned counselors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75031-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information, activities, and instruction designed to acquaint students participating in the project with the range of career options available to the students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75032-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exposure to cultural events and academic programs not usually available to disadvantaged students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75033-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mentoring programs involving faculty or upper class students, or a combination thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75034-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" securing temporary housing during breaks in the academic year for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce75035-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" students who are homeless children and youths (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11434a"},"text":"section 11434a of title 42","children":[],"tail":") or were formerly homeless children and youths; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce75036-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" students who are in foster care or are aging out of the foster care system; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75037-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs and activities as described in subsection (b) or paragraphs (1) through (4) of this subsection that are specially designed for students who are limited English proficient, students from groups that are traditionally underrepresented in postsecondary education, students with disabilities, students who are homeless children and youths (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11434a"},"text":"section 11434a of title 42","children":[],"tail":"), students who are in foster care or are aging out of the foster care system, or other disconnected students."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce75038-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce75039-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use for student aid","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient of a grant that undertakes any of the permissible services identified in subsection (c) may, in addition, use such funds to provide grant aid to students. A grant provided under this paragraph shall not exceed the Federal Pell Grant amount, determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a/b/2/A"},"text":"section 1070a(b)(2)(A) of this title","children":[],"tail":", for which a student is eligible, or be less than the minimum Federal Pell Grant amount described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a/b/4"},"text":"section 1070a(b)(4) of this title","children":[],"tail":", for the current academic year. In making grants to students under this subsection, an institution shall ensure that adequate consultation takes place between the student support service program office and the institution’s financial aid office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7503a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible students","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of receiving grant aid under this subsection, eligible students shall be current participants in the student support services program offered by the institution and be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce7503b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" students who are in their first 2 years of postsecondary education and who are receiving Federal Pell Grants under subpart 1 of part A; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce7503c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" students who have completed their first 2 years of postsecondary education and who are receiving Federal Pell Grants under subpart 1 if the institution demonstrates to the satisfaction of the Secretary that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0ce7503d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" these students are at high risk of dropping out; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ce7503e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it will first meet the needs of all its eligible first- and second-year students for services under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7503f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of need","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant provided to a student under paragraph (1) shall not be considered in determining that student’s need for grant or work assistance under this subchapter, except that in no case shall the total amount of student financial assistance awarded to a student under this subchapter exceed that student’s cost of attendance, as defined in section 1087","children":[{"tag":"i","attrib":{},"text":"ll","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75040-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient of a grant who uses such funds for the purpose described in paragraph (1) shall match the funds used for such purpose, in cash, from non-Federal funds, in an amount that is not less than 33 percent of the total amount of funds used for that purpose. This paragraph shall not apply to any grant recipient that is an institution of higher education eligible to receive funds under part A or B of subchapter III or subchapter V.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75041-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In no event may a recipient use more than 20 percent of the funds received under this section for grant aid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75042-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement, not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds received by a grant recipient that are used under this subsection shall be used to supplement, and not supplant, non-Federal funds expended for student support services programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce75043-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for approval of applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In approving applications for projects under this section for any fiscal year, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce75044-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require an assurance that not less than two-thirds of the persons participating in the project proposed to be carried out under any application—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce75045-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be individuals with disabilities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce75046-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be low-income individuals who are first generation college students;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75047-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require an assurance that the remaining students participating in the project proposed to be carried out under any application be low-income individuals, first generation college students, or individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75048-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require an assurance that not less than one-third of the individuals with disabilities participating in the project be low-income individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce75049-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that there be a determination by the institution, with respect to each participant in such project, that the participant has a need for academic support in order to pursue successfully a program of education beyond secondary school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7504a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that such participants be enrolled or accepted for enrollment at the institution which is the recipient of the grant or contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce7504b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider, in addition to such other criteria as the Secretary may prescribe, the institution’s effort, and where applicable past history, in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce7504c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/e/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing sufficient financial assistance to meet the full financial need of each student in the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce7504d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–14/e/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining the loan burden of each such student at a manageable level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ce7504e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s402D"},"text":"Pub. L. 89–329, title IV, § 402D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s402/a/4"},"text":"Pub. L. 102–325, title IV, § 402(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/488"},"text":"106 Stat. 488","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/b/11"},"text":"Pub. L. 103–208, § 2(b)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2459"},"text":"107 Stat. 2459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s402/d"},"text":"Pub. L. 105–244, title IV, § 402(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1655"},"text":"112 Stat. 1655","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/1/tIII/s317/a"},"text":"Pub. L. 106–554, § 1(a)(1) [title III, § 317(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–48; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s403/d"},"text":"Pub. L. 110–315, title IV, § 403(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3201"},"text":"122 Stat. 3201","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/152/tII/s2101/b/2"},"text":"Pub. L. 111–152, title II, § 2101(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-30"},"text":"Mar. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1073"},"text":"124 Stat. 1073","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ce7504f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ce75050-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ce75051-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152"},"text":"Pub. L. 111–152","children":[],"tail":" substituted “exceed the Federal Pell Grant amount, determined under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a/b/2/A"},"text":"section 1070a(b)(2)(A) of this title","children":[],"tail":", for which a student is eligible, or be less than the minimum Federal Pell Grant amount described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a/b/4"},"text":"section 1070a(b)(4) of this title","children":[],"tail":", for” for “exceed the maximum appropriated Pell Grant or, be less than the minimum appropriated Pell Grant, for”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/d/1"},"text":"Pub. L. 110–315, § 403(d)(1)","children":[],"tail":", added pars. (3) and (4) and struck out former par. (3) which read as follows: “to foster an institutional climate supportive of the success of low-income and first generation college students and individuals with disabilities.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/d/3"},"text":"Pub. L. 110–315, § 403(d)(3)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which related to permissible services."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/d/2"},"text":"Pub. L. 110–315, § 403(d)(2)","children":[],"tail":", (3), added subsec. (c) and redesignated former subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/d/4"},"text":"Pub. L. 110–315, § 403(d)(4)","children":[],"tail":", substituted “subsection (c)” for “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s403/d/2"},"text":"Pub. L. 110–315, § 403(d)(2)","children":[],"tail":", (5), redesignated subsec. (d) as (e) and substituted “projects under this section” for “student support services projects under this division” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" amended par. (6) generally. Prior to amendment, par. (6) read as follows: “require an assurance from the institution which is the recipient of the grant or contract that each student enrolled in the project will be offered sufficient financial assistance to meet that student’s full financial need.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" struck out “either” after “application”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ce75052-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":