{"tag":"section","attrib":{"id":"id0dda8ab4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3482"},"text":null,"children":[{"tag":"num","attrib":{"value":"3482"},"text":"§ 3482.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical advice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dda8ab5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3482/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized, upon request, to provide advice, counsel, and technical assistance to applicants or potential applicants for grants and contracts and other interested persons with respect to any functions of the Secretary or the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dda8ab6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3482/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation of applications for grants and contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may permit the consolidation of applications for grants or contracts with respect to two or more functions of the Secretary or the Department, but such consolidation shall not alter the statutory criteria for approval of applications for funding with respect to such functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dda8ab7-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIV/s422"},"text":"Pub. L. 96–88, title IV, § 422","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/687"},"text":"93 Stat. 687","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
