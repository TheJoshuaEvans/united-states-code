{"tag":"section","attrib":{"id":"id0de40104-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4073"},"text":null,"children":[{"tag":"num","attrib":{"value":"4073"},"text":"§ 4073.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Severability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this subchapter or the application thereof to any person or circumstances is judicially determined to be invalid, the provisions of the remainder of the subchapter and the application to other persons or circumstances shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0de40105-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tVIII/s804"},"text":"Pub. L. 98–377, title VIII, § 804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1304"},"text":"98 Stat. 1304","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
