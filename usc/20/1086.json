{"tag":"section","attrib":{"id":"id0d1e17a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1086"},"text":null,"children":[{"tag":"num","attrib":{"value":"1086"},"text":"§ 1086.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d1e17a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1086/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible lender or guaranty agency that contracts with another entity to perform any of the lender’s or agency’s functions under this subchapter, or otherwise delegates the performance of such functions to such other entity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d1e17a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1086/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be relieved of the lender’s or agency’s duty to comply with the requirements of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d1e17aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1086/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall monitor the activities of such other entity for compliance with such requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d1e17ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1086/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A lender that holds a loan made under this part in the lender’s capacity as a trustee is responsible for complying with all statutory and regulatory requirements imposed on any other holder of a loan made under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d1e17ac-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s436"},"text":"Pub. L. 89–329, title IV, § 436","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s402/a"},"text":"Pub. L. 99–498, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1413"},"text":"100 Stat. 1413","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s430"},"text":"Pub. L. 105–244, title IV, § 430","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1709"},"text":"112 Stat. 1709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d1e17ad-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d1e17ae-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d1e17af-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1086, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s436"},"text":"Pub. L. 89–