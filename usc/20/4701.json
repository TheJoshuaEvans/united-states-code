{"tag":"section","attrib":{"id":"id0defe73f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4701"},"text":null,"children":[{"tag":"num","attrib":{"value":"4701"},"text":"§ 4701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0defe740-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Senator Barry Goldwater of the State of Arizona has served his country for 56 years as a soldier and statesman, including service in the United States Senate for a period of 30 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe741-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Senator Goldwater has a distinguished record as a Senator, including service as Chairman of the Select Committee on Intelligence of the Senate and as Chairman of the Committee on Armed Services of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe742-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Senator Goldwater has long maintained a special interest in the education of America’s youth, particularly in the fields of science and mathematics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0defe743-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4701/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It would, therefore, be a fitting tribute to the leadership, courage, and vision of Senator Goldwater to establish in his name a scholarship program to foster and encourage excellence in science and mathematics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0defe744-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIV/s1402"},"text":"Pub. L. 99–661, div. A, title XIV, § 1402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4008"},"text":"100 Stat. 4008","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0defe745-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0defe746-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id0defe747-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXIII/s6301"},"text":"Pub. L. 117–81, div. F, title LXIII, § 6301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2393"},"text":"135 Stat. 2393","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dF/tLXIII/s6301"},"text":"“This title [amending sections 4702, 4704 to 4707, and 4710 of this title] may be cited as the ‘Barry Goldwater Scholarship and Excellence in Education Modernization Act of 2021’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0defe748-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIV/s1401"},"text":"Pub. L. 99–661, div. A, title XIV, § 1401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4007"},"text":"100 Stat. 4007","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/661/dA/tXIV/s1401"},"text":"“This title [enacting this chapter] may be cited as the ‘Barry Goldwater Scholarship and Excellence in Education Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
