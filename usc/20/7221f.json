{"tag":"section","attrib":{"id":"id0e2b9044-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7221f"},"text":null,"children":[{"tag":"num","attrib":{"value":"7221f"},"text":"§ 7221f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of input from charter school operators","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To the extent practicable, the Secretary shall ensure that administrators, teachers, and other individuals directly involved in the operation of charter schools are consulted in the development of any rules or regulations required to implement this subpart, as well as in the development of any rules or regulations relevant to charter schools that are required to implement part A of subchapter I, the Individuals with Disabilities Education Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.], or any other program administered by the Secretary that provides education funds to charter schools or regulates the activities of charter schools."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e2b9045-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4307"},"text":"Pub. L. 89–10, title IV, § 4307","children":[],"tail":", formerly title V, § 5207, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1798"},"text":"115 Stat. 1798","children":[],"tail":"; renumbered title IV, § 4307, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4001/b/2/A"},"text":"Pub. L. 114–95, title IV, § 4001(b)(2)(A)","children":[],"tail":", (B), (D)(iii), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1967"},"text":"129 Stat. 1967","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e2b9046-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e2b9047-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e2b9048-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in text, is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":", which is classified generally to chapter 33 (§ 1400 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
