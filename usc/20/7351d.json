{"tag":"section","attrib":{"id":"id0e3505e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7351d"},"text":null,"children":[{"tag":"num","attrib":{"value":"7351d"},"text":"§ 7351d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Choice of participation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e3505e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7351d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a local educational agency is eligible for funding under both this subpart and subpart 1, such local educational agency may receive funds under either this subpart or subpart 1 for a fiscal year, but may not receive funds under both subparts for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3505e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7351d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency eligible for funding under both this subpart and subpart 1 shall notify the Secretary and the State educational agency under which of such subparts the local educational agency intends to receive funds for a fiscal year by a date that is established by the Secretary for the notification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e3505e3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5225"},"text":"Pub. L. 89–10, title V, § 5225","children":[],"tail":", as added "},{"tag":"ref","a