{"tag":"section","attrib":{"id":"id0e304b9f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292"},"text":null,"children":[{"tag":"num","attrib":{"value":"7292"},"text":"§ 7292.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for arts education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e304ba0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards to provide assistance for arts education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e304ba1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Awards made to eligible entities to fulfill the purpose described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7291/a/1"},"text":"section 7291(a)(1) of this title","children":[],"tail":", shall be used for a program (to be known as the “Assistance for Arts Education program”) to promote arts education for students, including disadvantaged students and students who are children with disabilities, through activities such as—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e304ba2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional development for arts educators, teachers, and principals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304ba3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and dissemination of accessible instructional materials and arts-based educational programming, including online resources, in multiple arts disciplines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304ba4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community and national outreach activities that strengthen and expand partnerships among schools, local educational agencies, communities, or centers for the arts, including national centers for the arts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304ba5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As conditions of receiving assistance made available under this section, the Secretary shall require each eligible entity receiving such assistance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e304ba6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate, to the extent practicable, each project or program carried out with such assistance with appropriate activities of public or private cultural agencies, institutions, and organizations, including museums, arts education associations, libraries, and theaters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304ba7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use such assistance only to supplement, and not to supplant, any other assistance or funds made available from non-Federal sources for the activities assisted under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304ba8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall consult with Federal agencies or institutions, arts educators (including professional arts education associations), and organizations representing the arts (including State and local arts agencies involved in arts education).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304ba9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall give priority to eligible entities that are eligible national nonprofit organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e304baa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e304bab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e304bac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency in which 20 percent or more of the students served by the local educational agency are from families with an income below the poverty line;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304bad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of such local educational agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304bae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State educational agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304baf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304bb0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a museum or cultural institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304bb1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Indian Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304bb2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/e/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an eligible national nonprofit organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304bb3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/e/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another private agency, institution, or organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e304bb4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible national nonprofit organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible national nonprofit organization” means an organization of national scope that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e304bb5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is supported by staff, which may include volunteers, or affiliates at the State and local levels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e304bb6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7292/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates effectiveness or high-quality plans for addressing arts education activities for disadvantaged students or students who are children with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e304bb7-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4642"},"text":"Pub. L. 89–10, title IV, § 4642","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4601"},"text":"Pub. L. 114–95, title IV, § 4601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2033"},"text":"129 Stat. 2033","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e304bb8-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e304bb9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e304bba-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
