{"tag":"section","attrib":{"id":"id0e0ee08e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361"},"text":null,"children":[{"tag":"num","attrib":{"value":"6361"},"text":"§ 6361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for State assessments and related activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e0ee08f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts made available in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6363"},"text":"section 6363 of this title","children":[],"tail":", the Secretary shall make grants to State educational agencies to enable the States to carry out 1 or more of the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0ee090-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To pay the costs of the development of the State assessments and standards adopted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b"},"text":"section 6311(b) of this title","children":[],"tail":", which may include the costs of working in voluntary partnerships with other States, at the sole discretion of each such State."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee091-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a State has developed the assessments adopted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b"},"text":"section 6311(b) of this title","children":[],"tail":", to administer those assessments or to carry out other assessment activities described in this part, such as the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0ee092-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ensuring the provision of appropriate accommodations available to English learners and children with disabilities to improve the rates of inclusion in regular assessments of such children, including professional development activities to improve the implementation of such accommodations in instructional practice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee093-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing challenging State academic standards and aligned assessments in academic subjects for which standards and assessments are not required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b"},"text":"section 6311(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee094-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing or improving assessments for English learners, including assessments of English language proficiency as required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2/G"},"text":"section 6311(b)(2)(G) of this title","children":[],"tail":" and academic assessments in languages other than English to meet the State’s obligations under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2/F"},"text":"section 6311(b)(2)(F) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee095-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ensuring the continued validity and reliability of State assessments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee096-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Refining State assessments to ensure their continued alignment with the challenging State academic standards and to improve the alignment of curricula and instructional materials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee097-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing or improving balanced assessment systems that include summative, interim, and formative assessments, including supporting local educational agencies in developing or improving such assessments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee098-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the discretion of the State, refining science assessments required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2"},"text":"section 6311(b)(2) of this title","children":[],"tail":" in order to integrate engineering design skills and practices into such assessments."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee099-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing or improving models to measure and assess student progress or student growth on State assessments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2"},"text":"section 6311(b)(2) of this title","children":[],"tail":" and other assessments not required under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2"},"text":"section 6311(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee09a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing or improving assessments for children with disabilities, including alternate assessments aligned to alternate academic achievement standards for students with the most significant cognitive disabilities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2/D"},"text":"section 6311(b)(2)(D) of this title","children":[],"tail":", and using the principles of universal design for learning."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee09b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Allowing for collaboration with institutions of higher education, other research institutions, or other organizations to improve the quality, validity, and reliability of State academic assessments beyond the requirements for such assessments described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2"},"text":"section 6311(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee09c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Measuring student academic achievement using multiple measures of student academic achievement from multiple sources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee09d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evaluating student academic achievement through the development of comprehensive academic assessment instruments (such as performance and technology-based academic assessments, computer adaptive assessments, projects, or extended performance task assessments) that emphasize the mastery of standards and aligned competencies in a competency-based education model.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee09e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Designing the report cards and reports under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/h"},"text":"section 6311(h) of this title","children":[],"tail":" in an easily accessible, user friendly-manner that cross-tabulates student information by any category the State determines appropriate, as long as such cross-tabulation—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0e0ee09f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a/2/M/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not reveal personally identifiable information about an individual student; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0ee0a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/a/2/M/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is derived from existing State and local reporting requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0ee0a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subsection (a)(2)(M) shall be construed as authorizing, requiring, or allowing any additional reporting requirements, data elements, or information to be reported to the Secretary unless such reporting, data, or information is explicitly authorized under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0ee0a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6361/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State educational agency receiving a grant under this section shall submit an annual report to the Secretary describing the State’s activities under the grant and the result of such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e0ee0a3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1201"},"text":"Pub. L. 89–10, title I, § 1201","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1201"},"text":"Pub. L. 114–95, title I, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1879"},"text":"129 Stat. 1879","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e0ee0a4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e0ee0a5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e0ee0a6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6361, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1201"},"text":"Pub. L. 89–10, title I, § 1201","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1535"},"text":"115 Stat. 1535","children":[],"tail":", stated purpose of former subpart 1 of this part, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 6361, ","children":[{"tag":"ref","attrib":{"href":"/us