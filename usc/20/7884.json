{"tag":"section","attrib":{"id":"id0e4f4591-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884"},"text":null,"children":[{"tag":"num","attrib":{"value":"7884"},"text":"§ 7884.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By-pass determination process","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e4f4592-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e4f4593-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4f4594-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written objections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not take any final action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7882"},"text":"section 7882 of this title","children":[],"tail":" until the State educational agency, local educational agency, educational service agency, consortium of those agencies, or entity affected by the action has had an opportunity, for not less than 45 days after receiving written notice thereof, to submit written objections and to appear before the Secretary to show cause why that action should not be taken."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4f4595-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior to reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pending final resolution of any investigation or complaint that could result in a determination under this section, the Secretary may withhold from the allocation of the affected State educational agency or local educational agency the amount estimated by the Secretary to be necessary to pay the cost of those services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4f4596-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition for review","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4f4597-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the affected agency, consortium, or entity is dissatisfied with the Secretary’s final action after a proceeding under paragraph (1), the agency, consortium, or entity may, within 60 days after notice of that action, file with the United States court of appeals for the circuit in which the State is located a petition for review of that action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4f4598-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A copy of the petition shall be forthwith transmitted by the clerk of the court to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4f4599-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, upon receipt of the copy of the petition, shall file in the court the record of the proceedings on which the Secretary based the action, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2112"},"text":"section 2112 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4f459a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings of fact","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4f459b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The findings of fact by the Secretary, if supported by substantial evidence, shall be conclusive, but the court, for good cause shown, may remand the case to the Secretary to take further evidence and the Secretary may then make new or modified findings of fact and may modify the Secretary’s previous action, and shall file in the court the record of the further proceedings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4f459c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New or modified findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any new or modified findings of fact shall likewise be conclusive if supported by substantial evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e4f459d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e4f459e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the filing of a petition, the court shall have jurisdiction to affirm the action of the Secretary or to set the action aside, in whole or in part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e4f459f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judgment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The judgment of the court shall be subject to review by the Supreme Court of the United States upon certiorari or certification as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1254"},"text":"section 1254 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4f45a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any determination by the Secretary under this section shall continue in effect until the Secretary determines, in consultation with that agency, consortium, or entity and representatives of the affected private school children, teachers, or other educational personnel, that there will no longer be any failure or inability on the part of the agency, consortium, or entity to meet the applicable requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7881"},"text":"section 7881 of this title","children":[],"tail":" or any other provision of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4f45a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment from State allotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When the Secretary arranges for services pursuant to this section, the Secretary shall, after consultation with the appropriate public and private school officials, pay the cost of those services, including the administrative costs of arranging for those services, from the appropriate allocation or allocations under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e4f45a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7884/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any by-pass determination by the Secretary under this chapter as in effect on the day preceding ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", shall remain in effect to the extent the Secretary determines that that determination is consistent with the purpose of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e4f45a3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8504"},"text":"Pub. L. 89–10, title VIII, § 8504","children":[],"tail":", formerly title IX, § 9504, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1978"},"text":"115 Stat. 1978","children":[],"tail":"; renumbered title VIII, § 8504, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII"},"text":"Pub. L. 114–95, title VIII","children":[],"tail":", §§ 8001(a)(5), (b)(4), 8018, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089, 2112.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e4f45a4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e4f45a5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e4f45a6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8018"},"text":"Pub. L. 114–95, § 8018","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7882"},"text":"section 7882 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8001/b/4"},"text":"Pub. L. 114–95, § 8001(b)(4)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7881"},"text":"section 7881 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e4f45a7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e4f45a8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
