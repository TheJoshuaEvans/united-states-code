{"tag":"section","attrib":{"id":"id0d14a262-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"1078–12"},"text":"§ 1078–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan repayment for civil legal assistance attorneys","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d14a263-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to encourage qualified individuals to enter and continue employment as civil legal assistance attorneys.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d14a264-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d14a265-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil legal assistance attorney","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “civil legal assistance attorney” means an attorney who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d14a266-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is a full-time employee of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d14a267-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization that provides legal assistance with respect to civil matters to low-income individuals without a fee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d14a268-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a protection and advocacy system or client assistance program that provides legal assistance with respect to civil matters and receives funding under—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d14a269-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subtitle C of title I of the Developmental Disabilities Assistance and Bill of Rights Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15041"},"text":"42 U.S.C. 15041","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d14a26a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 732 or 794e of title 29;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d14a26b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part A of title I of the Protection and Advocacy for Individuals with Mental Illness Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10801"},"text":"42 U.S.C. 10801","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d14a26c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/1/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3004"},"text":"section 3004 of title 29","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d14a26d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/1/A/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–21"},"text":"section 1320b–21 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d14a26e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/1/A/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–53"},"text":"section 300d–53 of title 42","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d14a26f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/1/A/ii/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21061"},"text":"section 21061 of title 52","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d14a270-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as such employee, provides civil legal assistance as described in subparagraph (A) on a full-time basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d14a271-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is continually licensed to practice law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d14a272-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student loan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d14a273-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), the term “student loan” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d14a274-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to clause (ii), a loan made, insured, or guaranteed under this part, part D, or part E; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d14a275-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a loan made under section 1078–3 or 1087e(g) of this title, to the extent that such loan was used to repay—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d14a276-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal Direct Stafford Loan, a Federal Direct Unsubsidized Stafford Loan, or a Federal Direct PLUS Loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d14a277-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan made under section 1078, 1078–2, or 1078–8 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d14a278-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan made under part E.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d14a279-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of parent plus loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “student loan” does not include any of the following loans:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d14a27a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A loan made to the parents of a dependent student under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078–2"},"text":"section 1078–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d14a27b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Federal Direct PLUS Loan made to the parents of a dependent student.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d14a27c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A loan made under section 1078–3 or 1087e(g) of this title, to the extent that such loan was used to repay—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d14a27d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan made to the parents of a dependent student under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078–2"},"text":"section 1078–2 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d14a27e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/b/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal Direct PLUS Loan made to the parents of a dependent student.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d14a27f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts appropriated under subsection (i) for a fiscal year, the Secretary shall carry out a program of assuming the obligation to repay a student loan, by direct payments on behalf of a borrower to the holder of such loan, in accordance with subsection (d), for any borrower who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d14a280-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed as a civil legal assistance attorney; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d14a281-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not in default on a loan for which the borrower seeks repayment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d14a282-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d14a283-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive repayment benefits under subsection (c), a borrower shall enter into a written agreement with the Secretary that specifies that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d14a284-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the borrower will remain employed as a civil legal assistance attorney for a required period of service of not less than three years, unless involuntarily separated from that employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d14a285-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the borrower is involuntarily separated from employment on account of misconduct, or voluntarily separates from employment, before the end of the period specified in the agreement, the borrower will repay the Secretary the amount of any benefits received by such employee under this agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d14a286-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the borrower is required to repay an amount to the Secretary under subparagraph (B) and fails to repay such amount, a sum equal to that amount shall be recoverable by the Federal Government from the employee by such methods as are provided by law for the recovery of amounts owed to the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d14a287-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may waive, in whole or in part, a right of recovery under this subsection if it is shown that recovery would be contrary to the public interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d14a288-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall make student loan payments under this section for the period of the agreement, subject to the availability of appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d14a289-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d14a28a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount repaid by, or recovered from, an individual under this subsection shall be credited to the appropriation account from which the amount involved was originally paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d14a28b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merger","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount credited under subparagraph (A) shall be merged with other sums in such account and shall be available for the same purposes and period, and subject to the same limitations, if any, as the sums with which the amount was merged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d14a28c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d14a28d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student loan payment amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Student loan repayments made by the Secretary under this section shall be made subject to such terms, limitations, or conditions as may be mutually agreed upon by the borrower and the Secretary in an agreement under paragraph (1), except that the amount paid by the Secretary under this section shall not exceed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d14a28e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $6,000 for any borrower in any calendar year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d14a28f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an aggregate total of $40,000 in the case of any borrower.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d14a290-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beginning of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall authorize the Secretary to pay any amount to reimburse a borrower for any repayments made by such borrower prior to the date on which the Secretary entered into an agreement with the borrower under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d14a291-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d14a292-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On completion of the required period of service under an agreement under subsection (d), the borrower and the Secretary may, subject to paragraph (2), enter into an additional agreement in accordance with subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d14a293-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An agreement entered into under paragraph (1) may require the borrower to remain employed as a civil legal assistance attorney for less than three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d14a294-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award basis; priority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d14a295-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary shall provide repayment benefits under this section on a first-come, first-served basis, and subject to the availability of appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d14a296-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall give priority in providing repayment benefits under this section in any fiscal year to a borrower who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d14a297-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has practiced law for five years or less and, for not less than 90 percent of the time in such practice, has served as a civil legal assistance attorney;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d14a298-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received repayment benefits under this section during the preceding fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d14a299-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed less than three years of the first required period of service specified for the borrower in an agreement entered into under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d14a29a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility for double benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No borrower may, for the same service, receive a reduction of loan obligations under both this section and section 1078–11 or 1087e(m) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d14a29b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to issue such regulations as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d14a29c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1078–12/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $10,000,000 for fiscal year 2009 and such sums as may be necessary for each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d14a29d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s428L"},"text":"Pub. L. 89–329, title IV, § 428L","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s431"},"text":"Pub. L. 110–315, title IV, § 431","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3242"},"text":"122 Stat. 3242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d14a29e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d14a29f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d14a2a0-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Developmental Disabilities Assistance and Bill of Rights Act of 2000, referred to in (b)(1)(A)(ii)(I), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402"},"text":"Pub. L. 106–402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1677"},"text":"114 Stat. 1677","children":[],"tail":". Subtitle C of title I of the Act is classified generally to part C (§ 15041 et seq.) of subchapter I of chapter 144 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15001"},"text":"section 15001 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Protection and Advocacy for Individuals with Mental Illness Act, referred to in subsec. (b)(1)(A)(ii)(III), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/319"},"text":"Pub. L. 99–319","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-23"},"text":"May 23, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/478"},"text":"100 Stat. 478","children":[],"tail":". Part A of title I of the Act is classified generally to part A (§ 10801 et seq.) of subchapter I of chapter 114 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10801"},"text":"section 10801 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
