{"tag":"section","attrib":{"id":"id0ca6ebf5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s931"},"text":null,"children":[{"tag":"num","attrib":{"value":"931"},"text":"§ 931.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations; issuance and contents","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall issue regulations to carry out this chapter. Such regulations shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ca6ebf6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s931/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe the educational goals and objectives of the defense dependents’ education system,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6ebf7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s931/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish standards for the development of curricula for the system and for the selection of instructional materials,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6ebf8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s931/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe professional standards for professional personnel employed in the system,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6ebf9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s931/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for arrangements between the Director and commanders of military installations for necessary logistic support for schools of the system located on military installations,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6ebfa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s931/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a recertification program for professional personnel employed in the system, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca6ebfb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s931/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for such other matters as may be necessary to ensure the efficient organization and operation of the defense dependents’ education system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ca6ebfc-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXIV/s1413"},"text":"Pub. L. 95–561, title XIV, § 1413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2372"},"text":"92 Stat. 2372","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIII/s354/6"},"text":"Pub. L. 106–65, div. A, title III, § 354(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/574"},"text":"113 Stat. 574","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ca6ebfd-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ca6ebfe-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ca6ebff-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “The Secretary” for “Not later than 180 days after "},{"tag":"date","attrib":{"date":"1979-07-01"},"text":"July 1, 1979","children":[],"tail":", the Secretary” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
