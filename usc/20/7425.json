{"tag":"section","attrib":{"id":"id0e3506ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425"},"text":null,"children":[{"tag":"num","attrib":{"value":"7425"},"text":"§ 7425.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized services and activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e3506bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each local educational agency that receives a grant under this subpart shall use the grant funds, in a manner consistent with the purpose specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7421"},"text":"section 7421 of this title","children":[],"tail":", for services and activities that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3506bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are designed to carry out the comprehensive program of the local educational agency for Indian students, and described in the application of the local educational agency submitted to the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7424/a"},"text":"section 7424(a) of this title","children":[],"tail":" solely for the services and activities described in such application;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3776bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are designed to be responsive to the language and cultural needs of the Indian students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3776be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplement and enrich the regular school program of such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3776bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Particular activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The services and activities referred to in subsection (a) may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3776c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities that support Native American language programs and Native American language restoration programs, which may be taught by traditional leaders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3776c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" culturally related activities that support the program described in the application submitted by the local educational agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3776c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early childhood and family programs that emphasize school readiness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3776c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrichment programs that focus on problem solving and cognitive skills development and directly support the attainment of challenging State academic standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3776c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrated educational services in combination with other programs that meet the needs of Indian children and their families, including programs that promote parental involvement in school activities and increase student achievement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3776c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" career preparation activities to enable Indian students to participate in programs such as the programs supported by the Carl D. Perkins Career and Technical Education Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2301"},"text":"20 U.S.C. 2301","children":[],"tail":" et seq.), including programs for mentoring and apprenticeship;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3776c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities to educate individuals so as to prevent violence, suicide, and substance abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3776c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of equipment, but only if the acquisition of the equipment is essential to achieve the purpose described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7421"},"text":"section 7421 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3776c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities that promote the incorporation of culturally responsive teaching and learning strategies into the educational program of the local educational agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3776c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family literacy services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3776ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities that recognize and support the unique cultural and educational needs of Indian children, and incorporate appropriately qualified tribal elders and seniors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3776cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dropout prevention strategies for Indian students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3776cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategies to meet the educational needs of at-risk Indian students in correctional facilities, including such strategies that support Indian students who are transitioning from such facilities to schools served by local educational agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3776cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schoolwide programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, a local educational agency may use funds made available to such agency under this subpart to support a schoolwide program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6314"},"text":"section 6314 of this title","children":[],"tail":" if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3776ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the committee established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7424/c/4"},"text":"section 7424(c)(4) of this title","children":[],"tail":" approves the use of the funds for the schoolwide program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3776cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the schoolwide program is consistent with the purpose described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7421"},"text":"section 7421 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3776d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local educational agency identifies in its application how the use of such funds in a schoolwide program will produce benefits to Indian students that would not be achieved if the funds were not used in a schoolwide program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3776d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 percent of the funds provided to a grantee under this subpart for any fiscal year may be used for administrative purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3776d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7425/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on the use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided to a grantee under this subpart may not be used for long-distance travel expenses for training activities that are available locally or regionally.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e3776d3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6115"},"text":"Pub. L. 89–10, title VI, § 6115","children":[],"tail":", formerly title VII, § 7115, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1912"},"text":"115 Stat. 1912","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s2/f/4"},"text":"Pub. L. 109–270, § 2(f)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/747"},"text":"120 Stat. 747","children":[],"tail":", renumbered title VI, § 6115, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI"},"text":"Pub. L. 114–95, title VI","children":[],"tail":", §§ 6001(a), (b)(1), (5), 6002(g), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":", 2052; "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/tIII/s302/2"},"text":"Pub. L. 115–224, title III, § 302(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-31"},"text":"July 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1623"},"text":"132 Stat. 1623","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e3776d4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e3776d5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e3776d6-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Carl D. Perkins Career and Technical Education Act of 2006, referred to in subsec. (b)(6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210"},"text":"Pub. L. 88–210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-12-18"},"text":"Dec. 18, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/403"},"text":"77 Stat. 403","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/683"},"text":"120 Stat. 683","children":[],"tail":", which is classified generally to chapter 44 (§ 2301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2301"},"text":"section 2301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e3776d7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7425, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVII/s7115"},"text":"Pub. L. 89–10, title VII, § 7115","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3722"},"text":"108 Stat. 3722","children":[],"tail":", related to systemwide improvement grants, prior to the general amendment of former subchapter VII of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e3776d8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/224"},"text":"Pub. L. 115–224","children":[],"tail":" substituted “mentoring” for “tech-prep education, mentoring,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6001/b/5/A/i"},"text":"Pub. L. 114–95, § 6001(b)(5)(A)(i)","children":[],"tail":", made technical amendment to reference in original act which appears in text of introductory provisions as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7421"},"text":"section 7421 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/g/1/A"},"text":"Pub. L. 114–95, § 6002(g)(1)(A)","children":[],"tail":", inserted “solely for the services and activities described in such application” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6001/b/5/A/ii"},"text":"Pub. L. 114–95, § 6001(b)(5)(A)(ii)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7424/a"},"text":"section 7424(a) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/g/1/B"},"text":"Pub. L. 114–95, § 6002(g)(1)(B)","children":[],"tail":", substituted “to be responsive to” for “with special regard for”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/g/2"},"text":"Pub. L. 114–95, § 6002(g)(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which related to particular authorized services and activities of local educational agencies receiving grant funds."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6001/b/5/B/i"},"text":"Pub. L. 114–95, § 6001(b)(5)(B)(i)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7424/c/4"},"text":"section 7424(c)(4) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6001/b/5/B/ii"},"text":"Pub. L. 114–95, § 6001(b)(5)(B)(ii)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7421"},"text":"section 7421 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/g/3"},"text":"Pub. L. 114–95, § 6002(g)(3)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/g/4"},"text":"Pub. L. 114–95, § 6002(g)(4)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/270"},"text":"Pub. L. 109–270","children":[],"tail":" substituted “Carl D. Perkins Career and Technical Education Act of 2006” for “Carl D. Perkins Vocational and Technical Education Act of 1998”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e3776d9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e3776da-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/224"},"text":"Pub. L. 115–224","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/s4"},"text":"section 4 of Pub. L. 115–224","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2301"},"text":"section 2301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e3776db-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
