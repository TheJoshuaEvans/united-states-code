{"tag":"section","attrib":{"id":"id0e0c961d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331"},"text":null,"children":[{"tag":"num","attrib":{"value":"6331"},"text":"§ 6331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for the outlying areas and the Secretary of the Interior","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e0c961e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (e), from the amount appropriated for payments to States for any fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6302/a"},"text":"section 6302(a) of this title","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0c961f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserve 0.4 percent to provide assistance to the outlying areas in accordance with subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c9620-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserve 0.7 percent to provide assistance to the Secretary of the Interior in accordance with subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0c9621-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to outlying areas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0c9622-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds reserved","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amount made available for any fiscal year under subsection (a)(1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0c9623-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first reserve $1,000,000 for the Republic of Palau, subject to such terms and conditions as the Secretary may establish, except that ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/134"},"text":"Public Law 95–134","children":[],"tail":", permitting the consolidation of grants, shall not apply; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c9624-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the remaining funds to award grants to the outlying areas in accordance with paragraphs (2) through (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c9625-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allocate the amount available under paragraph (1)(B) to the outlying areas in proportion to their relative numbers of children, aged 5 to 17, inclusive, from families below the poverty level, on the basis of the most recent satisfactory data available from the Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c9626-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hold-harmless amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, the amount made available to each outlying area under this subsection shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0c9627-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 95 percent of the amount made available for the preceding fiscal year if the number of children counted under paragraph (2) is not less than 30 percent of the total number of children aged 5 to 17 years, inclusive, in the outlying area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c9628-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 90 percent of the amount made available for the preceding fiscal year if the percentage described in subparagraph (A) is between 15 percent and 30 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c9629-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 85 percent of the amount made available for the preceding fiscal year if the percentage described in subparagraph (A) is below 15 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c962a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratable reductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount made available under paragraph (1)(B) for any fiscal year is insufficient to pay the full amounts that the outlying areas are eligible to receive under paragraphs (2) and (3) for that fiscal year, the Secretary shall ratably reduce those amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c962b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grant funds awarded under paragraph (1)(A) may be used only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0c962c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for programs described in this chapter, including teacher training, curriculum development, instructional materials, or general school improvement and reform; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c962d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide direct educational services that assist all students with meeting the challenging State academic standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0c962e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this section, the term “outlying area” means the United States Virgin Islands, Guam, American Samoa, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0c962f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment to the Secretary of the Interior","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0c9630-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount allotted for payments to the Secretary of the Interior under subsection (a)(2) for any fiscal year shall be used, in accordance with such criteria as the Secretary may establish, to meet the unique educational needs of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0c9631-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian children on reservations served by elementary schools and secondary schools for Indian children operated or supported by the Department of the Interior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c9632-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" out-of-State Indian children in elementary schools and secondary schools in local educational agencies under special contracts with the Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0c9633-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amount allotted for payments to the Secretary of the Interior under subsection (a)(2), the Secretary of the Interior shall make payments to local educational agencies, on such terms as the Secretary determines will best carry out the purposes of this part, with respect to out-of-State Indian children described in paragraph (1). The amount of such payment may not exceed, for each such child, the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0c9634-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40 percent of the average per-pupil expenditure in the State in which the agency is located; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0c9635-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 48 percent of such expenditure in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0c9636-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6331/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, by reason of the application of subsection (a) for any fiscal year, the total amount available for allocation to all States under this part would be less than the amount allocated to all States for fiscal year 2016 under this part, the Secretary shall provide assistance to the outlying areas and the Secretary of the Interior in accordance with this section, as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e0c9637-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1121"},"text":"Pub. L. 89–10, title I, § 1121","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1513"},"text":"115 Stat. 1513","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1014"},"text":"Pub. L. 114–95, title I, § 1014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1876"},"text":"129 Stat. 1876","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/42/dG/tII/s209/b/4/A"},"text":"Pub. L. 118–42, div. G, title II, § 209(b)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-09"},"text":"Mar. 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/443"},"text":"138 Stat. 443","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e0c9638-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e0c9639-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e0c963a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/134"},"text":"Public Law 95–134","children":[],"tail":", referred to in subsec. (b)(1)(A), is "},{"tag":"ref","attrib":{"href":"/us/pl/95/134"},"text":"Pub. L. 95–134","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-15"},"text":"Oct. 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1159"},"text":"91 Stat. 1159","children":[],"tail":". Provisions relating to consolidation of grants are contained in "},{"tag":"ref","attrib":{"href":"/us/pl/95/134/s501"},"text":"section 501 of Pub. L. 95–134","children":[],"tail":" which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1469a"},"text":"section 1469a of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e0c963b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6331, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1121"},"text":"Pub. L. 89–10, title I, § 1121","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3561"},"text":"108 Stat. 3561","children":[],"tail":", related to grants for outlying areas and the Secretary of the Interior, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e0c963c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42"},"text":"Pub. L. 118–42","children":[],"tail":" added subpar. (A) and struck out former subpar. (A) which read as follows: “first reserve $1,000,000 for the Republic of Palau, until Palau enters into an agreement for extension of United States educational assistance under the Compact of Free Association, and subject to such terms and conditions as the Secretary may establish, except that "},{"tag":"ref","attrib":{"href":"/us/pl/95/134"},"text":"Public Law 95–134","children":[],"tail":", permitting the consolidation of grants, shall not apply; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (d) relating to reservation of one percent of funds for assistance to outlying areas and the Secretary of the Interior, grants to outlying areas, definitions, and allotment to the Secretary of the Interior to meet special educational needs of Indian children."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e0c963d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e0c963e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
