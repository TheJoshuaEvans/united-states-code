66(3)","children":[],"tail":", substituted “2004” for “1997” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" realigned margin."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s466/1"},"text":"Pub. L. 102–325, § 466(1)","children":[],"tail":", substituted “2005” for “1997”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s466/2"},"text":"Pub. L. 102–325, § 466(2)","children":[],"tail":", designated existing provisions as par. (1), redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d3ac7f5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d3ac7f6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/84"},"text":"Pub. L. 110–84","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2007-10-01"},"text":"Oct. 1, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/84/s1/c"},"text":"section 1(c) of Pub. L. 110–84","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"section 1070a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":