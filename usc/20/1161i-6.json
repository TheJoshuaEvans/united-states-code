{"tag":"section","attrib":{"id":"id0d84a289-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161i–6"},"text":"§ 1161i–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d84a28a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State receiving a grant under this part shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a28b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" evaluate the activities that are assisted under this part in order to determine—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d84a28c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–6/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the activities in achieving State goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a28d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–6/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of a career lattice for individuals working in early childhood education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a28e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–6/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of the activities on licensing or regulating requirements for individuals in the field of early childhood development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a28f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–6/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of the activities, and the impact of the statewide plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1161i–4/a/3"},"text":"section 1161i–4(a)(3) of this title","children":[],"tail":", on the quality of education, professional development, and training related to early childhood education programs that are offered in the State;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a290-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–6/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the change in compensation and retention of individuals working in early childhood education programs within the State resulting from the activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d84a291-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–6/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of the activities on the demographic characteristics of individuals working in early childhood education programs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a292-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a report at the end of the grant period to the Secretary regarding the evaluation described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a293-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary’s evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2013-09-30"},"text":"September 30, 2013","children":[],"tail":", the Secretary, in consultation with the Secretary of Health and Human Services, shall prepare and submit to the authorizing committees an evaluation of the State reports submitted under subsection (a)(2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d84a294-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s817"},"text":"Pub. L. 89–329, title VIII, § 817","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3401"},"text":"122 Stat. 3401","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
