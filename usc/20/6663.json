{"tag":"section","attrib":{"id":"id0e1d38a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6663"},"text":null,"children":[{"tag":"num","attrib":{"value":"6663"},"text":"§ 6663.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e1d38a2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6663/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to promote new and existing evidence-based strategies to encourage innovative American history, civics and government, and geography instruction, learning strategies, and professional development activities and programs for teachers, principals, or other school leaders, particularly such instruction, strategies, activities, and programs that benefit low-income students and underserved populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d38a3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6663/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amounts reserved by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6661/b/2"},"text":"section 6661(b)(2) of this title","children":[],"tail":", the Secretary shall award grants, on a competitive basis, to eligible entities for the purposes of expanding, developing, implementing, evaluating, and disseminating for voluntary use, innovative, evidence-based approaches or professional development programs in American history, civics and government, and geography, which—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d38a4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6663/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1d38a5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6663/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" show potential to improve the quality of student achievement in, and teaching of, American history, civics and government, or geography, in elementary schools and secondary schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d38a6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6663/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate innovation, scalability, accountability, and a focus on underserved populations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38a7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6663/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1d38a8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6663/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hands-on civic engagement activities for teachers and students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d38a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6663/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that educate students about the history and principles of the Constitution of the United States, including the Bill of Rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d38aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6663/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program periods and diversity of projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d38ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6663/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded by the Secretary to an eligible entity under this section shall be for a period of not more than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6663/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may renew a grant awarded under this section for 1 additional 2-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d38ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6663/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diversity of projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall ensure that, to the extent practicable, grants are distributed among eligible entities that will serve geographically diverse areas, including urban, suburban, and rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d38ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6663/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to receive a grant under this section, an eligible entity shall submit an application to the Secretary at such time and in such manner as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d38af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6663/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “eligible entity” means an institution of higher education or other nonprofit or for-profit organization with demonstrated expertise in the development of evidence-based approaches with the potential to improve the quality of American history, civics and government, or geography learning and teaching.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1d38b0-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2233"},"text":"Pub. L. 89–10, title II, § 2233","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tII/s2002"},"text":"Pub. L. 114–95, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1947"},"text":"129 Stat. 1947","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e1d38b1-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e1d38b2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e1d38b3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6663, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2203"},"text":"Pub. L. 89–10, title II, § 2203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tII/s201"},"text":"Pub. L. 107–110, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1647"},"text":"115 Stat. 1647","children":[],"tail":", authorized appropriations to carry out part B of former subchapter II of this chapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"Pub. L. 114–95, § 5","children":[],"tail":", title II, § 2002, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1806"},"text":"129 Stat. 1806","children":[],"tail":", 1913, effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[