{"tag":"section","attrib":{"id":"id0e2e0120-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7241"},"text":null,"children":[{"tag":"num","attrib":{"value":"7241"},"text":"§ 7241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this part are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2e0121-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7241/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide financial support to organizations to provide technical assistance and training to State educational agencies and local educational agencies in the implementation and enhancement of systemic and effective family engagement policies, programs, and activities that lead to improvements in student development and academic achievement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e0122-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7241/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assist State educational agencies, local educational agencies, community-based organizations, schools, and educators in strengthening partnerships among parents, teachers, school leaders, administrators, and other school personnel in meeting the educational needs of children and fostering greater parental engagement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e0123-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7241/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To support State educational agencies, local educational agencies, schools, educators, and parents in developing and strengthening the relationship between parents and their children’s school in order to further the developmental progress of children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e0124-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7241/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To coordinate activities funded under this part with parent involvement initiatives funded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6318"},"text":"section 6318 of this title","children":[],"tail":" and other provisions of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e0125-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7241/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assist the Secretary, State educational agencies, and local educational agencies in the coordination and integration of Federal, State, and local services and programs to engage families in education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e2e0126-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4501"},"text":"Pub. L. 89–10, title IV, § 4501","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4501"},"text":"Pub. L. 114–95, title IV, § 4501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2016"},"text":"129 Stat. 2016","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e2e0127-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e2e0128-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e2e0129-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7241, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tV/s5401"},"text":"Pub. L. 89–10, title V, § 5401","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1811"},"text":"115 Stat. 1811","children":[],"tail":", authorized appropriations for fiscal years 2002 to 2007, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"Pub. L. 114–95, § 5","children":[],"tail":", title IV, § 4001(b)(1)(C), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1806"},"text":"129 Stat. 1806","children":[],"tail":", 1967, effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s4501"},"text":"section 4501 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3141"},"text":"section 3141 of this title","children":[],"tail":", prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e2e012a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e2e012b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
