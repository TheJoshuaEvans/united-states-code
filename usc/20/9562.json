{"tag":"section","attrib":{"id":"id0e64c808-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562"},"text":null,"children":[{"tag":"num","attrib":{"value":"9562"},"text":"§ 9562.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner for Education Evaluation and Regional Assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e64c809-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Center for Education Evaluation and Regional Assistance shall be headed by a Commissioner for Education Evaluation and Regional Assistance (in this part referred to as the “Evaluation and Regional Assistance Commissioner”) who is highly qualified and has demonstrated a capacity to carry out the mission of the Center and shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e64c80a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct evaluations pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9563"},"text":"section 9563 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c80b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" widely disseminate information on scientifically valid research, statistics, and evaluation on education, particularly to State educational agencies and local educational agencies, to institutions of higher education, to the public, the media, voluntary organizations, professional associations, and other constituencies, especially with respect to information relating to, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e64c80c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the core academic areas of reading, mathematics, and science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c80d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" closing the achievement gap between high-performing students and low-performing students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c80e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational practices that improve academic achievement and promote learning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c80f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education technology, including software; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c810-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those topics covered by the Educational Resources Information Center Clearinghouses (established under section 941(f) of the Educational Research, Development, Dissemination, and Improvement Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6041/f"},"text":"20 U.S.C. 6041(f)","children":[],"tail":") (as such provision was in effect on the day before "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"November 5, 2002","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c811-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such information accessible in a user-friendly, timely, and efficient manner (including through use of a searchable Internet-based online database that shall include all topics covered in paragraph (2)(E)) to schools, institutions of higher education, educators (including early childhood educators), parents, administrators, policymakers, researchers, public and private entities (including providers of early childhood services), entities responsible for carrying out technical assistance through the Department, and the general public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c812-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the regional educational laboratories in conducting applied research, the development and dissemination of educational research, products and processes, the provision of technical assistance, and other activities to serve the educational needs of such laboratories’ regions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c813-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manage the National Library of Education described in subsection (d), and other sources of digital information on education research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c814-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Director in the preparation of a biennial report, described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9519"},"text":"section 9519 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c815-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award a contract for a prekindergarten through grade 12 mathematics and science teacher clearinghouse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e64c816-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Evaluation and Regional Assistance Commissioner shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e64c817-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that information disseminated under this section is provided in a cost-effective, nonduplicative manner that includes the most current research findings, which may include through the continuation of individual clearinghouses authorized under the Educational Research, Development, Dissemination, and Improvement Act of 1994 (title IX of the Goals 2000: Educate America Act; ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6001"},"text":"20 U.S.C. 6001","children":[],"tail":" et seq.) (as such Act existed on the day before "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"November 5, 2002","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c818-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe prominently the type of scientific evidence that is used to support the findings that are disseminated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c819-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" explain clearly the scientifically appropriate and inappropriate uses of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e64c81a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings that are disseminated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c81b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of evidence used to support those findings; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c81c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respond, as appropriate, to inquiries from schools, educators, parents, administrators, policymakers, researchers, public and private entities, and entities responsible for carrying out technical assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e64c81d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall continue awards for the support of the Educational Resources Information Center Clearinghouses and contracts for regional educational laboratories (established under subsections (f) and (h) of section 941 of the Educational Research, Development, Dissemination, and Improvement Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6041/f"},"text":"20 U.S.C. 6041(f)","children":[],"tail":" and (h)) (as such awards were in effect on the day before "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"November 5, 2002","children":[],"tail":")) for the duration of those awards, in accordance with the terms and agreements of such awards."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e64c81e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Library of Education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e64c81f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established within the National Center for Education Evaluation and Regional Assistance a National Library of Education that shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e64c820-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be headed by an individual who is highly qualified in library science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c821-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and archive information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c822-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a central location within the Federal Government for information about education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c823-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide comprehensive reference services on matters related to education to employees of the Department of Education and its contractors and grantees, other Federal employees, and members of the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c824-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote greater cooperation and resource sharing among providers and repositories of education information in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e64c825-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information collected and archived by the National Library of Education shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e64c826-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" products and publications developed through, or supported by, the Institute; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e64c827-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other relevant and useful education-related research, statistics, and evaluation materials and other information, projects, and publications that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e64c828-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consistent with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e64c829-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/d/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientifically valid research; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e64c82a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/d/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the priorities and mission of the Institute; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e64c82b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9562/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developed by the Department, other Federal agencies, or entities (including entities supported under subchapter II of this chapter and the Educational Resources Information Center Clearinghouses (established under section 941(f) of the Educational Research, Development, Dissemination, and Improvement Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6041/f"},"text":"20 U.S.C. 6041(f)","children":[],"tail":") (as such provision was in effect on the day before "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"November 5, 2002","children":[],"tail":")))."},{"tag":"ref","attrib":{"idref":"fn002247"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002247"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The third closing parenthesis probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e64c82c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s172"},"text":"Pub. L. 107–279, title I, § 172","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1962"},"text":"116 Stat. 1962","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e64c82d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e64c82e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e64c82f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Educational Research, Development, Dissemination, and Improvement Act of 1994 (as such Act existed on the day before ","children":[{"tag":"date","attrib":{"date":"2002-11-05"},"text":"November 5, 2002","children":[],"tail":"), referred to in subsecs. (a)(1)(E), (b)(1), (c), and (d)(2)(B)(ii), is title IX of "},{"tag":"ref","attrib":{"href":"/us/pl/103/227"},"text":"Pub. L. 103–227","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/212"},"text":"108 Stat. 212","children":[],"tail":", which was classified principally to subchapter IX (§ 6001 et seq.) of chapter 68 of this title and was substantially repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/279/tIV/s403/2"},"text":"Pub. L. 107–279, title IV, § 403(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1985"},"text":"116 Stat. 1985","children":[],"tail":". Section 941 of the Act was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6041"},"text":"section 6041 of this title","children":[],"tail":" prior to repeal. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6001"},"text":"section 6001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
