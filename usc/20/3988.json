{"tag":"section","attrib":{"id":"id0de18f66-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3988"},"text":null,"children":[{"tag":"num","attrib":{"value":"3988"},"text":"§ 3988.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments; Federal share; limitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de18f67-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3988/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal and non-Federal shares","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18f68-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3988/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall pay, to each applicant having an application approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3987"},"text":"section 3987 of this title","children":[],"tail":", the Federal share of the cost of the program described in the application."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f69-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3988/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal share for each fiscal year shall be 50 per centum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f6a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3988/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The non-Federal share of payments under this part may be in cash or in kind, fairly evaluated, including plant, equipment, or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18f6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3988/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year State limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 15 per centum of the funds appropriated under this part in any fiscal year may be paid to applicants in any single State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de18f6c-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tIII/s309"},"text":"Pub. L. 98–377, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1286"},"text":"98 Stat. 1286","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tII/s231"},"text":"Pub. L. 99–159, title II, § 231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/900"},"text":"99 Stat. 900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6031/b/2"},"text":"Pub. L. 100–418, title VI, § 6031(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1483"},"text":"102 Stat. 1483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de18f6d-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de18f6e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0de18f6f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsecs. (a)(3), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" substituted “part” for “subchapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/159"},"text":"Pub. L. 99–159","children":[],"tail":" substituted “Secretary” for “Foundation”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
