{"tag":"section","attrib":{"id":"id0e600e54-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501"},"text":null,"children":[{"tag":"num","attrib":{"value":"9501"},"text":"§ 9501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e600e55-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e600e56-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “elementary school”, “secondary school”, “local educational agency”, and “State educational agency” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e57-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outlying areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “outlying areas” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6331/c"},"text":"section 6331(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e58-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Freely associated states","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “freely associated states” means the Republic of the Marshall Islands, the Federated States of Micronesia, and the Republic of Palau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e59-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applied research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applied research” means research—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e600e5a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to gain knowledge or understanding necessary for determining the means by which a recognized and specific need may be met; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e5b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is specifically directed to the advancement of practice in the field of education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e5c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “basic research” means research—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e600e5d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to gain fundamental knowledge or understanding of phenomena and observable facts, without specific application toward processes or products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e5e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the advancement of knowledge in the field of education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e5f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the National Board for Education Sciences established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9516"},"text":"section 9516 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e60-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Bureau” means the Bureau of Indian Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e61-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “comprehensive center” means an entity established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9602"},"text":"section 9602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e62-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e63-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “development” means the systematic use of knowledge or understanding gained from the findings of scientifically valid research and the shaping of that knowledge or understanding into products or processes that can be applied and evaluated and may prove useful in areas such as the preparation of materials and new methods of instruction and practices in teaching, that lead to the improvement of the academic skills of students, and that are replicable in different educational settings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e64-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Institute of Education Sciences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e65-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dissemination” means the communication and transfer of the results of scientifically valid research, statistics, and evaluations, in forms that are understandable, easily accessible, and usable, or adaptable for use in, the improvement of educational practice by teachers, administrators, librarians, other practitioners, researchers, parents, policymakers, and the public, through technical assistance, publications, electronic transfer, and other means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e66-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early childhood educator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “early childhood educator” means a person providing, or employed by a provider of, nonresidential child care services (including center-based, family-based, and in-home child care services) that is legally operating under State law, and that complies with applicable State and local requirements for the provision of child care services to children at any age from birth through the age at which a child may start kindergarten in that State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e67-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Field-initiated research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “field-initiated research” means basic research or applied research in which specific questions and methods of study are generated by investigators (including teachers and other practitioners) and that conforms to standards of scientifically valid research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e68-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historically Black college or university","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “historically Black college or university” means a part B institution as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061"},"text":"section 1061 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e69-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institute","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Institute” means the Institute of Education Sciences established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9511"},"text":"section 9511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e6a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"section 1001(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National research and development center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national research and development center” means a research and development center supported under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9533/c"},"text":"section 9533(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e6c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provider of early childhood services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “provider of early childhood services” means a public or private entity that serves young children, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e600e6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/17/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" child care providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/17/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Head Start agencies operating Head Start programs, and entities carrying out Early Head Start programs, under the Head Start Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9831"},"text":"42 U.S.C. 9831","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/17/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preschools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/17/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" kindergartens; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/17/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" libraries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientifically based research standards","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e600e73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/18/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “scientifically based research standards” means research standards that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e600e74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/18/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply rigorous, systematic, and objective methodology to obtain reliable and valid knowledge relevant to education activities and programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e600e75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/18/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present findings and make claims that are appropriate to and supported by the methods that have been employed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/18/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term includes, appropriate to the research being conducted—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e600e77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/18/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employing systematic, empirical methods that draw on observation or experiment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e600e78-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/18/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involving data analyses that are adequate to support the general findings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e600e79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/18/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relying on measurements or observational methods that provide reliable data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e600e7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/18/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making claims of causal relationships only in random assignment experiments or other designs (to the extent such designs substantially eliminate plausible competing explanations for the obtained results);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e600e7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/18/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that studies and methods are presented in sufficient detail and clarity to allow for replication or, at a minimum, to offer the opportunity to build systematically on the findings of the research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e600e7c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/18/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining acceptance by a peer-reviewed journal or approval by a panel of independent experts through a comparably rigorous, objective, and scientific review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e600e7d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/18/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using research designs and methods appropriate to the research question posed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e7e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientifically valid education evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “scientifically valid education evaluation” means an evaluation that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e600e7f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/19/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adheres to the highest possible standards of quality with respect to research design and statistical analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e80-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/19/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an adequate description of the programs evaluated and, to the extent possible, examines the relationship between program implementation and program impacts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e81-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/19/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an analysis of the results achieved by the program with respect to its projected effects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e82-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/19/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employs experimental designs using random assignment, when feasible, and other research methodologies that allow for the strongest possible causal inferences when random assignment is not feasible; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e83-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/19/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may study program implementation through a combination of scientifically valid and reliable methods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e84-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientifically valid research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “scientifically valid research” includes applied research, basic research, and field-initiated research in which the rationale, design, and interpretation are soundly developed in accordance with scientifically based research standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e85-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” includes (except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9548"},"text":"section 9548 of this title","children":[],"tail":") each of the 50 States, the District of Columbia, the Commonwealth of Puerto Rico, the freely associated states, and the outlying areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “technical assistance” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e600e88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/23/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assistance in identifying, selecting, or designing solutions based on research, including professional development and high-quality training to implement solutions leading to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e600e89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/23/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved educational and other practices and classroom instruction based on scientifically valid research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e600e8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/23/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved planning, design, and administration of programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e8b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/23/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in interpreting, analyzing, and utilizing statistics and evaluations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e8c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9501/23/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other assistance necessary to encourage the improvement of teaching and learning through the applications of techniques supported by scientifically valid research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e600e8d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s102"},"text":"Pub. L. 107–279, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1941"},"text":"116 Stat. 1941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/ff/1"},"text":"Pub. L. 114–95, title IX, § 9215(ff)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2174"},"text":"129 Stat. 2174","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e600e8e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e600e8f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e600e90-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Head Start Act, referred to in par. (17)(B), is subchapter B (§§ 635–657) of chapter 8 of subtitle A of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/499"},"text":"95 Stat. 499","children":[],"tail":", which is classified generally to subchapter II (§ 9831 et seq.) of chapter 105 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9801"},"text":"section 9801 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e600e91-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" amended par. (1) generally. Prior to amendment, text read as follows: “The terms ‘elementary school’, ‘secondary school’, ‘local educational agency’, and ‘State educational agency’ have the meanings given those terms in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":" and the terms ‘freely associated states’ and ‘outlying area’ have the meanings given those terms in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6331/c"},"text":"section 6331(c) of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e600e92-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e600e93-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0e600e94-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s101"},"text":"Pub. L. 107–279, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1941"},"text":"116 Stat. 1941","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/279/tI/s101"},"text":"“This title [enacting this subchapter] may be cited as the ‘Education Sciences Reform Act of 2002’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tII/s201"},"text":"Pub. L. 107–279, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1975"},"text":"116 Stat. 1975","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/279/tII/s201"},"text":"“This title [enacting subchapter II of this chapter] may be cited as the ‘Educational Technical Assistance Act of 2002’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tIII/s301"},"text":"Pub. L. 107–279, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1982"},"text":"116 Stat. 1982","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/279/tIII/s301"},"text":"“This title [enacting subchapter III of this chapter] may be referred to as the ‘National Assessment of Educational Progress Authorization Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0e600e95-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Orderly Transition","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tIV/s405"},"text":"Pub. L. 107–279, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1986"},"text":"116 Stat. 1986","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/279/tIV/s405"},"text":"“The Secretary of Education shall take such steps as are necessary to provide for the orderly transition to, and implementation of, the offices, boards, committees, and centers (and their various functions and responsibilities) established or authorized by this Act [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3419"},"text":"section 3419 of this title","children":[],"tail":", amending sections 1232j, 3412, 3461, 6194, 6311, 6312, 7013, 7451, 7703, 7909, 9007, 9010, 9011, 9573, 9623, and 9624 and former sections 6317, 6491, 6932, 7253c, 7283b, and 7283d of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of Title 5","children":[],"tail":", Government Organization and Employees, transferring sections 9010 and 9011 of this title to sections 9622 and 9621 of this title, respectively, repealing sections 3419, 6011, 6021, 6031, 6041, 6051, 6053 to 6053e, 6054 to 6054b, 6055 to 6055h, 6056, 6056a, 9001 to 9009, and 9012 of this title, enacting provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703"},"text":"section 7703 of this title","children":[],"tail":", and repealing provisions set out as notes under sections 1221e and 9001 of this title], and by the amendments made by this Act, from those established or authorized by the Educational Research, Development, Dissemination, and Improvement Act of 1994 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6001"},"text":"20 U.S.C. 6001","children":[],"tail":" et seq.) and the National Education Statistics Act of 1994 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9001"},"text":"20 U.S.C. 9001","children":[],"tail":" et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
