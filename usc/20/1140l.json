{"tag":"section","attrib":{"id":"id0d7d7620-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l"},"text":null,"children":[{"tag":"num","attrib":{"value":"1140l"},"text":"§ 1140l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Advisory Commission on Accessible Instructional Materials in Postsecondary Education for Students with Disabilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d7d7621-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7d7622-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a commission to be known as the Advisory Commission on Accessible Instructional Materials in Postsecondary Education for Students with Disabilities (in this section referred to as the “Commission”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d7623-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7d7624-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total number of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall include not more than 19 members, who shall be appointed by the Secretary in accordance with subparagraphs (B) and (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d7625-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of the Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission members shall include one representative from each of the following categories:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d7d7626-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Postsecondary Education of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d7627-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Special Education and Rehabilitative Services of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d7628-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office for Civil Rights of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d7629-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Library of Congress National Digital Information and Infrastructure Preservation Program Copyright Working Group.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d762a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Association on Higher Education and Disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d762b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Association of American Publishers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d762c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Association of American University Presses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d762d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Council on Disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d762e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recording for the Blind and Dyslexic.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d762f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National organizations representing individuals with visual impairments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d7630-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National organizations representing individuals with learning disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d7631-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional members of the Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission members shall include two representatives from each of the following categories:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d7d7632-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Staff from institutions of higher education with demonstrated experience teaching or supporting students with print disabilities, including representatives from both two-year and four-year institutions of higher education of different sizes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d7633-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Producers of accessible materials, publishing software, and supporting technologies in specialized formats, such as Braille, audio or synthesized speech, and digital media.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d7634-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals with visual impairments, including not less than one currently enrolled postsecondary student.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d7635-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals with dyslexia or other learning disabilities related to reading, including not less than one currently enrolled postsecondary student.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d7636-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint the members of the Commission not later than 60 days after the Commission is established under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d7637-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson and vice chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall select a chairperson and vice chairperson from among the members of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d7638-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7d7639-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall meet at the call of the Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d763a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the appointment of the members of the Commission under paragraph (2)(D), the Commission shall hold the Commission’s first meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d763b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Commission shall constitute a quorum, but a lesser number of members may hold hearings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7d763c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Commission","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7d763d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7d763e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall conduct a comprehensive study to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d7d763f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the barriers and systemic issues that may affect, and technical solutions available that may improve, the timely delivery and quality of accessible instructional materials for postsecondary students with print disabilities, as well as the effective use of such materials by faculty and staff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d7640-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations related to the development of a comprehensive approach to improve the opportunities for postsecondary students with print disabilities to access instructional materials in specialized formats in a timeframe comparable to the availability of instructional materials for postsecondary nondisabled students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d7641-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, in carrying out the study under this paragraph, the Commission shall identify and use existing research, recommendations, and information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d7642-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d7d7643-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall develop recommendations—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d7d7644-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to inform Federal regulations and legislation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7d7645-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the model demonstration programs authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1140m"},"text":"section 1140m of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7d7646-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify best practices in systems for collecting, maintaining, processing, and disseminating materials in specialized formats to students with print disabilities at costs comparable to instructional materials for postsecondary nondisabled students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7d7647-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/C/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the effective use of such materials by faculty and staff, while complying with applicable copyright law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7d7648-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/C/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to modify the definitions of instructional materials, authorized entities, and eligible students, as such terms are used in applicable Federal law, for the purpose of improving services to students with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7d7649-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the recommendations under clause (i), the Commission shall consider—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d7d764a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" how students with print disabilities may obtain instructional materials in accessible formats—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id0d7d764b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/C/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within a timeframe comparable to the availability of instructional materials for nondisabled students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id0d7d764c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/C/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, at costs comparable to the costs of such materials for nondisabled students;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7d764d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility and technical parameters of establishing standardized electronic file formats, such as the National Instructional Materials Accessibility Standard as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1474/e/3"},"text":"section 1474(e)(3) of this title","children":[],"tail":", to be provided by publishers of instructional materials to producers of materials in specialized formats, institutions of higher education, and eligible students;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7d764e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility of establishing a national clearinghouse, repository, or file-sharing network for electronic files in specialized formats and files used in producing instructional materials in specialized formats, and a list of possible entities qualified to administer such clearinghouse, repository, or network;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7d764f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/C/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility of establishing market-based solutions involving collaborations among publishers of instructional materials, producers of materials in specialized formats, and institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7d7650-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/C/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solutions utilizing universal design; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7d7651-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/1/C/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solutions for low-incidence, high-cost requests for instructional materials in specialized formats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d7652-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after the Commission’s first meeting, the Commission shall submit a report to the Secretary and the authorizing committees detailing the findings and recommendations of the study conducted under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7d7653-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the study under paragraph (1), the Commission shall disseminate information concerning the issues that are the subject of the study through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7d7654-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Technical Assistance Center established under subpart 4; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7d7655-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other means, as determined by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7d7656-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1140l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of the Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall terminate on the date that is 90 days after the date on which the Commission submits the report under subsection (b)(2) to the Secretary and the authorizing committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d7d7657-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s772"},"text":"Pub. L. 89–329, title VII, § 772","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s709/2"},"text":"Pub. L. 110–315, title VII, § 709(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3368"},"text":"122 Stat. 3368","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tVII/s701/5"},"text":"Pub. L. 111–39, title VII, § 701(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1955"},"text":"123 Stat. 1955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d7d7658-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d7d7659-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d7d765a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s772"},"text":"section 772 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1132h–1"},"text":"section 1132h–1 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d7d765b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s701/5/A"},"text":"Pub. L. 111–39, § 701(5)(A)","children":[],"tail":", substituted “with” for “with in”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s701/5/B"},"text":"Pub. L. 111–39, § 701(5)(B)","children":[],"tail":", substituted “clause (i)” for “subparagraph (C)” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d7d765c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag"