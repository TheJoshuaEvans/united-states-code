{"tag":"section","attrib":{"id":"id0cb2d354-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s975"},"text":null,"children":[{"tag":"num","attrib":{"value":"975"},"text":"§ 975.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims for losses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cb2d355-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s975/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations for prompt adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall prescribe regulations providing for prompt adjustment of valid claims for losses which are covered by an agreement made pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s974"},"text":"section 974 of this title","children":[],"tail":", including provision for arbitration of issues relating to the dollar value of damages involving less than total loss or destruction of such covered objects."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cb2d356-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s975/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a claim of loss with respect to an item which is covered by an agreement made pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s974"},"text":"section 974 of this title","children":[],"tail":", the Council shall certify the validity of the claim and the amount of the loss to the Speaker of the House of Representatives and the President pro tempore of the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cb2d357-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/158/s6"},"text":"Pub. L. 94–158, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/845"},"text":"89 Stat. 845","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
