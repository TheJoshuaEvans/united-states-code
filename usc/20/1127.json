{"tag":"section","attrib":{"id":"id0d6f1e5d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1127"},"text":null,"children":[{"tag":"num","attrib":{"value":"1127"},"text":"§ 1127.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of certain grant recipients","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6f1e5e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1127/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1122"},"text":"section 1122 of this title","children":[],"tail":" competitively on the basis of criteria that separately, but not less rigorously, evaluates—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d6f1e5f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1127/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applications for comprehensive foreign language and area or international studies centers and programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d6f1e60-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1127/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applications for undergraduate foreign language and area or international studies centers and programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6f1e61-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1127/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall set criteria for grants awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1122"},"text":"section 1122 of this title","children":[],"tail":" by which a determination of excellence shall be made to meet the differing objectives of graduate and undergraduate institutions. In keeping with the purposes of this part, the Secretary shall take into account the degree to which activities of centers, programs, and fellowships at institutions of higher education address national needs, and generate information for and disseminate information to the public. The Secretary shall also consider an applicant’s record of placing students into postgraduate employment, education, or training in areas of national need and an applicant’s stated efforts to increase the number of such students that go into such placements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6f1e62-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1127/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable distribution of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, to the extent practicable, award grants under this part (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1122"},"text":"section 1122 of this title","children":[],"tail":") in such manner as to achieve an equitable distribution of the grant funds throughout the United States, based on the merit of a proposal as determined pursuant to a peer review process involving broadly representative professionals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6f1e63-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s607"},"text":"Pub. L. 89–329, title VI, § 607","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVI/s601"},"text":"Pub. L. 105–244, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1782"},"text":"112 Stat. 1782","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVI/s607"},"text":"Pub. L. 110–315, title VI, § 607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3338"},"text":"122 Stat. 3338","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6f1e64-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6f1e65-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d6f1e66-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1127, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s610"},"text":"Pub. L. 89–329, title VI, § 610","children":[],"tail":", formerly § 607, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tVI/s601/a"},"text":"Pub. L. 96–374, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1467"},"text":"94 Stat. 1467","children":[],"tail":"; renumbered § 610 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tVI"},"text":"Pub. L. 99–498, title VI","children":[],"tail":", §§ 605(1), 609, "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1517"},"text":"100 Stat. 1517","children":[],"tail":", 1519; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tVI/s601"},"text":"Pub. L. 102–325, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/728"},"text":"106 Stat. 728","children":[],"tail":", authorized grants and contracts for American overseas research centers, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1127, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s607"},"text":"Pub. L. 89–329, title VI, § 607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1265"},"text":"79 Stat. 1265","children":[],"tail":", provided procedures to be followed in event of disapproval of a State plan under equipment grant program, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s607"},"text":"section 607 of Pub. L. 89–329","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1125a"},"text":"section 1125a of this title","children":[],"tail":", prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d6f1e67-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s607/1"},"text":"Pub. L. 110–315, § 607(1)","children":[],"tail":", substituted “evaluates—” and pars. (1) and (2) for “evaluates the applications for comprehensive and undergraduate language and area centers and programs.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s607/2"},"text":"Pub. L. 110–315, § 607(2)","children":[],"tail":", inserted at end “In keeping with the purposes of this part, the Secretary shall take into account the degree to which activities of centers, programs, and fellowships at institutions of higher education address national needs, and generate information for and disseminate information to the public. The Secretary shall also consider an applicant’s record of placing students into postgraduate employment, education, or training in areas of national need and an applicant’s stated efforts to increase the number of such students that go into such placements.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
