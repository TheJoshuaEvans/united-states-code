{"tag":"section","attrib":{"id":"id0e5b2bf0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9109"},"text":null,"children":[{"tag":"num","attrib":{"value":"9109"},"text":"§ 9109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds for construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No funds appropriated to carry out this chapter, subchapter II of this chapter, or subchapter III of this chapter may be used for construction expenses.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e5b2bf1-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/tII/s210A"},"text":"Pub. L. 94–462, title II, § 210A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/81/tI/s105"},"text":"Pub. L. 108–81, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-25"},"text":"Sept. 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/997"},"text":"117 Stat. 997","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
