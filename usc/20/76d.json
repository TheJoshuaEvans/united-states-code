{"tag":"section","attrib":{"id":"id0c7be3db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s76d"},"text":null,"children":[{"tag":"num","attrib":{"value":"76d"},"text":"§ 76d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations of works of art from Government agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator of General Services and other agencies of the Government are authorized to donate to the Gallery any works of art now or hereafter under their control.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c7be3dc-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-05-17/ch238/s5"},"text":"May 17, 1938, ch. 238, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/401"},"text":"52 Stat. 401","children":[],"tail":"; 1939 Reorg. Plan No. I, §§ 301, 303, eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 FR 2729, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1426"},"text":"53 Stat. 1426","children":[],"tail":", 1427; "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title I, § 103, "},{"tag":"ref","attrib":{"href":"/us/stat/63/380"},"text":"63 Stat. 380","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c7be3dd-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c7be3de-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0c7be3df-3a70-11f1-a648-bee82ed8a795"},"text":"\n","chil