{"tag":"section","attrib":{"id":"id0cec0bf3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070b–2"},"text":"§ 1070b–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements with institutions; selection of recipients","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cec0bf4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance may be made available under this subpart only to an institution which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cec0bf5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1094"},"text":"section 1094 of this title","children":[],"tail":", an agreement with the Secretary applicable to this subpart;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0bf6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees that the Federal share of awards under this subpart will not exceed 75 percent of such awards, except that the Federal share may be exceeded if the Secretary determines, pursuant to regulations establishing objective criteria for such determinations, that a larger Federal share is required to further the purpose of this subpart; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0bf7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" agrees that the non-Federal share of awards made under this subpart shall be made from the institution’s own resources, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cec0bf8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutional grants and scholarships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0bf9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tuition or fee waivers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0bfa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State scholarships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0bfb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foundation or other charitable organization funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0bfc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Awards may be made under this subpart only to a student who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cec0bfd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an eligible student under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1091"},"text":"section 1091 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0bfe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes application at a time and in a manner consistent with the requirements of the Secretary and that institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0bff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of individuals and determination of amount of awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cec0c00-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From among individuals who are eligible for supplemental grants for each fiscal year, the institution shall, in accordance with the agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1094"},"text":"section 1094 of this title","children":[],"tail":", and within the amount allocated to the institution for that purpose for that year under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070b–3"},"text":"section 1070b–3 of this title","children":[],"tail":", select individuals who are to be awarded such grants and determine, in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070b–1"},"text":"section 1070b–1 of this title","children":[],"tail":", the amounts to be paid to them."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cec0c01-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cec0c02-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out paragraph (1) of this subsection, each institution of higher education shall, in the agreement made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1094"},"text":"section 1094 of this title","children":[],"tail":", assure that the selection procedures—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0cec0c03-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be designed to award supplemental grants under this subpart, first, to students with exceptional need, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cec0c04-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will give a priority for supplemental grants under this subpart to students who receive Pell Grants and meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1091"},"text":"section 1091 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cec0c05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of subparagraph (A), the term “students with exceptional need” means students with the lowest student aid indexes at the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0c06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds for less-than-full-time students","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the institution’s allocation under this subpart is directly or indirectly based in part on the financial need demonstrated by students who are independent students or attending the institution on less than a full-time basis, then a reasonable proportion of the allocation shall be made available to such students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cec0c07-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use and transfer of funds for administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An agreement entered into pursuant to this section shall provide that funds granted to an institution of higher education may be used only to make payments to students participating in a grant program authorized under this subpart, except that an institution may use a portion of the sums allocated to it under this subpart to meet administrative expenses in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1096"},"text":"section 1096 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cec0c08-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s413C"},"text":"Pub. L. 89–329, title IV, § 413C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s401/a"},"text":"Pub. L. 99–498, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1329"},"text":"100 Stat. 1329","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s403/d"},"text":"Pub. L. 102–325, title IV, § 403(d)","children":[],"tail":"–(f), "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/506"},"text":"106 Stat. 506","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/b/25"},"text":"Pub. L. 103–208, § 2(b)(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2459"},"text":"107 Stat. 2459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s406/b"},"text":"Pub. L. 105–244, title IV, § 406(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1665"},"text":"112 Stat. 1665","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tVII/s704/2"},"text":"Pub. L. 116–260, div. FF, title VII, § 704(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3199"},"text":"134 Stat. 3199","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cec0c09-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cec0c0a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cec0c0b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1070b–2, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s413C"},"text":"Pub. L. 89–329, title IV, § 413C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tI/s131/b/1"},"text":"Pub. L. 92–318, title I, § 131(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/253"},"text":"86 Stat. 253","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/482/tI/s122/b"},"text":"Pub. L. 94–482, title I, § 122(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2094"},"text":"90 Stat. 2094","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tIV/s403/d"},"text":"Pub. L. 96–374, title IV, § 403(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1405"},"text":"94 Stat. 1405","children":[],"tail":", related to selection of recipients of supplemental educational opportunity grants and agreements with institutions, prior to the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0cee7c0c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “student aid indexes” for “expected family contributions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" amended heading and text of subsec. (d) generally. Prior to amendment, text read as follows: “If the institution’s allocation under this subpart is directly or indirectly based in part on the financial need demonstrated by students who are independent students or attending the institution less than full time and if the total financial need of all such students attending the institution exceeds 5 percent of the total financial need of all students attending such institution, then at least 5 percent of such allotment shall be made available to such students.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" substituted “and” for “, a reasonable proportion of the institution’s allocation shall be made available to such students, except that” and “5 percent of the total financial need” for “5 percent of the need”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s403/d"},"text":"Pub. L. 102–325, § 403(d)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “agrees that the Federal share of awards under this subpart will not exceed—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) 95 percent of such awards in fiscal year 1989,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) 90 percent of such awards in fiscal year 1990, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) 85 percent of such awards in fiscal year 1991,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"except that the Federal share may be exceeded if the Secretary determines, pursuant to regulations establishing objective criteria for such determinations, that a larger Federal share is required to further the purpose of this subpart; and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s403/e"},"text":"Pub. L. 102–325, § 403(e)","children":[],"tail":", inserted “who are independent students or” after “demonstrated by students” and inserted before period at end “, except that if the total financial need of all such students attending the institution exceeds 5 percent of the need of all students attending such institution, then at least 5 percent of such allotment shall be made available to such students”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/s403/f"},"text":"Pub. L. 102–325, § 403(f)","children":[],"tail":", struck out before period at end “, and may transfer such funds in accordance with the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1095"},"text":"section 1095 of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cee7c0d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cee7c0e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2024-07-01"},"text":"July 1, 2024","children":[],"tail":", except as otherwise expressly provided, and applicable with respect to award year 2024–2025 and each subsequent award year, as determined under this chapter, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/s701/b"},"text":"section 701(b) of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cee7c0f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cee7c10-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" effective on and after "},{"tag":"date","attrib":{"date":"1994-07-01"},"text":"July 1, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s5/b/6"},"text":"section 5(b)(6) of Pub. L. 103–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0cee7c11-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", except that changes in subsec. (a)(2) of this section, relating to Federal share for supplemental educational opportunity grant program, applicable to funds provided for such program for award years beginning on or after "},{"tag":"date","attrib":{"date":"1993-07-01"},"text":"July 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/s410"},"text":"section 410 of Pub. L. 102–325","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"section 1070a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0cee7c12-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/s2"},"text":"section 2 of Pub. L. 99–498","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s401/b/5"},"text":"Pub. L. 99–498, title IV, § 401(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1353"},"text":"100 Stat. 1353","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/498/tIV/s401/b/5"},"text":"“Section 413C(c)(2) of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070b–2/c/2"},"text":"20 U.S.C. 1070b–2(c)(2)","children":[],"tail":"] as amended by this section shall apply to the awarding of grants under subpart 2 of part A of title IV of the Act [this subpart] for periods of enrollment beginning on or after "},{"tag":"date","attrib":{"date":"1987-07-01"},"text":"July 1, 1987","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
