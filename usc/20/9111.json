{"tag":"section","attrib":{"id":"id0e5b2bf4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9111"},"text":null,"children":[{"tag":"num","attrib":{"value":"9111"},"text":"§ 9111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, the Director shall establish one account to be used to pay the Federal administrative costs of carrying out this chapter, and not more than $17,000,000 of the total funds appropriated under sections 9108(g), 9123, and 9176 of this title shall be placed in such account.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e5b2bf5-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/tII/s210C"},"text":"Pub. L. 94–462, title II, § 210C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/340/tI/s108"},"text":"Pub. L. 111–340, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3599"},"text":"124 Stat. 3599","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/410/s6"},"text":"Pub. L. 115–410, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5415"},"text":"132 Stat. 5415","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e5b2bf6-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e5b2bf7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e5b2bf8-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act” and was translated as reading “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462"},"text":"Pub. L. 94–462","children":[],"tail":", known as the Museum and Library Services Act, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e5b2bf9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/410"},"text":"Pub. L. 115–410","children":[],"tail":" substituted “$17,000,000 of the total funds” for “a total of 7 percent of the funds” and “sections 9108(g), 9123, and 9176 of this title” for “sections 9108(f), 9123, and 9176 of this title”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
