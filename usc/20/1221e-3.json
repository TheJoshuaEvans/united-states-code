 of the General Education Provisions Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1225/b/2"},"text":"section 1225(b)(2) of this title","children":[],"tail":"], as added by section 1245 of this Act, shall not take effect with respect to the use of funds under section 421 of the Elementary and Secondary Education Act of 1965 [former "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3101"},"text":"section 3101 of this title","children":[],"tail":"] until "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":", except at the option of local educational agencies.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d8e3ef1-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/380/tV/s502/b"},"text":"Pub. L. 93–380, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/560"},"text":"88 Stat. 560","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/380/tV/s502/b"},"text":"“The amendments made by this section [enacting this section and section 1221e–2 and amending sections 1221b and 1221e of this title] shall be effective on the tenth day after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
