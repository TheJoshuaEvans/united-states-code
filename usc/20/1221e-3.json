{"tag":"section","attrib":{"id":"id0d8e3eea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1221e–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"1221e–3"},"text":"§ 1221e–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, in order to carry out functions otherwise vested in the Secretary by law or by delegation of authority pursuant to law, and subject to limitations as may be otherwise imposed by law, is authorized to make, promulgate, issue, rescind, and amend rules and regulations governing the manner of operation of, and governing the applicable programs administered by, the Department.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d8e3eeb-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s410"},"text":"Pub. L. 90–247, title IV, § 410","children":[],"tail":", formerly § 408, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/380/tV/s502/a/1"},"text":"Pub. L. 93–380, title V, § 502(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/559"},"text":"88 Stat. 559","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXII"},"text":"Pub. L. 95–561, title XII","children":[],"tail":", §§ 1243(b), 1244, "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2353"},"text":"92 Stat. 2353","children":[],"tail":"; renumbered § 410 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII"},"text":"Pub. L. 103–382, title II","children":[],"tail":", §§ 212(b)(1), 222, "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3913"},"text":"108 Stat. 3913","children":[],"tail":", 3914.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d8e3eec-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d8e3eed-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d8e3eee-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s222"},"text":"Pub. L. 103–382, § 222","children":[],"tail":", amended section generally, substituting single par. relating to general authority of Secretary for former subsecs. (a) to (d) relating to general authority of administrative heads of education agencies."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/s1243/b"},"text":"Pub. L. 95–561, § 1243(b)","children":[],"tail":", inserted “or by delegation of authority pursuant to law” after “vested in him by law” in provisions preceding par. (1) and, in par. (1), inserted “, and governing the applicable programs administered by” after “the manner of operation of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561/s1244"},"text":"Pub. L. 95–561, § 1244","children":[],"tail":", added subsec. (b), redesignated former subsecs. (b) and (c) as (c) and (d), and in subsec. (d) as so redesignated substituted “For the purposes of this chapter” for “For the purposes of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"