{"tag":"section","attrib":{"id":"id0d7649e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1134b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1134b"},"text":"§ 1134b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stipends","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d7649e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1134b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall pay to individuals awarded fellowships under this subpart such stipends as the Secretary may establish, reflecting the purpose of this program to encourage highly talented students to undertake graduate study as described in this subpart. In the case of an individual who receives such individual’s first stipend under this subpart in academic year 2009–2010 or any succeeding academic year, such stipend shall be set at a level of support equal to that provided by the National Science Foundation Graduate Research Fellowship Program for such academic year, except such amount shall be adjusted as necessary so as not to exceed the fellow’s demonstrated level of need determined in accordance with part F of subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7649e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1134b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7649e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1134b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7649e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1134b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall (in addition to stipends paid to individuals under this subpart) pay to the institution of higher education, for each individual awarded a fellowship under this subpart at such institution, an institutional allowance. Except as provided in subparagraph (B), such allowance shall be, for academic year 2009–2010 and succeeding academic years, the same amount as the institutional payment made for academic year 2008–2009, adjusted for academic year 2009–2010 and annually thereafter in accordance with inflation as determined by the Department of Labor’s Consumer Price Index for the previous calendar year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7649ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1134b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The institutional allowance paid under subparagraph (A) shall be reduced by the amount the institution charges and collects from a fellowship recipient for tuition and other expenses as part of the recipient’s instructional program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7649eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1134b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7649ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1134b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beginning ","children":[{"tag":"date","attrib":{"date":"1992-03-01"},"text":"March 1, 1992","children":[],"tail":", any applicant for a fellowship under this subpart who has been notified in writing by the Secretary that such applicant has been selected to receive such a fellowship and is subsequently notified that the fellowship award has been withdrawn, shall receive such fellowship unless the Secretary subsequently makes a determination that such applicant submitted fraudulent information on the application."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7649ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1134b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the availability of appropriations, amounts payable to an institution by the Secretary pursuant to this subsection shall not be reduced for any purpose other than the purposes specified under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d7649ee-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s703"},"text":"Pub. L. 89–329, title VII, § 703","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVII/s701"},"text":"Pub. L. 105–244, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1789"},"text":"112 Stat. 1789","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s702/c/1"},"text":"Pub. L. 110–315, title VII, § 702(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","at