{"tag":"section","attrib":{"id":"id0ce99abf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070a–21"},"text":"§ 1070a–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early intervention and college awareness program authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0ce99ac0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized, in accordance with the requirements of this division, to establish a program that encourages eligible entities to provide support, and maintain a commitment, to eligible low-income students, including students with disabilities, to assist the students in obtaining a secondary school diploma (or its recognized equivalent) and to prepare for and succeed in postsecondary education, by providing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce99ac1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" financial assistance, academic support, additional counseling, mentoring, outreach, and supportive services to secondary school students, including students with disabilities, to reduce—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce99ac2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the risk of such students dropping out of school; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99ac3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for remedial education for such students at the postsecondary level; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99ac4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information to students and their families about the advantages of obtaining a postsecondary education and, college financing options for the students and their families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce99ac5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce99ac6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a–28"},"text":"section 1070a–28 of this title","children":[],"tail":" for each fiscal year, the Secretary shall make awards to eligible entities described in paragraphs (1) and (2) of subsection (c) to enable the entities to carry out the program authorized under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99ac7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award a grant under this division to an eligible entity described in paragraphs (1) and (2) of subsection (c) for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce99ac8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99ac9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible entity that applies for a grant under this division for seven years to enable the eligible entity to provide services to a student through the student’s first year of attendance at an institution of higher education, seven years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99aca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making awards to eligible entities described in subsection (c)(1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce99acb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" give priority to eligible entities that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0ce99acc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the day before ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", carried out successful educational opportunity programs under this division (as this division was in effect on such day); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ce99acd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a prior, demonstrated commitment to early intervention leading to college access through collaboration and replication of successful strategies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99ace-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that students served under this division on the day before ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", continue to receive assistance through the completion of secondary school."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0ce99acf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Eligible entity” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this division, the term “eligible entity” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ce99ad0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ce99ad1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a partnership—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0ce99ad2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consisting of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0ce99ad3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more local educational agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0ce99ad4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more degree granting institutions of higher education; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0ce99ad5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070a–21/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which may include not less than two other community organizations or entities, such as businesses, professional organizations, State agencies, institutions or agencies sponsoring programs authorized under subpart 4, or other public or private agencies or organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ce99ad6-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s404A"},"text":"Pub. L. 89–329, title IV, § 404A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s403"},"text":"Pub. L. 105–244, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1656"},"text":"112 Stat. 1656","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s404/a"},"text":"Pub. L. 110–315, title IV, § 404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3206"},"text":"122 Stat. 3206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ce99ad7-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ce99ad8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0ce99ad9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1070a–21, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s404A"},"text":"Pub. L. 89–329, title IV, § 404A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tIV/s402/a/4"},"text":"Pub. L. 102–325, title IV, § 402(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/492"},"text":"106 Stat. 492","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/b/12"},"text":"Pub. L. 103–208, § 2(b)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2459"},"text":"107 Stat. 2459","children":[],"tail":", authorized establishment of early intervention program, prior to the general amendment of this division by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0ce99ada-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s404/a/1"},"text":"Pub. L. 110–315, § 404(a)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “The Secretary is authorized, in accordance with the requirements of this division, to establish a program that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) encourages eligible entities to provide or maintain a guarantee to eligible low-income students who obtain a secondary school diploma (or its recognized equivalent), of the financial assistance necessary to permit the students to attend an institution of higher education; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) supports eligible entities in providing—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) additional counseling, mentoring, academic support, outreach, and supportive services to elementary school, middle school, and secondary school students who are at risk of dropping out of school; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) information to students and their parents about the advantages of obtaining a postsecondary education and the college financing options for the students and their parents.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s404/a/2"},"text":"Pub. L. 110–315, § 404(a)(2)","children":[],"tail":", added pars. (2) and (3) and struck out former par. (2) which related to priority in making awards to eligible entities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s404/a/3"},"text":"Pub. L. 110–315, § 404(a)(3)","children":[],"tail":", added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “a partnership consisting of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) one or more local educational agencies acting on behalf of—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) one or more elementary schools or secondary schools; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the secondary schools that students from the schools described in clause (i) would normally attend;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) one or more degree granting institutions of higher education; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) at least two community organizations or entities, such as businesses, professional associations, community-based organizations, philanthropic organizations, State agencies, institutions or agencies sponsoring programs authorized under subpart 4 of this part, or other public or private agencies or organizations.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0ce99adb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0ce99adc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Division effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0ce99add-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Evaluation of Tuition Guaranty Programs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325/tXIV/s1407"},"text":"Pub. L. 102–325, title XIV, § 1407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/819"},"text":"106 Stat. 819","children":[],"tail":", directed Secretary of Education to conduct study of effectiveness of programs for disadvantaged children that promise the child financial resources needed to pursue postsecondary education in exchange for child’s commitment to achieve satisfactory elementary and secondary education, and to submit reports regarding study by "},{"tag":"date","attrib":{"date":"1996-06-30"},"text":"June 30, 1996","children":[],"tail":", and by "},{"tag":"date","attrib":{"date":"1997-01-01"},"text":"Jan. 1, 1997","children":[],"tail":", to committees of Congress, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/332/s6/b/2"},"text":"Pub. L. 105–332, § 6(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3128"},"text":"112 Stat. 3128","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
