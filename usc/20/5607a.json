{"tag":"section","attrib":{"id":"id0df71259-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5607a"},"text":"§ 5607a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental Dispute Resolution Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0df7125a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States an Environmental Dispute Resolution Fund to be administered by the Foundation. The Fund shall consist of amounts appropriated to the Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5609/b"},"text":"section 5609(b) of this title","children":[],"tail":" and amounts paid into the Fund under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s5607b"},"text":"section 5607b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df7125b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall expend from the Fund such sums as the Board determines are necessary to establish and operate the National Center, including such amounts as are necessary for salaries, administration, the provision of mediation and other services, and such other expenses as the Board determines are necessary, including not to exceed $1,000 annually for official reception and representation expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df7125c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distinction from Trust Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund shall be maintained separately from the Trust Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5606"},"text":"section 5606 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0df7125d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df7125e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall invest such portion of the Fund as is not, in the judgment of the Secretary, required to meet current withdrawals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df7125f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest-bearing obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Investments may be made only in interest-bearing obligations of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df71260-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of obligations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of investments under paragraph (1), obligations may be acquired—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0df71261-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607a/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on original issue at the issue price; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df71262-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607a/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by purchase of outstanding obligations at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df71263-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any obligation acquired by the Fund may be sold by the Secretary of the Treasury at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df71264-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5607a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits to Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest on, and the proceeds from the sale or redemption of, any obligations held in the Fund shall be credited to and form a part of the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0df71265-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/259/s10"},"text":"Pub. L. 102–259, § 10","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/156/s6/b"},"text":"Pub. L. 105–156, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-02-11"},"text":"Feb. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/10"},"text":"112 Stat. 10","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/h/tV/s517/c"},"text":"Pub. L. 105–277, div. A, § 101(h) [title V, § 517(c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-480"},"text":"112 Stat. 2681–480","children":[],"tail":", 2681–512; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tIII/s306"},"text":"Pub. L. 116–94, div. P, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3190"},"text":"133 Stat. 3190","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0df71266-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0df71267-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0df71268-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/259/s10"},"text":"section 10 of Pub. L. 102–259","children":[],"tail":" was renumbered section 12 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s5608"},"text":"section 5608 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0df71269-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “National Center” for “Institute”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" inserted before period at end “, including not to exceed $1,000 annually for official reception and representation expenses”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
