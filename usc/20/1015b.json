{"tag":"section","attrib":{"id":"id0cc3743c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1015b"},"text":"§ 1015b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Textbook information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cc3743d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose and intent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to ensure that students have access to affordable course materials by decreasing costs to students and enhancing transparency and disclosure with respect to the selection, purchase, sale, and use of course materials. It is the intent of this section to encourage all of the involved parties, including faculty, students, administrators, institutions of higher education, bookstores, distributors, and publishers, to work together to identify ways to decrease the cost of college textbooks and supplemental materials for students while supporting the academic freedom of faculty members to select high quality course materials for students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc3743e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc3743f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bundle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bundle” means one or more college textbooks or other supplemental materials that may be packaged together to be sold as course materials for one price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc37440-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" College textbook","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “college textbook” means a textbook or a set of textbooks, used for, or in conjunction with, a course in postsecondary education at an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc37441-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Course schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “course schedule” means a listing of the courses or classes offered by an institution of higher education for an academic period, as defined by the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc37442-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Custom textbook","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “custom textbook”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cc37443-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a college textbook that is compiled by a publisher at the direction of a faculty member or other person or adopting entity in charge of selecting course materials at an institution of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc37444-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include, alone or in combination, items such as selections from original instructor materials, previously copyrighted publisher materials, copyrighted third-party works, and elements unique to a specific institution, such as commemorative editions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc37445-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc37446-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated textbook","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “integrated textbook” means a college textbook that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cc37447-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combined with materials developed by a third party and that, by third-party contractual agreement, may not be offered by publishers separately from the college textbook with which the materials are combined; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc37448-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combined with other materials that are so interrelated with the content of the college textbook that the separation of the college textbook from the other materials would render the college textbook unusable for its intended purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc37449-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publisher","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “publisher” means a publisher of college textbooks or supplemental materials involved in or affecting interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc3744a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial content","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “substantial content” means parts of a college textbook such as new chapters, new material covering additional eras of time, new themes, or new subject matter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc3744b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental material","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “supplemental material” means educational material developed to accompany a college textbook that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cc3744c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include printed materials, computer disks, website access, and electronically distributed materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc3744d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not being used as a component of an integrated textbook.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc3744e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publisher requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc3744f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" College textbook pricing information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When a publisher provides a faculty member or other person or adopting entity in charge of selecting course materials at an institution of higher education receiving Federal financial assistance with information regarding a college textbook or supplemental material, the publisher shall include, with any such information and in writing (which may include electronic communications), the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cc37450-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The price at which the publisher would make the college textbook or supplemental material available to the bookstore on the campus of, or otherwise associated with, such institution of higher education and, if available, the price at which the publisher makes the college textbook or supplemental material available to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc37451-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The copyright dates of the three previous editions of such college textbook, if any.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc37452-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the substantial content revisions made between the current edition of the college textbook or supplemental material and the previous edition, if any.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc37453-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0cc37454-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the college textbook or supplemental material is available in any other format, including paperback and unbound; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0cc37455-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each other format of the college textbook or supplemental material, the price at which the publisher would make the college textbook or supplemental material in the other format available to the bookstore on the campus of, or otherwise associated with, such institution of higher education and, if available, the price at which the publisher makes such other format of the college textbook or supplemental material available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc37456-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unbundling of college textbooks from supplemental materials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A publisher that sells a college textbook and any supplemental material accompanying such college textbook as a single bundle shall also make available the college textbook and each supplemental material as separate and unbundled items, each separately priced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc37457-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Custom textbooks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, a publisher shall provide the information required under this subsection with respect to the development and provision of custom textbooks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc37458-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of ISBN college textbook information in course schedules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, each institution of higher education receiving Federal financial assistance shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc37459-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" disclose, on the institution’s Internet course schedule and in a manner of the institution’s choosing, the International Standard Book Number and retail price information of required and recommended college textbooks and supplemental materials for each course listed in the institution’s course schedule used for preregistration and registration purposes, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cc3745a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the International Standard Book Number is not available for such college textbook or supplemental material, then the institution shall include in the Internet course schedule the author, title, publisher, and copyright date for such college textbook or supplemental material; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc3745b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the institution determines that the disclosure of the information described in this subsection is not practicable for a college textbook or supplemental material, then the institution shall so indicate by placing the designation “To Be Determined” in lieu of the information required under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc3745c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, include on the institution’s written course schedule a notice that textbook information is available on the institution’s Internet course schedule, and the Internet address for such schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc3745d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of information for college bookstores","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education receiving Federal financial assistance shall make available to a college bookstore that is operated by, or in a contractual relationship or otherwise affiliated with, the institution, as soon as is practicable upon the request of such college bookstore, the most accurate information available regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc3745e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution’s course schedule for the subsequent academic period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc3745f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each course or class offered by the institution for the subsequent academic period—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cc37460-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required by subsection (d)(1) for each college textbook or supplemental material required or recommended for such course or class;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc37461-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of students enrolled in such course or class; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc37462-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum student enrollment for such course or class.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc37463-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution disclosing the information required by subsection (d)(1) is encouraged to disseminate to students information regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc37464-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available institutional programs for renting textbooks or for purchasing used textbooks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc37465-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available institutional guaranteed textbook buy-back programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc37466-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available institutional alternative content delivery programs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc37467-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other available institutional cost-saving strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc37468-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2013-07-01"},"text":"July 1, 2013","children":[],"tail":", the Comptroller General of the United States shall report to the authorizing committees on the implementation of this section by institutions of higher education, college bookstores, and publishers. The report shall particularly examine—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc37469-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of college textbook information on course schedules;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc3746a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of pricing information to faculty of institutions of higher education by publishers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc3746b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of bundled and unbundled material in the college textbook marketplace, including the adoption of unbundled materials by faculty and the use of integrated textbooks by publishers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc3746c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of this section by institutions of higher education, including the costs and benefits to such institutions and to students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc3746d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to supercede the institutional autonomy or academic freedom of instructors involved in the selection of college textbooks, supplemental materials, and other classroom materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc3746e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1015b/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No regulatory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not promulgate regulations with respect to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cc3746f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s133"},"text":"Pub. L. 89–329, title I, § 133","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tI/s112/a"},"text":"Pub. L. 110–315, title I, § 112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3107"},"text":"122 Stat. 3107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cc37470-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cc37471-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cc37472-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1015b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s133"},"text":"Pub. L. 89–329, title I, § 133","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tI/s101"},"text":"Pub. L. 102–325, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/466"},"text":"106 Stat. 466","children":[],"tail":", related to activities for which grants could be used, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1015b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s133"},"text":"Pub. L. 89–329, title I, § 133","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/482/tI/s101/g/3"},"text":"Pub. L. 94–482, title I, § 101(g)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2087"},"text":"90 Stat. 2087","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/43/s1/a/4"},"text":"Pub. L. 95–43, § 1(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-06-15"},"text":"June 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/213"},"text":"91 Stat. 213","children":[],"tail":", related to implementation of lifelong learning program by Assistant Secretary, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cc37473-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0cc37474-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/tI/s112/b"},"text":"Pub. L. 110–315, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3110"},"text":"122 Stat. 3110","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/315/tI/s112/b"},"text":"“The amendment made by subsection (a) [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0cc37475-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Establishment of Pilot Program for Course Material Rental","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s803"},"text":"Pub. L. 110–315, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3449"},"text":"122 Stat. 3449","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/315/tVIII/s803"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pilot Grant Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"From the amounts appropriated pursuant to subsection (e), the Secretary of Education (referred to in this section as the ‘Secretary’) shall make grants on a competitive basis to not more than ten institutions of higher education to support pilot programs that expand the services of bookstores to provide the option for students to rent course materials in order to achieve savings for students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An institution of higher education that desires to obtain a grant under this section shall submit an application to the Secretary at such time, in such form, and containing or accompanied by such information, agreements, and assurances as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The funds made available by a grant under this section may be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase of course materials that the entity will make available by rent to students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any equipment or software necessary for the conduct of a rental program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hiring staff needed for the conduct of a rental program, with priority given to hiring enrolled undergraduate students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building or acquiring extra storage space dedicated to course materials for rent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluation and Report.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluations by recipients","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After a period of time to be determined by the Secretary, each institution of higher education that receives a grant under this section shall submit a report to the Secretary on the effectiveness of their rental programs in reducing textbook costs for students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2010-09-30"},"text":"September 30, 2010","children":[],"tail":", the Secretary shall submit a report to Congress on the effectiveness of the textbook rental pilot programs under this section, and identify the best practices developed in such pilot programs. Such report shall contain an estimate by the Secretary of the savings achieved by students who participate in such pilot programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal years 2009 and 2010.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
