{"tag":"section","attrib":{"id":"id0cf33782-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070d–31"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070d–31"},"text":"§ 1070d–31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the purpose of this subpart to establish a Robert C. Byrd Honors Scholarship Program to promote student excellence and achievement and to recognize exceptionally able students who show promise of continued excellence.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0cf33783-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s419A"},"text":"Pub. L. 89–329, title IV, § 419A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s401/a"},"text":"Pub. L. 99–498, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1343"},"text":"100 Stat. 1343","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cf33784-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cf33785-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cf33786-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1070d–31, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s419A"},"text":"Pub. L. 89