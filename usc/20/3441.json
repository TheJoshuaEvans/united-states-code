101/e/tVII/s709/b/2/B"},"text":"Pub. L. 104–208, § 101(e) [title VII, § 709(b)(2)(B)]","children":[],"tail":", redesignated pars. (5) to (7) as (4) to (6), respectively, and struck out former par. (4) which transferred the offices, etc., of the Institute of Museum Services of the Department of Health, Education, and Welfare to the Department of Education."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(2)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/476"},"text":"Pub. L. 101–476","children":[],"tail":" substituted “Individuals with Disabilities Education Act” for “Education of the Handicapped Act”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dd819ea-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id0dd819eb-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Gallaudet College, referred to in subsec. (a)(2)(M), redesignated Gallaudet University by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/371/tI/s101/a"},"text":"Pub. L. 99–371, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-04"},"text":"Aug. 4, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/781"},"text":"100 Stat. 781","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4301/a"},"text":"section 4301(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0dd819ec-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 19