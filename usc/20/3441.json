9/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq.], except that the provisions of this subparagraph shall not be construed to transfer to the Secretary the functions of the Secretary of Health, Education, and Welfare under sections 222 and 1615 of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s422"},"text":"42 U.S.C. 422","children":[],"tail":" and 1382d];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dd819d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3441/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all functions with respect to or being administered by the Secretary of Health, Education, and Welfare through the Commissioner of Rehabilitation Services under the Act of ","children":[{"tag":"date","attrib":{"date":"1936-06-20"},"text":"June 20, 1936","children":[],"tail":", commonly referred to as the Randolph-Sheppard Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s107"},"text":"20 U.S.C. 107","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dd819d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3441/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all functions of the Commissioner of Rehabilitation and the Director of the National Institute of Handicapped Research of the Department of Health, Education, and Welfare under the Rehabilitation Act of 1973 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dd819d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3441/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":