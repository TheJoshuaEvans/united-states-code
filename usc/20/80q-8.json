{"tag":"section","attrib":{"id":"id0c87f25b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"80q–8"},"text":"§ 80q–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Regents functions with respect to certain agreements and programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c87f25c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority to be given to Indian organizations with respect to certain agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In entering into agreements with museums and other educational and cultural organizations to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c87f25d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–8/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lend Native American artifacts and objects from any collection of the Smithsonian Institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f25e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–8/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sponsor or coordinate traveling exhibitions of artifacts and objects; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f25f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–8/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training or technical assistance;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Board of Regents shall give priority to agreements with Indian organizations, including Indian tribes, museums, cultural centers, educational institutions, libraries, and archives. Such agreements may provide that loans or services to such organizations may be furnished by the Smithsonian Institution at minimal or no cost.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c87f260-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Regents may establish—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c87f261-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–8/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to serve Indian tribes and communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c87f262-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–8/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with educational institutions, including tribally controlled colleges or universities (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801/a"},"text":"section 1801(a) of title 25","children":[],"tail":"), programs to enhance the opportunities for Indians in the areas of museum studies, management, and research."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c87f263-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Museum Management Fellowships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Regents shall establish an Indian Museum Management Fellowship program to provide stipend support to Indians for training in museum development and management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c87f264-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80q–8/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $2,000,000 for each fiscal year, beginning with fiscal year 1991, to carry out subsections (b) and (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c87f265-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/185/s10"},"text":"Pub. L. 101–185, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1342"},"text":"103 Stat. 1342","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s901/d"},"text":"Pub. L. 105–244, title IX, § 901(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1828"},"text":"112 Stat. 1828","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s941/k/2/B"},"text":"Pub. L. 110–315, title IX, § 941(k)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3465"},"text":"122 Stat. 3465","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c87f266-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c87f267-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c87f268-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" substituted “tribally controlled colleges or universities (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801/a"},"text":"section 1801(a) of title 25","children":[],"tail":")” for “tribally controlled community colleges (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801"},"text":"section 1801 of title 25","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801"},"text":"section 1801 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c87f269-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAm