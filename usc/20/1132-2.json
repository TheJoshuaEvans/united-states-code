{"tag":"section","attrib":{"id":"id0d740093-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1132–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1132–2"},"text":"§ 1132–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to authorize the Secretary to mandate, direct, or control an institution of higher education’s specific instructional content, curriculum, or program of instruction.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d740094-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVI/s633"},"text":"Pub. L. 89–329, title VI, § 633","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVI/s622"},"text":"Pub. L. 110–315, title VI, § 622","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3343"},"text":"122 Stat. 3343","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
