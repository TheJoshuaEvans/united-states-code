{"tag":"section","attrib":{"id":"id0cfa63cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1076"},"text":null,"children":[{"tag":"num","attrib":{"value":"1076"},"text":"§ 1076.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sources of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Loans made by eligible lenders in accordance with this part shall be insurable by the Secretary whether made from funds fully owned by the lender or from funds held by the lender in a trust or similar capacity and available for such loans.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0cfa63d0-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s426"},"text":"Pub. L. 89–329, title IV, § 426","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tIV/s402/a"},"text":"Pub. L. 99–498, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1361"},"text":"100 Stat. 1361","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cfa63d1-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cfa63d2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cfa63d3-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1076, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s426"},"text":"Pub. L. 89–329, t