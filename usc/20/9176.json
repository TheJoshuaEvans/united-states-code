{"tag":"section","attrib":{"id":"id0e5d9d56-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9176"},"text":null,"children":[{"tag":"num","attrib":{"value":"9176"},"text":"§ 9176.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e5d9d57-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9176/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this subchapter, there are authorized to be appropriated to the Director $38,600,000 for each of the fiscal years 2020 through 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e5d9d58-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9176/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sums remaining available","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sums appropriated pursuant to subsection (a) for any fiscal year shall remain available for obligation until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e5d9d59-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9176/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subchapter, if the amount appropriated under subsection (a) for a fiscal year is greater than the amount appropriated under such subsection for fiscal year 2020 by more than $10,000,000, then an amount of not less than 30 percent but not more than 50 percent of the increase in appropriated funds shall be available, from the funds appropriated under such subsection for the fiscal year, to enter into arrangements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9173"},"text":"section 9173 of this title","children":[],"tail":" to carry out the State assessments described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9173/a/4"},"text":"section 9173(a)(4) of this title","children":[],"tail":" and to assist States in the implementation of such plans."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e5d9d5a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/tII/s276"},"text":"Pub. L. 94–462, title II, § 276","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/e/tVII/s702"},"text":"Pub. L. 104–208, div. A, title I, § 101(e) [title VII, § 702]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-233"},"text":"110 Stat. 3009–233","children":[],"tail":", 3009–306; renumbered § 275 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/81/tIII/s305"},"text":"Pub. L. 108–81, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-25"},"text":"Sept. 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1002"},"text":"117 Stat. 1002","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/340/tIII/s304"},"text":"Pub. L. 111–340, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3604"},"text":"124 Stat. 3604","children":[],"tail":"; renumbered § 276 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/410"},"text":"Pub. L. 115–410","children":[],"tail":", §§ 19(1), 20, "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5421"},"text":"132 Stat. 5421","children":[],"tail":", 5422.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e5d9d5b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e5d9d5c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e5d9d5d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/410/s20/1"},"text":"Pub. L. 115–410, § 20(1)","children":[],"tail":", substituted “each of the fiscal years 2020 through 2025” for “fiscal year 2011 and such sums as may be necessary for each of the fiscal years 2012 through 2016”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/410/s20/2"},"text":"Pub. L. 115–410, § 20(2)","children":[],"tail":", substituted “fiscal year 2020” for “fiscal year 2011”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/340/s304/1"},"text":"Pub. L. 111–340, § 304(1)","children":[],"tail":", added subsec. (a) and struck out heading and text of former subsec. (a). Prior to amendment, text read as follows: “For the purpose of carrying out this subchapter, there are authorized to be appropriated to the Director $38,600,000 for fiscal year 2004 and such sums as may be necessary for fiscal years 2005 through 2009.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/340/s304/2"},"text":"Pub. L. 111–340, § 304(2)","children":[],"tail":", (3), redesignated subsec. (c) as (b) and struck out heading and text of former subsec. (b). Prior to amendment, text of former subsec. (b) read as follows: “Not more than 10 percent of the funds appropriated under this section for a fiscal year may be used to pay for the administrative costs of carrying out this subchapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/340/s304/4"},"text":"Pub. L. 111–340, § 304(4)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/81/s305/1"},"text":"Pub. L. 108–81, § 305(1)","children":[],"tail":", substituted “$38,600,000 for fiscal year 2004 and such sums as may be necessary for fiscal years 2005 through 2009.” for “$28,700,000 for the fiscal year 1997, and such sums as may be necessary for each of the fiscal years 1998 through 2002.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e5d9d5e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e5d9d5f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/81"},"text":"Pub. L. 108–81","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2003-10-01"},"text":"Oct. 1, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/81/s506"},"text":"section 506 of Pub. L. 108–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9101"},"text":"section 9101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
