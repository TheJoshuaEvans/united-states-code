{"tag":"section","attrib":{"id":"id0cee7c52-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070b–4"},"text":"§ 1070b–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover and carryback authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cee7c53-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the sums made available to an eligible institution under this subpart for a fiscal year, not more than 10 percent may, at the discretion of the institution, remain available for expenditure during the succeeding fiscal year to carry out the program under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cee7c54-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryback authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cee7c55-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the sums made available to an eligible institution under this subpart for a fiscal year, not more than 10 percent may, at the discretion of the institution, be used by the institution for expenditure for the fiscal year preceding the fiscal year for which the sums were appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cee7c56-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1070b–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of carried-back funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible institution may make grants to students after the end of the academic year, but prior to the beginning of the succeeding fiscal year, from such succeeding fiscal year’s appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cee7c57-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s413E"},"text":"Pub. L. 89–329, title IV, § 413E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIV/s406/d"},"text":"Pub. L. 105–244, title IV, § 406(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1665"},"text":"112 Stat. 1665","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cee7c58-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0cee7c59-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0cee7c5a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
