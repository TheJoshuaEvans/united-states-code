{"tag":"section","attrib":{"id":"id0e00b025-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b"},"text":null,"children":[{"tag":"num","attrib":{"value":"6303b"},"text":"§ 6303b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct student services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e00b026-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State reservation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e00b027-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e00b028-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State educational agency, after meaningful consultation with geographically diverse local educational agencies described in subparagraph (B), may reserve not more than 3 percent of the amount the State educational agency receives under subpart 2 of part A for each fiscal year to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b029-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State educational agency shall consult under subparagraph (A) with local educational agencies that include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e00b02a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suburban, rural, and urban local educational agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e00b02b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local educational agencies serving a high percentage of schools identified by the State for comprehensive support and improvement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/c/4/D/i"},"text":"section 6311(c)(4)(D)(i) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e00b02c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local educational agencies serving a high percentage of schools implementing targeted support and improvement plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d/2"},"text":"section 6311(d)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b02d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds reserved under paragraph (1)(A), the State educational agency may use not more than 1 percent to administer the program described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e00b02e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e00b02f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount reserved under subsection (a) by a State educational agency, the State educational agency shall award grants to geographically diverse local educational agencies described in subsection (a)(1)(B)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b030-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making such awards, the State educational agency shall prioritize awards to local educational agencies serving the highest percentage of schools, as compared to other local educational agencies in the State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e00b031-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified by the State for comprehensive support and improvement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/c/4/D/i"},"text":"section 6311(c)(4)(D)(i) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b032-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing targeted support and improvement plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d/2"},"text":"section 6311(d)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e00b033-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A local educational agency receiving an award under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e00b034-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use not more than 1 percent of its award for outreach and communication to parents about available direct student services described in paragraph (3) in the local educational agency and State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b035-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use not more than 2 percent of its award for administrative costs related to such direct student services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b036-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall use the remainder of the award to pay the costs associated with one or more of the following direct student services—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e00b037-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enrollment and participation in academic courses not otherwise available at a student’s school, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e00b038-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced courses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e00b039-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" career and technical education coursework that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0e00b03a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/c/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is aligned with the challenging State academic standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0e00b03b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/c/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leads to industry-recognized credentials that meet the quality criteria established by the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3153/a"},"text":"section 3153(a) of title 29","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b03c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credit recovery and academic acceleration courses that lead to a regular high school diploma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b03d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities that assist students in successfully completing postsecondary level instruction and examinations that are accepted for credit at institutions of higher education (including Advanced Placement and International Baccalaureate courses), which may include reimbursing low-income students to cover part or all of the costs of fees for such examinations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b03e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" components of a personalized learning approach, which may include high-quality academic tutoring; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b03f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a local educational agency that does not reserve funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d/1/D/v"},"text":"section 6311(d)(1)(D)(v) of this title","children":[],"tail":", transportation to allow a student enrolled in a school identified for comprehensive support and improvement under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/c/4/D/i"},"text":"section 6311(c)(4)(D)(i) of this title","children":[],"tail":" to transfer to another public school (which may include a charter school) that has not been identified by the State under such section; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b040-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in paying the costs associated with the direct student services described in paragraph (3), shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e00b041-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first, pay such costs for students who are enrolled in schools identified by the State for comprehensive support and improvement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/c/4/D/i"},"text":"section 6311(c)(4)(D)(i) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b042-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" second, pay such costs for low-achieving students who are enrolled in schools implementing targeted support and improvement plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d/2"},"text":"section 6311(d)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b043-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with any remaining funds, pay such costs for other low-achieving students served by the local educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e00b044-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A local educational agency desiring to receive an award under subsection (b) shall submit an application to the State educational agency at such time and in such manner as the State educational agency shall require. At a minimum, each application shall describe how the local educational agency will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e00b045-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide adequate outreach to ensure parents can exercise a meaningful choice of direct student services for their child’s education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b046-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure parents have adequate time and information to make a meaningful choice prior to enrolling their child in a direct student service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b047-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a local educational agency offering public school choice under this section, ensure sufficient availability of seats in the public schools the local educational agency will make available for public school choice options;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b048-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize services to students who are lowest-achieving;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b049-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" select providers of direct student services, which may include one or more of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e00b04a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local educational agency or other local educational agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b04b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community colleges or other institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b04c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" non-public entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b04d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/d/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based organizations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b04e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/d/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of high-quality academic tutoring, a variety of providers of such tutoring that are selected and approved by the State and appear on the State’s list of such providers required under subsection (e)(2);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b04f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the provision of direct student services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b050-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publicly report the results of direct student service providers in improving relevant student outcomes in a manner that is accessible to parents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e00b051-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Providers and schools","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State educational agency that reserves an amount under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e00b052-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that each local educational agency that receives an award under this section and intends to provide public school choice under subsection (c)(3)(E) can provide a sufficient number of options to provide a meaningful choice for parents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b053-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" compile and maintain an updated list of State-approved high-quality academic tutoring providers that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e00b054-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is developed using a fair negotiation and rigorous selection and approval process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b055-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides parents with meaningful choices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b056-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers a range of tutoring models, including online and on campus; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e00b057-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes only providers that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e00b058-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/e/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a demonstrated record of success in increasing students’ academic achievement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e00b059-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/e/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with all applicable Federal, State, and local health, safety, and civil rights laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e00b05a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/e/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide instruction and content that is secular, neutral, and non-ideological;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b05b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that each local educational agency receiving an award is able to provide an adequate number of high-quality academic tutoring options to ensure parents have a meaningful choice of services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b05c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement procedures for monitoring the quality of services provided by direct student service providers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e00b05d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6303b/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and implement clear criteria describing the course of action for direct student service providers that are not successful in improving student academic outcomes, which, for a high-quality academic tutoring provider, may include a process to remove State approval under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e00b05e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1003A"},"text":"Pub. L. 89–10, title I, § 1003A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1004"},"text":"Pub. L. 114–95, title I, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1817"},"text":"129 Stat. 1817","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e00b05f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e00b060-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e00b061-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
