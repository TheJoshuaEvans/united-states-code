{"tag":"section","attrib":{"id":"id0dc77761-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2412"},"text":null,"children":[{"tag":"num","attrib":{"value":"2412"},"text":"§ 2412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds to induce out-of-State relocation of businesses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No funds provided under this chapter shall be used for the purpose of directly providing incentives or inducements to an employer to relocate a business enterprise from one State to another State if such relocation will result in a reduction in the number of jobs available in the State where the business enterprise is located before such incentives or inducements are offered.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0dc77762-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tII/s222"},"text":"Pub. L. 88–210, title II, § 222","children":[],"tail":", formerly title III, § 322, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/745"},"text":"120 Stat. 745","children":[],"tail":"; renumbered title II, § 222, "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/tII/s201/a/5"},"text":"Pub. L. 115–224, title II, § 201(a)(5)","children":[],"tail":", (7), "},{"tag":"date","attrib":{"date":"2018-07-31"},"text":"July 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1621"},"text":"132 Stat. 1621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dc77763-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":