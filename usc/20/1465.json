{"tag":"section","attrib":{"id":"id0daf824d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465"},"text":null,"children":[{"tag":"num","attrib":{"value":"1465"},"text":"§ 1465.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim alternative educational settings, behavioral supports, and systemic school interventions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0daf824e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award grants, and enter into contracts and cooperative agreements, to support safe learning environments that support academic achievement for all students by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf824f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the quality of interim alternative educational settings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf8250-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing increased behavioral supports and research-based, systemic interventions in schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf8251-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary may support activities to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf8252-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish, expand, or increase the scope of behavioral supports and systemic interventions by providing for effective, research-based practices, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf8253-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training for school staff on early identification, prereferral, and referral procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8254-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training for administrators, teachers, related services personnel, behavioral specialists, and other school staff in positive behavioral interventions and supports, behavioral intervention planning, and classroom and student management techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8255-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" joint training for administrators, parents, teachers, related services personnel, behavioral specialists, and other school staff on effective strategies for positive behavioral interventions and behavior management strategies that focus on the prevention of behavior problems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8256-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing or implementing specific curricula, programs, or interventions aimed at addressing behavioral problems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8257-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stronger linkages between school-based services and community-based resources, such as community mental health and primary care providers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8258-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using behavioral specialists, related services personnel, and other staff necessary to implement behavioral supports; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf8259-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improve interim alternative educational settings by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf825a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the training of administrators, teachers, related services personnel, behavioral specialists, and other school staff (including ongoing mentoring of new teachers) in behavioral supports and interventions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf825b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attracting and retaining a high quality, diverse staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf825c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for referral to counseling services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf825d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilizing research-based interventions, curriculum, and practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf825e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowing students to use instructional technology that provides individualized instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf825f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that the services are fully consistent with the goals of the individual student’s IEP;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8260-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting effective case management and collaboration among parents, teachers, physicians, related services personnel, behavioral specialists, principals, administrators, and other school staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8261-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting interagency coordination and coordinated service delivery among schools, juvenile courts, child welfare agencies, community mental health providers, primary care providers, public recreation agencies, and community-based organizations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8262-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for behavioral specialists to help students transitioning from interim alternative educational settings reintegrate into their regular classrooms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf8263-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible entity” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf8264-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf8265-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a consortium consisting of a local educational agency and 1 or more of the following entities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf8266-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Another local educational agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8267-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A community-based organization with a demonstrated record of effectiveness in helping children with disabilities who have behavioral challenges succeed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8268-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf8269-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A community mental health provider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf826a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An educational service agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf826b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any eligible entity that wishes to receive a grant, or enter into a contract or cooperative agreement, under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf826c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf826d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve parents of participating students in the design and implementation of the activities funded under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf826e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1465/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report and evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity receiving a grant under this section shall prepare and submit annually to the Secretary a report on the outcomes of the activities assisted under the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0daf826f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s665"},"text":"Pub. L. 91–230, title VI, § 665","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2786"},"text":"118 Stat. 2786","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
