{"tag":"section","attrib":{"id":"id0e3777a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7451"},"text":null,"children":[{"tag":"num","attrib":{"value":"7451"},"text":"§ 7451.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National research activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e3777aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7451/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may use funds made available to carry out this subpart for each fiscal year to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3777ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7451/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research related to effective approaches for the education of Indian children and adults;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3777ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7451/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate federally assisted education programs from which Indian children and adults may benefit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3777ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7451/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and analyze data on the educational status and needs of Indians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e3777ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7451/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out other activities that are consistent with the purpose of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3777af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7451/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may carry out any of the activities described in subsection (a) directly or through grants to, or contracts or cooperative agreements with, Indian tribes, Indian organizations, State educational agencies, local educational agencies, institutions of higher education, including Indian institutions of higher education, and other public and private agencies and institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e3777b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7451/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Research activities supported under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e3777b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7451/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be carried out in consultation with the Institute of Education Sciences to ensure that such activities are coordinated with and enhance the research and development activities supported by the Institute; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e39e7b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7451/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include collaborative research activities that are jointly funded and carried out by the Office of Indian Education Programs, the Bureau of Indian Education, and the Institute of Education Sciences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e39e7b3-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6131"},"text":"Pub. L. 89–10, title VI, § 6131","children":[],"tail":", formerly title VII, § 7131, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1923"},"text":"115 Stat. 1923","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/279/tIV/s404/d/5/E"},"text":"Pub. L. 107–279, title IV, § 404(d)(5)(E)","children":[],"tail":", (8), "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1986"},"text":"116 Stat. 1986","children":[],"tail":"; renumbered title VI, § 6131, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI"},"text":"Pub. L. 114–95, title VI","children":[],"tail":", §§ 6001(a), (b)(1), 6002(m), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":", 2057.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e39e7b4-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e39e7b5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e39e7b6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7451, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVII/s7131"},"text":"Pub. L. 89–10, title VII, § 7131","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3729"},"text":"108 Stat. 3729","children":[],"tail":", authorized research, evaluation of activities, and dissemination of information, prior to the general amendment of former subchapter VII of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s6131"},"text":"section 6131 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7311"},"text":"section 7311 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e39e7b7-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref