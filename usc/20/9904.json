{"tag":"section","attrib":{"id":"id0e6e66bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904"},"text":null,"children":[{"tag":"num","attrib":{"value":"9904"},"text":"§ 9904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant oversight and administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e6e66be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may execute a contract for program oversight and fiscal management with an organization at an institution of higher education, a non-profit organization, or other entity that demonstrates capacity for and experience in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6e66bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" replicating 1 or more similar programs at regional or national levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6e66c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing programmatic and technical implementation assistance for the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6e66c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing data collection and analysis to ensure proper implementation and continuous program improvement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6e66c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing accountability for results by measuring and monitoring achievement of programmatic milestones.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6e66c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight responsibilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6e66c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Director executes a contract under subsection (a) with an organization for program oversight and fiscal management, the organization shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6e66c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that a grant recipient faithfully replicates and implements the program or programs for which the grant is awarded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6e66c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that grant funds are used for the purposes authorized and that a grant recipient has a system in place to track and account for all Federal grant funds provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6e66c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to grant recipients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6e66c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collect and analyze data and report to the Director annually on the effects of the program on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e6e66c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress of participating students in achieving teaching competence and teaching certification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e6e66ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participation of students in the program by major, compared with local and State needs on secondary teachers by discipline; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e6e66cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/b/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participation of students in the program by demographic subgroup;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6e66cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and analyze data and report to the Director annually on the effects of the program on the academic achievement of elementary and secondary school students taught by graduates of programs funded by grants under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6e66cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit an annual report to the Director demonstrating compliance with the requirements of subparagraphs (A) through (E).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6e66ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of the Director, the organization under contract under subsection (a) may assist the Director in evaluating grant applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6e66cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall submit a copy of the annual report required by subsection (b)(1)(F) to the Senate Committee on Commerce, Science, and Transportation, the Senate Committee on Health, Education, Labor, and Pensions, the House of Representatives Committee on Science and Technology, and the House of Representatives Committee on Education and Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e6e66d0-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/tV/s554"},"text":"Pub. L. 111–358, title V, § 554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4024"},"text":"124 Stat. 4024","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e6e66d1-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e6e66d2-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id0e6e66d3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Science and Technology of House of Representatives changed to Committee on Science, Space, and Technology of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, ","children":[{"tag":"date","attrib":{"date":"2011-01-05"},"text":"Jan. 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
