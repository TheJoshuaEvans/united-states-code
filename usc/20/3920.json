{"tag":"section","attrib":{"id":"id0de18eeb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3920"},"text":null,"children":[{"tag":"num","attrib":{"value":"3920"},"text":"§ 3920.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds to carry out this subchapter for any fiscal year shall be made available from amounts appropriated pursuant to annual authorizations of appropriations for the National Science Foundation for Science and Engineering Education. For fiscal year 1986, funds to carry out this subchapter shall be available from amounts authorized by section 102(a)(8) of the National Science Foundation Authorization Act for fiscal year 1986.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0de18eec-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tI/s110"},"text":"Pub. L. 98–377, title I, § 110","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tII/s201"},"text":"Pub. L. 99–159, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/897"},"text":"99 Stat. 897","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de18eed-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de18eee-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0de18eef-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 102(a)(8) of the National Science Foundation Authorization Act for fiscal year 1986, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/159/s102/a/8"},"text":"section 102(a)(8) of Pub. L. 99–159","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/887"},"text":"99 Stat. 887","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
