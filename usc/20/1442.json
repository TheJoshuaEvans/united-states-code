{"tag":"section","attrib":{"id":"id0daac871-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1442"},"text":null,"children":[{"tag":"num","attrib":{"value":"1442"},"text":"§ 1442.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal administration","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Sections 1416, 1417, and 1418 of this title shall, to the extent not inconsistent with this subchapter, apply to the program authorized by this subchapter, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daac872-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1442/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference in such sections to a State educational agency shall be considered to be a reference to a State’s lead agency established or designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1435/a/10"},"text":"section 1435(a)(10) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daac873-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1442/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference in such sections to a local educational agency, educational service agency, or a State agency shall be considered to be a reference to an early intervention service provider under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daac874-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1442/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference to the education of children with disabilities or the education of all children with disabilities shall be considered to be a reference to the provision of appropriate early intervention services to infants and toddlers with disabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0daac875-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s642"},"text":"Pub. L. 91–230, title VI, § 642","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2760"},"text":"118 Stat. 2760","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0daac876-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0daac877-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0daac878-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1442, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s642"},"text":"Pub. L. 91–230, title VI, § 642","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tI/s101"},"text":"Pub. L. 105–17, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June 4, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/118"},"text":"111 Stat. 118","children":[],"tail":", related to Federal administration, prior to the general amendment of subchapters I to IV of this chapter by "},{"tag":"ref","attrib":{"href":"/us