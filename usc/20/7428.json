{"tag":"section","attrib":{"id":"id0e377733-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7428"},"text":null,"children":[{"tag":"num","attrib":{"value":"7428"},"text":"§ 7428.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e377734-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7428/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsections (b) and (c), the Secretary shall pay to each local educational agency that submits an application that is approved by the Secretary under this subpart the amount determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7423"},"text":"section 7423 of this title","children":[],"tail":". The Secretary shall notify the local educational agency of the amount of the payment not later than June 1 of the year for which the Secretary makes the payment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e377735-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7428/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments taken into account by the State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under this subpart to a local educational agency for a fiscal year if, for such fiscal year, the State in which the local educational agency is located takes into consideration payments made under this chapter ","children":[{"tag":"ref","attrib":{"idref":"fn002224"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002224"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “this subpart”."}],"tail":" in determining the eligibility of the local educational agency for State aid, or the amount of the State aid, with respect to the free public education of children during such fiscal year or the preceding fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e377736-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7428/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of payment for failure to maintain fiscal effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each local educational agency shall maintain fiscal effort in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7901"},"text":"section 7901 of this title","children":[],"tail":" or be subject to reduced payments under this subpart in accordance with such "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7901"},"text":"section 7901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e377737-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7428/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may reallocate, in a manner that the Secretary determines will best carry out the purpose of this subpart, any amounts that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e377738-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7428/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on estimates made by local educational agencies or other information, the Secretary determines will not be needed by such agencies to carry out approved programs under this subpart; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e377739-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7428/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise become available for reallocation under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e37773a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVI/s6118"},"text":"Pub. L. 89–10, title VI, § 6118","children":[],"tail":", formerly title VII, § 7118, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tVII/s701"},"text":"Pub. L. 107–110, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1918"},"text":"115 Stat. 1918","children":[],"tail":"; renumbered title VI, § 6118, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVI"},"text":"Pub. L. 114–95, title VI","children":[],"tail":", §§ 6001(a), (b)(1), (8), 6002(j), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2046"},"text":"129 Stat. 2046","children":[],"tail":", 2047, 2054.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e37773b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e37773c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e37773d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7428, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVII/s7118"},"text":"Pub. L. 89–10, title VII, § 7118","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3727"},"text":"108 Stat. 3727","children":[],"tail":", related to capacity building, prior to the general amendment of former subchapter VII of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e37773e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6001/b/8"},"text":"Pub. L. 114–95, § 6001(b)(8)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7423"},"text":"section 7423 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6002/j"},"text":"Pub. L. 114–95, § 6002(j)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which related to reduction of payment for failure to maintain fiscal effort with possibility of temporary waiver."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e37773f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e377740-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
