{"tag":"section","attrib":{"id":"id0dc04bf6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327"},"text":null,"children":[{"tag":"num","attrib":{"value":"2327"},"text":"§ 2327.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribally controlled postsecondary career and technical institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dc04bf7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Secretary shall make grants under this section, to provide basic support for the education and training of Indian students, to tribally controlled postsecondary career and technical institutions that are not receiving Federal assistance as of the date on which the grant is provided under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc04bf8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title I of the Tribally Controlled Colleges and Universities Assistance Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1802"},"text":"25 U.S.C. 1802","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc04bf9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Navajo Community College Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/189"},"text":"Public Law 92–189","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/85/646"},"text":"85 Stat. 646","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc04bfa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available under this section shall be used for career and technical education programs for Indian students and for the institutional support costs of the grant, including the expenses described in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc04bfb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc04bfc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the sums appropriated for any fiscal year for grants under this section are not sufficient to pay in full the total amount which approved applicants are eligible to receive under this section for such fiscal year, the Secretary shall first allocate to each such applicant who received funds under this part for the preceding fiscal year an amount equal to 100 percent of the product of the per capita payment for the preceding fiscal year and such applicant’s Indian student count for the current program year, plus an amount equal to the actual cost of any increase to the per capita figure resulting from inflationary increases to necessary costs beyond the institution’s control.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc04bfd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Per capita determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of paragraph (1), the per capita payment for any fiscal year shall be determined by dividing the amount available for grants to tribally controlled postsecondary career and technical institutions under this section for such program year by the sum of the Indian student counts of such institutions for such program year. The Secretary shall, on the basis of the most accurate data available from the institutions, compute the Indian student count for any fiscal year for which such count was not used for the purpose of making allocations under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc04bfe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indirect costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law or regulation, the Secretary shall not require the use of a restricted indirect cost rate for grants issued under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc04bff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, a tribally controlled postsecondary career and technical institution that is not receiving Federal assistance under title I of the Tribally Controlled Colleges and Universities Assistance Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1802"},"text":"25 U.S.C. 1802","children":[],"tail":" et seq.) or the Navajo Community College Act ("},{"tag":"ref","attrib":{"href":"/us/pl/92/189"},"text":"Public Law 92–189","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/85/646"},"text":"85 Stat. 646","children":[],"tail":") shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc04c00-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc04c01-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, subject to the availability of appropriations, provide for each program year to each tribally controlled postsecondary career and technical institution having an application approved by the Secretary, an amount necessary to pay expenses associated with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dc04c02-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance and operation of the program, including development costs, costs of basic and special instruction (including special programs for individuals with disabilities and academic instruction), materials, student costs, administrative expenses, boarding costs, transportation, student services, daycare and family support programs for students and their families (including contributions to the costs of education for dependents), and student stipends;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc04c03-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital expenditures, including operations and maintenance, and minor improvements and repair, and physical plant maintenance costs, for the conduct of programs funded under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc04c04-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs associated with repair, upkeep, replacement, and upgrading of the instructional equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc04c05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutional support of career and technical education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc04c06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each institution receiving a grant under this section shall provide annually to the Secretary an accurate and detailed accounting of the institution’s operating and maintenance expenses and such other information concerning costs as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc04c07-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc04c08-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as specifically provided in this chapter, eligibility for assistance under this section shall not preclude any tribally controlled postsecondary career and technical institution from receiving Federal financial assistance under any program authorized under the Higher Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"20 U.S.C. 1001","children":[],"tail":" et seq.], or under any other applicable program for the benefit of institutions of higher education or career and technical education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc04c09-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on alteration of grant amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any grant for which tribally controlled postsecondary career and technical institutions are eligible under this section shall not be altered because of funds allocated to any such institution from funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc04c0a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on contract denial","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tribally controlled postsecondary career and technical institution for which an Indian Tribe has designated a portion of the funds appropriated for the Tribe from funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s13"},"text":"section 13 of title 25","children":[],"tail":", may be denied a contract for such portion under the Indian Self-Determination and Education Assistance Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.] (except as provided in that Act), or denied appropriate contract support to administer such portion of the appropriated funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc04c0b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complaint resolution procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish (after consultation with tribally controlled postsecondary career and technical institutions) a complaint resolution procedure for grant determinations and calculations under this section for tribally controlled postsecondary career and technical institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc04c0c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc04c0d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian; Indian Tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Indian” and “Indian Tribe” have the meanings given the terms “Indian” and “Indian tribe”, respectively, in section 2 of the Tribally Controlled Colleges and Universities Assistance Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1801"},"text":"25 U.S.C. 1801","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc04c0e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian student count","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dc04c0f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian student count” means a number equal to the total number of Indian students enrolled in each tribally controlled postsecondary career and technical institution, as determined in accordance with subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc04c10-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0dc04c11-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each academic year, the Indian student count shall be determined on the basis of the enrollments of Indian students as in effect at the conclusion of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0dc04c12-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/h/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the fall term, the third week of the fall term; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0dc04c13-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/h/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the spring term, the third week of the spring term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dc04c14-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each academic year, the Indian student count for a tribally controlled postsecondary career and technical institution shall be the quotient obtained by dividing—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0dc04c15-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/h/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the credit hours of all Indian students enrolled in the tribally controlled postsecondary career and technical institution (as determined under clause (i)); by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0dc04c16-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/h/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 12.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dc04c17-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/h/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summer term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any credit earned in a class offered during a summer term shall be counted in the determination of the Indian student count for the succeeding fall term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dc04c18-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/h/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Students without secondary school degrees","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0dc04c19-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/h/2/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A credit earned at a tribally controlled postsecondary career and technical institution by any Indian student that has not obtained a secondary school degree (or the recognized equivalent of such a degree) shall be counted toward the determination of the Indian student count if the institution at which the student is enrolled has established criteria for the admission of the student on the basis of the ability of the student to benefit from the education or training of the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0dc04c1a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/h/2/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The institution shall be presumed to have established the criteria described in subclause (I) if the admission procedures for the institution include counseling or testing that measures the aptitude of a student to successfully complete a course in which the student is enrolled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0dc04c1b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/h/2/B/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits toward secondary school degree","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No credit earned by an Indian student for the purpose of obtaining a secondary school degree (or the recognized equivalent of such a degree) shall be counted toward the determination of the Indian student count under this clause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0dc04c1c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/h/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing education programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any credit earned by an Indian student in a continuing education program of a tribally controlled postsecondary career and technical institution shall be included in the determination of the sum of all credit hours of the student if the credit is converted to a credit hour basis in accordance with the system of the institution for providing credit for participation in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc04c1d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc04c1e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $9,762,539 for fiscal year 2019;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc04c1f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $9,899,215 for fiscal year 2020;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc04c20-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,037,804 for fiscal year 2021;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc04c21-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,178,333 for fiscal year 2022;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc04c22-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,320,829 for fiscal year 2023; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc04c23-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2327/i/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,465,321 for fiscal year 2024.","children":[]