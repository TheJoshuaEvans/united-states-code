{"tag":"section","attrib":{"id":"id0d7b2c17-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138"},"text":null,"children":[{"tag":"num","attrib":{"value":"1138"},"text":"§ 1138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund for the Improvement of Postsecondary Education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d7b2c18-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to make grants to, or enter into contracts with, institutions of higher education, combinations of such institutions, and other public and private nonprofit institutions and agencies, to enable such institutions, combinations, and agencies to improve postsecondary education opportunities by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7b2c19-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the encouragement of reform and improvement of, and innovation in, postsecondary education and the provision of educational opportunity for all students, including nontraditional students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c1a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the creation of institutions, programs, and joint efforts involving paths to career and professional training, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7b2c1b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts that provide academic credit for programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7b2c1c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combinations of academic and experiential learning;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c1d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment and continuation of institutions, programs, consortia, collaborations, and other joint efforts based on communications technology, including those efforts that utilize distance education and technological advancements to educate and train postsecondary students (including health professionals serving medically underserved populations);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c1e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the carrying out, in postsecondary educational institutions, of changes in internal structure and operations designed to clarify institutional priorities and purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c1f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the design and introduction of cost-effective methods of instruction and operation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c20-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the introduction of institutional reforms designed to expand individual opportunities for entering and reentering postsecondary institutions and pursuing programs of postsecondary study tailored to individual needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c21-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the introduction of reforms in graduate education, in the structure of academic professions, and in the recruitment and retention of faculties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c22-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creation of new institutions and programs for examining and awarding credentials to individuals, and the introduction of reforms in current institutional practices related thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c23-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the introduction of reforms in remedial education, including English language instruction, to customize remedial courses to student goals and help students progress rapidly from remedial courses into core courses and through postsecondary program completion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c24-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the provision of support and assistance to partnerships between institutions of higher education and secondary schools with a significant population of students identified as late-entering limited English proficient students, to establish programs that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7b2c25-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in increased secondary school graduation rates of limited English proficient students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7b2c26-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the number of participating late-entering limited English proficient students who pursue postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c27-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the creation of consortia that join diverse institutions of higher education to design and offer curricular and cocurricular interdisciplinary programs at the undergraduate and graduate levels, sustained for not less than a 5 year period, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7b2c28-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focus on poverty and human capability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7b2c29-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d7b2c2a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/11/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a service-learning component; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7b2c2b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/11/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the delivery of educational services through informational resource centers, summer institutes, midyear seminars, and other educational activities that stress the effects of poverty and how poverty can be alleviated through different career paths;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c2c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of support and assistance for demonstration projects to provide comprehensive support services to ensure that homeless students, or students who were in foster care or were a ward of the court at any time before the age of 13, enroll and succeed in postsecondary education, including providing housing to such students during periods when housing at the institution of higher education is closed or generally unavailable to other students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c2d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the support of efforts to work with institutions of higher education, and nonprofit organizations, that seek to promote cultural diversity in the entertainment media industry, including through the training of students in production, marketing, and distribution of culturally relevant content.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7b2c2e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make planning grants to institutions of higher education for the development and testing of innovative techniques in postsecondary education. Such grants shall not exceed $20,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7b2c2f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center for best practices to support single parent students","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7b2c30-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to award one grant or contract to an institution of higher education to enable such institution to establish and maintain a center to study and develop best practices for institutions of higher education to support single parents who are also students attending such institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c31-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award the grant or contract under this subsection to a four-year institution of higher education that has demonstrated expertise in the development of programs to assist single parents who are students at institutions of higher education, as shown by the institution’s development of a variety of targeted services to such students, including on-campus housing, child care, counseling, advising, internship opportunities, financial aid, and financial aid counseling and assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c32-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The center funded under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7b2c33-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist institutions implementing innovative programs that support single parents pursuing higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7b2c34-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" study and develop an evaluation protocol for such programs that includes quantitative and qualitative methodologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7b2c35-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide appropriate technical assistance regarding the replication, evaluation, and continuous improvement of such programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7b2c36-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and disseminate best practices for such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7b2c37-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7b2c38-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds made available under this part shall be used to provide direct financial assistance in the form of grants or scholarships to students who do not meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1091/a"},"text":"section 1091(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c39-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to prevent a student who does not meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1091/a"},"text":"section 1091(a) of this title","children":[],"tail":" from participating in programs funded under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7b2c3a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under this part to any institution of higher education after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", the Secretary may give priority to institutions that meet or exceed the most current version of ASHRAE/IES Standard 90.1 (as such term is used in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6313/a/6"},"text":"section 6313(a)(6) of title 42","children":[],"tail":") for any new facilities construction or major renovation of the institution after such date, except that this subsection shall not apply with respect to barns or greenhouses or similar structures owned by the institution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7b2c3b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarship program for family members of veterans or members of the military","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d7b2c3c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into a contract with a nonprofit organization with demonstrated success in carrying out the activities described in this subsection to carry out a program to provide postsecondary education scholarships for eligible students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c3d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible student","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “eligible student” means an individual who is enrolled as a full-time or part-time student at an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of this title","children":[],"tail":") and is—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d7b2c3e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a dependent student who is a child of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d7b2c3f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an individual who is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d7b2c40-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving on active duty during a war or other military operation or national emergency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1088"},"text":"section 1088 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7b2c41-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing qualifying National Guard duty during a war or other military operation or national emergency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1088"},"text":"section 1088 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7b2c42-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a veteran who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d7b2c43-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served or performed, as described in clause (i), since ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7b2c44-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" died, or has been disabled, as a result of such service or performance; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d7b2c45-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an independent student who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d7b2c46-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is a spouse of an individual who is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d7b2c47-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving on active duty during a war or other military operation or national emergency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1088"},"text":"section 1088 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7b2c48-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing qualifying National Guard duty during a war or other military operation or national emergency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1088"},"text":"section 1088 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7b2c49-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was (at the time of death of the veteran) a spouse of a veteran who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d7b2c4a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served or performed, as described in clause (i), since ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7b2c4b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" died as a result of such service or performance; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d7b2c4c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is a spouse of a veteran who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0d7b2c4d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served or performed, as described in clause (i), since ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0d7b2c4e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been disabled as a result of such service or performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c4f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awarding of scholarships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Scholarships awarded under this subsection shall be awarded based on need with priority given to eligible students who are eligible to receive Federal Pell Grants under subpart 1 of part A of subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c50-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum scholarship amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum scholarship amount awarded to an eligible student under this subsection for an award year shall be the lesser of $5,000, or the student’s cost of attendance (as defined in section 1087","children":[{"tag":"i","attrib":{},"text":"ll","children":[],"tail":" of this title)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d7b2c51-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1138/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts for scholarships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All of the amounts appropriated to carry out this subsection for a fiscal year shall be used for scholarships awarded under this subsection, except that the nonprofit organization receiving a contract under this subsection may use not more than one percent of such amounts for the administrative costs of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d7b2c52-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s741"},"text":"Pub. L. 89–329, title VII, § 741","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVII/s701"},"text":"Pub. L. 105–244, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1796"},"text":"112 Stat. 1796","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVII/s707/a"},"text":"Pub. L. 110–315, title VII, § 707(a)","children":[],"tail":"–(e), "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","