{"tag":"section","attrib":{"id":"id0e1d3857-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6646"},"text":null,"children":[{"tag":"num","attrib":{"value":"6646"},"text":"§ 6646.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovative approaches to literacy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e1d3858-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6646/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6621/2"},"text":"section 6621(2) of this title","children":[],"tail":", the Secretary may award grants, contracts, or cooperative agreements, on a competitive basis, to eligible entities for the purposes of promoting literacy programs that support the development of literacy skills in low-income communities, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d3859-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6646/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and enhancing effective school library programs, which may include providing professional development for school librarians, books, and up-to-date materials to high-need schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d385a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6646/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early literacy services, including pediatric literacy programs through which, during well-child visits, medical providers trained in research-based methods of early language and literacy promotion provide developmentally appropriate books and recommendations to parents to encourage them to read aloud to their children starting in infancy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d385b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6646/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that provide high-quality books on a regular basis to children and adolescents from low-income communities to increase reading motivation, performance, and frequency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d385c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6646/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d385d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6646/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1d385e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6646/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency in which 20 percent or more of the students served by the local educational agency are from families with an income below the poverty line;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d385f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6646/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of such local educational agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d3860-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6646/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Indian Education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d3861-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6646/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an eligible national nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d3862-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6646/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible national nonprofit organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible national nonprofit organization” means an organization of national scope that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1d3863-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6646/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is supported by staff, which may include volunteers, or affiliates at the State and local levels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d3864-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6646/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates effectiveness or high-quality plans for addressing childhood literacy activities for the population targeted by the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1d3865-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2226"},"text":"Pub. L. 89–10, title II, § 2226","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tII/s2002"},"text":"Pub. L. 114–95, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1944"},"text":"129 Stat. 1944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e1d3866-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e1d3867-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e1d3868-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 6646 to 6650 were omitted in the general amendment of this subchapter by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6646, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2206"},"text":"Pub. L. 89–10, title II, § 2206","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101"