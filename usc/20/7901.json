{"tag":"section","attrib":{"id":"id0e51b5b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7901"},"text":null,"children":[{"tag":"num","attrib":{"value":"7901"},"text":"§ 7901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e51b5b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency may receive funds under a covered program for any fiscal year only if the State educational agency finds that either the combined fiscal effort per student or the aggregate expenditures of the agency and the State with respect to the provision of free public education by the agency for the preceding fiscal year was not less than 90 percent of the combined fiscal effort or aggregate expenditures for the second preceding fiscal year, subject to the requirements of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e51b5b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction in case of failure to meet","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e51b5b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7901/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State educational agency shall reduce the amount of the allocation of funds under a covered program in any fiscal year in the exact proportion by which a local educational agency fails to meet the requirement of subsection (a) of this section by falling below 90 percent of both the combined fiscal effort per student and aggregate expenditures (using the measure most favorable to the local agency), if such local educational agency has also failed to meet such requirement (as determined using the measure most favorable to the local agency) for 1 or more of the 5 immediately preceding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e51b5b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7901/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No such lesser amount shall be used for computing the effort required under subsection (a) of this section for subsequent years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e51b5b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7901/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive the requirements of this section if the Secretary determines that a waiver would be equitable due to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e51b5b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7901/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exceptional or uncontrollable circumstances, such as a natural disaster or a change in the organizational structure of the local educational agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e51b5b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7901/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a precipitous decline in the financial resources of the local educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e51b5ba-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tVIII/s8521"},"text":"Pub. L. 89–10, title VIII, § 8521","children":[],"tail":", formerly title IX, § 9521, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIX/s901"},"text":"Pub. L. 107–110, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1980"},"text":"115 Stat. 1980","children":[],"tail":"; renumbered title VIII, § 8521, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tVIII"},"text":"Pub. L. 114–95, title VIII","children":[],"tail":", §§ 8001(a)(6), 8019, "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2088"},"text":"129 Stat. 2088","children":[],"tail":", 2089, 2112.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e51b5bb-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e51b5bc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e51b5bd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7901, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIX/s9201"},"text":"Pub. L. 89–10, title IX, § 9201","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3794"},"text":"108 Stat. 3794","children":[],"tail":", set forth short title of the Native Hawaiian Education Act, prior to the general amendment of former subchapter IX of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e51b5be-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8019/1"},"text":"Pub. L. 114–95, § 8019(1)","children":[],"tail":", inserted “, subject to the requirements of subsection (b)” after “for the second preceding fiscal year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8019/2"},"text":"Pub. L. 114–95, § 8019(2)","children":[],"tail":", inserted before period at end “, if such local educational agency has also failed to meet such requirement (as determined using the measure most favorable to the local agency) for 1 or more of the 5 immediately preceding fiscal years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s8019/3"},"text":"Pub. L. 114–95, § 8019(3)","children":[],"tail":", inserted “or a change in the organizational structure of the local educational agency” after “such as a natural disaster”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e51b5bf-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e51b5c0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
