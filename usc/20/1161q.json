{"tag":"section","attrib":{"id":"id0d895d5d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161q"},"text":"§ 1161q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to rural-serving institutions of higher education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d895d5e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895d5f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase enrollment and graduation rates of secondary school graduates and nontraditional students from rural areas at two-year and four-year institutions of higher education, and their articulation from two-year degree programs into four-year degree programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d60-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote economic growth and development in rural America through partnership grants to consortia of rural-serving institutions of higher education, local educational agencies, and regional employers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895d61-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895d62-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural-serving institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rural-serving institution of higher education” means an institution of higher education that primarily serves rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d63-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rural area” means an area that is defined, identified, or otherwise recognized as rural by a governmental agency of the State in which the area is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d64-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nontraditional student","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “nontraditional student” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895d65-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delays enrollment in an institution of higher education by three or more years after secondary school graduation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d66-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attends an institution of higher education part-time; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d67-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" attends an institution of higher education and—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d895d68-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" works full-time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d895d69-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an independent student, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087vv"},"text":"section 1087vv of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d895d6a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/b/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has one or more dependents other than a spouse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d895d6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/b/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a single parent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d895d6c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/b/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not have a secondary school diploma or the recognized equivalent of such a diploma.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional employer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “regional employer” means an employer within a rural area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895d6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895d6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required partners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A rural-serving institution of higher education, or a consortium of rural-serving institutions of higher education, that receives a grant under this section shall carry out the activities of the grant in partnership with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895d70-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more local educational agencies serving a rural area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d71-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more regional employers or local boards (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of title 29","children":[],"tail":") serving a rural area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d72-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optional partners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A rural-serving institution of higher education, or a consortium of rural-serving institutions of higher education, that receives a grant under this section, may carry out the activities of the grant in partnership with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895d73-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an educational service agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d74-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization with demonstrated expertise in rural education at the secondary and postsecondary levels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895d75-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895d76-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available under subsection (g), the Secretary is authorized to award grants, on a competitive basis, to eligible rural-serving institutions of higher education or a consortium of such institutions, to carry out the activities described in subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d77-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this section shall be awarded for a period not to exceed three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d78-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum and minimum grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant awarded under this section shall be less than $200,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d79-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary shall give special consideration to applications that demonstrate the most potential and propose the most promising and innovative approaches for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895d7a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the percentage of graduates of rural secondary schools attending rural-serving institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d7b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meeting the employment needs of regional employers with graduates of rural-serving institutions of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d7c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the health of the regional economy of a rural area through a partnership of local educational agencies serving the rural area, rural-serving institutions of higher education, and regional employers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d7d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A rural-serving institution of higher education shall not receive more than one grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895d7e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each rural-serving institution of higher education desiring a grant under this section shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895d7f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A rural-serving institution of higher education that receives a grant under this section shall use grant funds for at least three of the following four purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895d80-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To improve postsecondary enrollment rates for rural secondary school students at rural-serving institutions of higher education, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895d81-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to provide students and families with counseling related to applying for postsecondary education, and Federal and State financial assistance for postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d82-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that provide students and families of rural high schools access and exposure to campuses, classes, programs, and internships of rural-serving institutions of higher education, including covering the cost of transportation to and from such institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d83-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other initiatives that assist students and families in applying for and developing interest in attending rural-serving institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d84-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To increase enrollment rates of nontraditional students in degree programs at rural-serving institutions of higher education, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895d85-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to provide nontraditional students with counseling related to applying for postsecondary education, and Federal and State financial assistance for postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community outreach initiatives to encourage nontraditional students to enroll in a rural-serving institution of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895d87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to improve the enrollment of nontraditional students in two-year degree programs and the transition of nontraditional students articulating from two-year degree programs to four-year degree programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To create or strengthen academic programs at rural-serving institutions of higher education to prepare graduates to enter into high-need occupations in the regional and local economies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895d89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide additional career training to students of rural-serving institutions of higher education in fields relevant to the regional economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895d8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161q/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as many be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d895d8b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s861"},"text":"Pub. L. 89–329, title VIII, § 861","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-1