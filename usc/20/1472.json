{"tag":"section","attrib":{"id":"id0daf82b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1472"},"text":null,"children":[{"tag":"num","attrib":{"value":"1472"},"text":"§ 1472.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community parent resource centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0daf82b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1472/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf82b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1472/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award grants to, and enter into contracts and cooperative agreements with, local parent organizations to support community parent resource centers that will help ensure that underserved parents of children with disabilities, including low income parents, parents of limited English proficient children, and parents with disabilities, have the training and information the parents need to enable the parents to participate effectively in helping their children with disabilities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf82b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1472/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet developmental and functional goals, and challenging academic achievement goals that have been established for all children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf82b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1472/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be prepared to lead productive independent adult lives, to the maximum extent possible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf82b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1472/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of local parent organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “local parent organization” means a parent organization, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1471/a/2"},"text":"section 1471(a)(2) of this title","children":[],"tail":", that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0daf82b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1472/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a board of directors the majority of whom are parents of children with disabilities ages birth through 26 from the community to be served; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0daf82ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1472/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has as its mission serving parents of children with disabilities who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0daf82bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1472/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are ages birth through 26; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0daf82bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1472/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the full range of disabilities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1401/3"},"text":"section 1401(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0daf82bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1472/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each community parent resource center assisted under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0daf82be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1472/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training and information that meets the training and information needs of parents of children with disabilities proposed to be served by the grant, contract, or cooperative agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf82bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1472/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the activities required of parent training and information centers under paragraphs (2) through (9) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1471/b"},"text":"section 1471(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf82c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1472/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish cooperative partnerships with the parent training and information centers funded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1471"},"text":"section 1471 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0daf82c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1472/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be designed to meet the specific needs of families who experience significant isolation from available sources of information and support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0daf82c2-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s672"},"text":"Pub. L. 91–230, title VI, § 672","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2791"},"text":"118 Stat. 2791","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0daf82c3-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0daf82c4-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0daf82c5-3a70-11f1-a648-