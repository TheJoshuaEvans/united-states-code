{"tag":"section","attrib":{"id":"id0e2e015f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244"},"text":null,"children":[{"tag":"num","attrib":{"value":"7244"},"text":"§ 7244.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e2e0160-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each statewide organization or consortium receiving a grant under this part shall use the grant funds, based on the needs determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7243/b/6/I"},"text":"section 7243(b)(6)(I) of this title","children":[],"tail":", to provide training and technical assistance to State educational agencies, local educational agencies, and organizations that support family-school partnerships, and activities, services, and training for local educational agencies, school leaders, educators, and parents—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2e0161-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to assist parents in participating effectively in their children’s education and to help their children meet challenging State academic standards, such as by assisting parents—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2e0162-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to engage in activities that will improve student academic achievement, including understanding how parents can support learning in the classroom with activities at home and in after school and extracurricular programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e0163-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to communicate effectively with their children, teachers, school leaders, counselors, administrators, and other school personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e0164-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to become active participants in the development, implementation, and review of school-parent compacts, family engagement in education policies, and school planning and improvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e0165-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to participate in the design and provision of assistance to students who are not making academic progress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e0166-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to participate in State and local decisionmaking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e0167-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to train other parents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e0168-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in learning and using technology applied in their children’s education;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e0169-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and implement, in partnership with the State educational agency, statewide family engagement in education policy and systemic initiatives that will provide for a continuum of services to remove barriers for family engagement in education and support school reform efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e016a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and implement parental involvement policies under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2e016b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to prohibit a statewide family engagement center from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2e016c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having its employees or agents meet with a parent at a site that is not on school grounds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e016d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working with another agency that serves children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e2e016e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parental rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2e016f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no person (including a parent who educates a child at home, a public school parent, or a private school parent) shall be required to participate in any program of parent education or developmental screening under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e0170-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7244/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no program or center assisted under this section shall take any action that infringes in any manner on the right of parents to direct the education of their children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e2e0171-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4504"},"text":"Pub. L. 89–10, title IV, § 4504","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV/s4501"},"text":"Pub. L. 114–95, title IV, § 4501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2019"},"text":"129 Stat. 2019","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e2e0172-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e2e0173-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e2e0174-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
