{"tag":"section","attrib":{"id":"id0ca47b3e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s907"},"text":null,"children":[{"tag":"num","attrib":{"value":"907"},"text":"§ 907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of other laws","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In the case of any teacher who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ca47b3f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s907/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is performing services as a teacher at the close of a school year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca47b40-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s907/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees in writing to serve as a teacher for the next school year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ca47b41-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s907/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed in another position in the recess period immediately preceding such next school year, or, during such recess period, receives quarters, allowances, or additional compensation referred to in sections 905 and 906 of this title, or both, as the case may be,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5533"},"text":"section 5533 of title 5","children":[],"tail":" shall not apply to such teacher by reason of any such employment during a recess period or any such receipt of quarters, allowances, or additional compensation, or both, as the case may be."}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0ca47b42-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/91/s10/b"},"text":"Pub. L. 86–91, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-07-17"},"text":"July 17, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/217"},"text":"73 Stat. 217","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/448/tIV/s401/n"},"text":"Pub. L. 88–448, title IV, § 401(n)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-19"},"text":"Aug. 19, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/492"},"text":"78 Stat. 492","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0ca47b43-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0ca47b44-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0ca47b45-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5533"},"text":"Section 5533 of title 5","children":[],"tail":"” substituted in text for “section 301 of the Dual Compensation Act” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", the first section of which enacted Title 5, Government Organiza