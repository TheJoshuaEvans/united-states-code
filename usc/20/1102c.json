{"tag":"section","attrib":{"id":"id0d6a631d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1102c"},"text":"§ 1102c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application and duration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d6a631e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any eligible institution may apply for a grant under this part by submitting an application to the Secretary at such time and in such manner as the Secretary may require. Such application shall demonstrate how the grant funds will be used to improve postbaccalaureate education opportunities for Hispanic and low-income students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a631f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under this part shall be awarded for a period not to exceed five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d6a6320-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1102c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not award more than one grant under this part in any fiscal year to any Hispanic-serving institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d6a6321-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s514"},"text":"Pub. L. 89–329, title V, § 514","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tV/s502/a/3"},"text":"Pub. L. 110–315, title V, § 502(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3332"},"text":"122 Stat. 3332","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d6a6322-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d6a6323-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d6a6324-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1102c, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tV/s504"},"text":"Pub. L. 89–329, title V, § 504","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tV/s501/a"},"text":"Pub. L. 102–325, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/661"},"text":"106 Stat. 661","children":[],"tail":", related to State uses of funds, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","