{"tag":"section","attrib":{"id":"id0e21f41b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011"},"text":null,"children":[{"tag":"num","attrib":{"value":"7011"},"text":"§ 7011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided, in this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e21f41c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “child” means any individual aged 3 through 21.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f41d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community-based organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community-based organization” means a private nonprofit organization of demonstrated effectiveness, Indian tribe, or tribally sanctioned educational authority, that is representative of a community or significant segments of a community and that provides educational or related services to individuals in the community. Such term includes a Native Hawaiian or Native American Pacific Islander native language educational organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f41e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e21f41f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more local educational agencies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e21f420-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more local educational agencies, in consortia or collaboration with an institution of higher education, educational service agency, community-based organization, or State educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f421-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" English learner with a disability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “English learner with a disability” means an English learner who is also a child with a disability, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1401"},"text":"section 1401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f422-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immigrant children and youth","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “immigrant children and youth” means individuals who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e21f423-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are aged 3 through 21;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e21f424-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were not born in any State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e21f425-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have not been attending one or more schools in any one or more States for more than 3 full academic years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f426-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” means any Indian tribe, band, nation, or other organized group or community, including any Native village or Regional Corporation or Village Corporation as defined in or established pursuant to the Alaska Native Claims Settlement Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.], that is recognized as eligible for the special programs and services provided by the United States to Indians because of their status as Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f427-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Language instruction educational program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “language instruction educational program” means an instruction course—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e21f428-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which an English learner is placed for the purpose of developing and attaining English proficiency, while meeting challenging State academic standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e21f429-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that may make instructional use of both English and a child’s native language to enable the child to develop and attain English proficiency, and may include the participation of English proficient children if such course is designed to enable all participating children to become proficient in English and a second language.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f42a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American and Native American language","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Native American” and “Native American language” shall have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2902"},"text":"section 2902 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f42b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native Hawaiian or Native American Pacific Islander native language educational organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Native Hawaiian or Native American Pacific Islander native language educational organization” means a nonprofit organization with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e21f42c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a majority of its governing board and employees consisting of fluent speakers of the traditional Native American languages used in the organization’s educational programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e21f42d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 5 years successful experience in providing educational services in traditional Native American languages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f42e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native language","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “native language”, when used with reference to an individual of limited English proficiency, means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e21f42f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the language normally used by such individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e21f430-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a child or youth, the language normally used by the parents of the child or youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f431-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paraprofessional","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “paraprofessional” means an individual who is employed in a preschool, elementary school, or secondary school under the supervision of a certified or licensed teacher, including individuals employed in language instruction educational programs, special education, and migrant education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f432-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specially qualified agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “specially qualified agency” means an eligible entity in a State whose State educational agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e21f433-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not participate in a program under subpart 1 of part A for a fiscal year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e21f434-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits a plan (or any amendment to a plan) that the Secretary, after reasonable notice and opportunity for a hearing, determines does not satisfy the requirements of such subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f435-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the 50 States, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e21f436-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribally sanctioned educational authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tribally sanctioned educational authority” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e21f437-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any department or division of education operating within the administrative structure of the duly constituted governing body of an Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e21f438-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any nonprofit institution or organization that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e21f439-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/14/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chartered by the governing body of an Indian tribe to operate a school described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6822/a"},"text":"section 6822(a) of this title","children":[],"tail":" or otherwise to oversee the delivery of educational services to members of the tribe; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e21f43a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7011/14/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approved by the Secretary for the purpose of carrying out programs under subpart 1 of part A for individuals served by a school described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6822/a"},"text":"section 6822(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e21f43b-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIII/s3201"},"text":"Pub. L. 89–10, title III, § 3201","children":[],"tail":", formerly § 3301, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tIII/s301"},"text":"Pub. L. 107–110, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1729"},"text":"115 Stat. 1729","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s941/k/2/F/i"},"text":"Pub. L. 110–315, title IX, § 941(k)(2)(F)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3466"},"text":"122 Stat. 3466","children":[],"tail":"; renumbered § 3201 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIII"},"text":"Pub. L. 114–95, title III","children":[],"tail":", §§ 3001(5)(A), 3004(a), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1953"},"text":"129 Stat. 1953","children":[],"tail":", 1965.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e21f43c-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e21f43d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e21f43e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Alaska Native Claims Settlement Act, referred to in par. (6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e21f43f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s3201"},"text":"section 3201 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6891"},"text":"section 6891 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s3201"},"text":"section 3201 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6891"},"text":"section 6891 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e21f440-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s3004/a/1"},"text":"Pub. L. 114–95, § 3004(a)(1)","children":[],"tail":", (2), added pars. (3) and (4) and struck out former pars. (3) and (4) which defined “community college” and “Director”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s3004/a/1"},"text":"Pub. L. 114–95, § 3004(a)(1)","children":[],"tail":", (3), redesignated par. (6) as (5) and struck out former par. (5) which defined “family education program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s3004/a/3"},"text":"Pub. L. 114–95, § 3004(a)(3)","children":[],"tail":", redesignated par. (7) as (6). Former par. (6) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s3004/a/3"},"text":"Pub. L. 114–95, § 3004(a)(3)","children":[],"tail":", redesignated par. (8) as (7). Former par. (7) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s3004/a/4"},"text":"Pub. L. 114–95, § 3004(a)(4)","children":[],"tail":", substituted “an English learner” for “a limited English proficient child” and “challenging State academic standards” for “challenging State academic content and student academic achievement standards, as required by "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/1"},"text":"section 6311(b)(1) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (8) to (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s3004/a/3"},"text":"Pub. L. 114–95, § 3004(a)(3)","children":[],"tail":", redesignated pars. (9) to (12) as (8) to (11), respectively. Former par. (8) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s3004/a/3"},"text":"Pub. L. 114–95, § 3004(a)(3)","children":[],"tail":", (5), redesignated par. (13) as (12) and struck out “, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6871"},"text":"section 6871 of this title","children":[],"tail":",” after “eligible entity” in introductory provisions. Former par. (12) redesignated (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (13), (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s3004/a/3"},"text":"Pub. L. 114–95, § 3004(a)(3)","children":[],"tail":", redesignated pars. (14) and (15) as (13) and (14), respectively. Former par. (13) redesignated (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" substituted “the Tribally Controlled Colleges and Universities Assistance Act of 1978” for “the Tribally Controlled College or University Assistance Act of 1978”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e21f441-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e21f442-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0e21f443-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Research Relating to Bilingual Education","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/tVI/s6211"},"text":"Pub. L. 100–297, title VI, § 6211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/429"},"text":"102 Stat. 429","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/297/tVI/s6211"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research and Development","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary [of Education] shall, through competitive contracts under this section, provide financial assistance for research and development proposals submitted by institutions of higher education, private for-profit and nonprofit organizations, State and local educational agencies, and individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Research activities authorized to be assisted under this section shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies to determine and evaluate effective models for bilingual education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies which examine the process by which individuals acquire a second language and master the subject matter skills required for grade-promotion and graduation, and which identify effective methods for teaching English and subject matter skills within the context of a bilingual education program or special alternative instructional program to students who have language proficiencies other than English;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" longitudinal studies to measure the effect of title VII of the Elementary and Secondary Education Act of 1965 [former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3281"},"text":"20 U.S.C. 3281","children":[],"tail":" et seq.] on students enrolled in programs under such title (including a longitudinal study of the impact of bilingual education programs on limited-English proficient students using a nationally representative sample of the programs funded under such title and which provides information including data on grade retention, academic performance, and dropout rates);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies to determine effective and reliable methods for identifying students who are entitled to services under such title and for determining when their English language proficiency is sufficiently well developed to permit them to derive optimal benefits from an all-English instructional program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation of a clearinghouse which shall collect, analyze, and disseminate information about bilingual education and related programs (and coordinate its activities with the National Diffusion Network);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies to determine effective methods of teaching English to adults who have language proficiencies other than English;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies to determine and evaluate effective methods of instruction for bilingual programs, taking into account language and cultural differences among students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies to determine effective approaches to preservice and inservice training for teachers, taking into account the language and cultural differences of their students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of such title on the capacity of local educational agencies to operate bilingual programs following the termination of assistance under this [such] title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"“(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies to determine effective and reliable methods for identifying gifted and talented students who have language proficiencies other than English.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation and Delegation of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the responsibilities of this section, the Secretary may delegate authority to the Director, and in any event, shall consult with the Director, representatives of State and local educational agencies, appropriate groups and organizations involved in bilingual education, the Committee on Labor and Human Resources [now Committee on Health, Education, Labor, and Pensions] of the Senate, and the Committee on Education and Labor [now Committee on Education and the Workforce] of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication of Proposals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall publish and disseminate all requests for proposals in research and development assisted under such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed as authorizing the Secretary to conduct or support studies or analyses of the content of educational textbooks.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0e21f444-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Information Regarding Bilingual Education","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297/tVI/s6213"},"text":"Pub. L. 100–297, title VI, § 6213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/429"},"text":"102 Stat. 429","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1042/a"},"text":"Pub. L. 104–66, title I, § 1042(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/715"},"text":"109 Stat. 715","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/66/tI/s1042/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary [of Education] shall collect data for program management and accountability purposes regarding—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national assessment of the educational needs of children and other persons with limited English proficiency and of the extent to which such needs are being met from Federal, State, and local efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan, including cost estimates, to be carried out during the 5-year period beginning on such date [sic], for extending programs of bilingual education and bilingual vocational and adult education programs to all such preschool and elementary schoolchildren and other persons of limited English proficiency, including a phased plan for the training of the necessary teachers and other education personnel necessary for such purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the activities intended to be carried out during the succeeding period, including an estimate of the cost of such activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the number of teachers and other educational personnel needed to carry out programs of bilingual education under such title [sic] and those carried out under other programs for persons of limited English proficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement describing the activities carried out thereunder designed to prepare teachers and other educational personnel for such programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of other educational personnel needed to carry out programs of bilingual education in the States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
