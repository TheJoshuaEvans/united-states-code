{"tag":"section","attrib":{"id":"id0e600e97-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511"},"text":null,"children":[{"tag":"num","attrib":{"value":"9511"},"text":"§ 9511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e600e98-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Department the Institute of Education Sciences, to be administered by a Director (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9514"},"text":"section 9514 of this title","children":[],"tail":") and, to the extent set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9516"},"text":"section 9516 of this title","children":[],"tail":", a board of directors."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e600e99-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e600e9a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The mission of the Institute is to provide national leadership in expanding fundamental knowledge and understanding of education from early childhood through postsecondary study, in order to provide parents, educators, students, researchers, policymakers, and the general public with reliable information about—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e600e9b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the condition and progress of education in the United States, including early childhood education and special education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e9c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational practices that support learning and improve academic achievement and access to educational opportunities for all students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600e9d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of Federal and other education programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600e9e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carrying out mission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the mission described in paragraph (1), the Institute shall compile statistics, develop products, and conduct research, evaluations, and wide dissemination activities in areas of demonstrated national need (including in technology areas) that are supported by Federal funds appropriated to the Institute and ensure that such activities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e600e9f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conform to high standards of quality, integrity, and accuracy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600ea0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are objective, secular, neutral, and nonideological and are free of partisan political influence and racial, cultural, gender, or regional bias.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e600ea1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Institute shall consist of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e600ea2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Director (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9514"},"text":"section 9514 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600ea3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Board for Education Sciences (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9516"},"text":"section 9516 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e600ea4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The National Education Centers, which include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e600ea5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Center for Education Research (as described in part B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600ea6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Center for Education Statistics (as described in part C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600ea7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Center for Education Evaluation and Regional Assistance (as described in part D); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e600ea8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9511/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Center for Special Education Research (as described in part E).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e600ea9-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s111"},"text":"Pub. L. 107–279, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1944"},"text":"116 Stat. 1944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tII/s201/b/2/A"},"text":"Pub. L. 108–446, title II, § 201(b)(2)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2802"},"text":"118 Stat. 2802","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e600eaa-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e600eab-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e600eac-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/446/s201/b/2/A"},"text":"Pub. L. 108–446, § 201(b)(2)(A)","children":[],"tail":", inserted “and special education” after “early childhood education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/446/s201/b/2/B"},"text":"Pub. L. 108–446, § 201(b)(2)(B)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
