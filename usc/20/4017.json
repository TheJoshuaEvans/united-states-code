{"tag":"section","attrib":{"id":"id0de40063-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4017"},"text":null,"children":[{"tag":"num","attrib":{"value":"4017"},"text":"§ 4017.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de40064-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4017/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan condition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de40065-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4017/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As a condition of the award of any financial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4014"},"text":"section 4014 of this title","children":[],"tail":", the recipient of any such loan or grant shall permit the United States to sue on behalf of such recipient any person determined by the Attorney General to be liable to the recipient for the costs of any activities undertaken by the recipient under such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de40066-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4017/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The proceeds from any judgment recovered in any suit brought by the United States under paragraph (1) (or, if the recipient files a similar suit on its own behalf, the proceeds from a judgment recovered by the recipient in such suit) shall be used to repay to the United States, by deposit in the Asbestos Trust Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4022"},"text":"section 4022 of this title","children":[],"tail":", to the extent that the proceeds are sufficient to provide for such repayment, an amount equal to the sum of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de40067-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4017/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount (i) outstanding on any loan and (ii) of any grant made to the recipient; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de40068-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4017/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the interest which would have been charged on such loan were the loan made by a commercial lender at prevailing interest rates (as determined by the Administrator).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de40069-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4017/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expeditious recovery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall, where appropriate, proceed in an expeditious manner to recover the amounts expended by the United States to carry out this subchapter from the persons identified by the Attorney General as being liable for such costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de4006a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tV/s508"},"text":"Pub. L. 98–377, title V, § 508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1293"},"text":"98 Stat. 1293","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/637"},"text":"Pub. L. 101–637","children":[],"tail":", §§ 9, 14(a)(8), (b)(10), (11), (c)(5), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4592"},"text":"104 Stat. 4592","children":[],"tail":", 4594–4596.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de4006b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de4006c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0de4006d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/a/8"},"text":"Pub. L. 101–637, § 14(a)(8)","children":[],"tail":", inserted section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/b/10"},"text":"Pub. L. 101–637, § 14(b)(10)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/c/5"},"text":"Pub. L. 101–637, § 14(c)(5)","children":[],"tail":", substituted “section” for “sections” after “such”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s9"},"text":"Pub. L. 101–637, § 9","children":[],"tail":", inserted “by deposit in the Asbestos Trust Fund established by "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4022"},"text":"section 4022 of this title","children":[],"tail":",” after “repay to the United States,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s14/b/11"},"text":"Pub. L. 101–637, § 14(b)(11)","children":[],"tail":", inserted heading."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
