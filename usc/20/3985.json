{"tag":"section","attrib":{"id":"id0de18f42-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985"},"text":null,"children":[{"tag":"num","attrib":{"value":"3985"},"text":"§ 3985.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0de18f43-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements; terms, assurances, and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any applicant which desires to receive a grant under this part shall submit an application approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3986"},"text":"section 3986 of this title","children":[],"tail":" to the Secretary, at such time, in such manner, and accompanied by such additional information as the Secretary may reasonably require. Each such application shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0de18f44-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the activities for which assistance under this part is sought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f45-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assurances that not more than 5 per centum of the amount received by the applicant in any fiscal year may be expended on administrative expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f46-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to each program for which assistance is sought, provide assurances that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0de18f47-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 per centum of the funds for each such project will be furnished by business concerns within the community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18f48-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 20 per centum of the funds will be supplied by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0de18f49-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de18f4a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution of higher education or the local educational agency, as the case may be, participating in the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0de18f4b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the other parties participating in the program;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18f4c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no stipend will be paid directly to employees of a profitmaking business concern; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0de18f4d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teachers participating in the exchange program may not be employed by the participating business concern with which the teacher served within three years after the end of the exchange program unless the teacher repays the full cost of the exchange program to the State and local educational agency, as the case may be; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f4e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assurances that whenever the program for which assistance is sought includes scholarships, the scholarships be awarded to undergraduate students at institutions of higher education within the State who wish to pursue a course of study in mathematics or science, engineering or computer science, and that each student awarded a scholarship under this part will receive a stipend which shall not exceed the cost of tuition at the institution of higher education plus a stipend of not to exceed $750 for each academic year of study for which the scholarship is awarded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f4f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth policies and procedures to assure that whenever the application includes a local educational agency, to the extent consistent with the number and location of children in the school district of such agency who are enrolled in private elementary and secondary schools, provision is made for the participation of such children in the program assisted under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f50-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assurances that consideration is given to programs and activities designed to meet the needs of underrepresented and underserved populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f51-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assurances that in the consideration of applications submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3986/a"},"text":"section 3986(a) of this title","children":[],"tail":" that equitable consideration is given to applications submitted by private and public institutions of higher education; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0de18f52-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such additional assurances as the Secretary determines essential to ensure compliance with the requirements of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0de18f53-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3985/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional joint application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A regional consortium of applicants in two or more States may file a joint application under the provisions of subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0de18f54-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tIII/s306"},"text":"Pub. L. 98–377, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-11"},"text":"Aug. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1285"},"text":"98 Stat. 1285","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tII/s231"},"text":"Pub. L. 99–159, title II, § 231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/900"},"text":"99 Stat. 900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6031/b/2"},"text":"Pub. L. 100–418, title VI, § 6031(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1483"},"text":"102 Stat. 1483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0de18f55-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0de18f56-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0de18f57-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" substituted “part” for “subchapter” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/159"},"text":"Pub. L. 99–159","children":[],"tail":" substituted “Secretary” for “Foundation” in two places in provisions preceding par. (1) and in par. (8)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
