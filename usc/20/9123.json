{"tag":"section","attrib":{"id":"id0e5b2c1e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9123"},"text":null,"children":[{"tag":"num","attrib":{"value":"9123"},"text":"§ 9123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e5b2c1f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e5b2c20-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9123/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out parts 1, 2, and 3, $232,000,000 for each of the fiscal years 2020 through 2025; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5b2c21-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9123/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out part 4, $24,500,000 for each of the fiscal years 2020 through 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e5b2c22-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forward funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e5b2c23-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9123/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the end of affording the responsible Federal, State, and local officers adequate notice of available Federal financial assistance for carrying out ongoing library activities and projects, appropriations for grants, contracts, or other payments under any program under this subchapter are authorized to be included in the appropriations Act for the fiscal year preceding the fiscal year during which such activities and projects shall be carried out.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e5b2c24-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9123/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to effect a transition to the timing of appropriation action authorized by subsection (a), the application of this section may result in the enactment, in a fiscal year, of separate appropriations for a program under this subchapter (whether in the same appropriations Act or otherwise) for two consecutive fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e5b2c25-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/462/tII/s214"},"text":"Pub. L. 94–462, title II, § 214","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/e/tVII/s702"},"text":"Pub. L. 104–208, div. A, title I, § 101(e) [title VII, § 702]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-233"},"text":"110 Stat. 3009–233","children":[],"tail":", 3009–296; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/81/tII/s203"},"text":"Pub. L. 108–81, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-25"},"text":"Sept. 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/997"},"text":"117 Stat. 997","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/340/tII/s202"},"text":"Pub. L. 111–340, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3599"},"text":"124 Stat. 3599","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/410/s9"},"text":"Pub. L. 115–410, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5416"},"text":"132 Stat. 5416","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e5b2c26-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e5b2c27-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e5b2c28-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/410"},"text":"Pub. L. 115–410","children":[],"tail":" substituted “each of the fiscal years 2020 through 2025” for “fiscal year 2011 and such sums as may be necessary for each of the fiscal years 2012 through 2016” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/340/s202/a"},"text":"Pub. L. 111–340, § 202(a)","children":[],"tail":", added subsec. (a) and struck out heading and text of former subsec. (a). Prior to amendment, text read as follows: “There are authorized to be appropriated to carry out this subchapter $232,000,000 for fiscal year 2004 and such sums as may be necessary for fiscal years 2005 through 2009.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/340/s202/b"},"text":"Pub. L. 111–340, § 202(b)","children":[],"tail":", struck out heading and text of subsec. (c). Text read as follows: “Not more than 3.5 percent of the funds appropriated under this section for a fiscal year may be used to pay for the Federal administrative costs of carrying out this subchapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/81/s203/1"},"text":"Pub. L. 108–81, § 203(1)","children":[],"tail":", added subsec. (a) and struck out heading and text of former subsec. (a). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—There are authorized to be appropriated $150,000,000 for fiscal year 1997 and such sums as may be necessary for each of the fiscal years 1998 through 2002 to carry out this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Transfer","children":[],"tail":".—The Secretary of Education shall—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) transfer promptly to the Director any funds appropriated under the authority of paragraph (1), to enable the Director to carry out this subchapter; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) not exercise any authority concerning the administration of this chapter other than the transfer described in subparagraph (A).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/81/s203/2"},"text":"Pub. L. 108–81, § 203(2)","children":[],"tail":", substituted “3.5 percent” for “3 percent”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e5b2c29-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e5b2c2a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/81"},"text":"Pub. L. 108–81","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2003-10-01"},"text":"Oct. 1, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/81/s506"},"text":"section 506 of Pub. L. 108–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9101"},"text":"section 9101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
