{"tag":"section","attrib":{"id":"id0d8230f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161b"},"text":"§ 1161b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mathematics and science scholars program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d8230f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amounts appropriated under subsection (f), the Secretary is authorized to award grants to States, on a competitive basis, to enable the States to encourage students to pursue a rigorous course of study, beginning in secondary school and continuing through the students’ postsecondary education, in science, technology, engineering, mathematics, or a health-related field.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8230f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8230f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that desires a grant under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require. A State may submit an application to receive a grant under subsection (c) or (d), or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8230f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application shall include a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8230f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program or programs for which the State is applying;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, the priority set by the Governor pursuant to subsection (c)(4) or (d)(3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the State will meet the requirements of subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8230f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mathematics and science scholars program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8230fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant for scholarships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants under this subsection to provide scholarship support to eligible students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8230fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible students","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A student is eligible for a scholarship under this subsection if the student—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8230fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1091/a"},"text":"section 1091(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a full-time student in the student’s first year of undergraduate study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8230fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed a rigorous secondary school curriculum in mathematics and science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8230ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rigorous curriculum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each participating State shall determine the requirements for a rigorous secondary school curriculum in mathematics and science described in paragraph (2)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823100-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for scholarships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor of a State may set a priority for awarding scholarships under this subsection for particular eligible students, such as students attending schools in high-need local educational agencies (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1021"},"text":"section 1021 of this title","children":[],"tail":"), students who are from groups underrepresented in the fields of mathematics, science, and engineering, students served by local educational agencies that do not meet or exceed State standards in mathematics and science, or other high-need students."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823101-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount and duration of scholarship","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award a grant under this subsection to provide scholarships—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d823102-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an amount that does not exceed $5,000 per student; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d823103-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for not more than one year of undergraduate study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d823104-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" STEM or health-related scholars program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d823105-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant for scholarships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants under this subsection to provide scholarship support to eligible students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d823106-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible students","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A student is eligible for scholarship under this subsection if the student—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d823107-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1091/a"},"text":"section 1091(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d823108-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a full-time student who has completed at least the first year of undergraduate study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d823109-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled in a program of undergraduate instruction leading to a bachelor’s degree with a major in science, technology, engineering, mathematics, or a health-related field; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d82310a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has obtained a cumulative grade point average of at least a 3.0 (or the equivalent as determined under regulations prescribed by the Secretary) at the end of the most recently completed term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d82310b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for scholarships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor of a State may set a priority for awarding scholarships under this subsection for students agreeing to work in areas of science, technology, engineering, mathematics, or health-related fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d82310c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount and duration of scholarship","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award a grant under this subsection to provide scholarships—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d82310d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an amount that does not exceed $5,000 per student for an academic year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d82310e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an aggregate amount that does not exceed $20,000 per student.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d82310f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to receive a grant under this section, a State shall provide matching funds for the scholarships awarded under this section in an amount equal to 50 percent of the Federal funds received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d823110-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d823111-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Governor” means the chief executive officer of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d823112-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s802"},"text":"Pub. L. 89–329, title VIII, § 802","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3381"},"text":"122 Stat. 3381","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tVIII/s801/1"},"text":"Pub. L. 111–39, title VIII, § 801(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1955"},"text":"123 Stat. 1955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d823113-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d823114-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d823115-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (d)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" substituted “regulations” for “regulation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d823116-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d823117-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/s3"},"text":"section 3 of Pub. L. 111–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
