{"tag":"section","attrib":{"id":"id0c8a3c34-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"80r–6"},"text":"§ 80r–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Building for the National Museum of African American History and Culture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0c8a3c35-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c8a3c36-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0c8a3c37-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"2003-12-16"},"text":"December 16, 2003","children":[],"tail":", the Board of Regents shall designate a site for the Museum."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8a3c38-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sites for consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In designating a site under subparagraph (A), the Board of Regents shall select from among the following sites in the District of Columbia:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0c8a3c39-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Arts and Industries Building of the Smithsonian Institution, located on the National Mall at 900 Jefferson Drive, Southwest, Washington, District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8a3c3a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The area bounded by Constitution Avenue, Madison Drive, and 14th and 15th Streets, Northwest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8a3c3b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The site known as the “Liberty Loan site”, located on 14th Street Southwest at the foot of the 14th Street Bridge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8a3c3c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The site known as the “Banneker Overlook site”, located on 10th Street Southwest at the foot of the L’Enfant Plaza Promenade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8a3c3d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of site","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0c8a3c3e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A site described in subparagraph (B) shall remain available until the date on which the Board of Regents designates a site for the Museum under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8a3c3f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer to Smithsonian Institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except with respect to a site described in clause (i) of subparagraph (B), if the site designated for the Museum is in an area that is under the administrative jurisdiction of a Federal agency, as soon as practicable after the date on which the designation is made, the head of the Federal agency shall transfer to the Smithsonian Institution administrative jurisdiction over the area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0c8a3c40-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Regents shall carry out its duties under this paragraph in consultation with the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0c8a3c41-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chair of the National Capital Planning Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8a3c42-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chair of the Commission on Fine Arts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8a3c43-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chair and Vice Chair of the Presidential Commission referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80r–8"},"text":"section 80r–8 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8a3c44-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chair of the Building and Site Subcommittee of the Presidential Commission referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80r–8"},"text":"section 80r–8 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0c8a3c45-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Chair and ranking minority member of each of the following Committees:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0c8a3c46-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/D/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Rules and Administration of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0c8a3c47-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/D/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on House Administration of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0c8a3c48-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/D/v/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Transportation and Infrastructure of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0c8a3c49-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/D/v/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0c8a3c4a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/1/D/v/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Appropriations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8a3c4b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of building","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Regents, in consultation with the Council, may plan, design, and construct a building for the Museum, which shall be located at the site designated by the Board of Regents under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8a3c4c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of provisions relating to monuments and commemorative works","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 89 of title 40 shall not apply with respect to the Museum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8a3c4d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Regents shall pay—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0c8a3c4e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the costs of carrying out this section from Federal funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0c8a3c4f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the costs of carrying out this section from non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0c8a3c50-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s80r–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0c8a3c51-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/184/s8"},"text":"Pub. L. 108–184, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2680"},"text":"117 Stat. 2680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c8a3c52-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0c8a3c53-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0c8a3c54-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Procurement for Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dE/tIII"},"text":"Pub. L. 112–74, div. E, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1033"},"text":"125 Stat. 1033","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/74/dE/tIII"},"text":"“That during fiscal year 2012 and any succeeding fiscal year, a single procurement for construction of the National Museum of African American History and Culture, as authorized under section 8 of the National Museum of African American History and Culture Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s80r–6"},"text":"20 U.S.C. 80r–6","children":[],"tail":"), may be issued that includes the full scope of the project”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
