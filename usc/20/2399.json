{"tag":"section","attrib":{"id":"id0dc77739-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2399"},"text":null,"children":[{"tag":"num","attrib":{"value":"2399"},"text":"§ 2399.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study on programs of study aligned to high-skill, high-wage occupations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dc7773a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2399/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Comptroller General of the United States shall conduct a study to evaluate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc7773b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2399/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the strategies, components, policies, and practices used by eligible agencies or eligible recipients receiving funding under this chapter to successfully assist—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0dc7773c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2399/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all students in pursuing and completing programs of study aligned to high-skill, high-wage occupations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0dc7773d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2399/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any special population or specific subgroup of students identified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/h/1/C/ii"},"text":"section 6311(h)(1)(C)(ii) of this title","children":[],"tail":" in pursuing and completing programs of study aligned to high-skill, high-wage occupations in fields in which such special population or subgroup is underrepresented; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc7773e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2399/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any challenges associated with replication of such strategies, components, policies, and practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc7773f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2399/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the study conducted under subsection (a), the Comptroller General of the United States shall consult with a geographically diverse (including urban, suburban, and rural) representation of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc77740-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2399/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" students and parents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc77741-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2399/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible agencies and eligible recipients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc77742-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2399/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teachers, faculty, specialized instructional support personnel, and paraprofessionals, including those with expertise in preparing career and technical education students for non-traditional fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc77743-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2399/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian Tribes and Tribal organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc77744-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2399/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc77745-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2399/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of business and industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc77746-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2399/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon completion, the Comptroller General of the United States shall submit the study conducted under subsection (a) to the Committee on Education and the Workforce of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dc77747-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tII/s219"},"text":"Pub. L. 88–210, title II, § 219","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/tII/s201/a/8"},"text":"Pub. L. 115–224, title II, § 201(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-31"},"text":"July 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1621"},"text":"132 Stat. 1621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dc77748-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dc77749-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0dc7774a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 2401 to 2404 were omitted in the general amendment of this chapter by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/332"},"text":"Pub. L. 105–332","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2401, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tIV/s401"},"text":"Pub. L. 88–210, title IV, § 401","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/524/s1"},"text":"Pub. L. 98–524, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us