{"tag":"section","attrib":{"id":"id0db1f33f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482"},"text":null,"children":[{"tag":"num","attrib":{"value":"1482"},"text":"§ 1482.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0db1f340-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicant and recipient responsibilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db1f341-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and assessment of projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require that an applicant for, and a recipient of, a grant, contract, or cooperative agreement for a project under part B or C—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db1f342-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve individuals with disabilities or parents of individuals with disabilities ages birth through 26 in planning, implementing, and evaluating the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f343-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where appropriate, determine whether the project has any potential for replication and adoption by other entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db1f344-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may require a recipient of a grant, contract, or cooperative agreement under part B or C to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db1f345-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" share in the cost of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f346-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare any findings and products from the project in formats that are useful for specific audiences, including parents, administrators, teachers, early intervention personnel, related services personnel, and individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f347-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate such findings and products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f348-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with other such recipients in carrying out subparagraphs (B) and (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db1f349-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application management","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db1f34a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standing panel","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db1f34b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and use a standing panel of experts who are qualified, by virtue of their training, expertise, or experience, to evaluate each application under part B or C that requests more than $75,000 per year in Federal financial assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f34c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The standing panel shall include, at a minimum—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0db1f34d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who are representatives of institutions of higher education that plan, develop, and carry out high quality programs of personnel preparation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db1f34e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who design and carry out scientifically based research targeted to the improvement of special education programs and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db1f34f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who have recognized experience and knowledge necessary to integrate and apply scientifically based research findings to improve educational and transitional results for children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db1f350-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who administer programs at the State or local level in which children with disabilities participate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db1f351-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who prepare parents of children with disabilities to participate in making decisions about the education of their children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db1f352-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who establish policies that affect the delivery of services to children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db1f353-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who are parents of children with disabilities ages birth through 26 who are benefiting, or have benefited, from coordinated research, personnel preparation, and technical assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db1f354-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/1/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f355-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No individual shall serve on the standing panel for more than 3 consecutive years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db1f356-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer-review panels for particular competitions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db1f357-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that each subpanel selected from the standing panel that reviews an application under part B or C includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0db1f358-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with knowledge and expertise on the issues addressed by the activities described in the application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db1f359-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, parents of children with disabilities ages birth through 26, individuals with disabilities, and persons from diverse backgrounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f35a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal employment limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the individuals on each subpanel that reviews an application under part B or C shall be individuals who are not employees of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db1f35b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of discretionary funds for administrative purposes","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db1f35c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses and fees of non-Federal panel members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use funds available under part B or C to pay the expenses and fees of the panel members who are not officers or employees of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f35d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use not more than 1 percent of the funds appropriated to carry out part B or C to pay non-Federal entities for administrative support related to management of applications submitted under part B or C, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db1f35e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use funds made available to carry out part B or C to evaluate activities carried out under part B or C, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db1f35f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum funding required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db1f360-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), the Secretary shall ensure that, for each fiscal year, not less than the following amounts are provided under parts B and C to address the following needs:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db1f361-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $12,832,000 to address the educational, related services, transitional, and early intervention needs of children with deaf-blindness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f362-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,000,000 to address the postsecondary, vocational, technical, continuing, and adult education needs of individuals with deafness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db1f363-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,000,000 to address the educational, related services, and transitional needs of children with an emotional disturbance and those who are at risk of developing an emotional disturbance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db1f364-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1482/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratable reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the sum of the amount appropriated to carry out parts B and C, and part E of the Education Sciences Reform Act of 2002 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9567"},"text":"20 U.S.C. 9567","children":[],"tail":" et seq.] for any fiscal year is less than $130,000,000, the amounts listed in paragraph (1) shall be ratably reduced for the fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0db1f365-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s682"},"text":"Pub. L. 91–230, title VI, § 682","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2797"},"text":"118 Stat. 2797","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db1f366-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0db1f367-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0db1f368-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Education Sciences Reform Act of 2002, referred to in subsec. (d)(2), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279"},"text":"Pub. L. 107–279","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1941"},"text":"116 Stat. 1941","children":[],"tail":". Part E of the Act is classified generally to part E (§ 9567 et seq.) of subchapter I of chapter 76 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9501"},"text":"section 9501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0db1f369-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1482, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s682"},"text":"Pub. L. 91–230, title VI, § 682","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tI/s101"},"text":"Pub. L. 105–17, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June 4