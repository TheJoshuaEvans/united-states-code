{"tag":"section","attrib":{"id":"id0de18f58-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3986"},"text":null,"children":[{"tag":"num","attrib":{"value":"3986"},"text":"§ 3986.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each applicant within a State which desires to receive a grant under this part shall submit the application prepared in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3985"},"text":"section 3985 of this title","children":[],"tail":" to the State agency on "},{"tag":"ref","attrib":{"idref":"fn002157"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002157"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “for”."}],"tail":" higher education or the State educational agency, as the case may be, for approval and shall submit the approved application to the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3985"},"text":"section 3985 of this title","children":[],"tail":". Each such application shall be submitted jointly by the local educational agency in the case of activities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3984/a"},"text":"section 3984(a) of this title","children":[],"tail":", or an institution of higher education in the case of activities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3984/b"},"text":"section 3984(b) of this title","children":[],"tail":", and each business concern or other party that is to participate in the program for which assistance is sought."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0de18f59-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/377/tIII/s307"},"text":"Pub. L. 98–377, title III, § 307","childr