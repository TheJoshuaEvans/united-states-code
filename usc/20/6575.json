{"tag":"section","attrib":{"id":"id0e187d28-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6575"},"text":null,"children":[{"tag":"num","attrib":{"value":"6575"},"text":"§ 6575.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against Federal mandates, direction, or control","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to authorize an officer or employee of the Federal Government to mandate, direct, or control a State, local educational agency, or school’s specific instructional content, academic achievement standards and assessments, curriculum, or program of instruction.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0e187d29-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1604"},"text":"Pub. L. 89–10, title I, § 1604","children":[],"tail":", formerly § 1905, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1619"},"text":"115 Stat. 1619","children":[],"tail":"; renumbered § 1604, "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1501/a/5"},"text":"Pub. L. 114–95, title I, § 1501(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1906"},"text":"129 Stat. 1906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e187d2a-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e187d2b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null