{"tag":"section","attrib":{"id":"id0d895e15-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161v"},"text":"§ 1161v.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modeling and simulation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d895e16-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose; definition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895e17-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this section is to promote the study of modeling and simulation at institutions of higher education, through the collaboration with new and existing programs, and specifically to promote the use of technology in such study through the creation of accurate models that can simulate processes or recreate real life, by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895e18-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a task force at the Department of Education to raise awareness of and define the study of modeling and simulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895e19-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing grants to institutions of higher education to develop new modeling and simulation degree programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895e1a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing grants for institutions of higher education to enhance existing modeling and simulation degree programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895e1b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “modeling and simulation” means a field of study related to the application of computer science and mathematics to develop a level of understanding of the interaction of the parts of a system and of a system as a whole.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895e1c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of task force","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895e1d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Secretary shall establish a task force within the Department to study modeling and simulation and to support the development of the modeling and simulation field. The activities of such task force shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895e1e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" helping to define the study of modeling and simulation (including the content of modeling and simulation classes and programs);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895e1f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying best practices for such study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895e20-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying core knowledge and skills that individuals who participate in modeling and simulation programs should acquire; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895e21-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing recommendations to the Secretary with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d895e22-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information described in subparagraphs (A) through (C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d895e23-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a system by which grants under this section will be distributed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895e24-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task force membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The membership of the task force under this subsection shall be composed of representatives from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895e25-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education with established modeling and simulation degree programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895e26-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895e27-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal Government agencies that use modeling and simulation extensively, including the Department of Defense, the National Institutes of Health, the Department of Homeland Security, the Department of Health and Human Services, the Department of Energy, and the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895e28-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private industries with a primary focus on modeling and simulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895e29-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national modeling and simulation organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895e2a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Science and Technology Policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d895e2b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhancing modeling and simulation at institutions of higher education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d895e2c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhancement grants authorized","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895e2d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to award grants, on a competitive basis, to eligible institutions to enhance modeling and simulation degree programs at such eligible institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895e2e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this subsection shall be awarded for a three-year period, and such grant period may be extended for not more than two years if the Secretary determines that an eligible institution has demonstrated success in enhancing the modeling and simulation degree program at such eligible institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895e2f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum grant amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, a grant awarded to an eligible institution under this subsection shall not be less than $750,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895e30-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible institution receiving a grant under this subsection shall provide, from non-Federal sources, in cash or in-kind, an amount equal to 25 percent of the amount of the grant to carry out the activities supported by the grant. The Secretary may waive the non-Federal share requirement under this subparagraph for an eligible institution if the Secretary determines a waiver to be appropriate based on the financial ability of the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895e31-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subsection, an eligible institution is an institution of higher education that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895e32-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an established modeling and simulation degree program, including a major, minor, or career-track program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895e33-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an established modeling and simulation certificate or concentration program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d895e34-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be considered for a grant under this subsection, an eligible institution shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require. Such application shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d895e35-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a letter from the president or provost of the eligible institution that demonstrates the institution’s commitment to the enhancement of the modeling and simulation program at the institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d895e36-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of designated faculty responsible for the enhancement of the institution’s modeling and simulation program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8bcd37-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed plan for how the grant funds will be used to enhance the modeling and simulation program of the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8bcd38-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant awarded under this subsection shall be used by an eligible institution to carry out the plan developed in accordance with paragraph (3)(C) to enhance modeling and simulation programs at the institution, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8bcd39-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an institution that is eligible under paragraph (2)(B), activities to assist in the establishment of a major, minor, or career-track modeling and simulation program at the eligible institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8bcd3a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding the multidisciplinary nature of the institution’s modeling and simulation programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8bcd3b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruiting students into the field of modeling and simulation through the provision of fellowships or assistantships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8bcd3c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating new courses to complement existing courses and reflect emerging developments in the modeling and simulation field;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8bcd3d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting research to support new methodologies and techniques in modeling and simulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8bcd3e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/c/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchasing equipment necessary for modeling and simulation programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8bcd3f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishing modeling and simulation programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8bcd40-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment grants authorized","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8bcd41-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to award grants to institutions of higher education to establish a modeling and simulation program, including a major, minor, career-track, certificate, or concentration program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8bcd42-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this subsection shall be awarded for a three-year period, and such grant period may be extended for not more than two years if the Secretary determines that an eligible institution has demonstrated success in establishing a modeling and simulation degree program at such eligible institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8bcd43-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum grant amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, a grant awarded to an eligible institution under this subsection shall not be less than $750,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8bcd44-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible institution receiving a grant under this subsection shall provide, from non-Federal sources, in cash or in-kind, an amount equal to 25 percent of the amount of the grant to carry out the activities supported by the grant. The Secretary may waive the non-Federal share requirement under this subparagraph for an eligible institution if the Secretary determines a waiver to be appropriate based on the financial ability of the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8bcd45-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To apply for a grant under this subsection, an eligible institution shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require. Such application shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8bcd46-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a letter from the president or provost of the eligible institution that demonstrates the institution’s commitment to the establishment of a modeling and simulation program at the institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8bcd47-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed plan for how the grant funds will be used to establish a modeling and simulation program at the institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8bcd48-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the modeling and simulation program established under this subsection will complement existing programs and fit into the institution’s current program and course offerings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8bcd49-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant awarded under this subsection may be used by an eligible institution to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8bcd4a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, or work toward the establishment of, a modeling and simulation program, including a major, minor, career-track, certificate, or concentration program at the eligible institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8bcd4b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide adequate staffing to ensure the successful establishment of the modeling and simulation program, which may include the assignment of full-time dedicated or supportive faculty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8bcd4c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase equipment necessary for a modeling and simulation program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8bcd4d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years. Of the amounts authorized to be appropriated for each fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8bcd4e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 is authorized to carry out the activities of the task force established pursuant to subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8bcd4f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" of the amount remaining after the allocation for paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8bcd50-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent is authorized to carry out the grant program under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8bcd51-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161v/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent is authorized to carry out the grant program under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d8bcd52-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s891"},"text":"Pub. L. 89–329, title VIII, § 891","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3432"},"text":"122 Stat. 3432","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
