{"tag":"section","attrib":{"id":"id0d92f95f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232"},"text":null,"children":[{"tag":"num","attrib":{"value":"1232"},"text":"§ 1232.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d92f960-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Regulation” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this section, the term “regulation” means any generally applicable rule, regulation, guideline, interpretation, or other requirement that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d92f961-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is prescribed by the Secretary or the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d92f962-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has legally binding effect in connection with, or affecting, the provision of financial assistance under any applicable program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d92f963-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citation of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Regulations shall contain, immediately following each substantive provision of such regulations, citations to the particular section or sections of statutory law or other legal authority on which such provision is based.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d92f964-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All regulations shall be uniformly applied and enforced throughout the 50 States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d92f965-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of exemption","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The exemption for public property, loans, grants and benefits in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553/a/2"},"text":"section 553(a)(2) of title 5","children":[],"tail":" shall apply only to regulations—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d92f966-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that govern the first grant competition under a new or substantially revised program authority as determined by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d92f967-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where the Secretary determines that the requirements of this subsection will cause extreme hardship to the intended beneficiaries of the program affected by such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d92f968-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule for promulgation of final regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the date of enactment of any Act, or any portion of any Act, affecting the administration of any applicable program, the Secretary shall submit to the Committee on Education and Labor of the House of Representatives and the Committee on Labor and Human Resources of the Senate a schedule in accordance with which the Secretary plans to promulgate final regulations that the Secretary determines are necessary to implement such Act or portion of such Act. Such schedule shall provide that all such final regulations shall be promulgated within 360 days after the date of enactment of such Act or portion of such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d92f969-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1232/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal of final regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Concurrently with the publication of any final regulations, the Secretary shall transmit a copy of such final regulations to the Speaker of the House of Representatives and the President pro tempore of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d92f96a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s437"},"text":"Pub. L. 90–247, title IV, § 437","children":[],"tail":", formerly § 421, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/230/tIV/s401/a/10"},"text":"Pub. L. 91–230, title IV, § 401(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/169"},"text":"84 Stat. 169","children":[],"tail":"; renumbered § 431, "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tIII/s301/a/1"},"text":"Pub. L. 92–318, title III, § 301(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/326"},"text":"86 Stat. 326","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/380/tV/s509/a"},"text":"Pub. L. 93–380, title V, § 509(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/566"},"text":"88 Stat. 566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/142/s7"},"text":"Pub. L. 94–142, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-29"},"text":"Nov. 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/796"},"text":"89 Stat. 796","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/482/tIV/s405"},"text":"Pub. L. 94–482, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2231"},"text":"90 Stat. 2231","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tXIII/s1302"},"text":"Pub. L. 96–374, title XIII, § 1302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1497"},"text":"94 Stat. 1497","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tV/s533/a/3"},"text":"Pub. L. 97–35, title V, § 533(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/453"},"text":"95 Stat. 453","children":[],"tail":"; renumbered § 437 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII"},"text":"Pub. L. 103–382, title II","children":[],"tail":", §§ 212(b)(1), 247, "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3913"},"text":"108 Stat. 3913","children":[],"tail":", 3923; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s7/a/1"},"text":"Pub. L. 103–437, § 7(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4587"},"text":"108 Stat. 4587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d92f96b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d92f96c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d92f96d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s437"},"text":"section 437 of Pub. L. 90–247","children":[],"tail":" was renumbered section 443, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232f"},"text":"section 1232f of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s437"},"text":"section 437 of Pub. L. 90–247","children":[],"tail":" was renumbered section 406A, and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221e–1a"},"text":"section 1221e–1a of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/s437"},"text":"section 437 of Pub. L. 90–247","children":[],"tail":" was renumbered section 447, and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1233f"},"text":"section 1233f of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d92f96e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":", which directed that section 431(b)(2)(B), (d)(2), and (g) of "},{"tag":"ref","attrib":{"href":"/us/pl/90/247"},"text":"Pub. L. 90–247","children":[],"tail":" be amended by substituting “Labor and Human Resources” for “Labor and Public Welfare”, could not be executed because this section, which was "},{"tag":"ref","attrib":{"href":"/us/pl/90/247/s431"},"text":"section 431 of Pub. L. 90–247","children":[],"tail":", was renumbered section 437 and amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s247"},"text":"Pub. L. 103–382, § 247","children":[],"tail":", amended section generally. Prior to amendment, section consisted of subsecs. (a) to (g) relating to promulgation of regulations by Secretary, and their publication, application, disapproval by Congress, and modification subsequent to disapproval."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" substituted “final regulation (except expected family contribution schedules and any amendments thereto promulgated pursuant to sections 1078(a)(2)(D) and (E) and 1089(a)(1) of this title) as required” for “final regulation as required”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":" inserted “, in whole or in part” after “disapprove such final regulation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/482/s405/a"},"text":"Pub. L. 94–482, § 405(a)","children":[],"tail":", added par. (1), designated existing provisions which constituted entire subsec. (a) as par. (2) and, as so redesignated, struck out applicability to rules, guidelines, interpretations, or orders."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/482/s405/b/1"},"text":"Pub. L. 94–482, § 405(b)(1)","children":[],"tail":", substituted “proposed regulation” for “standard, rule, regulation, or requirement of general applicability”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/482/s405/b/2"},"text":"Pub. L. 94–482, § 405(b)(2)","children":[],"tail":", substituted “regulation” for “standard, rule, regulation, or general requirement” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/482/s405/c"},"text":"Pub. L. 94–482, § 405(c)","children":[],"tail":", struck out applicability to rules, guidelines, interpretations, or orders."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/482/s405/d/1"},"text":"Pub. L. 94–482, § 405(d)(1)","children":[],"tail":", (2), struck out applicability to standards, rules, requirements, or requirements of general applicability."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/482/s405/d/3"},"text":"Pub. L. 94–482, § 405(d)(3)","children":[],"tail":", substituted “regulation” for “standard, rule, regulation, or requirement” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/482/s405/e"},"text":"Pub. L. 94–482, § 405(e)","children":[],"tail":", substituted “regulation” for “standard, rule, regulation, or requirement” wherever appearing and “final regulation” for “proposed standard, rule, regulation, or requirement of general applicability”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/482/s405/f"},"text":"Pub. L. 94–482, § 405(f)","children":[],"tail":", substituted “final regulations” for “rules, regulations, and guidelines” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/142/s7/a/1"},"text":"Pub. L. 94–142, § 7(a)(1)","children":[],"tail":", (b), inserted “final” before “standard” wherever appearing in existing provisions and inserted provisions covering the effect of the failure of Congress to adopt the concurrent resolution with respect to any final standard, rule, regulation, or requirement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/142/s7/a/2"},"text":"Pub. L. 94–142, § 7(a)(2)","children":[],"tail":", (3), substituted “objection to the final standard” for “objection to the proposed standard”, “effective date of the final standard” for “effective date of the standard”, and “In no event shall the final standard” for “In no event shall the standard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/380/s509/a/1"},"text":"Pub. L. 93–380, § 509(a)(1)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/380/s509/a/2"},"text":"Pub. L. 93–380, § 509(a)(2)","children":[],"tail":", added subsecs. (d) to (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d92f96f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id0d92f970-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Labor and Human Resources of Senate changed to Committee on Health, Education, Labor, and Pensions of Senate by Senate Resolution No. 20, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-19"},"text":"Jan. 19, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d92f971-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tV/s540/a"},"text":"Pub. L. 97–35, title V, § 540(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/458"},"text":"95 Stat. 458","children":[],"tail":", provided that the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" is effective "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d92f972-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/s1393/a"},"text":"section 1393(a) of Pub. L. 96–374","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d92f973-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/482"},"text":"Pub. L. 94–482","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", except either as specifically otherwise provided or, if not so specifically otherwise provided, effective "},{"tag":"date","attrib":{"date":"1976-07-01"},"text":"July 1, 1976","children":[],"tail":", for those amendments providing for authorization of appropriations, see "},{"tag":"ref","attrib":{"href":"/us/pl/94/482/s532"},"text":"section 532 of Pub. L. 94–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d92f974-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1975 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/142/s8"},"text":"Pub. L. 94–142, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-29"},"text":"Nov. 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/796"},"text":"89 Stat. 796","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/142/s8"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the amendments made by sections 2(a), 2(b), and 2(c) [amending sections 1411 and 1412 of this title as in effect through ","children":[{"tag":"date","attrib":{"date":"1977-09-30"},"text":"Sept. 30, 1977","children":[],"tail":", and amending provisions set out as notes under sections 1411 to 1413 of this title] shall take effect on "},{"tag":"date","attrib":{"date":"1975-07-01"},"text":"July 1, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by sections 2(d), 2(e), 3, 6, and 7 [enacting sections 1405 and 1406 of this title, amending this section and sections 1412 and 1453 of this title, enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1411"},"text":"section 1411 of this title","children":[],"tail":", and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1401"},"text":"section 1401 of this title","children":[],"tail":"] shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1975-11-29"},"text":"Nov. 29, 1975","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by sections 4 and 5(a) [enacting sections 1415 to 1420 of this title and amending sections 1401, 1411, 1412, 1413, and 1414 of this title] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":", except that the provisions of clauses (A), (C), (D), and (E) of paragraph (2) of section 612 of the Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1412"},"text":"section 1412 of this title","children":[],"tail":"], as amended by this Act, section 617(a)(1)(D) of the Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1417/a/1/D"},"text":"section 1417(a)(1)(D) of this title","children":[],"tail":"], as amended by this Act, section 617(b) of the Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1417/b"},"text":"section 1417(b) of this title","children":[],"tail":"], as amended by this Act, and section 618(a) of the Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1418/a"},"text":"section 1418(a) of this title","children":[],"tail":"], as amended by this Act, shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1975-11-29"},"text":"Nov. 29, 1975","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of section 5(b) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1411"},"text":"section 1411 of this title","children":[],"tail":" and enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1411"},"text":"section 1411 of this title","children":[],"tail":"] shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1975-11-29"},"text":"Nov. 29, 1975","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d92f975-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/380/tV/s509/b"},"text":"Pub. L. 93–380, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/568"},"text":"88 Stat. 568","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/380/tV/s509/b"},"text":"“The amendment made by paragraph (2) of subsection (a) [amending this section] shall be effective on the date of enactment of this [","children":[{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":"] and shall be effective with respect to the provisions of this Act [see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s821"},"text":"section 821 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0d92f976-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study and Report on Rules and Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/318/tV/s503"},"text":"Pub. L. 92–318, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/346"},"text":"86 Stat. 346","children":[],"tail":", provided for a study by the Commissioner of all rules, regulations, etc., in connection with the administration of any program to which the General Education Provisions Act [this chapter] applies, with a report to be submitted to Congress not later than one year after "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":". Such section further mandated the publication of all rules, regulations, etc., in the Federal Register not later than 60 days after submission of such report, followed by a public hearing on such matters within the 60 day period following such publication. Such section then required a subsequent report to the relevant Congressional Committees on such hearings, and a republication of all rules and regulations in the Federal Register, such republished rules, etc., to supercede all preceding rules and regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
