{"tag":"section","attrib":{"id":"id0d195cd7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1083a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1083a"},"text":"§ 1083a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer education information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d195cd8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1083a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each guaranty agency participating in a program under this part, working with the institutions of higher education served by such guaranty agency, shall develop and make available high-quality educational programs and materials to provide training for students and families in budgeting and financial management, including debt management and other aspects of financial literacy, such as the cost of using high interest loans to pay for postsecondary education, particularly as budgeting and financial management relates to student loan programs authorized by this subchapter. Such programs and materials shall be in formats that are simple and understandable to students and families, and shall be provided before, during, and after the students’ enrollment in an institution of higher education. The activities described in this section shall be considered default reduction activities for the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1072"},"text":"section 1072 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d195cd9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1083a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to prohibit—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d195cda-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1083a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a guaranty agency from using existing activities, programs, and materials in meeting the requirements of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d195cdb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1083a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a guaranty agency from providing programs or materials similar to the programs or materials described in subsection (a) to an institution of higher education that provides loans exclusively through part D; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d195cdc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1083a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lender or loan servicer from providing outreach or financial aid literacy information in accordance with subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d195cdd-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s433A"},"text":"Pub. L. 89–329, title IV, § 433A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIV/s435"},"text":"Pub. L. 110–315, title IV, § 435","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3252"},"text":"122 Stat. 3252","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d195cde-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d195cdf-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d195ce0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1083a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s433A"},"text":"Pub. L. 89–329, title IV, § 433A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tIV/s418"},"text":"Pub. L. 96–374, title IV, § 418","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1423"},"text":"94 Stat. 1423","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/301/s13/a"},"text":"Pub. L. 97–301, § 13(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-13"},"text":"Oct. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1404"},"text":"96 Stat. 1404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/79/s3/a"},"text":"Pub. L. 98–79, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-15"},"text":"Aug. 15, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/476"},"text":"97 Stat. 476","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXVI/s16012/c"},"text":"Pub. L. 99–272, title XVI, § 16012(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/340"},"text":"100 Stat. 340","children":[],"tail":", related to student loan information to be provided by eligible lenders, prior to the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1083"},"text":"section 1083 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
