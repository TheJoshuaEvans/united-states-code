{"tag":"section","attrib":{"id":"id0e1aee3c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6614"},"text":null,"children":[{"tag":"num","attrib":{"value":"6614"},"text":"§ 6614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e1aee3d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6614/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State educational agency receiving funds under this part shall annually submit to the Secretary a report that provides—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1aee3e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6614/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the State is using grant funds received under this part to meet the purpose of this subchapter, and how such chosen activities improved teacher, principal, or other school leader effectiveness, as determined by the State or local educational agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee3f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6614/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if funds are used under this part to improve equitable access to teachers for low-income and minority students, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/g/1/B"},"text":"section 6311(g)(1)(B) of this title","children":[],"tail":", a description of how funds have been used to improve such access;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee40-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6614/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a State that implements a teacher, principal, or other school leader evaluation and support system, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6611/c/4/B/ii"},"text":"section 6611(c)(4)(B)(ii) of this title","children":[],"tail":", using funds under this part, the evaluation results of teachers, principals, or other school leaders, except that such information shall not provide personally identifiable information on individual teachers, principals, or other school leaders; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1aee41-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6614/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where available, the annual retention rates of effective and ineffective teachers, principals, or other school leaders, using any methods or criteria the State has or develops under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/g/2/A"},"text":"section 6311(g)(2)(A) of this title","children":[],"tail":", except that nothing in this paragraph shall be construed to require any State educational agency or local educational agency to collect and report any data the State educational agency or local educational agency is not collecting or reporting as of the day before "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1aee42-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6614/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local educational agency report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each local educational agency receiving funds under this part shall submit to the State educational agency such information as the State requires, which shall include the information described in subsection (a) for the local educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1aee43-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6614/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reports and information provided under subsections (a) and (b) shall be made readily available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1aee44-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6614/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reports and information provided under subsections (a) and (b) shall not reveal personally identifiable information about any individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1aee45-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2104"},"text":"Pub. L. 89–10, title II, § 2104","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tII/s2002"},"text":"Pub. L. 114–95, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1930"},"text":"129 Stat. 1930","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e1aee46-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e1aee47-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e1aee48-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s2104"},"text":"section 2104 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3004"},"text":"section 3004 of this title","children":[],"tail":", prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e1aee49-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0e1aee4a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
