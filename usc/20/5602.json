{"tag":"section","attrib":{"id":"id0df4c8e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5602"},"text":null,"children":[{"tag":"num","attrib":{"value":"5602"},"text":"§ 5602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0df4c8e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5602/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Board” means the Board of Trustees of the Foundation established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5603/b"},"text":"section 5603(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5602/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Center” means the Udall Center for Studies in Public Policy established in 1987 at the University of Arizona, and includes the Native Nations Institute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5602/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “collaboration” means to work in partnership with other entities for the purpose of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0df4c8e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5602/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resolving disputes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df4c8ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5602/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing issues that may cause or result in disputes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0df4c8eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5602/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" streamlining and enhancing Federal, State, or tribal environmental and natural resource decision-making processes or procedures that may result in a dispute or conflict;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5602/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “eligible individual” means a citizen or national of the United States or a permanent resident alien of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5602/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “environmental dispute” means a dispute or conflict relating to the environment, public lands, or natural resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5602/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Foundation” means the Morris K. Udall and Stewart L. Udall Foundation established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5603/a"},"text":"section 5603(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5602/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “institution of higher education” has the same meaning given to such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"section 1001(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5602/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “National Center” means the John S. McCain III National Center for Environmental Conflict Resolution established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5605/a/1/B"},"text":"section 5605(a)(1)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5602/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Nation’s parks and wilderness” means units of the National Park System and components of the National Wilderness Preservation System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5602/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Native Nations Institute” means the Native Nations Institute for Leadership, Management, and Policy established at the University of Arizona in 2001;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5602/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means each of the several States, the District of Columbia, Guam, the Virgin Islands, American Samoa, the Commonwealth of the Northern Mariana Islands, the Republic of the Marshall Islands, the Federal States of Micronesia, and the Republic of Palau (until the Compact of Free Association is ratified); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0df4c8f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s5602/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Trust Fund” means the Morris K. Udall and Stewart L. Udall Trust Fund established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s5606"},"text":"section 5606 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0df4c8f5-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/259/s4"},"text":"Pub. L. 102–259, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-19"},"text":"Mar. 19, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/78"},"text":"106 Stat. 78","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/156/s2"},"text":"Pub. L. 105–156, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-02-11"},"text":"Feb. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/8"},"text":"112 Stat. 8","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl