{"tag":"section","attrib":{"id":"id0dc77771-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2414"},"text":null,"children":[{"tag":"num","attrib":{"value":"2414"},"text":"§ 2414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student assistance and other Federal programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dc77772-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attendance costs not treated as income or resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The portion of any student financial assistance received under this chapter that is made available for attendance costs described in subsection (b) shall not be considered as income or resources in determining eligibility for assistance under any other program funded in whole or in part with Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc77773-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attendance costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The attendance costs described in this subsection are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc77774-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2414/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tuition and fees normally assessed a student carrying an academic workload as determined by the institution, and including costs for rental or purchase of any equipment, materials, or supplies required of all students in that course of study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc77775-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2414/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an allowance for books, supplies, transportation, dependent care, and miscellaneous personal expenses for a student attending the institution on at least a half-time basis, as determined by the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc77776-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2414/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs of career and technical education services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under this chapter may be used to pay for the costs of career and technical education services required in an individualized education program developed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1414/d"},"text":"section 1414(d) of this title","children":[],"tail":" and services necessary to meet the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"section 794 of title 29","children":[],"tail":" with respect to ensuring equal access to career and technical education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dc77777-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tII/s224"},"text":"Pub. L. 88–210, title II, § 224","children":[],"tail":", title III, § 324, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 