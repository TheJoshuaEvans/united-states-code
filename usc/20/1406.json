{"tag":"section","attrib":{"id":"id0d9c6f5e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406"},"text":null,"children":[{"tag":"num","attrib":{"value":"1406"},"text":"§ 1406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for prescribing regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9c6f5f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the provisions of this chapter, the Secretary shall issue regulations under this chapter only to the extent that such regulations are necessary to ensure that there is compliance with the specific requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9c6f60-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protections provided to children","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not implement, or publish in final form, any regulation prescribed pursuant to this chapter that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9c6f61-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violates or contradicts any provision of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9c6f62-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedurally or substantively lessens the protections provided to children with disabilities under this chapter, as embodied in regulations in effect on ","children":[{"tag":"date","attrib":{"date":"1983-07-20"},"text":"July 20, 1983","children":[],"tail":" (particularly as such protections related to parental consent to initial evaluation or initial placement in special education, least restrictive environment, related services, timelines, attendance of evaluation personnel at individualized education program meetings, or qualifications of personnel), except to the extent that such regulation reflects the clear and unequivocal intent of Congress in legislation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9c6f63-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide a public comment period of not less than 75 days on any regulation proposed under subchapter II or subchapter III on which an opportunity for public comment is otherwise required by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9c6f64-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy letters and statements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not issue policy letters or other statements (including letters or statements regarding issues of national significance) that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9c6f65-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violate or contradict any provision of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9c6f66-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a rule that is required for compliance with, and eligibility under, this chapter without following the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9c6f67-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Explanation and assurances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any written response by the Secretary under subsection (d) regarding a policy, question, or interpretation under subchapter II shall include an explanation in the written response that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9c6f68-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such response is provided as informal guidance and is not legally binding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9c6f69-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when required, such response is issued in compliance with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9c6f6a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such response represents the interpretation by the Department of Education of the applicable statutory or regulatory requirements in the context of the specific facts presented.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9c6f6b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correspondence from Department of Education describing interpretations of this chapter","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9c6f6c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, on a quarterly basis, publish in the Federal Register, and widely disseminate to interested entities through various additional forms of communication, a list of correspondence from the Department of Education received by individuals during the previous quarter that describes the interpretations of the Department of Education of this chapter or the regulations implemented pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9c6f6d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each item of correspondence published in a list under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9c6f6e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the topic addressed by the correspondence and shall include such other summary information as the Secretary determines to be appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9c6f6f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1406/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that all such correspondence is issued, where applicable, in compliance with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9c6f70-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s607"},"text":"Pub. L. 91–230, title VI, § 607","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2659"},"text":"118 Stat. 2659","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9c6f71-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9c6f72-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d9c6f73-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1406, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s607"},"text":"Pub. L. 91–230, title VI, § 607","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/17/tI/s101"},"text":"Pub. L. 105–17, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-04"},"text":"June 4, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/47"},"text":"111 Stat. 47","children":[],"tail":", related to requirements for prescribing regulations, prior to the general amendment of subchapters I to IV of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/108/446"},"text":"Pub. L. 108–446","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 1406, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s607"},"text":"Pub. L. 91–230, title VI, § 607","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/142/s6/a"},"text":"Pub. L. 94–142, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-29"},"text":"Nov. 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/795"},"text":"89 Stat. 795","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/199"},"text":"Pub. L. 98–199","children":[],"tail":", §§ 3(b), 5, "},{"tag":"date","attrib":{"date":"1983-12-02"},"text":"Dec. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1358"},"text":"97 Stat. 1358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/457/tIV/s401"},"text":"Pub. L. 99–457, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-08"},"text":"Oct. 8, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1172"},"text":"100 Stat. 1172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/630/tI/s101/c"},"text":"Pub. L. 100–630, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3290"},"text":"102 Stat. 3290","children":[],"tail":", related to grants for removal of architectural barriers, prior to the general amendment of subchapters I to IV of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/17"},"text":"Pub. L. 105–17","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
