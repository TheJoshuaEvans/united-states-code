{"tag":"section","attrib":{"id":"id0e13c21b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398"},"text":null,"children":[{"tag":"num","attrib":{"value":"6398"},"text":"§ 6398.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of migrant education activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e13c21c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvement of coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e13c21d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the States, may make grants to, or enter into contracts with, State educational agencies, local educational agencies, institutions of higher education, and other public and private entities to improve the interstate and intrastate coordination among such agencies’ educational programs, including through the establishment or improvement of programs for credit accrual and exchange, available to migratory children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e13c21e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under this subsection may be awarded for not more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e13c21f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student records","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e13c220-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall assist States in the electronic transfer of student records and in determining the number of migratory children in each State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e13c221-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information system","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e13c222-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the States, shall ensure the linkage of migrant student record systems for the purpose of electronically exchanging, among the States, health and educational information regarding all migratory students eligible under this part. The Secretary shall ensure that such linkage occurs in a cost-effective manner, utilizing systems used by the States prior to, or developed after, ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":". Such information may include—"}],"tail":null},{"tag":"clause","attrib":{"id":"id0e13c223-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immunization records and other health information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e13c224-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elementary and secondary academic history (including partial credit), credit accrual, and results from State assessments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2"},"text":"section 6311(b)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e13c225-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other academic information essential to ensuring that migratory children achieve to the challenging State academic standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e13c226-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligibility for services under the Individuals with Disabilities Education Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e13c227-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall maintain ongoing consultation with the States, local educational agencies, and other migratory student service providers on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e13c228-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the system described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e13c229-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ongoing improvement of such system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e13c22a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After consulting with the States under subparagraph (A), the Secretary shall publish a notice in the Federal Register seeking public comment on any new proposed data elements that each State receiving funds under this part shall be required to collect for purposes of electronic transfer of migratory student information and the requirements that States shall meet for immediate electronic access to such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e13c22b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No cost for certain transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State educational agency or local educational agency receiving assistance under this part shall make student records available to another State educational agency or local educational agency that requests the records at no cost to the requesting agency, if the request is made in order to meet the needs of a migratory child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e13c22c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section in any fiscal year, the Secretary shall reserve not more than $10,000,000 of the amount appropriated to carry out this part for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e13c22d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentive grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amounts made available to carry out this section for any fiscal year, the Secretary may reserve not more than $3,000,000 to award grants of not more than $250,000 on a competitive basis to State educational agencies that propose a consortium arrangement with another State or other appropriate entity that the Secretary determines, pursuant to criteria that the Secretary shall establish, will improve the delivery of services to migratory children whose education is interrupted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e13c22e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6398/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall direct the National Center for Education Statistics to collect data on migratory children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e13c22f-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1308"},"text":"Pub. L. 89–10, title I, § 1308","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1578"},"text":"115 Stat. 1578","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1301/g"},"text":"Pub. L. 114–95, title I, § 1301(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1898"},"text":"129 Stat. 1898","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e13c230-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e13c231-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0e13c232-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in subsec. (b)(2)(A)(iv), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":", which is classified generally to chapter 33 (§ 1400 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e13c233-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6398, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1308"},"text":"Pub. L. 89–10, title I, § 1308","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tI/s101"},"text":"Pub. L. 103–382, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3590"},"text":"108 Stat. 3590","children":[],"tail":", related to coordination of migrant education activities, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e13c234-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/g/1"},"text":"Pub. L. 114–95, § 1301(g)(1)","children":[],"tail":", struck out “nonprofit” before “entities”, inserted “through” after “including”, and substituted “children” for “students”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/g/2/A"},"text":"Pub. L. 114–95, § 1301(g)(2)(A)","children":[],"tail":", struck out “developing effective methods for” before “the electronic transfer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/g/2/B/i/I"},"text":"Pub. L. 114–95, § 1301(g)(2)(B)(i)(I)","children":[],"tail":", added introductory provisions and struck out former introductory provisions which read as follows: “The Secretary, in consultation with the States, shall ensure the linkage of migrant student record systems for the purpose of electronically exchanging, among the States, health and educational information regarding all migratory students. The Secretary shall ensure such linkage occurs in a cost-effective manner, utilizing systems used by the States prior to, or developed after, "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", and shall determine the minimum data elements that each State receiving funds under this part shall collect and maintain. Such elements may include—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/g/2/B/i/II"},"text":"Pub. L. 114–95, § 1301(g)(2)(B)(i)(II)","children":[],"tail":", substituted “assessments under section 6311(b)(2)” for “assessments required under section 6311(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/g/2/B/i/III"},"text":"Pub. L. 114–95, § 1301(g)(2)(B)(i)(III)","children":[],"tail":", substituted “the challenging State academic standards” for “high standards”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/g/2/B/ii"},"text":"Pub. L. 114–95, § 1301(g)(2)(B)(ii)","children":[],"tail":"–(iv), added subpar. (B), redesignated former subpar. (B) as (C), and in subpar. (C) substituted “any new proposed data elements” for “the proposed data elements” and struck out at end “Such publication shall occur not later than 120 days after "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s1301/g/2/C"},"text":"Pub. L. 114–95, § 1301(g)(2)(C)","children":[],"tail":", struck out par. (4) which related to report to Congress not later than "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", on the Secretary’s findings and recommendations regarding the maintenance and transfer of health and educational information for migratory students by the States."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e13c235-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e13c236-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
