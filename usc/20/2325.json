{"tag":"section","attrib":{"id":"id0dc04bc0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2325"},"text":null,"children":[{"tag":"num","attrib":{"value":"2325"},"text":"§ 2325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for the outlying areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dc04bc1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2325/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outlying areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From funds reserved pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2321/a/1/A"},"text":"section 2321(a)(1)(A) of this title","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dc04bc2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2325/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a grant in the amount of $660,000 to Guam;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc04bc3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2325/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a grant in the amount of $350,000 to each of American Samoa and the Commonwealth of the Northern Mariana Islands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dc04bc4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2325/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a grant of $160,000 to the Republic of Palau, subject to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dc04bc5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2325/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Republic of Palau shall cease to be eligible to receive funding under this section upon entering into an agreement for an extension of United States educational assistance under the Compact of Free Association, unless otherwise provided in such agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dc04bc6-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/210/tI/s115"},"text":"Pub. L. 88–210, title I, § 115","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s1/b"},"text":"Pub. L. 109–270, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/706"},"text":"120 Stat. 706","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/224/tI/s114"},"text":"Pub. L. 115–224, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-31"},"text":"July 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1597"},"text":"132 Stat. 1597","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dc04bc7-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dc04bc8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attri