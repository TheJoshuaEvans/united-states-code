{"tag":"section","attrib":{"id":"id0e0ee0e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6363"},"text":null,"children":[{"tag":"num","attrib":{"value":"6363"},"text":"§ 6363.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment of appropriated funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e0ee0e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6363/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts equal to or less than trigger amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts made available for each fiscal year under subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002211"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002211"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 6302(b) of this title that are equal to or less than the amount described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2/I"},"text":"section 6311(b)(2)(I) of this title","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0ee0ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6363/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserve one-half of 1 percent for the Bureau of Indian Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee0eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6363/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserve one-half of 1 percent for the outlying areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee0ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6363/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserve not more than 20 percent to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6362"},"text":"section 6362 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee0ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6363/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" from the remainder, carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6361"},"text":"section 6361 of this title","children":[],"tail":" by allocating to each State an amount equal to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0ee0ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6363/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000,000, except for a fiscal year for which the amounts available are insufficient to allocate such amount to each State, the Secretary shall ratably reduce such amount for each State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee0ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6363/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any amounts remaining after the allocation under subparagraph (A), an amount that bears the same relationship to such total remaining amounts as the number of students aged 5 through 17 in the State (as determined by the Secretary on the basis of the most recent satisfactory data) bears to the total number of such students in all States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0ee0f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6363/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts above trigger amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any fiscal year for which the amount made available for a fiscal year under subsection ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" 6302(b) of this title exceeds the amount described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2/I"},"text":"section 6311(b)(2)(I) of this title","children":[],"tail":", the Secretary shall make such excess amount available as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0ee0f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6363/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0ee0f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6363/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall first use such funds to award grants, on a competitive basis, to State educational agencies or consortia of State educational agencies that have submitted applications described in subparagraph (B) to enable such States to carry out the activities described in subparagraphs (C), (H), (I), (J), (K), and (L) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6361/a/2"},"text":"section 6361(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee0f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6363/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State, or a consortium of States, that desires a competitive grant under subparagraph (A) shall submit an application to the Secretary at such time and in such manner as the Secretary may reasonably require. The application shall demonstrate that the requirements of this section will be met for the uses of funds described under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee0f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6363/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of competitive grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the amount of a grant under subparagraph (A), the Secretary shall ensure that a State or consortium’s grant, as the case may be, shall include an amount that bears the same relationship to the total funds available to carry out this subsection for the fiscal year as the number of students aged 5 through 17 in the State, or, in the case of a consortium, in each State that comprises the consortium, (as determined by the Secretary on the basis of the most recent satisfactory data) bears to the total number of such students in all States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee0f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6363/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts remaining after the Secretary awards funds under paragraph (1) shall be allotted to each State, or consortium of States, that did not receive a grant under such paragraph, in an amount that bears the same relationship to the remaining amounts as the number of students aged 5 through 17 in the State, or, in the case of a consortium, in the States of the consortium, (as determined by the Secretary on the basis of the most recent satisfactory data) bears to the total number of such students in all States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0ee0f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6363/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this part, the term “State” means each of the 50 States, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0ee0f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6363/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making funds available to States under this part, the Secretary shall comply with the prohibitions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7909"},"text":"section 7909 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e0ee0f8-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1203"},"text":"Pub. L. 89–10, title I, § 1203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tI/s1201"},"text":"Pub. L. 114–95, title I, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1884"},"text":"129 Stat. 1884","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e0ee0f9-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e0ee0fa-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e0ee0fb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6363, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tI/s1203"},"text":"Pub. L. 89–10, title I, § 1203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tI/s101"},"text":"Pub. L. 107–110, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1543"},"text":"115 Stat. 1543","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/154/s1/c/3"},"text":"Pub. L. 110–154, § 1(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-21"},"text":"Dec. 21, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1828"},"t