{"tag":"section","attrib":{"id":"id0d871313-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161l"},"text":"§ 1161l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student safety and campus emergency management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d871314-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d871315-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amounts appropriated under subsection (f), the Secretary is authorized to award grants, on a competitive basis, to institutions of higher education or consortia of institutions of higher education to enable institutions of higher education or consortia to pay the Federal share of the cost of carrying out the authorized activities described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871316-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with the Attorney General and the Secretary of Homeland Security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where appropriate, the Secretary shall award grants under this section in consultation with the Attorney General and the Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871317-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award each grant under this section for a period of two years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871318-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on institutions and consortia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of higher education or consortium shall be eligible for only one grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d871319-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share; non-Federal share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d87131a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the activities described in subsection (c) shall be 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d87131b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of higher education or consortium that receives a grant under this section shall provide the non-Federal share, which may be provided from State and local resources dedicated to emergency preparedness and response.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d87131c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each institution of higher education or consortium receiving a grant under this section may use the grant funds to carry out one or more of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d87131d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Developing and implementing a state-of-the-art emergency communications system for each campus of an institution of higher education or consortium, in order to contact students via cellular, text message, or other state-of-the-art communications methods when a significant emergency or dangerous situation occurs. An institution or consortium using grant funds to carry out this paragraph shall also, in coordination with the appropriate State and local emergency management authorities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d87131e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop procedures that students, employees, and others on a campus of an institution of higher education or consortium will be directed to follow in the event of a significant emergency or dangerous situation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d87131f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop procedures the institution of higher education or consortium shall follow to inform, in a reasonable and timely manner, students, employees, and others on a campus in the event of a significant emergency or dangerous situation, which procedures shall include the emergency communications system described in this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871320-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Supporting measures to improve safety at the institution of higher education or consortium, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d871321-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d871322-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security training of personnel and students at the institution of higher education or consortium;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d871323-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where appropriate, coordination of campus preparedness and response efforts with local law enforcement, local emergency management authorities, and other agencies, to improve coordinated responses in emergencies among such entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d871324-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a hotline that allows a student or staff member at an institution or consortium to report another student or staff member at the institution or consortium who the reporting student or staff member believes may be a danger to the reported student or staff member or to others; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d871325-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition and installation of access control, video surveillance, intrusion detection, and perimeter security technologies and systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d871326-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinating with appropriate local entities for the provision of mental health services for students and staff of the institution of higher education or consortium, including mental health crisis response and intervention services for students and staff affected by a campus or community emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d871327-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each institution of higher education or consortium desiring a grant under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d871328-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate technical assistance provided by State and local emergency management agencies, the Department of Homeland Security, and other agencies as appropriate, to institutions of higher education or consortia that request assistance in developing and implementing the activities assisted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d871329-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161l/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this part such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d87132a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s821"},"text":"Pub. L. 89–329, title VIII, § 821","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3408"},"text":"122 Stat. 3408","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/tVIII/s801/6"},"text":"Pub. L. 111–39, title VIII, § 801(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1956"},"text":"123 Stat. 1956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d87132b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d87132c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d87132d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s801/6/A"},"text":"Pub. L. 111–39, § 801(6)(A)","children":[],"tail":", substituted “subsection (f)” for “subsection (g)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39/s801/6/B"},"text":"Pub. L. 111–39, § 801(6)(B)","children":[],"tail":", substituted “in a reasonable” for “within a reasonable”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d87132e-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d87132f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/39"},"text":"Pub. L. 111–39","children":[],"tail":" effective as if enacted on the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/111/39/s3"},"text":"section 3 of Pub. L. 111–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
