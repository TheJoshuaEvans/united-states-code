},"text":"Pub. L. 107–279, § 401(c)(2)","children":[],"tail":", substituted “Assessment Board” for “Board” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/s401/c/2"},"text":"Pub. L. 107–279, § 401(c)(2)","children":[],"tail":", substituted “Assessment Board” for “Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/1/tIII/s307/1"},"text":"Pub. L. 106–554, § 1(a)(1) [title III, § 307(1)]","children":[],"tail":", substituted “4 years” for “3 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/1/tIII/s307/2"},"text":"Pub. L. 106–554, § 1(a)(1) [title III, § 307(2)]","children":[],"tail":", added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e6982fd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e6982fe-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id0e6982ff-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter is known as the “National Assessment of Educational Progress Authorization Act”, see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9501"},"text":"section 9501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
