{"tag":"section","attrib":{"id":"id0e6739ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621"},"text":null,"children":[{"tag":"num","attrib":{"value":"9621"},"text":"§ 9621.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Assessment Governing Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e6739cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the National Assessment Governing Board (hereafter in this subchapter referred to as the “Assessment Board”), which shall formulate policy guidelines for the National Assessment (carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9622"},"text":"section 9622 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6739d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6739d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assessment Board shall be appointed by the Secretary and be composed as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6739d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two Governors, or former Governors, who shall not be members of the same political party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two State legislators, who shall not be members of the same political party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two chief State school officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One superintendent of a local educational agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member of a State board of education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member of a local board of education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three classroom teachers representing the grade levels at which the National Assessment is conducted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One representative of business or industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two curriculum specialists.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three testing and measurement experts, who shall have training and experience in the field of testing and measurement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One nonpublic school administrator or policymaker.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two school principals, of whom one shall be an elementary school principal and one shall be a secondary school principal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two parents who are not employed by a local, State or Federal educational agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b/1/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two additional members who are representatives of the general public, and who may be parents, but who are not employed by a local, State, or Federal educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of the Institute of Education Sciences","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute of Education Sciences shall serve as an ex officio, nonvoting member of the Assessment Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Balance and diversity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Assessment Board shall ensure at all times that the membership of the Assessment Board reflects regional, racial, gender, and cultural balance and diversity and that the Assessment Board exercises its independent judgment, free from inappropriate influences and special interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6739e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6739e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Terms of service of members of the Assessment Board shall be staggered and may not exceed a period of 4 years, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Assessment Board may serve not more than two terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change of status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Assessment Board who changes status under subsection (b) during the term of the appointment of the member may continue to serve as a member until the expiration of such term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conforming provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Assessment Board previously granted 3 year terms, whose terms are in effect on ","children":[{"tag":"date","attrib":{"date":"2000-12-21"},"text":"December 21, 2000","children":[],"tail":", shall have their terms extended by 1 year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6739e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6739e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6739e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint new members to fill vacancies on the Assessment Board from among individuals who are nominated by organizations representing the type of individuals described in subsection (b)(1) with respect to which the vacancy exists.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each organization submitting nominations to the Secretary with respect to a particular vacancy shall nominate for such vacancy six individuals who are qualified by experience or training to fill the particular Assessment Board vacancy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of Assessment Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary’s appointments shall maintain the composition, diversity, and balance of the Assessment Board required under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739ec-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional nominations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may request that each organization described in paragraph (1)(A) submit additional nominations if the Secretary determines that none of the individuals nominated by such organization have appropriate knowledge or expertise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6739ed-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6739ee-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out its functions under this section the Assessment Board shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e6739ef-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select the subject areas to be assessed (consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9622/b"},"text":"section 9622(b) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739f0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop appropriate student achievement levels as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9622/e"},"text":"section 9622(e) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739f1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop assessment objectives consistent with the requirements of this section and test specifications that produce an assessment that is valid and reliable, and are based on relevant widely accepted professional standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739f2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a process for review of the assessment which includes the active participation of teachers, curriculum specialists, local school administrators, parents, and concerned members of the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design the methodology of the assessment to ensure that assessment items are valid and reliable, in consultation with appropriate technical experts in measurement and assessment, content and subject matter, sampling, and other technical experts who engage in large scale surveys;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9622"},"text":"section 9622 of this title","children":[],"tail":", measure student academic achievement in grades 4, 8, and 12 in the authorized academic subjects;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/e/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop guidelines for reporting and disseminating results;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739f6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/e/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop standards and procedures for regional and national comparisons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739f7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/e/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take appropriate actions needed to improve the form, content, use, and reporting of results of any assessment authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9622"},"text":"section 9622 of this title","children":[],"tail":" consistent with the provisions of this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9622"},"text":"section 9622 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e6739f8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/e/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan and execute the initial public release of National Assessment of Educational Progress reports.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The National Assessment of Educational Progress data shall not be released prior to the release of the reports described in subparagraph (J).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739f9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assessment Board may delegate any of the Board’s procedural and administrative functions to its staff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739fa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" All cognitive and noncognitive assessment items","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assessment Board shall have final authority on the appropriateness of all assessment items.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739fb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against bias","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assessment Board shall take steps to ensure that all items selected for use in the National Assessment are free from racial, cultural, gender, or regional bias and are secular, neutral, and non-ideological.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739fc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the duties required by paragraph (1), the Assessment Board may seek technical advice, as appropriate, from the Commissioner for Education Statistics and other experts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e6739fd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after an evaluation of the student achievement levels under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9622/e"},"text":"section 9622(e) of this title","children":[],"tail":", the Assessment Board shall make a report to the Secretary, the Committee on Education and the Workforce of the House of Representatives, and the Committee on Health, Education, Labor, and Pensions of the Senate describing the steps the Assessment Board is taking to respond to each of the recommendations contained in such evaluation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6739fe-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e6739ff-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the exercise of its responsibilities, the Assessment Board shall be independent of the Secretary and the other offices and officers of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e673a00-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e673a01-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may appoint, at the request of the Assessment Board, such staff as will enable the Assessment Board to carry out its responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e673a02-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such appointments may include, for terms not to exceed 3 years and without regard to the provisions of title 5 governing appointments in the competitive service, not more than six technical employees who may be paid without regard to the provisions of chapter 51 and subchapter III of chapter 53 of such title relating to classification and General Schedule pay rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e673a03-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner for Education Statistics and the Assessment Board shall meet periodically—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e673a04-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure coordination of their duties and activities relating to the National Assessment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e673a05-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the Commissioner for Education Statistics to report to the Assessment Board on the Department’s actions to implement the decisions of the Assessment Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e673a06-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9621/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply with respect to the Assessment Board, other than sections 1009, 1010, and 1011 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":