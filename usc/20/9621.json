09, 1010, and 1011 of title 5.” for “The Federal Advisory Committee Act (5 U.S.C. App.) shall not apply with respect to the Assessment Board, other than sections 10, 11, and 12 of such Act.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":" amended section generally, restating and expanding provisions and inserting headings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/s401/c/1"},"text":"Pub. L. 107–279, § 401(c)(1)","children":[],"tail":", substituted “referred to as the ‘Assessment Board’ ” for “referred to as the ‘Board’ ” and inserted “(carried out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9622"},"text":"section 9622 of this title","children":[],"tail":")” after “for the National Assessment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/s401/c/2"},"text":"Pub. L. 107–279, § 401(c)(2)","children":[],"tail":", substituted “Assessment Board” for “Board” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/s401/c/4"},"text":"Pub. L. 107–279, § 401(c)(4)","children":[],"tail":", substituted “Director of the Institute of Education Sciences” for “Assistant Secretary for Educational Research” in heading and “Assistant Secretary for Educational Research and Improvement” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/s401/c/2"},"text":"Pub. L. 107–279, § 401(c)(2)","children":[],"tail":", substituted “Assessment Board” for “Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b)(3) to (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/s401/c/2"},"text":"Pub. L. 107–279, § 401(c)(2)","children":[],"tail":", substituted “Assessment Board” for “Board” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/s401/c/2"},"text":"Pub. L. 107–279, § 401(c)(2)","children":[],"tail":", (5)(A)(vii), substituted “Assessment Board” for “Board” in introductory provisions and inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/s401/c/5/A/i"},"text":"Pub. L. 107–279, § 401(c)(5)(A)(i)","children":[],"tail":", substituted “section 9622(b)” for “section 9010(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/s401/c/5/A/ii"},"text":"Pub. L. 107–279, § 401(c)(5)(A)(ii)","children":[],"tail":", substituted “section 9622(e)” for “section 9010(e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/s401/c/5/A/iii"},"text":"Pub. L. 107–279, § 401(c)(5)(A)(iii)","children":[],"tail":", struck out “, including the Advisory Council established under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9006"},"text":"section 9006 of this title","children":[],"tail":"” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(F), (I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/s401/c/5/A/iv"},"text":"Pub. L. 107–279, § 401(c)(5)(A)(iv)","children":[],"tail":", substituted “section 9622” for “section 9010” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/s401/c/5/A/v"},"text":"Pub. L. 107–279, § 401(c)(5)(A)(v)","children":[],"tail":"–(vii), added subpar. (J)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/s401/c/2"},"text":"Pub. L. 107–279,