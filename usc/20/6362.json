{"tag":"section","attrib":{"id":"id0e0ee0a9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362"},"text":null,"children":[{"tag":"num","attrib":{"value":"6362"},"text":"§ 6362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State option to conduct assessment system audit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e0ee0aa-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amount reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6363/a/3"},"text":"section 6363(a)(3) of this title","children":[],"tail":" for a fiscal year, the Secretary shall make grants to States to enable the States to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0ee0ab-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a grant awarded under this section to a State for the first time—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0ee0ac-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" audit State assessment systems and ensure that local educational agencies audit local assessments under subsection (e)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee0ad-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute the State plan under subsection (e)(3)(D); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee0ae-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award subgrants under subsection (f); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee0af-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a grant awarded under this section to a State that has previously received a grant under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0ee0b0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute the State plan under subsection (e)(3)(D); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee0b1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award subgrants under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0ee0b2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State that receives a grant under this section shall receive an annual grant amount of not less than $1,500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0ee0b3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State chooses not to apply for a grant under this section, the Secretary shall reallocate such grant amount to other States in accordance with the formula described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6363/a/4/B"},"text":"section 6363(a)(4)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0ee0b4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State desiring to receive a grant under this section shall submit an application to the Secretary at such time and in such manner as the Secretary shall require. The application shall include a description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0ee0b5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a State that is receiving a grant under this section for the first time—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0ee0b6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the audit the State will carry out under subsection (e)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee0b7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the stakeholder feedback the State will seek in designing such audit;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee0b8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a State that is not receiving a grant under this section for the first time, the plan described in subsection (e)(3)(D); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee0b9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the State will award subgrants to local educational agencies under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0ee0ba-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits of State assessment systems and local assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0ee0bb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date a State receives an initial grant under this section, the State shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0ee0bc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a State assessment system audit as described in paragraph (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee0bd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that each local educational agency receiving funds under this section—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e0ee0be-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducts an audit of local assessments administered by the local educational agency as described in paragraph (4); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0ee0bf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits the results of such audit to the State; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee0c0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report the results of each State and local educational agency audit conducted under subparagraphs (A) and (B), in a format that is widely accessible and publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee0c1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resources for local educational agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1)(B), each State shall provide local educational agencies with resources, such as guidelines and protocols, to assist in conducting and reporting audit results.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee0c2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State assessment system description","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State assessment system audit conducted under paragraph (1)(A) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0ee0c3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the schedule for the administration of all State assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee0c4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each State assessment—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e0ee0c5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose for which the assessment was designed and the purpose for which the assessment is used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0ee0c6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the legal authority for the administration of the assessment;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee0c7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" feedback on such system from stakeholders, which shall include information such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e0ee0c8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how teachers, principals, other school leaders, and administrators use assessment data to improve and differentiate instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0ee0c9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the timing of release of assessment data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0ee0ca-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which assessment data is presented in an accessible and understandable format for all stakeholders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0ee0cb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opportunities, resources, and training teachers, principals, other school leaders, and administrators are given to review assessment results and make effective use of assessment data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0ee0cc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distribution of technological resources and personnel necessary to administer assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0ee0cd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of time teachers spend on assessment preparation and administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0ee0ce-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assessments that administrators, teachers, principals, other school leaders, parents, and students, if appropriate, do and do not find useful; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0ee0cf-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other information as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee0d0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a plan, based on the information gathered as a result of the activities described in subparagraphs (A), (B), and (C), to improve and streamline the State assessment system, including activities such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0e0ee0d1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminating any unnecessary assessments, which may include paying the cost associated with terminating procurement contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0ee0d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the dissemination of best practices from local educational agencies or other States that have successfully improved assessment quality and efficiency to improve teaching and learning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0e0ee0d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting local educational agencies or consortia of local educational agencies to carry out efforts to streamline local assessment systems and implement a regular process of review and evaluation of assessment use in local educational agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee0d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local assessment description","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An audit of local assessments conducted in accordance with paragraph (1)(B)(i) shall include the same information described in paragraph (3) that is required of a State audit, except that such information shall be included as applicable to the local educational agency and the local assessments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0ee0d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subgrants to local educational agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0ee0d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State shall reserve not less than 20 percent of the grant funds awarded to the State under this section to make subgrants to local educational agencies in the State or consortia of such local educational agencies, based on demonstrated need in the agency’s or consortium’s application, to enable such agencies or consortia to improve assessment quality and use, and alignment, including, if applicable, alignment to the challenging State academic standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee0d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local educational agency application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each local educational agency, or consortium of local educational agencies, seeking a subgrant under this subsection shall submit an application to the State at such time, in such manner, and containing such other information as determined necessary by the State. The application shall include a description of the agency’s or consortium’s needs relating to the improvement of assessment quality, use, and alignment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee0d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A subgrant awarded under this subsection to a local educational agency or consortium of such agencies may be used to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e0ee0d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an audit of local assessments under subsection (e)(1)(B)(i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee0da-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the plan described in subsection (e)(3)(D) as it pertains to such agency or consortium;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee0db-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve assessment delivery systems and schedules, including by increasing access to technology and assessment proctors, where appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee0dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hire instructional coaches, or promote teachers who may receive increased compensation to serve as instructional coaches, to support teachers in the development of classroom-based assessments, interpreting assessment data, and designing instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee0dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/f/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for appropriate accommodations to maximize inclusion of children with disabilities and English learners participating in assessments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e0ee0de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/f/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the capacity of teachers, principals, and other school leaders to disseminate assessment data in an accessible and understandable format for parents and families, including for children with disabilities and English learners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e0ee0df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e0ee0e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “local assessment” means an academic assessment selected and carried out by a local educational agency that is separate from an assessment required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2"},"text":"section 6311(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e0ee0e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6362/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the 50 States, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e0ee0