9","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/c/29"},"text":"Pub. L. 103–208, § 2(c)(29)","children":[],"tail":"–(32), "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2465"},"text":"107 Stat. 2465","children":[],"tail":", 2466, related to Federal supplemental loans for students, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tIV/s4047/b"},"text":"Pub. L. 103–66, title IV, § 4047(b)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/364"},"text":"107 Stat. 364","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1994-07-01"},"text":"July 1, 1994","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1078–1, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIV/s428A"},"text":"Pub. L. 89–329, title IV, § 428A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/482/tI/s127/a"},"text":"Pub. L. 94–482, title I, § 127(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2120"},"text":"90 Stat. 2120","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/43/s1/a/30"},"text":"Pub. L. 95–43, § 1(a)(30)","children":[],"tail":"–(32), "},{"tag":"date","attrib":{"date":"1977-06-15"},"text":"June 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/216"},"text":"91 Stat. 216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/374/tIV/s412/e"},"text":"Pub. L. 96–374, title IV, § 412(e)","children":[],"tail":", (f), title XIII, § 1391(a)(1), "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1416"},"text":"94 Stat. 1416","children":[],"tail":", 1417, 1503; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tV/s535/e"},"text":"Pub. L. 97–35, title V, § 535(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/455"},"text":"95 Stat. 455","children":[],"tail":", related to student loan insurance programs, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d0b0538-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s423"},"text":"Pub. L. 110–315, § 423","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s103/b/5/A"},"text":"Pub. L. 110–315, § 103(b)(5)(A)","children":[],"tail":", (B), substituted “members of the authorizing committees” for “Chairperson and the Ranking Minority Member of the Committee on Labor and Human Resources of the Senate and the Committee on Education and the Workforce of the House of Representatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s103/b/5/C"},"text":"Pub. L. 110–315, § 103(b)(5)(C)","children":[],"tail":", substituted “members of the authorizing committees” for “Chairperson and the Ranking Minority Members of the Committee on Labor and Human Resources of the Senate and the Committee on Education and the Workforce of the House of Representatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8014/f/1"},"text":"Pub. L. 109–171, § 8014(f)(1)","children":[],"tail":", struck out “unless the Secretary determines that such a waiver is consistent with the purposes of this section and is limited to activities of the guaranty agency within the State or States for which the guaranty agency serves as the designated guarantor” before “; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8014/b/3"},"text":"Pub. L. 109–171, § 8014(b)(3)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8014/f/2"},"text":"Pub. L. 109–171, § 8014(f)(2)","children":[],"tail":", (3), redesignated par. (3) as (2) and struck out heading and text of former par. (2). Text read as follows: “If the Secretary grants a waiver pursuant to paragraph (1)(B), any guaranty agency doing business within the affected State or States may request, and the Secretary shall grant, an identical waiver to such guaranty agency under the same terms and conditions (including service area limitations) as govern the original waiver.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8014/f/4"},"text":"Pub. L. 109–171, § 8014(f)(4)","children":[],"tail":", struck out par. (4), which required the Secretary to report to congressional committees regarding the impact that the voluntary flexible agreements had on program integrity, program and cost efficiencies, and the availability and delivery of student financial aid."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d0b0539-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d0b053a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171"},"text":"Pub. L. 109–171","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2006-07-01"},"text":"July 1, 2006","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/s8001/c"},"text":"section 8001(c) of Pub. L. 109–171","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d0b053b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
