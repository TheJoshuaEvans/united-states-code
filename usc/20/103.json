{"tag":"section","attrib":{"id":"id0c8ef718-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s103"},"text":null,"children":[{"tag":"num","attrib":{"value":"103"},"text":"§ 103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publications for National Library for the Blind","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Two copies of each of the publication printed by the American Printing House for the Blind shall be furnished free of charge to the National Library for the Blind located at 1729 H Street Northwest, Washington, District of Columbia.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c8ef719-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1919-11-04/ch93/s1"},"text":"Nov. 4, 1919, ch. 93, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/332"},"text":"41 Stat. 332","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
