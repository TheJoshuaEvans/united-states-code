{"tag":"section","attrib":{"id":"id0ddf4598-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3902"},"text":null,"children":[{"tag":"num","attrib":{"value":"3902"},"text":"§ 3902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0ddf4599-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “area career and technical education school” has the same meaning given that term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2302/3"},"text":"section 2302(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf459a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Director” means the Director of the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf459b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3902/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “elementary school” has the same meaning given that term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf459c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3902/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Governor” means the chief executive of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf459d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3902/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Foundation” means the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf459e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3902/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “institution of higher education” has the same meaning given that term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf459f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3902/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “local educational agency” has the same meaning given that term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf45a0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3902/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “secondary school” has the same meaning given that term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0ddf45a1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3902/9"},"text