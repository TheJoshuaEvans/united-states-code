{"tag":"section","attrib":{"id":"id0deb2c3e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4413"},"text":null,"children":[{"tag":"num","attrib":{"value":"4413"},"text":"§ 4413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0deb2c3f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall have an Executive Board composed of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0deb2c40-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4413/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairman of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c41-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4413/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vice chairman of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c42-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4413/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the secretary of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c43-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4413/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the treasurer of the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0deb2c44-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4413/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an at-large member of the Board elected by the Board at its initial meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0deb2c45-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any vacancy which occurs in the position of at-large member before the expiration of such member’s term, the Board shall elect a replacement to complete that term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0deb2c46-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4413/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Board shall hold not more than 4 regular meetings per calendar year. Special meetings may be held upon the call of the chairman or 3 members of the Executive Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0deb2c47-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4413/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the Executive Board shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0deb2c48-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s4413/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Board may hold and use all the powers of the Board, subject to the approval of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0deb2c49-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXV/s1506"},"text":"Pub. L. 99–498, title XV, § 1506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1603"},"text":"100 Stat. 1603","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
