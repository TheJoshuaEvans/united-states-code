{"tag":"section","attrib":{"id":"id0cc5e57b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1018b"},"text":"§ 1018b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative simplification of student aid delivery","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0cc5e57c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to improve the efficiency and effectiveness of the student aid delivery system, the Secretary and the Chief Operating Officer shall encourage and participate in the establishment of voluntary consensus standards and requirements for the electronic transmission of information necessary for the administration of programs under subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc5e57d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in standard setting organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc5e57e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Operating Officer shall participate in the activities of standard setting organizations in carrying out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc5e57f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Operating Officer shall encourage higher education groups seeking to develop common forms, standards, and procedures in support of the delivery of Federal student financial assistance to conduct these activities within a standard setting organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc5e580-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Operating Officer may pay necessary dues and fees associated with participating in standard setting organizations pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc5e581-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption of voluntary consensus standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except with respect to the common financial reporting form under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1090/a"},"text":"section 1090(a) of this title","children":[],"tail":", the Secretary shall consider adopting voluntary consensus standards agreed to by the organization described in subsection (b) for transactions required under subchapter IV, and common data elements for such transactions, to enable information to be exchanged electronically between systems administered by the Department and among participants in the Federal student aid delivery system."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc5e582-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of clearinghouses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall restrict the ability of participating institutions and lenders from using a clearinghouse or servicer to comply with the standards for the exchange of information established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc5e583-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data security","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any entity that maintains or transmits information under a transaction covered by this section shall maintain reasonable and appropriate administrative, technical, and physical safeguards—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc5e584-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure the integrity and confidentiality of the information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc5e585-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect against any reasonably anticipated security threats, or unauthorized uses or disclosures of the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0cc5e586-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0cc5e587-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clearinghouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “clearinghouse” means a public or private entity that processes or facilitates the processing of nonstandard data elements into data elements conforming to standards adopted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc5e588-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard setting organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “standard setting organization” means an organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0cc5e589-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is accredited by the American National Standards Institute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc5e58a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops standards for information transactions, data elements, or any other standard that is necessary to, or will facilitate, the implementation of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0cc5e58b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is open to the participation of the various entities engaged in the delivery of Federal student financial assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0cc5e58c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1018b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary consensus standard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “voluntary consensus standard” means a standard developed or used by a standard setting organization described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0cc5e58d-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s143"},"text":"Pub. L. 89–329, title I, § 143","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tI/s101/a"},"text":"Pub. L. 105–244, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1615"},"text":"112 Stat. 1615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cc5e58e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cc5e58f-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cc5e590-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 1018b to 1018f were omitted in the general amendment of this subchapter by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1018b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s143"},"text":"Pub. L. 89–329, title I, § 143","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6201"},"text":"Pub. L. 100–418, title VI, § 6201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1515"},"text":"102 Stat. 1515","children":[],"tail":", related to use of funds."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1018c, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s144"},"text":"Pub. L. 89–329, title I, § 144","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6201"},"text":"Pub. L. 100–418, title VI, § 6201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1515"},"text":"102 Stat. 1515","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/610/tII/s221/a"},"text":"Pub. L. 101–610, title II, § 221(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3180"},"text":"104 Stat. 3180","children":[],"tail":", related to applications."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1018d, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s145"},"text":"Pub. L. 89–329, title I, § 145","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6201"},"text":"Pub. L. 100–418, title VI, § 6201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1516"},"text":"102 Stat. 1516","children":[],"tail":", related to technical assistance and coordination contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1018e, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s146"},"text":"Pub. L. 89–329, title I, § 146","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6201"},"text":"Pub. L. 100–418, title VI, § 6201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1516"},"text":"102 Stat. 1516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/305/s5"},"text":"Pub. L. 101–305, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-30"},"text":"May 30, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/258"},"text":"104 Stat. 258","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/610/tII/s221/c"},"text":"Pub. L. 101–610, title II, § 221(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3180"},"text":"104 Stat. 3180","children":[],"tail":", related to authorization of appropriations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1018f, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tI/s147"},"text":"Pub. L. 89–329, title I, § 147","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tVI/s6201"},"text":"Pub. L. 100–418, title VI, § 6201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1516"},"text":"102 Stat. 1516","children":[],"tail":", defined “public community agency”, “institution of higher education” and “Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
