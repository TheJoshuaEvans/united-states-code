{"tag":"section","attrib":{"id":"id0d7649f3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1134c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1134c"},"text":"§ 1134c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship conditions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d7649f4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1134c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for receipt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual awarded a fellowship under the provisions of this subpart shall continue to receive payments provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1134b"},"text":"section 1134b of this title","children":[],"tail":" only during such periods as the Secretary finds that such individual is maintaining satisfactory proficiency in, and devoting essentially full time to, study or research in the field in which such fellowship was awarded, in an institution of higher education, and is not engaging in gainful employment other than part-time employment by such institution in teaching, research, or similar activities, approved by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d7649f5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1134c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports from recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to require reports containing such information in such form and filed at such times as the Secretary determines necessary from any person awarded a fellowship under the provisions of this subpart. The reports shall be accompanied by a certificate from an appropriate official at the institution of higher education, library, archive, or other research center approved by the Secretary, stating that such individual is making satisfactory progress in, and is devoting essentially full time to the program for which the fellowship was awarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d7649f6-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVII/s704"},"text":"Pub. L. 89–329, title VII, § 704","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVII/s701"},"text":"Pub. L. 105–244, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1789"},"text":"112 Stat. 1789","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d7649f7-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d7649f8-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d7649f9-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1134k"},"text":"section 1134k of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior sect