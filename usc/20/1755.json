fter ","children":[{"tag":"date","attrib":{"date":"1974-08-21"},"text":"Aug. 21, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/380/s2/c"},"text":"section 2(c) of Pub. L. 93–380","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221–1"},"text":"section 1221–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
