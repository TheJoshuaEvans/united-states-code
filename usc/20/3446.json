{"tag":"section","attrib":{"id":"id0dda8a11-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3446"},"text":null,"children":[{"tag":"num","attrib":{"value":"3446"},"text":"§ 3446.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers from Department of Housing and Urban Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are transferred to the Secretary all functions relating to college housing loans of the Secretary of Housing and Urban Development and of the Department of Housing and Urban Development under title IV of the Housing Act of 1950 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1749"},"text":"12 U.S.C. 1749","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0dda8a12-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIII/s305"},"text":"Pub. L. 96–88, title III, § 305","children":[],"tail":", formerly § 306, "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/681"},"text":"93 Stat. 681","children":[],"tail":"; renumbered § 305, "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tII/s271/a/2"},"text":"Pub. L. 103–382, title II, § 271(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3929"},"text":"108 Stat. 3929","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dda8a13-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dda8a14-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail"