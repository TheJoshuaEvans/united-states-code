{"tag":"section","attrib":{"id":"id0dfbce32-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6064"},"text":null,"children":[{"tag":"num","attrib":{"value":"6064"},"text":"§ 6064.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contraceptive devices","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Department of Health and Human Services and the Department of Education shall ensure that all federally funded programs which provide for the distribution of contraceptive devices to unemancipated minors develop procedures to encourage, to the extent practical, family participation in such programs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0dfbce33-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227/tX/s1018"},"text":"Pub. L. 103–227, title X, § 1018","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/268"},"text":"108 Stat. 268","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
