{"tag":"section","attrib":{"id":"id0d9c6f7e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408"},"text":null,"children":[{"tag":"num","attrib":{"value":"1408"},"text":"§ 1408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paperwork reduction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9c6f7f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9c6f80-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to provide an opportunity for States to identify ways to reduce paperwork burdens and other administrative duties that are directly associated with the requirements of this chapter, in order to increase the time and resources available for instruction and other activities aimed at improving educational and functional results for children with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9c6f81-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9c6f82-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to carry out the purpose of this section, the Secretary is authorized to grant waivers of statutory requirements of, or regulatory requirements relating to, subchapter II for a period of time not to exceed 4 years with respect to not more than 15 States based on proposals submitted by States to reduce excessive paperwork and noninstructional time burdens that do not assist in improving educational and functional results for children with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9c6f83-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not waive under this section any statutory requirements of, or regulatory requirements relating to, applicable civil rights requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9c6f84-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d9c6f85-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affect the right of a child with a disability to receive a free appropriate public education under subchapter II; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9c6f86-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit a State or local educational agency to waive procedural safeguards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1415"},"text":"section 1415 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9c6f87-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposal","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9c6f88-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State desiring to participate in the program under this section shall submit a proposal to the Secretary at such time and in such manner as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9c6f89-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The proposal shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d9c6f8a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of any statutory requirements of, or regulatory requirements relating to, subchapter II that the State desires the Secretary to waive, in whole or in part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9c6f8b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of any State requirements that the State proposes to waive or change, in whole or in part, to carry out a waiver granted to the State by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9c6f8c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall terminate a State’s waiver under this section if the Secretary determines that the State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9c6f8d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" needs assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1416/d/2/A/ii"},"text":"section 1416(d)(2)(A)(ii) of this title","children":[],"tail":" and that the waiver has contributed to or caused such need for assistance;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9c6f8e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" needs intervention under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1416/d/2/A/iii"},"text":"section 1416(d)(2)(A)(iii) of this title","children":[],"tail":" or needs substantial intervention under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1416/d/2/A/iv"},"text":"section 1416(d)(2)(A)(iv) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9c6f8f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failed to appropriately implement its waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9c6f90-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning 2 years after ","children":[{"tag":"date","attrib":{"date":"2004-12-03"},"text":"December 3, 2004","children":[],"tail":", the Secretary shall include in the annual report to Congress submitted pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3486"},"text":"section 3486 of this title","children":[],"tail":" information related to the effectiveness of waivers granted under subsection (a), including any specific recommendations for broader implementation of such waivers, in—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9c6f91-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reducing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9c6f92-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the paperwork burden on teachers, principals, administrators, and related service providers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9c6f93-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" noninstructional time spent by teachers in complying with subchapter II;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9c6f94-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing longer-term educational planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9c6f95-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving positive outcomes for children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9c6f96-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting collaboration between IEP Team members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9c6f97-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1408/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring satisfaction of family members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9c6f98-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s609"},"text":"Pub. L. 91–230, title VI, § 609","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/446/tI/s101"},"text":"Pub. L. 108–446, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2661"},"text":"118 Stat. 2661","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9c6f99-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9c6f9a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0d9c6f9b-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1408, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230/tVI/s609"},"text":"Pub. L. 91–230, title VI, § 609","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/457/tII/s202"},"text":"Pub. L. 99–457, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-08"},"text":"Oct. 8, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1158"},"text":"100 Stat. 1158","children":[],"tail":", related to eligibility for financial assistance, prior to the general amendment of subchapters I to IV of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/17"},"text":"Pub. L. 105–17","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
