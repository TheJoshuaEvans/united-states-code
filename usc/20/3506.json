{"tag":"section","attrib":{"id":"id0ddcd427-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s3506"},"text":null,"children":[{"tag":"num","attrib":{"value":"3506"},"text":"§ 3506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter or the application thereof to any person or circumstance is held invalid, neither the remainder of this chapter nor the application of such provision to other persons or circumstances shall be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0ddcd428-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s506"},"text":"Pub. L. 96–88, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/692"},"text":"93 Stat. 692","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
