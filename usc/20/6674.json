{"tag":"section","attrib":{"id":"id0e1d3909-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6674"},"text":null,"children":[{"tag":"num","attrib":{"value":"6674"},"text":"§ 6674.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and national evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e1d390a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6674/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the funds reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6671/3"},"text":"section 6671(3) of this title","children":[],"tail":" for a fiscal year, the Secretary—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d390b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6674/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish, in a manner consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9602"},"text":"section 9602 of this title","children":[],"tail":", a comprehensive center on students at risk of not attaining full literacy skills due to a disability that meets the purposes of subsection (b); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d390c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6674/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1d390d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6674/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance, which may be carried out directly or through grants or contracts, to States and local educational agencies carrying out activities under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d390e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6674/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out evaluations of activities by States and local educational agencies under this part, which shall be conducted by a third party or by the Institute of Education Sciences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e1d390f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6674/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The comprehensive center established by the Secretary under subsection (a)(1) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e1d3910-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6674/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify or develop free or low-cost evidence-based assessment tools for identifying students at risk of not attaining full literacy skills due to a disability, including dyslexia impacting reading or writing, or developmental delay impacting reading, writing, language processing, comprehension, or executive functioning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d3911-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6674/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify evidence-based literacy instruction, strategies, and accommodations, including assistive technology, designed to meet the specific needs of such students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d3912-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6674/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide families of such students with information to assist such students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d3913-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6674/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify or develop evidence-based professional development for teachers, paraprofessionals, principals, other school leaders, and specialized instructional support personnel to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e1d3914-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6674/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understand early indicators of students at risk of not attaining full literacy skills due to a disability, including dyslexia impacting reading or writing, or developmental delay impacting reading, writing, language processing, comprehension, or executive functioning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d3915-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6674/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use evidence-based screening assessments for early identification of such students beginning not later than kindergarten; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e1d3916-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6674/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement evidence-based instruction designed to meet the specific needs of such students; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e1d3917-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s6674/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate the products of the comprehensive center to regionally diverse State educational agencies, local educational agencies, regional educational agencies, and schools, including, as appropriate, through partnerships with other comprehensive centers established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9602"},"text":"section 9602 of this title","children":[],"tail":", and regional educational laboratories established under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9564"},"text":"section 9564 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e1d3918-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tII/s2244"},"text":"Pub. L. 89–10, title II, § 2244","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tII/s2002"},"text":"Pub. L. 114–95, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1951"},"text":"129 Stat. 1951","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e1d3919-3a70-11f1-a648-bee82ed8a795"},"text":"\n",