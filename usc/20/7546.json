6004/e/1"},"text":"Pub. L. 114–95, § 6004(e)(1)","children":[],"tail":", inserted “and includes the descendants of individuals so defined” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s6004/e/2"},"text":"Pub. L. 114–95, § 6004(e)(2)","children":[],"tail":", added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “The term ‘Alaska Native organization’ means a federally recognized tribe, consortium of tribes, regional nonprofit Native association, and another organization that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) has or commits to acquire expertise in the education of Alaska Natives; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) has Alaska Natives in substantive and policymaking positions within the organization.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e3ea2f5-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e3ea2f6-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc