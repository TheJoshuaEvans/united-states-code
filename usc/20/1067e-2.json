{"tag":"section","attrib":{"id":"id0cddb316-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1067e–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1067e–2"},"text":"§ 1067e–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and accountability plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop an evaluation and accountability plan for projects funded under this subpart. Such plan shall include, if the Secretary determines that it is practical, an objective measure of the impact of such projects, such as a measure of whether underrepresented minority student enrollment in courses related to science, technology, engineering, and mathematics increases at the secondary and postsecondary levels.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0cddb317-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tIII/s357"},"text":"Pub. L. 89–329, title III, § 357","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIII/s315/a/2"},"text":"Pub. L. 110–315, title III, § 315(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3184"},"text":"122 Stat. 3184","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0cddb318-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0cddb319-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0cddb31a-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/s357"},"text":"section 357 of Pub. L. 89–329","children":[],"tail":" was renumbered section 396 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1068e"},"text":"section 1068e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
