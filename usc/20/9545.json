{"tag":"section","attrib":{"id":"id0e6258e8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9545"},"text":null,"children":[{"tag":"num","attrib":{"value":"9545"},"text":"§ 9545.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0e6258e9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9545/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for issuance of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Statistics Commissioner,","children":[{"tag":"ref","attrib":{"idref":"fn002246"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002246"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" shall establish procedures, in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s9576"},"text":"section 9576 of this title","children":[],"tail":", to ensure that the reports issued under this section are relevant, of high quality, useful to customers, subject to rigorous peer review, produced in a timely fashion, and free from any partisan political influence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6258ea-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9545/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on condition and progress of education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2003-06-01"},"text":"June 1, 2003","children":[],"tail":", and each June 1 thereafter, the Statistics Commissioner,"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall submit to the President and the appropriate congressional committees a statistical report on the condition and progress of education in the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0e6258eb-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s9545/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statistical reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Statistics Commissioner shall issue regular and, as necessary, special statistical reports on education topics, particularly in the core academic areas of reading, mathematics, and science, consistent with the priorities and the mission of the Statistics Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e6258ec-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/279/tI/s155"},"text":"Pub. L. 107–279, title I, § 155","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-05"},"text":"Nov. 5, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1960"},"text":"116 Stat. 1960","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
