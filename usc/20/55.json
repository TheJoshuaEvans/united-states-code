{"tag":"section","attrib":{"id":"id0c772923-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s55"},"text":null,"children":[{"tag":"num","attrib":{"value":"55"},"text":"§ 55.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of other sums","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury is authorized and directed to receive into the Treasury, on the same terms as the original bequest of James Smithson, such sums as the Regents may, from time to time, see fit to deposit, not exceeding, with the original bequest, the sum of $1,000,000. This shall not operate as a limitation on the power of the Smithsonian Institution to receive money or other property by gift, bequest, or devise, and to hold and dispose of the same in promotion of the purposes thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0c772924-3a70-11f1-a648-bee82ed8a795"},"text":"(R.S. § 5591; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1894-03-12/ch36"},"text":"Mar. 12, 1894, ch. 36","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/41"},"text":"28 Stat. 41","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0c772925-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0c772926-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0c772927-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5591 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1867-02-05/ch34/s1"},"text":"act Feb. 5, 1867, ch. 34, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/14/391"},"text":"14 Stat. 391","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0c772928-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1894—Act ","children":[{"tag":"date","attrib":{"date":"1894-03-12"},"text":"Mar. 12, 1894","children":[],"tail":", made limitation on deposits into the Treasury inapplicable to receipt of gifts, bequests and devises and dispositions of money or other property."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
