{"tag":"section","attrib":{"id":"id0d97b522-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1234d"},"text":"§ 1234d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d97b523-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary authority over further payments under applicable program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234c"},"text":"section 1234c of this title","children":[],"tail":", the Secretary may withhold from a recipient, in whole or in part, further payments (including payments for administrative costs) under an applicable program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b524-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before withholding payments, the Secretary shall notify the recipient, in writing, of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d97b525-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intent to withhold payments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b526-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the factual and legal basis for the Secretary’s belief that the recipient has failed to comply substantially with a requirement of law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b527-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an opportunity for a hearing to be held on a date at least 30 days after the notification has been sent to the recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b528-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The hearing shall be held before the Office and shall be conducted in accordance with the rules prescribed pursuant to subsections (f) and (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234"},"text":"section 1234 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b529-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of payments, authorities, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pending the outcome of any hearing under this section, the Secretary may suspend payments to a recipient, suspend the authority of the recipient to obligate Federal funds, or both, after such recipient has been given reasonable notice and an opportunity to show cause why future payments or authority to obligate Federal funds should not be suspended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b52a-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings of fact","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon review of a decision of the Office by the Secretary, the findings of fact by the Office, if supported by substantial evidence, shall be conclusive. However, the Secretary, for good cause shown, may remand the case to the Office to take further evidence, and the Office may thereupon make new or modified findings of fact and may modify its previous action. Such new or modified findings of fact shall likewise be conclusive if supported by substantial evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d97b52b-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final agency action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The decision of the Office in any hearing under this section shall become final agency action 60 days after the recipient receives written notice of the decision unless the Secretary either—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d97b52c-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234d/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modifies or sets aside the decision, in whole or in part, in which case the decision of the Secretary shall become final agency action when the recipient receives written notice of the Secretary’s action; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d97b52d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1234d/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remands the decision of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d97b52e-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247/tIV/s455"},"text":"Pub. L. 90–247, title IV, § 455","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXII/s1232"},"text":"Pub. L. 95–561, title XII, § 1232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2350"},"text":"92 Stat. 2350","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/tIII/s3501/a"},"text":"Pub. L. 100–297, title III, § 3501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/354"},"text":"102 Stat. 354","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d97b52f-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d97b530-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d97b531-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":" amended section generally, substituting provisions relating to withholding for provisions relating to judicial review. See "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234g"},"text":"section 1234g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d97b532-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d97b533-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/297"},"text":"Pub. L. 100–297","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1988-04-28"},"text":"Apr. 28, 1988","children":[],"tail":", but not applicable to recipients receiving written notice to return funds prior to that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/297/s3501/b"},"text":"section 3501(b) of Pub. L. 100–297","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1234"},"text":"section 1234 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
