{"tag":"section","attrib":{"id":"id0dc9c109-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s2567"},"text":null,"children":[{"tag":"num","attrib":{"value":"2567"},"text":"§ 2567.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Everett McKinley Dirksen Congressional Leadership Research Center; grants for development","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In recognition of the public service of Senator Everett McKinley Dirksen, the Secretary is authorized to make grants in accordance with the provisions of sections 2566 to 2569 of this title to assist in the development of the Everett McKinley Dirksen Congressional Leadership Research Center, located in Pekin, Illinois.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0dc9c10a-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/270/s2/b"},"text":"Pub. L. 95–270, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-04-27"},"text":"Apr. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/220"},"text":"92 Stat. 220","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIII/s301/a/1"},"text":"Pub. L. 96–88, title III, § 301(a)(1)","children":[],"tail":", title V, § 507, "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/677"},"text":"93 Stat. 677","children":[],"tail":", 692.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dc9c10b-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dc9c10c-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0dc9c10d-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/270/s4/d"},"text":"section 4(d) of Pub. L. 95–270","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s2566"},"text":"section 2566 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id0dc9c10e-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary”, meaning the Secretary of Education, substituted in text for “Commissioner” pursuant to sections 301(a)(1) and 507 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88"},"text":"Pub. L. 96–88","children":[],"tail":", which are classified to sections 3441(a)(1) and 3507 of this title and which transferred functions of Commissioner of Education to Secretary of Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
