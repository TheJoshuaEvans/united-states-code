{"tag":"section","attrib":{"id":"id0d5750dc-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1092d"},"text":"§ 1092d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarship fraud assessment and awareness activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d5750dd-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on scholarship fraud","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d5750de-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General and the Secretary of Education, in conjunction with the Federal Trade Commission, shall jointly submit to Congress each year a report on fraud in the offering of financial assistance for purposes of financing an education at an institution of higher education. Each report shall contain an assessment of the nature and quantity of incidents of such fraud during the one-year period ending on the date of such report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d5750df-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The first report under paragraph (1) shall be submitted not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2000-11-01"},"text":"November 1, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d5750e0-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National awareness activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Education shall, in conjunction with the Federal Trade Commission, maintain a scholarship fraud awareness site on the Internet web site of the Department of Education. The scholarship fraud awareness site may include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d5750e1-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriate materials from the Project Scholarscam awareness campaign of the Commission, including examples of common fraudulent schemes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c0e2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of companies and individuals who have been convicted of scholarship fraud in Federal or State court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c0e3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Internet-based message board to provide a forum for public complaints and experiences with scholarship fraud.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c0e4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An electronic comment form for individuals who have experienced scholarship fraud or have questions about scholarship fraud, with appropriate mechanisms for the transfer of comments received through such forms to the Department and the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c0e5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Internet links to other sources of information on scholarship fraud, including Internet web sites of appropriate nongovernmental organizations, colleges and universities, and government agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c0e6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092d/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Internet link to the Better Business Bureau in order to assist individuals in assessing the business practices of other persons and entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d59c0e7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1092d/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information on means of communicating with the Federal Student Aid Information Center, including telephone and Internet contact information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d59c0e8-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/420/s5"},"text":"Pub. L. 106–420, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1868"},"text":"114 Stat. 1868","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d59c0e9-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d59c0ea-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d59c0eb-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the College Scholarship Fraud Prevention Act of 2000, and not as part of title IV of the Higher Education Act of 1965 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d59c0ec-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0d59c0ed-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/420/s2"},"text":"Pub. L. 106–420, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1867"},"text":"114 Stat. 1867","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/420/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A substantial amount of fraud occurs in the offering of college education financial assistance services to consumers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such fraud includes the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Misrepresentations regarding the provision of sources from which consumers may obtain financial assistance (including scholarships, grants, loans, tuition, awards, and other assistance) for purposes of financing a college education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Misrepresentations regarding the provision of portfolios of such assistance tailored to the needs of specific consumers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Misrepresentations regarding the pre-selection of students as eligible to receive such assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Misrepresentations that such assistance will be provided to consumers who purchase specified services from specified entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Misrepresentations regarding the business relationships between particular entities and entities that award or may award such assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Misrepresentations regarding refunds of processing fees if consumers are not provided specified amounts of such assistance, and other misrepresentations regarding refunds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In 1996, the Federal Trade Commission launched ‘Project Scholarscam’, a joint law enforcement and consumer education campaign directed at fraudulent purveyors of so-called ‘scholarship services’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Despite the efforts of the Federal Trade Commission, colleges and universities, and nongovernmental organizations, the continued lack of awareness about scholarship fraud permits a significant amount of fraudulent activity to occur.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
