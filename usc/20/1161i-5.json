{"tag":"section","attrib":{"id":"id0d84a27d-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161i–5"},"text":"§ 1161i–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State application and report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d84a27e-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State desiring a grant under this part shall submit an application to the Secretary at such time, in such manner, and accompanied by such information as the Secretary may reasonably require. Each such application shall include a description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a27f-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the membership of the State Task Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a280-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities for which the grant assistance will be used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a281-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal, State, local, and private resources that will be available to support the activities of the State Task Force described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1161i–4"},"text":"section 1161i–4 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a282-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–5/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability within the State of training, early childhood educator preparation, professional development, compensation initiatives, and career systems, related to early childhood education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a283-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–5/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resources available within the State for such training, educator preparation, professional development, compensation initiatives, and career systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d84a284-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than two years after receiving a grant under this part, a State shall submit a report to the Secretary that shall describe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d84a285-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal, State, local, and private resources that will be used in combination with a grant under this section to develop or expand the State’s early childhood education professional development and career activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a286-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ways in which the State Advisory Council (or similar State entity) will coordinate the various State and local activities that support the early childhood education professional development and career system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d84a287-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s1161i–5/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ways in which the State Task Force will use funds provided under this part and carry out the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1161i–4"},"text":"section 1161i–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d84a288-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329/tVIII/s816"},"text":"Pub. L. 89–329, title VIII, § 816","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tVIII/s801"},"text":"Pub. L. 110–315, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3401"},"text":"122 Stat. 3401","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
