{"tag":"section","attrib":{"id":"id0e2b90d2-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7231e"},"text":null,"children":[{"tag":"num","attrib":{"value":"7231e"},"text":"§ 7231e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this part, the Secretary shall give priority to applicants that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0e2e00d3-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7231e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the greatest need for assistance, based on the expense or difficulty of effectively carrying out approved desegregation plans and the magnet school program for which the grant is sought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e00d4-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7231e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" propose to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0e2e00d5-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7231e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out a new, evidence-based magnet school program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e00d6-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7231e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly revise an existing magnet school program, using evidence-based methods and practices, as available; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0e2e00d7-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7231e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" replicate an existing magnet school program that has a demonstrated record of success in increasing student academic achievement and reducing isolation of minority groups;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e00d8-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7231e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" propose to select students to attend magnet school programs by methods such as lottery, rather than through academic examination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0e2e00d9-3a70-11f1-a648-bee82ed8a795","identifier":"/us/usc/t20/s7231e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" propose to increase racial integration by taking into account socioeconomic diversity in designing and implementing magnet school programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0e2e00da-3a70-11f1-a648-bee82ed8a795"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/tIV/s4406"},"text":"Pub. L. 89–10, title IV, § 4406","children":[],"tail":", formerly title V, § 5306, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tV/s501"},"text":"Pub. L. 107–110, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1809"},"text":"115 Stat. 1809","children":[],"tail":"; renumbered title IV, § 4406, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIV"},"text":"Pub. L. 114–95, title IV","children":[],"tail":", §§ 4001(b)(3)(A), (B), (D)(i), 4401(3), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1967"},"text":"129 Stat. 1967","children":[],"tail":", 2014.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0e2e00db-3a70-11f1-a648-bee82ed8a795"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0e2e00dc-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0e2e00dd-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10/s4406"},"text":"section 4406 of Pub. L. 89–10","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3126"},"text":"section 3126 of this title","children":[],"tail":", prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0e2e00de-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Pars. (2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s4401/3"},"text":"Pub. L. 114–95, § 4401(3)","children":[],"tail":", added pars. (2) to (4) and struck out former pars. (2) and (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) propose to carry out new magnet school programs, or significantly revise existing magnet school programs; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) propose to select students to attend magnet school programs by methods such as lottery, rather than through academic examination.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0e2e00df-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0e2e00e0-3a70-11f1-a648-bee82ed8a795"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
